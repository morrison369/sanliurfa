# EditorConfig for Şanlıurfa.com
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 100

[*.{js,ts,tsx,astro}]
indent_size = 2
quote_type = single

[*.{css,scss}]
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2

[*.{md,mdx}]
trim_trailing_whitespace = false
max_line_length = off

[Makefile]
indent_style = tab

[*.sql]
indent_size = 2

[Dockerfile]
indent_size = 2
