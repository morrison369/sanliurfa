NODE_ENV=development
PORT=4321
APP_PORT=4321

# === ZORUNLU ===
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
SESSION_SECRET=change-me-to-a-random-session-secret-at-least-32-chars
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12
PREVIEW_PORT=3000
SITE_URL=https://sanliurfa.com
PUBLIC_APP_URL=https://sanliurfa.com
CORS_ORIGINS=https://sanliurfa.com

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/sanliurfa
DB_PORT=5432
REDIS_PASSWORD=change-me-local-redis-password
REDIS_URL=redis://:change-me-local-redis-password@127.0.0.1:6381
REDIS_PORT=6381
REDIS_KEY_PREFIX=sanliurfa:

# Image providers
# Optional fallback — admin can set these via /admin/integrations (DB takes precedence).
# Unsplash: https://unsplash.com/oauth/applications
# Pexels: https://www.pexels.com/api/new/ (free)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key
UNSPLASH_SECRET_KEY=your_unsplash_secret_key
PEXELS_API_KEY=your_pexels_api_key

# OAuth providers
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret

# Transport provider URLs (optional health probes)
BUS_PROVIDER_URL=
FLIGHT_PROVIDER_URL=

# Social matching (Faz 1: tumu acik)
PHASE1_FREE_MODE=true
SOCIAL_OPEN_ACCESS=true
SOCIAL_TINDER_ENABLED=true
SOCIAL_AUTO_CONVERSATION=true
SOCIAL_SWIPE_DAILY_LIMIT=100
PLACE_PENDING_SLA_HOURS=48
PLACE_SLA_ALERT_COOLDOWN_HOURS=24
SOCIAL_EVENTS_RETENTION_DAYS=90
SOCIAL_EVENTS_ARCHIVE_DAYS=90
SOCIAL_ARCHIVE_CREATE_AHEAD_MONTHS=3
SOCIAL_ARCHIVE_KEEP_MONTHS=24
PLACE_LIFECYCLE_RETENTION_DAYS=365
SOCIAL_LIFECYCLE_REPORT_HOURS=24
SOCIAL_DEFAULT_TENANT_ID=default
ADMIN_EMAIL=admin@sanliurfa.com
EXPORT_TOKEN_SECRET=change_this_export_secret

# Optional image pipeline tuning
IMAGE_FETCH_LIMIT=4
IMAGE_MAIN_WIDTH=1200
IMAGE_THUMB_WIDTH=400
IMAGE_JPEG_QUALITY=85
SITE_MEDIA_KEY_PREFIX=content
E2E_SEED=20260418

# === E-POSTA (SMTP) ===
# Optional fallback — admin can set host/port/user/pass via /admin/integrations (DB takes precedence).
# SMTP is Tier 2 in the email pipeline; Tier 1 is Resend (also admin-managed).
# When neither is configured, sendEmail() logs to dev console (Tier 3).
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@sanliurfa.com
SMTP_FROM_NAME=Şanlıurfa.com
EMAIL_FROM=noreply@sanliurfa.com
EMAIL_MOCK=true

# === WEB PUSH BİLDİRİMLERİ ===
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@sanliurfa.com
# PUBLIC_ prefix is required so the browser can read it (subscription happens client-side).
# Must be the SAME value as VAPID_PUBLIC_KEY above.
PUBLIC_VAPID_PUBLIC_KEY=

# === STRIPE ÖDEMELERİ ===
# Optional fallback — admin can set these via /admin/integrations (DB takes precedence).
# Get keys from https://dashboard.stripe.com/apikeys
# Webhook secret from https://dashboard.stripe.com/webhooks (point endpoint to /api/billing/webhook)
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# === METRİKLER & INTERNAL CRON ===
# Cron job ve internal service-to-service çağrıları için Bearer token.
# /api/metrics ve /api/emails/process endpoint'lerinde kullanılır.
# Boş bırakılırsa endpoint'ler 401 döner (security-by-default).
INTERNAL_API_TOKEN=change_this_strong_random_token

# Legacy fallback — eski cron'lar için, yeni setup'larda kullanmayın.
METRICS_API_TOKEN=

# === ANALİTİK ===
# Optional fallback — admin can set this via /admin/integrations (DB takes precedence).
# Get from GA4 → Admin → Data Streams → Web stream details
GA_TRACKING_ID=
LOG_LEVEL=info

# === YEDEKLEME ===
BACKUP_DIR=backups
BACKUP_LOCAL_PATH=backups
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTION_KEY=

# === MEDYA YÜKLEME ===
UPLOAD_DIR=public/uploads/photos
UPLOAD_MAX_SIZE=10485760
