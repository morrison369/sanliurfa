# ====== CRITICAL VARIABLES (Required) ======
NODE_ENV=production
DATABASE_URL=postgresql://user:password@localhost:5432/sanliurfa
JWT_SECRET=your-secret-key-min-32-characters-long!
REDIS_URL=redis://localhost:6379
REDIS_DB=15

# ====== APP CONFIG ======
PORT=4321
CORS_ORIGINS=https://sanliurfa.com
SITE_URL=https://sanliurfa.com
REDIS_KEY_PREFIX=sanliurfa:
REDIS_ENABLED=true
REDIS_RETRY_INTERVAL_MS=30000
REDIS_CONNECT_TIMEOUT_MS=1500

# ====== DATABASE ======
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sanliurfa
DB_USER=postgres
DB_PASSWORD=postgres

# ====== STRIPE (Payment) ======
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=STRIPE_WEBHOOK_SECRET_PLACEHOLDER...

# ====== EMAIL (Resend) ======
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@sanliurfa.com

# ====== PUSH NOTIFICATIONS ======
VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...

# ====== SENTRY (Error Logging) ======
SENTRY_DSN=https://...@sentry.io/...

# ====== THIRD-PARTY INTEGRATIONS ======
SUPABASE_URL=https://...supabase.co
SUPABASE_ANON_KEY=...

# ====== IMAGE PROVIDERS (Pexels / Unsplash) ======
# Real values live in ignored .env.local locally and hosting secret/env settings in production.
# Never commit provider key values to tracked docs or source files.
PEXELS_API_KEY=your_pexels_api_key
UNSPLASH_APPLICATION_ID=your_unsplash_application_id
UNSPLASH_ACCESS_KEY=your_unsplash_access_key
UNSPLASH_SECRET_KEY=your_unsplash_secret_key

# ====== MONITORING & ANALYTICS ======
GOOGLE_ANALYTICS_ID=G-...

# ====== FEATURE FLAGS ======
FEATURE_FLAGS_ENABLED=true

# ====== STAGING ENVIRONMENT ======
STAGING_URL=https://staging.sanliurfa.com
STAGING_DATABASE_URL=postgresql://user:password@staging-db:5432/sanliurfa
STAGING_REDIS_URL=redis://staging-redis:6379

# ====== LOGGING ======
LOG_LEVEL=info

# ====== CACHE ======
CACHE_TTL=600

# ====== LOCAL MEDIA STORAGE ======
STORAGE_TYPE=local
PHOTO_UPLOAD_DIR=public/uploads/photos
UPLOAD_PUBLIC_PATH=/uploads/photos

# ====== RATE LIMITING ======
RATE_LIMIT_WINDOW=900
RATE_LIMIT_MAX=100

# ====== SESSION ======
SESSION_TTL=86400
SESSION_SECRET=session-secret-key-min-32-characters!

# ====== AWS (Optional - for S3 uploads) ======
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=eu-central-1
S3_BUCKET=sanliurfa-uploads
