NODE_ENV=development
PORT=4321
APP_PORT=4321
PREVIEW_PORT=3000
SITE_URL=https://sanliurfa.com
PUBLIC_APP_URL=https://sanliurfa.com
CORS_ORIGINS=https://sanliurfa.com
ALLOWED_ORIGINS=https://sanliurfa.com

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/sanliurfa
DB_PORT=5432
REDIS_PASSWORD=change-me-local-redis-password
REDIS_URL=redis://:change-me-local-redis-password@127.0.0.1:6381
REDIS_PORT=6381
REDIS_KEY_PREFIX=sanliurfa:

# Image providers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key
UNSPLASH_SECRET_KEY=your_unsplash_secret_key
PEXELS_API_KEY=your_pexels_api_key

# OAuth providers
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret

# Transport provider URLs (optional health probes)
BUS_PROVIDER_URL=
FLIGHT_PROVIDER_URL=

# Social matching (Faz 1: tumu acik)
PHASE1_FREE_MODE=true
SOCIAL_OPEN_ACCESS=true
SOCIAL_TINDER_ENABLED=true
SOCIAL_AUTO_CONVERSATION=true
SOCIAL_SWIPE_DAILY_LIMIT=100
PLACE_PENDING_SLA_HOURS=48
PLACE_SLA_ALERT_COOLDOWN_HOURS=24
SOCIAL_EVENTS_RETENTION_DAYS=90
SOCIAL_EVENTS_ARCHIVE_DAYS=90
SOCIAL_ARCHIVE_CREATE_AHEAD_MONTHS=3
SOCIAL_ARCHIVE_KEEP_MONTHS=24
PLACE_LIFECYCLE_RETENTION_DAYS=365
SOCIAL_LIFECYCLE_REPORT_HOURS=24
SOCIAL_DEFAULT_TENANT_ID=default
ADMIN_EMAIL=admin@sanliurfa.com
EXPORT_TOKEN_SECRET=change_this_export_secret

# Optional image pipeline tuning
IMAGE_FETCH_LIMIT=4
IMAGE_MAIN_WIDTH=1200
IMAGE_THUMB_WIDTH=400
IMAGE_JPEG_QUALITY=85
SITE_MEDIA_KEY_PREFIX=content
E2E_SEED=20260418
