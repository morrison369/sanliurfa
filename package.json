{
  "name": "sanliurfa",
  "version": "1.0.0",
  "description": "Şanlıurfa Travel Guide Platform",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint src --ext .ts,.tsx,.astro",
    "lint:fix": "eslint src --ext .ts,.tsx,.astro --fix",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "load:test": "k6 run load-tests/load-test.js",
    "db:migrate": "npx tsx scripts/migrate.ts",
    "db:migrate:status": "npx tsx scripts/migrate.ts status",
    "db:migrate:down": "npx tsx scripts/migrate.ts down",
    "db:seed": "npx tsx scripts/seed.ts",
    "db:backup": "bash scripts/backup.sh",
    "docs:dev": "cd docs && npm run dev",
    "docs:build": "cd docs && npm run build"
  },
  "dependencies": {
    "@astrojs/node": "^8.3.0",
    "@astrojs/react": "^3.6.0",
    "@astrojs/sitemap": "^3.1.6",
    "@astrojs/tailwind": "^5.1.0",
    "astro": "^6.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "pg": "^8.11.0",
    "redis": "^4.6.0",
    "zod": "^3.22.0",
    "date-fns": "^3.0.0",
    "lucide-react": "^0.400.0",
    "bcryptjs": "^2.4.3",
    "nodemailer": "^6.9.0",
    "sharp": "^0.34.0",
    "stripe": "^22.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/nodemailer": "^6.4.14",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-astro": "^0.31.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
