#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "Running pre-commit checks..."

# Lint only changed files (full lint runs in CI)
npm run lint:changed || exit 1

# Run tests related to changed files
npm run test:changed || exit 1

# Check for secrets / insecure defaults in code
npm run security:check || exit 1

echo "All checks passed!"
