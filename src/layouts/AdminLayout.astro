---
import Layout from './Layout.astro';

interface Props {
  title: string;
  subtitle?: string;
  label?: string;
  seo?: { title?: string; description?: string; noIndex?: boolean };
}

const { title, subtitle, label = 'YÖNETİM PANELİ', seo } = Astro.props;

const user = Astro.locals.user;
if (!user || !Astro.locals.isAdmin) {
  return Astro.redirect(`/giris?redirect=${Astro.url.pathname}`);
}

const resolvedSeo = {
  title: seo?.title ?? `${title} - Yönetim Paneli`,
  description: seo?.description,
  noIndex: seo?.noIndex ?? true,
};
---

<Layout seo={resolvedSeo}>
  <div class="min-h-screen bg-[#FDFAF3]">
    <div class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)] text-white py-10">
      <div class="container mx-auto px-4">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
          <div>
            <p class="text-sm font-semibold uppercase tracking-widest text-[#9A8470] mb-2">{label}</p>
            <h1 class="text-3xl font-bold text-[#F5EDD6]">{title}</h1>
            {subtitle && <p class="text-[#9A8470] mt-1">{subtitle}</p>}
          </div>
          <slot name="hero-action" />
        </div>
      </div>
    </div>

    <slot />
  </div>
</Layout>
