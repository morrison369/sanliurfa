---
import Layout from './Layout.astro';

interface Props {
 title: string;
 subtitle?: string;
 label?: string;
 seo?: { title?: string; description?: string; noIndex?: boolean };
}

const { title, subtitle, label = 'YÖNETİM PANELİ', seo } = Astro.props;

const user = Astro.locals.user;
if (!user || !Astro.locals.isAdmin) {
 return Astro.redirect(`/giris?redirect=${Astro.url.pathname}`);
}

const resolvedSeo: { title: string; description?: string; noIndex: boolean } = {
 title: seo?.title ?? `${title} - Yönetim Paneli`,
 noIndex: seo?.noIndex ?? true,
};
if (seo?.description) {
 resolvedSeo.description = seo.description;
}
---

<Layout seo={resolvedSeo}>
 <div class="admin-page min-h-screen" style="background:#FBF6EC">
  <div style="background:linear-gradient(135deg,#FBF6EC 0%,#F4ECD8 50%,#FBF6EC 100%);border-bottom:1px solid rgba(192,87,31,0.15);padding:2.5rem 0;position:relative;overflow:hidden">
   <div aria-hidden="true" style="position:absolute;inset:0;background:radial-gradient(circle at 15% 0%,rgba(212,151,24,0.10),transparent 45%),radial-gradient(circle at 85% 100%,rgba(44,122,82,0.08),transparent 45%);pointer-events:none"></div>
   <div class="sf-container" style="position:relative">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
     <div>
      <p style="font-size:0.7rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#C0571F;margin:0 0 0.45rem;display:inline-flex;align-items:center;gap:0.4rem;padding:0.35rem 0.85rem;background:rgba(192,87,31,0.10);border:1px solid rgba(192,87,31,0.22);border-radius:999px">
       <span style="width:0.4rem;height:0.4rem;background:#D49718;border-radius:50%"></span>
       {label}
      </p>
      <h1 style="font-family:'Cormorant Garamond',serif;font-size:clamp(1.75rem,3.5vw,2.6rem);font-weight:700;line-height:1.1;margin:0.5rem 0 0.35rem;background:linear-gradient(135deg,#C0571F 0%,#D49718 60%,#C0571F 100%);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;color:#C0571F">
       {title}
      </h1>
      {subtitle && <p style="color:#5A4030;font-size:0.95rem;margin:0;line-height:1.5">{subtitle}</p>}
     </div>
     <slot name="hero-action" />
    </div>
   </div>
  </div>

  <slot />
 </div>
</Layout>

<style is:global>
 /* Admin form controls — light Şanlıurfa palette */
 .admin-page input:not([type='checkbox']):not([type='radio']):not([type='range']):not([type='file']),
 .admin-page select,
 .admin-page textarea {
  background-color: #FFFFFF;
  color: #1F1410;
  border: 1px solid rgba(192, 87, 31, 0.18);
  border-radius: 6px;
 }
 .admin-page input:focus,
 .admin-page select:focus,
 .admin-page textarea:focus {
  border-color: #C0571F;
  outline: 2px solid rgba(192, 87, 31, 0.18);
  outline-offset: 1px;
 }
 .admin-page input::placeholder,
 .admin-page textarea::placeholder {
  color: #9A7A5C;
 }
 .admin-page option {
  background-color: #FFFFFF;
  color: #1F1410;
 }
 .admin-page label {
  color: #1F1410;
 }
 /* Common dark utility overrides — push admin content cards to light */
 .admin-page .bg-\[var\(--bg-card\)\],
 .admin-page .bg-\[\#0D0A08\],
 .admin-page .bg-\[\#1A1410\],
 .admin-page .bg-\[\#1A1008\] {
  background-color: #FFFFFF !important;
  border-color: rgba(192, 87, 31, 0.12) !important;
 }
 .admin-page .text-\[\#EDE0C6\],
 .admin-page .text-\[\#F5EDD6\] {
  color: #1F1410 !important;
 }
 .admin-page .text-\[\#C4A882\],
 .admin-page .text-\[\#9A8470\],
 .admin-page .text-\[\#7A6B58\] {
  color: #5A4030 !important;
 }
 .admin-page .text-\[\#4A3828\] {
  color: #7A6448 !important;
 }
 .admin-page .border-\[rgba\(184\,115\,51\,0\.14\)\],
 .admin-page .border-\[rgba\(184\,115\,51\,0\.18\)\],
 .admin-page .border-\[rgba\(184\,115\,51\,0\.25\)\] {
  border-color: rgba(192, 87, 31, 0.14) !important;
 }
</style>
