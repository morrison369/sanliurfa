---
/**
 * AdminLayoutV2 — modern 2026 admin shell.
 *
 * Mimari:
 *   ┌──────────────────────────────────────────────┐
 *   │ TopBar (60px) — breadcrumb · search · theme · user  │
 *   ├──────┬───────────────────────────────────────┤
 *   │      │                                       │
 *   │ Side │  Main content                         │
 *   │ bar  │  (responsive padding)                 │
 *   │ 240px│                                       │
 *   └──────┴───────────────────────────────────────┘
 */
import Layout from './Layout.astro';
import { Icon } from 'astro-icon/components';

interface Props {
 title: string;
 subtitle?: string;
 breadcrumbs?: Array<{ label: string; href?: string }>;
 seo?: { title?: string; description?: string; noIndex?: boolean };
}

const { title, subtitle, breadcrumbs = [], seo } = Astro.props;

const user = Astro.locals.user;
if (!user || !Astro.locals.isAdmin) {
 return Astro.redirect(`/giris?redirect=${Astro.url.pathname}`);
}

const resolvedSeo: { title: string; description?: string; noIndex: boolean } = {
 title: seo?.title ?? `${title} · Admin`,
 noIndex: seo?.noIndex ?? true,
};
if (seo?.description) {
 resolvedSeo.description = seo.description;
}

const path = Astro.url.pathname;

const nav = [
 {
  group: 'Komuta',
  items: [
   { href: '/admin', label: 'Dashboard', icon: 'lucide:layout-dashboard' },
   { href: '/admin/command', label: 'Komut Merkezi', icon: 'lucide:command' },
   { href: '/admin/analytics', label: 'Analitik & Web Vitals', icon: 'lucide:bar-chart-3' },
   { href: '/admin/monitoring', label: 'Sistem İzleme', icon: 'lucide:activity' },
   { href: '/admin/settings', label: 'Frontend Yönetimi', icon: 'lucide:sliders-horizontal' },
   { href: '/admin/seo', label: 'SEO Merkezi', icon: 'lucide:search-check' },
   { href: '/admin/bots', label: 'Botlar Merkezi', icon: 'lucide:bot' },
  ],
 },
 {
  group: 'Şehir Rehberi CRM',
  items: [
   { href: '/admin/businesses', label: 'Mekanlar CRM', icon: 'lucide:store' },
   { href: '/admin/submissions', label: 'İşletme Başvuruları', icon: 'lucide:kanban-square' },
   { href: '/admin/classifieds', label: 'Ücretsiz İlanlar', icon: 'lucide:badge-plus' },
   { href: '/admin/categories', label: 'Kategori / Alt Kategori', icon: 'lucide:folder-tree' },
   { href: '/admin/locations/districts', label: 'İlçeler', icon: 'lucide:map' },
   { href: '/admin/locations/neighborhoods', label: 'Mahalleler', icon: 'lucide:route' },
   { href: '/admin/map', label: 'Harita Yönetimi', icon: 'lucide:map-pinned' },
  ],
 },
 {
  group: 'İçerik ve Günlük Veri',
  items: [
   { href: '/admin/blog', label: 'Blog / Rehber', icon: 'lucide:file-text' },
   { href: '/admin/events', label: 'Etkinlikler', icon: 'lucide:calendar' },
   { href: '/admin/recipes', label: 'Yemek Tarifleri', icon: 'lucide:chef-hat' },
   { href: '/admin/historical-sites', label: 'Tarihi Yerler', icon: 'lucide:landmark' },
   { href: '/admin/pharmacies', label: 'Nöbetçi Eczaneler', icon: 'lucide:cross' },
   { href: '/admin/transport/bus', label: 'Otobüs Hatları', icon: 'lucide:bus' },
   { href: '/admin/transport/flights', label: 'Uçak Saatleri', icon: 'lucide:plane' },
   { href: '/admin/media', label: 'Medya Kütüphanesi', icon: 'lucide:image' },
  ],
 },
 {
  group: 'Topluluk',
  items: [
   { href: '/admin/community/users', label: 'Kullanıcılar', icon: 'lucide:users' },
   { href: '/admin/community/profiles', label: 'Eşleşme Profilleri', icon: 'lucide:heart-handshake' },
   { href: '/admin/community/matches', label: 'Eşleşmeler', icon: 'lucide:users-round' },
   { href: '/admin/community/reports', label: 'Şikayetler', icon: 'lucide:shield-alert' },
   { href: '/admin/moderation', label: 'Moderasyon', icon: 'lucide:shield-check' },
   { href: '/admin/reviews', label: 'Yorumlar', icon: 'lucide:message-square' },
   { href: '/admin/messages', label: 'Mesajlar', icon: 'lucide:inbox' },
  ],
 },
 {
  group: 'Gelir',
  items: [
   { href: '/admin/ads', label: 'Reklam ve Sponsor', icon: 'lucide:badge-dollar-sign' },
   { href: '/admin/revenue', label: 'Gelir Özeti', icon: 'lucide:trending-up' },
   { href: '/admin/subscriptions', label: 'Abonelikler', icon: 'lucide:credit-card' },
   { href: '/admin/campaigns', label: 'Kampanyalar', icon: 'lucide:megaphone' },
   { href: '/admin/reservations', label: 'Rezervasyonlar', icon: 'lucide:book-open-check' },
  ],
 },
 {
  group: 'Sistem',
  items: [
   { href: '/admin/users', label: 'Rol ve Yetki', icon: 'lucide:user-cog' },
   { href: '/admin/performance', label: 'SSR Performans', icon: 'lucide:gauge' },
   { href: '/admin/audit-log', label: 'Audit Log', icon: 'lucide:scroll-text' },
   { href: '/admin/integrations', label: 'Entegrasyonlar', icon: 'lucide:plug' },
   { href: '/admin/api-docs', label: 'API Docs', icon: 'lucide:code' },
  ],
 },
];

const allItems = nav.flatMap(g => g.items.map(i => ({ ...i, group: g.group })));
---

<Layout seo={resolvedSeo} hideFooter hideHeader>
 <!-- Top progress bar (sayfa geçişleri sırasında görsel feedback) -->
 <div class="adm-progress" id="adm-progress" aria-hidden="true"></div>

 <div id="adm-shell" data-path={path}>
  <aside class="adm-sidebar" id="adm-sidebar" aria-label="Yönetim menüsü">
   <div class="adm-sidebar-head">
    <a href="/admin" class="adm-brand" aria-label="Admin Dashboard">
     <span class="adm-brand-mark">S</span>
     <span class="adm-brand-text">
      <span class="adm-brand-name">Sanliurfa</span>
      <span class="adm-brand-sub">Admin Panel</span>
     </span>
    </a>
    <button type="button" class="adm-sidebar-toggle" aria-label="Menüyü daralt" id="adm-sidebar-toggle">
     <Icon name="lucide:panel-left-close" class="w-4 h-4" />
    </button>
   </div>

   <nav class="adm-nav">
    {nav.map(group => (
     <div class="adm-nav-group">
      <p class="adm-nav-group-label">{group.group}</p>
      <ul>
       {group.items.map(item => {
        const active = path === item.href || (item.href !== '/admin' && path.startsWith(item.href));
        return (
         <li>
          <a href={item.href} class:list={['adm-nav-link', active && 'adm-nav-link--active']}>
           <Icon name={item.icon} class="adm-nav-icon" />
           <span class="adm-nav-label">{item.label}</span>
          </a>
         </li>
        );
       })}
      </ul>
     </div>
    ))}
   </nav>

   <div class="adm-sidebar-foot">
    <a href="/" class="adm-foot-link" target="_blank" rel="noopener">
     <Icon name="lucide:external-link" class="w-3.5 h-3.5" /> <span>Siteyi aç</span>
    </a>
   </div>
  </aside>

  <div class="adm-backdrop" id="adm-backdrop" aria-hidden="true"></div>

  <div class="adm-main">
   <header class="adm-topbar">
    <button type="button" class="adm-mobile-toggle" id="adm-mobile-toggle" aria-label="Menü">
     <Icon name="lucide:menu" class="w-5 h-5" />
    </button>

    <div class="adm-breadcrumb">
     <a href="/admin" class="adm-breadcrumb-home" aria-label="Admin ana"><Icon name="lucide:home" class="w-3.5 h-3.5" /></a>
     <span class="adm-breadcrumb-sep">/</span>
     {breadcrumbs.map((b, i) => (
      <>
       {b.href ? <a href={b.href} class="adm-breadcrumb-item">{b.label}</a> : <span class="adm-breadcrumb-item">{b.label}</span>}
       {i < breadcrumbs.length - 1 && <span class="adm-breadcrumb-sep">/</span>}
      </>
     ))}
     {breadcrumbs.length === 0 && <span class="adm-breadcrumb-item">{title}</span>}
    </div>

    <div class="adm-topbar-actions">
     <button type="button" class="adm-cmdk-btn" id="adm-cmdk-btn" aria-label="Hızlı arama">
      <Icon name="lucide:search" class="w-3.5 h-3.5" />
      <span>Ara</span>
      <kbd>⌘K</kbd>
     </button>
     <button type="button" class="adm-icon-btn" id="adm-help-btn" aria-label="Klavye kısayolları (?)" title="Klavye kısayolları (?)">
      <Icon name="lucide:keyboard" class="w-4 h-4" />
     </button>
     <button type="button" class="adm-icon-btn" id="adm-theme-toggle" aria-label="Tema değiştir" title="Tema (D)">
      <Icon name="lucide:sun" class="adm-theme-sun w-4 h-4" />
      <Icon name="lucide:moon" class="adm-theme-moon w-4 h-4" />
     </button>
     <div class="adm-user-menu">
      <button type="button" class="adm-icon-btn" id="adm-activity-btn" aria-label="Son aktiviteler" title="Son 7 günde olanlar">
       <Icon name="lucide:bell" class="w-4 h-4" />
       <span class="adm-activity-dot" id="adm-activity-dot" hidden></span>
      </button>
      <div class="adm-activity-dropdown" id="adm-activity-dropdown" hidden>
       <div class="adm-activity-head">
        <strong>Son Aktiviteler</strong>
        <a href="/admin" class="dash-link-sm">Tümü →</a>
       </div>
       <ul class="adm-activity-list" id="adm-activity-list">
        <li class="adm-activity-skel">Yükleniyor…</li>
       </ul>
      </div>
     </div>
     <div class="adm-user-menu">
      <button type="button" class="adm-user-btn" id="adm-user-btn">
       <span class="adm-user-avatar">{(user.fullName || user.email || 'A').charAt(0).toUpperCase()}</span>
       <span class="adm-user-name">{user.fullName || 'Admin'}</span>
       <Icon name="lucide:chevron-down" class="w-3.5 h-3.5" />
      </button>
      <div class="adm-user-dropdown" id="adm-user-dropdown" hidden>
       <a href="/profil" class="adm-user-item"><Icon name="lucide:user" class="w-3.5 h-3.5" /> Profil</a>
       <a href="/ayarlar" class="adm-user-item"><Icon name="lucide:settings" class="w-3.5 h-3.5" /> Ayarlar</a>
       <div class="adm-user-divider"></div>
       <a href="/cikis" class="adm-user-item"><Icon name="lucide:log-out" class="w-3.5 h-3.5" /> Çıkış</a>
      </div>
     </div>
    </div>
   </header>

   <div class="adm-page-head">
    <div>
     <h1 class="adm-h1">{title}</h1>
     {subtitle && <p class="adm-subtitle">{subtitle}</p>}
    </div>
    <slot name="page-actions" />
   </div>

   <main class="adm-content">
    <slot />
   </main>
  </div>

  <div class="adm-cmdk" id="adm-cmdk" hidden role="dialog" aria-label="Hızlı arama">
   <div class="adm-cmdk-backdrop" data-cmdk-close></div>
   <div class="adm-cmdk-panel" role="document">
    <div class="adm-cmdk-input-row">
     <Icon name="lucide:search" class="w-4 h-4" />
     <input type="text" id="adm-cmdk-input" placeholder="İşletme, kullanıcı, kategori, etkinlik, blog, eczane, ilçe ara..." autocomplete="off" />
     <kbd>ESC</kbd>
    </div>
    <div class="adm-cmdk-results" id="adm-cmdk-results"></div>
   </div>
  </div>

  <!-- Keyboard Shortcuts Help Overlay (? tuşu) -->
  <div class="adm-help" id="adm-help" hidden role="dialog" aria-label="Klavye kısayolları">
   <div class="adm-help-backdrop" data-help-close></div>
   <div class="adm-help-panel" role="document">
    <div class="adm-help-head">
     <h2>Klavye Kısayolları</h2>
     <button type="button" class="adm-icon-btn" data-help-close aria-label="Kapat">
      <Icon name="lucide:x" class="w-4 h-4" />
     </button>
    </div>
    <div class="adm-help-grid">
     <section>
      <h3>Navigasyon</h3>
      <dl>
       <div><dt><kbd>⌘</kbd><kbd>K</kbd></dt><dd>Sayfa arama (Cmd Palette)</dd></div>
       <div><dt><kbd>g</kbd> <kbd>d</kbd></dt><dd>Dashboard</dd></div>
       <div><dt><kbd>g</kbd> <kbd>p</kbd></dt><dd>Mekanlar</dd></div>
       <div><dt><kbd>g</kbd> <kbd>b</kbd></dt><dd>Blog</dd></div>
       <div><dt><kbd>g</kbd> <kbd>e</kbd></dt><dd>Etkinlikler</dd></div>
       <div><dt><kbd>g</kbd> <kbd>r</kbd></dt><dd>Yorumlar</dd></div>
       <div><dt><kbd>g</kbd> <kbd>u</kbd></dt><dd>Kullanıcılar</dd></div>
       <div><dt><kbd>g</kbd> <kbd>s</kbd></dt><dd>Ayarlar (Marketing)</dd></div>
      </dl>
     </section>
     <section>
      <h3>Genel</h3>
      <dl>
       <div><dt><kbd>?</kbd></dt><dd>Bu yardım</dd></div>
       <div><dt><kbd>D</kbd></dt><dd>Tema değiştir (Light/Dark)</dd></div>
       <div><dt><kbd>[</kbd></dt><dd>Sidebar daralt/genişlet</dd></div>
       <div><dt><kbd>Esc</kbd></dt><dd>Dialog/Modal kapat</dd></div>
       <div><dt><kbd>↑</kbd> <kbd>↓</kbd></dt><dd>Komut listesinde gez</dd></div>
       <div><dt><kbd>Enter</kbd></dt><dd>Seçili komutu çalıştır</dd></div>
      </dl>
     </section>
    </div>
    <p class="adm-help-foot">
     Tüm kısayollar input/textarea aktifken devre dışıdır. <kbd>?</kbd> tuşuna basıp bu pencereyi açabilirsiniz.
    </p>
   </div>
  </div>
 </div>
</Layout>

<script is:inline define:vars={{ allItems }}>
 (function initTheme() {
  const stored = localStorage.getItem('adm-theme');
  const system = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  document.documentElement.dataset.admTheme = stored || system;
 })();

 const themeBtn = document.getElementById('adm-theme-toggle');
 themeBtn?.addEventListener('click', () => {
  const cur = document.documentElement.dataset.admTheme === 'dark' ? 'dark' : 'light';
  const next = cur === 'dark' ? 'light' : 'dark';
  document.documentElement.dataset.admTheme = next;
  localStorage.setItem('adm-theme', next);
 });

 const shell = document.getElementById('adm-shell');
 const sidebarToggle = document.getElementById('adm-sidebar-toggle');
 const mobileToggle = document.getElementById('adm-mobile-toggle');
 const backdrop = document.getElementById('adm-backdrop');

 if (localStorage.getItem('adm-sidebar-collapsed') === '1') {
  shell?.classList.add('adm-shell--collapsed');
 }
 sidebarToggle?.addEventListener('click', () => {
  shell?.classList.toggle('adm-shell--collapsed');
  localStorage.setItem('adm-sidebar-collapsed', shell?.classList.contains('adm-shell--collapsed') ? '1' : '0');
 });
 mobileToggle?.addEventListener('click', () => shell?.classList.toggle('adm-shell--drawer-open'));
 backdrop?.addEventListener('click', () => shell?.classList.remove('adm-shell--drawer-open'));

 const userBtn = document.getElementById('adm-user-btn');
 const userDropdown = document.getElementById('adm-user-dropdown');
 userBtn?.addEventListener('click', (e) => {
  e.stopPropagation();
  userDropdown.hidden = !userDropdown.hidden;
 });
 document.addEventListener('click', (e) => {
  if (!userDropdown.hidden && !userDropdown.contains(e.target) && !userBtn.contains(e.target)) {
   userDropdown.hidden = true;
  }
 });

 const cmdk = document.getElementById('adm-cmdk');
 const cmdkBtn = document.getElementById('adm-cmdk-btn');
 const cmdkInput = document.getElementById('adm-cmdk-input');
 const cmdkResults = document.getElementById('adm-cmdk-results');
 let activeIdx = 0;

 function clearResults() {
  while (cmdkResults.firstChild) cmdkResults.removeChild(cmdkResults.firstChild);
 }

 function openCmdk() {
  cmdk.hidden = false;
  setTimeout(() => cmdkInput.focus(), 50);
  renderCmdk('');
 }
 function closeCmdk() {
  cmdk.hidden = true;
  cmdkInput.value = '';
 }
 function renderCmdk(query) {
  const q = (query || '').toLowerCase().trim();
  const filtered = q
   ? allItems.filter(i => i.label.toLowerCase().includes(q) || i.group.toLowerCase().includes(q))
   : allItems.slice(0, 10);
  clearResults();
  activeIdx = 0;
  if (filtered.length === 0) {
   const empty = document.createElement('p');
   empty.className = 'adm-cmdk-empty';
   empty.textContent = 'Sonuç yok';
   cmdkResults.appendChild(empty);
   return;
  }
  filtered.slice(0, 20).forEach((item, idx) => {
   const link = document.createElement('a');
   link.href = item.href;
   link.className = 'adm-cmdk-item' + (idx === 0 ? ' adm-cmdk-item--active' : '');
   const lbl = document.createElement('span');
   lbl.className = 'adm-cmdk-item-label';
   lbl.textContent = item.label;
   const grp = document.createElement('span');
   grp.className = 'adm-cmdk-item-group';
   grp.textContent = item.group;
   link.appendChild(lbl);
   link.appendChild(grp);
   cmdkResults.appendChild(link);
  });
  if (q.length >= 2) {
   const loading = document.createElement('p');
   loading.className = 'adm-cmdk-empty';
   loading.textContent = 'CRM kayıtları aranıyor...';
   cmdkResults.appendChild(loading);
   fetch('/api/admin/command?q=' + encodeURIComponent(q))
    .then((res) => (res.ok ? res.json() : { results: [] }))
    .then((payload) => {
     if (cmdkInput.value.toLowerCase().trim() !== q) return;
     loading.remove();
     const results = Array.isArray(payload.results) ? payload.results : [];
     if (results.length === 0) return;
     const groupTitle = document.createElement('p');
     groupTitle.className = 'adm-cmdk-section-title';
     groupTitle.textContent = 'CRM sonuçları';
     cmdkResults.appendChild(groupTitle);
     results.forEach((item) => {
      const link = document.createElement('a');
      link.href = item.adminHref || item.href || '/admin';
      link.className = 'adm-cmdk-item adm-cmdk-item--crm';
      const lbl = document.createElement('span');
      lbl.className = 'adm-cmdk-item-label';
      lbl.textContent = item.label || '(başlıksız)';
      const grp = document.createElement('span');
      grp.className = 'adm-cmdk-item-group';
      grp.textContent = `${item.type || 'Kayıt'} · ${item.description || ''}`;
      link.appendChild(lbl);
      link.appendChild(grp);
      cmdkResults.appendChild(link);
     });
    })
    .catch(() => {
     loading.textContent = 'CRM araması yüklenemedi';
    });
  }
 }

 cmdkBtn?.addEventListener('click', openCmdk);
 document.querySelectorAll('[data-cmdk-close]').forEach(el => el.addEventListener('click', closeCmdk));
 cmdkInput?.addEventListener('input', (e) => renderCmdk(e.target.value));

 document.addEventListener('keydown', (e) => {
  if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
   e.preventDefault();
   if (cmdk.hidden) openCmdk(); else closeCmdk();
   return;
  }
  if (!cmdk.hidden && e.key === 'Escape') { closeCmdk(); return; }
  if (!cmdk.hidden && (e.key === 'ArrowDown' || e.key === 'ArrowUp')) {
   e.preventDefault();
   const items = cmdkResults.querySelectorAll('.adm-cmdk-item');
   if (!items.length) return;
   items[activeIdx]?.classList.remove('adm-cmdk-item--active');
   activeIdx = e.key === 'ArrowDown' ? (activeIdx + 1) % items.length : (activeIdx - 1 + items.length) % items.length;
   items[activeIdx].classList.add('adm-cmdk-item--active');
   items[activeIdx].scrollIntoView({ block: 'nearest' });
  }
  if (!cmdk.hidden && e.key === 'Enter') {
   e.preventDefault();
   const items = cmdkResults.querySelectorAll('.adm-cmdk-item');
   items[activeIdx]?.click();
  }
  if (e.key.toLowerCase() === 'd' && !['INPUT', 'TEXTAREA'].includes(document.activeElement?.tagName) && !e.metaKey && !e.ctrlKey && cmdk.hidden && help.hidden) {
   themeBtn?.click();
  }
  // Sidebar toggle: [
  if (e.key === '[' && !['INPUT', 'TEXTAREA'].includes(document.activeElement?.tagName) && cmdk.hidden && help.hidden) {
   sidebarToggle?.click();
  }
 });

 // Top progress bar — link tıklayınca slide-in, sayfa hazır olunca slide-out
 const adminProgressEl = document.getElementById('adm-progress');
 function showProgress() {
  if (!adminProgressEl) return;
  adminProgressEl.classList.remove('adm-progress--done');
  adminProgressEl.classList.add('adm-progress--active');
 }
 function hideProgress() {
  if (!adminProgressEl) return;
  adminProgressEl.classList.remove('adm-progress--active');
  adminProgressEl.classList.add('adm-progress--done');
  setTimeout(() => adminProgressEl?.classList.remove('adm-progress--done'), 350);
 }
 // Admin link tıklamalarında progress göster
 document.addEventListener('click', (e) => {
  const target = e.target?.closest?.('a[href^="/admin"]');
  if (!target || target.target === '_blank' || target.hasAttribute('data-no-progress')) return;
  const href = target.getAttribute('href');
  if (!href || href.startsWith('#')) return;
  showProgress();
 });
 // Page load complete
 window.addEventListener('load', hideProgress);
 window.addEventListener('beforeunload', showProgress);
 // Initial state — page already loaded so done
 hideProgress();

 // Activity feed dropdown — topbar'da bell icon
 const activityBtn = document.getElementById('adm-activity-btn');
 const activityDropdown = document.getElementById('adm-activity-dropdown');
 const activityList = document.getElementById('adm-activity-list');
 const activityDot = document.getElementById('adm-activity-dot');
 let activityLoaded = false;

 const activityIconMap = { user: '👤', place: '🏪', review: '💬', blog: '📝', event: '📅' };
 const activityLabelMap = { user: 'Yeni kullanıcı', place: 'Yeni mekan', review: 'Yorum', blog: 'Blog yazısı', event: 'Etkinlik' };

 function timeAgo(date) {
  const diff = Date.now() - new Date(date).getTime();
  const m = Math.floor(diff / 60000);
  if (m < 1) return 'az önce';
  if (m < 60) return m + 'dk';
  const h = Math.floor(m / 60);
  if (h < 24) return h + 'sa';
  return Math.floor(h / 24) + 'g';
 }

 async function loadAdminActivity() {
  if (!activityList) return;
  try {
   const res = await fetch('/api/admin/dashboard/activity');
   if (!res.ok) throw new Error('failed');
   const j = await res.json();
   const items = j?.data?.items || [];
   while (activityList.firstChild) activityList.removeChild(activityList.firstChild);
   if (items.length === 0) {
    const empty = document.createElement('li');
    empty.className = 'adm-activity-skel';
    empty.textContent = 'Son 7 günde aktivite yok.';
    activityList.appendChild(empty);
   } else {
    if (activityDot && items.length > 5) activityDot.hidden = false;
    items.slice(0, 8).forEach((item) => {
     const li = document.createElement('li');
     li.className = 'adm-activity-li';
     const icon = document.createElement('span'); icon.className = 'adm-activity-li-ico'; icon.textContent = activityIconMap[item.type] || '•';
     const body = document.createElement('div'); body.className = 'adm-activity-li-body';
     const lbl = document.createElement('p'); lbl.className = 'adm-activity-li-lbl'; lbl.textContent = activityLabelMap[item.type] || item.type;
     const ttl = document.createElement('p'); ttl.className = 'adm-activity-li-ttl'; ttl.textContent = item.title || '(başlıksız)';
     body.appendChild(lbl); body.appendChild(ttl);
     const time = document.createElement('span'); time.className = 'adm-activity-li-time'; time.textContent = timeAgo(item.created_at);
     li.appendChild(icon); li.appendChild(body); li.appendChild(time);
     activityList.appendChild(li);
    });
   }
   activityLoaded = true;
  } catch {
   while (activityList.firstChild) activityList.removeChild(activityList.firstChild);
   const err = document.createElement('li');
   err.className = 'adm-activity-skel';
   err.textContent = '✗ Yüklenemedi';
   activityList.appendChild(err);
  }
 }

 activityBtn?.addEventListener('click', (e) => {
  e.stopPropagation();
  if (!activityDropdown) return;
  activityDropdown.hidden = !activityDropdown.hidden;
  if (!activityDropdown.hidden && !activityLoaded) loadAdminActivity();
 });
 document.addEventListener('click', (e) => {
  if (activityDropdown && !activityDropdown.hidden && !activityDropdown.contains(e.target) && !activityBtn?.contains(e.target)) {
   activityDropdown.hidden = true;
  }
 });

 // Initial badge check (idle background, after 1s — non-blocking)
 setTimeout(() => loadAdminActivity().catch(() => null), 1500);

 // ? help overlay
 const help = document.getElementById('adm-help');
 function openHelp() { if (help) help.hidden = false; }
 function closeHelp() { if (help) help.hidden = true; }
 document.getElementById('adm-help-btn')?.addEventListener('click', openHelp);
 document.querySelectorAll('[data-help-close]').forEach(el => el.addEventListener('click', closeHelp));
 document.addEventListener('keydown', (e) => {
  if (e.key === '?' && !['INPUT', 'TEXTAREA'].includes(document.activeElement?.tagName) && cmdk.hidden && !e.metaKey && !e.ctrlKey) {
   e.preventDefault();
   if (help && help.hidden) openHelp(); else closeHelp();
  }
  if (!help?.hidden && e.key === 'Escape') closeHelp();
 });

 // Gmail-style `g <key>` navigation
 let gPressed = false;
 let gTimeout = null;
 const gMap = {
  d: '/admin', p: '/admin/places', b: '/admin/blog',
  e: '/admin/events', r: '/admin/reviews', u: '/admin/users',
  s: '/admin/settings/marketing',
 };
 document.addEventListener('keydown', (e) => {
  if (['INPUT', 'TEXTAREA'].includes(document.activeElement?.tagName) || e.metaKey || e.ctrlKey) return;
  if (e.key.toLowerCase() === 'g' && !gPressed) {
   gPressed = true;
   if (gTimeout) clearTimeout(gTimeout);
   gTimeout = setTimeout(() => { gPressed = false; }, 1200);
   return;
  }
  if (gPressed && gMap[e.key.toLowerCase()]) {
   e.preventDefault();
   gPressed = false;
   if (gTimeout) clearTimeout(gTimeout);
   window.location.href = gMap[e.key.toLowerCase()];
  }
 });
</script>

