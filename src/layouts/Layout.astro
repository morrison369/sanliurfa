---
import { ClientRouter } from 'astro:transitions';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileBottomNav from '../components/MobileBottomNav.astro';
import ThemeScript from '../components/ThemeScript.astro';
import Toast from '../components/ui/Toast.astro';
import ErrorBoundary from '../components/ErrorBoundary.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import PWARegister from '../components/PWARegister.astro';
import PerformanceMonitor from '../components/PerformanceMonitor.tsx';
import { getSiteSetting } from '../lib/site-content';
import '../styles/global.css';

export interface Props {
 title?: string;
 seo?: {
 title: string;
 description?: string;
 canonical?: string;
 ogImage?: string;
 noIndex?: boolean;
 noFollow?: boolean;
 keywords?: string[];
 author?: string;
 publishedTime?: string;
 modifiedTime?: string;
 type?: 'website' | 'article';
 };
 hideHeader?: boolean;
 hideFooter?: boolean;
 class?: string;
}

const { seo, hideHeader = false, hideFooter = false, class: className = '' } = Astro.props;

let GA_MEASUREMENT_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID
 || import.meta.env.GA_TRACKING_ID
 || '';
if (!GA_MEASUREMENT_ID) {
 try {
 const ga = await getSiteSetting<{ ga_id?: string }>('integrations.analytics', {});
 GA_MEASUREMENT_ID = (ga as any)?.ga_id || '';
 } catch { /* sessiz */ }
}

let siteName = 'Sanliurfa.com';
try {
 const schema = await getSiteSetting('homepage.schema', { siteName: 'Sanliurfa.com' });
 siteName = String((schema as any)?.siteName || 'Sanliurfa.com');
} catch { /* sessiz */ }

const user = Astro.locals.user;
---

<!DOCTYPE html>
<html lang="tr" class="scroll-smooth" data-theme="light">
 <head>
 <meta charset="UTF-8" />
 <meta name="viewport" content="width=device-width, initial-scale=1.0" />
 <meta http-equiv="X-UA-Compatible" content="IE=edge" />
 <meta name="google-adsense-account" content="ca-pub-7160871802649062" />

 <!-- Favicons -->
 <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
 <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
 <link rel="manifest" href="/manifest.json" />
 <meta name="theme-color" content="#B87333" />
 <meta name="mobile-web-app-capable" content="yes" />
 <meta name="apple-mobile-web-app-title" content={siteName} />

 <!-- SEO -->
 {seo && <SEO {...seo} />}

 <!-- Feeds -->
 <link rel="alternate" type="application/rss+xml" title={`${siteName} Blog`} href="/rss.xml" />
 <link rel="sitemap" type="application/xml" href="/sitemap.xml" />

 <!-- Fonts -->
 <link rel="preconnect" href="https://fonts.googleapis.com" />
 <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
 <!-- Preload the CSS itself with high priority — fonts load asap without guessing woff2 hashes -->
 <link rel="preload" as="style"
   href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600;0,700&family=Jost:wght@300;400;500;600;700&display=swap" />
 <link
 rel="stylesheet"
 href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600;0,700&family=Jost:wght@300;400;500;600;700&display=swap"
 />
 <!-- Fallback font metrics override — keep layout stable while Cormorant loads -->
 <style is:inline>
 @font-face {
   font-family: 'Cormorant Garamond Fallback';
   src: local('Georgia'), local('Times New Roman');
   font-display: block;
   ascent-override: 100%;
   descent-override: 31%;
   line-gap-override: 0%;
   size-adjust: 105%;
 }
 </style>

 <!-- Critical inline CSS: FOUC yok, taş beji zemin hemen (Şanlıurfa palette light) -->
 <style is:inline>
 *,*::before,*::after{box-sizing:border-box}
 :root{--bg:#FBF6EC;--text-1:#1F1410;--copper:#C0571F;--text-on-deep:#FBF6EC}
 html{-webkit-font-smoothing:antialiased;font-family:'Jost',system-ui,sans-serif;color-scheme:light}
 html.dark{color-scheme:light}
 body{margin:0;min-height:100vh;background:var(--bg);color:var(--text-1)}
@media (max-width:768px){body{padding-bottom:calc(4.2rem + env(safe-area-inset-bottom))}}
 .sf-container{width:100%;max-width:1280px;margin-inline:auto;padding-inline:1.25rem}
 #main-content{outline:none}
 .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap}
 </style>
 <ThemeScript />
 <ClientRouter />
 <slot name="head" />
 </head>

 <body class={`flex flex-col min-h-screen ${className}`}>
 <!-- Skip link -->
 <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:rounded focus:bg-bakir-500 focus:text-white">
 Ana içeriğe geç
 </a>

 {!hideHeader && <Header user={user} transition:persist="site-header" />}

 <ErrorBoundary fallback="Sayfa yüklenirken bir hata oluştu. Lütfen yenileyin.">
 <main id="main-content" class="flex-1" role="main">
 <slot />
 </main>
 </ErrorBoundary>

 {!hideFooter && <Footer transition:persist="site-footer" />}

 <!-- Mobile bottom navigation (only <768px viewport) -->
 <MobileBottomNav />

 <!-- Toast -->
 <Toast transition:persist="toast-container" />

 <!-- Cookie banner -->
 <div
 id="sf-cookie"
 class="fixed bottom-0 inset-x-0 z-50 hidden"
 style="background:linear-gradient(180deg,#1F1410 0%,#15100C 100%);border-top:1px solid rgba(212,151,24,0.30)"
 >
 <div class="sf-container flex flex-col sm:flex-row items-center justify-between gap-3 py-3">
 <p style="font-size:0.8rem;color:#C4A882;margin:0">
 Deneyiminizi geliştirmek için çerezler kullanıyoruz.
 <a href="/gizlilik-politikasi" style="color:#B87333;text-decoration:underline">Politika</a>
 </p>
 <div style="display:flex;gap:0.5rem;flex-shrink:0">
 <button id="sf-cookie-decline" style="padding:0.4rem 1rem;border:1px solid rgba(184,115,51,0.28);border-radius:0.2rem;background:transparent;color:#C4A882;font-size:0.8rem;cursor:pointer">Reddet</button>
 <button id="sf-cookie-accept" style="padding:0.4rem 1rem;background:linear-gradient(135deg,#C0571F 0%,#9F4717 100%);border:none;border-radius:0.4rem;color:#FFFFFF;font-weight:700;font-size:0.8rem;cursor:pointer">Kabul Et</button>
 </div>
 </div>
 </div>

 <!-- Yukarı çık -->
 <button
 id="sf-top"
 aria-label="Yukarı dön"
 style="position:fixed;bottom:1.5rem;right:1.5rem;z-index:40;width:2.5rem;height:2.5rem;border-radius:50%;background:linear-gradient(135deg,#C0571F 0%,#9F4717 100%);color:#FFFFFF;border:none;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity 0.2s;cursor:pointer"
 >
 <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
 </button>

 <script>
 // Cookie
 const banner = document.getElementById('sf-cookie');
 if (!localStorage.getItem('sf_cookie')) {
 setTimeout(() => banner && (banner.style.display = 'block'), 1500);
 }
 document.getElementById('sf-cookie-accept')?.addEventListener('click', () => {
 localStorage.setItem('sf_cookie', '1');
 if (banner) banner.style.display = 'none';
 });
 document.getElementById('sf-cookie-decline')?.addEventListener('click', () => {
 localStorage.setItem('sf_cookie', '0');
 if (banner) banner.style.display = 'none';
 });

 // Back to top
 const topBtn = document.getElementById('sf-top');
 window.addEventListener('scroll', () => {
 if (!topBtn) return;
 if (window.scrollY > 500) {
 topBtn.style.opacity = '1';
 topBtn.style.pointerEvents = 'auto';
 } else {
 topBtn.style.opacity = '0';
 topBtn.style.pointerEvents = 'none';
 }
 });
 topBtn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

 // Toast
 if (typeof window !== 'undefined') {
 import('../lib/toast').then(({ toast }) => { (window as any).toast = toast; });
 }

 // Modal dialog helpers — replaces native prompt()/confirm() with themed UI
 (function() {
   function _dialogBase(): { overlay: HTMLDivElement; dialog: HTMLDivElement } {
     const overlay = document.createElement('div');
     overlay.style.cssText = 'position:fixed;inset:0;z-index:9999;background:rgba(13,10,8,0.85);display:flex;align-items:center;justify-content:center;padding:1rem';
     const dialog = document.createElement('div');
     dialog.style.cssText = 'background:#1A1410;border:1px solid rgba(184,115,51,0.28);border-radius:0.25rem;padding:1.5rem;min-width:280px;max-width:480px;width:100%';
     overlay.appendChild(dialog);
     return { overlay, dialog };
   }
   function _btnStyle(primary: boolean): string {
     return primary
       ? 'padding:0.4rem 1rem;background:linear-gradient(135deg,#C0571F 0%,#9F4717 100%);border:none;border-radius:0.4rem;color:#FFFFFF;font-weight:600;font-size:0.85rem;cursor:pointer'
       : 'padding:0.4rem 1rem;border:1px solid rgba(184,115,51,0.28);border-radius:0.2rem;background:transparent;color:#C4A882;font-size:0.85rem;cursor:pointer';
   }
   function _label(text: string): HTMLParagraphElement {
     const p = document.createElement('p');
     p.style.cssText = 'color:#FBF6EC;margin:0 0 0.75rem;font-size:0.9rem;line-height:1.5';
     p.textContent = text;
     return p;
   }

   (window as any).showConfirm = function(message: string): Promise<boolean> {
     return new Promise((resolve) => {
       const { overlay, dialog } = _dialogBase();
       dialog.appendChild(_label(message));
       const btns = document.createElement('div');
       btns.style.cssText = 'display:flex;gap:0.5rem;justify-content:flex-end;margin-top:0.5rem';
       const cancel = document.createElement('button');
       cancel.textContent = 'İptal';
       cancel.style.cssText = _btnStyle(false);
       const ok = document.createElement('button');
       ok.textContent = 'Tamam';
       ok.style.cssText = _btnStyle(true);
       cancel.addEventListener('click', () => { overlay.remove(); resolve(false); });
       ok.addEventListener('click', () => { overlay.remove(); resolve(true); });
       btns.appendChild(cancel);
       btns.appendChild(ok);
       dialog.appendChild(btns);
       document.body.appendChild(overlay);
       ok.focus();
     });
   };

   (window as any).promptInput = function(message: string, defaultValue?: string): Promise<string | null> {
     return new Promise((resolve) => {
       const { overlay, dialog } = _dialogBase();
       dialog.appendChild(_label(message));
       const input = document.createElement('input');
       input.type = 'text';
       input.value = defaultValue ?? '';
       input.style.cssText = 'width:100%;padding:0.45rem 0.65rem;background:#FFFFFF;border:1.5px solid rgba(192,87,31,0.30);border-radius:0.4rem;color:#1F1410;font-size:0.85rem;box-sizing:border-box;margin-bottom:1rem;outline:none';
       dialog.appendChild(input);
       const btns = document.createElement('div');
       btns.style.cssText = 'display:flex;gap:0.5rem;justify-content:flex-end';
       const cancel = document.createElement('button');
       cancel.textContent = 'İptal';
       cancel.style.cssText = _btnStyle(false);
       const ok = document.createElement('button');
       ok.textContent = 'Tamam';
       ok.style.cssText = _btnStyle(true);
       const confirm = () => { overlay.remove(); resolve(input.value || null); };
       cancel.addEventListener('click', () => { overlay.remove(); resolve(null); });
       ok.addEventListener('click', confirm);
       input.addEventListener('keydown', (e: KeyboardEvent) => {
         if (e.key === 'Enter') confirm();
         if (e.key === 'Escape') { overlay.remove(); resolve(null); }
       });
       btns.appendChild(cancel);
       btns.appendChild(ok);
       dialog.appendChild(btns);
       document.body.appendChild(overlay);
       input.focus();
     });
   };
 })();
 </script>

 <PWARegister />
 <PerformanceMonitor client:only="react" />
 {GA_MEASUREMENT_ID && <GoogleAnalytics measurementId={GA_MEASUREMENT_ID} debug={import.meta.env.DEV} />}
 </body>
</html>
