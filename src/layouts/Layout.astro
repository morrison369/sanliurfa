---
import { Icon } from 'astro-icon/components';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';
import Toast from '../components/ui/Toast.astro';
import ErrorBoundary from '../components/ErrorBoundary.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import PWARegister from '../components/PWARegister.astro';
import PerformanceMonitor from '../components/PerformanceMonitor.tsx';
import ThemeScript from '../components/ThemeScript.astro';
import DarkModeToggle from '../components/DarkModeToggle.astro';
import PageLoader from '../components/PageLoader.astro';
import { getSiteSetting } from '../lib/site-content';
import '../styles/global.css';

export interface Props {
  title?: string;
  seo?: {
    title: string;
    description?: string;
    canonical?: string;
    ogImage?: string;
    noIndex?: boolean;
    noFollow?: boolean;
    keywords?: string[];
    author?: string;
    publishedTime?: string;
    modifiedTime?: string;
    type?: 'website' | 'article';
  };
  hideHeader?: boolean;
  hideFooter?: boolean;
  class?: string;
}

const {
  seo,
  hideHeader = false,
  hideFooter = false,
  class: className = ''
} = Astro.props;

// GA ID: önce env, sonra admin panelinden DB'ye kaydedilen değer (rebuild gerekmez)
let GA_MEASUREMENT_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID
  || import.meta.env.GA_TRACKING_ID
  || process.env.GA_TRACKING_ID
  || import.meta.env.GOOGLE_ANALYTICS_ID
  || process.env.GOOGLE_ANALYTICS_ID
  || '';
if (!GA_MEASUREMENT_ID) {
  try {
    const gaSettings = await getSiteSetting<{ ga_id?: string }>('integrations.analytics', {});
    GA_MEASUREMENT_ID = gaSettings.ga_id || '';
  } catch { /* DB henüz hazır değilse sessizce geç */ }
}
const homepageSchemaFallback = {
  siteName: 'Sanliurfa.com',
  baseUrl: 'https://sanliurfa.com',
};
const homepageSchema = await getSiteSetting('homepage.schema', homepageSchemaFallback);
const siteName = String((homepageSchema as any)?.siteName || homepageSchemaFallback.siteName);

// Get current user from middleware (set by src/middleware.ts)
const user = Astro.locals.user;
---

<!DOCTYPE html>
<html lang="tr" dir="ltr" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    
    <!-- Theme Script (FOUC prevention) -->
    <ThemeScript />
    
    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/manifest.json" />
    
    <!-- Theme Colors for Light/Dark -->
    <meta name="theme-color" content="#be7239" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0f172a" media="(prefers-color-scheme: dark)" />
    <meta name="msapplication-TileColor" content="#be7239" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content={siteName} />
    
    <!-- SEO -->
    {seo && <SEO {...seo} />}
    
    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title={`${siteName} Blog`} href="/rss.xml" />
    
    <!-- Sitemap -->
    <link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap.xml" />

    <!-- Preconnect to External Domains -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Preload Critical Fonts -->
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Jost:wght@300;400;500;600;700&display=swap" as="style" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Jost:wght@300;400;500;600;700&display=swap" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Jost:wght@300;400;500;600;700&display=swap" /></noscript>

    <!-- Critical CSS -->
    <style is:inline>
      /* Critical CSS - Above the fold */
      *,*::before,*::after{box-sizing:border-box}
      html{font-family:'Jost',system-ui,-apple-system,sans-serif;line-height:1.5;-webkit-text-size-adjust:100%;-webkit-font-smoothing:antialiased}
      body{margin:0;min-height:100vh;background-color:#FDFAF3;color:#1A1008}
      img{max-width:100%;height:auto;display:block}
      a{color:inherit;text-decoration:none}
      button{font-family:inherit}
      .container{width:100%;max-width:1280px;margin:0 auto;padding:0 1rem}
      @media(min-width:640px){.container{padding:0 1.5rem}}
      @media(min-width:1024px){.container{padding:0 2rem}}
      .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border-width:0}
      .flex{display:flex}.flex-col{flex-direction:column}.flex-1{flex:1 1 0%}
      .min-h-screen{min-height:100vh}
      #main-content{outline:none}
    </style>
    
    <!-- Astro View Transitions (SPA-like navigation + prefetch) -->
    <ClientRouter fallback="animate" />

    <slot name="head" />
  </head>
  
  <body class={`min-h-screen flex flex-col transition-colors duration-300 ${className}`}>
    <!-- Page Loader -->
    <PageLoader />
    
    <!-- Skip to main content for accessibility -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-urfa-600 focus:text-white focus:rounded-lg">
      Ana içeriğe geç
    </a>
    
    {!hideHeader && <Header user={user} transition:persist="site-header" />}

    <!-- Theme Toggle (floating) -->
    <div class="fixed top-24 right-4 z-40 hidden lg:block" transition:persist="dark-mode-toggle">
      <DarkModeToggle />
    </div>
    
    <ErrorBoundary fallback="Sayfa yüklenirken bir teknik hata oluştu. Lütfen sayfayı yenileyip tekrar deneyin.">
      <main id="main-content" class="flex-1" role="main">
        <slot />
      </main>
    </ErrorBoundary>
    
    {!hideFooter && <Footer transition:persist="site-footer" />}

    <!-- Toast Notifications -->
    <Toast transition:persist="toast-container" />
    <script>
      // Initialize toast container
      if (typeof window !== 'undefined') {
        import('../lib/toast').then(({ toast }) => {
          window.toast = toast;
        });
      }
    </script>
    <script is:inline>
      window.showConfirm = function(message) {
        return new Promise(function(resolve) {
          var d = document.createElement('div');
          d.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:9999;display:flex;align-items:center;justify-content:center;';
          var box = document.createElement('div');
          box.style.cssText = 'background:#fff;border-radius:16px;padding:24px;max-width:360px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,0.3);';
          var msg = document.createElement('p');
          msg.style.cssText = 'margin:0 0 20px;font-size:15px;line-height:1.5;color:#111827;';
          msg.textContent = message;
          var row = document.createElement('div');
          row.style.cssText = 'display:flex;gap:10px;justify-content:flex-end;';
          var no = document.createElement('button');
          no.textContent = 'İptal';
          no.style.cssText = 'padding:8px 18px;border:1px solid #d1d5db;border-radius:8px;cursor:pointer;background:#fff;color:#374151;font-size:14px;';
          var yes = document.createElement('button');
          yes.textContent = 'Onayla';
          yes.style.cssText = 'padding:8px 18px;background:#dc2626;color:#fff;border:none;border-radius:8px;cursor:pointer;font-weight:600;font-size:14px;';
          row.append(no, yes);
          box.append(msg, row);
          d.appendChild(box);
          document.body.appendChild(d);
          function done(v) { document.body.removeChild(d); resolve(v); }
          yes.onclick = function() { done(true); };
          no.onclick = function() { done(false); };
          d.addEventListener('click', function(e) { if (e.target === d) done(false); });
          document.addEventListener('keydown', function h(e) { if (e.key === 'Escape') { done(false); document.removeEventListener('keydown', h); } });
        });
      };
    </script>
    
    <!-- PWA Registration -->
    <PWARegister />

    <!-- Performance Monitoring -->
    <PerformanceMonitor client:only="react" />
    
    <!-- Cookie Consent Banner -->
    <div id="cookie-consent" class="fixed bottom-0 left-0 right-0 bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-700 p-4 shadow-lg transform translate-y-full transition-transform duration-300 z-50 hidden">
      <div class="container-custom flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-sm text-gray-600 dark:text-gray-300">
          Deneyiminizi geliştirmek için çerezler kullanıyoruz. Daha fazla bilgi için 
          <a href="/gizlilik-politikasi" class="text-urfa-600 dark:text-urfa-400 hover:underline">Gizlilik Politikası</a>'nı inceleyebilirsiniz.
        </p>
        <div class="flex gap-2">
          <button id="cookie-decline" class="btn-secondary text-sm">Reddet</button>
          <button id="cookie-accept" class="btn-primary text-sm">Kabul Et</button>
        </div>
      </div>
    </div>
    
    <!-- Back to Top Button -->
    <button 
      id="back-to-top" 
      class="fixed bottom-6 right-6 bg-urfa-600 text-white p-3 rounded-full shadow-lg opacity-0 invisible transition-all duration-300 hover:bg-urfa-700 focus:outline-none focus:ring-2 focus:ring-urfa-500 z-40"
      aria-label="Yukarı dön"
    >
      <Icon name="lucide:arrow-up" class="h-6 w-6" />
    </button>
    
    <!-- Scripts -->
    <script>
      // Back to top button
      const backToTopBtn = document.getElementById('back-to-top');
      
      window.addEventListener('scroll', () => {
        if (window.scrollY > 500) {
          backToTopBtn?.classList.remove('opacity-0', 'invisible');
          backToTopBtn?.classList.add('opacity-100', 'visible');
        } else {
          backToTopBtn?.classList.add('opacity-0', 'invisible');
          backToTopBtn?.classList.remove('opacity-100', 'visible');
        }
      });
      
      backToTopBtn?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
      
      // Cookie consent
      const cookieConsent = document.getElementById('cookie-consent');
      const cookieAccepted = localStorage.getItem('cookieConsent');
      
      if (!cookieAccepted) {
        setTimeout(() => {
          cookieConsent?.classList.remove('translate-y-full', 'hidden');
        }, 2000);
      }
      
      document.getElementById('cookie-accept')?.addEventListener('click', () => {
        localStorage.setItem('cookieConsent', 'accepted');
        cookieConsent?.classList.add('translate-y-full');
        setTimeout(() => cookieConsent?.classList.add('hidden'), 300);
      });
      
      document.getElementById('cookie-decline')?.addEventListener('click', () => {
        localStorage.setItem('cookieConsent', 'declined');
        cookieConsent?.classList.add('translate-y-full');
        setTimeout(() => cookieConsent?.classList.add('hidden'), 300);
      });
    </script>
    
    <!-- XSS Protection -->
    <script src="/js/xss-protection.js" defer is:inline></script>
    
    {GA_MEASUREMENT_ID && <GoogleAnalytics measurementId={GA_MEASUREMENT_ID} debug={import.meta.env.DEV} />}
  </body>
</html>
