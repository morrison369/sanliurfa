---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileBottomNav from '../components/MobileBottomNav.astro';
import BackToTop from '../components/BackToTop.astro';
import ThemeScript from '../components/ThemeScript.astro';
import Toast from '../components/ui/Toast.astro';
import ErrorBoundary from '../components/ErrorBoundary.astro';
import Analytics from '../components/Analytics.astro';
import PWARegister from '../components/PWARegister.astro';
import PerformanceMonitor from '../components/PerformanceMonitor.tsx';
import { getPublicAppUrl } from '../lib/public-app-url';
import { getSiteSetting } from '../lib/site-content';
import { PUBLISHER_PROFILE } from '../lib/transparency';
import { buildHomepageThemeRootCss, HOMEPAGE_THEME_TOKENS } from '../data/homepage-theme';
import '../styles/global.css';

export interface Props {
 title?: string;
 seo?: {
 title: string;
 description?: string;
 canonical?: string;
 ogImage?: string;
 noIndex?: boolean;
 noFollow?: boolean;
 keywords?: string[];
 author?: string;
 publishedTime?: string;
 modifiedTime?: string;
 type?: 'website' | 'article';
 };
 hideHeader?: boolean;
 hideFooter?: boolean;
 disableViewTransitions?: boolean;
 class?: string;
}

const { seo, hideHeader = false, hideFooter = false, class: className = '' } = Astro.props;

// ClientRouter public sayfalarda gereksiz JS maliyeti ve reklam script re-execute riski oluşturuyor.
const isAdminPath = Astro.url.pathname.startsWith('/admin');
const isAuthPath = ['/giris', '/kayit', '/sifre'].some(p => Astro.url.pathname.startsWith(p));
const enablePerformanceMonitor = import.meta.env.DEV || import.meta.env.PUBLIC_ENABLE_PERFORMANCE_MONITOR === 'true';
const skipPerfMonitor = !enablePerformanceMonitor || isAdminPath || isAuthPath;
const baseUrl = getPublicAppUrl();

function toAbsoluteUrl(pathname: string): string {
 const normalized = pathname === '/' ? '/' : pathname.replace(/\/$/, '');
 return `${baseUrl}${normalized === '/' ? '' : normalized}`;
}

let GA_MEASUREMENT_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID
 || import.meta.env.GA_TRACKING_ID
 || '';
if (!GA_MEASUREMENT_ID) {
 try {
 const ga = await getSiteSetting<{ ga_id?: string }>('integrations.analytics', {});
 GA_MEASUREMENT_ID = (ga as any)?.ga_id || '';
 } catch { /* sessiz */ }
}

let siteName = 'Sanliurfa.com';
try {
 const schema = await getSiteSetting('homepage.schema', { siteName: 'Sanliurfa.com' });
 siteName = String((schema as any)?.siteName || 'Sanliurfa.com');
} catch { /* sessiz */ }

let frontendThemeCss = buildHomepageThemeRootCss(HOMEPAGE_THEME_TOKENS);
try {
 const theme = await getSiteSetting('homepage.theme', HOMEPAGE_THEME_TOKENS);
 frontendThemeCss = [
  buildHomepageThemeRootCss(theme),
  ':root{--bg:var(--landing-sand);--text-1:var(--landing-ink);--copper:var(--landing-copper-strong);--text-on-deep:var(--landing-sand)}',
 ].join('\n');
} catch { /* sessiz */ }

// GSC + Bing webmaster verification meta tag'leri (admin panel veya env var ile)
let gscVerification = process.env.GSC_VERIFICATION || import.meta.env.GSC_VERIFICATION || '';
let bingVerification = process.env.BING_VERIFICATION || import.meta.env.BING_VERIFICATION || '';
if (!gscVerification) {
 try {
  const verify = await getSiteSetting<{ gsc?: string; bing?: string }>('integrations.verification', {});
  gscVerification = (verify as any)?.gsc || '';
  bingVerification = (verify as any)?.bing || bingVerification;
 } catch { /* sessiz */ }
}

// Microsoft Clarity heatmap/session recording (admin panel veya env)
let clarityProjectId = process.env.CLARITY_PROJECT_ID || import.meta.env.CLARITY_PROJECT_ID || 'wq08o4hm02';
try {
 const clarity = await getSiteSetting<{ clarity_id?: string }>('integrations.clarity', {});
 if ((clarity as any)?.clarity_id) clarityProjectId = String((clarity as any).clarity_id);
} catch { /* sessiz */ }

// Yandex Metrica (TR + RU pazarı; bot/click metrics tamamlayıcı)
let yandexMetricaId = process.env.YANDEX_METRICA_ID || import.meta.env.YANDEX_METRICA_ID || '';
try {
 const ym = await getSiteSetting<{ metrica_id?: string }>('integrations.yandex', {});
 if ((ym as any)?.metrica_id) yandexMetricaId = String((ym as any).metrica_id);
} catch { /* sessiz */ }

const user = Astro.locals.user;
const canonicalPath = seo?.canonical || Astro.url.pathname || '/';
const pageUrl = toAbsoluteUrl(canonicalPath);
const transparencyAuthor = seo?.author || PUBLISHER_PROFILE.publisherName;
const pagePublishedIso = seo?.publishedTime || PUBLISHER_PROFILE.sitePublishedAtIso;
const pageModifiedIso = seo?.modifiedTime || PUBLISHER_PROFILE.transparencyReviewedAtIso;
const publisherStructuredData = {
 '@context': 'https://schema.org',
 '@type': ['Organization', 'NewsMediaOrganization'],
 name: PUBLISHER_PROFILE.siteName,
 alternateName: PUBLISHER_PROFILE.siteAltName,
 legalName: PUBLISHER_PROFILE.legalName,
 url: baseUrl,
 publishingPrinciples: `${baseUrl}${PUBLISHER_PROFILE.policyPath}`,
 ownershipFundingInfo: `${baseUrl}${PUBLISHER_PROFILE.imprintPath}`,
 correctionsPolicy: `${baseUrl}${PUBLISHER_PROFILE.policyPath}#duzeltme-ve-geri-bildirim-sureci`,
 ethicsPolicy: `${baseUrl}${PUBLISHER_PROFILE.policyPath}`,
 logo: {
  '@type': 'ImageObject',
  url: `${baseUrl}${PUBLISHER_PROFILE.logoPath}`,
 },
 email: PUBLISHER_PROFILE.generalEmail,
 foundingDate: PUBLISHER_PROFILE.foundedYear,
 address: {
  '@type': 'PostalAddress',
  streetAddress: 'Eyyübiye',
  addressLocality: 'Şanlıurfa',
  addressRegion: 'Şanlıurfa',
  addressCountry: 'TR',
 },
 contactPoint: [
  {
   '@type': 'ContactPoint',
   contactType: 'customer service',
   email: PUBLISHER_PROFILE.generalEmail,
   availableLanguage: 'Turkish',
  },
  {
   '@type': 'ContactPoint',
   contactType: 'business inquiry',
   email: PUBLISHER_PROFILE.businessEmail,
   availableLanguage: 'Turkish',
  },
  {
   '@type': 'ContactPoint',
   contactType: 'privacy',
   email: PUBLISHER_PROFILE.privacyEmail,
   availableLanguage: 'Turkish',
  },
 ],
 sameAs: PUBLISHER_PROFILE.sameAs,
};
const websiteStructuredData = {
 '@context': 'https://schema.org',
 '@type': 'WebSite',
 name: siteName,
 alternateName: PUBLISHER_PROFILE.siteAltName,
 url: baseUrl,
 inLanguage: 'tr-TR',
};
const webPageStructuredData = {
 '@context': 'https://schema.org',
 '@type': 'WebPage',
 name: seo?.title || siteName,
 url: pageUrl,
 inLanguage: 'tr-TR',
 isPartOf: {
  '@type': 'WebSite',
  name: siteName,
  url: baseUrl,
 },
 about: {
  '@type': 'Thing',
  name: 'Şanlıurfa',
 },
 author: {
  '@type': transparencyAuthor === PUBLISHER_PROFILE.publisherName ? 'Organization' : 'Person',
  name: transparencyAuthor,
  url: `${baseUrl}${PUBLISHER_PROFILE.authorsPath}`,
 },
 publisher: {
  '@type': 'Organization',
  name: PUBLISHER_PROFILE.siteName,
  url: baseUrl,
  email: PUBLISHER_PROFILE.generalEmail,
 },
 datePublished: pagePublishedIso,
 dateModified: pageModifiedIso,
};
---

<!DOCTYPE html>
<html lang="tr" class="scroll-smooth" data-theme="light">
 <head>
 <meta charset="UTF-8" />
 <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
 <meta http-equiv="X-UA-Compatible" content="IE=edge" />
 <meta name="author" content={transparencyAuthor} />
 <meta name="publisher" content={PUBLISHER_PROFILE.publisherName} />
 <meta name="copyright" content={`© ${new Date().getFullYear()} ${PUBLISHER_PROFILE.siteName}`} />
 <meta name="date" content={pagePublishedIso} />
 <meta property="article:published_time" content={pagePublishedIso} />
 <meta property="article:modified_time" content={pageModifiedIso} />
 <meta name="google-adsense-account" content="ca-pub-7160871802649062" />
 <Fragment set:html={'<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7160871802649062" crossorigin="anonymous" data-sf-adsense-loader="1"></script>'} />
 {gscVerification && <meta name="google-site-verification" content={gscVerification} />}
 {bingVerification && <meta name="msvalidate.01" content={bingVerification} />}

 <!-- Favicons -->
 <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
 <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
 <link rel="manifest" href="/manifest.json" />
 <meta name="theme-color" content="#FBF6EC" media="(prefers-color-scheme: light)" />
 <meta name="theme-color" content="#1F1410" media="(prefers-color-scheme: dark)" />
 <meta name="mobile-web-app-capable" content="yes" />
 <meta name="apple-mobile-web-app-capable" content="yes" />
 <meta name="apple-mobile-web-app-status-bar-style" content="default" />
 <meta name="apple-mobile-web-app-title" content={siteName} />
 <meta name="format-detection" content="telephone=no" />

 <!-- SEO -->
 {seo && <SEO {...seo} />}
 <script type="application/ld+json" set:html={JSON.stringify(publisherStructuredData)} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify(websiteStructuredData)} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify(webPageStructuredData)} is:inline />

 <!-- Feeds -->
 <link rel="alternate" type="application/rss+xml" title={`${siteName} Blog`} href="/rss.xml" />
 <link rel="sitemap" type="application/xml" href="/sitemap.xml" />

 <!-- Harici görsel kaynak ipuçları (yalnızca içerik toplama/fallback yüzeyleri için) -->
 <link rel="dns-prefetch" href="https://images.pexels.com" />
 <link rel="dns-prefetch" href="https://images.unsplash.com" />
 <!-- Local-only font policy: no Google Fonts request on the critical path. -->
 <style is:inline>
 @font-face {
   font-family: 'Jost';
   src: local('Segoe UI'), local('Arial');
   font-display: swap;
 }
 @font-face {
   font-family: 'Cormorant Garamond';
   src: local('Georgia'), local('Times New Roman');
   font-display: swap;
   ascent-override: 100%;
   descent-override: 31%;
   line-gap-override: 0%;
   size-adjust: 105%;
 }
 @font-face {
   font-family: 'Cormorant Garamond Fallback';
   src: local('Georgia'), local('Times New Roman');
   font-display: block;
   ascent-override: 100%;
   descent-override: 31%;
   line-gap-override: 0%;
   size-adjust: 105%;
 }
 </style>

 <!-- Critical inline CSS: FOUC yok, taş beji zemin hemen (Şanlıurfa palette light) -->
 <style is:inline>
 *,*::before,*::after{box-sizing:border-box}
 :root{--bg:#FBF6EC;--text-1:#1F1410;--copper:#C0571F;--text-on-deep:#FBF6EC}
 html{-webkit-font-smoothing:antialiased;font-family:'Jost',system-ui,sans-serif;color-scheme:light}
 html.dark{color-scheme:light}
 body{margin:0;min-height:100vh;background:var(--bg);color:var(--text-1)}
@media (max-width:768px){body{padding-bottom:calc(4.2rem + env(safe-area-inset-bottom))}}
 .sf-container{width:100%;max-width:1280px;margin-inline:auto;padding-inline:1.25rem}
 #main-content{outline:none}
 .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap}
 </style>
 <style is:inline set:html={frontendThemeCss} />
 <ThemeScript />
 {/* Consolidated analytics: GA4 + Clarity + Yandex (all via Partytown, sfTrack helper) */}
 <Analytics
  ga4MeasurementId={GA_MEASUREMENT_ID}
  clarityProjectId={clarityProjectId}
  yandexMetricaId={yandexMetricaId}
  debug={import.meta.env.DEV}
 />
 <slot name="head" />
 </head>

 <body class={`flex flex-col min-h-screen ${className}`}>
 <!-- Skip link -->
 <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:rounded focus:bg-bakir-500 focus:text-white">
 Ana içeriğe geç
 </a>

 {!hideHeader && <Header user={user} transition:persist="site-header" />}

 <ErrorBoundary fallback="Sayfa yüklenirken bir hata oluştu. Lütfen yenileyin.">
 <main id="main-content" class="flex-1" role="main">
 <slot />
 </main>
 </ErrorBoundary>

 {!hideFooter && <Footer transition:persist="site-footer" />}

 {/* Admin sayfalarda public mobil nav + back-to-top gizli (AdminLayout kendi UI'ı var) */}
 {!isAdminPath && (
  <>
   <MobileBottomNav />
   <BackToTop />
  </>
 )}

 <!-- Toast -->
 <Toast transition:persist="toast-container" />

 <!-- Cookie banner -->
 <div
 id="sf-cookie"
 class="fixed bottom-0 inset-x-0 z-50 hidden"
 style="background:linear-gradient(180deg,#1F1410 0%,#15100C 100%);border-top:1px solid rgba(212,151,24,0.30)"
 >
 <div class="sf-container flex flex-col sm:flex-row items-center justify-between gap-3 py-3">
 <p style="font-size:0.8rem;color:#C4A882;margin:0;flex:1;min-width:200px">
 <strong style="color:#fff">Çerez Onayı (KVKK)</strong> — Site deneyimini iyileştirmek için zorunlu ve analitik çerezler kullanıyoruz. Pazarlama çerezleri ve üçüncü taraf izleme için onay gerekli.
 <a href="/cerez-politikasi" style="color:#B87333;text-decoration:underline">Çerez Politikası</a>
 ·
 <a href="/kvkk" style="color:#B87333;text-decoration:underline">KVKK</a>
 </p>
 <div style="display:flex;gap:0.4rem;flex-shrink:0;flex-wrap:wrap">
 <button id="sf-cookie-decline" style="padding:0.45rem 0.85rem;border:1px solid rgba(184,115,51,0.28);border-radius:0.25rem;background:transparent;color:#C4A882;font-size:0.78rem;font-weight:600;cursor:pointer">Sadece Gerekli</button>
 <button id="sf-cookie-customize" style="padding:0.45rem 0.85rem;border:1px solid rgba(212,151,24,0.4);border-radius:0.25rem;background:rgba(212,151,24,0.08);color:#D49718;font-size:0.78rem;font-weight:600;cursor:pointer">Tercihler</button>
 <button id="sf-cookie-accept" style="padding:0.45rem 1.1rem;background:linear-gradient(135deg,#C0571F 0%,#9F4717 100%);border:none;border-radius:0.3rem;color:#FFFFFF;font-weight:700;font-size:0.78rem;cursor:pointer">Tümünü Kabul Et</button>
 </div>
 </div>
 </div>

 <!-- Yukarı çık -->
 <button
 id="sf-top"
 aria-label="Yukarı dön"
 style="position:fixed;bottom:1.5rem;right:1.5rem;z-index:40;width:2.5rem;height:2.5rem;border-radius:50%;background:linear-gradient(135deg,#C0571F 0%,#9F4717 100%);color:#FFFFFF;border:none;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity 0.2s;cursor:pointer"
 >
 <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
 </button>

 <script>
 // Cookie banner — KVKK uyumlu 3-button
 const banner = document.getElementById('sf-cookie');
 if (!localStorage.getItem('sf_cookie')) {
 if (banner) banner.style.display = 'block';
 }
 // Tümünü kabul
 document.getElementById('sf-cookie-accept')?.addEventListener('click', () => {
 localStorage.setItem('sf_cookie', JSON.stringify({ essential: true, analytics: true, marketing: true, ts: Date.now() }));
 window.dispatchEvent(new CustomEvent('sf-cookie-consent-changed'));
 if (banner) banner.style.display = 'none';
 });
 // Sadece gerekli
 document.getElementById('sf-cookie-decline')?.addEventListener('click', () => {
 localStorage.setItem('sf_cookie', JSON.stringify({ essential: true, analytics: false, marketing: false, ts: Date.now() }));
 window.dispatchEvent(new CustomEvent('sf-cookie-consent-changed'));
 if (banner) banner.style.display = 'none';
 });
 // Tercihler → /cerez-politikasi'ne yönlendir (advanced settings ileride)
 document.getElementById('sf-cookie-customize')?.addEventListener('click', () => {
 window.location.href = '/cerez-politikasi#tercihler';
 });

 // Back to top
 const topBtn = document.getElementById('sf-top');
 window.addEventListener('scroll', () => {
 if (!topBtn) return;
 if (window.scrollY > 500) {
 topBtn.style.opacity = '1';
 topBtn.style.pointerEvents = 'auto';
 } else {
 topBtn.style.opacity = '0';
 topBtn.style.pointerEvents = 'none';
 }
 });
 topBtn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

 // Toast
 if (typeof window !== 'undefined') {
 import('../lib/toast').then(({ toast }) => { (window as any).toast = toast; });
 }

 // Modal dialog helpers — replaces native prompt()/confirm() with themed UI
 (function() {
   function _dialogBase(): { overlay: HTMLDivElement; dialog: HTMLDivElement } {
     const overlay = document.createElement('div');
     overlay.style.cssText = 'position:fixed;inset:0;z-index:9999;background:rgba(13,10,8,0.85);display:flex;align-items:center;justify-content:center;padding:1rem';
     const dialog = document.createElement('div');
     dialog.style.cssText = 'background:#1A1410;border:1px solid rgba(184,115,51,0.28);border-radius:0.25rem;padding:1.5rem;min-width:280px;max-width:480px;width:100%';
     overlay.appendChild(dialog);
     return { overlay, dialog };
   }
   function _btnStyle(primary: boolean): string {
     return primary
       ? 'padding:0.4rem 1rem;background:linear-gradient(135deg,#C0571F 0%,#9F4717 100%);border:none;border-radius:0.4rem;color:#FFFFFF;font-weight:600;font-size:0.85rem;cursor:pointer'
       : 'padding:0.4rem 1rem;border:1px solid rgba(184,115,51,0.28);border-radius:0.2rem;background:transparent;color:#C4A882;font-size:0.85rem;cursor:pointer';
   }
   function _label(text: string): HTMLParagraphElement {
     const p = document.createElement('p');
     p.style.cssText = 'color:#FBF6EC;margin:0 0 0.75rem;font-size:0.9rem;line-height:1.5';
     p.textContent = text;
     return p;
   }

   (window as any).showConfirm = function(message: string): Promise<boolean> {
     return new Promise((resolve) => {
       const { overlay, dialog } = _dialogBase();
       dialog.appendChild(_label(message));
       const btns = document.createElement('div');
       btns.style.cssText = 'display:flex;gap:0.5rem;justify-content:flex-end;margin-top:0.5rem';
       const cancel = document.createElement('button');
       cancel.textContent = 'İptal';
       cancel.style.cssText = _btnStyle(false);
       const ok = document.createElement('button');
       ok.textContent = 'Tamam';
       ok.style.cssText = _btnStyle(true);
       cancel.addEventListener('click', () => { overlay.remove(); resolve(false); });
       ok.addEventListener('click', () => { overlay.remove(); resolve(true); });
       btns.appendChild(cancel);
       btns.appendChild(ok);
       dialog.appendChild(btns);
       document.body.appendChild(overlay);
       ok.focus();
     });
   };

   (window as any).promptInput = function(message: string, defaultValue?: string): Promise<string | null> {
     return new Promise((resolve) => {
       const { overlay, dialog } = _dialogBase();
       dialog.appendChild(_label(message));
       const input = document.createElement('input');
       input.type = 'text';
       input.value = defaultValue ?? '';
       input.style.cssText = 'width:100%;padding:0.45rem 0.65rem;background:#FFFFFF;border:1.5px solid rgba(192,87,31,0.30);border-radius:0.4rem;color:#1F1410;font-size:0.85rem;box-sizing:border-box;margin-bottom:1rem;outline:none';
       dialog.appendChild(input);
       const btns = document.createElement('div');
       btns.style.cssText = 'display:flex;gap:0.5rem;justify-content:flex-end';
       const cancel = document.createElement('button');
       cancel.textContent = 'İptal';
       cancel.style.cssText = _btnStyle(false);
       const ok = document.createElement('button');
       ok.textContent = 'Tamam';
       ok.style.cssText = _btnStyle(true);
       const confirm = () => { overlay.remove(); resolve(input.value || null); };
       cancel.addEventListener('click', () => { overlay.remove(); resolve(null); });
       ok.addEventListener('click', confirm);
       input.addEventListener('keydown', (e: KeyboardEvent) => {
         if (e.key === 'Enter') confirm();
         if (e.key === 'Escape') { overlay.remove(); resolve(null); }
       });
       btns.appendChild(cancel);
       btns.appendChild(ok);
       dialog.appendChild(btns);
       document.body.appendChild(overlay);
       input.focus();
     });
   };
 })();
 </script>

 <PWARegister />
 {/* Admin + auth sayfalarda PerformanceMonitor disable — 429 rate-limit, beacon queue spillover'ı önle */}
 {!skipPerfMonitor && <PerformanceMonitor client:only="react" />}
 {/* Note: Analytics (GA4 + Clarity + Yandex) head'de yüklendi — burada tekrar yükleme yok */}
 </body>
</html>
