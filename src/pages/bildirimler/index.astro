---
import Layout from "../../layouts/Layout.astro";
import NotificationsCenter from "../../components/NotificationsCenter.astro";

const { locals, redirect } = Astro;
if (!locals.user) {
  return redirect("/giris?redirect=/bildirimler");
}
---

<Layout title="Bildirim merkezi | Şanlıurfa.com" description="Hesabınıza gelen bildirimleri görüntüleyin.">
  <div class="max-w-2xl mx-auto px-4 py-8">
    <NotificationsCenter />
  </div>
</Layout>
