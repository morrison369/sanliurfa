---
import Layout from '../layouts/Layout.astro';
import RankedPlaceCard from '../components/landing/RankedPlaceCard.astro';
import { query } from '../lib/postgres';
import { getCachedPublicRouteData } from '../lib/public-route-cache';
import { getPublicAppUrl } from '../lib/public-app-url';
import { logger } from '../lib/logging';
import {
  buildItemListSchema,
  buildBreadcrumbSchema,
  buildFAQSchema,
  type LandingPlace,
} from '../lib/landing/landing-schema';
const baseUrl = getPublicAppUrl();

let yerler: LandingPlace[] = [];
try {
  yerler = await getCachedPublicRouteData('page:guide:en-iyi-gezilecek-yerler', async () => {
    const result = await query(`
      SELECT p.id, p.slug, p.name, p.address, p.avg_rating AS rating, p.review_count, p.image_url, p.images,
             p.short_description, c.name AS category_name
      FROM places p
      LEFT JOIN categories c ON p.category_id = c.id
      WHERE p.status = 'active'
        AND (c.name ILIKE '%turizm%' OR c.name ILIKE '%gezilecek%'
             OR c.name ILIKE '%tarihi%' OR c.name ILIKE '%müze%'
             OR c.name ILIKE '%park%' OR c.name ILIKE '%kültür%')
      ORDER BY p.avg_rating DESC NULLS LAST, p.review_count DESC NULLS LAST
      LIMIT 20
    `);
    return result.rows;
  });
} catch (e) {
  logger.error('Gezilecek yerler yüklenemedi:', e instanceof Error ? e : new Error(String(e)));
}

const seo = {
  title: 'Şanlıurfa Gezilecek Yerler 2026 | En İyi 20 Yer',
  description: "Şanlıurfa'da mutlaka görülmesi gereken 20 yer. Göbeklitepe, Balıklıgöl, Harran ve daha fazlası. Tarihi, kültürel ve doğal güzelliklerin listesi.",
  keywords: ['şanlıurfa gezilecek yerler', 'şanlıurfa turistik yerler', 'şanlıurfa ne gezilir', 'urfa gezi', 'şanlıurfa en iyi yerler'],
  canonical: '/en-iyi-gezilecek-yerler',
};

const faqItems = [
  {
    S: "Şanlıurfa'da mutlaka görülmesi gereken yer nedir?",
    C: "Göbeklitepe arkeoloji alanı, Balıklıgöl ve Rızvaniye Külliyesi, Harran kümbet evleri ve Halfeti ile Rumkale Şanlıurfa'nın en önemli turistik noktalarıdır.",
  },
  {
    S: "Şanlıurfa gezilecek yerler kaç günde gezilir?",
    C: "Şanlıurfa ve çevresi için minimum 2-3 gün önerilir. Göbeklitepe, Harran ve Halfeti için her birine yarım gün ile tam gün arası süre ayrılabilir.",
  },
  {
    S: "Şanlıurfa'da ücretsiz gezilecek yer var mı?",
    C: "Balıklıgöl çevresi, Dergah bölgesi, tarihi çarşılar ve bazı arkeoloji alanlarının çevresi ücretsiz gezilebilir. Göbeklitepe ve Harran için giriş ücreti ödenmesi gerekir.",
  },
];
---

<Layout seo={seo}>
  <style is:inline>
  .ek-hero{position:relative;overflow:hidden;border-bottom:1px solid rgba(184,115,51,0.12);padding:clamp(3rem,6vw,5rem) 0;background:radial-gradient(circle at 18% 0%,rgba(212,151,24,0.10) 0%,transparent 42%),radial-gradient(circle at 82% 100%,rgba(44,122,82,0.08) 0%,transparent 40%),linear-gradient(180deg,#fbf6ec 0%,#f4ecd8 58%,#fbf6ec 100%)}
  .ek-hero-label{font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--public-text-soft)}
  .ek-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.7rem,4vw,2.6rem);font-weight:700;color:var(--public-text);margin:.75rem 0 .25rem}
  .ek-hero-desc{color:var(--public-muted);font-size:.9rem;max-width:40rem}
  .ek-body{background:var(--bg);padding:2rem 0 4rem}
  .ek-info{background:rgba(44,122,82,.05);border:1px solid rgba(44,122,82,.18);padding:1.25rem;margin-bottom:1.75rem}
  .ek-info-h2{font-size:.9rem;font-weight:700;color:var(--public-text);margin-bottom:.25rem}
  .ek-info-p{font-size:.8rem;line-height:1.7;color:var(--public-muted)}
  .ek-grid{display:grid;gap:1rem}
  @media(min-width:48rem){.ek-grid{grid-template-columns:1fr 1fr}}
  .ek-card{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);display:flex;overflow:hidden;transition:border-color .15s}
  .ek-card:hover{border-color:var(--public-accent)}
  .ek-card-rank{width:6rem;height:6rem;background:rgba(44,122,82,.1);display:flex;align-items:center;justify-content:center;font-size:1.5rem;font-weight:700;color:#2c7a52;flex-shrink:0}
  .ek-card-body{padding:1rem;flex:1;min-width:0}
  .ek-card-name{font-size:.9rem;font-weight:700;color:var(--public-text);transition:color .15s}
  .ek-card:hover .ek-card-name{color:var(--public-accent)}
  .ek-card-cat{font-size:.72rem;color:var(--public-muted);margin-top:.15rem}
  .ek-card-addr{font-size:.78rem;color:var(--public-muted);margin-top:.4rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .ek-card-meta{display:flex;align-items:center;gap:.75rem;margin-top:.5rem;font-size:.8rem}
  .ek-rating{color:var(--public-accent);font-weight:600}
  .ek-reviews{color:var(--public-text-soft)}
  .ek-empty{text-align:center;padding:4rem 1rem;background:var(--bg-card);border:1px solid rgba(184,115,51,.14)}
  .ek-empty-icon{font-size:2.5rem;margin-bottom:.75rem}
  .ek-empty-txt{font-size:.9rem;color:var(--public-muted)}
  .ek-cta{display:flex;flex-wrap:wrap;gap:.75rem;margin-top:2.5rem}
  .ek-btn-primary{background:#2c7a52;color:#fff;font-size:.85rem;font-weight:600;padding:.65rem 1.25rem;transition:background .15s}
  .ek-btn-outline{border:1px solid rgba(44,122,82,.25);color:#2c7a52;font-size:.85rem;font-weight:500;padding:.65rem 1.25rem;transition:border-color .15s,color .15s}
  details summary{list-style:none}
  details summary::-webkit-details-marker{display:none}
  details[open] .faq-arrow{transform:rotate(180deg)}
  </style>

  <div class="ek-hero">
    <div class="sf-container">
      <p class="ek-hero-label">Şanlıurfa Turizm Rehberi</p>
      <h1 class="ek-h1">Şanlıurfa'nın En İyi Gezilecek Yerleri</h1>
      <p class="ek-hero-desc">Göbeklitepe'den Halfeti'ye, Harran'dan Balıklıgöl'e — mutlaka görülmesi gereken 20 destinasyon.</p>
    </div>
  </div>

  <div class="ek-body">
    <div class="sf-container">
      <div class="ek-info">
        <h2 class="ek-info-h2">Şanlıurfa'nın Turistik Önemi</h2>
        <p class="ek-info-p">Şanlıurfa, M.Ö. 10.000'e uzanan insan tarihinin en önemli merkezlerinden biridir. Göbeklitepe uygarlığın doğum yeri olarak kabul edilirken, Harran dünyanın hâlâ yaşayan en eski şehirlerinden biridir. Bu eşsiz tarih mirası şehri bölgenin en önemli turizm destinasyonlarından biri yapmaktadır.</p>
      </div>

      {yerler.length > 0 ? (
        <div class="ek-grid">
          {yerler.map((place, i) => (
            <RankedPlaceCard place={place} rank={i + 1} variant="attraction" />
          ))}
        </div>
      ) : (
        <div class="ek-empty">
          <div class="ek-empty-icon">🏛️</div>
          <p class="ek-empty-txt">Mekan bilgileri yakında eklenecek.</p>
        </div>
      )}

      <div class="ek-cta">
        <a href="/gezilecek-yerler" class="ek-btn-primary">Tüm Gezilecek Yerler</a>
        <a href="/gobeklitepe-gezi-rehberi" class="ek-btn-outline">Göbeklitepe Rehberi</a>
        <a href="/ucretsiz-gezilecek-yerler" class="ek-btn-outline">Ücretsiz Yerler →</a>
      </div>
    </div>
  </div>

  {faqItems.length > 0 && (
    <div style="padding:2rem 0 3rem;border-top:1px solid rgba(184,115,51,.12)">
      <div class="sf-container">
        <h2 style="font-size:1.25rem;font-weight:700;color:#1F1410;margin-bottom:1.25rem">Sık Sorulan Sorular</h2>
        <div style="display:flex;flex-direction:column;gap:.75rem">
          {faqItems.map((item) => (
            <details style="background:var(--bg-card);border:1px solid rgba(184,115,51,.14);border-radius:.375rem;overflow:hidden">
              <summary style="padding:1rem 1.25rem;font-weight:600;color:#1F1410;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:1rem">
                {item.S}
                <span style="flex-shrink:0;color:#B87333;font-size:1.25rem;transition:transform .2s" class="faq-arrow">▾</span>
              </summary>
              <div style="padding:.75rem 1.25rem 1rem;color:#4A3828;font-size:.95rem;line-height:1.7;border-top:1px solid rgba(184,115,51,.08)">
                {item.C}
              </div>
            </details>
          ))}
        </div>
      </div>
    </div>
  )}

  <script type="application/ld+json" set:html={JSON.stringify(buildItemListSchema({
    places: yerler,
    pageName: 'Şanlıurfa En İyi Gezilecek Yerler',
    pagePath: '/en-iyi-gezilecek-yerler',
    baseUrl,
    type: 'TouristAttraction',
    description: "Şanlıurfa'nın en iyi turistik ve tarihi mekanları — müzeler, parklar, dini ve kültürel ziyaret noktaları.",
  }))} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(buildBreadcrumbSchema({
    baseUrl,
    crumbs: [
      { name: 'Ana Sayfa', href: '/' },
      { name: 'Gezilecek Yerler', href: '/gezilecek-yerler' },
      { name: 'En İyi Gezilecek Yerler', href: '/en-iyi-gezilecek-yerler' },
    ],
  }))} is:inline />
  {(() => {
    const faqJson = buildFAQSchema(faqItems);
    return faqJson ? <script type="application/ld+json" set:html={JSON.stringify(faqJson)} is:inline /> : null;
  })()}
</Layout>
