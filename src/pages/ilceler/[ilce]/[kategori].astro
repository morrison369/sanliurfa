---

import Layout from '../../../layouts/Layout.astro';
import PublicCollectionHero from '../../../components/public/PublicCollectionHero.astro';
import PublicCollectionBody from '../../../components/public/PublicCollectionBody.astro';
import PublicSidebarCard from '../../../components/public/PublicSidebarCard.astro';
import PublicFaqList from '../../../components/public/PublicFaqList.astro';
import PlaceCard from '../../../components/PlaceCard.astro';
import { query, queryOne } from '../../../lib/postgres';
import { getCachedPublicRouteData } from '../../../lib/public-route-cache';
import { getMediaAsset, getSeoOverride } from '../../../lib/site-platform';
import { getPublicAppUrl } from '../../../lib/public-app-url';
import { logger } from '../../../lib/logging';
import { resolvePlaceImage } from '../../../lib/public-image-resolvers';
const baseUrl = getPublicAppUrl();

const { ilce, kategori } = Astro.params;
let district: any = null;
let category: any = null;
let places: any[] = [];
let heroImage = '/images/places/balikligol.jpg';
let seoOverridePayload: Record<string, any> | null = null;
let seoOverrideCanonical = '';

try {
 const data = await getCachedPublicRouteData(`page:ilceler:category:${ilce || 'unknown'}:${kategori || 'unknown'}`, async () => {
  const [districtRow, categoryRow] = await Promise.all([
   queryOne("SELECT * FROM districts WHERE slug = $1", [ilce]),
   queryOne("SELECT * FROM categories WHERE slug = $1", [kategori]),
  ]);

  if (!districtRow || !categoryRow) return { district: districtRow, category: categoryRow, places: [] };

  const result = await query(
   `SELECT p.* FROM places p
 JOIN categories c ON p.category_id = c.id
 WHERE p.district_id = $1
 AND (c.slug = $2 OR c.parent_id = (SELECT id FROM categories WHERE slug = $2))
 AND p.status = 'active'
 ORDER BY p.rating DESC`,
   [districtRow.id, kategori]
  );
  return { district: districtRow, category: categoryRow, places: result.rows };
 });
 district = data.district;
 category = data.category;
 if (!district || !category) return Astro.redirect('/ilceler');
 places = data.places;
} catch (e) {
 logger.error('Error:', e instanceof Error ? e : new Error(String(e)));
}

if (!district || !category) return Astro.redirect(`/ilceler/${ilce || ''}`);

try {
 const [heroAsset, seoOverride] = await Promise.all([
 getMediaAsset(
 `district-category.${String(ilce || '').trim()}.${String(kategori || '').trim()}.hero`,
 ),
 getSeoOverride(
 'district-category',
 `${String(ilce || '').trim()}/${String(kategori || '').trim()}`,
 ),
 ]);
 heroImage = String(heroAsset?.url || heroImage);
 seoOverridePayload = seoOverride?.seo_payload || null;
 seoOverrideCanonical = String(seoOverride?.canonical_path || '').trim();
} catch (e) {
 logger.error('Error loading district category platform data:', e instanceof Error ? e : new Error(String(e)));
}

const seo = {
 title: `${district?.name || ilce} ${category?.name || kategori} Mekanları | Şanlıurfa`,
 description: `${district?.name || ilce} ilçesindeki ${(category?.name || kategori).toLowerCase()} mekanlarını keşfedin. Puan, yorum ve konuma göre sıralanmış güncel liste, adres ve iletişim bilgileri.`,
 canonical: `/ilceler/${ilce}/${kategori}`,
 keywords: [
  (district?.name || ilce) + ' ' + (category?.name || kategori).toLowerCase(),
  'şanlıurfa ' + (category?.name || kategori).toLowerCase(),
  (district?.name || ilce) + ' mekanlar',
 ],
 ogImage: '/images/places/balikligol.jpg',
};

if (seoOverridePayload) {
 Object.assign(seo, seoOverridePayload, {
 canonical: seoOverrideCanonical || seoOverridePayload.canonical || seo.canonical,
 });
}
const resolveDistrictCategoryPlaceImage = (place: any) =>
 resolvePlaceImage({
  slug: place?.slug,
  image_url: place?.image_url ?? place?.cover_image ?? null,
  cover_image: place?.cover_image ?? null,
  images: Array.isArray(place?.images) ? place.images : [],
 });
const districtName = district?.name || String(ilce || '');
const categoryName = category?.name || String(kategori || '');
const faqItems = [
 {
  S: `${districtName} ilçesinde ${categoryName} var mı?`,
  C: `${districtName} ilçesinde ${categoryName} kategorisinde birden fazla mekan aktif olarak hizmet vermektedir. Mekanlar puan, yorum sayısı ve öne çıkarılma durumuna göre sıralanmaktadır. Detaylı bilgi edinmek ve iletişime geçmek için her mekan kartına tıklayabilirsiniz.`,
 },
 {
  S: `${districtName} ilçesindeki ${categoryName} mekanlarına nasıl ulaşılır?`,
  C: `Mekan kartlarındaki adres bilgilerine tıklayarak Google Harita veya benzeri uygulamalar üzerinden yol tarifi alabilirsiniz. ${districtName} ilçesindeki mekanların büyük bölümüne şehir merkezi toplu taşıması veya özel araçla kolayca ulaşmak mümkündür.`,
 },
 {
  S: `${districtName} ${categoryName} mekanları yorumlanabilir mi?`,
  C: `Evet, üye girişi yaptıktan sonra ziyaret ettiğiniz her ${categoryName} mekanını puanlayabilir ve yorum bırakabilirsiniz. Yorumlar diğer kullanıcıların doğru mekanı seçmesine yardımcı olmak için yayımlanmaktadır.`,
 },
 {
  S: `${districtName} ilçesinde başka mekan kategorileri var mı?`,
  C: `${districtName} ilçesinde restoran, kafe, sağlık hizmeti, alışveriş, konaklama ve daha pek çok kategoride mekan bulunmaktadır. Tüm kategorileri ve aktif mekanları keşfetmek için ${districtName} ilçe rehber sayfasını ziyaret edebilirsiniz.`,
 },
];

---

<Layout seo={seo}>
 <style is:inline>
 .ik-page{background:var(--bg);min-height:100vh}
 .ik-grid{display:grid;gap:1rem;grid-template-columns:repeat(auto-fit,minmax(250px,1fr))}
 .ik-empty{text-align:center;padding:4rem 0}
 .ik-empty-back{color:var(--public-accent);text-decoration:none;display:inline-block;margin-top:.5rem}
 .ik-empty-back:hover{text-decoration:underline}
 </style>

 <div class="ik-page">
 <PublicCollectionHero
  title={`${district?.name} ${category?.name}`}
  description={`${district?.name} ilçesindeki ${category?.name} mekanları puan, görünürlük ve aktif kayıt durumuna göre listelenir.`}
  imageSrc={heroImage}
  imageAlt={`${district?.name || ilce} ${category?.name || kategori} hero`}
  eyebrow="İlçe Kategori Rehberi"
  breadcrumbItems={[
   { href: '/', label: 'Ana Sayfa' },
   { href: '/ilceler', label: 'İlçeler' },
   { href: `/ilceler/${ilce}`, label: district?.name || ilce },
   { label: category?.name || kategori },
  ]}
  stats={[
   { label: 'Bulunan Mekan', value: places.length },
   { label: 'İlçe', value: district?.name || ilce },
  ]}
 />

 <PublicCollectionBody compactSidebar>
  {places.length > 0 ? (
   <div class="ik-grid">
    {places.map((place) => (
     <PlaceCard
      place={{
       id: String(place.id),
       name: place.name,
       slug: place.slug,
       description: place.short_description || place.address || '',
       image_url: resolveDistrictCategoryPlaceImage(place),
       category: String(kategori || 'general'),
       rating: place.rating,
       review_count: place.review_count,
      }}
     />
    ))}
   </div>
  ) : (
   <div class="ik-empty">
    <p style="color:var(--public-muted)">Bu kategoride mekan bulunmuyor.</p>
    <a href={`/ilceler/${ilce}`} class="ik-empty-back">← {district?.name} Rehberine Dön</a>
   </div>
  )}

  <Fragment slot="sidebar">
   <PublicSidebarCard title="Kategori Özeti">
    <p style="margin:0;color:var(--public-muted);line-height:1.7;font-size:.88rem">
     {district?.name} ilçesindeki {category?.name} mekanları puan, görünürlük ve aktif kayıt durumuna göre listelenir.
    </p>
   </PublicSidebarCard>
   <PublicSidebarCard title="Sık Sorulanlar">
    <PublicFaqList items={faqItems.map((item) => ({ q: item.S, a: item.C }))} />
   </PublicSidebarCard>
  </Fragment>
 </PublicCollectionBody>
 </div>

 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'CollectionPage',
 name: `${district?.name || ilce} ${category?.name || kategori}`,
 description: `${district?.name} ilçesindeki en iyi ${(category?.name || '').toLowerCase()} mekanları.`,
 url: `${baseUrl}/ilceler/${ilce}/${kategori}`,
 about: { '@type': 'City', name: 'Şanlıurfa' },
 itemListElement: places.slice(0, 10).map((p: any, i: number) => ({
 '@type': 'ListItem',
 position: i + 1,
 item: {
 '@type': 'LocalBusiness',
 '@id': `${baseUrl}/isletme/${p.slug}`,
 name: p.name,
 url: `${baseUrl}/isletme/${p.slug}`,
 },
 })),
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'İlçeler', item: `${baseUrl}/ilceler` },
 { '@type': 'ListItem', position: 3, name: district?.name || ilce, item: `${baseUrl}/ilceler/${ilce}` },
 { '@type': 'ListItem', position: 4, name: category?.name || kategori, item: `${baseUrl}/ilceler/${ilce}/${kategori}` },
 ],
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqItems.map((item) => ({
 '@type': 'Question',
 name: item.S,
 acceptedAnswer: { '@type': 'Answer', text: item.C },
 })),
 })} is:inline />
</Layout>
