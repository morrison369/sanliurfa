---
import Layout from '../../layouts/Layout.astro';
import { query } from '../../lib/postgres';
import { getSiteBranding } from '../../lib/site-branding';

let districts: any[] = [];

const fallbackDistricts = [
  { slug: 'eyyubiye', name: 'Eyyübiye', description: 'Balıklıgöl, tarihi çarşılar ve inanç turizmi aksının merkez ilçesi.', is_central: true, sort_order: 1, place_count: 0 },
  { slug: 'haliliye', name: 'Haliliye', description: 'Şehir merkezi, kamu hizmetleri, yeme içme ve günlük yaşam noktalarının yoğun olduğu ilçe.', is_central: true, sort_order: 2, place_count: 0 },
  { slug: 'karakopru', name: 'Karaköprü', description: 'Yeni yaşam alanları, kafeler, konut bölgeleri ve modern şehir aksı.', is_central: true, sort_order: 3, place_count: 0 },
  { slug: 'siverek', name: 'Siverek', description: 'Takoran Vadisi, doğal güzellikler ve geniş kırsal kültürüyle öne çıkan ilçe.', is_central: false, sort_order: 4, place_count: 0 },
  { slug: 'viransehir', name: 'Viranşehir', description: 'Tarih, tarım ve bölgesel ulaşım akslarıyla güçlü bir ilçe merkezi.', is_central: false, sort_order: 5, place_count: 0 },
  { slug: 'suruc', name: 'Suruç', description: 'Yerel kültür, sınır hattı ticareti ve kırsal yaşam dinamikleriyle bilinir.', is_central: false, sort_order: 6, place_count: 0 },
  { slug: 'birecik', name: 'Birecik', description: 'Fırat Nehri, kelaynak kuşları ve nehir kıyısı gezi rotalarıyla tanınır.', is_central: false, sort_order: 7, place_count: 0 },
  { slug: 'akcakale', name: 'Akçakale', description: 'Sınır ticareti, tarım alanları ve yerel pazar kültürüyle öne çıkar.', is_central: false, sort_order: 8, place_count: 0 },
  { slug: 'ceylanpinar', name: 'Ceylanpınar', description: 'Geniş tarım arazileri ve sınır hattı yaşamıyla bilinen ilçe.', is_central: false, sort_order: 9, place_count: 0 },
  { slug: 'halfeti', name: 'Halfeti', description: 'Saklı cennet olarak bilinen, tekne turları ve sular altında kalan tarihi dokusuyla ünlü ilçe.', is_central: false, sort_order: 10, place_count: 0 },
  { slug: 'harran', name: 'Harran', description: 'Kümbet evleri, tarihi üniversite kalıntıları ve Mezopotamya mirasıyla öne çıkar.', is_central: false, sort_order: 11, place_count: 0 },
  { slug: 'hilvan', name: 'Hilvan', description: 'Atatürk Barajı çevresi ve kırsal gezi rotalarıyla bilinir.', is_central: false, sort_order: 12, place_count: 0 },
  { slug: 'bozova', name: 'Bozova', description: 'Atatürk Barajı, su sporları ve doğa rotalarıyla öne çıkan ilçe.', is_central: false, sort_order: 13, place_count: 0 },
];

try {
  const result = await query(
    `SELECT d.*,
            (SELECT COUNT(*) FROM places p WHERE p.district_id = d.id AND p.status = 'active') as place_count
     FROM districts d
     ORDER BY d.is_central DESC, d.sort_order`
  );
  districts = result.rows;
} catch (e) {
  console.error('Error loading districts:', e);
}

if (districts.length === 0) {
  districts = fallbackDistricts;
}

const centralDistricts = districts.filter(d => d.is_central);
const otherDistricts = districts.filter(d => !d.is_central);

const seo = {
  title: 'Şanlıurfa İlçeler Rehberi | Tüm İlçeler ve Yaşam',
  description: 'Şanlıurfa\'nın 13 ilçesi hakkında detaylı bilgi. Eyyübiye, Haliliye, Karaköprü, Siverek, Halfeti ve daha fazlası.',
  keywords: ['şanlıurfa ilçeler', 'urfa eyyübiye', 'urfa haliliye', 'şanlıurfa karaköprü', 'şanlıurfa halfeti', 'urfa harran', 'şanlıurfa siverek', 'şanlıurfa birecik'],
  ogImage: '/images/hero/hero-home.webp',
  canonical: '/ilceler',
};
const { baseUrl } = await getSiteBranding();

const faqItems = [
  {
    S: 'Şanlıurfa merkez ilçeler hangileri?',
    C: 'Merkez ilçeler Eyyübiye, Haliliye ve Karaköprü olarak listelenir.',
  },
  {
    S: 'İlçe sayfalarında ne tür bilgiler var?',
    C: 'İlçe sayfalarında mekan yoğunluğu, temel yaşam bilgileri ve kategori bazlı içerik bağlantıları yer alır.',
  },
  {
    S: 'İlçelere göre mekan araması yapılabilir mi?',
    C: 'Evet. İlçe detay sayfasına girerek ilgili ilçedeki mekanları filtrelenmiş şekilde inceleyebilirsiniz.',
  },
];
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50">
    <div class="bg-gradient-to-br from-teal-700 to-teal-900 text-white py-16">
      <div class="container mx-auto px-4">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Şanlıurfa İlçeleri</h1>
        <p class="text-xl text-teal-100">13 ilçe, binlerce yıllık tarih ve kültür</p>
      </div>
    </div>

    <div class="container mx-auto px-4 py-12">
      <div class="rounded-2xl border border-teal-100 bg-teal-50 p-5 mb-8">
        <h2 class="text-lg font-bold text-teal-900">Hızlı Cevap</h2>
        <p class="text-sm text-teal-800 mt-1">
          İlçe rehberi üzerinden Şanlıurfa’nın tüm ilçelerini tek ekranda görebilir ve ilçe bazlı mekan içeriklerine geçiş yapabilirsiniz.
        </p>
      </div>

      {/* Merkez İlçeler */}
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Merkez İlçeler</h2>
      <div class="grid md:grid-cols-3 gap-6 mb-12">
        {centralDistricts.map((d) => (
          <a href={`/ilceler/${d.slug}`} class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all group">
            <div class="h-40 bg-gradient-to-br from-teal-100 to-cyan-100 flex items-center justify-center">
              <span class="text-6xl opacity-60">🏙️</span>
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 group-hover:text-teal-600">{d.name}</h3>
              <p class="text-sm text-gray-500 mt-2 line-clamp-2">{d.description}</p>
              <div class="flex items-center gap-4 mt-4 text-sm text-gray-400">
                <span>📍 {d.place_count || 0} mekan</span>
                {d.population && <span>👥 {(d.population / 1000).toFixed(0)}K nüfus</span>}
              </div>
            </div>
          </a>
        ))}
      </div>

      {/* Diğer İlçeler */}
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Diğer İlçeler</h2>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {otherDistricts.map((d) => (
          <a href={`/ilceler/${d.slug}`} class="bg-white rounded-xl p-5 shadow-sm hover:shadow-lg transition-all group">
            <h3 class="font-bold text-gray-900 group-hover:text-teal-600">{d.name}</h3>
            <p class="text-sm text-gray-500 mt-1">{d.place_count || 0} mekan</p>
          </a>
        ))}
      </div>
    </div>
  </div>
  {/* Schema.org */}
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Şanlıurfa İlçeleri',
    description: 'Şanlıurfa\'nın 13 ilçesi',
    numberOfItems: districts.length,
    itemListElement: districts.map((d, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'City',
        name: d.name,
        url: `${baseUrl}/ilceler/${d.slug}`,
        containedInPlace: { '@type': 'AdministrativeArea', name: 'Şanlıurfa' },
      }
    }))
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.C,
      },
    })),
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'İlçeler', item: `${baseUrl}/ilceler` },
    ],
  })} is:inline />
</Layout>