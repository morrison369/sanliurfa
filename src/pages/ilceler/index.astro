---
import Layout from '../../layouts/Layout.astro';
import PublicPageIntro from '../../components/public/PublicPageIntro.astro';
import { query } from '../../lib/postgres';
import { getPublicAppUrl } from '../../lib/public-app-url';
import { logger } from '../../lib/logging';
import { getCachedPublicRouteData } from '../../lib/public-route-cache';

let districts: any[] = [];

const fallbackDistricts = [
 { slug: 'eyyubiye', name: 'Eyyübiye', description: 'Balıklıgöl, tarihi çarşılar ve inanç turizmi aksının merkez ilçesi.', is_central: true, sort_order: 1, place_count: 0 },
 { slug: 'haliliye', name: 'Haliliye', description: 'Şehir merkezi, kamu hizmetleri, yeme içme ve günlük yaşam noktalarının yoğun olduğu ilçe.', is_central: true, sort_order: 2, place_count: 0 },
 { slug: 'karakopru', name: 'Karaköprü', description: 'Yeni yaşam alanları, kafeler, konut bölgeleri ve modern şehir aksı.', is_central: true, sort_order: 3, place_count: 0 },
 { slug: 'siverek', name: 'Siverek', description: 'Takoran Vadisi, doğal güzellikler ve geniş kırsal kültürüyle öne çıkan ilçe.', is_central: false, sort_order: 4, place_count: 0 },
 { slug: 'viransehir', name: 'Viranşehir', description: 'Tarih, tarım ve bölgesel ulaşım akslarıyla güçlü bir ilçe merkezi.', is_central: false, sort_order: 5, place_count: 0 },
 { slug: 'suruc', name: 'Suruç', description: 'Yerel kültür, sınır hattı ticareti ve kırsal yaşam dinamikleriyle bilinir.', is_central: false, sort_order: 6, place_count: 0 },
 { slug: 'birecik', name: 'Birecik', description: 'Fırat Nehri, kelaynak kuşları ve nehir kıyısı gezi rotalarıyla tanınır.', is_central: false, sort_order: 7, place_count: 0 },
 { slug: 'akcakale', name: 'Akçakale', description: 'Sınır ticareti, tarım alanları ve yerel pazar kültürüyle öne çıkar.', is_central: false, sort_order: 8, place_count: 0 },
 { slug: 'ceylanpinar', name: 'Ceylanpınar', description: 'Geniş tarım arazileri ve sınır hattı yaşamıyla bilinen ilçe.', is_central: false, sort_order: 9, place_count: 0 },
 { slug: 'halfeti', name: 'Halfeti', description: 'Saklı cennet olarak bilinen, tekne turları ve sular altında kalan tarihi dokusuyla ünlü ilçe.', is_central: false, sort_order: 10, place_count: 0 },
 { slug: 'harran', name: 'Harran', description: 'Kümbet evleri, tarihi üniversite kalıntıları ve Mezopotamya mirasıyla öne çıkar.', is_central: false, sort_order: 11, place_count: 0 },
 { slug: 'hilvan', name: 'Hilvan', description: 'Atatürk Barajı çevresi ve kırsal gezi rotalarıyla bilinir.', is_central: false, sort_order: 12, place_count: 0 },
 { slug: 'bozova', name: 'Bozova', description: 'Atatürk Barajı, su sporları ve doğa rotalarıyla öne çıkan ilçe.', is_central: false, sort_order: 13, place_count: 0 },
];

try {
 const data = await getCachedPublicRouteData('page:ilceler:index', async () => {
  const result = await query(
  `SELECT d.*,
  (SELECT COUNT(*) FROM places p WHERE p.district_id = d.id AND p.status = 'active') as place_count
  FROM districts d
  ORDER BY d.is_central DESC, d.sort_order`
  );
  return { districts: result.rows };
 });
 districts = data.districts;
} catch (e) {
 logger.error('Error loading districts:', e instanceof Error ? e : new Error(String(e)));
}

if (districts.length === 0) {
 districts = fallbackDistricts;
}

const centralDistricts = districts.filter(d => d.is_central);
const otherDistricts = districts.filter(d => !d.is_central);

const seo = {
 title: 'Şanlıurfa İlçeler Rehberi | Tüm İlçeler ve Yaşam',
 description: 'Şanlıurfa\'nın 13 ilçesi hakkında detaylı bilgi. Eyyübiye, Haliliye, Karaköprü, Siverek, Halfeti ve daha fazlası.',
 keywords: ['şanlıurfa ilçeler', 'urfa eyyübiye', 'urfa haliliye', 'şanlıurfa karaköprü', 'şanlıurfa halfeti', 'urfa harran', 'şanlıurfa siverek', 'şanlıurfa birecik'],
 canonical: '/ilceler',
};

const baseUrl = getPublicAppUrl();

const faqItems = [
 { S: 'Şanlıurfa merkez ilçeler hangileri?', C: 'Merkez ilçeler Eyyübiye, Haliliye ve Karaköprü olarak listelenir.' },
 { S: 'İlçe sayfalarında ne tür bilgiler var?', C: 'İlçe sayfalarında mekan yoğunluğu, temel yaşam bilgileri ve kategori bazlı içerik bağlantıları yer alır.' },
 { S: 'İlçelere göre mekan araması yapılabilir mi?', C: 'Evet. İlçe detay sayfasına girerek ilgili ilçedeki mekanları filtrelenmiş şekilde inceleyebilirsiniz.' },
];
---

<Layout seo={seo}>
 <style is:inline>
 .il-body{padding:2.5rem 0 5rem}
 .il-section-title{font-family:'Cormorant Garamond',serif;font-size:1.35rem;font-weight:600;color:var(--public-text);margin-bottom:1.25rem}
 .il-grid-central{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.25rem;margin-bottom:3rem}
 .il-grid-other{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:.75rem;margin-bottom:2rem}
 .il-card{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);text-decoration:none;display:block;transition:border-color .15s,background .15s}
 .il-card:hover{border-color:rgba(184,115,51,.35);background:var(--bg-hover)}
 .il-card-img{height:9rem;background:rgba(184,115,51,.06);display:flex;align-items:center;justify-content:center}
 .il-card-emoji{font-size:3rem;opacity:.5}
 .il-card-body{padding:1.25rem}
 .il-card-name{font-size:.95rem;font-weight:700;color:var(--public-text);margin-bottom:.35rem;transition:color .15s}
 .il-card:hover .il-card-name{color:var(--public-accent)}
 .il-card-desc{font-size:.78rem;color:var(--public-muted);line-height:1.55;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
 .il-card-meta{font-size:.72rem;color:var(--public-text-soft);margin-top:.75rem}
 .il-card-sm{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);padding:1rem 1.25rem;text-decoration:none;display:block;transition:border-color .15s,background .15s}
 .il-card-sm:hover{border-color:rgba(184,115,51,.35);background:var(--bg-hover)}
 .il-card-sm-name{font-size:.875rem;font-weight:600;color:var(--public-accent);margin-bottom:.2rem;transition:color .15s}
 .il-card-sm:hover .il-card-sm-name{color:var(--public-text)}
 .il-card-sm-meta{font-size:.72rem;color:var(--public-text-soft)}
 </style>

 <PublicPageIntro
  eyebrow="Şanlıurfa"
  title="Şanlıurfa İlçeleri"
  description="13 ilçe, binlerce yıllık tarih ve kültür."
  quickAnswerTitle="Hızlı Cevap"
  quickAnswerText="İlçe rehberi üzerinden Şanlıurfa'nın tüm ilçelerini tek ekranda görebilir ve ilçe bazlı mekan içeriklerine geçiş yapabilirsiniz."
 />

 <!-- Content -->
 <div class="sf-container il-body">
 <h2 class="il-section-title">Merkez İlçeler</h2>
 <div class="il-grid-central">
 {centralDistricts.map((d) => (
 <a href={`/ilceler/${d.slug}`} class="il-card">
 <div class="il-card-img">
 <span class="il-card-emoji" aria-hidden="true">🏙️</span>
 </div>
 <div class="il-card-body">
 <p class="il-card-name">{d.name}</p>
 <p class="il-card-desc">{d.description}</p>
 <p class="il-card-meta">
 {d.place_count || 0} mekan
 {d.population ? ` · ${(d.population / 1000).toFixed(0)}K nüfus` : ''}
 </p>
 </div>
 </a>
 ))}
 </div>

 <h2 class="il-section-title">Diğer İlçeler</h2>
 <div class="il-grid-other">
 {otherDistricts.map((d) => (
 <a href={`/ilceler/${d.slug}`} class="il-card-sm">
 <p class="il-card-sm-name">{d.name}</p>
 <p class="il-card-sm-meta">{d.place_count || 0} mekan</p>
 </a>
 ))}
 </div>
 </div>

 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org', '@type': 'ItemList',
 name: 'Şanlıurfa İlçeleri',
 description: 'Şanlıurfa\'nın 13 ilçesi',
 numberOfItems: districts.length,
 itemListElement: districts.map((d, i) => ({
 '@type': 'ListItem', position: i + 1,
 item: {
 '@type': 'City', name: d.name,
 url: `${baseUrl}/ilceler/${d.slug}`,
 containedInPlace: { '@type': 'AdministrativeArea', name: 'Şanlıurfa' },
 },
 })),
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org', '@type': 'FAQPage',
 mainEntity: faqItems.map(item => ({
 '@type': 'Question', name: item.S,
 acceptedAnswer: { '@type': 'Answer', text: item.C },
 })),
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org', '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'İlçeler', item: `${baseUrl}/ilceler` },
 ],
 })} is:inline />
</Layout>
