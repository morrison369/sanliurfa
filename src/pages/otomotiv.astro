---
import Layout from '../layouts/Layout.astro';
import CategoryHub from '../components/public/CategoryHub.astro';
import { CITY_TAXONOMY_CATEGORIES } from '../data/city-taxonomy';
import { getPublicAppUrl } from '../lib/public-app-url';
const category = CITY_TAXONOMY_CATEGORIES.find((item) => item.slug === 'otomotiv')!;
const baseUrl = getPublicAppUrl();

const faqItems = [
 {
  S: "Şanlıurfa'da yetkili araç servisi nasıl bulunur?",
  C: "Otomotiv kategorisinde Şanlıurfa'daki yetkili servisler, bağımsız tamirhaneler ve oto elektrikçiler listelenmektedir. Marka ve ilçe bazlı arama yaparak size en uygun servise ulaşabilirsiniz.",
 },
 {
  S: "Şanlıurfa'da araç muayene ve ekspertiz nerede yapılır?",
  C: "TÜVTÜRK araç muayene istasyonları ve bağımsız ekspertiz merkezleri Otomotiv kategorisinde bulunabilir. Randevu saatleri ve adres bilgilerine profil sayfalarından ulaşılabilir.",
 },
 {
  S: "Şanlıurfa'da oto yıkama ve detay hizmeti nerede aranır?",
  C: "Oto yıkama, iç temizlik ve detay hizmetleri sunan merkezler Otomotiv kategorisinde listelenmektedir. Konum ve fiyat bilgilerini karşılaştırarak en uygun hizmeti seçebilirsiniz.",
 },
];
---
<Layout seo={{ title: 'Şanlıurfa Otomotiv Rehberi | Servis, Ekspertiz ve Oto Yıkama', description: category.description, canonical: '/otomotiv' }}>
 <style is:inline>
 details summary{list-style:none}
 details summary::-webkit-details-marker{display:none}
 details[open] .faq-arrow{transform:rotate(180deg)}
 </style>
 <CategoryHub category={category} />
 {faqItems.length > 0 && (
 <div style="padding:2rem 0 3rem;border-top:1px solid rgba(184,115,51,.12)">
 <div class="sf-container">
 <h2 style="font-size:1.25rem;font-weight:700;color:#1F1410;margin-bottom:1.25rem">Sık Sorulan Sorular</h2>
 <div style="display:flex;flex-direction:column;gap:.75rem">
 {faqItems.map((item) => (
 <details style="background:var(--bg-card);border:1px solid rgba(184,115,51,.14);border-radius:.375rem;overflow:hidden">
 <summary style="padding:1rem 1.25rem;font-weight:600;color:#1F1410;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:1rem">
 {item.S}
 <span style="flex-shrink:0;color:#B87333;font-size:1.25rem;transition:transform .2s" class="faq-arrow">▾</span>
 </summary>
 <div style="padding:.75rem 1.25rem 1rem;color:#4A3828;font-size:.95rem;line-height:1.7;border-top:1px solid rgba(184,115,51,.08)">
 {item.C}
 </div>
 </details>
 ))}
 </div>
 </div>
 </div>
 )}
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqItems.map((item) => ({
 '@type': 'Question',
 name: item.S,
 acceptedAnswer: { '@type': 'Answer', text: item.C },
 })),
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'Otomotiv', item: `${baseUrl}/otomotiv` },
 ],
 })} is:inline />
</Layout>
