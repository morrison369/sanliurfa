---
// @ts-nocheck
import Layout from "../layouts/Layout.astro";
import LeaderboardsDisplay from "../components/LeaderboardsDisplay";
---

<Layout
  title="Şanlıurfa Topluluk Liderlik Tablosu - sanliurfa.com"
  description="Şanlıurfa mekan, yorum, keşif ve katkı puanlarına göre topluluk liderlik tablosu."
>
  <div class="container-custom py-10">
    <div
      class="mb-8 rounded-3xl bg-gradient-to-br from-urfa-900 via-urfa-800 to-isot-800 p-8 text-white shadow-xl"
    >
      <p
        class="mb-3 text-sm font-semibold uppercase tracking-[0.28em] text-amber-200"
      >
        Şanlıurfa topluluğu
      </p>
      <h1 class="text-4xl font-bold">Liderlik tablosu</h1>
      <p class="mt-3 max-w-3xl text-amber-50">
        Şanlıurfa mekanlarını yorumlayan, rota oluşturan, fotoğraf ve yerel
        bilgi ekleyen en aktif üyeleri keşfet.
      </p>
    </div>

    <LeaderboardsDisplay client:load currentUserId={Astro.locals.user?.id} />
  </div>
</Layout>
