---
import Layout from '../../layouts/Layout.astro';
import { query } from '../../lib/postgres';
import { getCachedPublicRouteData } from '../../lib/public-route-cache';
import { getPublicAppUrl } from '../../lib/public-app-url';
import { logger } from '../../lib/logging';
import PublicFaqList from '../../components/public/PublicFaqList.astro';
const baseUrl = getPublicAppUrl();

let featuredPlaces: any[] = [];

const egitimCategories = [
 { slug: 'anaokullari', name: 'Anaokulları', icon: '🎨', desc: 'Anaokulu ve kreşler' },
 { slug: 'okullar', name: 'İlk ve Ortaokullar', icon: '🏫', desc: 'İlkokul, ortaokul, lise' },
 { slug: 'universiteler', name: 'Üniversiteler', icon: '🎓', desc: 'Harran Üniversitesi ve diğerleri' },
 { slug: 'dershaneler', name: 'Dershaneler', icon: '📚', desc: 'Etüt ve dershaneler' },
 { slug: 'kurslar', name: 'Kurslar', icon: '🎯', desc: 'Dil, sürücü ve özel kurslar' },
];

try {
 featuredPlaces = await getCachedPublicRouteData('page:egitim:index', async () => {
  const placesResult = await query(
   `SELECT p.*, c.name as category_name FROM places p
 LEFT JOIN categories c ON p.category_id = c.id
 WHERE c.slug IN ('anaokullari','okullar','universiteler','dershaneler','kurslar')
 AND p.status = 'active'
 ORDER BY p.rating DESC LIMIT 6`
  );
  return placesResult.rows;
 });
} catch (e) {
 logger.error('Error loading egitim:', e instanceof Error ? e : new Error(String(e)));
}

const seo = {
 title: 'Şanlıurfa Eğitim Rehberi | Okullar, Üniversiteler ve Kurslar',
 description: "Şanlıurfa'da anaokulları, ilk ve ortaokullar, Harran Üniversitesi, dershaneler ve özel kurslar.",
 keywords: ['şanlıurfa okullar', 'harran üniversitesi', 'şanlıurfa dershaneler', 'urfa özel kurslar', 'şanlıurfa anaokulu', 'urfa eğitim', 'şanlıurfa üniversite'],
 ogImage: '/images/places/balikligol.jpg',
 canonical: '/egitim',
};

const faqItems = [
 { S: "Şanlıurfa'da hangi üniversite var?", C: "Şanlıurfa'nın tek devlet üniversitesi 1992 yılında kurulan Harran Üniversitesi'dir. Pek çok fakülte ve yüksekokuldan oluşur." },
 { S: 'Harran Üniversitesi nerede?', C: "Harran Üniversitesi'nin merkez kampüsü Şanlıurfa şehir merkezinde yer almaktadır. Tıp fakültesi ve bazı birimler farklı lokasyonlardadır." },
 { S: "Şanlıurfa'da dershane ve etüt merkezi var mı?", C: "Evet. Şanlıurfa'da sınav hazırlık dershaneleri, etüt merkezleri ve çeşitli özel kurslar bulunmaktadır. Eğitim rehberindeki dershaneler kategorisinden listeye ulaşabilirsiniz." },
];
---

<Layout seo={seo}>
 <style>
 .eg-hero{position:relative;overflow:hidden;border-bottom:1px solid rgba(184,115,51,0.12);padding:clamp(3rem,6vw,5rem) 0;background:radial-gradient(circle at 18% 0%,rgba(212,151,24,0.10) 0%,transparent 42%),radial-gradient(circle at 82% 100%,rgba(44,122,82,0.08) 0%,transparent 40%),linear-gradient(180deg,#fbf6ec 0%,#f4ecd8 58%,#fbf6ec 100%)}
 .eg-eyebrow{font-size:.7rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--public-muted);margin-bottom:.5rem}
 .eg-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.9rem,4vw,3rem);font-weight:600;color:var(--public-text);margin-bottom:.5rem}
 .eg-sub{font-size:.9rem;color:var(--public-muted);max-width:38rem;line-height:1.75}
 .eg-body{background:var(--public-bg);padding:2.5rem 0 5rem}
 .eg-info-box{background:var(--public-accent-soft);border:1px solid var(--public-border);padding:1.25rem 1.5rem;margin-bottom:2rem}
 .eg-info-title{font-size:1rem;font-weight:700;color:var(--public-text);margin-bottom:.4rem}
 .eg-info-text{font-size:.82rem;color:var(--public-muted);line-height:1.7}
 .eg-section-title{font-family:'Cormorant Garamond',serif;font-size:1.25rem;font-weight:600;color:var(--public-text);margin-bottom:1.1rem}
 .eg-cat-grid{display:grid;gap:.85rem;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));margin-bottom:2.5rem}
 .eg-cat-card{background:var(--public-surface);border:1px solid var(--public-border);padding:1.25rem;text-align:center;transition:border-color .15s,transform .15s}
 .eg-cat-card:hover{border-color:var(--public-accent);transform:translateY(-2px)}
 .eg-cat-icon{font-size:1.75rem;margin-bottom:.5rem}
 .eg-cat-name{font-size:.8rem;font-weight:700;color:var(--public-text);margin-bottom:.15rem;transition:color .15s}
 .eg-cat-card:hover .eg-cat-name{color:var(--public-accent)}
 .eg-cat-desc{font-size:.68rem;color:var(--public-muted)}
 .eg-feat-grid{display:grid;gap:.85rem;grid-template-columns:repeat(auto-fill,minmax(260px,1fr))}
 .eg-feat-card{background:var(--public-surface);border:1px solid var(--public-border);padding:1rem;display:flex;align-items:flex-start;gap:.75rem;transition:border-color .15s}
 .eg-feat-card:hover{border-color:var(--public-accent)}
 .eg-feat-icon{font-size:1.4rem;flex-shrink:0}
 .eg-feat-name{font-size:.85rem;font-weight:700;color:var(--public-text);margin-bottom:.15rem;transition:color .15s}
 .eg-feat-card:hover .eg-feat-name{color:var(--public-accent)}
 .eg-feat-cat{font-size:.7rem;color:var(--public-accent);font-weight:600;margin-bottom:.15rem}
 .eg-feat-addr{font-size:.72rem;color:var(--public-text-soft)}
 .eg-hero-inner{max-width:50rem;margin:0 auto}
 </style>

 <div class="eg-hero">
 <div class="sf-container">
 <div class="eg-hero-inner">
 <p class="eg-eyebrow">Eğitim Rehberi</p>
 <h1 class="eg-h1">Eğitim Rehberi</h1>
 <p class="eg-sub">Şanlıurfa'da okullar, üniversiteler, dershaneler ve kurslar</p>
 </div>
 </div>
 </div>

 <div class="eg-body">
 <div class="sf-container">
 <div class="eg-info-box">
 <p class="eg-info-title">🎓 Harran Üniversitesi</p>
 <p class="eg-info-text">Şanlıurfa'nın köklü üniversitesi — 1992 yılında kurulan Harran Üniversitesi, pek çok fakülte ve yüksekokul ile hizmet vermektedir.</p>
 </div>

 <h2 class="eg-section-title">Eğitim Kategorileri</h2>
 <div class="eg-cat-grid">
 {egitimCategories.map((cat) => (
 <a href={`/egitim/${cat.slug}`} class="eg-cat-card">
 <div class="eg-cat-icon">{cat.icon}</div>
 <p class="eg-cat-name">{cat.name}</p>
 <p class="eg-cat-desc">{cat.desc}</p>
 </a>
 ))}
 </div>

 {featuredPlaces.length > 0 && (
 <div>
 <h2 class="eg-section-title">Öne Çıkan Eğitim Kurumları</h2>
 <div class="eg-feat-grid">
 {featuredPlaces.map((place) => (
 <a href={`/isletme/${place.slug}`} class="eg-feat-card">
 <span class="eg-feat-icon">🏫</span>
 <div>
 <p class="eg-feat-name">{place.name}</p>
 <p class="eg-feat-cat">{place.category_name}</p>
 {place.address && <p class="eg-feat-addr">📍 {place.address}</p>}
 </div>
 </a>
 ))}
 </div>
 </div>
 )}

 {faqItems.length > 0 && (
  <div style="margin-top:3rem">
   <PublicFaqList items={faqItems} />
  </div>
 )}
 </div>
 </div>

 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'CollectionPage',
 name: 'Şanlıurfa Eğitim Rehberi',
 description: "Şanlıurfa'daki okullar, üniversiteler, kurslar ve eğitim kurumları.",
 url: `${baseUrl}/egitim`,
 about: { '@type': 'City', name: 'Şanlıurfa' },
 itemListElement: featuredPlaces.slice(0, 10).map((p: any, i: number) => ({
 '@type': 'ListItem',
 position: i + 1,
 item: { '@type': 'EducationalOrganization', name: p.name, url: `${baseUrl}/isletme/${p.slug}` },
 })),
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'Eğitim', item: `${baseUrl}/egitim` },
 ],
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqItems.map((item) => ({
 '@type': 'Question',
 name: item.S,
 acceptedAnswer: { '@type': 'Answer', text: item.C },
 })),
 })} is:inline />
</Layout>
