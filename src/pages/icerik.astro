---
import Layout from '../layouts/Layout.astro';
import { ContentManager } from '../components/ContentManager';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/giris?redirect=/icerik');
}
---

<Layout seo={{ title: "İçerik Yönetimi - Şanlıurfa", noIndex: true }}>
  <div class="min-h-screen bg-[#FDFAF3]">
    <div class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)] text-white py-10">
      <div class="container mx-auto px-4">
        <p class="text-sm font-semibold uppercase tracking-widest text-[#9A8470] mb-2">HESABIM</p>
        <h1 class="text-3xl font-bold text-[#F5EDD6]">İçerik Yönetimi</h1>
        <p class="text-[#9A8470] mt-1">Şanlıurfa hakkında makale ve içerik oluşturun ve yayınlayın</p>
      </div>
    </div>

    <div class="container mx-auto px-4 py-8">
      <ContentManager client:visible />

      <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-[rgba(200,160,100,0.06)] border border-[rgba(200,160,100,0.2)] rounded-sm p-6">
          <h3 class="font-semibold text-[#1A1008] mb-2">Kolay Oluşturma</h3>
          <p class="text-sm text-[#6B5540]">Basit editör ile profesyonel içerik oluşturun.</p>
        </div>

        <div class="bg-[rgba(200,160,100,0.06)] border border-[rgba(200,160,100,0.2)] rounded-sm p-6">
          <h3 class="font-semibold text-[#1A1008] mb-2">Hızlı Yayınlama</h3>
          <p class="text-sm text-[#6B5540]">Bir tıkla içeriğinizi yayınlayın ve paylaşın.</p>
        </div>

        <div class="bg-[rgba(200,160,100,0.06)] border border-[rgba(200,160,100,0.2)] rounded-sm p-6">
          <h3 class="font-semibold text-[#1A1008] mb-2">Analitikler</h3>
          <p class="text-sm text-[#6B5540]">İçeriğinizin performansını izleyin.</p>
        </div>
      </div>
    </div>
  </div>
</Layout>
