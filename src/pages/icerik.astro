---
import Layout from '../layouts/Layout.astro';
import { ContentManager } from '../components/ContentManager';

const user = Astro.locals.user;
if (!user) {
 return Astro.redirect('/giris?redirect=/icerik');
}
---

<Layout seo={{ title: "İçerik Yönetimi - Şanlıurfa", noIndex: true }}>
 <style is:inline>
 .ic-hero{position:relative;overflow:hidden;border-bottom:1px solid rgba(184,115,51,.12);padding:2.5rem 0;background:radial-gradient(circle at 18% 0%,rgba(212,151,24,.10) 0%,transparent 42%),radial-gradient(circle at 82% 100%,rgba(44,122,82,.08) 0%,transparent 40%),linear-gradient(180deg,#fbf6ec 0%,#f4ecd8 58%,#fbf6ec 100%)}
 .ic-label{font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--public-text-soft)}
 .ic-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.5rem,3.5vw,2.2rem);font-weight:700;color:var(--public-text);margin:.5rem 0 .25rem}
 .ic-hero-desc{color:var(--public-muted);font-size:.9rem}
 .ic-body{background:var(--bg);padding:2rem 0 4rem}
 .ic-manager{margin-bottom:2rem}
 .ic-cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem;margin-top:2rem}
 .ic-card{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);padding:1.5rem}
 .ic-card-title{font-size:.9rem;font-weight:700;color:var(--public-text);margin-bottom:.4rem}
 .ic-card-desc{font-size:.8rem;color:var(--public-muted);line-height:1.6}
 </style>

 <div class="ic-hero">
 <div class="sf-container">
 <p class="ic-label">Hesabım</p>
 <h1 class="ic-h1">İçerik Yönetimi</h1>
 <p class="ic-hero-desc">Şanlıurfa hakkında makale ve içerik oluşturun ve yayınlayın</p>
 </div>
 </div>

 <div class="ic-body">
 <div class="sf-container">
 <div class="ic-manager">
 <ContentManager client:visible />
 </div>

 <div class="ic-cards">
 <div class="ic-card">
 <h3 class="ic-card-title">Kolay Oluşturma</h3>
 <p class="ic-card-desc">Basit editör ile profesyonel içerik oluşturun.</p>
 </div>
 <div class="ic-card">
 <h3 class="ic-card-title">Hızlı Yayınlama</h3>
 <p class="ic-card-desc">Bir tıkla içeriğinizi yayınlayın ve paylaşın.</p>
 </div>
 <div class="ic-card">
 <h3 class="ic-card-title">Analitikler</h3>
 <p class="ic-card-desc">İçeriğinizin performansını izleyin.</p>
 </div>
 </div>
 </div>
 </div>
</Layout>
