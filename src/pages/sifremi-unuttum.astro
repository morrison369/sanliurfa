---
import Layout from '../layouts/Layout.astro';
import { actions, isInputError } from 'astro:actions';

// SVG ikonlar
const icons = {
  mail: `<svg class="h-12 w-12 text-red-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
  mailLg: `<svg class="h-16 w-16 text-red-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
  arrowLeft: `<svg class="w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>`,
  checkCircle: `<svg class="w-5 h-5 text-green-500 mr-2 flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
  alertCircle: `<svg class="w-5 h-5 text-red-500 mr-2 flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
};

const seo = {
  title: 'Şifremi Unuttum - Sanliurfa.com',
  description: 'Şifrenizi sıfırlayın',
  noIndex: true
};

const success = Astro.url.searchParams.get('success');
const error = Astro.url.searchParams.get('error');
const result = Astro.getActionResult(actions.requestPasswordReset);
const inputErrors = isInputError(result?.error) ? result.error.fields : {};
const submitError =
  !isInputError(result?.error) && result?.error?.message
    ? result.error.message
    : null;
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50 flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full">
      <div class="bg-white rounded-2xl shadow-lg p-8">
        <div class="text-center mb-8">
          <div class="mx-auto h-16 w-16 bg-red-100 rounded-2xl flex items-center justify-center mb-4">
            <span set:html={icons.mail}></span>
          </div>
          <h2 class="text-2xl font-bold text-gray-900">
            Şifremi Unuttum
          </h2>
          <p class="mt-2 text-sm text-gray-600">
            E-posta adresinizi girin, şifre sıfırlama bağlantısını gönderelim.
          </p>
        </div>
        
        {success || (result && !result.error) ? (
          <div class="bg-green-50 border border-green-200 rounded-xl p-4 mb-6">
            <div class="flex items-start gap-3">
              <span set:html={icons.checkCircle}></span>
              <div>
                <p class="text-green-800 font-medium">
                  Bağlantı Gönderildi
                </p>
                <p class="text-green-700 text-sm mt-1">
                  {result?.data?.message || 'E-posta adresinize şifre sıfırlama bağlantısı gönderdik. Lütfen gelen kutunuzu kontrol edin.'}
                </p>
              </div>
            </div>
          </div>
        ) : (
          <form action={actions.requestPasswordReset} method="POST" class="space-y-6">
            {(error || submitError) && (
              <div class="bg-red-50 border border-red-200 rounded-xl p-4">
                <div class="flex items-start gap-3">
                  <span set:html={icons.alertCircle}></span>
                  <div>
                    <p class="text-red-800 font-medium">
                      {error === 'email_not_found' ? 'E-posta adresi bulunamadı' : 'Bir hata oluştu'}
                    </p>
                    <p class="text-red-700 text-sm mt-1">
                      {submitError || (error === 'email_not_found' 
                        ? 'Bu e-posta adresiyle kayıtlı bir hesap bulunmuyor.' 
                        : 'Lütfen tekrar deneyin.')}
                    </p>
                  </div>
                </div>
              </div>
            )}
            
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">E-posta Adresi</label>
              <div class="relative mt-1">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                  <span set:html={icons.mail}></span>
                </div>
                <input
                  id="email"
                  name="email"
                  type="email"
                  required
                  aria-invalid={inputErrors.email ? 'true' : 'false'}
                  class="w-full px-4 py-3 pl-10 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent"
                  placeholder="ornek@email.com"
                />
              </div>
              {inputErrors.email && (
                <p class="mt-2 text-sm text-red-600">{inputErrors.email.join(', ')}</p>
              )}
            </div>
            
            <button 
              type="submit" 
              class="w-full py-3 bg-red-600 text-white rounded-lg font-medium hover:bg-red-700 transition-colors"
            >
              Sıfırlama Bağlantısı Gönder
            </button>
          </form>
        )}
        
        <div class="mt-6 text-center">
          <a href="/giris" class="inline-flex items-center gap-2 text-sm text-red-600 hover:text-red-700">
            <span set:html={icons.arrowLeft}></span>
            Giriş sayfasına dön
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>
