---
import { Icon } from 'astro-icon/components';
import Layout from '../layouts/Layout.astro';
import { actions, isInputError } from 'astro:actions';

const seo = {
  title: 'Şifremi Unuttum - Sanliurfa.com',
  description: 'Sanliurfa.com şifrenizi sıfırlayın. E-posta adresinizi girerek yeni şifre belirleme bağlantısı alın.',
  noIndex: true
};

const success = Astro.url.searchParams.get('success');
const error = Astro.url.searchParams.get('error');
const result = Astro.getActionResult(actions.requestPasswordReset);
const inputErrors = isInputError(result?.error) ? result.error.fields : {};
const submitError =
  !isInputError(result?.error) && result?.error?.message
    ? result.error.message
    : null;
---

<Layout seo={seo} hideFooter>
  <div class="min-h-screen bg-[#0D0A08] flex items-center justify-center py-12 px-4">
    <div class="max-w-md w-full">
      <div class="text-center mb-8">
        <a href="/" style="display:inline-flex;align-items:baseline;gap:0.0625rem;text-decoration:none;">
          <span style="font-family:'Cormorant Garamond',Georgia,serif;font-size:2rem;font-weight:300;font-style:italic;color:#F5EDD6;letter-spacing:-0.02em;">Sanliurfa</span>
          <span style="font-family:'Jost',sans-serif;font-size:1rem;font-weight:700;color:#CE8E38;letter-spacing:0.06em;">.com</span>
        </a>
      </div>

      <div class="bg-[#FDFAF3] border border-[rgba(200,160,100,0.22)] rounded-sm shadow-2xl shadow-black/40 p-8">
        <div class="text-center mb-8">
          <div class="mx-auto h-16 w-16 bg-[rgba(200,160,100,0.1)] border border-[rgba(200,160,100,0.2)] rounded-sm flex items-center justify-center mb-4">
            <Icon name="lucide:mail" class="h-10 w-10 text-urfa-600" />
          </div>
          <h2 class="text-2xl font-bold text-[#1A1008]">
            Şifremi Unuttum
          </h2>
          <p class="mt-2 text-sm text-[#9A8470]">
            E-posta adresinizi girin, şifre sıfırlama bağlantısını gönderelim.
          </p>
        </div>

        {success || (result && !result.error) ? (
          <div class="bg-green-50 border border-green-200 rounded-sm p-4 mb-6">
            <div class="flex items-start gap-3">
              <Icon name="lucide:check-circle" class="w-5 h-5 text-green-500 shrink-0 mt-0.5" />
              <div>
                <p class="text-green-800 font-medium">
                  Bağlantı Gönderildi
                </p>
                <p class="text-green-700 text-sm mt-1">
                  {result?.data?.message || 'E-posta adresinize şifre sıfırlama bağlantısı gönderdik. Lütfen gelen kutunuzu kontrol edin.'}
                </p>
              </div>
            </div>
          </div>
        ) : (
          <form action={actions.requestPasswordReset} method="POST" class="space-y-6">
            {(error || submitError) && (
              <div class="bg-isot-50 border border-isot-200 rounded-sm p-4">
                <div class="flex items-start gap-3">
                  <Icon name="lucide:alert-circle" class="w-5 h-5 text-isot-500 shrink-0 mt-0.5" />
                  <div>
                    <p class="text-isot-700 font-medium">
                      {error === 'email_not_found' ? 'E-posta adresi bulunamadı' : 'Bir hata oluştu'}
                    </p>
                    <p class="text-isot-600 text-sm mt-1">
                      {submitError || (error === 'email_not_found'
                        ? 'Bu e-posta adresiyle kayıtlı bir hesap bulunmuyor.'
                        : 'Lütfen tekrar deneyin.')}
                    </p>
                  </div>
                </div>
              </div>
            )}

            <div>
              <label for="email" class="block text-sm font-medium text-[#4A3828] mb-1">E-posta Adresi</label>
              <div class="relative mt-1">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                  <Icon name="lucide:mail" class="h-5 w-5 text-[#9A8470]" />
                </div>
                <input
                  id="email"
                  name="email"
                  type="email"
                  required
                  aria-invalid={inputErrors.email ? 'true' : 'false'}
                  class="w-full px-4 py-3 pl-10 border border-[rgba(200,160,100,0.3)] rounded-sm focus:ring-2 focus:ring-urfa-400 focus:border-transparent bg-white"
                  placeholder="ornek@email.com"
                />
              </div>
              {inputErrors.email && (
                <p class="mt-2 text-sm text-isot-600">{inputErrors.email.join(', ')}</p>
              )}
            </div>

            <button
              type="submit"
              class="w-full py-3 bg-urfa-600 text-white rounded-sm font-medium hover:bg-urfa-700 transition-colors tracking-wide"
            >
              Sıfırlama Bağlantısı Gönder
            </button>
          </form>
        )}

        <div class="mt-6 text-center">
          <a href="/giris" class="inline-flex items-center gap-2 text-sm text-urfa-600 hover:text-urfa-700 transition-colors">
            <Icon name="lucide:arrow-left" class="w-4 h-4" />
            Giriş sayfasına dön
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>
