---

import Layout from '../layouts/Layout.astro';
import { query } from '../lib/postgres';
import { getSiteBranding } from '../lib/site-branding';
import { logger } from '../lib/logging';
const { baseUrl } = await getSiteBranding();

let recipes: any[] = [];
let topRestaurants: any[] = [];

try {
  const [recipesResult, restaurantsResult] = await Promise.all([
    query(`SELECT id, slug, name, description, cover_image, is_spicy, difficulty, rating
           FROM recipes WHERE status = 'published'
           ORDER BY is_featured DESC, rating DESC NULLS LAST LIMIT 6`),
    query(`SELECT p.slug, p.name, p.address, p.rating, p.review_count, c.name AS category_name
           FROM places p LEFT JOIN categories c ON p.category_id = c.id
           WHERE p.status = 'active'
             AND c.slug IN ('restoran', 'kebapcilar', 'cigerciler', 'yoresel-yemekler')
           ORDER BY p.rating DESC NULLS LAST, p.review_count DESC NULLS LAST LIMIT 8`),
  ]);
  recipes = recipesResult.rows;
  topRestaurants = restaurantsResult.rows;
} catch (e) {
  logger.error('sanliurfada-ne-yenir verileri yüklenemedi:', e instanceof Error ? e : new Error(String(e)));
}

const lezzetler = [
  { name: 'Urfa Kebabı', emoji: '🥩', link: '/yemek-tarifleri/urfa-kebabi', desc: 'Yağlı kuzu kıyması ve isot dengesi' },
  { name: 'Çiğ Köfte', emoji: '🌿', link: '/yemek-tarifleri/cig-kofte', desc: 'Urfa usulü elde yoğurulmuş bulgur' },
  { name: 'Tandır Ciğeri', emoji: '🍖', link: '/en-iyi-cigerciler', desc: 'Şanlıurfa\'nın simgesi olan lezzet' },
  { name: 'Borani', emoji: '🥣', link: '/yemek-tarifleri/borani', desc: 'Yoğurt, pazı ve nohutla' },
  { name: 'Şıllık Tatlısı', emoji: '🍮', link: '/yemek-tarifleri/sillik-tatlisi', desc: 'Cevizli krep tatlısı' },
  { name: 'Lebeni', emoji: '🍜', link: '/yemek-tarifleri/lebeni', desc: 'Yoğurtlu buğday çorbası' },
];

const seo = {
  title: 'Şanlıurfa\'da Ne Yenir? | Urfa Mutfağı Rehberi',
  description: 'Şanlıurfa\'da ne yenir? Urfa kebabı, tandır ciğeri, çiğ köfte, borani ve daha fazlası. Şanlıurfa mutfağının en özel lezzetleri.',
  keywords: ['şanlıurfada ne yenir', 'urfa mutfağı', 'urfa yemekleri', 'şanlıurfa lezzetleri', 'urfa yöresel yemek', 'şanlıurfa gastronomi rehberi'],
  ogImage: '/images/hero/hero-food.webp',
  canonical: '/sanliurfada-ne-yenir',
};
---

<Layout seo={seo}>
  <div class="min-h-screen bg-[#FDFAF3]">
    <div class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)] text-white py-16">
      <div class="container mx-auto px-4 max-w-5xl">
        <p class="text-sm font-semibold uppercase tracking-widest text-[#9A8470] mb-2">Şanlıurfa Yemek Rehberi</p>
        <h1 class="text-4xl md:text-5xl font-bold text-[#F5EDD6] mb-4">Şanlıurfa'da Ne Yenir?</h1>
        <p class="text-[#C4B49A] text-lg max-w-2xl">
          UNESCO Gastronomi Şehri adayı Şanlıurfa'nın eşsiz mutfağını keşfedin. İşte mutlaka tatmanız gereken lezzetler.
        </p>
      </div>
    </div>

    <div class="container mx-auto px-4 max-w-5xl py-12">
      <!-- Öne Çıkan Lezzetler -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-[#1A1008] mb-6">Mutlaka Denenmesi Gereken Lezzetler</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {lezzetler.map((l) => (
            <a href={l.link} class="bg-white rounded-sm p-5 border border-[rgba(200,160,100,0.18)] shadow-sm hover:shadow-md hover:border-urfa-300 transition-all group">
              <div class="text-3xl mb-3">{l.emoji}</div>
              <h3 class="font-bold text-[#1A1008] group-hover:text-urfa-700 transition-colors">{l.name}</h3>
              <p class="text-sm text-[#9A8470] mt-1">{l.desc}</p>
            </a>
          ))}
        </div>
      </section>

      <!-- Tarifler -->
      {recipes.length > 0 && (
        <section class="mb-12">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-2xl font-bold text-[#1A1008]">Yöresel Tarifler</h2>
            <a href="/yemek-tarifleri" class="text-urfa-600 hover:text-urfa-700 font-medium text-sm">Tüm Tarifler →</a>
          </div>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
            {recipes.map((r) => (
              <a href={`/yemek-tarifleri/${r.slug}`} class="bg-white rounded-sm overflow-hidden border border-[rgba(200,160,100,0.18)] shadow-sm hover:shadow-md hover:border-urfa-300 transition-all group">
                <div class="h-36 bg-[rgba(200,160,100,0.06)] overflow-hidden">
                  <img src={r.cover_image || '/images/foods/default.jpg'} alt={r.name}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
                </div>
                <div class="p-3">
                  <h3 class="font-semibold text-[#1A1008] group-hover:text-urfa-700">{r.name}</h3>
                  <div class="flex items-center gap-2 mt-1 text-xs text-[#9A8470]">
                    {r.is_spicy && <span class="text-red-500">🌶 Acılı</span>}
                    <span>{r.difficulty}</span>
                    {r.rating && <span>★ {r.rating}</span>}
                  </div>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Restoranlar -->
      {topRestaurants.length > 0 && (
        <section>
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-2xl font-bold text-[#1A1008]">En İyi Restoranlar</h2>
            <a href="/gastronomi#restoranlar" class="text-urfa-600 hover:text-urfa-700 font-medium text-sm">Tümünü Gör →</a>
          </div>
          <div class="grid md:grid-cols-2 gap-4">
            {topRestaurants.map((p) => (
              <a href={`/isletme/${p.slug}`} class="bg-white rounded-sm p-4 border border-[rgba(200,160,100,0.18)] shadow-sm hover:shadow-md hover:border-urfa-300 transition-all group flex items-center gap-4">
                <div class="w-12 h-12 bg-[rgba(200,160,100,0.08)] rounded-sm flex items-center justify-center text-xl shrink-0">🍽️</div>
                <div class="flex-1 min-w-0">
                  <h3 class="font-semibold text-[#1A1008] group-hover:text-urfa-700 truncate">{p.name}</h3>
                  <p class="text-xs text-[#9A8470]">{p.category_name}</p>
                </div>
                {p.rating && <span class="text-yellow-600 font-bold shrink-0">★ {p.rating}</span>}
              </a>
            ))}
          </div>
        </section>
      )}
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'Şanlıurfa\'da ne yenir?',
        acceptedAnswer: { '@type': 'Answer', text: 'Şanlıurfa\'da mutlaka Urfa kebabı, tandır ciğeri, çiğ köfte, borani, şıllık tatlısı ve lebeni yenilmelidir. Bu lezzetler Şanlıurfa mutfağının simgeleridir.' },
      },
      {
        '@type': 'Question',
        name: 'Şanlıurfa kebabı nerede yenir?',
        acceptedAnswer: { '@type': 'Answer', text: 'Şanlıurfa\'daki kebapçı mekanları için sanliurfa.com/en-iyi-kebapcilar sayfasını ziyaret edebilirsiniz.' },
      },
      {
        '@type': 'Question',
        name: 'Şanlıurfa ciğeri nasıl bir lezzettir?',
        acceptedAnswer: { '@type': 'Answer', text: 'Şanlıurfa tandır ciğeri, ince dilimlenmiş kuzu ciğerinin yüksek ateşte hızla pişirilmesiyle hazırlanır. Taze pide, domates ve maydanozla servis edilir.' },
      },
    ],
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Gastronomi', item: `${baseUrl}/gastronomi` },
      { '@type': 'ListItem', position: 3, name: 'Şanlıurfa\'da Ne Yenir?', item: `${baseUrl}/sanliurfada-ne-yenir` },
    ],
  })} is:inline />
</Layout>
