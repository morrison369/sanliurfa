---

/**
 * User Discovery & Search Page
 * Browse and search for users
 */

import Layout from '../layouts/Layout.astro';
import UserSearchResults from '../components/UserSearchResults';
import { getSiteBranding } from '../lib/site-branding';
const { baseUrl } = await getSiteBranding();

const seo = {
  title: 'Kullanıcıları Keşfet - Sanliurfa.com',
  description: 'Şanlıurfa.com topluluğunu keşfet ve diğer kullanıcılarla bağlantı kur.',
  keywords: ['şanlıurfa.com kullanıcılar', 'topluluk keşfet', 'sanliurfa.com üyeler'],
  ogImage: '/images/hero/hero-home.webp',
  canonical: '/kullanicilar',
};
const faqItems = [
  { S: 'Sanliurfa.com topluluğuna nasıl katılabilirim?', C: 'Ücretsiz kayıt olarak topluluğa katılabilir, mekan yorumlayabilir ve diğer kullanıcıları takip edebilirsiniz.' },
  { S: 'Kullanıcıları nasıl arayabilirim?', C: 'Kullanıcılar sayfasındaki arama alanını kullanarak üyeleri adlarına göre bulabilirsiniz.' },
  { S: 'Sanliurfa.com üyeliğinin avantajları nelerdir?', C: 'Üyeler yorum yazabilir, koleksiyon oluşturabilir, etkinliklere katılabilir ve premium özelliklerden yararlanabilir.' },
];

---

<Layout seo={seo}>
  <div class="min-h-screen bg-[#FDFAF3]">
    <div class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)] text-white py-12">
      <div class="container mx-auto px-4">
        <p class="text-sm font-semibold uppercase tracking-widest text-[#9A8470] mb-2">Şanlıurfa Topluluğu</p>
        <h1 class="text-3xl font-bold text-[#F5EDD6] mb-2">Kullanıcıları Keşfet</h1>
        <p class="text-[#C4B49A]">Toplulumuzu keşfet ve diğer kullanıcılarla bağlantı kur</p>
      </div>
    </div>

    <div class="container mx-auto px-4 py-8">
      <UserSearchResults client:visible={{ rootMargin: '140px' }} currentUserId={Astro.locals.user?.id} />
    </div>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Kullanıcılar', item: `${baseUrl}/kullanıcılar` },
    ],
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: { '@type': 'Answer', text: item.C },
    })),
  })} is:inline />
</Layout>
