---

import Layout from '../layouts/Layout.astro';
import { query } from '../lib/postgres';
import { getSiteBranding } from '../lib/site-branding';
import { logger } from '../lib/logging';
const { baseUrl } = await getSiteBranding();

let cigerciler: any[] = [];
try {
  const result = await query(`
    SELECT p.id, p.slug, p.name, p.address, p.rating, p.review_count,
           c.name AS category_name
    FROM places p
    LEFT JOIN categories c ON p.category_id = c.id
    WHERE p.status = 'active'
      AND (
        c.slug ILIKE '%ciger%'
        OR p.name ILIKE '%ciğer%'
        OR p.name ILIKE '%ciger%'
      )
    ORDER BY p.rating DESC NULLS LAST, p.review_count DESC NULLS LAST
    LIMIT 20
  `);
  cigerciler = result.rows;
} catch (e) {
  logger.error('Cigerciler yüklenemedi:', e instanceof Error ? e : new Error(String(e)));
}

const seo = {
  title: 'Şanlıurfa En İyi Cigerciler | Urfa Ciğeri Nerede Yenir?',
  description: 'Şanlıurfa\'nın meşhur tandır ciğerini en iyi sunan mekanlar. Urfa\'ya gelen herkesin mutlaka denemesi gereken lezzet.',
  keywords: ['şanlıurfa cigerciler', 'urfa tandır ciğeri', 'urfa ciğer nerede yenir', 'şanlıurfa ciğer mekanları', 'urfa en iyi cigerciler'],
  ogImage: '/images/hero/hero-food.webp',
  canonical: '/en-iyi-cigerciler',
};

const faqItems = [
  {
    S: 'Şanlıurfa ciğeri neden meşhurdur?',
    C: 'Şanlıurfa tandır ciğeri, taze dana ciğerinin özel baharatlarla sarımsak, maydanoz ve Urfa biberine bulanarak pişirilmesiyle hazırlanır. Bu lezzet şehrin gastronomik kimliğinin ayrılmaz bir parçasıdır.',
  },
  {
    S: 'Şanlıurfa\'da en iyi cigerciler nerede bulunur?',
    C: 'Şehir merkezinde ve tarihi çarşı çevresindeki köklü ciğerciler sabahın erken saatlerinden öğlene kadar hizmet verir.',
  },
  {
    S: 'Urfa ciğeri kahvaltıda mı yenir?',
    C: 'Evet. Şanlıurfa\'da tandır ciğeri sabah kahvaltısı olarak yenir ve genellikle pide ekmeği, domates, soğan ve nar ekşisiyle servis edilir.',
  },
];
---


<Layout seo={seo}>
  <div class="min-h-screen bg-[#FDFAF3]">
    <div class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)] text-white py-16">
      <div class="container mx-auto px-4 max-w-5xl">
        <p class="text-sm font-semibold uppercase tracking-widest text-[#9A8470] mb-2">Şanlıurfa Gastronomi Rehberi</p>
        <h1 class="text-4xl md:text-5xl font-bold text-[#F5EDD6] mb-4">Şanlıurfa'nın En İyi Cigercileri</h1>
        <p class="text-[#C4B49A] text-lg max-w-2xl">
          Tandır ciğeri, Urfa'nın adıyla özdeşleşmiş eşsiz bir lezzettir. Kıtır kıtır pişirilmiş kuzu ciğeri, domates ve maydanozla sunulur.
        </p>
      </div>
    </div>

    <div class="container mx-auto px-4 max-w-5xl py-12">
      <div class="mb-8 bg-[rgba(200,160,100,0.06)] border border-[rgba(200,160,100,0.2)] rounded-sm p-5">
        <h2 class="font-bold text-[#1A1008] text-lg mb-1">Urfa Tandır Ciğeri</h2>
        <p class="text-[#6B5540] text-sm leading-relaxed">
          Şanlıurfa ciğeri Türkiye'nin en meşhur sokak lezzetlerinden biridir. İnce dilimlenmiş kuzu ciğeri yüksek ateşte kısa sürede pişirilir ve tazeliğini korur. Yanında pide, domates ve taze soğan ile servis edilir.
        </p>
      </div>

      {cigerciler.length > 0 ? (
        <div class="grid md:grid-cols-2 gap-5">
          {cigerciler.map((place, i) => (
            <a href={`/isletme/${place.slug}`} class="bg-white rounded-sm overflow-hidden border border-[rgba(200,160,100,0.18)] shadow-sm hover:shadow-md hover:border-urfa-300 transition-all group flex">
              <div class="w-24 h-24 bg-[rgba(200,160,100,0.08)] shrink-0 flex items-center justify-center text-3xl font-bold text-urfa-700">
                {i < 3 ? ['🥇','🥈','🥉'][i] : `${i+1}`}
              </div>
              <div class="p-4 flex-1">
                <h3 class="font-bold text-[#1A1008] group-hover:text-urfa-700 transition-colors">{place.name}</h3>
                <p class="text-xs text-[#9A8470] mt-0.5">{place.category_name || 'Cigerciler'}</p>
                {place.address && <p class="text-sm text-[#6B5540] mt-1 line-clamp-1">{place.address}</p>}
                <div class="flex items-center gap-3 mt-2 text-sm">
                  {place.rating && <span class="text-yellow-600 font-semibold">★ {place.rating}</span>}
                  {place.review_count > 0 && <span class="text-[#9A8470]">{place.review_count} yorum</span>}
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-16 text-[#9A8470]">
          <p class="text-4xl mb-4">🍖</p>
          <p>Mekan bilgileri yakında eklenecek.</p>
        </div>
      )}

      <div class="mt-10 flex flex-wrap gap-3">
        <a href="/gastronomi" class="px-5 py-2.5 rounded-sm bg-urfa-600 text-white hover:bg-urfa-700 transition-colors font-medium">Gastronomi Rehberi</a>
        <a href="/en-iyi-kebapcilar" class="px-5 py-2.5 rounded-sm border border-[rgba(200,160,100,0.3)] text-urfa-700 hover:bg-[rgba(200,160,100,0.06)] transition-colors">En İyi Kebapçılar →</a>
      </div>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Şanlıurfa En İyi Cigerciler',
    description: 'Şanlıurfa\'nın en iyi ciğer mekanları listesi',
    url: `${baseUrl}/en-iyi-cigerciler`,
    itemListElement: cigerciler.slice(0, 10).map((p: any, i: number) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Restaurant',
        name: p.name,
        url: `${baseUrl}/isletme/${p.slug}`,
        address: { '@type': 'PostalAddress', addressLocality: 'Şanlıurfa', addressCountry: 'TR' },
        ...(p.rating && { aggregateRating: { '@type': 'AggregateRating', ratingValue: p.rating, reviewCount: p.review_count || 1 } }),
      },
    })),
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Yeme İçme', item: `${baseUrl}/yeme-icme` },
      { '@type': 'ListItem', position: 3, name: 'En İyi Cigerciler', item: `${baseUrl}/en-iyi-cigerciler` },
    ],
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: { '@type': 'Answer', text: item.C },
    })),
  })} is:inline />
</Layout>
