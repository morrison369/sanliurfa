---

import Layout from '../layouts/Layout.astro';
import RankedPlaceCard from '../components/landing/RankedPlaceCard.astro';
import { query } from '../lib/postgres';
import { getCachedPublicRouteData } from '../lib/public-route-cache';
import { getPublicAppUrl } from '../lib/public-app-url';
import { logger } from '../lib/logging';
import {
  buildItemListSchema,
  buildBreadcrumbSchema,
  buildFAQSchema,
  type LandingPlace,
} from '../lib/landing/landing-schema';
const baseUrl = getPublicAppUrl();

let cigerciler: LandingPlace[] = [];
try {
 cigerciler = await getCachedPublicRouteData('page:guide:en-iyi-cigerciler', async () => {
  const result = await query(`
 SELECT p.id, p.slug, p.name, p.address, p.rating, p.review_count, p.image_url, p.images, p.short_description,
 c.name AS category_name
 FROM places p
 LEFT JOIN categories c ON p.category_id = c.id
 WHERE p.status = 'active'
 AND (
 c.slug ILIKE '%ciger%'
 OR p.name ILIKE '%ciğer%'
 OR p.name ILIKE '%ciger%'
 )
 ORDER BY p.rating DESC NULLS LAST, p.review_count DESC NULLS LAST
 LIMIT 20
 `);
  return result.rows;
 });
} catch (e) {
 logger.error('Cigerciler yüklenemedi:', e instanceof Error ? e : new Error(String(e)));
}

const seo = {
 title: 'Şanlıurfa En İyi Cigerciler | Urfa Ciğeri Nerede Yenir?',
 description: "Şanlıurfa'nın meşhur tandır ciğerini en iyi sunan mekanlar. Urfa'ya gelen herkesin mutlaka denemesi gereken lezzet.",
 keywords: ['şanlıurfa cigerciler', 'urfa tandır ciğeri', 'urfa ciğer nerede yenir', 'şanlıurfa ciğer mekanları', 'urfa en iyi cigerciler'],
 ogImage: '/images/hero/hero-food.webp',
 canonical: '/en-iyi-cigerciler',
};

const faqItems = [
 {
 S: 'Şanlıurfa ciğeri neden meşhurdur?',
 C: "Şanlıurfa tandır ciğeri, taze dana ciğerinin özel baharatlarla sarımsak, maydanoz ve Urfa biberine bulanarak pişirilmesiyle hazırlanır.",
 },
 {
 S: "Şanlıurfa'da en iyi cigerciler nerede bulunur?",
 C: "Şehir merkezinde ve tarihi çarşı çevresindeki köklü ciğerciler sabahın erken saatlerinden öğlene kadar hizmet verir.",
 },
 {
 S: 'Urfa ciğeri kahvaltıda mı yenir?',
 C: "Evet. Şanlıurfa'da tandır ciğeri sabah kahvaltısı olarak yenir ve genellikle pide ekmeği, domates, soğan ve nar ekşisiyle servis edilir.",
 },
];
---

<Layout seo={seo}>
 <style is:inline>
 .ec-hero{position:relative;overflow:hidden;border-bottom:1px solid rgba(184,115,51,0.12);padding:clamp(3rem,6vw,5rem) 0;background:radial-gradient(circle at 18% 0%,rgba(212,151,24,0.10) 0%,transparent 42%),radial-gradient(circle at 82% 100%,rgba(44,122,82,0.08) 0%,transparent 40%),linear-gradient(180deg,#fbf6ec 0%,#f4ecd8 58%,#fbf6ec 100%)}
 .ec-hero-label{font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--public-text-soft)}
 .ec-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.7rem,4vw,2.6rem);font-weight:700;color:var(--public-text);margin:.75rem 0 .25rem}
 .ec-hero-desc{color:var(--public-muted);font-size:.9rem;max-width:40rem}
 .ec-body{background:var(--bg);padding:2rem 0 4rem}
 .ec-info{background:rgba(184,115,51,.05);border:1px solid rgba(184,115,51,.18);padding:1.25rem;margin-bottom:1.75rem}
 .ec-info-h2{font-size:.9rem;font-weight:700;color:var(--public-text);margin-bottom:.25rem}
 .ec-info-p{font-size:.8rem;line-height:1.7;color:var(--public-muted)}
 .ec-grid{display:grid;gap:1rem}
 @media(min-width:48rem){.ec-grid{grid-template-columns:1fr 1fr}}
 .ec-card{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);display:flex;overflow:hidden;transition:border-color .15s}
 .ec-card:hover{border-color:var(--public-accent)}
 .ec-card-rank{width:6rem;height:6rem;background:rgba(184,115,51,.1);display:flex;align-items:center;justify-content:center;font-size:1.5rem;font-weight:700;color:var(--public-accent);flex-shrink:0}
 .ec-card-body{padding:1rem;flex:1;min-width:0}
 .ec-card-name{font-size:.9rem;font-weight:700;color:var(--public-text);transition:color .15s}
 .ec-card:hover .ec-card-name{color:var(--public-accent)}
 .ec-card-cat{font-size:.72rem;color:var(--public-muted);margin-top:.15rem}
 .ec-card-addr{font-size:.78rem;color:var(--public-muted);margin-top:.4rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
 .ec-card-meta{display:flex;align-items:center;gap:.75rem;margin-top:.5rem;font-size:.8rem}
 .ec-rating{color:var(--public-accent);font-weight:600}
 .ec-reviews{color:var(--public-text-soft)}
 .ec-empty{text-align:center;padding:4rem 1rem;background:var(--bg-card);border:1px solid rgba(184,115,51,.14)}
 .ec-empty-icon{font-size:2.5rem;margin-bottom:.75rem}
 .ec-empty-txt{font-size:.9rem;color:var(--public-muted)}
 .ec-cta{display:flex;flex-wrap:wrap;gap:.75rem;margin-top:2.5rem}
 .ec-btn-primary{background:var(--public-accent);color:#fff;font-size:.85rem;font-weight:600;padding:.65rem 1.25rem;transition:background .15s}
 .ec-btn-primary:hover{background:var(--public-accent-strong)}
 .ec-btn-outline{border:1px solid rgba(184,115,51,.25);color:var(--public-accent);font-size:.85rem;font-weight:500;padding:.65rem 1.25rem;transition:border-color .15s,color .15s}
 .ec-btn-outline:hover{border-color:var(--public-accent);color:var(--public-text)}
 details summary{list-style:none}
 details summary::-webkit-details-marker{display:none}
 details[open] .faq-arrow{transform:rotate(180deg)}
 </style>

 <div class="ec-hero">
 <div class="sf-container">
 <p class="ec-hero-label">Şanlıurfa Gastronomi Rehberi</p>
 <h1 class="ec-h1">Şanlıurfa'nın En İyi Cigercileri</h1>
 <p class="ec-hero-desc">Tandır ciğeri, Urfa'nın adıyla özdeşleşmiş eşsiz bir lezzettir.</p>
 </div>
 </div>

 <div class="ec-body">
 <div class="sf-container">
 <div class="ec-info">
 <h2 class="ec-info-h2">Urfa Tandır Ciğeri</h2>
 <p class="ec-info-p">Şanlıurfa ciğeri Türkiye'nin en meşhur sokak lezzetlerinden biridir. İnce dilimlenmiş kuzu ciğeri yüksek ateşte kısa sürede pişirilir. Yanında pide, domates ve taze soğan ile servis edilir.</p>
 </div>

 {cigerciler.length > 0 ? (
 <div class="ec-grid">
 {cigerciler.map((place, i) => (
 <RankedPlaceCard place={place} rank={i + 1} variant="restaurant" />
 ))}
 </div>
 ) : (
 <div class="ec-empty">
 <div class="ec-empty-icon">🍖</div>
 <p class="ec-empty-txt">Mekan bilgileri yakında eklenecek.</p>
 </div>
 )}

 <div class="ec-cta">
 <a href="/gastronomi" class="ec-btn-primary">Gastronomi Rehberi</a>
 <a href="/en-iyi-kebapcilar" class="ec-btn-outline">En İyi Kebapçılar →</a>
 </div>
 </div>
 </div>

 {faqItems.length > 0 && (
 <div style="padding:2rem 0 3rem;border-top:1px solid rgba(184,115,51,.12)">
 <div class="sf-container">
 <h2 style="font-size:1.25rem;font-weight:700;color:#1F1410;margin-bottom:1.25rem">Sık Sorulan Sorular</h2>
 <div style="display:flex;flex-direction:column;gap:.75rem">
 {faqItems.map((item) => (
 <details style="background:var(--bg-card);border:1px solid rgba(184,115,51,.14);border-radius:.375rem;overflow:hidden">
 <summary style="padding:1rem 1.25rem;font-weight:600;color:#1F1410;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:1rem">
 {item.S}
 <span style="flex-shrink:0;color:#B87333;font-size:1.25rem;transition:transform .2s" class="faq-arrow">▾</span>
 </summary>
 <div style="padding:.75rem 1.25rem 1rem;color:#4A3828;font-size:.95rem;line-height:1.7;border-top:1px solid rgba(184,115,51,.08)">
 {item.C}
 </div>
 </details>
 ))}
 </div>
 </div>
 </div>
 )}

 <script type="application/ld+json" set:html={JSON.stringify(buildItemListSchema({
 places: cigerciler,
 pageName: 'Şanlıurfa En İyi Cigerciler',
 pagePath: '/en-iyi-cigerciler',
 baseUrl,
 type: 'Restaurant',
 description: "Şanlıurfa'nın en iyi ciğer mekanları listesi — tandır ciğeri ve şiş için tercih edilen adresler.",
 }))} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify(buildBreadcrumbSchema({
 baseUrl,
 crumbs: [
   { name: 'Ana Sayfa', href: '/' },
   { name: 'Yeme İçme', href: '/yeme-icme' },
   { name: 'En İyi Cigerciler', href: '/en-iyi-cigerciler' },
 ],
 }))} is:inline />
 {(() => {
   const faqJson = buildFAQSchema(faqItems);
   return faqJson ? <script type="application/ld+json" set:html={JSON.stringify(faqJson)} is:inline /> : null;
 })()}
</Layout>
