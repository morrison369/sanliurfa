---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm';

const seo = {
  title: 'İletişim - Şanlıurfa.com',
  description: 'Bize ulaşın, işletmenizi ekleyin veya destek alın. Şanlıurfa.com ekibi size yardımcı olmaya hazır.',
};

const contactInfo = [
  {
    icon: '📧',
    title: 'E-posta',
    value: 'info@sanliurfa.com',
    link: 'mailto:info@sanliurfa.com',
  },
  {
    icon: '📱',
    title: 'Telefon',
    value: '+90 (414) 123 45 67',
    link: 'tel:+904141234567',
  },
  {
    icon: '📍',
    title: 'Adres',
    value: 'Eyyübiye, Şanlıurfa',
    link: '#',
  },
  {
    icon: '💼',
    title: 'İşletme Başvurusu',
    value: 'business@sanliurfa.com',
    link: 'mailto:business@sanliurfa.com',
  },
];
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gradient-to-b from-gray-50 to-white pt-20 pb-12">
    <div class="container mx-auto px-4">
      {/* Header */}
      <div class="text-center max-w-2xl mx-auto mb-12">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">Bize Ulaşın</h1>
        <p class="text-gray-600 text-lg">
          Sorularınız mı var? İşletmenizi mi eklemek istiyorsunuz? 
          Veya önerileriniz mi var? Size yardımcı olmaktan memnuniyet duyarız.
        </p>
      </div>

      <div class="grid lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
        {/* Contact Form */}
        <div class="lg:col-span-2">
          <div class="bg-white rounded-2xl shadow-lg p-8">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Mesaj Gönderin</h2>
            <ContactForm client:load />
          </div>
        </div>

        {/* Contact Info Sidebar */}
        <div class="space-y-6">
          <div class="bg-white rounded-2xl shadow-lg p-6">
            <h3 class="font-bold text-gray-900 mb-4">İletişim Bilgileri</h3>
            <div class="space-y-4">
              {contactInfo.map((item) => (
                <a
                  href={item.link}
                  class="flex items-start gap-3 p-3 rounded-lg hover:bg-gray-50 transition-colors"
                >
                  <span class="text-2xl">{item.icon}</span>
                  <div>
                    <div class="font-medium text-gray-900">{item.title}</div>
                    <div class="text-gray-600 text-sm">{item.value}</div>
                  </div>
                </a>
              ))}
            </div>
          </div>

          {/* Business CTA */}
          <div class="bg-gradient-to-br from-red-600 to-orange-500 rounded-2xl shadow-lg p-6 text-white">
            <h3 class="font-bold text-xl mb-2">İşletmenizi Ekleyin</h3>
            <p class="text-red-100 text-sm mb-4">
              Şanlıurfa.com'da yer alın, binlerce potansiyel müşteriye ulaşın.
            </p>
            <a
              href="/isletme-kayit"
              class="inline-block px-4 py-2 bg-white text-red-600 rounded-lg font-medium hover:bg-red-50 transition-colors"
            >
              Hemen Başvurun →
            </a>
          </div>

          {/* FAQ Link */}
          <div class="bg-white rounded-2xl shadow-lg p-6">
            <h3 class="font-bold text-gray-900 mb-2">Sıkça Sorulan Sorular</h3>
            <p class="text-gray-600 text-sm mb-4">
              Hızlı cevaplar için SSS sayfamıza göz atın.
            </p>
            <a
              href="/sss"
              class="text-red-600 font-medium hover:underline"
            >
              SSS'yi Görüntüle →
            </a>
          </div>
        </div>
      </div>

      {/* Map Section */}
      <div class="max-w-6xl mx-auto mt-12">
        <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
          <div class="aspect-[21/9] bg-gray-100 flex items-center justify-center">
            <div class="text-center text-gray-400">
              <div class="text-6xl mb-4">🗺️</div>
              <p>Harita entegrasyonu burada görüntülenecek</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
