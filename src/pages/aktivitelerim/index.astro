---
import Layout from "../../layouts/Layout.astro";
import MyActivityLog from "../../components/MyActivityLog";

const user = Astro.locals.user;
if (!user) {
 return Astro.redirect("/giris?redirect=/aktivitelerim");
}
---

<Layout seo={{ title: "Aktivitelerim - Sanliurfa.com", noIndex: true }}>
 <style is:inline>
 .at-hero{position:relative;overflow:hidden;border-bottom:1px solid rgba(184,115,51,.12);background:radial-gradient(circle at 18% 0%,rgba(212,151,24,.10) 0%,transparent 42%),radial-gradient(circle at 82% 100%,rgba(44,122,82,.08) 0%,transparent 40%),linear-gradient(180deg,#fbf6ec 0%,#f4ecd8 58%,#fbf6ec 100%);padding:2.5rem 0}
 .at-label{font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--public-text-soft)}
 .at-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.5rem,3.5vw,2.2rem);font-weight:700;color:var(--public-text);margin:.5rem 0}
 .at-body{background:var(--bg);padding:2rem 0 4rem}
 .at-inner{max-width:42rem;margin:0 auto}
 </style>

 <div class="at-hero">
 <div class="sf-container">
 <div class="at-inner">
 <p class="at-label">Hesabım</p>
 <h1 class="at-h1">Aktivitelerim</h1>
 </div>
 </div>
 </div>

 <div class="at-body">
 <div class="sf-container">
 <div class="at-inner">
 <MyActivityLog client:visible={{ rootMargin: '120px' }} />
 </div>
 </div>
 </div>
</Layout>
