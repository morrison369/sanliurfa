---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { randomBytes } from 'node:crypto';

const seo = {
  title: 'Sunucu Hatası - 500',
  description: 'Bir hata oluştu. Lütfen daha sonra tekrar deneyin.',
  noIndex: true
};

const errorCode = `500-ERR-${randomBytes(6).toString('hex').toUpperCase()}`;
---

<Layout seo={seo} hideHeader={false} hideFooter={true}>
  <div class="min-h-screen flex items-center justify-center bg-[#FDFAF3]">
    <div class="container mx-auto px-4 py-20">
      <div class="max-w-2xl mx-auto text-center">
        <!-- Error Illustration -->
        <div class="relative mb-8">
          <div class="text-9xl font-bold text-[#CE8E38]/20 select-none" style="font-family:'Cormorant Garamond',Georgia,serif;font-style:italic;">500</div>
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-32 h-32 bg-white border border-[rgba(200,160,100,0.2)] rounded-sm shadow-xl flex items-center justify-center">
              <Icon name="lucide:refresh-cw" class="w-16 h-16 text-urfa-500" />
            </div>
          </div>
        </div>

        <h1 class="text-3xl md:text-4xl font-display font-bold text-[#1A1008] mb-4">
          Bir Hata Oluştu
        </h1>
        <p class="text-lg text-[#6B5540] mb-8">
          Üzgünüz, bir şeyler yanlış gitti. Teknik ekibimiz konuyu inceliyor.
          <br />Lütfen biraz sonra tekrar deneyin.
        </p>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
          <button
            onclick="location.reload()"
            class="btn-primary flex items-center gap-2"
          >
            <Icon name="lucide:refresh-cw" class="w-5 h-5" />
            Sayfayı Yenile
          </button>
          <a href="/" class="btn-secondary flex items-center gap-2">
            <Icon name="lucide:home" class="w-5 h-5" />
            Ana Sayfaya Dön
          </a>
        </div>

        <!-- Contact -->
        <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6 max-w-md mx-auto">
          <div class="flex items-center justify-center gap-2 text-[#6B5540] mb-2">
            <Icon name="lucide:mail" class="w-5 h-5" />
            <span>Sorun devam ederse bize ulaşın</span>
          </div>
          <a href="mailto:destek@sanliurfa.com" class="text-urfa-600 hover:underline font-medium">
            destek@sanliurfa.com
          </a>
        </div>

        <!-- Error ID (for debugging) -->
        <p class="text-sm text-[#9A8470] mt-8">
          Hata Kodu: <code class="bg-[rgba(200,160,100,0.08)] px-2 py-1 rounded-sm">{errorCode}</code>
        </p>
      </div>
    </div>
  </div>
</Layout>


