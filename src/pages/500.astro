---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { randomBytes } from 'node:crypto';

const seo = {
 title: '500 — Sunucu Hatası | Sanliurfa.com',
 description: 'Bir hata oluştu. Lütfen daha sonra tekrar deneyin.',
 noIndex: true,
};

const errorCode = `ERR-${randomBytes(6).toString('hex').toUpperCase()}`;
---
<Layout seo={seo} hideFooter={true}>
 <style is:inline>
 .e500-wrap{min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--bg);padding:2rem}
 .e500-box{text-align:center;max-width:500px}
 .e500-visual{position:relative;display:inline-block;margin-bottom:1.5rem}
 .e500-bg-num{font-family:'Cormorant Garamond',serif;font-size:8rem;font-weight:600;font-style:italic;color:rgba(184,115,51,.1);line-height:1;letter-spacing:-.02em;user-select:none}
 .e500-icon{position:absolute;inset:0;display:flex;align-items:center;justify-content:center}
 .e500-icon-ring{width:5.5rem;height:5.5rem;border:1px solid rgba(184,115,51,.2);display:flex;align-items:center;justify-content:center;background:var(--bg-card)}
 .e500-title{font-family:'Cormorant Garamond',serif;font-size:clamp(1.5rem,3vw,2.2rem);font-weight:600;color:var(--public-text);margin-bottom:.75rem}
 .e500-desc{font-size:.88rem;color:var(--public-muted);line-height:1.7;margin-bottom:2rem;max-width:380px;margin-inline:auto}
 .e500-actions{display:flex;flex-wrap:wrap;gap:.75rem;justify-content:center;margin-bottom:2rem}
 .e500-contact{background:var(--bg-card);border:1px solid var(--border);padding:1.25rem;max-width:300px;margin:0 auto 1.5rem}
 .e500-contact p{font-size:.8rem;color:var(--public-muted);margin-bottom:.4rem}
 .e500-contact a{font-size:.82rem;color:var(--public-accent);font-weight:600}
 .e500-contact a:hover{color:var(--public-text)}
 .e500-code{font-size:.72rem;color:var(--public-text-soft)}
 .e500-code code{background:rgba(184,115,51,.07);padding:.2rem .5rem;border-radius:.125rem;font-family:ui-monospace,monospace;color:var(--public-muted)}
 </style>
 <div class="e500-wrap">
 <div class="e500-box">
 <div class="e500-visual">
 <div class="e500-bg-num" aria-hidden="true">500</div>
 <div class="e500-icon" aria-hidden="true">
 <div class="e500-icon-ring">
 <Icon name="lucide:refresh-cw" class="w-10 h-10 text-urfa-500" style="color:var(--public-accent);width:2.5rem;height:2.5rem" />
 </div>
 </div>
 </div>

 <h1 class="e500-title">Bir Hata Oluştu</h1>
 <p class="e500-desc">Üzgünüz, bir şeyler yanlış gitti. Teknik ekibimiz konuyu inceliyor. Lütfen biraz sonra tekrar deneyin.</p>

 <div class="e500-actions">
 <button onclick="location.reload()" class="sf-btn-primary" type="button">
 Sayfayı Yenile
 </button>
 <a href="/" class="sf-btn-ghost">Ana Sayfaya Dön</a>
 </div>

 <div class="e500-contact">
 <p>Sorun devam ederse bize ulaşın</p>
 <a href="mailto:destek@sanliurfa.com">destek@sanliurfa.com</a>
 </div>

 <p class="e500-code">Hata kodu: <code>{errorCode}</code></p>
 </div>
 </div>
</Layout>
