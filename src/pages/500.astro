---
import Layout from '../layouts/Layout.astro';

const icons = {
  refreshCw: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>',
  home: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>',
  mail: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>'
};

const seo = {
  title: 'Sunucu Hatası - 500',
  description: 'Bir hata oluştu. Lütfen daha sonra tekrar deneyin.',
  noindex: true
};
---

<Layout seo={seo} hideHeader={false} hideFooter={true}>
  <div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-red-50 to-orange-50">
    <div class="container-custom py-20">
      <div class="max-w-2xl mx-auto text-center">
        <!-- Error Illustration -->
        <div class="relative mb-8">
          <div class="text-9xl font-bold text-red-200 select-none">500</div>
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-32 h-32 bg-white rounded-full shadow-xl flex items-center justify-center">
              <span set:html={icons.refreshCw} class="w-16 h-16 text-red-500"></span>
            </div>
          </div>
        </div>

        <h1 class="text-3xl md:text-4xl font-display font-bold text-gray-900 mb-4">
          Bir Hata Oluştu
        </h1>
        <p class="text-lg text-gray-600 mb-8">
          Üzgünüz, bir şeyler yanlış gitti. Teknik ekibimiz konuyu inceliyor.
          <br />Lütfen biraz sonra tekrar deneyin.
        </p>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
          <button
            onclick="location.reload()"
            class="btn-primary flex items-center gap-2"
          >
            <span set:html={icons.refreshCw} class="w-5 h-5"></span>
            Sayfayı Yenile
          </button>
          <a href="/" class="btn-secondary flex items-center gap-2">
            <span set:html={icons.home} class="w-5 h-5"></span>
            Ana Sayfaya Dön
          </a>
        </div>

        <!-- Contact -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 max-w-md mx-auto">
          <div class="flex items-center justify-center gap-2 text-gray-600 mb-2">
            <span set:html={icons.mail} class="w-5 h-5"></span>
            <span>Sorun devam ederse bize ulaşın</span>
          </div>
          <a href="mailto:destek@sanliurfa.com" class="text-urfa-600 hover:underline font-medium">
            destek@sanliurfa.com
          </a>
        </div>

        <!-- Error ID (for debugging) -->
        <p class="text-sm text-gray-400 mt-8">
          Hata Kodu: <code className="bg-gray-100 px-2 py-1 rounded">500-ERR-{Math.random().toString(36).substr(2, 9).toUpperCase()}</code>
        </p>
      </div>
    </div>
  </div>
</Layout>
