---
import Layout from '../layouts/Layout.astro';
import { query } from '../lib/postgres';
import { actions, isInputError } from 'astro:actions';
import { getSiteBranding } from '../lib/site-branding';

let categories: any[] = [];
let districts: any[] = [];

try {
  const [catResult, distResult] = await Promise.all([
    query("SELECT id, name, slug FROM categories WHERE parent_id IS NOT NULL AND is_active = true ORDER BY sort_order LIMIT 30"),
    query("SELECT id, name, slug FROM districts ORDER BY is_central DESC, sort_order"),
  ]);
  categories = catResult.rows;
  districts = distResult.rows;
} catch (e) {
  console.error('Error loading isletme-kayit data:', e);
}

const seo = {
  title: 'Şanlıurfa İşletme Kaydı | Sanliurfa.com',
  description: 'Şanlıurfa işletmenizi Sanliurfa.com\'a ücretsiz ekleyin. Mekan başvurusu, kategori, ilçe, yorum ve görünürlük yönetimi.',
  keywords: ['şanlıurfa işletme ekle', 'urfa mekan kaydı', 'sanliurfa.com işletme', 'şanlıurfa ücretsiz ilan', 'urfa işletme kayıt'],
  ogImage: '/images/hero/hero-home.webp',
  canonical: '/isletme-kayit',
};
const { baseUrl } = await getSiteBranding();

const faqItems = [
  {
    S: 'Şanlıurfa işletme kaydı ücretsiz mi?',
    C: 'Evet. İlk aşamada işletme başvurusu ve temel listeleme ücretsiz olarak açık tutulur.',
  },
  {
    S: 'Başvuru sonrası işletme hemen yayınlanır mı?',
    C: 'Başvuru admin onayından geçer. Onaylanan işletme kayıtları public rehberde görünür olur.',
  },
  {
    S: 'İşletme hangi bilgilerle eklenir?',
    C: 'İşletme adı, kategori, ilçe, telefon, adres ve kısa açıklama bilgileriyle başvuru yapılır.',
  },
];

const applicationResult = Astro.getActionResult(actions.submitPlaceApplication);
const applicationInputErrors = isInputError(applicationResult?.error)
  ? applicationResult.error.fields
  : {};
const applicationSubmitError =
  !isInputError(applicationResult?.error) && applicationResult?.error?.message
    ? applicationResult.error.message
    : null;
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50 pt-20 pb-16">
    <div class="container mx-auto px-4 max-w-3xl">
      <!-- Header -->
      <div class="text-center mb-10">
        <div class="text-5xl mb-4">🏪</div>
        <h1 class="text-4xl font-bold text-gray-900 mb-3">Şanlıurfa İşletmenizi Ekleyin</h1>
        <p class="text-gray-600 text-lg">
          Sanliurfa.com'a katılın — ücretsiz, hızlı ve kolay.
          Binlerce kişiye işletmenizi tanıtın.
        </p>
      </div>

      <section class="mb-10 rounded-2xl border border-red-100 bg-white p-5 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-wide text-red-700">Hızlı Cevap</p>
        <h2 class="mt-1 text-2xl font-bold text-gray-950">Şanlıurfa işletme kaydı nasıl yapılır?</h2>
        <p class="mt-2 text-sm leading-6 text-gray-700">
          İşletme adı, kategori, ilçe, telefon ve adres bilgilerini girerek ücretsiz başvuru yapabilirsiniz.
          Başvurular admin onayından sonra Şanlıurfa mekan rehberinde yayınlanır.
        </p>
        <div class="mt-3 flex flex-wrap gap-3 text-sm">
          <a href="/isletme-kayit" class="font-semibold text-red-700 underline underline-offset-4">İşletme kaydı</a>
          <a href="/mekanlar" class="font-semibold text-red-700 underline underline-offset-4">Mekanlar</a>
          <a href="/topluluk" class="font-semibold text-red-700 underline underline-offset-4">Topluluk</a>
        </div>
      </section>

      <!-- Faydalar -->
      <div class="grid md:grid-cols-3 gap-4 mb-10">
        {[
          { icon: '🆓', title: 'Ücretsiz Kayıt', desc: 'Temel listeleme tamamen ücretsiz' },
          { icon: '👥', title: 'Geniş Kitle', desc: 'Şanlıurfa\'nın en büyük rehberinde yer alın' },
          { icon: '⭐', title: 'Yorum Sistemi', desc: 'Müşteri yorumları ile güven inşa edin' },
        ].map(item => (
          <div class="bg-white rounded-xl p-5 text-center shadow-sm">
            <div class="text-3xl mb-2">{item.icon}</div>
            <h3 class="font-bold text-gray-900">{item.title}</h3>
            <p class="text-sm text-gray-500 mt-1">{item.desc}</p>
          </div>
        ))}
      </div>

      <!-- Form -->
      <form action={actions.submitPlaceApplication} method="POST" class="bg-white rounded-2xl shadow-lg p-8 space-y-8">
        {applicationResult?.data?.success && (
          <div class="rounded-xl p-4 text-sm font-medium bg-green-50 text-green-700 border border-green-200">
            Başvurunuz alındı. 1-3 iş günü içinde size ulaşacağız.
          </div>
        )}

        {applicationSubmitError && (
          <div class="rounded-xl p-4 text-sm font-medium bg-red-50 text-red-700 border border-red-200">
            {applicationSubmitError}
          </div>
        )}

        <!-- İşletme Bilgileri -->
        <section>
          <h2 class="text-xl font-bold text-gray-900 mb-5 pb-3 border-b">İşletme Bilgileri</h2>
          <div class="grid md:grid-cols-2 gap-4">
            <div class="md:col-span-2">
              <label class="block text-sm font-medium text-gray-700 mb-1">İşletme Adı *</label>
              <input type="text" name="name" required placeholder="Örn: Ciğerci Aziz Usta"
                class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-red-500 focus:border-transparent">
              {applicationInputErrors.name && (
                <p class="mt-2 text-sm text-red-600">{applicationInputErrors.name.join(', ')}</p>
              )}
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Kategori *</label>
              <select name="category_id" required
                class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-red-500">
                <option value="">Kategori seçin</option>
                {categories.map(cat => (
                  <option value={cat.id}>{cat.name}</option>
                ))}
              </select>
              {applicationInputErrors.category_id && (
                <p class="mt-2 text-sm text-red-600">{applicationInputErrors.category_id.join(', ')}</p>
              )}
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">İlçe *</label>
              <select name="district_id" required
                class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-red-500">
                <option value="">İlçe seçin</option>
                {districts.map(d => (
                  <option value={d.id}>{d.name}</option>
                ))}
              </select>
              {applicationInputErrors.district_id && (
                <p class="mt-2 text-sm text-red-600">{applicationInputErrors.district_id.join(', ')}</p>
              )}
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Telefon *</label>
              <input type="tel" name="phone" required placeholder="+90 414 000 0000"
                class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-red-500">
              {applicationInputErrors.phone && (
                <p class="mt-2 text-sm text-red-600">{applicationInputErrors.phone.join(', ')}</p>
              )}
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Web Sitesi</label>
              <input type="url" name="website" placeholder="https://..."
                class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-red-500">
              {applicationInputErrors.website && (
                <p class="mt-2 text-sm text-red-600">{applicationInputErrors.website.join(', ')}</p>
              )}
            </div>

            <div class="md:col-span-2">
              <label class="block text-sm font-medium text-gray-700 mb-1">Açık Adres *</label>
              <textarea name="address" rows="2" required placeholder="Mahalle, cadde, kapı no..."
                class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-red-500 resize-none"></textarea>
              {applicationInputErrors.address && (
                <p class="mt-2 text-sm text-red-600">{applicationInputErrors.address.join(', ')}</p>
              )}
            </div>

            <div class="md:col-span-2">
              <label class="block text-sm font-medium text-gray-700 mb-1">Kısa Açıklama</label>
              <textarea name="short_description" rows="2" maxlength="200"
                placeholder="İşletmenizi kısaca tanıtın (max 200 karakter)"
                class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-red-500 resize-none"></textarea>
              {applicationInputErrors.short_description && (
                <p class="mt-2 text-sm text-red-600">{applicationInputErrors.short_description.join(', ')}</p>
              )}
            </div>
          </div>
        </section>

        <!-- Başvuran Bilgileri -->
        <section>
          <h2 class="text-xl font-bold text-gray-900 mb-5 pb-3 border-b">Başvuran Bilgileri</h2>
          <div class="grid md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Ad Soyad *</label>
              <input type="text" name="owner_name" required placeholder="Adınız ve soyadınız"
                class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-red-500">
              {applicationInputErrors.owner_name && (
                <p class="mt-2 text-sm text-red-600">{applicationInputErrors.owner_name.join(', ')}</p>
              )}
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">E-posta *</label>
              <input type="email" name="owner_email" required placeholder="ornek@email.com"
                class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-red-500">
              {applicationInputErrors.owner_email && (
                <p class="mt-2 text-sm text-red-600">{applicationInputErrors.owner_email.join(', ')}</p>
              )}
            </div>
          </div>
        </section>

        <button type="submit"
          class="w-full py-4 bg-red-600 text-white rounded-xl font-bold text-lg hover:bg-red-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
          Başvuruyu Gönder
        </button>

        <p class="text-xs text-gray-500 text-center">
          Başvurunuz incelendikten sonra 1-3 iş günü içinde e-posta ile bildirilecektir.
        </p>
      </form>
    </div>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.C,
      },
    })),
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Şanlıurfa İşletme Kaydı',
    url: `${baseUrl}/isletme-kayit`,
    description: 'Şanlıurfa işletmeleri için ücretsiz başvuru ve mekan rehberine kayıt sayfası.',
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'İşletme Kayıt', item: `${baseUrl}/isletme-kayit` },
    ],
  })} is:inline />
</Layout>
