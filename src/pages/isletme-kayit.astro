---
import Layout from '../layouts/Layout.astro';
const seo = { title: 'Isletme Kayit', description: 'Isletmenizi ekleyin' };
const categories = [
  { value: 'restaurant', label: 'Restoran' },
  { value: 'hotel', label: 'Otel' },
  { value: 'shopping', label: 'Alisveris' },
];
---
<Layout seo={seo}>
  <div class="min-h-screen pt-20 pb-12">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="text-center mb-10">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">Isletmenizi Ekleyin</h1>
        <p class="text-gray-600 text-lg">Sanliurfa.com a katilin</p>
      </div>
      <form id="applicationForm" class="bg-white rounded-2xl shadow-lg p-8">
        <section class="mb-8">
          <h2 class="text-xl font-bold text-gray-900 mb-4">Isletme Bilgileri</h2>
          <div class="grid md:grid-cols-2 gap-4">
            <div class="md:col-span-2">
              <label class="block text-sm font-medium text-gray-700 mb-1">Isletme Adi</label>
              <input type="text" name="name" required class="w-full px-4 py-2 border border-gray-300 rounded-lg">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Kategori</label>
              <select name="category" required class="w-full px-4 py-2 border border-gray-300 rounded-lg">
                <option value="">Secin</option>
                {categories.map(cat => <option value={cat.value}>{cat.label}</option>)}
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Telefon</label>
              <input type="tel" name="phone" required class="w-full px-4 py-2 border border-gray-300 rounded-lg">
            </div>
            <div class="md:col-span-2">
              <label class="block text-sm font-medium text-gray-700 mb-1">Adres</label>
              <textarea name="address" rows="2" required class="w-full px-4 py-2 border border-gray-300 rounded-lg resize-none"></textarea>
            </div>
          </div>
        </section>
        <section class="mb-8">
          <h2 class="text-xl font-bold text-gray-900 mb-4">Sahip Bilgileri</h2>
          <div class="grid md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Ad Soyad</label>
              <input type="text" name="ownerName" required class="w-full px-4 py-2 border border-gray-300 rounded-lg">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">E-posta</label>
              <input type="email" name="ownerEmail" required class="w-full px-4 py-2 border border-gray-300 rounded-lg">
            </div>
          </div>
        </section>
        <button type="submit" class="w-full py-3 bg-red-600 text-white rounded-lg">Basvuru Yap</button>
      </form>
    </div>
  </div>
  <script>
    document.getElementById('applicationForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(e.target);
      const data = Object.fromEntries(formData);
      const response = await fetch('/api/places/apply', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      const result = await response.json();
      if (result.success) {
        alert('Basvurunuz alindi!');
        e.target.reset();
      } else {
        alert('Hata: ' + result.error);
      }
    });
  </script>
</Layout>
