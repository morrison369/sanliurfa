---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import CityUtilities from "../components/CityUtilities.astro";
import FeaturedPlaces from "../components/FeaturedPlaces.astro";
import HistoricalSites from "../components/HistoricalSites.astro";
import FoodGuide from "../components/FoodGuide.astro";
import UpcomingEvents from "../components/UpcomingEvents.astro";
import WeatherWidget from "../components/weather/WeatherWidget.astro";
import Stats from "../components/Stats.astro";
import CTASection from "../components/CTASection.astro";
import LatestBlog from "../components/LatestBlog.astro";
import {
  buildArticleItemListSchema,
  buildFAQPageSchema,
  buildOrganizationSchema,
  buildPlaceItemListSchema,
  buildWebPageSchema,
  buildWebSiteSchema,
} from "../lib/rich-snippets";
import { getPublicSiteSettings } from "../lib/site-settings";
import { getCuratedBlogPosts } from "../data/curated-blog-posts";
import { getCuratedPlaces } from "../data/curated-places";

const publicSiteSettings = await getPublicSiteSettings();
const homepageSections = publicSiteSettings.homepageSections;
const homePlaces = getCuratedPlaces(6);
const homePosts = getCuratedBlogPosts().slice(0, 6);
const homeDescription =
  "Şanlıurfa'nın en kapsamlı şehir rehberi. Göbeklitepe, Balıklıgöl, Harran, gastronomi ve daha fazlası. Mekânlar, yorumlar ve puanlama sistemi ile keşfedin.";

const seo = {
  title: "Şanlıurfa Şehir Rehberi - Tarihin Sıfır Noktası",
  description: homeDescription,
  image: "/images/og-home.jpg",
  canonicalUrl: "https://sanliurfa.com/",
  schemaMode: "replace" as const,
  schema: [
    buildOrganizationSchema(),
    buildWebSiteSchema(),
    buildWebPageSchema({
      path: "/",
      name: "Şanlıurfa Şehir Rehberi - Tarihin Sıfır Noktası",
      description: homeDescription,
      image: "/images/og-home.jpg",
    }),
    buildPlaceItemListSchema(homePlaces, "/"),
    buildArticleItemListSchema(homePosts, "/"),
    buildFAQPageSchema(
      [
        {
          question: "Şanlıurfa'da gezilecek en önemli yerler nereler?",
          answer:
            "Şanlıurfa gezisinde Göbeklitepe, Balıklıgöl, Harran, tarihi çarşılar ve Halfeti öne çıkan duraklardır.",
        },
        {
          question: "sanliurfa.com hangi içerikleri sunar?",
          answer:
            "sanliurfa.com Şanlıurfa mekanları, tarihi yerleri, yöresel yemekleri, etkinlikleri ve şehir yaşamı rehberlerini Türkçe olarak sunar.",
        },
        {
          question: "Şanlıurfa mekan puanları nasıl gösterilir?",
          answer:
            "Mekan sayfalarında kullanıcı değerlendirmeleri, puan ortalaması, yorum sayısı, görseller ve fiyat aralığı birlikte listelenir.",
        },
      ],
      "/",
    ),
  ],
};
---

<Layout seo={seo}>
  <!-- Hero Section -->
  <Hero settings={publicSiteSettings.hero} />

  {homepageSections.map((sectionId) =>
    sectionId === "city-utilities" ? (
      <CityUtilities services={publicSiteSettings.cityServices} />
    ) : sectionId === "weather" ? (
      <section class="bg-gray-50 dark:bg-gray-800 border-y border-gray-100 dark:border-gray-700">
        <div class="container-custom py-6">
          <WeatherWidget />
        </div>
      </section>
    ) : sectionId === "stats" ? (
      <Stats />
    ) : sectionId === "featured-places" ? (
      <FeaturedPlaces />
    ) : sectionId === "historical-sites" ? (
      <HistoricalSites />
    ) : sectionId === "food-guide" ? (
      <FoodGuide />
    ) : sectionId === "upcoming-events" ? (
      <UpcomingEvents />
    ) : sectionId === "latest-blog" ? (
      <LatestBlog />
    ) : sectionId === "cta" ? (
      <CTASection />
    ) : null
  )}
</Layout>
