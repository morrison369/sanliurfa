---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import CityUtilities from "../components/CityUtilities.astro";
import FeaturedPlaces from "../components/FeaturedPlaces.astro";
import HistoricalSites from "../components/HistoricalSites.astro";
import FoodGuide from "../components/FoodGuide.astro";
import UpcomingEvents from "../components/UpcomingEvents.astro";
import WeatherWidget from "../components/weather/WeatherWidget.astro";
import Stats from "../components/Stats.astro";
import CTASection from "../components/CTASection.astro";
import LatestBlog from "../components/LatestBlog.astro";
import {
  buildOrganizationSchema,
  buildWebSiteSchema,
} from "../lib/rich-snippets";
import { getPublicSiteSettings } from "../lib/site-settings";

const publicSiteSettings = await getPublicSiteSettings();

const seo = {
  title: "Şanlıurfa Şehir Rehberi - Tarihin Sıfır Noktası",
  description:
    "Şanlıurfa'nın en kapsamlı şehir rehberi. Göbeklitepe, Balıklıgöl, Harran, gastronomi ve daha fazlası. Mekânlar, yorumlar ve puanlama sistemi ile keşfedin.",
  image: "/images/og-home.jpg",
  schemaMode: "replace" as const,
  schema: [
    buildOrganizationSchema(),
    buildWebSiteSchema(),
    {
      "@type": "WebPage",
      "@id": "https://sanliurfa.com/#webpage",
      url: "https://sanliurfa.com",
      name: "Şanlıurfa Şehir Rehberi - Tarihin Sıfır Noktası",
      description:
        "Şanlıurfa'nın en kapsamlı şehir rehberi. Göbeklitepe, Balıklıgöl, Harran, gastronomi ve daha fazlası.",
      inLanguage: "tr-TR",
      isPartOf: { "@id": "https://sanliurfa.com/#website" },
      about: { "@id": "https://sanliurfa.com/#organization" },
      primaryImageOfPage: {
        "@type": "ImageObject",
        url: "https://sanliurfa.com/images/og-home.jpg",
      },
    },
  ],
};
---

<Layout seo={seo}>
  <!-- Hero Section -->
  <Hero settings={publicSiteSettings.hero} />

  <!-- City Utility Section -->
  <CityUtilities services={publicSiteSettings.cityServices} />

  <!-- Weather Widget -->
  <section
    class="bg-gray-50 dark:bg-gray-800 border-y border-gray-100 dark:border-gray-700"
  >
    <div class="container-custom py-6">
      <WeatherWidget />
    </div>
  </section>

  <!-- Stats Section -->
  <Stats />

  <!-- Featured Places -->
  <FeaturedPlaces />

  <!-- Historical Sites -->
  <HistoricalSites />

  <!-- Food Guide -->
  <FoodGuide />

  <!-- Upcoming Events -->
  <UpcomingEvents />

  <!-- Latest Blog Posts -->
  <LatestBlog />

  <!-- CTA Section -->
  <CTASection />
</Layout>
