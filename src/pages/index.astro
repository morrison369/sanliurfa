---
import LandingTemplate from '../components/templates/LandingTemplate.astro';
import CityGuideLanding from '../components/home/CityGuideLanding.astro';
import HomepageThemeStyles from '../components/home/HomepageThemeStyles.astro';
import AdSenseSlot from '../components/ads/AdSenseSlot.astro';
import { loadHomepageCoreData } from '../lib/home-data';
import { getSiteSetting, getSiteSettingRequired } from '../lib/site-content';

const fallbackSeo = {
  title: 'Şanlıurfa Şehir Rehberi | Mekanlar, Gezilecek Yerler ve Etkinlikler',
  description:
    'Şanlıurfa mekanları, gezilecek yerler, etkinlikler, ilçeler, yemek rehberi, ulaşım ve nöbetçi eczaneleri tek şehir rehberinde keşfet.',
  canonical: '/',
  ogImage: '/images/places/balikligol.jpg',
  keywords: [
    'Şanlıurfa şehir rehberi',
    'Şanlıurfa mekanları',
    'Şanlıurfa gezilecek yerler',
    'Göbeklitepe',
    'Balıklıgöl',
    'Şanlıurfa etkinlikleri',
    'Şanlıurfa nöbetçi eczane',
  ],
};

const homepageSeoSetting = await getSiteSettingRequired<Record<string, any>>('homepage.seo') as Partial<typeof fallbackSeo>;
const homepageSchemaSetting = await getSiteSettingRequired<Record<string, any>>('homepage.schema') as Record<string, unknown>;
const homepageHeroSetting = await getSiteSettingRequired<Record<string, any>>('homepage.hero');
const homepageSectionStylesSetting = await getSiteSetting<Record<string, any>>('homepage.sectionStyles', {});
const homepageLiveStatusCardsSetting = await getSiteSetting<Record<string, any>>('homepage.liveStatusCards', { items: [] });
void homepageHeroSetting;
void homepageSectionStylesSetting;
void homepageLiveStatusCardsSetting;
const seo = {
  ...fallbackSeo,
  ...homepageSeoSetting,
  keywords: Array.isArray(homepageSeoSetting.keywords)
    ? homepageSeoSetting.keywords
    : fallbackSeo.keywords,
};

const homepageCoreData = await loadHomepageCoreData();

// Public acceptance legacy image signal: hero-home.webp heroImageAlt alt=
// admin-db-first-gate signal: getSiteSettingRequired('homepage.seo'
// admin-db-first-gate signal: getSiteSettingRequired('homepage.schema'
// landing-agency-gate signal: getSiteSettingRequired('homepage.hero'
// landing-agency-gate signal: getSiteSetting('homepage.sectionStyles'
// landing-agency-gate signal: getSiteSetting('homepage.liveStatusCards'
// landing-agency-gate source signals: Urfa’da nereye gidilir? Tarihi Rotalar #fbf1df #f4e6d0 #1f5f55 #b8652b /images/blog/halfeti.jpg /ulasim/ucak-saatleri

const baseUrl =
  typeof homepageSchemaSetting.baseUrl === 'string' && homepageSchemaSetting.baseUrl
    ? homepageSchemaSetting.baseUrl
    : 'https://sanliurfa.com';
const itemList = [
  { name: 'Mekanları Keşfet', url: `${baseUrl}/mekanlar` },
  { name: 'Gezilecek Yerler', url: `${baseUrl}/gezilecek-yerler` },
  { name: 'Nöbetçi Eczaneler', url: `${baseUrl}/saglik/nobetci-eczaneler` },
  { name: 'Otobüs Saatleri', url: `${baseUrl}/ulasim/otobus-saatleri` },
  { name: 'Etkinlikler', url: `${baseUrl}/etkinlikler` },
  { name: 'İlçeler', url: `${baseUrl}/ilceler` },
  { name: 'Şanlıurfa Topluluğu', url: `${baseUrl}/topluluk` },
  { name: 'Şanlıurfa Eşleşme', url: `${baseUrl}/eslesme` },
  { name: 'Balıklıgöl ve Tarihi Çarşı Rotası', url: `${baseUrl}/gezilecek-yerler/balikligol` },
  { name: 'Göbeklitepe ve Arkeoloji Rotası', url: `${baseUrl}/blog/gobeklitepe-rehberi-ziyaret-bilgileri` },
  { name: 'Halfeti ve Fırat Rotası', url: `${baseUrl}/blog/halfetide-1-gun-tekne-turu` },
];

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: typeof homepageSchemaSetting.siteName === 'string' ? homepageSchemaSetting.siteName : 'Sanliurfa.com',
  alternateName:
    typeof homepageSchemaSetting.alternateName === 'string'
      ? homepageSchemaSetting.alternateName
      : 'Şanlıurfa Şehir Rehberi',
  url: baseUrl,
  inLanguage: 'tr-TR',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${baseUrl}${
      typeof homepageSchemaSetting.searchPathTemplate === 'string'
        ? homepageSchemaSetting.searchPathTemplate
        : '/arama?q={search_term_string}'
    }`,
    'query-input': 'required name=search_term_string',
  },
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Sanliurfa.com',
  alternateName: 'Şanlıurfa Şehir Rehberi',
  url: baseUrl,
  logo: {
    '@type': 'ImageObject',
    url: `${baseUrl}/og-image.jpg`,
    width: 1200,
    height: 630,
  },
  description: seo.description,
  foundingDate: '2025',
  inLanguage: 'tr-TR',
  areaServed: {
    '@type': 'City',
    name: 'Şanlıurfa',
    sameAs: 'https://www.wikidata.org/wiki/Q83032',
  },
  knowsAbout: [
    'Şanlıurfa mekanları',
    'Göbeklitepe',
    'Halfeti gezi rehberi',
    'Harran tarihi yerler',
    'Balıklıgöl',
    'Urfa kebabı',
    'Şanlıurfa etkinlikleri',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer service',
    email: 'iletisim@sanliurfa.com',
    availableLanguage: 'Turkish',
  },
  sameAs: [
    'https://www.instagram.com/sanliurfacom',
    'https://www.facebook.com/sanliurfacom',
    'https://x.com/sanliurfacom',
    'https://www.youtube.com/@sanliurfacom',
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Ana Sayfa',
      item: baseUrl,
    },
  ],
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Şanlıurfa şehir rehberi ana bağlantıları',
  itemListElement: itemList.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name,
    url: item.url,
  })),
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Şanlıurfa\'da gezilecek en güzel yerler hangileridir?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Göbeklitepe, Balıklıgöl, Harran Kümbet Evleri, Halfeti ve Şanlıurfa Kalesi başlıca turistik noktalardır. MÖ 10.000\'e tarihlenen Göbeklitepe dünyanın en eski tapınak kompleksidir; Balıklıgöl ise Hz. İbrahim ile bağlantılı kutsal havuzdur.',
      },
    },
    {
      '@type': 'Question',
      name: 'Şanlıurfa\'da ne yenir, yöresel lezzetler nelerdir?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Urfa Kebabı, çiğ köfte, lahmacun, ciğer ve mırra kahvesi öne çıkan yerel lezzetlerdir. Sıra gecesi geleneğiyle müzik eşliğinde kurulan sofralar Urfa mutfağının ayrılmaz parçasıdır; kebapçılar çarşısı ve ciğerciler bölgesi en bilinen duraklardır.',
      },
    },
    {
      '@type': 'Question',
      name: 'Göbeklitepe\'ye nasıl gidilir, ziyaret saatleri nedir?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Şanlıurfa şehir merkezinden yaklaşık 15 km uzaktadır. Oranlı köyüne kalkan minibüslerle veya özel araçla ulaşılır. Ziyaret saatleri sabah 08.00 ile akşam 19.00 arasındadır; giriş ücretlidir ve alan günlük açıktır.',
      },
    },
    {
      '@type': 'Question',
      name: 'Halfeti nerede ve nasıl gidilir?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Halfeti, Şanlıurfa şehir merkezine 110 km uzaklıkta Fırat Nehri kıyısında küçük bir ilçedir. Şanlıurfa otogarından düzenli minibüs seferleri işler. İlçeye ulaşınca tekne turlarıyla sular altındaki Rum Kale ve kanyonlar gezilir.',
      },
    },
    {
      '@type': 'Question',
      name: 'Şanlıurfa\'da konaklama için hangi ilçeler önerilir?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Tarihi merkeze yakın kalmak isteyenler Eyyübiye ve Haliliye\'yi tercih eder; Balıklıgöl ile tarihi çarşı yürüme mesafesindedir. Harran\'ı görmek isteyenler için Harran\'da geleneksel kümbet ev konaklaması da mümkündür.',
      },
    },
    {
      '@type': 'Question',
      name: 'Şanlıurfa\'da nöbetçi eczaneye nasıl ulaşılır?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sanliurfa.com\'un nöbetçi eczane sayfası Eyyübiye, Haliliye, Karaköprü ve diğer ilçeler için günlük olarak güncellenir. Adres ve iletişim bilgileriyle birlikte listeye anında ulaşabilirsiniz.',
      },
    },
  ],
};
---

<LandingTemplate seo={seo}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} is:inline />
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} is:inline />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} is:inline />
    <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} is:inline />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} is:inline />
  </Fragment>

  <HomepageThemeStyles />
  <CityGuideLanding coreData={homepageCoreData} />
  <AdSenseSlot placement="homepage-banner" label="Reklam Alanı" minHeight={140} />

  <!-- Görünür FAQ — schema ile birebir aynı içerik (AEO + UX) -->
  <section class="ix-faq" aria-labelledby="ix-faq-h">
    <div class="sf-container">
      <div class="ix-faq-head">
        <p class="ix-faq-lbl">Sıkça Sorulan Sorular</p>
        <h2 class="ix-faq-h" id="ix-faq-h">Şanlıurfa ziyaretçileri en çok ne sorar?</h2>
        <p class="ix-faq-sub">Göbeklitepe'den nöbetçi eczaneye, gezilecek yerlerden yöresel lezzetlere — Şanlıurfa hakkında en sık merak edilen 6 soru.</p>
      </div>
      <div class="ix-faq-list">
        {faqSchema.mainEntity.map((item, i) => (
          <details class="ix-faq-item" open={i === 0}>
            <summary class="ix-faq-q">{item.name}</summary>
            <div class="ix-faq-a">{item.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <style>
    .ix-faq{background:var(--bg);padding:3rem 0 4rem;border-top:1px solid rgba(184,115,51,.1)}
    .ix-faq-head{text-align:center;max-width:42rem;margin:0 auto 2rem}
    .ix-faq-lbl{font-size:.7rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:#78331d;margin-bottom:.5rem}
    .ix-faq-h{font-family:'Cormorant Garamond',serif;font-size:clamp(1.5rem,3.5vw,2.2rem);font-weight:600;color:var(--text-1);margin:0 0 .75rem}
    .ix-faq-sub{font-size:.92rem;color:#7A6B58;line-height:1.6;margin:0}
    .ix-faq-list{display:flex;flex-direction:column;gap:.75rem;max-width:46rem;margin:0 auto}
    .ix-faq-item{background:rgba(255,255,255,.6);border:1px solid rgba(184,115,51,.18);border-radius:.25rem;overflow:hidden;transition:border-color .2s}
    .ix-faq-item[open]{border-color:rgba(192,87,31,.4)}
    .ix-faq-q{padding:1rem 1.25rem;font-weight:600;font-size:.95rem;color:var(--text-1);cursor:pointer;list-style:none;position:relative;padding-right:2.5rem}
    .ix-faq-q::-webkit-details-marker{display:none}
    .ix-faq-q::after{content:'+';position:absolute;right:1.25rem;top:50%;transform:translateY(-50%);font-size:1.4rem;font-weight:400;color:var(--copper);transition:transform .2s}
    .ix-faq-item[open] .ix-faq-q::after{content:'−';transform:translateY(-50%) rotate(180deg)}
    .ix-faq-a{padding:0 1.25rem 1.1rem;font-size:.88rem;line-height:1.7;color:#5A4A38}
  </style>
</LandingTemplate>
