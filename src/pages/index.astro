    {isSectionEnabled('districts') && districts.length > 0 && (
      <section class={sectionStyles.districtsSectionClass} style={`order:${getSectionOrder('districts')}`}>
        <div class={sectionStyles.districtsContainerClass}>
          <div class={sectionStyles.districtsHeaderWrapClass}>
            <h2 class={sectionStyles.sectionHeadingClass}>{sectionCopy.districtsTitle}</h2>
            <a href="/ilceler" class={sectionStyles.sectionCtaLinkClass}>{sectionCopy.districtsCtaLabel}</a>
          </div>
          <div class={sectionStyles.districtsGridClass}>
            {districts.map((district) => (
              <a href={`/ilceler/${district.slug}`} class={sectionStyles.districtsCardClass}>
                <h3 class="font-bold text-lg text-slate-900">{district.name}</h3>
                <p class={sectionStyles.sectionMutedTextLineClampClass}>{district.description || 'İlçe bazlı mekan, sağlık ve günlük yaşam içerikleri.'}</p>
                <p class="mt-3 text-xs font-semibold text-slate-500">{district.place_count || 0} aktif mekan</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    {isSectionEnabled('historical-sites') && featuredSites.length > 0 && (
      <section class={sectionStyles.historicalSitesSectionClass} style={`order:${getSectionOrder('historical-sites')}`}>
        <div class={sectionStyles.historicalSitesContainerClass}>
          <div class={sectionStyles.historicalSitesHeaderWrapClass}>
            <h2 class={sectionStyles.sectionHeadingClass}>{sectionCopy.historicalSitesTitle}</h2>
            <a href="/gezilecek-yerler" class="text-amber-700 font-semibold hover:text-amber-800">{sectionCopy.historicalSitesCtaLabel}</a>
          </div>
          <div class={sectionStyles.historicalSitesGridClass}>
            {featuredSites.map((site) => (
              <a href={`/gezilecek-yerler/${site.slug}`} class={sectionStyles.historicalSitesCardClass}>
                <div class={sectionStyles.historicalSitesImageWrapClass}>
                  <img
                    src={getHistoricalCardImage(site)}
                    alt={site.name}
                    class={sectionStyles.historicalSitesImageClass}
                    loading="lazy"
                    onerror="this.setAttribute('src','/images/hero/hero-home.webp')"
                  />
                </div>
                <div class="p-4">
                  <h3 class="font-bold text-lg text-slate-900">{site.name}</h3>
                  <p class={sectionStyles.sectionMutedTextLineClampClass}>{site.short_description || 'Şanlıurfa tarihi ve turistik noktaları hakkında özet bilgi.'}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    {isSectionEnabled('featured-places') && featuredPlaces.length > 0 && (
      <section class={sectionStyles.featuredPlacesSectionClass} style={`order:${getSectionOrder('featured-places')}`}>
        <div class={sectionStyles.featuredPlacesContainerClass}>
          <div class={sectionStyles.featuredPlacesHeaderWrapClass}>
            <h2 class={sectionStyles.sectionHeadingClass}>{sectionCopy.featuredPlacesTitle}</h2>
            <a href="/mekanlar" class={sectionStyles.sectionCtaLinkClass}>{sectionCopy.featuredPlacesCtaLabel}</a>
          </div>
          <div class={sectionStyles.featuredPlacesGridClass}>
            {featuredPlaces.map((place) => (
              <PlaceCard place={place} />
            ))}
          </div>
        </div>
      </section>
    )}

    {isSectionEnabled('recent-places') && recentPlaces.length > 0 && (
      <section class={sectionStyles.recentPlacesSectionClass} style={`order:${getSectionOrder('recent-places')}`}>
        <div class={sectionStyles.recentPlacesContainerClass}>
          <h2 class={sectionStyles.sectionHeadingSpacedLgClass}>{sectionCopy.recentPlacesTitle}</h2>
          <div class={sectionStyles.recentPlacesGridClass}>
            {recentPlaces.map((place) => (
              <PlaceCard place={place} compact />
            ))}
          </div>
        </div>
      </section>
    )}

    {isSectionEnabled('trust-signals') && recentTrustSignals.length > 0 && (
      <section class={sectionStyles.trustSignalsSectionClass} style={`order:${getSectionOrder('trust-signals')}`}>
        <div class={sectionStyles.trustSignalsContainerClass}>
          <div class={sectionStyles.trustSignalsHeaderWrapClass}>
            <h2 class={sectionStyles.sectionHeadingClass}>{sectionCopy.trustSignalsTitle}</h2>
            <p class="text-sm text-slate-500">{sectionCopy.trustSignalsSubtitle}</p>
          </div>
          <div class={sectionStyles.trustSignalsGridClass}>
            {recentTrustSignals.map((place) => (
              <a href={`/isletme/${place.slug}`} class={sectionStyles.trustSignalsCardClass}>
                <h3 class="font-bold text-slate-900">{place.name}</h3>
                <p class="mt-1 text-sm text-slate-600">{place.district}</p>
                <div class="mt-3 flex items-center justify-between text-xs">
                  <span class="font-semibold text-slate-500">Güncelleme: {place.updatedAt}</span>
                  <span class="rounded-full bg-urfa-100 px-2 py-1 font-semibold text-urfa-700">Puan: {place.rating}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    {isSectionEnabled('guides-community') && (
    <section class={sectionStyles.guidesCommunitySectionClass} style={`order:${getSectionOrder('guides-community')}`}>
      <div class={sectionStyles.guidesCommunityContainerClass}>
        <div class={sectionStyles.guidesCommunityPanelClass}>
          <h2 class="text-xl font-bold text-amber-900">{communityPanel.title}</h2>
          <p class="mt-1 text-sm text-amber-800">{communityPanel.description}</p>
          <div class={sectionStyles.guidesCommunityLinksWrapClass}>
            {communityPanel.items.map((item: any) => (
              <a
                href={item.href}
                class={sectionStyles.guidesCommunityLinkClass}
              >
                {item.label}
              </a>
            ))}
          </div>
        </div>
        <h2 class={sectionStyles.sectionHeadingSpacedClass}>{sectionCopy.guidesTitle}</h2>
        <div class={sectionStyles.guidesCommunityGridClass}>
          {featuredGuides.map((guide) => (
            <a href={guide.href} class={sectionStyles.guidesCommunityGuideCardClass}>
              {guide.title}
            </a>
          ))}
        </div>
      </div>
    </section>
    )}

    {isSectionEnabled('audience-plans') && (
      <section class={sectionStyles.audiencePlansSectionClass} style={`order:${getSectionOrder('audience-plans')}`}>
        <div class={sectionStyles.audiencePlansContainerClass}>
          <div class={sectionStyles.audiencePlansHeaderWrapClass}>
            <div>
              <h2 class={sectionStyles.sectionHeadingClass}>{sectionCopy.audiencePlansTitle}</h2>
              <p class="mt-1 text-slate-300">{sectionCopy.audiencePlansDescription}</p>
            </div>
          </div>
          <div class={sectionStyles.audiencePlansGridClass}>
            {audiencePlans.map((plan) => (
              <article class={sectionStyles.audiencePlansCardClass}>
                <span class={sectionStyles.audiencePlansBadgeClass}>{plan.badge}</span>
                <h3 class="mt-4 text-2xl font-bold text-white">{plan.title}</h3>
                <p class="mt-2 text-sm text-slate-300">{plan.description}</p>
                <ul class={sectionStyles.audiencePlansListClass}>
                  {plan.bullets.map((bullet) => (
                    <li class="flex items-start gap-2">
                      <span class="mt-1 h-2 w-2 rounded-full bg-urfa-400"></span>
                      <span>{bullet}</span>
                    </li>
                  ))}
                </ul>
                <a href={plan.href} class={sectionStyles.audiencePlansActionClass}>{plan.cta}</a>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

    {isSectionEnabled('district-spotlights') && districtSpotlights.length > 0 && (
      <section class={sectionStyles.districtSpotlightsSectionClass} style={`order:${getSectionOrder('district-spotlights')}`}>
        <div class={sectionStyles.districtSpotlightsContainerClass}>
          <div class={sectionStyles.districtSpotlightsHeaderWrapClass}>
            <div>
              <h2 class={sectionStyles.sectionHeadingClass}>{sectionCopy.districtSpotlightsTitle}</h2>
              <p class="mt-1 text-slate-600">{sectionCopy.districtSpotlightsDescription}</p>
            </div>
            <a href="/ilceler" class={sectionStyles.sectionCtaLinkClass}>{sectionCopy.districtSpotlightsCtaLabel}</a>
          </div>
          <div class={sectionStyles.districtSpotlightsGridClass}>
            {districtSpotlights.map((item: any) => (
              <article class={sectionStyles.districtSpotlightsCardClass}>
                <p class="text-xs font-semibold uppercase tracking-[0.22em] text-urfa-600">{item.district_name}</p>
                <a href={`/isletme/${item.place_slug}`} class="mt-3 block text-xl font-bold text-slate-900 hover:text-urfa-700">
                  {item.place_name}
                </a>
                <div class="mt-4 flex items-center justify-between text-sm">
                  <span class="rounded-full bg-emerald-50 px-3 py-1 font-semibold text-emerald-700">
                    Puan {item.rating ? Number(item.rating).toFixed(1) : '-'}
                  </span>
                  <span class="text-slate-500">{Number(item.review_count || 0)} yorum</span>
                </div>
                <a href={`/ilceler/${item.district_slug}`} class="mt-4 inline-flex items-center text-sm font-semibold text-slate-700 hover:text-urfa-700">
                  {item.district_name} rehberini aç
                </a>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

    {isSectionEnabled('recent-reviews') && reviewHighlights.length > 0 && (
      <section class={sectionStyles.recentReviewsSectionClass} style={`order:${getSectionOrder('recent-reviews')}`}>
        <div class={sectionStyles.recentReviewsContainerClass}>
          <div class={sectionStyles.recentReviewsHeaderWrapClass}>
            <div>
              <h2 class={sectionStyles.sectionHeadingClass}>{sectionCopy.recentReviewsTitle}</h2>
              <p class="mt-1 text-slate-600">{sectionCopy.recentReviewsDescription}</p>
            </div>
          </div>
          <div class={sectionStyles.recentReviewsGridClass}>
            {reviewHighlights.map((item: any) => (
              <article class={sectionStyles.recentReviewsCardClass}>
                <div class="flex items-center justify-between gap-3">
                  <a href={`/isletme/${item.place_slug}`} class="font-bold text-slate-900 hover:text-urfa-700">
                    {item.place_name}
                  </a>
                  <span class="rounded-full bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700">
                    {item.rating ? `${Number(item.rating).toFixed(1)} / 5` : 'Yeni yorum'}
                  </span>
                </div>
                <p class="mt-3 line-clamp-4 text-sm leading-6 text-slate-600">"{item.excerpt}"</p>
                <div class="mt-4 flex items-center justify-between text-xs text-slate-500">
                  <span>{item.author_name}</span>
                  <span>{item.createdLabel}</span>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

    {isSectionEnabled('main-categories') && mainCategories.length > 0 && (
      <section class={sectionStyles.mainCategoriesSectionClass} style={`order:${getSectionOrder('main-categories')}`}>
        <div class={sectionStyles.mainCategoriesContainerClass}>
          <h2 class={sectionStyles.sectionHeadingSpacedClass}>{sectionCopy.mainCategoriesTitle}</h2>
          <div class={sectionStyles.mainCategoriesGridClass}>
            {mainCategories.map((cat) => (
              <a
                href={
                  ['mekanlar', 'gezilecek-yerler', 'etkinlikler', 'saglik', 'egitim', 'ulasim', 'alisveris', 'hizmetler', 'emlak', 'konaklama', 'yeme-icme', 'ilceler', 'blog'].includes(cat.slug)
                    ? `/${cat.slug}`
                    : `/mekanlar/${cat.slug}`
                }
                class={sectionStyles.mainCategoriesCardClass}
              >
                {cat.name}
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    {isSectionEnabled('recipes') && featuredRecipes.length > 0 && (
      <section class={sectionStyles.recipesSectionClass} style={`order:${getSectionOrder('recipes')}`}>
        <div class={sectionStyles.recipesContainerClass}>
          <div class={sectionStyles.recipesHeaderWrapClass}>
            <h2 class={sectionStyles.sectionHeadingClass}>{sectionCopy.recipesTitle}</h2>
            <a href="/yemek-tarifleri" class={sectionStyles.sectionCtaLinkClass}>{sectionCopy.recipesCtaLabel}</a>
          </div>
          <div class={sectionStyles.recipesGridClass}>
            {featuredRecipes.map((recipe) => (
              <a href={`/yemek-tarifleri/${recipe.slug}`} class={sectionStyles.recipesCardClass}>
                <div class={sectionStyles.recipesImageWrapClass}>
                  <img
                    src={recipe.cover_image || '/images/foods/default.jpg'}
                    alt={recipe.name}
                    class={sectionStyles.recipesImageClass}
                    loading="lazy"
                    onerror="this.setAttribute('src','/images/foods/default.jpg')"
                  />
                </div>
                <div class="p-4">
                  <h3 class="font-bold text-slate-900">{recipe.name}</h3>
                  <p class="mt-1 text-sm text-slate-600 line-clamp-2">{recipe.description || 'Şanlıurfa mutfağına ait özel tarif içeriği.'}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    {isSectionEnabled('blog') && recentPosts.length > 0 && (
      <section class={sectionStyles.blogSectionClass} style={`order:${getSectionOrder('blog')}`}>
        <div class={sectionStyles.blogContainerClass}>
          <div class={sectionStyles.blogHeaderWrapClass}>
            <h2 class={sectionStyles.sectionHeadingClass}>{sectionCopy.blogTitle}</h2>
            <a href="/blog" class={sectionStyles.sectionCtaLinkClass}>{sectionCopy.blogCtaLabel}</a>
          </div>
          <div class={sectionStyles.blogGridClass}>
            {recentPosts.map((post) => (
              <a href={`/blog/${post.slug}`} class={sectionStyles.blogCardClass}>
                {post.cover_image ? (
                  <img src={post.cover_image} alt={post.title} class={sectionStyles.blogImageClass} loading="lazy" />
                ) : (
                  <div class={sectionStyles.blogImageFallbackClass}></div>
                )}
                <div class="p-4">
                  <p class="text-xs font-semibold uppercase tracking-wider text-urfa-600">{post.category || 'Rehber'}</p>
                  <h3 class="mt-2 font-bold text-slate-900 line-clamp-2">{post.title}</h3>
                  <p class="mt-2 text-sm text-slate-600 line-clamp-2">{post.excerpt || 'Şanlıurfa hakkında güncel rehber içerikleri.'}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    {isSectionEnabled('faq') && (
    <section class={sectionStyles.faqSectionClass} style={`order:${getSectionOrder('faq')}`}>
      <div class={sectionStyles.faqContainerClass}>
        <div class={sectionStyles.faqIntroWrapClass}>
          <h2 class={sectionStyles.sectionHeadingClass}>{sectionCopy.faqTitle}</h2>
          <p class="mt-2 text-slate-300">{sectionCopy.faqDescription}</p>
        </div>
        <div class={sectionStyles.faqGridClass}>
          {faqItems.map((item) => (
            <article class={sectionStyles.faqCardClass}>
              <h3 class="font-semibold text-white">{item.S}</h3>
              <p class="mt-2 text-sm text-slate-300">{item.C}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
    )}

    {isSectionEnabled('main-cta') && (
    <section class={sectionStyles.mainCtaSectionClass} style={`order:${getSectionOrder('main-cta')}`}>
      <div class={sectionStyles.mainCtaContainerClass}>
        <h2 class="text-3xl md:text-4xl font-extrabold">{mainCtaConfig.title}</h2>
        <p class={sectionStyles.mainCtaDescriptionClass}>
          {mainCtaConfig.description}
        </p>
        <div class={sectionStyles.mainCtaActionsWrapClass}>
          <a href={mainCtaConfig.primaryHref} class={sectionStyles.mainCtaPrimaryButtonClass}>{mainCtaConfig.primaryLabel}</a>
          <a href={mainCtaConfig.secondaryHref} class={sectionStyles.mainCtaSecondaryButtonClass}>{mainCtaConfig.secondaryLabel}</a>
        </div>
      </div>
    </section>
    )}
  </div>
</Layout>
