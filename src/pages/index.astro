<Layout seo={seo}>
  <Fragment slot="head">
    <link rel="preload" as="image" href={heroConfig.backgroundImage} fetchpriority="high" />
  </Fragment>

  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: homepageSchema.siteName,
      alternateName: homepageSchema.alternateName,
      url: homepageSchema.baseUrl,
      inLanguage: 'tr-TR',
      potentialAction: {
        '@type': 'SearchAction',
        target: `${homepageSchema.baseUrl}${homepageSchema.searchPathTemplate}`,
        'query-input': 'required name=search_term_string',
      },
    })}
    is:inline
  />

  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'ItemList',
      name: homepageSchema.trendingListName,
      itemListElement: trendingSearches.slice(0, 10).map((item, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: item.query,
        url: `${homepageSchema.baseUrl}/arama?q=${encodeURIComponent(item.query)}`,
      })),
    })}
    is:inline
  />

  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      '@id': `${homepageSchema.baseUrl}${homepageSchema.organizationId}`,
      name: homepageSchema.siteName,
      url: homepageSchema.baseUrl,
      areaServed: {
        '@type': 'City',
        name: homepageSchema.cityName,
      },
      sameAs: [],
    })}
    is:inline
  />

  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      '@id': `${homepageSchema.baseUrl}${homepageSchema.webpageId}`,
      url: `${homepageSchema.baseUrl}/`,
      name: homepageSchema.webpageName,
      inLanguage: 'tr-TR',
      isPartOf: {
        '@id': `${homepageSchema.baseUrl}${homepageSchema.organizationId}`,
      },
      about: {
        '@type': 'City',
        name: homepageSchema.cityName,
      },
    })}
    is:inline
  />

  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqItems.map((item) => ({
        '@type': 'Question',
        name: item.S,
        acceptedAnswer: { '@type': 'Answer', text: item.C },
      })),
    })}
    is:inline
  />

  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'ItemList',
      name: homepageSchema.servicesListName,
      itemListElement: primaryActions.map((item, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: item.title,
        url: `${homepageSchema.baseUrl}${item.href}`,
      })),
    })}
    is:inline
  />

  <div class="bg-slate-950 text-slate-100 flex flex-col">
    {isSectionEnabled('hero') && (
    <section class={heroMeta.heroSectionClass} style={`order:${getSectionOrder('hero')}`}>
      <div class="absolute inset-0">
        <img
          src={heroConfig.backgroundImage}
          alt={heroMeta.heroImageAlt}
          class="h-full w-full object-cover opacity-20"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          width="1600"
          height="900"
        />
      </div>
      <div class={heroMeta.heroOverlayClass}></div>
      <div class={heroMeta.heroContainerClass}>
        <div class={heroMeta.heroGridClass}>
          <div>
            <p class={heroMeta.heroBadgeClass}>
              {heroConfig.badge}
            </p>
            <h1 class={heroMeta.heroTitleClass}>
              {heroConfig.title}
            </h1>
            <p class={heroMeta.heroDescriptionClass}>
              {heroConfig.description}
            </p>

            <form action="/arama" class={heroMeta.searchFormClass}>
              <div class={heroMeta.searchRowClass}>
                <input
                  type="text"
                  name="q"
                  placeholder={heroConfig.searchPlaceholder}
                  class={heroMeta.searchInputClass}
                />
                <button type="submit" class={heroMeta.searchButtonClass}>
                  {heroMeta.searchButtonLabel}
                </button>
              </div>
            </form>

            <div class="mt-5 flex flex-wrap gap-2">
              {heroQuickLinks.map((item: any) => (
                <a
                  href={item.href}
                  class={`${heroMeta.heroQuickLinkClass} ${heroMeta.heroQuickLinkHoverClass}`}
                >
                  {item.label}
                </a>
              ))}
            </div>

            <div class="mt-7 grid sm:grid-cols-2 gap-3 max-w-2xl">
              <a href="/isletme-kayit" class={heroMeta.businessCardClass}>
                <p class="text-xs font-semibold uppercase tracking-wide text-urfa-300">{heroMeta.businessCardBadge}</p>
                <h2 class="mt-1 text-base font-bold text-white">{heroMeta.businessCardTitle}</h2>
                <p class="mt-1 text-sm text-slate-200">{heroMeta.businessCardDescription}</p>
              </a>
              <a href="/topluluk" class={heroMeta.communityCardClass}>
                <p class="text-xs font-semibold uppercase tracking-wide text-sky-200">{heroMeta.communityCardBadge}</p>
                <h2 class="mt-1 text-base font-bold text-white">{heroMeta.communityCardTitle}</h2>
                <p class="mt-1 text-sm text-slate-200">{heroMeta.communityCardDescription}</p>
              </a>
            </div>
          </div>

          <div class={heroMeta.heroStatsPanelClass}>
            <h2 class={heroMeta.heroStatsPanelTitleClass}>{heroMeta.statsPanelTitle}</h2>
            <p class={heroMeta.heroStatsPanelSubtitleClass}>{heroMeta.statsPanelSubtitle}</p>
            <div class="mt-5 grid grid-cols-2 gap-3">
              <div class={heroMeta.statsCardClass}>
                <p class={heroMeta.statsLabelClass}>{heroMeta.statsActivePlacesLabel}</p>
                <p class={heroMeta.statsValueClass}>{totalPlaceCount}+</p>
              </div>
              <div class={heroMeta.statsCardClass}>
                <p class={heroMeta.statsLabelClass}>{heroMeta.statsPharmacyLabel}</p>
                <p class={heroMeta.statsValueClass}>{pharmacyCount}+</p>
              </div>
              <div class={heroMeta.statsCardClass}>
                <p class={heroMeta.statsLabelClass}>{heroMeta.statsBusRouteLabel}</p>
                <p class={heroMeta.statsValueClass}>{busRouteCount}+</p>
              </div>
              <div class={heroMeta.statsCardClass}>
                <p class={heroMeta.statsLabelClass}>{heroMeta.statsEventsLabel}</p>
                <p class={heroMeta.statsValueClass}>{upcomingEventsCount}+</p>
              </div>
            </div>
            <p class={heroMeta.heroStatsUpdatedClass}>{heroMeta.statsUpdatedPrefix} {new Date(generatedAtIso).toLocaleDateString('tr-TR')}</p>
          </div>
        </div>
      </div>
    </section>
    )}

    {isSectionEnabled('mvp-quick-start') && (
    <section
      id="mvp-hizli-baslangic"
      data-section="mvp-quick-start"
      class={sectionStyles.mvpQuickStartSectionClass}
      style={`order:${getSectionOrder('mvp-quick-start')}`}
    >
      <div class={sectionStyles.mvpQuickStartContainerClass}>
        <div class={sectionStyles.mvpQuickStartPanelClass}>
          <div class={sectionStyles.mvpQuickStartHeaderClass}>
            <div>
              <p class={sectionStyles.mvpQuickStartBadgeClass}>
                {sectionCopy.mvpQuickStartBadge}
              </p>
              <h2 class={sectionStyles.mvpQuickStartTitleClass}>
                {sectionCopy.mvpQuickStartTitle}
              </h2>
              <p class={sectionStyles.mvpQuickStartDescriptionClass}>
                {sectionCopy.mvpQuickStartDescription}
              </p>
            </div>
            <a
              href={sectionCopy.mvpQuickStartCtaHref}
              class={sectionStyles.mvpQuickStartCtaClass}
            >
              {sectionCopy.mvpQuickStartCtaLabel}
            </a>
          </div>
          <div class={sectionStyles.mvpQuickStartGridClass}>
            {mvpQuickStartCards.map((card) => (
              <article class={sectionStyles.mvpQuickStartCardClass}>
                <a href={card.href} class={sectionStyles.mvpQuickStartCardLinkClass}>
                  <span class={sectionStyles.mvpQuickStartCardBadgeClass}>
                    {card.badge}
                  </span>
                  <h3 class={sectionStyles.mvpQuickStartCardTitleClass}>{card.title}</h3>
                  <p class={sectionStyles.mvpQuickStartCardDescriptionClass}>{card.description}</p>
                </a>
                <div class={sectionStyles.mvpQuickStartLinksWrapClass}>
                  {card.links.map((link) => (
                    <a
                      href={link.href}
                      class={sectionStyles.mvpQuickStartLinkClass}
                    >
                      {link.label}
                    </a>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>
    )}

    {isSectionEnabled('quick-actions') && (
    <section class={sectionStyles.quickActionsSectionClass} style={`order:${getSectionOrder('quick-actions')}`}>
      <div class={sectionStyles.quickActionsContainerClass}>
        <div class={sectionStyles.quickActionsHeaderWrapClass}>
          <div>
            <h2 class={sectionStyles.sectionHeadingClass}>{sectionCopy.quickActionsTitle}</h2>
            <p class="text-slate-600 mt-1">{sectionCopy.quickActionsDescription}</p>
          </div>
          <a href="/kesfet" class={`hidden sm:inline ${sectionStyles.sectionCtaLinkClass}`}>{sectionCopy.quickActionsCtaLabel}</a>
        </div>
        <div class={sectionStyles.quickActionsGridClass}>
          {primaryActions.map((item) => (
            <a href={item.href} class={sectionStyles.quickActionsCardClass}>
              <p class="text-xs font-semibold uppercase tracking-wider text-urfa-600">{item.stat}</p>
              <h3 class="mt-2 text-lg font-bold text-slate-900 group-hover:text-urfa-700">{item.title}</h3>
              <p class="mt-1 text-sm text-slate-600">{item.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
    )}

    {isSectionEnabled('live-status') && (
    <section class={sectionStyles.liveStatusSectionClass} style={`order:${getSectionOrder('live-status')}`}>
      <div class={sectionStyles.liveStatusContainerClass}>
        <div class={sectionStyles.liveStatusHeaderWrapClass}>
          <div>
            <h2 class={sectionStyles.sectionHeadingClass}>{sectionCopy.liveStatusTitle}</h2>
            <p class="text-slate-300 mt-1">{sectionCopy.liveStatusDescription}</p>
          </div>
          <p class="text-xs text-slate-400">{sectionCopy.liveStatusUpdatedPrefix}: {lastUpdatedLabel}</p>
        </div>

        <div class={sectionStyles.liveStatusGridClass}>
          {liveStatusCards.map((card: any) => (
            <article class={sectionStyles.liveStatusCardClass}>
              <div class="flex items-start justify-between gap-3">
                <h3 class="font-semibold text-white">{card.title}</h3>
                <span class={`inline-flex items-center rounded-full border px-2.5 py-1 text-[11px] font-semibold ${card.badgeClass}`}>
                  {card.statusText}
                </span>
              </div>
              <p class="mt-4 text-3xl font-extrabold tracking-tight text-white">{card.metric}</p>
              <p class="text-sm text-slate-400">{card.metricLabel}</p>
              <p class="mt-1 text-xs text-slate-500">Veri tazeliği: {card.freshness}</p>
              <a
                href={card.href}
                class="mt-5 inline-flex items-center rounded-xl border border-slate-600 bg-slate-950 px-4 py-2 text-sm font-semibold text-white transition hover:border-urfa-400 hover:text-urfa-200"
              >
                {card.cta}
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
    )}

    {isSectionEnabled('district-service') && (
    <section class={sectionStyles.districtServiceSectionClass} style={`order:${getSectionOrder('district-service')}`}>
      <div class={sectionStyles.districtServiceContainerClass}>
        <div class={sectionStyles.districtServiceHeaderWrapClass}>
          <div>
            <h2 class={sectionStyles.sectionHeadingClass}>{sectionCopy.districtServiceTitle}</h2>
            <p class="text-slate-300 mt-1">{sectionCopy.districtServiceDescription}</p>
          </div>
          <a href="/ilceler" class="text-sm font-semibold text-urfa-300 hover:text-urfa-200">{sectionCopy.districtServiceCtaLabel}</a>
        </div>

        <div class={sectionStyles.districtServiceGridClass}>
          {serviceQuickLinks.map((item: any) => {
            const labelClass =
              item.key === 'pharmacy'
                ? 'text-emerald-300'
                : item.key === 'bus'
                  ? 'text-sky-300'
                  : item.key === 'flight'
                    ? 'text-violet-300'
                    : 'text-slate-300';
            return (
              <a href={item.href} class={`${sectionStyles.districtServiceCardClass} ${item.hoverBorderClass || 'hover:border-urfa-400/60'}`}>
                <p class={`text-xs font-semibold uppercase tracking-wide ${labelClass}`}>{item.categoryLabel}</p>
                <h3 class="mt-2 text-lg font-bold">{item.title}</h3>
                <p class="mt-2 text-sm text-slate-300">{item.description}</p>
              </a>
            );
          })}
        </div>

        {districtServiceLinks.length > 0 && (
          <div class={sectionStyles.districtServiceChipsWrapClass}>
            {districtServiceLinks.map((district) => (
              <a
                href={district.href}
                class={sectionStyles.districtServiceChipClass}
              >
                {district.name} <span class="text-slate-400">({district.placeCount})</span>
              </a>
            ))}
          </div>
        )}
      </div>
    </section>
    )}

    {isSectionEnabled('popular-categories') && (
    <section class={sectionStyles.popularCategoriesSectionClass} style={`order:${getSectionOrder('popular-categories')}`}>
      <div class={sectionStyles.popularCategoriesContainerClass}>
        <div class={sectionStyles.popularCategoriesHeaderWrapClass}>
          <h2 class={sectionStyles.sectionHeadingClass}>{sectionCopy.popularCategoriesTitle}</h2>
          <a href="/mekanlar" class={sectionStyles.sectionCtaLinkClass}>{sectionCopy.popularCategoriesCtaLabel}</a>
        </div>
        <div class={sectionStyles.popularCategoriesGridClass}>
          {quickCategories.map((cat) => (
            <a href={`/mekanlar/${cat.slug}`} class={sectionStyles.popularCategoriesCardClass}>
              {cat.name}
            </a>
          ))}
        </div>
      </div>
    </section>
    )}

    {isSectionEnabled('trend-density') && (
    <section class={sectionStyles.trendDensitySectionClass} style={`order:${getSectionOrder('trend-density')}`}>
      <div class={sectionStyles.trendDensityContainerClass}>
        <div class={sectionStyles.trendDensityGridClass}>
          <article class={sectionStyles.trendDensityCardClass}>
            <div class={sectionStyles.trendDensityHeaderWrapClass}>
              <h2 class="text-xl md:text-2xl font-bold">{sectionCopy.trendingTitle}</h2>
              <a href="/arama" class="text-sm font-semibold text-urfa-600 hover:text-urfa-700">{sectionCopy.trendingCtaLabel}</a>
            </div>
            <div class={sectionStyles.trendDensityTrendGridClass}>
              {trendingSearches.slice(0, 10).map((item, idx) => (
                <a
                  href={`/arama?q=${encodeURIComponent(item.query)}`}
                  class={sectionStyles.trendDensityTrendItemClass}
                >
                  <span class="mr-2 text-xs text-slate-500">#{idx + 1}</span>{item.query}
                </a>
              ))}
            </div>
          </article>

          <article class={sectionStyles.trendDensityCardClass}>
            <div class={sectionStyles.trendDensityHeaderWrapClass}>
              <h2 class="text-xl md:text-2xl font-bold">{sectionCopy.densityTitle}</h2>
              <a href="/kesfet" class="text-sm font-semibold text-urfa-600 hover:text-urfa-700">{sectionCopy.densityCtaLabel}</a>
            </div>
            {categoryDensityCards.length > 0 ? (
              <div class={sectionStyles.trendDensityDensityWrapClass}>
                {categoryDensityCards.slice(0, 8).map((item) => (
                  <a href={`/mekanlar/${item.slug}`} class={sectionStyles.trendDensityDensityItemClass}>
                    <div class="flex items-center justify-between text-sm">
                      <span class="font-semibold text-slate-900">{item.name}</span>
                      <span class="text-slate-500">{item.count}</span>
                    </div>
                    <div class="mt-2 h-2 w-full rounded-full bg-slate-200 overflow-hidden">
                      <div class="h-full rounded-full bg-gradient-to-r from-red-500 to-amber-500" style={`width:${item.ratio}%`}></div>
                    </div>
                  </a>
                ))}
              </div>
            ) : (
              <p class="text-sm text-slate-600">Yoğunluk verisi hazırlanıyor.</p>
            )}
          </article>
        </div>
      </div>
