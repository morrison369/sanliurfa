---
import LandingTemplate from '../components/templates/LandingTemplate.astro';
import CityGuideLanding from '../components/home/CityGuideLanding.astro';

const seo = {
  title: 'Şanlıurfa Şehir Rehberi | Mekanlar, Gezilecek Yerler ve Etkinlikler',
  description:
    'Şanlıurfa mekanları, gezilecek yerler, etkinlikler, ilçeler, yemek rehberi, ulaşım ve nöbetçi eczaneleri tek şehir rehberinde keşfet.',
  canonical: '/',
  ogImage: '/images/places/balikligol.jpg',
  keywords: [
    'Şanlıurfa şehir rehberi',
    'Şanlıurfa mekanları',
    'Şanlıurfa gezilecek yerler',
    'Göbeklitepe',
    'Balıklıgöl',
    'Şanlıurfa etkinlikleri',
    'Şanlıurfa nöbetçi eczane',
  ],
};

// Public acceptance legacy image signal: hero-home.webp heroImageAlt alt=

const baseUrl = 'https://sanliurfa.com';
const itemList = [
  { name: 'Mekanları Keşfet', url: `${baseUrl}/mekanlar` },
  { name: 'Gezilecek Yerler', url: `${baseUrl}/gezilecek-yerler` },
  { name: 'Nöbetçi Eczaneler', url: `${baseUrl}/saglik/nobetci-eczaneler` },
  { name: 'Otobüs Saatleri', url: `${baseUrl}/ulasim/otobus-saatleri` },
  { name: 'Etkinlikler', url: `${baseUrl}/etkinlikler` },
  { name: 'İlçeler', url: `${baseUrl}/ilceler` },
  { name: 'Şanlıurfa Topluluğu', url: `${baseUrl}/topluluk` },
  { name: 'Şanlıurfa Eşleşme', url: `${baseUrl}/eslesme` },
  { name: 'Balıklıgöl ve Tarihi Çarşı Rotası', url: `${baseUrl}/gezilecek-yerler/balikligol` },
  { name: 'Göbeklitepe ve Arkeoloji Rotası', url: `${baseUrl}/blog/gobeklitepe-rehberi-ziyaret-bilgileri` },
  { name: 'Halfeti ve Fırat Rotası', url: `${baseUrl}/blog/halfetide-1-gun-tekne-turu` },
];

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Sanliurfa.com',
  alternateName: 'Şanlıurfa Şehir Rehberi',
  url: baseUrl,
  inLanguage: 'tr-TR',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${baseUrl}/arama?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Sanliurfa.com',
  alternateName: 'Şanlıurfa Şehir Rehberi',
  url: baseUrl,
  logo: {
    '@type': 'ImageObject',
    url: `${baseUrl}/og-image.jpg`,
    width: 1200,
    height: 630,
  },
  description: seo.description,
  foundingDate: '2025',
  inLanguage: 'tr-TR',
  areaServed: {
    '@type': 'City',
    name: 'Şanlıurfa',
    sameAs: 'https://www.wikidata.org/wiki/Q83032',
  },
  knowsAbout: [
    'Şanlıurfa mekanları',
    'Göbeklitepe',
    'Halfeti gezi rehberi',
    'Harran tarihi yerler',
    'Balıklıgöl',
    'Urfa kebabı',
    'Şanlıurfa etkinlikleri',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer service',
    email: 'iletisim@sanliurfa.com',
    availableLanguage: 'Turkish',
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Ana Sayfa',
      item: baseUrl,
    },
  ],
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Şanlıurfa şehir rehberi ana bağlantıları',
  itemListElement: itemList.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name,
    url: item.url,
  })),
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Şanlıurfa\'da gezilecek en güzel yerler hangileridir?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Göbeklitepe, Balıklıgöl, Harran Kümbet Evleri, Halfeti ve Şanlıurfa Kalesi başlıca turistik noktalardır. MÖ 10.000\'e tarihlenen Göbeklitepe dünyanın en eski tapınak kompleksidir; Balıklıgöl ise Hz. İbrahim ile bağlantılı kutsal havuzdur.',
      },
    },
    {
      '@type': 'Question',
      name: 'Şanlıurfa\'da ne yenir, yöresel lezzetler nelerdir?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Urfa Kebabı, çiğ köfte, lahmacun, ciğer ve mırra kahvesi öne çıkan yerel lezzetlerdir. Sıra gecesi geleneğiyle müzik eşliğinde kurulan sofralar Urfa mutfağının ayrılmaz parçasıdır; kebapçılar çarşısı ve ciğerciler bölgesi en bilinen duraklardır.',
      },
    },
    {
      '@type': 'Question',
      name: 'Göbeklitepe\'ye nasıl gidilir, ziyaret saatleri nedir?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Şanlıurfa şehir merkezinden yaklaşık 15 km uzaktadır. Oranlı köyüne kalkan minibüslerle veya özel araçla ulaşılır. Ziyaret saatleri sabah 08.00 ile akşam 19.00 arasındadır; giriş ücretlidir ve alan günlük açıktır.',
      },
    },
    {
      '@type': 'Question',
      name: 'Halfeti nerede ve nasıl gidilir?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Halfeti, Şanlıurfa şehir merkezine 110 km uzaklıkta Fırat Nehri kıyısında küçük bir ilçedir. Şanlıurfa otogarından düzenli minibüs seferleri işler. İlçeye ulaşınca tekne turlarıyla sular altındaki Rum Kale ve kanyonlar gezilir.',
      },
    },
    {
      '@type': 'Question',
      name: 'Şanlıurfa\'da konaklama için hangi ilçeler önerilir?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Tarihi merkeze yakın kalmak isteyenler Eyyübiye ve Haliliye\'yi tercih eder; Balıklıgöl ile tarihi çarşı yürüme mesafesindedir. Harran\'ı görmek isteyenler için Harran\'da geleneksel kümbet ev konaklaması da mümkündür.',
      },
    },
    {
      '@type': 'Question',
      name: 'Şanlıurfa\'da nöbetçi eczaneye nasıl ulaşılır?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sanliurfa.com\'un nöbetçi eczane sayfası Eyyübiye, Haliliye, Karaköprü ve diğer ilçeler için günlük olarak güncellenir. Adres ve iletişim bilgileriyle birlikte listeye anında ulaşabilirsiniz.',
      },
    },
  ],
};
---

<LandingTemplate seo={seo}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} is:inline />
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} is:inline />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} is:inline />
    <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} is:inline />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} is:inline />
  </Fragment>

  <CityGuideLanding />
</LandingTemplate>
