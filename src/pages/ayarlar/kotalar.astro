---
import Layout from '../../layouts/Layout.astro';
import QuotaUsageDisplay from '../../components/QuotaUsageDisplay';

const user = Astro.locals.user;
if (!user) {
 return Astro.redirect('/giris?redirect=/ayarlar/kotalar');
}
---

<Layout seo={{ title: "Kullanım Kotaları - Şanlıurfa", noIndex: true }}>
 <style is:inline>
 .kk-page{background:var(--bg);min-height:100vh}
 .kk-hero{position:relative;overflow:hidden;border-bottom:1px solid rgba(184,115,51,.12);background:radial-gradient(circle at 18% 0%,rgba(212,151,24,.10) 0%,transparent 42%),radial-gradient(circle at 82% 100%,rgba(44,122,82,.08) 0%,transparent 40%),linear-gradient(180deg,#fbf6ec 0%,#f4ecd8 58%,#fbf6ec 100%);padding:2.5rem 0}
 .kk-inner{max-width:56rem;margin:0 auto}
 .kk-label{font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:#4A3828}
 .kk-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.5rem,3.5vw,2rem);font-weight:700;color:#1F1410;margin:.5rem 0 .25rem}
 .kk-hero-desc{color:#7A6B58;font-size:.88rem}
 .kk-body{padding:2rem 0 4rem}
 .kk-info-grid{display:grid;gap:1.25rem;margin-top:3rem}
 @media(min-width:48rem){.kk-info-grid{grid-template-columns:repeat(2,1fr)}}
 .kk-info-card{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);padding:1.5rem}
 .kk-info-title{font-size:.9rem;font-weight:700;color:#1F1410;margin-bottom:.75rem}
 .kk-info-list{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:.5rem}
 .kk-info-list li{font-size:.82rem;color:#7A6B58}
 .kk-info-btn{display:inline-block;margin-top:1rem;padding:.5rem 1.1rem;background:#B87333;color:#EDE0C6;font-size:.82rem;font-weight:600;transition:background .15s}
 .kk-info-btn:hover{background:#9D5F1A}
 .kk-faq-section{margin-top:3rem}
 .kk-faq-title{font-family:'Cormorant Garamond',serif;font-size:1.35rem;font-weight:700;color:#1F1410;margin-bottom:1.25rem}
 .kk-faq-item{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);padding:1.25rem;margin-bottom:.75rem}
 .kk-faq-q{font-weight:600;color:#1F1410;margin-bottom:.4rem;font-size:.9rem}
 .kk-faq-a{color:#7A6B58;font-size:.85rem;line-height:1.65}
 </style>

 <div class="kk-page">
 <div class="kk-hero">
 <div class="sf-container">
 <div class="kk-inner">
 <p class="kk-label">Hesabım</p>
 <h1 class="kk-h1">Kullanım Kotaları</h1>
 <p class="kk-hero-desc">Faz 1 açık erişim döneminde özellik kullanımlarını bilgilendirme amaçlı görüntüleyin</p>
 </div>
 </div>
 </div>

 <div class="kk-body">
 <div class="sf-container">
 <div class="kk-inner">
 <QuotaUsageDisplay client:visible={{ rootMargin: '120px' }} />

 <div class="kk-info-grid">
 <div class="kk-info-card">
 <h3 class="kk-info-title">Kotalar Nasıl Çalışır?</h3>
 <ul class="kk-info-list">
 <li>✓ Faz 1 döneminde tüm çekirdek özellikler ücretsizdir</li>
 <li>✓ Sistem kotaları sadece teknik gözlem amaçlı tutulur</li>
 <li>✓ Kullanıcı tarafında erişim engeli uygulanmaz</li>
 <li>✓ Ücretlendirme sonraki fazlarda ayrıca duyurulacaktır</li>
 </ul>
 </div>
 <div class="kk-info-card">
 <h3 class="kk-info-title">Faz 1 Erişim</h3>
 <p style="font-size:.82rem;color:#7A6B58;margin-bottom:.75rem">Şu anda yükseltme gerekmeksizin tam erişim açıktır:</p>
 <a href="/fiyatlandirma" class="kk-info-btn">Erişim Detayını Gör →</a>
 </div>
 </div>

 <div class="kk-faq-section">
 <h2 class="kk-faq-title">Sık Sorulan Sorular</h2>
 <div class="kk-faq-item">
 <p class="kk-faq-q">Kotam tükendiyse ne olur?</p>
 <p class="kk-faq-a">Faz 1 döneminde kullanıcı erişimi engellenmez. Uyarılar sadece bilgi amaçlıdır.</p>
 </div>
 <div class="kk-faq-item">
 <p class="kk-faq-q">Kotalar ne zaman sıfırlanır?</p>
 <p class="kk-faq-a">Kotalar aylık olarak otomatik olarak sıfırlanır. Tam tarih yukarıdaki listede gösterilmektedir.</p>
 </div>
 <div class="kk-faq-item">
 <p class="kk-faq-q">Sınırsız özellikler nelerdir?</p>
 <p class="kk-faq-a">Faz 1 kapsamında özellikler zaten sınırsızdır. Sonraki faz model güncellemeleri ayrıca duyurulur.</p>
 </div>
 </div>
 </div>
 </div>
 </div>
 </div>
</Layout>
