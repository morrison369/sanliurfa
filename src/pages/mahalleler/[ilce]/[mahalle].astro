---

import Layout from '../../../layouts/Layout.astro';
import { query, queryOne } from '../../../lib/postgres';
import { getCachedPublicRouteData } from '../../../lib/public-route-cache';
import { getPublicAppUrl } from '../../../lib/public-app-url';
import NearbyPharmacies from '../../../components/health/NearbyPharmacies.astro';
import { logger } from '../../../lib/logging';
const baseUrl = getPublicAppUrl();

const { ilce, mahalle } = Astro.params;
let district: any = null;
let neighborhood: any = null;
let places: any[] = [];

try {
 const data = await getCachedPublicRouteData(`page:mahalleler:detail:${ilce || 'unknown'}:${mahalle || 'unknown'}`, async () => {
  const districtRow = await queryOne("SELECT * FROM districts WHERE slug = $1", [ilce]);
  if (!districtRow) return { district: null, neighborhood: null, places: [] };

  const neighborhoodRow = await queryOne(
   "SELECT * FROM neighborhoods WHERE slug = $1 AND district_id = $2",
   [mahalle, districtRow.id]
  );
  if (!neighborhoodRow) return { district: districtRow, neighborhood: null, places: [] };

  const placesResult = await query(
   `SELECT p.*, c.name as category_name FROM places p
 LEFT JOIN categories c ON p.category_id = c.id
 WHERE p.neighborhood_id = $1 AND p.status = 'active'
 ORDER BY p.rating DESC LIMIT 20`,
   [neighborhoodRow.id]
  );

  return { district: districtRow, neighborhood: neighborhoodRow, places: placesResult.rows };
 });
 district = data.district;
 if (!district) return Astro.redirect('/ilceler');

 neighborhood = data.neighborhood;
 if (!neighborhood) return Astro.redirect(`/ilceler/${ilce}`);
 places = data.places;
 // Nearby pharmacies query moved to <NearbyPharmacies server:defer> below.
} catch (e) {
 logger.error('Error loading neighborhood:', e instanceof Error ? e : new Error(String(e)));
}

const seo = {
 title: `${neighborhood?.name || mahalle} Mahallesi - ${district?.name || ilce} | Şanlıurfa`,
 description: `${district?.name} ${neighborhood?.name} mahallesindeki mekanlar, eczaneler ve yaşam rehberi.`,
 keywords: [(neighborhood?.name || mahalle) + ' mahallesi', (district?.name || ilce) + ' mahalle', 'şanlıurfa mahalle rehberi'],
 ogImage: '/images/places/balikligol.jpg',
 canonical: `/mahalleler/${ilce}/${mahalle}`,
};
const faqItems = [
 { S: `${neighborhood?.name || mahalle} mahallesi hangi ilçeye bağlı?`, C: `${neighborhood?.name || mahalle} mahallesi, ${district?.name || ilce} ilçesine bağlıdır.` },
 { S: `${neighborhood?.name || mahalle} mahallesinde hangi mekanlar var?`, C: `${neighborhood?.name || mahalle} mahallesindeki aktif mekanlar sayfamızda listelenmektedir.` },
 { S: `${district?.name || ilce} ilçesindeki diğer mahalleleri nasıl görüntüleyebilirim?`, C: `${district?.name || ilce} ilçesindeki tüm mahallelere /ilceler/${ilce} sayfasından ulaşabilirsiniz.` },
];

---

<Layout seo={seo}>
 <style>
 .mh-page{background:var(--public-bg);min-height:100vh}
 .mh-breadcrumb{background:var(--public-surface);border-bottom:1px solid var(--public-border);padding:.75rem 0}
 .mh-nav{display:flex;align-items:center;gap:.5rem;font-size:.875rem;color:var(--public-muted)}
 .mh-nav a{color:var(--public-muted);text-decoration:none;transition:color .15s}
 .mh-nav a:hover{color:var(--public-accent)}
 .mh-nav-current{color:var(--public-text);font-weight:500}
 .mh-hero{background:var(--public-bg);border-bottom:1px solid var(--public-border);padding:2.5rem 0}
 .mh-label{font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--public-text-soft);margin-bottom:.5rem}
 .mh-h1{font-size:1.75rem;font-weight:700;color:var(--public-text)}
 .mh-hero-sub{color:var(--public-muted)}
 .mh-body{padding:2rem 0 4rem}
 .mh-grid{display:grid;gap:2rem}
 @media(min-width:64rem){.mh-grid{grid-template-columns:2fr 1fr}}
 .mh-section-title{font-size:1.125rem;font-weight:700;color:var(--public-text);margin-bottom:1rem}
 .mh-places{display:flex;flex-direction:column;gap:.75rem}
 .mh-place{display:flex;align-items:center;gap:1rem;background:var(--public-surface);border:1px solid var(--public-border);padding:1rem;text-decoration:none;transition:border-color .15s}
 .mh-place:hover{border-color:var(--public-accent)}
 .mh-place-icon{width:3rem;height:3rem;background:var(--public-accent-soft);display:flex;align-items:center;justify-content:center;font-size:1.25rem;flex-shrink:0}
 .mh-place-main{flex:1}
 .mh-place-name{font-weight:700;color:var(--public-text)}
 .mh-place-cat{font-size:.75rem;color:var(--public-accent)}
 .mh-place-rating{color:var(--public-accent);font-weight:700}
 .mh-empty{color:var(--public-muted);background:var(--public-surface);border:1px solid var(--public-border);padding:2rem;text-align:center}
 @keyframes mh-pulse{0%,100%{opacity:1}50%{opacity:.5}}
 .mh-fallback-skeleton{background:var(--public-surface);border:1px solid var(--public-border);padding:1.25rem;margin-bottom:1.5rem;animation:mh-pulse 2s ease-in-out infinite}
 .mh-skel-head{height:1.25rem;background:var(--public-accent-soft);width:10rem;margin-bottom:1rem}
 .mh-skel-items{display:flex;flex-direction:column;gap:.75rem}
 .mh-skel-item{height:3rem;background:var(--public-accent-soft)}
 .mh-ql-card{background:var(--public-surface);border:1px solid var(--public-border);padding:1.25rem}
 .mh-ql-title{font-weight:700;color:var(--public-text);margin-bottom:.75rem}
 .mh-ql-links{display:flex;flex-direction:column;gap:.5rem;font-size:.875rem}
 .mh-ql-links a{color:var(--public-accent);text-decoration:none;transition:color .15s}
 .mh-ql-links a:hover{color:var(--public-accent-strong)}
 </style>

 <div class="mh-page">
 <div class="mh-breadcrumb">
 <div class="sf-container">
 <nav class="mh-nav">
 <a href="/">Ana Sayfa</a><span>/</span>
 <a href="/ilceler">İlçeler</a><span>/</span>
 <a href={`/ilceler/${ilce}`}>{district?.name}</a><span>/</span>
 <span class="mh-nav-current">{neighborhood?.name} Mah.</span>
 </nav>
 </div>
 </div>

 <div class="mh-hero">
 <div class="sf-container">
 <p class="mh-label">Şanlıurfa Semt Rehberi</p>
 <h1 class="mh-h1">{neighborhood?.name} Mahallesi</h1>
 <p class="mh-hero-sub">{district?.name}, Şanlıurfa</p>
 </div>
 </div>

 <div class="mh-body">
 <div class="sf-container">
 <div class="mh-grid">
 <div>
 <h2 class="mh-section-title">Mekanlar</h2>
 {places.length > 0 ? (
 <div class="mh-places">
 {places.map((p) => (
 <a href={`/isletme/${p.slug}`} class="mh-place">
 <div class="mh-place-icon">📍</div>
 <div class="mh-place-main">
 <h3 class="mh-place-name">{p.name}</h3>
 <span class="mh-place-cat">{p.category_name}</span>
 </div>
 {p.rating && <div class="mh-place-rating">★ {p.rating}</div>}
 </a>
 ))}
 </div>
 ) : (
 <p class="mh-empty">Henüz kayıtlı mekan yok.</p>
 )}
 </div>

 <aside>
 <NearbyPharmacies neighborhoodId={neighborhood.id} server:defer>
 <div slot="fallback" class="mh-fallback-skeleton">
 <div class="mh-skel-head"></div>
 <div class="mh-skel-items">
 <div class="mh-skel-item"></div>
 <div class="mh-skel-item"></div>
 <div class="mh-skel-item"></div>
 </div>
 </div>
 </NearbyPharmacies>

 <div class="mh-ql-card">
 <h3 class="mh-ql-title">Hızlı Linkler</h3>
 <div class="mh-ql-links">
 <a href={`/ilceler/${ilce}`}>{district?.name} Rehberi</a>
 <a href="/saglik/nobetci-eczaneler">Nöbetçi Eczaneler</a>
 <a href="/mekanlar">Tüm Mekanlar</a>
 </div>
 </div>
 </aside>
 </div>
 </div>
 </div>
 </div>

 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'Neighborhood',
 name: neighborhood.name,
 description: neighborhood.description || `${neighborhood.name} mahallesi, ${district?.name || ''} ilçesi, Şanlıurfa`,
 url: `${baseUrl}/mahalleler/${Astro.params.ilce}/${Astro.params.mahalle}`,
 containedInPlace: {
 '@type': 'AdministrativeArea',
 name: district?.name || 'Şanlıurfa',
 url: district?.slug ? `${baseUrl}/ilceler/${district.slug}` : `${baseUrl}/ilceler`,
 },
 address: {
 '@type': 'PostalAddress',
 addressLocality: district?.name || 'Şanlıurfa',
 addressRegion: 'Şanlıurfa',
 addressCountry: 'TR',
 },
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'Mahalleler', item: `${baseUrl}/mahalleler` },
 { '@type': 'ListItem', position: 3, name: district?.name || ilce, item: `${baseUrl}/mahalleler/${ilce}` },
 { '@type': 'ListItem', position: 4, name: neighborhood?.name || mahalle, item: `${baseUrl}/mahalleler/${ilce}/${mahalle}` },
 ],
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqItems.map((item) => ({
 '@type': 'Question',
 name: item.S,
 acceptedAnswer: { '@type': 'Answer', text: item.C },
 })),
 })} is:inline />
</Layout>
