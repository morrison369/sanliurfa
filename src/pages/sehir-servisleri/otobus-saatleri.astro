---
import Layout from '../../layouts/Layout.astro';
import CityServiceDetail from '../../components/CityServiceDetail.astro';
import { cityServiceDetailSchema } from '../../lib/city-service-schema';
import { getCityServiceSetting } from '../../lib/site-settings';

const service = await getCityServiceSetting('otobus-saatleri');
const title = service?.detailTitle || 'Şanlıurfa Otobüs Saatleri';
const description = service?.detailDescription || 'Şanlıurfa toplu ulaşım hatları ve otobüs saatleri rehberi.';

const seo = {
  title,
  description,
  canonicalUrl: 'https://sanliurfa.com/sehir-servisleri/otobus-saatleri',
  schema: cityServiceDetailSchema({
    service,
    slug: 'otobus-saatleri',
    title,
    description,
    canonicalPath: '/sehir-servisleri/otobus-saatleri',
  }),
};
---

<Layout seo={seo}>
  <CityServiceDetail
    title={title}
    description={description}
    sourceLabel={service?.sourceLabel || 'Şehir içi ulaşım veri kaynakları'}
    sourceUrl={service?.sourceUrl || ''}
    statusText={service?.statusText || 'Hat verisi bağlantısı bekleniyor'}
    lastUpdatedAt={service?.lastUpdatedAt || ''}
    type="bus"
  />
</Layout>
