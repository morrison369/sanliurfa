---
import Layout from '../../layouts/Layout.astro';
import CityServiceDetail from '../../components/CityServiceDetail.astro';
import { cityServiceDetailSchema } from '../../lib/city-service-schema';
import { getCityServiceSetting } from '../../lib/site-settings';

const service = await getCityServiceSetting('nobetci-eczaneler');
const title = service?.detailTitle || 'Şanlıurfa Nöbetçi Eczaneler';
const description =
  service?.detailDescription ||
  'Şanlıurfa ilçeleri için nöbetçi eczane bilgileri ve hızlı erişim rehberi.';

const seo = {
  title,
  description,
  canonicalUrl: 'https://sanliurfa.com/sehir-servisleri/nobetci-eczaneler',
  schema: cityServiceDetailSchema({
    service,
    slug: 'nobetci-eczaneler',
    title,
    description,
    canonicalPath: '/sehir-servisleri/nobetci-eczaneler',
  }),
};
---

<Layout seo={seo}>
  <CityServiceDetail
    title={title}
    description={description}
    sourceLabel={service?.sourceLabel || 'Resmi nöbetçi eczane kaynakları'}
    statusText={service?.statusText || 'Canlı veri entegrasyonu için hazır'}
    type="pharmacy"
  />
</Layout>
