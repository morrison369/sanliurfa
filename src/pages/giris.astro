---
import Layout from '../layouts/Layout.astro';
import { actions, isInputError } from 'astro:actions';
import { safeRedirectTarget } from '../lib/auth/safe-redirect';

const seo = {
  title: 'Giriş Yap - Sanliurfa.com',
  description: 'Sanliurfa.com hesabınıza giriş yapın. Mekan değerlendirmeleri, koleksiyonlar ve kişiselleştirilmiş içerikler için üye olun.',
  noIndex: true,
};

// Check if already logged in
const user = Astro.locals.user;
if (user) {
  return Astro.redirect('/');
}

const redirectTarget = safeRedirectTarget(Astro.url.searchParams.get('redirect'));
const loginResult = Astro.getActionResult(actions.login);
const loginInputErrors = isInputError(loginResult?.error) ? loginResult.error.fields : {};
const loginSubmitError =
  !isInputError(loginResult?.error) && loginResult?.error?.message
    ? loginResult.error.message
    : null;
const verifyResult = Astro.getActionResult(actions.verifyLoginTwoFactor);
const verifyInputErrors = isInputError(verifyResult?.error) ? verifyResult.error.fields : {};
const verifySubmitError =
  !isInputError(verifyResult?.error) && verifyResult?.error?.message
    ? verifyResult.error.message
    : null;
const twoFactorState = loginResult?.data?.requiresTwoFactor
  ? { active: true, tempToken: loginResult.data.tempToken || '' }
  : null;

if (loginResult?.data?.success && !loginResult.data.requiresTwoFactor) {
  return Astro.redirect(redirectTarget);
}

if (verifyResult?.data?.success) {
  return Astro.redirect(redirectTarget);
}
---
<Layout seo={seo} hideFooter>
  <div class="min-h-screen flex items-center justify-center bg-[#0D0A08] p-4">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <a href="/" style="display:inline-flex;align-items:baseline;gap:0.0625rem;text-decoration:none;">
          <span style="font-family:'Cormorant Garamond',Georgia,serif;font-size:2rem;font-weight:300;font-style:italic;color:#F5EDD6;letter-spacing:-0.02em;">Sanliurfa</span>
          <span style="font-family:'Jost',sans-serif;font-size:1rem;font-weight:700;color:#CE8E38;letter-spacing:0.06em;">.com</span>
        </a>
        <p class="text-[#9A8470] mt-2 text-sm tracking-wide">Hesabınıza giriş yapın</p>
      </div>

      <div class="bg-[#FDFAF3] border border-[rgba(200,160,100,0.22)] rounded-sm shadow-2xl shadow-black/40 p-8">
        {twoFactorState ? (
          <form action={actions.verifyLoginTwoFactor} method="POST" class="space-y-6">
            <input type="hidden" name="tempToken" value={twoFactorState.tempToken} />
            <input type="hidden" name="redirect" value={redirectTarget} />

            <div>
              <h2 class="text-2xl font-bold text-[#1A1008]">İki Adımlı Doğrulama</h2>
              <p class="mt-2 text-sm text-[#9A8470]">
                Kimlik doğrulayıcı uygulamanızdaki 6 haneli kodu girin.
              </p>
            </div>

            {verifySubmitError && (
              <div class="mb-4 rounded-sm border border-isot-200 bg-isot-50 p-3 text-sm text-isot-700">
                {verifySubmitError}
              </div>
            )}

            <div>
              <label class="block text-sm font-medium text-[#4A3828] mb-1">Doğrulama Kodu</label>
              <input
                type="text"
                name="code"
                inputmode="numeric"
                pattern="[0-9]{6}"
                maxlength="6"
                required
                aria-invalid={verifyInputErrors.code ? 'true' : 'false'}
                class="w-full px-4 py-3 text-center tracking-[0.4em] border border-[rgba(200,160,100,0.3)] rounded-sm bg-white focus:ring-2 focus:ring-urfa-400 focus:border-transparent"
                placeholder="000000"
              />
              {verifyInputErrors.code && (
                <p class="mt-2 text-sm text-isot-600">{verifyInputErrors.code.join(', ')}</p>
              )}
            </div>

            <button
              type="submit"
              class="w-full py-3 bg-urfa-600 text-white rounded-sm font-medium tracking-wide hover:bg-urfa-700 transition-colors"
            >
              Kodu Doğrula
            </button>
          </form>
        ) : (
          <form action={actions.login} method="POST" class="space-y-6">
            <input type="hidden" name="redirect" value={redirectTarget} />
            {loginSubmitError && (
              <div class="mb-4 rounded-sm border border-isot-200 bg-isot-50 p-3 text-sm text-isot-700">
                {loginSubmitError}
              </div>
            )}

            <div>
              <label class="block text-sm font-medium text-[#4A3828] mb-1">E-posta</label>
              <input
                type="email"
                name="email"
                required
                transition:persist
                aria-invalid={loginInputErrors.email ? 'true' : 'false'}
                class="w-full px-4 py-3 border border-[rgba(200,160,100,0.3)] rounded-sm bg-white focus:ring-2 focus:ring-urfa-400 focus:border-transparent"
                placeholder="ornek@email.com"
              />
              {loginInputErrors.email && (
                <p class="mt-2 text-sm text-isot-600">{loginInputErrors.email.join(', ')}</p>
              )}
            </div>

            <div>
              <label class="block text-sm font-medium text-[#4A3828] mb-1">Şifre</label>
              <input
                type="password"
                name="password"
                autocomplete="current-password"
                required
                aria-invalid={loginInputErrors.password ? 'true' : 'false'}
                class="w-full px-4 py-3 border border-[rgba(200,160,100,0.3)] rounded-sm bg-white focus:ring-2 focus:ring-urfa-400 focus:border-transparent"
                placeholder="••••••••"
              />
              {loginInputErrors.password && (
                <p class="mt-2 text-sm text-isot-600">{loginInputErrors.password.join(', ')}</p>
              )}
            </div>

            <div class="flex items-center justify-between">
              <label class="flex items-center">
                <input type="checkbox" name="remember" class="w-4 h-4 text-urfa-600 rounded border-[rgba(200,160,100,0.3)]" />
                <span class="ml-2 text-sm text-[#6B5540]">Beni hatırla</span>
              </label>
              <a href="/sifremi-unuttum" class="text-sm text-urfa-600 hover:underline">Şifremi unuttum</a>
            </div>

            <button
              type="submit"
              class="w-full py-3 bg-urfa-600 text-white rounded-sm font-medium tracking-wide hover:bg-urfa-700 transition-colors"
            >
              Giriş Yap
            </button>
          </form>
        )}

        <div class="mt-6 text-center">
          <p class="text-[#9A8470] text-sm">
            Hesabınız yok mu?
            <a href="/kayit" class="text-urfa-600 font-medium hover:underline">Kayıt Ol</a>
          </p>
        </div>

        <div class="mt-6 pt-6 border-t border-[rgba(200,160,100,0.18)]">
          <p class="text-center text-sm text-[#9A8470] mb-4">Veya ile giriş yap</p>
          <div class="space-y-3">
            <a
              href={`/api/auth/oauth/authorize?provider=google&redirect=${encodeURIComponent(redirectTarget)}`}
              class="w-full py-3 border border-[rgba(200,160,100,0.25)] rounded-sm bg-white flex items-center justify-center gap-2 hover:border-urfa-300 hover:bg-urfa-50 transition-colors text-[#4A3828] text-sm font-medium"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
              Google ile Devam Et
            </a>
          </div>
        </div>
      </div>

      <p class="text-center text-sm text-[#6B5540] mt-8">
        <a href="/" class="hover:text-[#C4B49A]">← Ana Sayfaya Dön</a>
      </p>
    </div>
  </div>
</Layout>



