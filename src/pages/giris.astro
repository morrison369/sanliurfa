---
import Layout from '../layouts/Layout.astro';
import { actions, isInputError } from 'astro:actions';
import { safeRedirectTarget } from '../lib/auth/safe-redirect';

const seo = {
 title: 'Giriş Yap — Sanliurfa.com',
 description: 'Sanliurfa.com hesabınıza giriş yapın.',
 noIndex: true,
};

const user = Astro.locals.user;
if (user) return Astro.redirect('/');

const redirectTarget = safeRedirectTarget(Astro.url.searchParams.get('redirect'));
const loginResult = Astro.getActionResult(actions.login);
const loginInputErrors = isInputError(loginResult?.error) ? loginResult.error.fields : {};
const loginSubmitError =
 !isInputError(loginResult?.error) && loginResult?.error?.message
 ? loginResult.error.message
 : null;
const verifyResult = Astro.getActionResult(actions.verifyLoginTwoFactor);
const verifyInputErrors = isInputError(verifyResult?.error) ? verifyResult.error.fields : {};
const verifySubmitError =
 !isInputError(verifyResult?.error) && verifyResult?.error?.message
 ? verifyResult.error.message
 : null;
const twoFactorState = loginResult?.data?.requiresTwoFactor
 ? { active: true, tempToken: loginResult.data.tempToken || '' }
 : null;

if (loginResult?.data?.success && !loginResult.data.requiresTwoFactor) {
 return Astro.redirect(
  redirectTarget.includes('?')
   ? `${redirectTarget}&auth_success=login`
   : `${redirectTarget}?auth_success=login`
 );
}
if (verifyResult?.data?.success) {
 return Astro.redirect(redirectTarget);
}
---
<Layout seo={seo} hideFooter>
 <style is:inline>
 .auth-wrap{min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--bg);padding:1.5rem}
 .auth-box{width:100%;max-width:420px}
 .auth-logo{text-align:center;margin-bottom:2rem}
 .auth-logo-name{font-family:'Cormorant Garamond',Georgia,serif;font-size:2rem;font-weight:300;font-style:italic;color:var(--public-text);letter-spacing:-.02em}
 .auth-logo-tld{font-family:'Jost',sans-serif;font-size:1rem;font-weight:700;color:var(--public-accent);letter-spacing:.06em}
 .auth-logo-sub{font-size:.8rem;color:var(--public-muted);margin-top:.4rem;letter-spacing:.04em}
 .auth-card{background:var(--bg-card);border:1px solid var(--border);padding:2rem}
 .auth-lbl{display:block;font-size:.75rem;font-weight:600;color:var(--public-accent);margin-bottom:.4rem;letter-spacing:.03em}
 .auth-input{width:100%;padding:.7rem 1rem;background:rgba(255,255,255,.03);border:1px solid rgba(184,115,51,.2);color:var(--public-text);border-radius:.125rem;font-size:.875rem;font-family:inherit;transition:border-color .15s}
 .auth-input:focus{outline:none;border-color:var(--public-accent)}
 .auth-input::placeholder{color:var(--public-text-soft)}
 .auth-field{margin-bottom:1rem}
 .auth-err{background:rgba(199,58,71,.1);border:1px solid rgba(199,58,71,.25);color:#E08090;padding:.65rem 1rem;border-radius:.125rem;font-size:.82rem;margin-bottom:1rem}
 .auth-field-err{font-size:.72rem;color:#E08090;margin-top:.3rem}
 .auth-submit{width:100%;padding:.75rem;margin-top:.5rem;font-size:.875rem}
 .auth-divider{border:none;border-top:1px solid rgba(184,115,51,.1);margin:1.5rem 0}
 .auth-divider-lbl{text-align:center;font-size:.75rem;color:var(--public-text-soft);position:relative;margin:1.25rem 0}
 .auth-divider-lbl::before,.auth-divider-lbl::after{content:'';position:absolute;top:50%;width:40%;height:1px;background:rgba(184,115,51,.1)}
 .auth-divider-lbl::before{left:0}.auth-divider-lbl::after{right:0}
 .auth-oauth{width:100%;padding:.65rem 1rem;background:rgba(255,255,255,.02);border:1px solid rgba(184,115,51,.2);color:var(--public-accent);border-radius:.125rem;font-size:.82rem;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:.6rem;cursor:pointer;transition:border-color .15s,background .15s,color .15s;text-decoration:none}
 .auth-oauth:hover{border-color:var(--public-accent);background:rgba(184,115,51,.06);color:var(--public-text)}
 .auth-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem}
 .auth-check{display:flex;align-items:center;gap:.5rem;font-size:.78rem;color:var(--public-muted);cursor:pointer}
 .auth-check input{accent-color:var(--public-accent)}
 .auth-forgot{font-size:.78rem;color:var(--public-accent)}
 .auth-forgot:hover{color:var(--public-text)}
 .auth-footer{text-align:center;font-size:.8rem;color:var(--public-muted);margin-top:1.25rem}
 .auth-footer a{color:var(--public-accent);text-decoration:underline;text-underline-offset:2px}.auth-footer a:hover{color:var(--public-text)}
 .auth-signup-cta{margin-top:1rem;text-align:center;font-size:.82rem;color:var(--public-muted)}
 .auth-signup-link{display:inline-flex;align-items:center;justify-content:center;min-height:2.75rem;padding:.7rem 1rem;border:1px solid rgba(184,115,51,.2);color:var(--public-accent);text-decoration:none;border-radius:.125rem;background:rgba(255,255,255,.02);transition:border-color .15s,background .15s,color .15s;cursor:pointer;font:inherit}
 .auth-signup-link:hover{border-color:var(--public-accent);background:rgba(184,115,51,.06);color:var(--public-text)}
 .auth-back{text-align:center;font-size:.78rem;color:var(--public-text-soft);margin-top:1.25rem}
 .auth-back a{color:var(--public-muted);transition:color .15s}.auth-back a:hover{color:var(--public-accent)}
 </style>

 <div class="auth-wrap">
 <div class="auth-box">
 <!-- Logo -->
 <div class="auth-logo">
 <a href="/" style="display:inline-flex;align-items:baseline;gap:.0625rem;text-decoration:none;">
 <span class="auth-logo-name">Sanliurfa</span>
 <span class="auth-logo-tld">.com</span>
 </a>
 <h1 class="auth-logo-sub">{twoFactorState ? 'İki adımlı doğrulama' : 'Hesabınıza giriş yapın'}</h1>
 </div>

 <div class="auth-card">
 {twoFactorState ? (
 <!-- 2FA form -->
 <form action={actions.verifyLoginTwoFactor} method="POST">
 <input type="hidden" name="tempToken" value={twoFactorState.tempToken} />
 <input type="hidden" name="redirect" value={redirectTarget} />

 {verifySubmitError && <div class="auth-err">{verifySubmitError}</div>}

 <div class="auth-field">
 <label class="auth-lbl">Doğrulama Kodu</label>
 <input
 type="text"
 name="code"
 inputmode="numeric"
 pattern="[0-9]{6}"
 maxlength="6"
 required
 autocomplete="one-time-code"
 aria-invalid={verifyInputErrors.code ? 'true' : 'false'}
 class="auth-input"
 placeholder="000 000"
 style="text-align:center;letter-spacing:.4em;font-size:1.1rem"
 />
 {verifyInputErrors.code && <p class="auth-field-err">{verifyInputErrors.code.join(', ')}</p>}
 </div>
 <p style="font-size:.78rem;color:var(--public-muted);margin-bottom:1.25rem;line-height:1.6">
 Kimlik doğrulayıcı uygulamanızdaki 6 haneli kodu girin.
 </p>
 <button type="submit" class="sf-btn-primary auth-submit">Kodu Doğrula</button>
 </form>
 ) : (
 <!-- Login form -->
 <form action={actions.login} method="POST">
 <input type="hidden" name="redirect" value={redirectTarget} />

 {loginSubmitError && <div class="auth-err">{loginSubmitError}</div>}

 <div class="auth-field">
 <label class="auth-lbl" for="email-input">E-posta</label>
 <input
 id="email-input"
 type="email"
 name="email"
 required
 transition:persist
 autocomplete="email"
 aria-invalid={loginInputErrors.email ? 'true' : 'false'}
 class="auth-input"
 placeholder="ornek@email.com"
 />
 {loginInputErrors.email && <p class="auth-field-err">{loginInputErrors.email.join(', ')}</p>}
 </div>

 <div class="auth-field">
 <label class="auth-lbl" for="pw-input">Şifre</label>
 <input
 id="pw-input"
 type="password"
 name="password"
 autocomplete="current-password"
 required
 aria-invalid={loginInputErrors.password ? 'true' : 'false'}
 class="auth-input"
 placeholder="••••••••"
 />
 {loginInputErrors.password && <p class="auth-field-err">{loginInputErrors.password.join(', ')}</p>}
 </div>

 <div class="auth-row">
 <label class="auth-check">
 <input type="checkbox" name="remember" />
 Beni hatırla
 </label>
 <a href="/sifremi-unuttum" class="auth-forgot">Şifremi unuttum</a>
 </div>

 <button type="submit" class="sf-btn-primary auth-submit">Giriş Yap</button>

 <p class="auth-divider-lbl">veya</p>

 <a
 href={`/api/auth/oauth/authorize?provider=google&redirect=${encodeURIComponent(redirectTarget)}`}
 class="auth-oauth"
 >
 <!-- Google brand mark — intentional inline SVG (whitelist exception per HARD RULE #21) -->
 <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
 <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
 <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
 <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
 <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
 </svg>
 Google ile Devam Et
 </a>

 <p class="auth-signup-cta">
 Hesabınız yok mu?
 <a href="/kayit" class="auth-signup-link" data-testid="login-register-link">Kayıt Ol</a>
 </p>
 </form>
 )}
 </div>

 <p class="auth-footer">
 Hesabınız yok mu? <a href="/kayit">Kayıt Ol</a>
 </p>
 <p class="auth-back"><a href="/">← Ana Sayfaya Dön</a></p>
 </div>
 </div>
</Layout>
