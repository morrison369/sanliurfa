---
import Layout from "../layouts/Layout.astro";
import { Eye, EyeOff, Mail, Lock } from "lucide-react";

const seo = {
  title: "Giriş Yap",
  description:
    "sanliurfa.com hesabınıza giriş yapın. Mekan yorumlayın, puan verin ve favorilerinizi kaydedin.",
  noindex: true,
};

const error = Astro.url.searchParams.get("error");
---

<Layout seo={seo}>
  <div
    class="min-h-screen bg-gray-50 dark:bg-gray-900 flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8"
  >
    <div class="max-w-md w-full space-y-8">
      <!-- Header -->
      <div class="text-center">
        <div
          class="mx-auto h-16 w-16 bg-urfa-600 rounded-2xl flex items-center justify-center"
        >
          <span class="text-white font-bold text-2xl">Ş</span>
        </div>
        <h2
          class="mt-6 text-3xl font-display font-bold text-gray-900 dark:text-white"
        >
          Hesabınıza Giriş Yapın
        </h2>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
          veya{" "}
          <a
            href="/kayit"
            class="font-medium text-urfa-600 dark:text-urfa-400 hover:text-urfa-500"
          >
            yeni hesap oluşturun
          </a>
        </p>
      </div>

      <!-- Error Message -->
      {
        error && (
          <div class="bg-red-50 border border-red-200 rounded-lg p-4">
            <p class="text-sm text-red-600">
              {error === "invalid_credentials" && "E-posta veya şifre hatalı."}
              {error === "session_error" &&
                "Oturum hatası. Lütfen tekrar deneyin."}
              {error === "server_error" &&
                "Bir hata oluştu. Lütfen tekrar deneyin."}
            </p>
          </div>
        )
      }

      <!-- Login Form -->
      <form class="mt-8 space-y-6" action="/api/auth/login" method="POST">
        <div class="space-y-4">
          <!-- Email -->
          <div>
            <label for="email" class="label">E-posta Adresi</label>
            <div class="relative mt-1">
              <div
                class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"
              >
                <Mail className="h-5 w-5 text-gray-400" />
              </div>
              <input
                id="email"
                name="email"
                type="email"
                required
                class="input pl-10"
                placeholder="kullanici@sanliurfa.com"
              />
            </div>
          </div>

          <!-- Password -->
          <div>
            <label for="password" class="label">Şifre</label>
            <div class="relative mt-1">
              <div
                class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"
              >
                <Lock className="h-5 w-5 text-gray-400" />
              </div>
              <input
                id="password"
                name="password"
                type="password"
                required
                class="input pl-10 pr-10"
                placeholder="••••••••"
              />
              <button
                type="button"
                id="toggle-password"
                class="absolute inset-y-0 right-0 pr-3 flex items-center"
              >
                <Eye id="eye-icon" className="h-5 w-5 text-gray-400" />
                <EyeOff
                  id="eye-off-icon"
                  className="h-5 w-5 text-gray-400 hidden"
                />
              </button>
            </div>
          </div>
        </div>

        <!-- Remember & Forgot -->
        <div class="flex items-center justify-between">
          <div class="flex items-center">
            <input
              id="remember-me"
              name="remember-me"
              type="checkbox"
              class="h-4 w-4 text-urfa-600 focus:ring-urfa-500 border-gray-300 rounded"
            />
            <label
              for="remember-me"
              class="ml-2 block text-sm text-gray-900 dark:text-gray-300"
            >
              Beni hatırla
            </label>
          </div>

          <div class="text-sm">
            <a
              href="/sifremi-unuttum"
              class="font-medium text-urfa-600 hover:text-urfa-500"
            >
              Şifremi unuttum
            </a>
          </div>
        </div>

        <!-- Submit Button -->
        <button type="submit" class="btn-primary w-full flex justify-center">
          Giriş Yap
        </button>
      </form>

      <!-- Terms -->
      <p class="text-xs text-center text-gray-500">
        Giriş yaparak{" "}
        <a href="/kullanim-kosullari" class="text-urfa-600 hover:underline"
          >Kullanım Koşulları</a
        >
        {" "}ve{" "}
        <a href="/gizlilik-politikasi" class="text-urfa-600 hover:underline"
          >Gizlilik Politikası</a
        >
        {" "}nı kabul etmiş olursunuz.
      </p>
    </div>
  </div>
</Layout>

<script>
  // Toggle password visibility
  const togglePassword = document.getElementById("toggle-password");
  const passwordInput = document.getElementById("password");
  const eyeIcon = document.getElementById("eye-icon");
  const eyeOffIcon = document.getElementById("eye-off-icon");

  togglePassword?.addEventListener("click", () => {
    const type =
      passwordInput?.getAttribute("type") === "password" ? "text" : "password";
    passwordInput?.setAttribute("type", type);
    eyeIcon?.classList.toggle("hidden");
    eyeOffIcon?.classList.toggle("hidden");
  });
</script>
