---
import { Icon } from 'astro-icon/components';
import Layout from '../layouts/Layout.astro';
import Image from '../components/Image.astro';
import { requireAuth } from '../lib/auth';
import { getFollowing, getSocialStats } from '../lib/social/friendship-db';

const auth = await requireAuth(Astro.request);
if (auth instanceof Response) return auth;
if (!auth.user) return Astro.redirect('/giris');
const user = auth.user;

const [following, stats] = await Promise.all([
 getFollowing(user.id, 50),
 getSocialStats(user.id),
]);
---

<Layout seo={{ title: `Takip Edilenler (${stats?.following_count || 0}) - Şanlıurfa Rehberi`, noIndex: true }}>
 <style is:inline>
 .te-page{background:var(--bg);min-height:100vh}
 .te-hero{position:relative;overflow:hidden;border-bottom:1px solid rgba(184,115,51,0.12);background:radial-gradient(circle at 18% 0%,rgba(212,151,24,.10) 0%,transparent 42%),radial-gradient(circle at 82% 100%,rgba(44,122,82,.08) 0%,transparent 40%),linear-gradient(180deg,#fbf6ec 0%,#f4ecd8 58%,#fbf6ec 100%);padding:2.5rem 0}
 .te-inner{max-width:48rem;margin:0 auto}
 .te-hero-top{display:flex;align-items:center;justify-content:space-between;gap:1rem}
 .te-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.5rem,3.5vw,2rem);font-weight:700;color:var(--public-text);margin:.25rem 0 0}
 .te-hero-desc{color:var(--public-muted);font-size:.88rem;margin-top:.2rem}
 .te-link{color:var(--public-accent);font-size:.85rem;font-weight:500;transition:color .15s;white-space:nowrap}
 .te-link:hover{color:var(--public-accent-strong)}
 .te-body{padding:2rem 0 4rem}
 .te-list{background:var(--bg-card);border:1px solid rgba(184,115,51,.14)}
 .te-item{display:flex;align-items:center;justify-content:space-between;padding:1.25rem 1.5rem;border-bottom:1px solid rgba(184,115,51,.1)}
 .te-item:last-child{border-bottom:none}
 .te-user-link{display:flex;align-items:center;gap:1rem}
 .te-avatar{width:3.5rem;height:3.5rem;border-radius:50%;background:linear-gradient(135deg,var(--public-accent-strong),var(--public-accent));display:flex;align-items:center;justify-content:center;color:var(--public-text);font-size:1.1rem;font-weight:700;flex-shrink:0;overflow:hidden}
 .te-avatar-img{width:100%;height:100%;object-fit:cover;border-radius:50%}
 .te-name{font-weight:700;color:var(--public-text);transition:color .15s;font-size:.95rem}
 .te-user-link:hover .te-name{color:var(--public-accent)}
 .te-handle{font-size:.82rem;color:var(--public-text-soft);margin-top:.1rem}
 .te-stats{font-size:.78rem;color:var(--public-muted);margin-top:.2rem}
 .te-actions{display:flex;align-items:center;gap:.75rem;flex-shrink:0}
 .te-unfollow-btn{font-size:.78rem;padding:.35rem .85rem;background:rgba(184,115,51,.08);color:var(--public-muted);cursor:pointer;border:none;transition:background .15s,color .15s}
 .te-unfollow-btn:hover{background:rgba(184,115,51,.16);color:var(--public-accent)}
 .te-msg-btn{padding:.4rem;color:var(--public-muted);transition:color .15s}
 .te-msg-btn:hover{color:var(--public-accent)}
 .te-empty{text-align:center;padding:4rem 1rem}
 .te-empty-emoji{font-size:3.5rem;display:block;margin-bottom:1rem}
 .te-empty-title{font-size:1.1rem;font-weight:700;color:var(--public-text);margin-bottom:.5rem}
 .te-empty-desc{color:var(--public-muted);font-size:.88rem}
 </style>

 <div class="te-page">
 <div class="te-hero">
 <div class="sf-container">
 <div class="te-inner">
 <div class="te-hero-top">
 <div>
 <h1 class="te-h1">Takip Edilenler</h1>
 <p class="te-hero-desc">Senin takip ettiğin {stats?.following_count || 0} kişi</p>
 </div>
 <a href="/takipciler" class="te-link">← Takipçiler</a>
 </div>
 </div>
 </div>
 </div>

 <div class="te-body">
 <div class="sf-container">
 <div class="te-inner">
 {following.length > 0 ? (
 <div class="te-list">
 {following.map(person => (
 <div class="te-item">
 <a href={`/kullanici/${person.username || person.id}`} class="te-user-link">
 <div class="te-avatar">
 {person.avatar_url ? (
 <Image src={person.avatar_url} alt={person.full_name || 'Avatar'} width={56} height={56} class="te-avatar-img" loading="lazy" />
 ) : (
 person.full_name?.charAt(0).toUpperCase() || 'U'
 )}
 </div>
 <div>
 <p class="te-name">{person.full_name}</p>
 <p class="te-handle">@{person.username || 'kullanici'}</p>
 <p class="te-stats">{person.follower_count} takipçi · {person.following_count} takip</p>
 </div>
 </a>

 <div class="te-actions">
 <button
 onclick={`unfollowUser('${person.id}')`}
 class="te-unfollow-btn"
 >
 Takipten Çık
 </button>
 <a href={`/mesajlar?user=${person.id}`} class="te-msg-btn" title="Mesaj gönder">
 <Icon name="lucide:message-circle" class="w-5 h-5" />
 </a>
 </div>
 </div>
 ))}
 </div>
 ) : (
 <div class="te-empty">
 <span class="te-empty-emoji">👥</span>
 <h3 class="te-empty-title">Henüz kimseyi takip etmiyorsunuz</h3>
 <p class="te-empty-desc">Topluluk sayfasından kullanıcıları keşfedip takip edebilirsiniz.</p>
 </div>
 )}
 </div>
 </div>
 </div>
 </div>

 <script is:inline>
 window.unfollowUser = async function (userId) {
 try {
 const response = await fetch('/api/social/follow', {
 method: 'POST',
 headers: { 'Content-Type': 'application/json' },
 body: JSON.stringify({ userId, action: 'unfollow' }),
 });

 if (response.ok) {
 window.location.reload();
 } else {
 window.toast?.error('İşlem başarısız');
 }
 } catch {
 window.toast?.error('Bağlantı hatası');
 }
 };
 </script>
</Layout>
