---
import { Icon } from 'astro-icon/components';
import Layout from '../layouts/Layout.astro';
import { requireAuth } from '../lib/auth';
import { getFollowing, getSocialStats } from '../lib/social/friendship-db';

const auth = await requireAuth(Astro.request);
if (auth instanceof Response) return auth;

const [following, stats] = await Promise.all([
  getFollowing(auth.user.id, 50),
  getSocialStats(auth.user.id),
]);
---

<Layout seo={{ title: `Takip Edilenler (${stats?.following_count || 0}) - Şanlıurfa Rehberi`, noIndex: true }}>
  <div class="min-h-screen bg-[#FDFAF3]">
    <div class="container-custom py-8">
      <div class="max-w-3xl mx-auto">
        <div class="flex items-center justify-between mb-8">
          <div>
            <h1 class="text-3xl font-bold text-[#1A1008]">Takip Edilenler</h1>
            <p class="text-[#6B5540] mt-1">Senin takip ettiğin {stats?.following_count || 0} kişi</p>
          </div>
          <a href="/takipciler" class="text-urfa-600 hover:text-urfa-700 font-medium">
            ← Takipçiler
          </a>
        </div>

        <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm">
          {following.length > 0 ? (
            <div class="divide-y divide-[rgba(200,160,100,0.12)]">
              {following.map(user => (
                <div class="p-6 flex items-center justify-between">
                  <a href={`/kullanıcı/${user.username || user.id}`} class="flex items-center gap-4">
                    <div class="w-14 h-14 rounded-full bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center text-white text-xl font-bold shrink-0">
                      {user.avatar_url ? (
                        <img src={user.avatar_url} alt={user.full_name} class="w-full h-full rounded-full object-cover" />
                      ) : (
                        user.full_name?.charAt(0).toUpperCase() || 'U'
                      )}
                    </div>
                    <div>
                      <h3 class="font-bold text-lg text-[#1A1008] hover:text-urfa-700 transition-colors">{user.full_name}</h3>
                      <p class="text-[#9A8470]">@{user.username || 'kullanici'}</p>
                      <p class="text-sm text-[#9A8470] mt-1">{user.follower_count} takipçi • {user.following_count} takip</p>
                    </div>
                  </a>

                  <div class="flex items-center gap-3">
                    <button
                      onclick={`unfollowUser('${user.id}')`}
                      class="px-4 py-2 bg-[rgba(200,160,100,0.08)] text-[#6B5540] rounded-sm text-sm font-medium hover:bg-[rgba(200,160,100,0.16)] transition-colors"
                    >
                      Takipten Çık
                    </button>
                    <a
                      href={`/mesajlar?user=${user.id}`}
                      class="p-2 text-[#9A8470] hover:text-urfa-600 hover:bg-[rgba(200,160,100,0.06)] rounded-sm transition-colors"
                      title="Mesaj gönder"
                    >
                      <Icon name="lucide:message-circle" class="w-5 h-5" />
                    </a>
                  </div>
                </div>
              ))}
            </div>
          ) : (
            <div class="text-center py-16">
              <div class="text-6xl mb-4">👥</div>
              <h3 class="text-xl font-bold text-[#1A1008] mb-2">Henüz kimseyi takip etmiyorsunuz</h3>
              <p class="text-[#6B5540]">Topluluk sayfasından kullanıcıları keşfedip takip edebilirsiniz.</p>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    window.unfollowUser = async function (userId) {
      try {
        const response = await fetch('/api/social/follow', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ userId, action: 'unfollow' }),
        });

        if (response.ok) {
          window.location.reload();
        } else {
          window.toast?.error('İşlem başarısız');
        }
      } catch {
        window.toast?.error('Bağlantı hatası');
      }
    };
  </script>
</Layout>
