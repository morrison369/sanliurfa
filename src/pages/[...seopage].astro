 "Bugün Şanlıurfa'da Balıklıgöl çevresini gezebilir, Göbeklitepe rotası planlayabilir, yöresel yemekleri deneyebilir ve günlük yaşam servislerini kontrol edebilirsiniz.",
 sort_by: 'popular',
 limit_count: 20,
 fallback_places: [
 {
 name: 'Balıklıgöl ve Tarihi Çarşı Rotası',
 slug: 'balikligol-ve-tarihi-carsi-rotasi',
 short_description: 'Kısa sürede Şanlıurfa tarihi dokusunu görmek isteyenler için yürünebilir merkez rota.',
 district_name: 'Eyyübiye',
 rating: 4.9,
 review_count: 1800,
 price_range: 'Ücretsiz',
 },
 {
 name: 'Göbeklitepe Yarım Gün Rotası',
 slug: 'gobeklitepe-yarim-gun-rotasi',
 short_description: "Şehir merkezinden Göbeklitepe'ye gidip müze ve yemek molasıyla tamamlanabilecek rota.",
 district_name: 'Haliliye',
 rating: 4.9,
 review_count: 1450,
 price_range: '₺₺',
 },
 {
 name: 'Urfa Mutfağı Tadım Rotası',
 slug: 'urfa-mutfagi-tadim-rotasi',
 short_description: 'Kebap, ciğer, çiğ köfte, şıllık tatlısı ve mırra deneyimini bir güne sığdırmak isteyenler için.',
 district_name: 'Şanlıurfa',
 rating: 4.8,
 review_count: 1320,
 price_range: '₺₺',
 },
 ],
 faq: [
 {
 S: "Şanlıurfa'da bir günde neler yapılır?",
 C: "Tek günde Şanlıurfa'yı gezmek için önerilen rota: Sabah Balıklıgöl ve Gümrük Hanı ziyareti → öğle ciğer veya kebap molası → öğleden sonra Göbeklitepe (30 km) → akşam tarihi çarşı gezmesi ve sıra gecesi deneyimi.",
 },
 {
 S: "Şanlıurfa'ya gitmek için en iyi mevsim hangisidir?",
 C: "Şanlıurfa'yı ziyaret etmek için en uygun dönem Eylül–Kasım (sonbahar) ve Mart–Mayıs (ilkbahar) arası. Yaz ayları (Haziran–Ağustos) sıcaklık 40°C'yi aşabilir; ziyaret sabah erken saatlerde önerilir.",
 },
 {
 S: "Şanlıurfa'da ücretsiz gezilecek yerler var mı?",
 C: "Balıklıgöl ve çevresi, Rızvaniye Camii, Kapalı Çarşı, Urfa Kalesi dış mekanı ücretsiz gezilebilir. Göbeklitepe ve bazı müzeler için bilet ücreti ödenmesi gerekir.",
 },
 ],
 },
};

try {
 const data = await getCachedPublicRouteData(`page:seo:${slug}`, async () => {
  const dbPage = await queryOne(
   "SELECT * FROM seo_pages WHERE slug = $1 AND is_active = true",
   [slug]
  );

  const resolvedPage = dbPage || fallbackSeoPages[String(slug)];
  if (!resolvedPage) return { page: null, places: [] };

  let sql = "SELECT p.*, c.name as category_name, d.name as district_name FROM places p LEFT JOIN categories c ON p.category_id = c.id LEFT JOIN districts d ON p.district_id = d.id WHERE p.status = 'active'";
  const params: any[] = [];
  let idx = 1;

  if (resolvedPage.category_filter) {
   sql += ` AND (c.slug = $${idx} OR c.parent_id = (SELECT id FROM categories WHERE slug = $${idx}))`;
   params.push(resolvedPage.category_filter);
   idx++;
  }

  if (resolvedPage.district_filter) {
   sql += ` AND p.district_id = $${idx}`;
   params.push(resolvedPage.district_filter);
   idx++;
  }

  const sortMap: Record<string, string> = {
   rating: 'p.rating DESC NULLS LAST',
   newest: 'p.created_at DESC',
   popular: 'p.view_count DESC NULLS LAST',
   name: 'p.name ASC',
  };
  sql += ` ORDER BY ${sortMap[resolvedPage.sort_by] || 'p.rating DESC NULLS LAST'}`;
  sql += ` LIMIT $${idx}`;
  params.push(resolvedPage.limit_count || 20);

  const result = await query(sql, params);
  return { page: resolvedPage, places: result.rows };
 });
 page = data.page;
 places = data.places;
 if (!page) {
  return new Response(null, { status: 404 });
 }
} catch (e) {
 logger.error('Error loading SEO page:', e instanceof Error ? e : new Error(String(e)));
}

if (!page) return new Response(null, { status: 404 });
if (places.length === 0 && Array.isArray(page.fallback_places)) {
 places = page.fallback_places;
}

const seo = {
 title: page.meta_title || page.title,
 description: page.meta_description || page.intro_text,
 keywords: [page.title, 'şanlıurfa ' + slug, 'urfa ' + slug],
 ogImage: (page.og_image as string | undefined) || '/images/places/balikligol.jpg',
 canonical: `/${slug}`,
};
---

<Layout seo={seo}>
 <style is:inline>
 .sp-page{background:var(--bg);min-height:100vh}
 .sp-hero{position:relative;overflow:hidden;border-bottom:1px solid rgba(184,115,51,0.12);padding:clamp(3rem,6vw,5rem) 0;background:radial-gradient(circle at 18% 0%,rgba(212,151,24,0.10) 0%,transparent 42%),radial-gradient(circle at 82% 100%,rgba(44,122,82,0.08) 0%,transparent 40%),linear-gradient(180deg,#fbf6ec 0%,#f4ecd8 58%,#fbf6ec 100%)}
 .sp-label{font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--public-muted);margin-bottom:.5rem}
 .sp-h1{font-size:clamp(1.5rem,4vw,2.25rem);font-weight:700;color:var(--public-text);margin-bottom:.75rem}
 .sp-intro{font-size:1.05rem;color:var(--public-muted);max-width:48rem}
 .sp-body{padding:2.5rem 0 4rem}
 .sp-list{display:flex;flex-direction:column;gap:1rem}
 .sp-item{display:flex;align-items:center;gap:1.25rem;background:var(--bg-card);border:1px solid rgba(184,115,51,.14);padding:1.25rem;text-decoration:none;transition:border-color .15s}
 .sp-item:hover{border-color:rgba(184,115,51,.35)}
 .sp-badge{flex-shrink:0;width:3rem;height:3rem;background:rgba(184,115,51,.08);display:flex;align-items:center;justify-content:center;color:#B87333;font-weight:700;font-size:1.125rem}
 .sp-item-content{flex:1;min-width:0}
 .sp-item-title{font-weight:700;font-size:1.05rem;color:#1F1410;margin-bottom:.25rem;transition:color .15s}
 .sp-item:hover .sp-item-title{color:#B87333}
 .sp-item-desc{font-size:.875rem;color:#7A6B58;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
 .sp-item-loc{font-size:.75rem;color:#7A6B58;margin-top:.25rem}
 .sp-item-rating{flex-shrink:0;text-align:right;color:#B87333}
 .sp-item-rating-num{font-weight:700;font-size:1.05rem}
 .sp-item-rev{font-size:.75rem;color:#7A6B58}
 .sp-item-price{font-size:.875rem;color:#7A6B58;margin-top:.25rem}
 .sp-empty{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);padding:2rem;text-align:center}
 .sp-empty-title{font-size:1.5rem;font-weight:700;color:#1F1410;margin-bottom:.75rem}
 .sp-empty-desc{max-width:42rem;margin:0 auto;color:#7A6B58}
 .sp-empty-btns{margin-top:1.5rem;display:flex;flex-wrap:wrap;justify-content:center;gap:.75rem}
 .sp-btn-primary{background:#B87333;color:#fff;padding:.75rem 1.25rem;font-weight:600;text-decoration:none;transition:background .15s}
 .sp-btn-primary:hover{background:#9A6528}
 .sp-btn-sec{border:1px solid rgba(184,115,51,.2);padding:.75rem 1.25rem;font-weight:600;color:#B87333;text-decoration:none;transition:border-color .15s}
 .sp-btn-sec:hover{border-color:rgba(184,115,51,.4)}
 details summary{list-style:none}
 details summary::-webkit-details-marker{display:none}
 details[open] .faq-arrow{transform:rotate(180deg)}
 </style>

 <div class="sp-page">
 <div class="sp-hero">
 <div class="sf-container">
 <p class="sp-label">ŞANLIURFA REHBERİ</p>
 <h1 class="sp-h1">{page.heading || page.title}</h1>
 {page.intro_text && <p class="sp-intro">{page.intro_text}</p>}
 </div>
 </div>

 <div class="sp-body">
 <div class="sf-container">
 {places.length > 0 ? (
 <div class="sp-list">
 {places.map((place, i) => (
 <a href={`/isletme/${place.slug}`} class="sp-item">
 <div class="sp-badge">{i + 1}</div>
 <div class="sp-item-content">
 <h2 class="sp-item-title">{place.name}</h2>
 <p class="sp-item-desc">{place.short_description || place.address}</p>
 {place.district_name && <span class="sp-item-loc">📍 {place.district_name}</span>}
 </div>
 <div class="sp-item-rating">
 <div style="display:flex;align-items:center;gap:.25rem;justify-content:flex-end">
 <span style="color:#B87333">★</span>
 <span class="sp-item-rating-num">{place.rating || '-'}</span>
 </div>
 <span class="sp-item-rev">{place.review_count || 0} yorum</span>
 {place.price_range && <div class="sp-item-price">{place.price_range}</div>}
 </div>
 </a>
 ))}
 </div>
 ) : (
 <div class="sp-empty">
 <h2 class="sp-empty-title">Bu rehber için uygun mekan bulunamadı</h2>
 <p class="sp-empty-desc">
 Aradığınız başlık aktif mekan kayıtlarıyla eşleşmedi. Şanlıurfa mekan rehberi,
 tarihi yerler ve yemek önerileri üzerinden benzer içerikleri keşfedebilirsiniz.
 </p>
 <div class="sp-empty-btns">
 <a href="/mekanlar" class="sp-btn-primary">Mekanları Keşfet</a>
 <a href="/tarihi-yerler" class="sp-btn-sec">Tarihi Yerler</a>
 <a href="/sanliurfada-ne-yenir" class="sp-btn-sec">Ne Yenir?</a>
 </div>
 </div>
 )}
 </div>
 </div>
 </div>

 {Array.isArray(page.faq) && page.faq.length > 0 && (
 <div style="padding:2rem 0 3rem;border-top:1px solid rgba(184,115,51,.12)">
 <div class="sf-container">
 <h2 style="font-size:1.25rem;font-weight:700;color:#1F1410;margin-bottom:1.25rem">Sık Sorulan Sorular</h2>
 <div style="display:flex;flex-direction:column;gap:.75rem">
 {page.faq.map((item: any) => (
 <details style="background:var(--bg-card);border:1px solid rgba(184,115,51,.14);border-radius:.375rem;overflow:hidden">
 <summary style="padding:1rem 1.25rem;font-weight:600;color:#1F1410;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:1rem">
 {item.S}
 <span style="flex-shrink:0;color:#B87333;font-size:1.25rem;transition:transform .2s" class="faq-arrow">▾</span>
 </summary>
 <div style="padding:.75rem 1.25rem 1rem;color:#4A3828;font-size:.95rem;line-height:1.7;border-top:1px solid rgba(184,115,51,.08)">
 {item.C}
 </div>
 </details>
 ))}
 </div>
 </div>
 </div>
 )}

 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'ItemList',
 name: page.heading || page.title,
 description: page.meta_description,
 numberOfItems: places.length,
 itemListElement: places.map((p, i) => ({
 '@type': 'ListItem',
 position: i + 1,
 item: {
 '@type': 'LocalBusiness',
 '@id': `${baseUrl}/isletme/${p.slug}`,
 name: p.name,
 url: `${baseUrl}/isletme/${p.slug}`,
 aggregateRating: p.rating ? { '@type': 'AggregateRating', ratingValue: p.rating, reviewCount: p.review_count || 0 } : undefined,
 }
 }))
 })} is:inline />
 {Array.isArray(page.faq) && page.faq.length > 0 && (
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: page.faq.map((item: any) => ({
 '@type': 'Question',
 name: item.S,
 acceptedAnswer: {
 '@type': 'Answer',
 text: item.C,
 },
 })),
 })} is:inline />
 )}
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: page.title, item: `${baseUrl}/${slug}` },
 ],
 })} is:inline />
</Layout>
