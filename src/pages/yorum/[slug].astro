---
import Layout from '../../layouts/Layout.astro';
import Image from '../../components/Image.astro';
import { getPlaceBySlug } from '../../lib/places/db';
import { getCurrentUser } from '../../lib/auth';
import { actions, isInputError } from 'astro:actions';
import { getPublicAppUrl } from '../../lib/public-app-url';
import { logger } from '../../lib/logging';
const baseUrl = getPublicAppUrl();

const { slug } = Astro.params;
if (!slug) {
 return Astro.redirect('/mekanlar');
}

let place: Awaited<ReturnType<typeof getPlaceBySlug>> = null;
try {
 place = await getPlaceBySlug(slug);
} catch (e) {
 logger.error('yorum/[slug] place query failed:', e instanceof Error ? e : new Error(String(e)));
}
if (!place) {
 return Astro.redirect('/404');
}

let user: Awaited<ReturnType<typeof getCurrentUser>> = null;
try {
 user = await getCurrentUser();
} catch (e) {
 logger.error('yorum/[slug] auth failed:', e instanceof Error ? e : new Error(String(e)));
}
if (!user) {
 return Astro.redirect(`/giris?redirect=/yorum/${slug}`);
}

const seo = {
 title: `${place.name} - Değerlendirme Yap | Şanlıurfa`,
 description: `${place.name} hakkında yorum yazın ve deneyiminizi paylaşın.`,
 keywords: [place.name + ' yorum', place.name + ' değerlendirme', 'şanlıurfa ' + place.name.toLowerCase()],
 ogImage: '/images/places/balikligol.jpg',
};

const reviewResult = Astro.getActionResult(actions.submitPlaceReview);
const reviewInputErrors = isInputError(reviewResult?.error) ? reviewResult.error.fields : {};
const reviewSubmitError =
 !isInputError(reviewResult?.error) && reviewResult?.error?.message
 ? reviewResult.error.message
 : null;

if (reviewResult?.data?.success) {
 return Astro.redirect(`/isletme/${slug}?success=review_added`);
}

const faqItems = [
 { S: 'Yorum yazmak için üye olmam gerekiyor mu?', C: 'Evet, yorum yazmak için bir hesap oluşturmanız gerekmektedir.' },
 { S: 'Yazdığım yorumu silebilir miyim?', C: 'Profil sayfanızdan kendi yorumlarınızı düzenleyebilir veya silebilirsiniz.' },
 { S: 'Uygunsuz yorum nasıl bildirilir?', C: 'Yorum kartında yer alan bildir seçeneğini kullanarak uygunsuz içerikleri moderasyon ekibimize iletebilirsiniz.' },
];
---

<Layout seo={seo}>
 <style is:inline>
 .yr-page{background:var(--bg);min-height:100vh;padding:2rem 0}
 .yr-inner{max-width:42rem;margin:0 auto}
 .yr-breadcrumb{font-size:.82rem;color:#7A6B58;margin-bottom:1.5rem}
 .yr-breadcrumb a{color:#7A6B58;text-decoration:none;transition:color .15s}
 .yr-breadcrumb a:hover{color:#B87333}
 .yr-breadcrumb span{margin:0 .5rem}
 .yr-breadcrumb-current{color:#1F1410}
 .yr-card{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);padding:1.5rem}
 @media(min-width:48rem){.yr-card{padding:2rem}}
 .yr-place-header{display:flex;align-items:center;gap:1rem;margin-bottom:2rem;padding-bottom:1.5rem;border-bottom:1px solid rgba(184,115,51,.12)}
 .yr-place-img{width:4rem;height:4rem;object-fit:cover}
 .yr-place-fallback{width:4rem;height:4rem;background:rgba(184,115,51,.08);display:flex;align-items:center;justify-content:center;font-size:1.5rem}
 .yr-h1{font-size:1.35rem;font-weight:700;color:#1F1410}
 .yr-place-name{font-size:.88rem;color:#7A6B58;margin-top:.2rem}
 .yr-alert-error{background:rgba(220,38,38,.1);border:1px solid rgba(220,38,38,.2);color:#F87171;padding:.75rem 1rem;margin-bottom:1.5rem;font-size:.85rem}
 .yr-section-label{display:block;font-weight:600;color:#4A3828;margin-bottom:.75rem;font-size:.9rem}
 .yr-section-label span{color:#F87171}
 .yr-section-label-opt span{font-size:.82rem;color:#7A6B58;font-weight:400}
 .yr-stars{display:flex;gap:.25rem}
 .yr-star-btn{font-size:1.75rem;color:rgba(184,115,51,.25);background:none;border:none;cursor:pointer;transition:transform .15s;padding:.25rem;line-height:1;width:3rem;height:3rem}
 .yr-star-btn--active{color:#B87333}
 .yr-star-btn--hover{color:rgba(196,168,130,.5)}
 .yr-rating-hint{font-size:.82rem;color:#7A6B58;margin-top:.5rem}
 .yr-rating-hint--selected{color:#B87333;font-weight:600}
 .yr-field-error{margin-top:.4rem;font-size:.78rem;color:#F87171}
 .yr-input{width:100%;padding:.75rem 1rem;background:rgba(255,255,255,.8);border:1px solid rgba(184,115,51,.2);color:#1F1410;font-size:.9rem;transition:border-color .15s}
 .yr-input:focus{outline:none;border-color:#B87333}
 .yr-input::placeholder{color:#4A3828}
 .yr-textarea{width:100%;padding:.75rem 1rem;background:rgba(255,255,255,.8);border:1px solid rgba(184,115,51,.2);color:#1F1410;font-size:.9rem;resize:none;transition:border-color .15s}
 .yr-textarea:focus{outline:none;border-color:#B87333}
 .yr-textarea::placeholder{color:#4A3828}
 .yr-hint{margin-top:.4rem;font-size:.75rem;color:#4A3828}
 .yr-form-group{margin-bottom:1.5rem}
 .yr-actions{display:flex;flex-direction:column;gap:1rem;padding-top:1rem}
 @media(min-width:36rem){.yr-actions{flex-direction:row}}
 .yr-submit-btn{flex:1;padding:.9rem 1.5rem;background:#B87333;color:#EDE0C6;font-weight:700;border:none;cursor:pointer;transition:background .15s;font-size:.95rem}
 .yr-submit-btn:hover:not(:disabled){background:#9D5F1A}
 .yr-submit-btn:disabled{background:rgba(184,115,51,.2);cursor:not-allowed;color:#4A3828}
 .yr-cancel-btn{padding:.9rem 1.5rem;background:rgba(184,115,51,.08);color:#7A6B58;font-weight:600;font-size:.95rem;text-align:center;text-decoration:none;transition:background .15s}
 .yr-cancel-btn:hover{background:rgba(184,115,51,.14)}
 .yr-footer-note{font-size:.82rem;color:#4A3828;text-align:center;margin-top:1rem}
 </style>

 <div class="yr-page">
 <div class="sf-container">
 <div class="yr-inner">
 <nav class="yr-breadcrumb">
 <a href="/">Ana Sayfa</a>
 <span>/</span>
 <a href={`/isletme/${slug}`}>{place.name}</a>
 <span>/</span>
 <span class="yr-breadcrumb-current">Değerlendirme</span>
 </nav>

 <div class="yr-card">
 <div class="yr-place-header">
 {place.thumbnail ? (
 <Image src={place.thumbnail} alt={place.name} class="yr-place-img" width={64} height={64} />
 ) : (
 <div class="yr-place-fallback">📍</div>
 )}
 <div>
 <h1 class="yr-h1">Değerlendirme Yap</h1>
 <p class="yr-place-name">{place.name}</p>
 </div>
 </div>

 {reviewSubmitError && (
 <div class="yr-alert-error">{reviewSubmitError}</div>
 )}

 <form action={actions.submitPlaceReview} method="POST">
 <input type="hidden" name="placeId" value={place.id} />

 <div class="yr-form-group">
 <label class="yr-section-label">Puanınız <span>*</span></label>
 <div class="yr-stars" id="rating-stars">
 {[1, 2, 3, 4, 5].map((star) => (
 <button type="button" data-rating={star} class="yr-star-btn" aria-label={`${star} yıldız`}>★</button>
 ))}
 </div>
 <input type="hidden" name="rating" id="rating-input" value="0" required />
 {reviewInputErrors.rating && (
 <p class="yr-field-error">{reviewInputErrors.rating.join(', ')}</p>
 )}
 <p class="yr-rating-hint" id="rating-text">Puan seçin</p>
 </div>

 <div class="yr-form-group">
 <label class="yr-section-label yr-section-label-opt">Başlık <span>(İsteğe bağlı)</span></label>
 <input type="text" name="title" placeholder="Örn: Harika bir deneyimdi" class="yr-input" maxlength="100" />
 {reviewInputErrors.title && (
 <p class="yr-field-error">{reviewInputErrors.title.join(', ')}</p>
 )}
 </div>

 <div class="yr-form-group">
 <label class="yr-section-label">Yorumunuz <span>*</span></label>
 <textarea name="content" rows="5" placeholder="Deneyiminizi paylaşın. Ne beğendiniz, ne beğenmediniz?" class="yr-textarea" minlength="10" maxlength="2000" required></textarea>
 {reviewInputErrors.content && (
 <p class="yr-field-error">{reviewInputErrors.content.join(', ')}</p>
 )}
 <p class="yr-hint">En az 10 karakter</p>
 </div>

 <div class="yr-form-group">
 <label class="yr-section-label yr-section-label-opt">Ziyaret Tarihi <span>(İsteğe bağlı)</span></label>
 <input type="date" name="visitDate" max={new Date().toISOString().split('T')[0]} class="yr-input" />
 </div>

 <div class="yr-actions">
 <button type="submit" class="yr-submit-btn" id="submit-btn" disabled>
 Değerlendirmeyi Gönder
 </button>
 <a href={`/isletme/${slug}`} class="yr-cancel-btn">İptal</a>
 </div>

 <p class="yr-footer-note">Değerlendirmeniz onaylandıktan sonra yayınlanacaktır.</p>
 </form>
 </div>
 </div>
 </div>
 </div>

 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'Mekanlar', item: `${baseUrl}/mekanlar` },
 { '@type': 'ListItem', position: 3, name: place.name, item: `${baseUrl}/isletme/${place.slug}` },
 { '@type': 'ListItem', position: 4, name: 'Değerlendirme', item: `${baseUrl}/yorum/${slug}` },
 ],
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqItems.map((item) => ({
 '@type': 'Question',
 name: item.S,
 acceptedAnswer: { '@type': 'Answer', text: item.C },
 })),
 })} is:inline />
</Layout>

<script>
 const starBtns = document.querySelectorAll('.yr-star-btn');
 const ratingInput = document.getElementById('rating-input') as HTMLInputElement;
 const ratingText = document.getElementById('rating-text');
 const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

 const ratingLabels: Record<number, string> = {
 1: 'Berbat', 2: 'Kötü', 3: 'Orta', 4: 'İyi', 5: 'Harika',
 };

 starBtns.forEach((btn) => {
 btn.addEventListener('click', () => {
 const rating = parseInt(btn.getAttribute('data-rating') || '0');
 ratingInput.value = rating.toString();
 starBtns.forEach((star, index) => {
 star.classList.toggle('yr-star-btn--active', index < rating);
 });
 if (ratingText) {
 ratingText.textContent = `${rating} yıldız - ${ratingLabels[rating]}`;
 ratingText.classList.add('yr-rating-hint--selected');
 }
 if (submitBtn) submitBtn.disabled = false;
 });

 btn.addEventListener('mouseenter', () => {
 const rating = parseInt(btn.getAttribute('data-rating') || '0');
 starBtns.forEach((star, index) => {
 star.classList.toggle('yr-star-btn--hover', index < rating);
 });
 });

 btn.addEventListener('mouseleave', () => {
 starBtns.forEach((star) => star.classList.remove('yr-star-btn--hover'));
 });
 });
</script>
