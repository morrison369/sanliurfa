---
import Layout from '../../layouts/Layout.astro';
import { getPlaceBySlug } from '../../lib/places/db';
import { getCurrentUser } from '../../lib/auth';

const { slug } = Astro.params;
if (!slug) {
  return Astro.redirect('/places');
}

const place = await getPlaceBySlug(slug);
if (!place) {
  return Astro.redirect('/404');
}

// Check authentication
const user = await getCurrentUser();
if (!user) {
  return Astro.redirect(`/giris?redirect=/yorum/${slug}`);
}

const seo = {
  title: `${place.name} - Değerlendirme Yap | Şanlıurfa`,
  description: `${place.name} hakkında yorum yazın ve deneyiminizi paylaşın.`,
};

const errors = {
  rating: '',
  content: '',
  general: '',
};

// Handle POST
if (Astro.request.method === 'POST') {
  let rating: any = null;
let title: any = null;
let content: any = null;
let error: any = null;

try {
    const formData = await Astro.request.formData();
    rating = parseInt(formData.get('rating')?.toString() || '0');
    title = formData.get('title')?.toString() || '';
    content = formData.get('content')?.toString() || '';
    const visitDate = formData.get('visit_date')?.toString();

    // Validation
    let hasError = false;
    if (!rating || rating < 1 || rating > 5) {
      errors.rating = 'Lütfen 1-5 arası bir puan seçin';
      hasError = true;
    }
    if (!content || content.length < 10) {
      errors.content = 'Yorum en az 10 karakter olmalıdır';
      hasError = true;
    }

    if (!hasError) {
      // Create review via API
      const response = await fetch(new URL('/api/reviews', Astro.url.origin), {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Cookie': Astro.request.headers.get('cookie') || '',
        },
        body: JSON.stringify({
          place_id: place.id,
          rating,
          title,
          content,
          visit_date: visitDate,
        }),
      });

      if (response.ok) {
        return Astro.redirect(`/places/${slug}?success=review_added`);
      } else {
        error = await response.json();
        errors.general = error.message || 'Yorum eklenirken bir hata oluştu';
      }
    }
  } catch (e) {
    errors.general = 'Bir hata oluştu. Lütfen tekrar deneyin.';
  }
}
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50 py-8">
    <div class="container mx-auto max-w-2xl px-4">
      {/* Breadcrumb */}
      <nav class="text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-gray-900">Ana Sayfa</a>
        <span class="mx-2">/</span>
        <a href={`/places/${slug}`} class="hover:text-gray-900">{place.name}</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900">Değerlendirme</span>
      </nav>

      <div class="bg-white rounded-2xl shadow-sm p-6 md:p-8">
        {/* Header */}
        <div class="flex items-center gap-4 mb-8 pb-6 border-b">
          {place.thumbnail ? (
            <img src={place.thumbnail} alt={place.name} class="w-16 h-16 rounded-xl object-cover" />
          ) : (
            <div class="w-16 h-16 bg-gray-100 rounded-xl flex items-center justify-center text-2xl">📍</div>
          )}
          <div>
            <h1 class="text-2xl font-bold text-gray-900">Değerlendirme Yap</h1>
            <p class="text-gray-500">{place.name}</p>
          </div>
        </div>

        {errors.general && (
          <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-xl text-red-700">
            {errors.general}
          </div>
        )}

        {/* Review Form */}
        <form method="POST" class="space-y-6">
          {/* Rating */}
          <div>
            <label class="block font-medium text-gray-900 mb-3">
              Puanınız <span class="text-red-500">*</span>
            </label>
            <div class="flex gap-2" id="rating-stars">
              {[1, 2, 3, 4, 5].map((star) => (
                <button
                  type="button"
                  data-rating={star}
                  class="star-btn w-12 h-12 text-3xl text-gray-300 hover:scale-110 transition-transform"
                  aria-label={`${star} yıldız`}
                >
                  ★
                </button>
              ))}
            </div>
            <input type="hidden" name="rating" id="rating-input" value="0" required />
            {errors.rating && <p class="mt-2 text-sm text-red-600">{errors.rating}</p>}
            <p class="mt-2 text-sm text-gray-500" id="rating-text">Puan seçin</p>
          </div>

          {/* Title (Optional) */}
          <div>
            <label class="block font-medium text-gray-900 mb-2">
              Başlık <span class="text-gray-400 text-sm font-normal">(İsteğe bağlı)</span>
            </label>
            <input
              type="text"
              name="title"
              placeholder="Örn: Harika bir deneyimdi"
              class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"
              maxlength="100"
            />
          </div>

          {/* Content */}
          <div>
            <label class="block font-medium text-gray-900 mb-2">
              Yorumunuz <span class="text-red-500">*</span>
            </label>
            <textarea
              name="content"
              rows="5"
              placeholder="Deneyiminizi paylaşın. Ne beğendiniz, ne beğenmediniz?"
              class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent resize-none"
              minlength="10"
              maxlength="2000"
              required
            ></textarea>
            {errors.content && <p class="mt-2 text-sm text-red-600">{errors.content}</p>}
            <p class="mt-2 text-xs text-gray-400">En az 10 karakter</p>
          </div>

          {/* Visit Date */}
          <div>
            <label class="block font-medium text-gray-900 mb-2">
              Ziyaret Tarihi <span class="text-gray-400 text-sm font-normal">(İsteğe bağlı)</span>
            </label>
            <input
              type="date"
              name="visit_date"
              max={new Date().toISOString().split('T')[0]}
              class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent"
            />
          </div>

          {/* Submit Buttons */}
          <div class="flex flex-col sm:flex-row gap-4 pt-4">
            <button
              type="submit"
              class="flex-1 px-6 py-4 bg-red-600 text-white font-medium rounded-xl hover:bg-red-700 transition-colors disabled:bg-gray-300 disabled:cursor-not-allowed"
              id="submit-btn"
              disabled
            >
              Değerlendirmeyi Gönder
            </button>
            <a
              href={`/places/${slug}`}
              class="px-6 py-4 bg-gray-100 text-gray-700 font-medium rounded-xl hover:bg-gray-200 transition-colors text-center"
            >
              İptal
            </a>
          </div>

          <p class="text-sm text-gray-500 text-center">
            Değerlendirmeniz onaylandıktan sonra yayınlanacaktır.
          </p>
        </form>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Star rating interaction
  const starBtns = document.querySelectorAll('.star-btn');
  const ratingInput = document.getElementById('rating-input') as HTMLInputElement;
  const ratingText = document.getElementById('rating-text');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  const ratingLabels: Record<number, string> = {
    1: 'Berbat',
    2: 'Kötü',
    3: 'Orta',
    4: 'İyi',
    5: 'Harika',
  };

  starBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const rating = parseInt(btn.getAttribute('data-rating') || '0');
      ratingInput.value = rating.toString();
      
      // Update stars
      starBtns.forEach((star, index) => {
        if (index < rating) {
          star.classList.remove('text-gray-300');
          star.classList.add('text-yellow-400');
        } else {
          star.classList.remove('text-yellow-400');
          star.classList.add('text-gray-300');
        }
      });

      // Update text
      if (ratingText) {
        ratingText.textContent = `${rating} yıldız - ${ratingLabels[rating]}`;
        ratingText.classList.remove('text-gray-500');
        ratingText.classList.add('text-gray-900', 'font-medium');
      }

      // Enable submit
      if (submitBtn) {
        submitBtn.disabled = false;
      }
    });

    // Hover effect
    btn.addEventListener('mouseenter', () => {
      const rating = parseInt(btn.getAttribute('data-rating') || '0');
      starBtns.forEach((star, index) => {
        if (index < rating) {
          star.classList.add('text-yellow-200');
        }
      });
    });

    btn.addEventListener('mouseleave', () => {
      starBtns.forEach((star) => {
        star.classList.remove('text-yellow-200');
      });
    });
  });
</script>
