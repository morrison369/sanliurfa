---
import Layout from "../../layouts/Layout.astro";
import LoyaltyDashboard from "../../components/LoyaltyDashboard";
import AuthFeatureLanding from "../../components/AuthFeatureLanding.astro";

const user = Astro.locals.user;

const seo = {
  title: "Sadakat Programı",
  description: "Puan kazanın ve özel ödüller açın",
  noindex: true,
};
---

<Layout seo={seo}>
  {
    !user ? (
      <AuthFeatureLanding
        eyebrow="Kullanıcı sadakati"
        title="Şanlıurfa topluluğunda katkınız puan kazandırsın"
        description="Mekân yorumu, fotoğraf, favori, etkinlik ve sosyal etkileşimler sadakat sistemine bağlanır. Hesap oluşturduğunuzda puan ve ödül akışınızı takip edebilirsiniz."
        loginRedirect="/kullanici/sadakat"
        features={[
          {
            title: "Puan kazanma",
            description:
              "Yorum, fotoğraf, favori ve etkinlik katılımı gibi katkılar puan üretir.",
          },
          {
            title: "Ödül kullanımı",
            description:
              "Puanlarınızı ödül kataloğunda yerel avantajlara dönüştürebilirsiniz.",
          },
          {
            title: "Seviye avantajları",
            description:
              "Bronz, gümüş, altın ve platin seviyeler profil görünürlüğünüzü artırır.",
          },
        ]}
      />
    ) : (
      <div class="bg-gray-50 dark:bg-gray-900 min-h-screen pt-20 pb-12">
        <div class="max-w-4xl mx-auto px-4">
          <LoyaltyDashboard client:load />

          <div class="mt-12 grid md:grid-cols-3 gap-6">
            <div class="bg-urfa-50 dark:bg-urfa-900/20 border border-urfa-200 dark:border-urfa-800 rounded-lg p-6">
              <h3 class="font-semibold text-urfa-900 dark:text-urfa-100 mb-2">
                Nasıl puan kazanabilirsiniz?
              </h3>
              <ul class="text-sm text-urfa-800 dark:text-urfa-200 space-y-2">
                <li>• Yorum yazın</li>
                <li>• Fotoğraf ekleyin</li>
                <li>• Favori ve koleksiyon oluşturun</li>
                <li>• Etkinliklere katılın</li>
              </ul>
            </div>
            <div class="bg-isot-50 dark:bg-isot-900/20 border border-isot-200 dark:border-isot-800 rounded-lg p-6">
              <h3 class="font-semibold text-isot-900 dark:text-isot-100 mb-2">
                Ödülleri nasıl kullanabilirsiniz?
              </h3>
              <ul class="text-sm text-isot-800 dark:text-isot-200 space-y-2">
                <li>• Yerel kampanya fırsatları</li>
                <li>• Özel rozetler</li>
                <li>• Topluluk avantajları</li>
                <li>• Erken etkinlik erişimi</li>
              </ul>
            </div>
            <div class="bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-6">
              <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">
                Seviye avantajları
              </h3>
              <ul class="text-sm text-gray-700 dark:text-gray-300 space-y-2">
                <li>• Bonus puan kazanımı</li>
                <li>• Özel ödüller</li>
                <li>• Erken erişim</li>
                <li>• Öne çıkan profil görünürlüğü</li>
              </ul>
            </div>
          </div>

          <div class="mt-12 bg-white dark:bg-gray-800 rounded-lg shadow p-8">
            <h2 class="text-2xl font-bold mb-6">Sık sorulan sorular</h2>
            <div class="space-y-6">
              <div>
                <h3 class="font-semibold mb-2">
                  Puanlarım ne zaman sona erer?
                </h3>
                <p class="text-gray-600 dark:text-gray-400">
                  Puan geçerlilik süresi yönetim ayarlarına göre belirlenir.
                  Süreli puanlarda son kullanım tarihi işlem geçmişinde
                  gösterilir.
                </p>
              </div>
              <div>
                <h3 class="font-semibold mb-2">
                  Puanlarımı nasıl kullanabilirim?
                </h3>
                <p class="text-gray-600 dark:text-gray-400">
                  Ödüller sayfasına giderek puanlarınızı yerel kampanya, rozet
                  ve topluluk avantajlarına dönüştürebilirsiniz.
                </p>
              </div>
              <div>
                <h3 class="font-semibold mb-2">
                  Seviyemi nasıl yükseltebilirim?
                </h3>
                <p class="text-gray-600 dark:text-gray-400">
                  Şanlıurfa rehberine katkı yaptıkça puan kazanır ve belirli
                  eşikleri geçince bir sonraki seviyeye yükselirsiniz.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    )
  }
</Layout>
