---
import Layout from '../../layouts/Layout.astro';
import LoyaltyDashboard from '../../components/LoyaltyDashboard';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/giris?redirect=/kullanici/sadakat');
}

const seo = {
  title: 'Sadakat Programı',
  description: 'Puan kazanın ve özel ödüller açın',
  noIndex: true
};
---

<Layout seo={seo}>
  <div class="min-h-screen bg-[#FDFAF3]">
    <div class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)] text-white py-10">
      <div class="container mx-auto px-4">
        <p class="text-sm font-semibold uppercase tracking-widest text-[#9A8470] mb-2">HESABIM</p>
        <h1 class="text-3xl font-bold text-[#F5EDD6]">Sadakat Programı</h1>
        <p class="text-[#9A8470] mt-1">Puan kazanın ve özel ödüller açın</p>
      </div>
    </div>

    <div class="max-w-4xl mx-auto px-4 py-8">
      <LoyaltyDashboard client:visible={{ rootMargin: '140px' }} />

      {/* Info Section */}
      <div class="mt-12 grid md:grid-cols-3 gap-6">
        <div class="bg-[rgba(200,160,100,0.06)] border border-[rgba(200,160,100,0.2)] rounded-sm p-6">
          <h3 class="font-semibold text-[#1A1008] mb-2">Nasıl Kazanabilirsiniz?</h3>
          <ul class="text-sm text-[#6B5540] space-y-2">
            <li>Yorum yazın: 10 puan</li>
            <li>Fotoğraf ekleyin: 5 puan</li>
            <li>Favori ekleyin: 2 puan</li>
            <li>Etkinliğe katılın: 15 puan</li>
          </ul>
        </div>
        <div class="bg-[rgba(200,160,100,0.06)] border border-[rgba(200,160,100,0.2)] rounded-sm p-6">
          <h3 class="font-semibold text-[#1A1008] mb-2">Ödülleri Nasıl Kullanabilirsiniz?</h3>
          <ul class="text-sm text-[#6B5540] space-y-2">
            <li>İndirim kuponları</li>
            <li>Özel rozetler</li>
            <li>Premium özellikler</li>
            <li>Hediye kartları</li>
          </ul>
        </div>
        <div class="bg-[rgba(200,160,100,0.06)] border border-[rgba(200,160,100,0.2)] rounded-sm p-6">
          <h3 class="font-semibold text-[#1A1008] mb-2">Seviye Avantajları</h3>
          <ul class="text-sm text-[#6B5540] space-y-2">
            <li>Bonus puan kazancı</li>
            <li>Özel ödüller</li>
            <li>Erken erişim</li>
            <li>VIP desteği</li>
          </ul>
        </div>
      </div>

      {/* FAQ Section */}
      <div class="mt-12 bg-white rounded-sm shadow-sm border border-[rgba(200,160,100,0.18)] p-8">
        <h2 class="text-2xl font-bold text-[#1A1008] mb-6">Sıkça Sorulan Sorular</h2>
        <div class="space-y-6">
          <div>
            <h3 class="font-semibold text-[#1A1008] mb-2">Puanlarım ne zaman sona erer?</h3>
            <p class="text-[#6B5540]">
              Puanlarınız asla sona ermez! Kazandığınız tüm puanlar hesabınızda saklanır.
            </p>
          </div>
          <div>
            <h3 class="font-semibold text-[#1A1008] mb-2">Puanlarımı nasıl kullanabilirim?</h3>
            <p class="text-[#6B5540]">
              Ödüller sayfasına giderek puanlarınızı harika ödüllere dönüştürebilirsiniz. İndirim kuponlarından premium özelliklere kadar birçok seçeneğiniz vardır.
            </p>
          </div>
          <div>
            <h3 class="font-semibold text-[#1A1008] mb-2">Seviyemi nasıl yükseltebilirim?</h3>
            <p class="text-[#6B5540]">
              Yalnızca puan kazanın! Belirli bir puan eşiğine ulaştığınızda otomatik olarak bir sonraki seviyeye yükseleceksiniz.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
