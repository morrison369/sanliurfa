---
import Layout from '../layouts/Layout.astro';
import { queryMany } from '../lib/postgres';
import { getSiteBranding } from '../lib/site-branding';
const { baseUrl } = await getSiteBranding();

interface RecommendedPlace {
  id: string;
  slug: string;
  name: string;
  category: string;
  short_description: string | null;
  cover_image: string | null;
  rating: number;
  rating_count: number;
  view_count: number;
}

// Check if user is authenticated
const token = Astro.cookies.get('token')?.value;
let recommendations: RecommendedPlace[] = [];
let isPersonalized = false;

try {
  recommendations = await queryMany<RecommendedPlace>(
    `SELECT
       p.id::text,
       p.slug,
       p.name,
       COALESCE(c.name, p.category, 'Mekan') as category,
       COALESCE(p.short_description, p.description) as short_description,
       COALESCE(p.thumbnail_url, p.images[1]) as cover_image,
       COALESCE(p.rating, 0)::float as rating,
       COALESCE(p.rating_count, p.review_count, 0)::int as rating_count,
       COALESCE(p.view_count, 0)::int as view_count
     FROM places p
     LEFT JOIN categories c ON c.id = p.category_id
     WHERE p.status = 'active'
     ORDER BY COALESCE(p.review_count, 0) DESC, COALESCE(p.rating, 0) DESC, p.created_at DESC
     LIMIT 12`
  );
} catch (e) {
  console.error('Öneriler sayfası query hatası:', e);
}
isPersonalized = Boolean(token);

const seo = {
  title: isPersonalized ? 'Sana Özel Öneriler - Sanliurfa.com' : 'Popüler Mekan Önerileri - Sanliurfa.com',
  description: "Şanlıurfa mekanları arasından popüler ve yüksek puanlı önerileri keşfedin.",
  keywords: ['şanlıurfa mekan önerileri', 'popüler mekanlar', 'kişiselleştirilmiş öneriler', 'şanlıurfa gezilecek yerler'],
  ogImage: '/images/hero/hero-home.webp',
  canonical: '/oneriler',
};

const faqItems = [
  { S: "Öneriler nasıl belirleniyor?", C: "Öneriler, kullanıcı puanları, yorum sayısı ve görüntülenme verisi baz alınarak akıllı sıralama algoritması tarafından belirlenir." },
  { S: "Kişiselleştirilmiş öneriler nasıl alabilirim?", C: "Hesabınıza giriş yaparak ilgi alanlarınıza göre kişiselleştirilmiş mekan önerileri alabilirsiniz." },
  { S: "Önerilen mekanlar ne sıklıkla güncelleniyor?", C: "Öneriler her gün kullanıcı aktivitelerine göre otomatik güncellenir." },
];
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-12 px-4">
    <div class="container max-w-6xl mx-auto">
      <!-- Header -->
      <div class="mb-12">
        <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-4">
          {isPersonalized ? 'Sana Özel Öneriler' : 'En Popüler Yerler'}
        </h1>
        <p class="text-lg text-gray-600 dark:text-gray-300">
          {isPersonalized
            ? 'Sana uygun, senin beğendiğin yerlere benzer mekanları keşfet.'
            : 'Şanlıurfa\'da en çok ziyaret edilen ve beğenilen yerleri gözden geçir.'}
        </p>
      </div>

      <!-- Recommendations Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {recommendations.length === 0 ? (
          <div class="col-span-full text-center py-12">
            <p class="text-gray-500 dark:text-gray-400 text-lg">
              Henüz yeterli veri yok. Lütfen daha sonra tekrar kontrol et.
            </p>
          </div>
        ) : (
          recommendations.map((place) => (
            <a
              href={`/isletme/${place.slug}`}
              class="group bg-white dark:bg-gray-800 rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow"
            >
              <!-- Image -->
              {place.cover_image ? (
                <div class="relative w-full h-48 overflow-hidden bg-gray-200">
                  <img
                    src={place.cover_image}
                    alt={place.name}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  />
                </div>
              ) : (
                <div class="w-full h-48 bg-gradient-to-br from-orange-200 to-red-200 flex items-center justify-center">
                  <span class="text-5xl" aria-hidden="true">📍</span>
                </div>
              )}

              <!-- Content -->
              <div class="p-4">
                <!-- Category Badge -->
                <span class="inline-block px-3 py-1 text-xs font-medium text-orange-700 bg-orange-100 dark:bg-orange-900 dark:text-orange-200 rounded-full mb-3">
                  {place.category}
                </span>

                <!-- Title -->
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2 line-clamp-2">
                  {place.name}
                </h3>

                <!-- Description -->
                {place.short_description && (
                  <p class="text-sm text-gray-600 dark:text-gray-400 mb-4 line-clamp-2">
                    {place.short_description}
                  </p>
                )}

                <!-- Rating -->
                {place.rating && (
                  <div class="flex items-center gap-2 mb-4">
                    <div class="flex items-center">
                      {[...Array(5)].map((_, i) => (
                        <span class={i < Math.floor(place.rating) ? 'text-yellow-400' : 'text-gray-300'}>
                          ★
                        </span>
                      ))}
                    </div>
                    <span class="text-sm text-gray-600 dark:text-gray-400">
                      {place.rating.toFixed(1)} ({place.rating_count || 0})
                    </span>
                  </div>
                )}

                <!-- View Count (if available) -->
                {place.view_count && (
                  <div class="text-xs text-gray-500 dark:text-gray-400">
                    {place.view_count.toLocaleString('tr-TR')} görüntüleme
                  </div>
                )}
              </div>

              <!-- Hover Overlay -->
              <div class="hidden group-hover:block absolute inset-0 bg-black bg-opacity-50 flex items-center justify-center transition-all">
                <button class="px-6 py-2 bg-orange-500 text-white font-medium rounded-lg hover:bg-orange-600">
                  Detayları Gör →
                </button>
              </div>
            </a>
          ))
        )}
      </div>

      <!-- Call to Action -->
      {!isPersonalized && (
        <div class="mt-16 bg-gradient-to-r from-orange-500 to-red-500 rounded-lg shadow-lg p-8 text-center">
          <h2 class="text-2xl font-bold text-white mb-4">Kişiselleştirilmiş Öneriler Al</h2>
          <p class="text-orange-50 mb-6">
            Giriş yap ve senin ilgi alanlarına göre özel öneriler al.
          </p>
          <a
            href="/giris"
            class="inline-block px-8 py-3 bg-white text-orange-600 font-bold rounded-lg hover:bg-gray-100 transition-colors"
          >
            Giriş Yap
          </a>
        </div>
      )}
    </div>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: { '@type': 'Answer', text: item.C },
    })),
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Öneriler', item: `${baseUrl}/oneriler` },
    ],
  })} is:inline />
</Layout>


