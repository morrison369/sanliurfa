---
import Layout from "../layouts/Layout.astro";
import { getTrendingPlaces } from "../lib/recommendations";
import { getCuratedPlaces } from "../data/curated-places";

const token = Astro.cookies.get("auth-token")?.value;
let recommendations = [];
let isPersonalized = false;

try {
  recommendations = await getTrendingPlaces(12);
} catch {
  recommendations = [];
}

if (!recommendations.length) {
  recommendations = getCuratedPlaces(12).map((place) => ({
    slug: place.slug,
    name: place.name,
    category: place.category,
    short_description: place.description,
    cover_image: place.images[0],
    rating: place.rating,
    rating_count: place.review_count,
    view_count: place.review_count * 24,
  }));
}

isPersonalized = Boolean(token);
---

<Layout
  title="Şanlıurfa Önerileri - sanliurfa.com"
  description="Şanlıurfa gezilecek yerler, tarihi duraklar, gastronomi rotaları ve yerel keşif önerileri."
>
  <div class="min-h-screen bg-stone-50 py-12 px-4 dark:bg-gray-950">
    <div class="container max-w-6xl mx-auto">
      <div
        class="mb-12 rounded-3xl bg-gradient-to-br from-urfa-900 via-urfa-800 to-isot-800 p-8 text-white shadow-xl"
      >
        <p
          class="mb-3 text-sm font-semibold uppercase tracking-[0.28em] text-amber-200"
        >
          Şanlıurfa keşif önerileri
        </p>
        <h1 class="text-4xl font-bold mb-4">
          {
            isPersonalized
              ? "Sana özel Şanlıurfa önerileri"
              : "Şanlıurfa için en güçlü keşif rotaları"
          }
        </h1>
        <p class="max-w-3xl text-lg text-amber-50">
          {
            isPersonalized
              ? "Gezdiğin ve kaydettiğin yerlere göre Şanlıurfa tarih, yemek, çarşı ve sosyal yaşam önerilerini keşfet."
              : "Göbeklitepe, Balıklıgöl, Harran, isot ve yöresel lezzet rotalarıyla Şanlıurfa deneyimini planla."
          }
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          recommendations.length === 0 ? (
            <div class="col-span-full rounded-2xl border border-amber-200 bg-white p-8 text-center shadow-sm dark:border-amber-900 dark:bg-gray-900">
              <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
                Öneriler hazırlanıyor
              </h2>
              <p class="mt-3 text-gray-600 dark:text-gray-400">
                Şanlıurfa keşif verisi güncelleniyor. Bu sırada mekanlar ve
                tarihi yerler sayfalarından rotaları inceleyebilirsiniz.
              </p>
              <div class="mt-6 flex flex-wrap justify-center gap-3">
                <a
                  href="/places"
                  class="rounded-full bg-urfa-700 px-5 py-2.5 font-semibold text-white hover:bg-urfa-800"
                >
                  Mekanları incele
                </a>
                <a
                  href="/tarihi-yerler"
                  class="rounded-full border border-urfa-200 px-5 py-2.5 font-semibold text-urfa-800 hover:bg-urfa-50"
                >
                  Tarihi yerler
                </a>
              </div>
            </div>
          ) : (
            recommendations.map((place: any) => (
              <a
                href={`/places/${place.slug}`}
                class="group relative overflow-hidden rounded-2xl border border-stone-200 bg-white shadow-sm transition-all hover:-translate-y-1 hover:shadow-xl dark:border-gray-800 dark:bg-gray-900"
              >
                {place.cover_image ? (
                  <div class="relative w-full h-48 overflow-hidden bg-gray-200">
                    <img
                      src={place.cover_image}
                      alt={place.name}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    />
                  </div>
                ) : (
                  <div class="flex h-48 w-full items-center justify-center bg-gradient-to-br from-amber-100 to-urfa-100">
                    <span class="text-sm font-bold uppercase tracking-[0.22em] text-urfa-800">
                      Şanlıurfa
                    </span>
                  </div>
                )}

                <div class="p-5">
                  <span class="mb-3 inline-block rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-urfa-800 dark:bg-amber-900/30 dark:text-amber-200">
                    {place.category}
                  </span>

                  <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2 line-clamp-2">
                    {place.name}
                  </h3>

                  {place.short_description && (
                    <p class="text-sm text-gray-600 dark:text-gray-400 mb-4 line-clamp-2">
                      {place.short_description}
                    </p>
                  )}

                  {place.rating && (
                    <div class="flex items-center gap-2 mb-4">
                      <span class="rounded-full bg-urfa-700 px-2.5 py-1 text-sm font-bold text-white">
                        {place.rating.toFixed(1)}
                      </span>
                      <span class="text-sm text-gray-600 dark:text-gray-400">
                        {place.rating_count || 0} değerlendirme
                      </span>
                    </div>
                  )}

                  {place.view_count && (
                    <div class="text-xs text-gray-500 dark:text-gray-400">
                      {place.view_count.toLocaleString()} görüntülenme
                    </div>
                  )}
                </div>
              </a>
            ))
          )
        }
      </div>

      {
        !isPersonalized && (
          <div class="mt-16 rounded-3xl bg-gradient-to-r from-urfa-800 to-isot-800 p-8 text-center shadow-lg">
            <h2 class="text-2xl font-bold text-white mb-4">
              Kişiselleştirilmiş önerileri aç
            </h2>
            <p class="text-amber-50 mb-6">
              Giriş yaparak favorilerin, yorumların ve ilgi alanlarına göre daha
              isabetli Şanlıurfa önerileri alabilirsin.
            </p>
            <a
              href="/giris"
              class="inline-block rounded-full bg-white px-8 py-3 font-bold text-urfa-800 transition-colors hover:bg-amber-50"
            >
              Giriş yap
            </a>
          </div>
        )
      }
    </div>
  </div>
</Layout>
