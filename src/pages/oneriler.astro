---
import Layout from '../layouts/Layout.astro';
import { queryMany } from '../lib/postgres';
import { getSiteBranding } from '../lib/site-branding';
import { logger } from '../lib/logging';
const { baseUrl } = await getSiteBranding();

interface RecommendedPlace {
  id: string;
  slug: string;
  name: string;
  category: string;
  short_description: string | null;
  cover_image: string | null;
  rating: number;
  rating_count: number;
  view_count: number;
}

// Check if user is authenticated
const token = Astro.cookies.get('token')?.value;
let recommendations: RecommendedPlace[] = [];
let isPersonalized = false;

try {
  recommendations = await queryMany<RecommendedPlace>(
    `SELECT
       p.id::text,
       p.slug,
       p.name,
       COALESCE(c.name, p.category, 'Mekan') as category,
       COALESCE(p.short_description, p.description) as short_description,
       COALESCE(p.thumbnail_url, p.images[1]) as cover_image,
       COALESCE(p.rating, 0)::float as rating,
       COALESCE(p.rating_count, p.review_count, 0)::int as rating_count,
       COALESCE(p.view_count, 0)::int as view_count
     FROM places p
     LEFT JOIN categories c ON c.id = p.category_id
     WHERE p.status = 'active'
     ORDER BY COALESCE(p.review_count, 0) DESC, COALESCE(p.rating, 0) DESC, p.created_at DESC
     LIMIT 12`
  );
} catch (e) {
  logger.error('Öneriler sayfası query hatası:', e instanceof Error ? e : new Error(String(e)));
}
isPersonalized = Boolean(token);

const seo = {
  title: isPersonalized ? 'Sana Özel Öneriler - Sanliurfa.com' : 'Popüler Mekan Önerileri - Sanliurfa.com',
  description: "Şanlıurfa mekanları arasından popüler ve yüksek puanlı önerileri keşfedin.",
  keywords: ['şanlıurfa mekan önerileri', 'popüler mekanlar', 'kişiselleştirilmiş öneriler', 'şanlıurfa gezilecek yerler'],
  ogImage: '/images/hero/hero-home.webp',
  canonical: '/oneriler',
};

const faqItems = [
  { S: "Öneriler nasıl belirleniyor?", C: "Öneriler, kullanıcı puanları, yorum sayısı ve görüntülenme verisi baz alınarak akıllı sıralama algoritması tarafından belirlenir." },
  { S: "Kişiselleştirilmiş öneriler nasıl alabilirim?", C: "Hesabınıza giriş yaparak ilgi alanlarınıza göre kişiselleştirilmiş mekan önerileri alabilirsiniz." },
  { S: "Önerilen mekanlar ne sıklıkla güncelleniyor?", C: "Öneriler her gün kullanıcı aktivitelerine göre otomatik güncellenir." },
];
---

<Layout seo={seo}>
  <div class="min-h-screen bg-[#FDFAF3]">
    <div class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)] text-white py-12">
      <div class="container max-w-6xl mx-auto px-4">
        <p class="text-sm font-semibold uppercase tracking-widest text-[#9A8470] mb-2">Şanlıurfa Mekan Rehberi</p>
        <h1 class="text-4xl font-bold text-[#F5EDD6] mb-2">
          {isPersonalized ? 'Sana Özel Öneriler' : 'En Popüler Yerler'}
        </h1>
        <p class="text-[#C4B49A]">
          {isPersonalized
            ? 'Sana uygun, senin beğendiğin yerlere benzer mekanları keşfet.'
            : 'Şanlıurfa\'da en çok ziyaret edilen ve beğenilen yerleri gözden geçir.'}
        </p>
      </div>
    </div>

    <div class="container max-w-6xl mx-auto px-4 py-12">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {recommendations.length === 0 ? (
          <div class="col-span-full text-center py-12">
            <p class="text-[#9A8470] text-lg">
              Henüz yeterli veri yok. Lütfen daha sonra tekrar kontrol et.
            </p>
          </div>
        ) : (
          recommendations.map((place) => (
            <a
              href={`/isletme/${place.slug}`}
              class="group bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm overflow-hidden hover:shadow-md hover:border-urfa-300 transition-all hover:-translate-y-0.5"
            >
              {place.cover_image ? (
                <div class="relative w-full h-48 overflow-hidden bg-[rgba(200,160,100,0.06)]">
                  <img
                    src={place.cover_image}
                    alt={place.name}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  />
                </div>
              ) : (
                <div class="w-full h-48 bg-[rgba(200,160,100,0.08)] flex items-center justify-center">
                  <span class="text-5xl" aria-hidden="true">📍</span>
                </div>
              )}

              <div class="p-4">
                <span class="inline-block px-3 py-1 text-xs font-medium text-urfa-700 bg-[rgba(200,160,100,0.08)] rounded-sm mb-3">
                  {place.category}
                </span>

                <h3 class="text-lg font-semibold text-[#1A1008] mb-2 line-clamp-2 group-hover:text-urfa-700 transition-colors">
                  {place.name}
                </h3>

                {place.short_description && (
                  <p class="text-sm text-[#6B5540] mb-4 line-clamp-2">
                    {place.short_description}
                  </p>
                )}

                {place.rating && (
                  <div class="flex items-center gap-2 mb-4">
                    <div class="flex items-center">
                      {[...Array(5)].map((_, i) => (
                        <span class={i < Math.floor(place.rating) ? 'text-urfa-500' : 'text-[#9A8470]'}>
                          ★
                        </span>
                      ))}
                    </div>
                    <span class="text-sm text-[#9A8470]">
                      {place.rating.toFixed(1)} ({place.rating_count || 0})
                    </span>
                  </div>
                )}

                {place.view_count && (
                  <div class="text-xs text-[#9A8470]">
                    {place.view_count.toLocaleString('tr-TR')} görüntüleme
                  </div>
                )}
              </div>
            </a>
          ))
        )}
      </div>

      {!isPersonalized && (
        <div class="mt-16 bg-[#0D0A08] border border-[rgba(200,160,100,0.2)] rounded-sm p-8 text-center">
          <h2 class="text-2xl font-bold text-[#F5EDD6] mb-4">Kişiselleştirilmiş Öneriler Al</h2>
          <p class="text-[#C4B49A] mb-6">
            Giriş yap ve senin ilgi alanlarına göre özel öneriler al.
          </p>
          <a
            href="/giris"
            class="inline-block px-8 py-3 bg-urfa-600 text-white font-bold rounded-sm hover:bg-urfa-700 transition-colors"
          >
            Giriş Yap
          </a>
        </div>
      )}
    </div>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: { '@type': 'Answer', text: item.C },
    })),
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Öneriler', item: `${baseUrl}/oneriler` },
    ],
  })} is:inline />
</Layout>
