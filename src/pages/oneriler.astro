---
import Layout from '../layouts/Layout.astro';
import Image from '../components/Image.astro';
import PublicPageIntro from '../components/public/PublicPageIntro.astro';
import { queryMany } from '../lib/postgres';
import { getPublicAppUrl } from '../lib/public-app-url';
import { logger } from '../lib/logging';
import { resolvePlaceImage } from '../lib/public-image-resolvers';
const baseUrl = getPublicAppUrl();

interface RecommendedPlace {
 id: string;
 slug: string;
 name: string;
 category: string;
 short_description: string | null;
 cover_image: string | null;
 rating: number;
 rating_count: number;
 view_count: number;
}

const token = Astro.cookies.get('token')?.value;
let recommendations: RecommendedPlace[] = [];
let isPersonalized = false;

try {
 recommendations = await queryMany<RecommendedPlace>(
 `SELECT
 p.id::text,
 p.slug,
 p.name,
 COALESCE(c.name, p.category, 'Mekan') as category,
 COALESCE(p.short_description, p.description) as short_description,
 COALESCE(p.thumbnail_url, p.images[1]) as cover_image,
 COALESCE(p.rating, 0)::float as rating,
 COALESCE(p.rating_count, p.review_count, 0)::int as rating_count,
 COALESCE(p.view_count, 0)::int as view_count
 FROM places p
 LEFT JOIN categories c ON c.id = p.category_id
 WHERE p.status = 'active'
 ORDER BY COALESCE(p.review_count, 0) DESC, COALESCE(p.rating, 0) DESC, p.created_at DESC
 LIMIT 12`
 );
} catch (e) {
 logger.error('Öneriler sayfası query hatası:', e instanceof Error ? e : new Error(String(e)));
}
isPersonalized = Boolean(token);

const seo = {
 title: isPersonalized ? 'Sana Özel Öneriler - Sanliurfa.com' : 'Popüler Mekan Önerileri - Sanliurfa.com',
 description: "Şanlıurfa mekanları arasından popüler ve yüksek puanlı önerileri keşfedin.",
 keywords: ['şanlıurfa mekan önerileri', 'popüler mekanlar', 'kişiselleştirilmiş öneriler', 'şanlıurfa gezilecek yerler'],
 ogImage: '/images/places/balikligol.jpg',
 canonical: '/oneriler',
};

const faqItems = [
 { S: "Öneriler nasıl belirleniyor?", C: "Öneriler, kullanıcı puanları, yorum sayısı ve görüntülenme verisi baz alınarak akıllı sıralama algoritması tarafından belirlenir." },
 { S: "Kişiselleştirilmiş öneriler nasıl alabilirim?", C: "Hesabınıza giriş yaparak ilgi alanlarınıza göre kişiselleştirilmiş mekan önerileri alabilirsiniz." },
 { S: "Önerilen mekanlar ne sıklıkla güncelleniyor?", C: "Öneriler her gün kullanıcı aktivitelerine göre otomatik güncellenir." },
];
const resolveRecommendationImage = (place: RecommendedPlace) =>
 resolvePlaceImage({
  slug: place.slug,
  cover_image: place.cover_image,
 });
---

<Layout seo={seo}>
 <style>
 .on-page{background:var(--public-bg);min-height:100vh}
 .on-body{padding:3rem 0 5rem}
 .on-container{max-width:72rem;margin:0 auto}
 .on-grid{display:grid;gap:1.5rem;grid-template-columns:1fr}
 @media(min-width:48rem){.on-grid{grid-template-columns:repeat(2,1fr)}}
 @media(min-width:64rem){.on-grid{grid-template-columns:repeat(3,1fr)}}
 .on-card{display:block;border:1px solid var(--public-border);background:var(--public-surface);overflow:hidden;transition:border-color .15s,transform .15s;text-decoration:none}
 .on-card:hover{border-color:var(--public-accent);transform:translateY(-2px)}
 .on-img-wrap{position:relative;width:100%;height:12rem;overflow:hidden;background:var(--public-accent-soft)}
 .on-img{width:100%;height:100%;object-fit:cover;transition:transform .3s}
 .on-card:hover .on-img{transform:scale(1.05)}
 .on-card-body{padding:1rem}
 .on-badge{display:inline-block;padding:.2rem .75rem;font-size:.72rem;font-weight:600;background:var(--public-accent-soft);color:var(--public-accent-strong);margin-bottom:.75rem;letter-spacing:.04em}
 .on-title{font-size:1rem;font-weight:700;color:var(--public-text);margin-bottom:.5rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
 .on-card:hover .on-title{color:var(--public-accent-strong)}
 .on-short-desc{font-size:.82rem;color:var(--public-muted);margin-bottom:.75rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
 .on-stars{display:flex;align-items:center;gap:.5rem;margin-bottom:.5rem}
 .on-star{color:var(--public-border)}
 .on-star-active{color:var(--public-accent)}
 .on-rating-val{font-size:.82rem;color:var(--public-muted)}
 .on-views{font-size:.75rem;color:var(--public-text-soft)}
 .on-empty{grid-column:1/-1;text-align:center;padding:3rem 0}
 .on-empty-text{color:var(--public-muted);font-size:1rem}
 .on-cta{margin-top:4rem;background:var(--public-surface);border:1px solid var(--public-border);padding:2.5rem;text-align:center}
 .on-cta-h2{font-family:'Cormorant Garamond',serif;font-size:1.75rem;font-weight:700;color:var(--public-text);margin-bottom:.75rem}
 .on-cta-desc{color:var(--public-text-soft);margin-bottom:1.5rem;font-size:.9rem}
 .on-cta-btn{display:inline-block;padding:.75rem 2rem;background:var(--public-accent);color:white;font-weight:700;font-size:.9rem;transition:background .15s;text-decoration:none}
 .on-cta-btn:hover{background:var(--public-accent-strong)}
 </style>

 <div class="on-page">
 <PublicPageIntro
 eyebrow="Şanlıurfa Mekan Rehberi"
 title={isPersonalized ? 'Sana Özel Öneriler' : 'En Popüler Yerler'}
 description={isPersonalized
  ? 'İlgi alanına yakın, senin beğendiğin yerlere benzeyen mekanları tek ekranda keşfet.'
  : "Şanlıurfa'da en çok ziyaret edilen, en çok puanlanan ve en çok konuşulan mekanları gözden geçir."}
 quickAnswerTitle="Hızlı cevap"
 quickAnswerText={isPersonalized
  ? 'Giriş yaptığında öneriler kullanıcı davranışı ve ilgi alanı sinyalleriyle daha kişisel hale gelir.'
  : 'Liste puan, yorum ve görüntülenme verisine göre günlük olarak yeniden sıralanır.'}
 actions={[
  { href: '/mekanlar', label: 'Tüm Mekanlar' },
  { href: '/gezilecek-yerler', label: 'Gezilecek Yerler' },
  { href: '/isletme', label: 'İşletmeler' },
  { href: '/giris', label: 'Giriş Yap' },
 ]}
 />

 <div class="on-body">
 <div class="sf-container on-container">
 <div class="on-grid">
 {recommendations.length === 0 ? (
 <div class="on-empty">
 <p class="on-empty-text">Henüz yeterli veri yok. Lütfen daha sonra tekrar kontrol et.</p>
 </div>
 ) : (
 recommendations.map((place) => (
 <a href={`/isletme/${place.slug}`} class="on-card">
 <div class="on-img-wrap">
 <Image src={resolveRecommendationImage(place)} alt={place.name} class="on-img" width={600} height={192} loading="lazy" />
 </div>
 <div class="on-card-body">
 <span class="on-badge">{place.category}</span>
 <h3 class="on-title">{place.name}</h3>
 {place.short_description && (
 <p class="on-short-desc">{place.short_description}</p>
 )}
 {place.rating ? (
 <div class="on-stars">
 <div>
 {[...Array(5)].map((_, i) => (
 <span class:list={['on-star', { 'on-star-active': i < Math.floor(place.rating) }]}>★</span>
 ))}
 </div>
 <span class="on-rating-val">{place.rating.toFixed(1)} ({place.rating_count || 0})</span>
 </div>
 ) : null}
 {place.view_count ? (
 <div class="on-views">{place.view_count.toLocaleString('tr-TR')} görüntüleme</div>
 ) : null}
 </div>
 </a>
 ))
 )}
 </div>

 {!isPersonalized && (
 <div class="on-cta">
 <h2 class="on-cta-h2">Kişiselleştirilmiş Öneriler Al</h2>
 <p class="on-cta-desc">Giriş yap ve senin ilgi alanlarına göre özel öneriler al.</p>
 <a href="/giris" class="on-cta-btn">Giriş Yap</a>
 </div>
 )}
 </div>
 </div>
 </div>

 <style is:inline>
 details summary{list-style:none}
 details summary::-webkit-details-marker{display:none}
 details[open] .faq-arrow{transform:rotate(180deg)}
 </style>
 {faqItems.length > 0 && (
 <div style="padding:2rem 0 3rem;border-top:1px solid rgba(184,115,51,.12)">
 <div class="sf-container">
 <h2 style="font-size:1.25rem;font-weight:700;color:#1F1410;margin-bottom:1.25rem">Sık Sorulan Sorular</h2>
 <div style="display:flex;flex-direction:column;gap:.75rem">
 {faqItems.map((item) => (
 <details style="background:var(--bg-card);border:1px solid rgba(184,115,51,.14);border-radius:.375rem;overflow:hidden">
 <summary style="padding:1rem 1.25rem;font-weight:600;color:#1F1410;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:1rem">
 {item.S}
 <span style="flex-shrink:0;color:#B87333;font-size:1.25rem;transition:transform .2s" class="faq-arrow">▾</span>
 </summary>
 <div style="padding:.75rem 1.25rem 1rem;color:#4A3828;font-size:.95rem;line-height:1.7;border-top:1px solid rgba(184,115,51,.08)">
 {item.C}
 </div>
 </details>
 ))}
 </div>
 </div>
 </div>
 )}
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqItems.map((item) => ({
 '@type': 'Question',
 name: item.S,
 acceptedAnswer: { '@type': 'Answer', text: item.C },
 })),
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'Öneriler', item: `${baseUrl}/oneriler` },
 ],
 })} is:inline />
</Layout>
