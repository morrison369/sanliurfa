---
import { Icon } from 'astro-icon/components';
import Layout from '../layouts/Layout.astro';
import { actions, isInputError } from 'astro:actions';

const seo = {
  title: 'Şifre Sıfırla - Sanliurfa.com',
  description: 'Sanliurfa.com hesabınız için yeni şifre belirleyin. E-posta ile aldığınız bağlantıyı kullanarak şifrenizi güncelleyin.',
  noIndex: true
};

const token = Astro.url.searchParams.get('token');
const error = Astro.url.searchParams.get('error');
const success = Astro.url.searchParams.get('success');
const result = Astro.getActionResult(actions.resetPassword);
const inputErrors = isInputError(result?.error) ? result.error.fields : {};
const submitError =
  !isInputError(result?.error) && result?.error?.message
    ? result.error.message
    : null;

if (!token && !error && !success && !(result && !result.error)) {
  return Astro.redirect('/sifremi-unuttum?error=invalid_token');
}
---

<Layout seo={seo} hideFooter>
  <div class="min-h-screen bg-[#0D0A08] flex items-center justify-center py-12 px-4">
    <div class="max-w-md w-full">
      <div class="text-center mb-8">
        <a href="/" style="display:inline-flex;align-items:baseline;gap:0.0625rem;text-decoration:none;">
          <span style="font-family:'Cormorant Garamond',Georgia,serif;font-size:2rem;font-weight:300;font-style:italic;color:#F5EDD6;letter-spacing:-0.02em;">Sanliurfa</span>
          <span style="font-family:'Jost',sans-serif;font-size:1rem;font-weight:700;color:#CE8E38;letter-spacing:0.06em;">.com</span>
        </a>
      </div>

      <div class="bg-[#FDFAF3] border border-[rgba(200,160,100,0.22)] rounded-sm shadow-2xl shadow-black/40 p-8">
        <div class="text-center mb-8">
          <div class="mx-auto h-16 w-16 bg-[rgba(200,160,100,0.1)] border border-[rgba(200,160,100,0.2)] rounded-sm flex items-center justify-center mb-4">
            <Icon name="lucide:lock" class="h-10 w-10 text-urfa-600" />
          </div>
          <h2 class="text-2xl font-bold text-[#1A1008]">
            Yeni Şifre Oluştur
          </h2>
          <p class="mt-2 text-sm text-[#9A8470]">
            Hesabınız için yeni bir şifre belirleyin.
          </p>
        </div>

        {success || (result && !result.error) ? (
          <div class="bg-green-50 border border-green-200 rounded-sm p-4">
            <div class="flex items-start gap-3">
              <Icon name="lucide:check-circle" class="w-5 h-5 text-green-500 shrink-0 mt-0.5" />
              <div>
                <p class="text-green-800 font-medium">
                  Şifreniz Güncellendi
                </p>
                <p class="text-green-700 text-sm mt-1">
                  {result?.data?.message || 'Yeni şifrenizle giriş yapabilirsiniz.'}
                </p>
              </div>
            </div>
            <div class="mt-4">
              <a href="/giris" class="w-full py-3 bg-urfa-600 text-white rounded-sm font-medium hover:bg-urfa-700 transition-colors tracking-wide text-center block">
                Giriş Yap
              </a>
            </div>
          </div>
        ) : (
          <form id="reset-password-form" action={actions.resetPassword} method="POST" class="space-y-6">
            <input type="hidden" name="token" value={token} />

            {(error || submitError) && (
              <div class="bg-isot-50 border border-isot-200 rounded-sm p-4">
                <div class="flex items-start gap-3">
                  <Icon name="lucide:alert-circle" class="w-5 h-5 text-isot-500 shrink-0 mt-0.5" />
                  <div>
                    <p class="text-isot-700 font-medium">
                      {error === 'invalid_token' ? 'Geçersiz veya Süresi Dolmuş Bağlantı' : 'Bir Hata Oluştu'}
                    </p>
                    <p class="text-isot-600 text-sm mt-1">
                      {submitError || (error === 'invalid_token'
                        ? 'Lütfen yeni bir şifre sıfırlama talebinde bulunun.'
                        : 'Lütfen tekrar deneyin.')}
                    </p>
                  </div>
                </div>
              </div>
            )}

            <div>
              <label for="password" class="block text-sm font-medium text-[#4A3828] mb-1">Yeni Şifre</label>
              <input
                id="password"
                name="password"
                type="password"
                autocomplete="new-password"
                required
                minlength="6"
                aria-invalid={inputErrors.password ? 'true' : 'false'}
                class="w-full px-4 py-3 border border-[rgba(200,160,100,0.3)] rounded-sm focus:ring-2 focus:ring-urfa-400 focus:border-transparent bg-white"
                placeholder="••••••••"
              />
              {inputErrors.password && (
                <p class="text-sm text-isot-500 mt-1">{inputErrors.password.join(', ')}</p>
              )}
              <p class="text-xs text-[#9A8470] mt-1">En az 6 karakter</p>
            </div>

            <div>
              <label for="confirm_password" class="block text-sm font-medium text-[#4A3828] mb-1">Şifre Tekrar</label>
              <input
                id="confirm_password"
                name="confirm_password"
                type="password"
                autocomplete="new-password"
                required
                aria-invalid={inputErrors.confirm_password ? 'true' : 'false'}
                class="w-full px-4 py-3 border border-[rgba(200,160,100,0.3)] rounded-sm focus:ring-2 focus:ring-urfa-400 focus:border-transparent bg-white"
                placeholder="••••••••"
              />
              <p id="password-error" class:list={['text-sm text-isot-500 mt-1', { hidden: !inputErrors.confirm_password }]}>
                {inputErrors.confirm_password ? inputErrors.confirm_password.join(', ') : 'Şifreler eşleşmiyor.'}
              </p>
            </div>

            <button type="submit" class="w-full py-3 bg-urfa-600 text-white rounded-sm font-medium tracking-wide hover:bg-urfa-700 transition-colors">
              Şifremi Güncelle
            </button>
          </form>
        )}
      </div>

      <p class="text-center text-sm text-[#6B5540] mt-8">
        <a href="/" class="hover:text-[#C4B49A]">← Ana Sayfaya Dön</a>
      </p>
    </div>
  </div>

  <script is:inline>
    const form = document.getElementById('reset-password-form');
    if (form) {
      form.addEventListener('submit', function (e) {
        const passwordEl = document.getElementById('password');
        const confirmEl = document.getElementById('confirm_password');
        const errorElement = document.getElementById('password-error');
        if (!passwordEl || !confirmEl || !errorElement) {
          return;
        }
        const password = passwordEl.value;
        const confirmPassword = confirmEl.value;
        if (password !== confirmPassword) {
          e.preventDefault();
          errorElement.classList.remove('hidden');
          return;
        }
        errorElement.classList.add('hidden');
      });
    }
  </script>
</Layout>
