---
import Layout from '../layouts/Layout.astro';

// SVG ikonlar
const icons = {
  lock: `<svg class="h-12 w-12 text-urfa-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`,
  checkCircle: `<svg class="w-5 h-5 text-green-500 mr-2 flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
  alertCircle: `<svg class="w-5 h-5 text-red-500 mr-2 flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
};

const seo = {
  title: 'Şifre Sıfırla - Şanlıurfa.com',
  description: 'Yeni şifre oluşturun',
  noindex: true
};

const token = Astro.url.searchParams.get('token');
const error = Astro.url.searchParams.get('token');
const success = Astro.url.searchParams.get('token');

// If no token, show error
if (!token && !error && !success) {
  return Astro.redirect('/sifremi-unuttum?error=invalid_token');
}
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50 dark:bg-gray-900 flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full">
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-8">
        <div class="text-center mb-8">
          <div class="mx-auto h-16 w-16 bg-urfa-100 dark:bg-urfa-900/30 rounded-2xl flex items-center justify-center mb-4">
            <span set:html={icons.lock}></span>
          </div>
          <h2 class="text-2xl font-display font-bold text-gray-900 dark:text-white">
            Yeni Şifre Oluştur
          </h2>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
            Hesabınız için yeni bir şifre belirleyin.
          </p>
        </div>
        
        {success ? (
          <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-xl p-4">
            <div class="flex items-start gap-3">
              <Check className="w-5 h-5 text-green-600 flex-shrink-0 mt-0.5" />
              <div>
                <p class="text-green-800 dark:text-green-300 font-medium">
                  Şifreniz Güncellendi
                </p>
                <p class="text-green-700 dark:text-green-400 text-sm mt-1">
                  Yeni şifrenizle giriş yapabilirsiniz.
                </p>
              </div>
            </div>
            <div class="mt-4">
              <a href="/giris" class="btn-primary w-full text-center block">
                Giriş Yap
              </a>
            </div>
          </div>
        ) : (
          <form action="/api/auth/reset-password" method="POST" class="space-y-6" onsubmit="return validatePasswords()">
            <input type="hidden" name="token" value={token} />
            
            {error && (
              <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl p-4">
                <div class="flex items-start gap-3">
                  <Alert className="w-5 h-5 text-red-600 flex-shrink-0 mt-0.5" />
                  <div>
                    <p class="text-red-800 dark:text-red-300 font-medium">
                      {error === 'invalid_token' ? 'Geçersiz veya Süresi Dolmuş Bağlantı' : 'Bir Hata Oluştu'}
                    </p>
                    <p class="text-red-700 dark:text-red-400 text-sm mt-1">
                      {error === 'invalid_token' 
                        ? 'Lütfen yeni bir şifre sıfırlama talebinde bulunun.' 
                        : 'Lütfen tekrar deneyin.'}
                    </p>
                  </div>
                </div>
              </div>
            )}
            
            <div>
              <label for="password" class="label dark:text-gray-300">Yeni Şifre</label>
              <input
                id="password"
                name="password"
                type="password"
                required
                minlength="6"
                class="input dark:bg-gray-700 dark:border-gray-600 dark:text-white"
                placeholder="••••••••"
              />
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">En az 6 karakter</p>
            </div>
            
            <div>
              <label for="confirm_password" class="label dark:text-gray-300">Şifre Tekrar</label>
              <input
                id="confirm_password"
                name="confirm_password"
                type="password"
                required
                class="input dark:bg-gray-700 dark:border-gray-600 dark:text-white"
                placeholder="••••••••"
              />
              <p id="password-error" class="text-sm text-red-500 mt-1 hidden">Şifreler eşleşmiyor.</p>
            </div>
            
            <button type="submit" class="btn-primary w-full flex justify-center">
              Şifremi Güncelle
            </button>
          </form>
        )}
      </div>
    </div>
  </div>
  
  <script is:inline>
    function validatePasswords() {
      const password = document.getElementById('password').value;
      const confirmPassword = document.getElementById('confirm_password').value;
      const errorElement = document.getElementById('password-error');
      
      if (password !== confirmPassword) {
        errorElement.classList.remove('hidden');
        return false;
      }
      
      errorElement.classList.add('hidden');
      return true;
    }
  </script>
</Layout>
