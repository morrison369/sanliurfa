---
import { Icon } from 'astro-icon/components';
import Layout from '../layouts/Layout.astro';
import { actions, isInputError } from 'astro:actions';

const seo = {
 title: 'Şifre Sıfırla — Sanliurfa.com',
 description: 'Sanliurfa.com hesabınız için yeni şifre belirleyin. E-posta ile aldığınız bağlantıyı kullanarak şifrenizi güncelleyin.',
 noIndex: true,
};

const token = Astro.url.searchParams.get('token');
const error = Astro.url.searchParams.get('error');
const success = Astro.url.searchParams.get('success');
const result = Astro.getActionResult(actions.resetPassword);
const inputErrors = isInputError(result?.error) ? result.error.fields : {};
const submitError =
 !isInputError(result?.error) && result?.error?.message
 ? result.error.message
 : null;

if (!token && !error && !success && !(result && !result.error)) {
 return Astro.redirect('/sifremi-unuttum?error=invalid_token');
}
---

<Layout seo={seo} hideFooter>
 <style is:inline>
 .auth-wrap{min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--bg);padding:1.5rem}
 .auth-box{width:100%;max-width:420px}
 .auth-logo{text-align:center;margin-bottom:2rem}
 .auth-logo-name{font-family:'Cormorant Garamond',Georgia,serif;font-size:2rem;font-weight:300;font-style:italic;color:var(--public-text);letter-spacing:-.02em}
 .auth-logo-tld{font-family:'Jost',sans-serif;font-size:1rem;font-weight:700;color:var(--public-accent);letter-spacing:.06em}
 .auth-card{background:var(--bg-card);border:1px solid var(--border);padding:2rem}
 .auth-icon-ring{width:4rem;height:4rem;border:1px solid rgba(184,115,51,.2);display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;background:rgba(184,115,51,.06)}
 .auth-card-title{font-family:'Cormorant Garamond',serif;font-size:1.35rem;font-weight:600;color:var(--public-text);text-align:center;margin-bottom:.35rem}
 .auth-card-sub{font-size:.8rem;color:var(--public-muted);text-align:center;margin-bottom:1.5rem;line-height:1.6}
 .auth-lbl{display:block;font-size:.75rem;font-weight:600;color:var(--public-accent);margin-bottom:.4rem;letter-spacing:.03em}
 .auth-input{width:100%;padding:.7rem 1rem;background:rgba(255,255,255,.03);border:1px solid rgba(184,115,51,.2);color:var(--public-text);border-radius:.125rem;font-size:.875rem;font-family:inherit;transition:border-color .15s}
 .auth-input:focus{outline:none;border-color:var(--public-accent)}
 .auth-input::placeholder{color:var(--public-text-soft)}
 .auth-hint{font-size:.72rem;color:var(--public-text-soft);margin-top:.3rem}
 .auth-field-err{font-size:.72rem;color:#E08090;margin-top:.3rem}
 .auth-field{margin-bottom:1rem}
 .auth-err{background:rgba(199,58,71,.1);border:1px solid rgba(199,58,71,.25);color:#E08090;padding:.75rem 1rem;border-radius:.125rem;font-size:.82rem;margin-bottom:1rem}
 .auth-err-title{font-weight:700;margin-bottom:.25rem}
 .auth-ok{background:rgba(23,184,166,.1);border:1px solid rgba(23,184,166,.25);color:#5ECFC6;padding:.75rem 1rem;border-radius:.125rem;font-size:.82rem;margin-bottom:1rem;line-height:1.6}
 .auth-ok-title{font-weight:700;margin-bottom:.25rem}
 .auth-ok-action{display:block;text-align:center;text-decoration:none;margin-top:.85rem;padding:.7rem;font-size:.875rem}
 .auth-submit{width:100%;padding:.75rem;margin-top:.5rem;font-size:.875rem}
 .auth-back{text-align:center;margin-top:1.25rem}
 .auth-back a{display:inline-flex;align-items:center;gap:.35rem;font-size:.8rem;color:var(--public-accent);transition:color .15s}
 .auth-back a:hover{color:var(--public-text)}
 .auth-footer{text-align:center;font-size:.78rem;color:var(--public-text-soft);margin-top:1.25rem}
 .auth-footer a{color:var(--public-muted);transition:color .15s}.auth-footer a:hover{color:var(--public-accent)}
 .hidden{display:none}
 </style>

 <div class="auth-wrap">
 <div class="auth-box">
 <div class="auth-logo">
 <a href="/" style="display:inline-flex;align-items:baseline;gap:.0625rem;text-decoration:none;">
 <span class="auth-logo-name">Sanliurfa</span>
 <span class="auth-logo-tld">.com</span>
 </a>
 </div>

 <div class="auth-card">
 <div class="auth-icon-ring">
 <Icon name="lucide:lock" style="color:var(--public-accent);width:1.75rem;height:1.75rem" />
 </div>
 <p class="auth-card-title">Yeni Şifre Oluştur</p>
 <p class="auth-card-sub">Hesabınız için güvenli bir şifre belirleyin.</p>

 {success || (result && !result.error) ? (
 <div class="auth-ok">
 <p class="auth-ok-title">Şifreniz Güncellendi</p>
 <p>{result?.data?.message || 'Yeni şifrenizle giriş yapabilirsiniz.'}</p>
 <a href="/giris" class="sf-btn-primary auth-ok-action">Giriş Yap</a>
 </div>
 ) : (
 <>
 {(error || submitError) && (
 <div class="auth-err">
 <p class="auth-err-title">
 {error === 'invalid_token' ? 'Geçersiz veya Süresi Dolmuş Bağlantı' : 'Bir Hata Oluştu'}
 </p>
 <p>
 {submitError || (error === 'invalid_token'
 ? 'Lütfen yeni bir şifre sıfırlama talebinde bulunun.'
 : 'Lütfen tekrar deneyin.')}
 </p>
 </div>
 )}
 <form id="reset-password-form" action={actions.resetPassword} method="POST">
 <input type="hidden" name="token" value={token} />
 <div class="auth-field">
 <label class="auth-lbl" for="password">Yeni Şifre</label>
 <input
 id="password"
 name="password"
 type="password"
 autocomplete="new-password"
 required
 minlength="6"
 aria-invalid={inputErrors.password ? 'true' : 'false'}
 class="auth-input"
 placeholder="••••••••"
 />
 {inputErrors.password && <p class="auth-field-err">{inputErrors.password.join(', ')}</p>}
 <p class="auth-hint">En az 6 karakter</p>
 </div>
 <div class="auth-field">
 <label class="auth-lbl" for="confirm_password">Şifre Tekrar</label>
 <input
 id="confirm_password"
 name="confirm_password"
 type="password"
 autocomplete="new-password"
 required
 aria-invalid={inputErrors.confirm_password ? 'true' : 'false'}
 class="auth-input"
 placeholder="••••••••"
 />
 <p id="password-error" class:list={['auth-field-err', { hidden: !inputErrors.confirm_password }]}>
 {inputErrors.confirm_password ? inputErrors.confirm_password.join(', ') : 'Şifreler eşleşmiyor.'}
 </p>
 </div>
 <button type="submit" class="sf-btn-primary auth-submit">Şifremi Güncelle</button>
 </form>
 </>
 )}

 <div class="auth-back">
 <a href="/sifremi-unuttum">
 <Icon name="lucide:arrow-left" style="width:.9rem;height:.9rem" />
 Şifremi Unuttum sayfasına dön
 </a>
 </div>
 </div>

 <p class="auth-footer"><a href="/">← Ana Sayfaya Dön</a></p>
 </div>
 </div>

 <script is:inline>
 const form = document.getElementById('reset-password-form');
 if (form) {
 form.addEventListener('submit', function (e) {
 const passwordEl = document.getElementById('password');
 const confirmEl = document.getElementById('confirm_password');
 const errorElement = document.getElementById('password-error');
 if (!passwordEl || !confirmEl || !errorElement) return;
 if (passwordEl.value !== confirmEl.value) {
 e.preventDefault();
 errorElement.classList.remove('hidden');
 return;
 }
 errorElement.classList.add('hidden');
 });
 }
 </script>
</Layout>
