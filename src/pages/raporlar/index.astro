---
import Layout from '../../layouts/Layout.astro';
import ReportManager from '../../components/ReportManager';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/giris?redirect=/raporlar');
}
---

<Layout seo={{ title: "Raporlar | Şanlıurfa", noIndex: true }}>
  <div class="min-h-screen bg-[#FDFAF3]">
    <div class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)] text-white py-10">
      <div class="container mx-auto px-4">
        <p class="text-sm font-semibold uppercase tracking-widest text-[#9A8470] mb-2">HESABIM</p>
        <h1 class="text-3xl font-bold text-[#F5EDD6]">Raporlar</h1>
        <p class="text-[#9A8470] mt-1">Raporları çalıştırın, dışa aktarın ve şablonları yönetin</p>
      </div>
    </div>
    <div class="container mx-auto px-4 py-8">
      <ReportManager client:visible={{ rootMargin: '140px' }} />
    </div>
  </div>
</Layout>
