---
import Layout from '../layouts/Layout.astro';
import RankedPlaceCard from '../components/landing/RankedPlaceCard.astro';
import { query } from '../lib/postgres';
import { getCachedPublicRouteData } from '../lib/public-route-cache';
import { getPublicAppUrl } from '../lib/public-app-url';
import { logger } from '../lib/logging';
import {
  buildItemListSchema,
  buildBreadcrumbSchema,
  buildFAQSchema,
  type LandingPlace,
} from '../lib/landing/landing-schema';
const baseUrl = getPublicAppUrl();

let oteller: LandingPlace[] = [];
try {
  oteller = await getCachedPublicRouteData('page:guide:en-iyi-oteller', async () => {
    const result = await query(`
      SELECT p.id, p.slug, p.name, p.address, p.avg_rating AS rating, p.review_count, p.image_url, p.images,
             p.short_description, c.name AS category_name
      FROM places p
      LEFT JOIN categories c ON p.category_id = c.id
      WHERE p.status = 'active'
        AND (c.name ILIKE '%otel%' OR c.name ILIKE '%konaklama%'
             OR c.name ILIKE '%pansiyon%' OR c.name ILIKE '%apart%'
             OR p.name ILIKE '%otel%' OR p.name ILIKE '%hotel%')
      ORDER BY p.avg_rating DESC NULLS LAST, p.review_count DESC NULLS LAST
      LIMIT 20
    `);
    return result.rows;
  });
} catch (e) {
  logger.error('Oteller yüklenemedi:', e instanceof Error ? e : new Error(String(e)));
}

const seo = {
  title: 'Şanlıurfa En İyi Oteller 2026 | Nerede Kalınır?',
  description: "Şanlıurfa'da en iyi oteller, pansiyonlar ve konaklama seçenekleri. Şehir merkezi ve tarihi bölgedeki en çok tercih edilen konaklamalar.",
  keywords: ['şanlıurfa oteller', 'şanlıurfa nerede kalınır', 'urfa otel', 'şanlıurfa konaklama', 'şanlıurfa en iyi otel'],
  canonical: '/en-iyi-oteller',
};

const faqItems = [
  {
    S: "Şanlıurfa'da nerede kalınır?",
    C: "Şanlıurfa'da tarihi merkeze yakın, şehir merkezindeki oteller en çok tercih edilenlerdir. Balıklıgöl ve Dergah bölgesine yürüme mesafesindeki oteller tarih ve konfor dengesi sunar.",
  },
  {
    S: "Şanlıurfa'da bütçe dostu konaklama var mı?",
    C: "Evet. Şehir merkezinde pansiyonlar ve apart oteller uygun fiyatlı konaklama seçenekleri sunar. Tarihi yapılarda restore edilen butik pansiyonlar da ilgi çekici bir alternatiftir.",
  },
  {
    S: "Şanlıurfa'da hangi semtte kalmalıyım?",
    C: "Tarihi alanlara yakın olmak için Balıklıgöl ve Kapalı Çarşı çevresi ideal. Daha modern bir konaklama için şehir merkezi ve yeni gelişme alanları tercih edilebilir.",
  },
];
---

<Layout seo={seo}>
  <style is:inline>
  .ek-hero{position:relative;overflow:hidden;border-bottom:1px solid rgba(184,115,51,0.12);padding:clamp(3rem,6vw,5rem) 0;background:radial-gradient(circle at 18% 0%,rgba(212,151,24,0.10) 0%,transparent 42%),radial-gradient(circle at 82% 100%,rgba(44,122,82,0.08) 0%,transparent 40%),linear-gradient(180deg,#fbf6ec 0%,#f4ecd8 58%,#fbf6ec 100%)}
  .ek-hero-label{font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--public-text-soft)}
  .ek-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.7rem,4vw,2.6rem);font-weight:700;color:var(--public-text);margin:.75rem 0 .25rem}
  .ek-hero-desc{color:var(--public-muted);font-size:.9rem;max-width:40rem}
  .ek-body{background:var(--bg);padding:2rem 0 4rem}
  .ek-info{background:rgba(184,115,51,.05);border:1px solid rgba(184,115,51,.18);padding:1.25rem;margin-bottom:1.75rem}
  .ek-info-h2{font-size:.9rem;font-weight:700;color:var(--public-text);margin-bottom:.25rem}
  .ek-info-p{font-size:.8rem;line-height:1.7;color:var(--public-muted)}
  .ek-grid{display:grid;gap:1rem}
  @media(min-width:48rem){.ek-grid{grid-template-columns:1fr 1fr}}
  .ek-card{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);display:flex;overflow:hidden;transition:border-color .15s}
  .ek-card:hover{border-color:var(--public-accent)}
  .ek-card-rank{width:6rem;height:6rem;background:rgba(184,115,51,.1);display:flex;align-items:center;justify-content:center;font-size:1.5rem;font-weight:700;color:var(--public-accent);flex-shrink:0}
  .ek-card-body{padding:1rem;flex:1;min-width:0}
  .ek-card-name{font-size:.9rem;font-weight:700;color:var(--public-text);transition:color .15s}
  .ek-card:hover .ek-card-name{color:var(--public-accent)}
  .ek-card-cat{font-size:.72rem;color:var(--public-muted);margin-top:.15rem}
  .ek-card-addr{font-size:.78rem;color:var(--public-muted);margin-top:.4rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .ek-card-meta{display:flex;align-items:center;gap:.75rem;margin-top:.5rem;font-size:.8rem}
  .ek-rating{color:var(--public-accent);font-weight:600}
  .ek-reviews{color:var(--public-text-soft)}
  .ek-empty{text-align:center;padding:4rem 1rem;background:var(--bg-card);border:1px solid rgba(184,115,51,.14)}
  .ek-empty-icon{font-size:2.5rem;margin-bottom:.75rem}
  .ek-empty-txt{font-size:.9rem;color:var(--public-muted)}
  .ek-cta{display:flex;flex-wrap:wrap;gap:.75rem;margin-top:2.5rem}
  .ek-btn-primary{background:var(--public-accent);color:#fff;font-size:.85rem;font-weight:600;padding:.65rem 1.25rem;transition:background .15s}
  .ek-btn-primary:hover{background:var(--public-accent-strong)}
  .ek-btn-outline{border:1px solid rgba(184,115,51,.25);color:var(--public-accent);font-size:.85rem;font-weight:500;padding:.65rem 1.25rem;transition:border-color .15s,color .15s}
  .ek-btn-outline:hover{border-color:var(--public-accent);color:var(--public-text)}
  details summary{list-style:none}
  details summary::-webkit-details-marker{display:none}
  details[open] .faq-arrow{transform:rotate(180deg)}
  </style>

  <div class="ek-hero">
    <div class="sf-container">
      <p class="ek-hero-label">Şanlıurfa Konaklama Rehberi</p>
      <h1 class="ek-h1">Şanlıurfa'nın En İyi Otelleri</h1>
      <p class="ek-hero-desc">Tarihi merkeze yakın, konforlu ve bütçe dostu konaklama seçenekleri.</p>
    </div>
  </div>

  <div class="ek-body">
    <div class="sf-container">
      <div class="ek-info">
        <h2 class="ek-info-h2">Şanlıurfa'da Konaklama Hakkında</h2>
        <p class="ek-info-p">Şanlıurfa'da konaklama seçenekleri tarihi alanlara yakın, modern şehir merkezinde ve bütçe dostu pansiyonlar olarak üç ana kategoride öne çıkar. Balıklıgöl, Dergah ve Kapalı Çarşı çevresindeki oteller, kısa yürüyüş mesafesinde birden fazla tarihi alana ulaşma imkânı sunar.</p>
      </div>

      {oteller.length > 0 ? (
        <div class="ek-grid">
          {oteller.map((place, i) => (
            <RankedPlaceCard place={place} rank={i + 1} variant="hotel" />
          ))}
        </div>
      ) : (
        <div class="ek-empty">
          <div class="ek-empty-icon">🏨</div>
          <p class="ek-empty-txt">Otel bilgileri yakında eklenecek.</p>
        </div>
      )}

      <div class="ek-cta">
        <a href="/konaklama" class="ek-btn-primary">Tüm Konaklama Seçenekleri</a>
        <a href="/sanliurfa-gezi-rehberi" class="ek-btn-outline">Şanlıurfa Gezi Rehberi</a>
        <a href="/en-iyi-gezilecek-yerler" class="ek-btn-outline">Gezilecek Yerler →</a>
      </div>
    </div>
  </div>

  {faqItems.length > 0 && (
    <div style="padding:2rem 0 3rem;border-top:1px solid rgba(184,115,51,.12)">
      <div class="sf-container">
        <h2 style="font-size:1.25rem;font-weight:700;color:#1F1410;margin-bottom:1.25rem">Sık Sorulan Sorular</h2>
        <div style="display:flex;flex-direction:column;gap:.75rem">
          {faqItems.map((item) => (
            <details style="background:var(--bg-card);border:1px solid rgba(184,115,51,.14);border-radius:.375rem;overflow:hidden">
              <summary style="padding:1rem 1.25rem;font-weight:600;color:#1F1410;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:1rem">
                {item.S}
                <span style="flex-shrink:0;color:#B87333;font-size:1.25rem;transition:transform .2s" class="faq-arrow">▾</span>
              </summary>
              <div style="padding:.75rem 1.25rem 1rem;color:#4A3828;font-size:.95rem;line-height:1.7;border-top:1px solid rgba(184,115,51,.08)">
                {item.C}
              </div>
            </details>
          ))}
        </div>
      </div>
    </div>
  )}

  <script type="application/ld+json" set:html={JSON.stringify(buildItemListSchema({
    places: oteller,
    pageName: 'Şanlıurfa En İyi Oteller',
    pagePath: '/en-iyi-oteller',
    baseUrl,
    type: 'LodgingBusiness',
    description: "Şanlıurfa'nın en iyi otel ve konaklama seçenekleri — şehir merkezi ve tarihi bölgedeki tercih edilen konaklamalar.",
  }))} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(buildBreadcrumbSchema({
    baseUrl,
    crumbs: [
      { name: 'Ana Sayfa', href: '/' },
      { name: 'Konaklama', href: '/konaklama' },
      { name: 'En İyi Oteller', href: '/en-iyi-oteller' },
    ],
  }))} is:inline />
  {(() => {
    const faqJson = buildFAQSchema(faqItems);
    return faqJson ? <script type="application/ld+json" set:html={JSON.stringify(faqJson)} is:inline /> : null;
  })()}
</Layout>
