---

import Layout from '../layouts/Layout.astro';
import { getPublicAppUrl } from '../lib/public-app-url';
const baseUrl = getPublicAppUrl();

const seo = {
 title: 'KVKK Aydınlatma Metni - Sanliurfa.com',
 description: 'Kişisel Verilerin Korunması Kanunu kapsamında aydınlatma metni.',
 keywords: ['kvkk', 'kişisel verilerin korunması', 'veri gizliliği', 'şanlıurfa.com kvkk'],
 ogImage: '/images/places/balikligol.jpg',
 canonical: '/kvkk',
};
const faqItems = [
 { S: "KVKK kapsamında haklarım nelerdir?", C: "Kişisel verilerinize erişim, düzeltme, silme ve işlemeye itiraz etme haklarına sahipsiniz." },
 { S: "Veri sorumlusu kimdir?", C: "Sanliurfa.com platformu adına veri sorumlusu olarak bilgiler gizlilik politikamızda yer almaktadır." },
 { S: "KVKK başvurusu nasıl yapılır?", C: "KVKK başvurularınızı kvkk@sanliurfa.com adresine yazılı olarak iletebilirsiniz." },
];
---

<Layout seo={seo}>
 <style is:inline>
 .lp-hero{padding:3rem 0 2.5rem;border-bottom:1px solid rgba(184,115,51,.1)}
 .lp-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.7rem,4vw,2.5rem);font-weight:600;color:var(--public-text);margin-bottom:.4rem}
 .lp-date{font-size:.78rem;color:var(--public-text-soft)}
 .lp-body{background:var(--bg);padding:2.5rem 0 5rem}
 .lp-inner{max-width:680px;margin:0 auto}
 .lp-card{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);padding:2rem 2.25rem}
 .lp-prose h2{font-family:'Cormorant Garamond',serif;font-size:1.15rem;font-weight:600;color:var(--public-text);margin:1.75rem 0 .6rem;padding-bottom:.4rem;border-bottom:1px solid rgba(184,115,51,.1)}
 .lp-prose h2:first-child{margin-top:0}
 .lp-prose p{font-size:.855rem;color:var(--public-muted);line-height:1.8;margin-bottom:.85rem}
 .lp-prose ul{margin:.4rem 0 1rem 1.1rem;list-style:disc}
 .lp-prose ol{margin:.4rem 0 1rem 1.1rem;list-style:decimal}
 .lp-prose ul li,.lp-prose ol li{font-size:.855rem;color:var(--public-muted);line-height:1.7;margin-bottom:.3rem}
 .lp-prose strong{color:var(--public-accent);font-weight:600}
 </style>

 <!-- Hero -->
 <div class="lp-hero">
 <div class="sf-container">
 <h1 class="lp-h1">KVKK Aydınlatma Metni</h1>
 <p class="lp-date">6698 Sayılı Kişisel Verilerin Korunması Kanunu kapsamında bilgilendirme</p>
 </div>
 </div>

 <!-- Content -->
 <div class="lp-body">
 <div class="sf-container">
 <div class="lp-inner">
 <div class="lp-card">
 <div class="lp-prose">
 <h2>Veri Sorumlusu</h2>
 <p>
 6698 sayılı Kişisel Verilerin Korunması Kanunu ("KVKK") uyarınca, kişisel verileriniz;
 veri sorumlusu olarak Sanliurfa.com ("Şirket") tarafından aşağıda açıklanan kapsamda işlenebilecektir.
 </p>

 <h2>Kişisel Verilerin İşlenme Amaçları</h2>
 <p>Kişisel verileriniz aşağıdaki amaçlarla işlenmektedir:</p>
 <ul>
 <li>Üyelik işlemlerinin gerçekleştirilmesi</li>
 <li>Hizmetlerimizin sunulması ve iyileştirilmesi</li>
 <li>İletişim faaliyetlerinin yürütülmesi</li>
 <li>Pazarlama ve kampanya süreçlerinin yönetimi</li>
 <li>Müşteri memnuniyetinin sağlanması</li>
 <li>Yasal yükümlülüklerin yerine getirilmesi</li>
 </ul>

 <h2>İşlenen Kişisel Veriler</h2>
 <p>Aşağıdaki kategorilerde kişisel veriler işlenmektedir:</p>
 <ul>
 <li><strong>Kimlik Bilgileri:</strong> Ad, soyad</li>
 <li><strong>İletişim Bilgileri:</strong> E-posta adresi, telefon numarası</li>
 <li><strong>Lokasyon Bilgileri:</strong> IP adresi, konum verileri</li>
 <li><strong>Kullanım Verileri:</strong> Site kullanım istatistikleri</li>
 </ul>

 <h2>Kişisel Verilerin Aktarılması</h2>
 <p>
 Kişisel verileriniz, yukarıda belirtilen amaçların gerçekleştirilmesi doğrultusunda;
 iş ortaklarımıza, tedarikçilerimize ve yasal zorunluluk halinde yetkili kamu kurum ve kuruluşlarına
 aktarılabilecektir.
 </p>

 <h2>Kişisel Veri Toplamanın Yöntemi ve Hukuki Sebebi</h2>
 <p>
 Kişisel verileriniz; web sitemiz, mobil uygulamalarımız ve çağrı merkezimiz aracılığıyla,
 otomatik veya otomatik olmayan yöntemlerle toplanmaktadır. Verilerin işlenmesinin hukuki sebepleri şunlardır:
 </p>
 <ul>
 <li>Açık rızanızın bulunması</li>
 <li>Bir sözleşmenin kurulması veya ifasıyla doğrudan doğruya ilgili olması</li>
 <li>Şirketin hukuki yükümlülüğünü yerine getirmesi için zorunlu olması</li>
 <li>Bir hakkın tesisi, kullanılması veya korunması için veri işlemenin zorunlu olması</li>
 </ul>

 <h2>Haklarınız</h2>
 <p>KVKK'nın 11. maddesi uyarınca aşağıdaki haklara sahipsiniz:</p>
 <ol>
 <li>Kişisel verilerinizin işlenip işlenmediğini öğrenme</li>
 <li>Kişisel verileriniz işlenmişse buna ilişkin bilgi talep etme</li>
 <li>Kişisel verilerinizin işlenme amacını ve bunların amacına uygun kullanılıp kullanılmadığını öğrenme</li>
 <li>Yurt içinde veya yurt dışında kişisel verilerinizin aktarıldığı üçüncü kişileri bilme</li>
 <li>Kişisel verilerinizin eksik veya yanlış işlenmişse düzeltilmesini isteme</li>
 <li>KVKK'nın 7. maddesinde öngörülen şartlar çerçevesinde kişisel verilerinizin silinmesini veya yok edilmesini isteme</li>
 <li>(e) ve (f) bentleri uyarınca yapılan işlemlerin, kişisel verilerinizin aktarıldığı üçüncü kişilere bildirilmesini isteme</li>
 <li>İşlenen verilerin münhasıran otomatik sistemler vasıtasıyla analiz edilmesi suretiyle aleyhinize bir sonucun ortaya çıkmasına itiraz etme</li>
 <li>Kişisel verilerinizin kanuna aykırı olarak işlenmesi sebebiyle zarara uğramanız hâlinde zararın giderilmesini talep etme</li>
 </ol>

 <h2>Başvuru Yöntemi</h2>
 <p>Yukarıda belirtilen haklarınızı kullanmak için aşağıdaki yöntemlerle başvuruda bulunabilirsiniz:</p>
 <ul>
 <li><strong>E-posta:</strong> kvkk@sanliurfa.com</li>
 <li><strong>Posta:</strong> Haliliye, Şanlıurfa, Türkiye</li>
 </ul>
 <p>Başvurunuz en geç 30 gün içinde değerlendirilecek ve sonuçlandırılacaktır.</p>
 </div>
 </div>
 </div>
 </div>
 </div>

 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'WebPage',
 name: 'KVKK Aydınlatma Metni',
 url: `${baseUrl}/kvkk`,
 publisher: {
 '@type': 'Organization',
 name: 'Sanliurfa.com',
 url: baseUrl,
 },
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'KVKK', item: `${baseUrl}/kvkk` },
 ],
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqItems.map((item) => ({
 '@type': 'Question',
 name: item.S,
 acceptedAnswer: { '@type': 'Answer', text: item.C },
 })),
 })} is:inline />
</Layout>
