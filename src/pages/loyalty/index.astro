---
import Layout from '../../layouts/Layout.astro';
import LoyaltyDashboard from '../../components/LoyaltyDashboard';

const user = Astro.locals.user;
if (!user) {
 return Astro.redirect('/giris?redirect=/loyalty');
}
---

<Layout seo={{ title: "Sadakat Programı - Şanlıurfa", noIndex: true }}>
 <style is:inline>
 .ly-hero{position:relative;overflow:hidden;border-bottom:1px solid rgba(184,115,51,.12);background:radial-gradient(circle at 18% 0%,rgba(212,151,24,.10) 0%,transparent 42%),radial-gradient(circle at 82% 100%,rgba(44,122,82,.08) 0%,transparent 40%),linear-gradient(180deg,#fbf6ec 0%,#f4ecd8 58%,#fbf6ec 100%);padding:2.5rem 0}
 .ly-label{font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:#4A3828}
 .ly-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.75rem,4vw,2.5rem);font-weight:700;color:#1F1410;margin:.5rem 0 .25rem}
 .ly-desc{color:#7A6B58;font-size:.9rem}
 .ly-body{background:var(--bg);padding:2rem 0 4rem}
 .ly-inner{max-width:72rem;margin:0 auto}
 .ly-cards{display:grid;gap:1rem;margin-top:3rem}
 @media(min-width:48rem){.ly-cards{grid-template-columns:repeat(3,1fr)}}
 .ly-card{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);padding:1.5rem}
 .ly-card-title{font-size:.9rem;font-weight:700;color:#1F1410;margin-bottom:.75rem}
 .ly-card-list{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:.4rem}
 .ly-card-list li{font-size:.82rem;color:#7A6B58}
 .ly-cta{background:rgba(184,115,51,.05);border:1px solid rgba(184,115,51,.2);padding:2rem;margin-top:2rem}
 .ly-cta-title{font-family:'Cormorant Garamond',serif;font-size:1.35rem;font-weight:700;color:#1F1410;margin-bottom:.5rem}
 .ly-cta-desc{font-size:.88rem;color:#7A6B58;margin-bottom:1.25rem}
 .ly-cta-btn{display:inline-block;padding:.65rem 1.5rem;background:#B87333;color:#EDE0C6;font-size:.85rem;font-weight:600;transition:background .15s}
 .ly-cta-btn:hover{background:#9D5F1A}
 </style>

 <div class="ly-hero">
 <div class="sf-container">
 <div class="ly-inner">
 <p class="ly-label">Ödül Sistemi</p>
 <h1 class="ly-h1">Sadakat Programı</h1>
 <p class="ly-desc">Puanlarınızı kazanın ve harika ödüllerle değerlendirin</p>
 </div>
 </div>
 </div>

 <div class="ly-body">
 <div class="sf-container">
 <div class="ly-inner">
 <LoyaltyDashboard client:visible={{ rootMargin: '140px' }} />

 <div class="ly-cards">
 <div class="ly-card">
 <h3 class="ly-card-title">Nasıl Kazanılır?</h3>
 <ul class="ly-card-list">
 <li>• Tesisler hakkında inceleme yazın</li>
 <li>• Favori ekleyin ve paylaşın</li>
 <li>• Diğer kullanıcıların incelemelerini beğenin</li>
 <li>• İnsanları takip edin</li>
 </ul>
 </div>
 <div class="ly-card">
 <h3 class="ly-card-title">Seviye Avantajları</h3>
 <ul class="ly-card-list">
 <li>• Bronz: %10 puan bonusu</li>
 <li>• Gümüş: %20 puan bonusu</li>
 <li>• Altın: %30 puan bonusu</li>
 <li>• Platin: %50 puan bonusu</li>
 </ul>
 </div>
 <div class="ly-card">
 <h3 class="ly-card-title">Ödüller</h3>
 <ul class="ly-card-list">
 <li>• Özel ayrıcalıklar</li>
 <li>• Erken etkinlik erişimi</li>
 <li>• Özel indirimler</li>
 <li>• VIP öznitelikler</li>
 </ul>
 </div>
 </div>

 <div class="ly-cta">
 <h2 class="ly-cta-title">Daha Fazla Puan Kazanın</h2>
 <p class="ly-cta-desc">Şanlıurfa'da yeni mekanlar keşfedin ve puanlarınızı artırın. Her etkinlik ve inceleme sizi ödüllere daha yakın getiriyor.</p>
 <a href="/mekanlar" class="ly-cta-btn">Mekanları Keşfedin</a>
 </div>
 </div>
 </div>
 </div>
</Layout>
