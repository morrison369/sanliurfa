---
import Layout from '../../layouts/Layout.astro';
import { TransactionHistory } from '../../components/TransactionHistory';

const user = Astro.locals.user;
if (!user) {
 return Astro.redirect('/giris?redirect=/loyalty/transactions');
}
---

<Layout seo={{ title: "İşlem Geçmişi - Sadakat Programı", noIndex: true }}>
 <style is:inline>
 .lx-hero{position:relative;overflow:hidden;border-bottom:1px solid rgba(184,115,51,.12);background:radial-gradient(circle at 18% 0%,rgba(212,151,24,.10) 0%,transparent 42%),radial-gradient(circle at 82% 100%,rgba(44,122,82,.08) 0%,transparent 40%),linear-gradient(180deg,#fbf6ec 0%,#f4ecd8 58%,#fbf6ec 100%);padding:2.5rem 0}
 .lx-back{font-size:.82rem;color:#7A6B58;transition:color .15s;display:inline-block;margin-bottom:.75rem}
 .lx-back:hover{color:#B87333}
 .lx-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.5rem,3.5vw,2.4rem);font-weight:700;color:#1F1410;margin:.25rem 0}
 .lx-desc{color:#7A6B58;font-size:.9rem}
 .lx-body{background:var(--bg);padding:2rem 0 4rem}
 .lx-inner{max-width:72rem;margin:0 auto}
 </style>

 <div class="lx-hero">
 <div class="sf-container">
 <div class="lx-inner">
 <a href="/loyalty" class="lx-back">← Sadakat Programı</a>
 <h1 class="lx-h1">İşlem Geçmişi</h1>
 <p class="lx-desc">Tüm puan işlemlerinizi görüntüleyin</p>
 </div>
 </div>
 </div>

 <div class="lx-body">
 <div class="sf-container">
 <div class="lx-inner">
 <TransactionHistory client:visible={{ rootMargin: '140px' }} />
 </div>
 </div>
 </div>
</Layout>
