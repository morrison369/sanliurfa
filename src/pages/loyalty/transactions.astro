---
import Layout from "../../layouts/Layout.astro";
import { TransactionHistory } from "../../components/TransactionHistory";
import AuthFeatureLanding from "../../components/AuthFeatureLanding.astro";

const user = Astro.locals.user;
---

<Layout title="İşlem geçmişi - Sadakat Programı" noindex>
  {
    !user ? (
      <AuthFeatureLanding
        eyebrow="Puan geçmişi"
        title="Şanlıurfa katkı puanlarınızı kayıt altında tutun"
        description="Puan kazanma, harcama, ödül kullanımı ve seviye ilerlemesi hesabınızla birlikte takip edilir. Ücretsiz hesap oluşturarak sadakat geçmişinizi açabilirsiniz."
        loginRedirect="/loyalty/transactions"
        features={[
          {
            title: "Kazanım geçmişi",
            description:
              "Yorum, favori, etkinlik ve sosyal katkılardan gelen puanlar listelenir.",
          },
          {
            title: "Harcama takibi",
            description:
              "Ödül kullanımı ve puan düşüşleri tarih bazlı izlenir.",
          },
          {
            title: "Seviye ilerlemesi",
            description:
              "Toplam puan ve kullanılabilir puan ayrımı tek geçmiş ekranında görülür.",
          },
        ]}
      />
    ) : (
      <div class="container mx-auto px-4 py-8">
        <div class="mb-8">
          <a
            href="/loyalty"
            class="text-urfa-700 hover:underline mb-4 inline-block"
          >
            Geri dön
          </a>
          <h1 class="text-4xl font-bold mb-2">İşlem geçmişi</h1>
          <p class="text-gray-600">Tüm puan işlemlerinizi görüntüleyin.</p>
        </div>

        <TransactionHistory client:load />
      </div>
    )
  }
</Layout>
