---
import Layout from '../../layouts/Layout.astro';
import { RewardsCatalog } from '../../components/RewardsCatalog';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/giris?redirect=/loyalty/rewards');
}
---

<Layout seo={{ title: "Ödüller - Sadakat Programı", noIndex: true }}>
  <div class="min-h-screen bg-[#FDFAF3]">
    <div class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)] text-white py-12">
      <div class="container mx-auto px-4 max-w-5xl">
        <a href="/loyalty" class="text-[#9A8470] hover:text-[#C4B49A] text-sm mb-4 inline-block transition-colors">← Sadakat Programı</a>
        <h1 class="text-4xl font-bold text-[#F5EDD6] mb-2">Ödüller</h1>
        <p class="text-[#C4B49A]">Puanlarınızı harika ödüllere dönüştürün</p>
      </div>
    </div>

    <div class="container mx-auto px-4 max-w-5xl py-8">
      <RewardsCatalog client:visible={{ rootMargin: '140px' }} />

      <div class="mt-12 bg-[rgba(200,160,100,0.06)] border border-[rgba(200,160,100,0.2)] rounded-sm p-6">
        <h2 class="font-semibold text-lg text-[#1A1008] mb-4">❓ Sıkça Sorulan Sorular</h2>
        <div class="space-y-4 text-sm">
          <div>
            <p class="font-medium text-[#1A1008] mb-1">Ödül nasıl kullanılır?</p>
            <p class="text-[#6B5540]">Bir ödülü seçin, "Puan Kullan" düğmesine tıklayın. Puanlarınız hemen çıkarılacak ve bir kullanım kodu alacaksınız.</p>
          </div>
          <div>
            <p class="font-medium text-[#1A1008] mb-1">Puanlarım ne kadar süre geçerlidir?</p>
            <p class="text-[#6B5540]">Puanlarınız 2 yıl boyunca geçerlidir. Son işleminizden sonra 2 yıl hesap inaktif kalırsa puanlarınız otomatik olarak iptal edilebilir.</p>
          </div>
          <div>
            <p class="font-medium text-[#1A1008] mb-1">Ödülü değiştirebilir miyim?</p>
            <p class="text-[#6B5540]">Ödül kullanıldıktan sonra değiştirilemez. Lütfen seçiminizden emin olunduktan sonra onaylayın.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
