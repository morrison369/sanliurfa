---
import Layout from '../layouts/Layout.astro';
import UserSettings from '../components/UserSettings';

const user = Astro.locals.user;
if (!user) {
 return Astro.redirect('/giris?redirect=/ayarlar');
}
---

<Layout seo={{ title: "Ayarlar - Şanlıurfa", noIndex: true }}>
 <style is:inline>
 .ay-hero{position:relative;overflow:hidden;border-bottom:1px solid rgba(184,115,51,.12);background:radial-gradient(circle at 18% 0%,rgba(212,151,24,.10) 0%,transparent 42%),radial-gradient(circle at 82% 100%,rgba(44,122,82,.08) 0%,transparent 40%),linear-gradient(180deg,#fbf6ec 0%,#f4ecd8 58%,#fbf6ec 100%);padding:2.5rem 0}
 .ay-label{font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--public-text-soft)}
 .ay-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.5rem,3.5vw,2.2rem);font-weight:700;color:var(--public-text);margin:.5rem 0 .25rem}
 .ay-desc{color:var(--public-muted);font-size:.9rem}
 .ay-body{background:var(--bg);padding:2rem 0 4rem}
 .ay-inner{max-width:56rem;margin:0 auto}
 </style>

 <div class="ay-hero">
 <div class="sf-container">
 <div class="ay-inner">
 <p class="ay-label">Hesabım</p>
 <h1 class="ay-h1">Hesap Ayarları</h1>
 <p class="ay-desc">Profil bilgilerinizi ve tercihlerinizi yönetin</p>
 </div>
 </div>
 </div>

 <div class="ay-body">
 <div class="sf-container">
 <div class="ay-inner">
 <UserSettings client:visible={{ rootMargin: '120px' }} />
 </div>
 </div>
 </div>
</Layout>
