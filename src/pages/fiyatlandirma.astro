---
import Layout from "../layouts/Layout.astro";
import PricingPlans from "../components/PricingPlans";

const seo = {
  title: "Fiyatlandırma | sanliurfa.com",
  description:
    "sanliurfa.com üyelik, premium ve işletme planları. Şanlıurfa mekân keşfi, sosyal topluluk ve işletme yönetimi ilk aşamada ücretsiz açık.",
  canonical: "https://sanliurfa.com/fiyatlandirma",
};
---

<Layout seo={seo}>
  <div
    class="min-h-screen bg-gradient-to-b from-urfa-50 to-white dark:from-gray-900 dark:to-gray-800 py-12 px-4 sm:px-6 lg:px-8"
  >
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <h1
          class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4"
        >
          sanliurfa.com üyelik planları
        </h1>
        <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
          Şanlıurfa odaklı keşif, sosyal topluluk, sadakat ve işletme yönetimi
          özellikleri ilk aşamada ücretsiz açık tutulur.
        </p>
        <div
          class="mt-6 inline-flex rounded-full border border-urfa-200 bg-white px-5 py-2 text-sm font-semibold text-urfa-800 shadow-sm dark:bg-gray-900 dark:text-urfa-200"
        >
          Ödeme açılana kadar temel özellikler ücretsizdir.
        </div>
      </div>

      <PricingPlans client:load />

      <div class="mt-20">
        <h2
          class="text-3xl font-bold text-gray-900 dark:text-white text-center mb-12"
        >
          Sık sorulan sorular
        </h2>

        <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
          <div
            class="bg-white dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700"
          >
            <h3
              class="text-lg font-semibold text-gray-900 dark:text-white mb-2"
            >
              Planı ne zaman değiştirebilirim?
            </h3>
            <p class="text-gray-600 dark:text-gray-400">
              İstediğiniz zaman plan yükseltebilir veya düşürebilirsiniz.
              Değişiklik hemen uygulanır.
            </p>
          </div>

          <div
            class="bg-white dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700"
          >
            <h3
              class="text-lg font-semibold text-gray-900 dark:text-white mb-2"
            >
              Ödeme yöntemi nedir?
            </h3>
            <p class="text-gray-600 dark:text-gray-400">
              Ödeme sistemi açıldığında işlemler güvenli ödeme altyapısı
              üzerinden yürütülür. İlk aşamada temel özellikler ücretsizdir.
            </p>
          </div>

          <div
            class="bg-white dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700"
          >
            <h3
              class="text-lg font-semibold text-gray-900 dark:text-white mb-2"
            >
              Aboneliği iptal edebilir miyim?
            </h3>
            <p class="text-gray-600 dark:text-gray-400">
              Evet, dilediğiniz zaman aboneliği iptal edebilirsiniz. Ek ücret
              yoktur.
            </p>
          </div>

          <div
            class="bg-white dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700"
          >
            <h3
              class="text-lg font-semibold text-gray-900 dark:text-white mb-2"
            >
              Ücretsiz plan limitlemesi var mı?
            </h3>
            <p class="text-gray-600 dark:text-gray-400">
              Ücretsiz planda Şanlıurfa keşfi, yorumlar, favoriler, mesajlaşma,
              sosyal akış ve işletme ekleme gibi temel özelliklere
              erişebilirsiniz.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
