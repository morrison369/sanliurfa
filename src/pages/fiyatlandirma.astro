---

import Layout from '../layouts/Layout.astro';
import PricingPlans from '../components/PricingPlans';
import { getSiteBranding } from '../lib/site-branding';
const { baseUrl } = await getSiteBranding();

const seo = {
  title: 'Fiyatlandırma - Şanlıurfa.com',
  description: 'Şanlıurfa.com üyelik planları ve fiyatlandırma. Tüm özellikler faz 1 döneminde ücretsizdir.',
  keywords: ['şanlıurfa.com fiyatlandırma', 'premium üyelik', 'abonelik planı', 'ücretsiz üyelik'],
  ogImage: '/images/hero/hero-home.webp',
  canonical: '/fiyatlandirma',
};

const faqItems = [
  {
    S: 'Planı ne zaman değiştirebilirim?',
    C: 'Faz 1 döneminde plan değişikliği gerekmiyor; tüm özellikler açık ve ücretsizdir.',
  },
  {
    S: 'Ödeme yöntemi nedir?',
    C: 'Faz 1 açık erişimde ücretlendirme aktif değildir.',
  },
  {
    S: 'Aboneliği iptal edebilir miyim?',
    C: 'Bu aşamada faturalama olmadığı için iptal süreci uygulanmaz.',
  },
  {
    S: 'Ücretsiz plan limitlemesi var mı?',
    C: 'Hayır. Faz 1 kapsamında tüm özellikler sınırsız ve ücretsizdir.',
  },
];
---

<Layout seo={seo}>
  <div class="min-h-screen bg-[#FDFAF3]">
    <!-- Hero -->
    <div class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)] text-white py-16">
      <div class="container mx-auto px-4 text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-[#F5EDD6] mb-4">
          Şanlıurfa’nın Gücünü Keşfet
        </h1>
        <p class="text-xl text-[#9A8470] max-w-2xl mx-auto">
          Faz 1 açık erişim aktif. Tüm özellikler şu anda ücretsiz ve tam erişimle kullanılabilir.
        </p>
      </div>
    </div>

    <div class="container mx-auto px-4 py-12 max-w-7xl">
      <!-- Pricing Plans Component -->
      <PricingPlans client:visible={{ rootMargin: '160px' }} />

      <!-- FAQ Section -->
      <div class="mt-20">
        <h2 class="text-3xl font-bold text-[#1A1008] text-center mb-12">
          Sık Sorulan Sorular
        </h2>

        <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
          <div class="bg-white rounded-sm p-6 border border-[rgba(200,160,100,0.18)] shadow-sm">
            <h3 class="text-lg font-semibold text-[#1A1008] mb-2">
              Planı ne zaman değiştirebilirim?
            </h3>
            <p class="text-[#9A8470]">
              Faz 1 döneminde plan yükseltme gerekmez, tüm özellikler açıktır.
            </p>
          </div>

          <div class="bg-white rounded-sm p-6 border border-[rgba(200,160,100,0.18)] shadow-sm">
            <h3 class="text-lg font-semibold text-[#1A1008] mb-2">
              Ödeme yöntemi nedir?
            </h3>
            <p class="text-[#9A8470]">
              Faz 1 döneminde ödeme adımı bulunmaz.
            </p>
          </div>

          <div class="bg-white rounded-sm p-6 border border-[rgba(200,160,100,0.18)] shadow-sm">
            <h3 class="text-lg font-semibold text-[#1A1008] mb-2">
              Aboneliği iptal edebilir miyim?
            </h3>
            <p class="text-[#9A8470]">
              Faturalama aktif olmadığından iptal işlemi gerekmez.
            </p>
          </div>

          <div class="bg-white rounded-sm p-6 border border-[rgba(200,160,100,0.18)] shadow-sm">
            <h3 class="text-lg font-semibold text-[#1A1008] mb-2">
              Ücretsiz plan limitlemesi var mı?
            </h3>
            <p class="text-[#9A8470]">
              Hayır. Faz 1 kapsamında tüm özellikler sınırsızdır.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqItems.map((item) => ({
        '@type': 'Question',
        name: item.S,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.C,
        },
      })),
    })}
    is:inline
  />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Fiyatlandırma', item: `${baseUrl}/fiyatlandirma` },
    ],
  })} is:inline />
</Layout>
