---
import { Icon } from 'astro-icon/components';
import Layout from '../../layouts/Layout.astro';
import Image from '../../components/Image.astro';
import { query, queryOne } from '../../lib/postgres';
import { resolveContentImage } from '../../lib/content-images';
import { getSiteBranding } from '../../lib/site-branding';
import { logger } from '../../lib/logging';
const { baseUrl } = await getSiteBranding();

let site: any = null;
let nearbySites: any[] = [];
const getHistoricalImage = (item: any, thumb = false) =>
  resolveContentImage({
    category: 'tarihi-yerler',
    slug: item?.slug,
    explicit: item?.images?.[0],
    placeholder: '/images/placeholder-historical.jpg',
    thumb,
  });

try {
  const { slug } = Astro.params;

  site = await queryOne(
    "SELECT * FROM historical_sites WHERE slug = $1 AND status = 'active'",
    [slug]
  );

  if (!site) {
    const knownPlaceSlugs = new Set(['gobeklitepe', 'balikligol', 'harran', 'halfeti', 'urfa-kalesi', 'ayna-carsi', 'kapali-carsi']);
    if (knownPlaceSlugs.has(String(slug))) {
      return Astro.redirect(`/isletme/${slug}`);
    }
    return Astro.redirect('/tarihi-yerler');
  }

  const nearbyResult = await query(
    "SELECT id, name, slug, location FROM historical_sites WHERE status = 'active' AND id != $1 LIMIT 5",
    [site.id]
  );
  nearbySites = nearbyResult.rows;
} catch (e) {
  logger.error('Error loading historical site:', e instanceof Error ? e : new Error(String(e)));
}

const seo = {
  title: site ? `${site.name} - Tarihi Yer` : 'Tarihi Yer - Şanlıurfa',
  description: site?.description || 'Şanlıurfa tarihi yerleri',
  ogImage: site ? getHistoricalImage(site) : '/images/placeholder-historical.jpg',
  keywords: [site.name, site.name + ' şanlıurfa', 'şanlıurfa tarihi yerler', 'urfa ' + site.name.toLowerCase()],
  canonical: `/tarihi-yerler/${Astro.params.slug}`,
};
const faqItems = [
  { S: `${site.name} nerede?`, C: `${site.name}, ${site.location || 'Şanlıurfa'} konumunda yer almaktadır.` },
  { S: `${site.name} ziyaret saatleri nedir?`, C: site.visiting_hours || `${site.name} için ziyaret saatlerini sayfamızdan veya ilgili kurumdan öğrenebilirsiniz.` },
  { S: `${site.name} giriş ücreti var mı?`, C: site.entrance_fee || `${site.name} giriş ücreti için güncel bilgiyi sayfamızdan takip edebilirsiniz.` },
];
---

<Layout seo={seo}>
  <div class="min-h-screen bg-[#FDFAF3]">
    <div class="relative h-[70vh] min-h-[600px]">
      <div class="absolute inset-0">
        <Image
          src={getHistoricalImage(site)}
          alt={site.name}
          width={1920}
          height={1080}
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent" />
      </div>

      <div class="absolute bottom-0 left-0 right-0 container mx-auto px-4 pb-12">
        <div class="flex flex-wrap items-center gap-3 mb-4">
          {site.is_unesco && (
            <span class="inline-flex items-center gap-1 px-3 py-1 bg-blue-600 text-white text-sm rounded-sm font-medium">
              <Icon name="lucide:star" class="w-3 h-3" />
              UNESCO Dünya Mirası
            </span>
          )}
          {site.is_featured && !site.is_unesco && (
            <span class="px-3 py-1 bg-urfa-600 text-white text-sm rounded-sm font-medium">Öne Çıkan</span>
          )}
          <span class="px-3 py-1 bg-white/20 border border-white/30 text-white text-sm rounded-sm">{site.period || 'Tarihi'}</span>
        </div>

        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-4">
          {site.name}
        </h1>
        <p class="text-xl md:text-2xl text-[#C4B49A] font-medium">{site.short_description || site.location}</p>

        <div class="flex items-center gap-6 mt-6 text-white">
          <div class="flex items-center gap-2">
            <Icon name="lucide:map-pin" class="w-5 h-5" />
            <span>{site.location}</span>
          </div>
        </div>
      </div>

      <div class="absolute top-4 right-4 flex gap-2">
        <button class="w-12 h-12 bg-white/20 backdrop-blur-sm rounded-sm flex items-center justify-center text-white hover:bg-white/30 transition-colors">
          <Icon name="lucide:heart" class="w-6 h-6" />
        </button>
        <button class="w-12 h-12 bg-white/20 backdrop-blur-sm rounded-sm flex items-center justify-center text-white hover:bg-white/30 transition-colors">
          <Icon name="lucide:share-2" class="w-6 h-6" />
        </button>
      </div>
    </div>

    <div class="container mx-auto px-4 py-12">
      <div class="grid lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2 space-y-12">
          <section>
            <h2 class="text-3xl font-bold text-[#1A1008] mb-4">Hakkında</h2>
            <p class="text-xl text-[#4A3828] leading-relaxed">{site.description}</p>
          </section>

          {site.images && site.images.length > 1 && (
            <section>
              <h2 class="text-3xl font-bold text-[#1A1008] mb-6">Galeri</h2>
              <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                {site.images.slice(1).map((img: string, i: number) => (
                  <div class={`${i === 0 ? 'col-span-2 row-span-2' : ''} rounded-sm overflow-hidden`}>
                    <Image
                      src={img}
                      alt={`${site.name} ${i + 1}`}
                      width={960}
                      height={720}
                      class="w-full h-full object-cover hover:scale-110 transition-transform duration-500"
                    />
                  </div>
                ))}
              </div>
            </section>
          )}
        </div>

        <aside class="space-y-6">
          <div class="bg-white rounded-sm shadow-sm border border-[rgba(200,160,100,0.18)] p-6 sticky top-24">
            <h3 class="font-semibold text-[#1A1008] mb-4">Ziyaret Bilgileri</h3>

            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <Icon name="lucide:clock" class="w-5 h-5 text-urfa-600 mt-0.5" />
                <div>
                  <p class="font-medium text-[#1A1008]">Çalışma Saatleri</p>
                  <p class="text-[#6B5540]">{site.opening_hours || '08:00 - 18:00'}</p>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <Icon name="lucide:ticket" class="w-5 h-5 text-urfa-600 mt-0.5" />
                <div>
                  <p class="font-medium text-[#1A1008]">Giriş Ücreti</p>
                  <p class="text-[#6B5540]">{site.entry_fee || 'Ücretsiz'}</p>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <Icon name="lucide:map-pin" class="w-5 h-5 text-urfa-600 mt-0.5" />
                <div>
                  <p class="font-medium text-[#1A1008]">Konum</p>
                  <p class="text-[#6B5540]">{site.location}</p>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <Icon name="lucide:camera" class="w-5 h-5 text-urfa-600 mt-0.5" />
                <div>
                  <p class="font-medium text-[#1A1008]">Fotoğraf</p>
                  <p class="text-[#6B5540]">Ücretsiz çekim yapılabilir</p>
                </div>
              </div>
            </div>

            {site.latitude && site.longitude && (
              <div class="mt-6 pt-6 border-t border-[rgba(200,160,100,0.2)]">
                <a
                  href={`https://www.google.com/maps/dir/?api=1&destination=${site.latitude},${site.longitude}`}
                  target="_blank"
                  rel="noopener"
                  class="w-full py-3 bg-urfa-600 text-white rounded-sm font-medium tracking-wide hover:bg-urfa-700 transition-colors flex items-center justify-center gap-2"
                >
                  <Icon name="lucide:navigation" class="w-5 h-5" />
                  Yol Tarifi Al
                </a>
              </div>
            )}
          </div>

          {nearbySites && nearbySites.length > 0 && (
            <div class="bg-white rounded-sm shadow-sm border border-[rgba(200,160,100,0.18)] p-6">
              <h3 class="font-semibold text-[#1A1008] mb-4">Diğer Tarihi Yerler</h3>
              <div class="space-y-3">
                {nearbySites.map((place: any) => (
                  <a href={`/tarihi-yerler/${place.slug}`} class="flex items-center justify-between p-3 rounded-sm hover:bg-[rgba(200,160,100,0.06)] transition-colors">
                    <span class="text-[#4A3828]">{place.name}</span>
                    <span class="text-sm text-urfa-600">→</span>
                  </a>
                ))}
              </div>
            </div>
          )}
        </aside>
      </div>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'LandmarksOrHistoricalBuildings',
    name: site.name,
    description: site.short_description || site.description,
    url: `${baseUrl}/tarihi-yerler/${site.slug}`,
    image: (site.cover_image || site.images?.[0]) ? `${baseUrl}${site.cover_image || site.images[0]}` : `${baseUrl}/images/hero/hero-home.webp`,
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Şanlıurfa',
      addressRegion: 'Şanlıurfa',
      addressCountry: 'TR',
    },
    geo: site.latitude && site.longitude ? {
      '@type': 'GeoCoordinates',
      latitude: site.latitude,
      longitude: site.longitude,
    } : undefined,
    containedInPlace: { '@type': 'City', name: 'Şanlıurfa', url: `${baseUrl}` },
    openingHours: site.visiting_hours || undefined,
    publicAccess: true,
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Tarihi Yerler', item: `${baseUrl}/tarihi-yerler` },
      { '@type': 'ListItem', position: 3, name: site.name, item: `${baseUrl}/tarihi-yerler/${site.slug}` },
    ],
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: { '@type': 'Answer', text: item.C },
    })),
  })} is:inline />
</Layout>
