---
import { Icon } from 'astro-icon/components';
import DetailTemplate from '../../components/templates/DetailTemplate.astro';
import PublicDetailBody from '../../components/public/PublicDetailBody.astro';
import PublicDetailHero from '../../components/public/PublicDetailHero.astro';
import PublicStickyCTA from '../../components/public/PublicStickyCTA.astro';
import PublicSidebarCard from '../../components/public/PublicSidebarCard.astro';
import PublicFaqList from '../../components/public/PublicFaqList.astro';
import PublicInfoRows from '../../components/public/PublicInfoRows.astro';
import PublicMediaGallery from '../../components/public/PublicMediaGallery.astro';
import PublicRelatedList from '../../components/public/PublicRelatedList.astro';
import { query, queryOne } from '../../lib/postgres';
import { getCachedPublicRouteData } from '../../lib/public-route-cache';
import { getPublicAppUrl } from '../../lib/public-app-url';
import { logger } from '../../lib/logging';
import { normalizeGalleryImages, resolveHistoricalImage } from '../../lib/public-image-resolvers';
import { linkifyContent } from '../../lib/seo/internal-linker';
const baseUrl = getPublicAppUrl();

let site: any = null;
let nearbySites: any[] = [];
let siteReviews: any[] = [];
const getHistoricalImage = (item: any) => resolveHistoricalImage(item);

try {
 const { slug } = Astro.params;

 const data = await getCachedPublicRouteData(`page:tarihi-yerler:detail:${slug || 'unknown'}`, async () => {
  const siteRow = await queryOne(
   "SELECT * FROM historical_sites WHERE slug = $1 AND status = 'published'",
   [slug]
  );
  if (!siteRow) return { site: null, nearbySites: [], reviews: [] };
  const nearbyResult = await query(
   "SELECT id, name, slug, location FROM historical_sites WHERE status = 'published' AND id != $1 LIMIT 5",
   [siteRow.id]
  );
  const reviewsResult = await query(
   `SELECT r.id, r.rating, r.content, r.visit_type, r.created_at,
           u.full_name, u.avatar_url
    FROM reviews r
    LEFT JOIN users u ON u.id = r.user_id
    WHERE r.historical_site_id = $1 AND r.status = 'active'
    ORDER BY r.created_at DESC LIMIT 8`,
   [siteRow.id]
  );
  return { site: siteRow, nearbySites: nearbyResult.rows, reviews: reviewsResult.rows };
 });
 site = data.site;
 nearbySites = data.nearbySites;
 siteReviews = data.reviews || [];

 if (!site) {
 const knownPlaceSlugs = new Set(['gobeklitepe', 'balikligol', 'harran', 'halfeti', 'urfa-kalesi', 'ayna-carsi', 'kapali-carsi']);
 if (knownPlaceSlugs.has(String(slug))) {
 return Astro.redirect(`/isletme/${slug}`);
 }
 return Astro.redirect('/tarihi-yerler');
 }

} catch (e) {
 logger.error('Error loading historical site:', e instanceof Error ? e : new Error(String(e)));
}

const primaryHistoricalImage = site ? getHistoricalImage(site) : '/images/placeholder-historical.jpg';
const seo = {
 title: site ? `${site.name} - Tarihi Yer` : 'Tarihi Yer - Şanlıurfa',
 description: site?.description || 'Şanlıurfa tarihi yerleri',
 ogImage: primaryHistoricalImage.includes('placeholder') ? undefined : primaryHistoricalImage,
 keywords: [site.name, site.name + ' şanlıurfa', 'şanlıurfa tarihi yerler', 'urfa ' + site.name.toLowerCase()],
 canonical: `/tarihi-yerler/${Astro.params.slug}`,
};
const historicalHeroBadges = [
 ...(site.is_unesco ? [{ label: 'UNESCO Dünya Mirası', tone: 'strong' as const, icon: 'lucide:star' }] : []),
 ...(!site.is_unesco && site.is_featured ? [{ label: 'Öne Çıkan', tone: 'accent' as const }] : []),
 { label: site.period || 'Tarihi', tone: 'soft' as const },
];
const galleryImages = normalizeGalleryImages(
 [primaryHistoricalImage, ...(Array.isArray(site?.images) ? site.images : [])],
 primaryHistoricalImage,
);
const toAbsoluteImageUrl = (src: string) => (src.startsWith('http') ? src : `${baseUrl}${src}`);
const faqItems = [
 { S: `${site.name} nerede?`, C: `${site.name}, ${site.location || 'Şanlıurfa'} konumunda yer almaktadır.` },
 { S: `${site.name} ziyaret saatleri nedir?`, C: site.visiting_hours || `${site.name} için ziyaret saatlerini sayfamızdan veya ilgili kurumdan öğrenebilirsiniz.` },
 { S: `${site.name} giriş ücreti var mı?`, C: site.entrance_fee || `${site.name} giriş ücreti için güncel bilgiyi sayfamızdan takip edebilirsiniz.` },
];
const visitLabels: Record<string, string> = { solo: 'Yalnız', couple: 'Çift', family: 'Aile', friends: 'Arkadaş', business: 'İş' };
const reviewAvg = siteReviews.length > 0 ? siteReviews.reduce((s: number, r: any) => s + r.rating, 0) / siteReviews.length : 0;
const historicalInfoRows = [
 { icon: 'lucide:clock', label: 'Çalışma Saatleri', value: site.opening_hours || '08:00 - 18:00' },
 { icon: 'lucide:ticket', label: 'Giriş Ücreti', value: site.entry_fee || 'Ücretsiz' },
 { icon: 'lucide:map-pin', label: 'Konum', value: site.location || 'Şanlıurfa' },
 { icon: 'lucide:camera', label: 'Fotoğraf', value: 'Ücretsiz çekim yapılabilir' },
];
---

<DetailTemplate
 seo={seo}
 breadcrumbItems={[
  { href: '/', label: 'Ana Sayfa' },
  { href: '/tarihi-yerler', label: 'Tarihi Yerler' },
  { label: site.name },
 ]}
>
 <style is:inline>
 .ts-section-title{font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-weight:600;color:var(--public-text);margin-bottom:.85rem}
 .ts-desc{font-size:.9rem;color:var(--public-muted);line-height:1.85;margin:0}
 .ts-directions-btn{width:100%;padding:.75rem;background:var(--public-accent);color:#fff;border:none;cursor:pointer;font-size:.85rem;font-weight:600;display:flex;align-items:center;justify-content:center;gap:.5rem;margin-top:1.25rem;text-decoration:none;letter-spacing:.05em;transition:background .15s}
 .ts-directions-btn:hover{background:var(--public-accent-strong);color:#fff}
 .ts-sidebar-divider{border:none;border-top:1px solid rgba(184,115,51,.1);margin:1rem 0}
 .ts-reviews{margin-top:2.5rem}
 .ts-reviews-title{font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:600;color:var(--public-text);margin-bottom:1.25rem;display:flex;align-items:center;gap:.5rem}
 .ts-review-card{background:var(--public-card-bg);border:1px solid var(--public-border);border-radius:8px;padding:1rem 1.25rem;margin-bottom:.85rem}
 .ts-review-header{display:flex;align-items:center;gap:.75rem;margin-bottom:.5rem}
 .ts-review-avatar{width:36px;height:36px;border-radius:50%;background:var(--public-accent);color:#fff;font-weight:700;display:flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0}
 .ts-review-name{font-weight:600;font-size:.85rem;color:var(--public-text)}
 .ts-review-date{font-size:.75rem;color:var(--public-muted);margin-top:.1rem}
 .ts-review-stars{display:flex;gap:2px;margin-left:auto}
 .ts-review-star{color:#CE8E38;font-size:.9rem}
 .ts-review-star.empty{color:var(--public-border)}
 .ts-review-content{font-size:.86rem;color:var(--public-text-soft);line-height:1.75}
 .ts-visit-badge{display:inline-block;font-size:.7rem;padding:.2rem .5rem;border-radius:20px;background:rgba(44,122,82,.1);color:#2C7A52;font-weight:600;margin-top:.5rem;letter-spacing:.04em}
 .ts-avg-rating{display:flex;align-items:baseline;gap:.5rem;margin-bottom:1.25rem}
 .ts-avg-score{font-size:2.5rem;font-weight:700;color:var(--public-accent);line-height:1}
 .ts-avg-label{font-size:.8rem;color:var(--public-muted)}
 </style>

 <PublicDetailHero
  imageSrc={primaryHistoricalImage}
  imageAlt={site.name}
  title={site.name}
  subtitle={site.short_description || site.location}
  badges={historicalHeroBadges}
  metaItems={[
   { label: String(site.location || 'Şanlıurfa'), icon: 'lucide:map-pin' },
  ]}
 />

 <PublicDetailBody compactSidebar>
 <div>
 <h2 class="ts-section-title">Hakkında</h2>
 <p class="ts-desc" set:html={linkifyContent(String(site.description || ''), `/tarihi-yerler/${site.slug}`)} />

 {galleryImages.length > 1 && (
 <div style="margin-top:2.5rem">
 <PublicMediaGallery items={galleryImages.slice(1)} altBase={site.name} />
 </div>
 )}

 <PublicFaqList items={faqItems} />

 {siteReviews.length > 0 && (
  <div class="ts-reviews">
   <h2 class="ts-reviews-title">
    <Icon name="lucide:star" style="width:1.2rem;height:1.2rem;color:var(--public-accent)" />
    Ziyaretçi Yorumları
   </h2>
   <div class="ts-avg-rating">
    <span class="ts-avg-score">{reviewAvg.toFixed(1)}</span>
    <div>
     <div class="ts-review-stars" style="margin-bottom:.2rem">
      {[1,2,3,4,5].map(n => <span class={n <= Math.round(reviewAvg) ? 'ts-review-star' : 'ts-review-star empty'}>★</span>)}
     </div>
     <span class="ts-avg-label">{siteReviews.length} ziyaretçi yorumu</span>
    </div>
   </div>
   {siteReviews.map((r: any) => {
    const initials = (r.full_name || 'Z').split(' ').map((w: string) => w[0]).join('').substring(0, 2).toUpperCase();
    const date = new Date(r.created_at).toLocaleDateString('tr-TR', { year: 'numeric', month: 'long' });
    return (
    <div class="ts-review-card">
     <div class="ts-review-header">
      <div class="ts-review-avatar">{initials}</div>
      <div>
       <div class="ts-review-name">{r.full_name || 'Ziyaretçi'}</div>
       <div class="ts-review-date">{date}</div>
      </div>
      <div class="ts-review-stars">
       {[1,2,3,4,5].map(n => <span class={n <= r.rating ? 'ts-review-star' : 'ts-review-star empty'}>★</span>)}
      </div>
     </div>
     <p class="ts-review-content">{r.content}</p>
     {r.visit_type && <span class="ts-visit-badge">{visitLabels[r.visit_type] || r.visit_type}</span>}
    </div>
    );
   })}
  </div>
 )}
 </div>

 <Fragment slot="sidebar">
 <PublicSidebarCard eyebrow="Ziyaret Bilgileri">
 <PublicInfoRows rows={historicalInfoRows} />

 {site.latitude && site.longitude && (
 <>
 <hr class="ts-sidebar-divider" />
 <a
 href={`https://www.google.com/maps/dir/?api=1&destination=${site.latitude},${site.longitude}`}
 target="_blank"
 rel="noopener"
 class="ts-directions-btn"
 >
 <Icon name="lucide:navigation" style="width:1rem;height:1rem" />
 Yol Tarifi Al
 </a>
 </>
 )}
 </PublicSidebarCard>

 {siteReviews.length > 0 && (
 <PublicSidebarCard eyebrow="Ziyaretçi Puanı">
  <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:.5rem">
   <span style="font-size:2rem;font-weight:700;color:var(--public-accent)">{reviewAvg.toFixed(1)}</span>
   <div>
    <div style="display:flex;gap:2px;font-size:.9rem;color:#CE8E38">
     {[1,2,3,4,5].map(n => <span>{n <= Math.round(reviewAvg) ? '★' : '☆'}</span>)}
    </div>
    <span style="font-size:.75rem;color:var(--public-muted)">{siteReviews.length} yorum</span>
   </div>
  </div>
 </PublicSidebarCard>
 )}

 {nearbySites && nearbySites.length > 0 && (
 <PublicSidebarCard eyebrow="Diğer Tarihi Yerler">
 <PublicRelatedList
  title="Yakındaki Yerler"
  items={nearbySites.map((place: any) => ({
   href: `/tarihi-yerler/${place.slug}`,
   title: place.name,
   meta: place.location || undefined,
  }))}
 />
 </PublicSidebarCard>
 )}
 </Fragment>

 <!-- Yayın bilgisi (GSC transparency) -->
 <div style="margin-top:2rem;padding:1rem 1.25rem;background:rgba(184,115,51,.05);border-left:3px solid var(--public-accent);border-radius:.25rem;font-size:.82rem;color:var(--public-muted);line-height:1.7">
  <p style="margin:0 0 .25rem">
   <strong style="color:var(--public-text)">Yazar:</strong> Sanliurfa.com Editöryel Ekibi
   {site.updated_at && (
    <>
     {' · '}<strong style="color:var(--public-text)">Son güncelleme:</strong> <time datetime={site.updated_at}>{new Date(site.updated_at).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' })}</time>
    </>
   )}
  </p>
  <p style="margin:0;font-size:.76rem">Yerel araştırma + yerinde inceleme. Hata bildirimi: <a href="mailto:iletisim@sanliurfa.com" style="color:var(--public-accent)">iletisim@sanliurfa.com</a> · <a href="/kunye" style="color:var(--public-accent)">Yayın bilgileri</a></p>
 </div>
 </PublicDetailBody>

 <PublicStickyCTA
   shareUrl={`${baseUrl}/tarihi-yerler/${site.slug}`}
   shareTitle={site.name}
 />

 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'LandmarksOrHistoricalBuildings',
 name: site.name,
 description: site.short_description || site.description,
 url: `${baseUrl}/tarihi-yerler/${site.slug}`,
 image: toAbsoluteImageUrl(primaryHistoricalImage),
 address: {
 '@type': 'PostalAddress',
 addressLocality: 'Şanlıurfa',
 addressRegion: 'Şanlıurfa',
 addressCountry: 'TR',
 },
 geo: site.latitude && site.longitude ? {
 '@type': 'GeoCoordinates',
 latitude: site.latitude,
 longitude: site.longitude,
 } : undefined,
 containedInPlace: { '@type': 'City', name: 'Şanlıurfa', url: baseUrl },
 openingHours: site.visiting_hours || undefined,
 publicAccess: true,
 ...(siteReviews.length > 0 ? {
  aggregateRating: {
   '@type': 'AggregateRating',
   ratingValue: reviewAvg.toFixed(1),
   reviewCount: siteReviews.length,
   bestRating: 5,
   worstRating: 1,
  },
  review: siteReviews.slice(0, 5).map((r: any) => ({
   '@type': 'Review',
   author: { '@type': 'Person', name: r.full_name || 'Ziyaretçi' },
   reviewRating: {
    '@type': 'Rating',
    ratingValue: Math.max(1, Math.min(5, Number(r.rating) || 5)),
    bestRating: 5,
    worstRating: 1,
   },
   datePublished: r.created_at ? new Date(r.created_at).toISOString().slice(0, 10) : undefined,
   reviewBody: String(r.content || '').slice(0, 500),
  })),
 } : {}),
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'Tarihi Yerler', item: `${baseUrl}/tarihi-yerler` },
 { '@type': 'ListItem', position: 3, name: site.name, item: `${baseUrl}/tarihi-yerler/${site.slug}` },
 ],
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqItems.map((item) => ({
 '@type': 'Question',
 name: item.S,
 acceptedAnswer: { '@type': 'Answer', text: item.C },
 })),
 })} is:inline />
</DetailTemplate>
