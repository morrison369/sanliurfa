---
import { Icon } from 'astro-icon/components';
import Layout from '../../layouts/Layout.astro';
import Image from '../../components/Image.astro';
import { query } from '../../lib/postgres';
import { resolveContentImage } from '../../lib/content-images';
import { getSiteBranding } from '../../lib/site-branding';
import { logger } from '../../lib/logging';
const { baseUrl } = await getSiteBranding();

const queryParam = Astro.url.searchParams.get('q') || '';

let sql = "SELECT * FROM historical_sites WHERE status = 'active'";
const values: any[] = [];

if (queryParam) {
  sql += " AND (name ILIKE $1 OR description ILIKE $1 OR location ILIKE $1)";
  values.push(`%${queryParam}%`);
}

sql += " ORDER BY is_featured DESC, created_at DESC";

let sites: any[] = [];
try {
  const result = await query(sql, values);
  sites = result.rows;
} catch (e) {
  logger.error('Error loading tarihi yerler', e instanceof Error ? e : new Error(String(e)));
}

const seo = {
  title: 'Tarihi Yerler - Şanlıurfa\'nın Zengin Tarihi',
  description: 'Göbeklitepe, Harran, Balıklıgöl ve daha fazlası. Şanlıurfa\'nın binlerce yıllık tarihi mirasını keşfedin.',
  ogImage: '/images/blog/urfa-tarihi.webp',
  keywords: ['şanlıurfa tarihi yerler', 'göbeklitepe ziyaret', 'harran kümbet evleri', 'balıklıgöl', 'şanlıurfa kalesi', 'urfa tarihi', 'şanlıurfa arkeoloji', 'urfa müze'],
  canonical: '/tarihi-yerler',
};

const faqItems = [
  { S: 'Şanlıurfa\'da en önemli tarihi yerler hangileridir?', C: 'Göbeklitepe (MÖ 10.000), Harran Kümbet Evleri, Balıklıgöl (Hz. İbrahim\'in atıldığı havuz), Şanlıurfa Kalesi ve Mozaik Müzesi Şanlıurfa\'nın öne çıkan tarihi alanlarıdır.' },
  { S: 'Göbeklitepe\'ye nasıl gidilir?', C: 'Göbeklitepe, Şanlıurfa şehir merkezine yaklaşık 18 km uzaklıktadır. Oruca Antep yolu üzerinde yer alır; şehir merkezinden taksi veya özel araçla kolayca ulaşılabilir.' },
  { S: 'Harran Kümbet Evleri ziyaret saatleri nedir?', C: 'Harran antik kenti ve kümbet evleri gün boyu ziyarete açıktır. Güneş batışına yakın ve sabah erken saatler en uygun fotoğraf çekim zamanlarıdır.' },
];

const getHistoricalImage = (site: any) =>
  resolveContentImage({
    category: 'tarihi-yerler',
    slug: site?.slug,
    explicit: site?.images?.[0],
    placeholder: '/images/placeholder-historical.jpg',
  });
---

<Layout seo={seo}>
  <!-- Hero -->
  <div class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)] text-white py-16">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4 text-[#F5EDD6]">Tarihi Yerler</h1>
        <p class="text-xl text-[#9A8470] max-w-2xl mx-auto">
          Tarihin sıfır noktası Şanlıurfa'nın eşsiz mirasını keşfedin.
        </p>
        <div class="mt-8 max-w-2xl mx-auto">
          <form action="/tarihi-yerler" class="relative">
            <input
              type="search"
              name="q"
              value={queryParam}
              placeholder="Tarihi yer ara..."
              class="w-full pl-12 pr-4 py-4 rounded-sm bg-white/10 backdrop-blur-sm text-white placeholder-white/60 border border-white/20 focus:outline-none focus:border-white/40"
            />
            <Icon name="lucide:search" class="w-5 h-5 absolute left-4 top-1/2 -translate-y-1/2 text-white/60" />
          </form>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-[#FDFAF3]">
    <div class="container mx-auto px-4 py-12">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {sites.map((site) => (
          <article class="bg-white border border-[rgba(200,160,100,0.18)] rounded-sm overflow-hidden shadow-sm hover:shadow-md hover:border-urfa-300 transition-all group">
            <a href={`/tarihi-yerler/${site.slug}`}>
              <div class="relative aspect-[4/3] overflow-hidden bg-[rgba(200,160,100,0.08)]">
                <Image
                  src={getHistoricalImage(site)}
                  alt={site.name}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                  loading="lazy"
                  width={800}
                  height={600}
                />
                {site.is_unesco && (
                  <div class="absolute top-4 left-4">
                    <span class="px-2 py-0.5 bg-blue-600 text-white text-xs font-medium rounded-sm">UNESCO</span>
                  </div>
                )}
                {site.is_featured && (
                  <div class="absolute top-4 right-4">
                    <span class="px-2 py-0.5 bg-urfa-600 text-white text-xs font-medium rounded-sm">Öne Çıkan</span>
                  </div>
                )}
              </div>

              <div class="p-6">
                <h3 class="font-bold text-xl text-[#1A1008] group-hover:text-urfa-700 transition-colors">
                  {site.name}
                </h3>

                <div class="flex items-center gap-2 text-sm text-[#9A8470] mt-2">
                  <Icon name="lucide:map-pin" class="w-4 h-4" />
                  {site.location}
                </div>

                {site.period && (
                  <div class="flex items-center gap-2 text-sm text-[#9A8470] mt-1">
                    <Icon name="lucide:clock" class="w-4 h-4" />
                    {site.period}
                  </div>
                )}

                <p class="text-[#9A8470] mt-3 line-clamp-2">
                  {site.short_description || site.description}
                </p>

                <div class="flex items-center gap-4 mt-4 text-sm text-urfa-600 font-medium">
                  <span class="flex items-center gap-1">
                    <Icon name="lucide:camera" class="w-4 h-4" />
                    {site.images?.length || 0} fotoğraf
                  </span>
                  <span>Detaylar →</span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>

      {sites.length === 0 && (
        <div class="text-center py-16">
          <Icon name="lucide:search" class="w-16 h-16 text-[rgba(200,160,100,0.3)] mx-auto mb-4" />
          <h3 class="text-xl font-semibold text-[#1A1008] mb-2">Sonuç bulunamadı</h3>
          <p class="text-[#9A8470]">Farklı bir arama terimi deneyin.</p>
        </div>
      )}
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Şanlıurfa Tarihi Yerler',
    description: 'Şanlıurfa\'daki tarihi mekanlar, müzeler ve kültürel miras alanları.',
    url: `${baseUrl}/tarihi-yerler`,
    about: { '@type': 'City', name: 'Şanlıurfa' },
    itemListElement: sites.slice(0, 10).map((s: any, i: number) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'LandmarksOrHistoricalBuildings',
        name: s.name,
        url: `${baseUrl}/tarihi-yerler/${s.slug}`,
      },
    })),
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Tarihi Yerler', item: `${baseUrl}/tarihi-yerler` },
    ],
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: { '@type': 'Answer', text: item.C },
    })),
  })} is:inline />
</Layout>
