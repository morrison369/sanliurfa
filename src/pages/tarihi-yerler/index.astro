---
import { Icon } from 'astro-icon/components';
import Layout from '../../layouts/Layout.astro';
import Image from '../../components/Image.astro';
import PublicPageIntro from '../../components/public/PublicPageIntro.astro';
import { query } from '../../lib/postgres';
import { getCachedPublicRouteData } from '../../lib/public-route-cache';
import { getPublicAppUrl } from '../../lib/public-app-url';
import { logger } from '../../lib/logging';
import { resolveHistoricalImage } from '../../lib/public-image-resolvers';
const baseUrl = getPublicAppUrl();

const queryParam = Astro.url.searchParams.get('q') || '';

let sql = "SELECT * FROM historical_sites WHERE status = 'published'";
const values: any[] = [];

if (queryParam) {
 sql += " AND (name ILIKE $1 OR description ILIKE $1 OR location ILIKE $1)";
 values.push(`%${queryParam}%`);
}

sql += " ORDER BY is_featured DESC, created_at DESC";

let sites: any[] = [];
try {
 sites = await getCachedPublicRouteData(`page:tarihi-yerler:index:${queryParam || 'all'}`, async () => {
  const result = await query(sql, values);
  return result.rows;
 });
} catch (e) {
 logger.error('Error loading tarihi yerler', e instanceof Error ? e : new Error(String(e)));
}

const seo = {
 title: 'Tarihi Yerler - Şanlıurfa\'nın Zengin Tarihi',
 description: 'Göbeklitepe, Harran, Balıklıgöl ve daha fazlası. Şanlıurfa\'nın binlerce yıllık tarihi mirasını keşfedin.',
 ogImage: '/images/blog/urfa-tarihi.webp',
 keywords: ['şanlıurfa tarihi yerler', 'göbeklitepe ziyaret', 'harran kümbet evleri', 'balıklıgöl', 'şanlıurfa kalesi', 'urfa tarihi', 'şanlıurfa arkeoloji', 'urfa müze'],
 canonical: '/tarihi-yerler',
};

const faqItems = [
 { S: 'Şanlıurfa\'da en önemli tarihi yerler hangileridir?', C: 'Göbeklitepe (MÖ 10.000), Harran Kümbet Evleri, Balıklıgöl (Hz. İbrahim\'in atıldığı havuz), Şanlıurfa Kalesi ve Mozaik Müzesi Şanlıurfa\'nın öne çıkan tarihi alanlarıdır.' },
 { S: 'Göbeklitepe\'ye nasıl gidilir?', C: 'Göbeklitepe, Şanlıurfa şehir merkezine yaklaşık 18 km uzaklıktadır. Oruca Antep yolu üzerinde yer alır; şehir merkezinden taksi veya özel araçla kolayca ulaşılabilir.' },
 { S: 'Harran Kümbet Evleri ziyaret saatleri nedir?', C: 'Harran antik kenti ve kümbet evleri gün boyu ziyarete açıktır. Güneş batışına yakın ve sabah erken saatler en uygun fotoğraf çekim zamanlarıdır.' },
];

const getHistoricalImage = (site: any) => resolveHistoricalImage(site);
const historicalFallbacks = [
 '/images/blog/gobeklitepe.jpg',
 '/images/blog/balikligol.jpg',
 '/images/blog/urfa-kalesi.jpg',
 '/images/blog/halfeti.jpg',
 '/images/tarihi-yerler/harran-kumbet-evleri.jpg',
];
---

<Layout seo={seo}>
 <style is:inline>
 .ty-body{background:var(--bg);padding:3rem 0 5rem}
 .ty-grid{display:grid;gap:1.25rem;grid-template-columns:repeat(auto-fill,minmax(290px,1fr))}
 .ty-card{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);overflow:hidden;transition:border-color .15s}
 .ty-card:hover{border-color:var(--public-accent)}
 .ty-card-img{position:relative;aspect-ratio:4/3;overflow:hidden;background:rgba(184,115,51,.06)}
 .ty-card-img-el{width:100%;height:100%;object-fit:cover;transition:transform .5s}
 .ty-card:hover .ty-card-img-el{transform:scale(1.08)}
 .ty-badge{position:absolute;top:.65rem;left:.65rem;padding:.18rem .55rem;font-size:.68rem;font-weight:700;letter-spacing:.05em}
 .ty-badge-feat{position:absolute;top:.65rem;right:.65rem;padding:.18rem .55rem;font-size:.68rem;font-weight:700;letter-spacing:.05em}
 .ty-badge-unesco{background:#1d4ed8;color:#fff}
 .ty-badge-featured{background:var(--public-accent);color:#fff}
 .ty-card-body{padding:1.15rem 1.25rem}
 .ty-card-title{font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-weight:600;color:var(--public-text);margin-bottom:.5rem;transition:color .15s;line-height:1.3}
 .ty-card:hover .ty-card-title{color:var(--public-accent)}
 .ty-card-meta{display:flex;align-items:center;gap:.35rem;font-size:.75rem;color:var(--public-muted);margin-bottom:.2rem}
 .ty-card-desc{font-size:.78rem;color:var(--public-muted);line-height:1.65;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;margin-top:.5rem}
 .ty-card-foot{display:flex;align-items:center;gap:1rem;margin-top:.85rem;font-size:.75rem;color:var(--public-accent);font-weight:600}
 .ty-empty{text-align:center;padding:5rem 1rem}
 .ty-empty-icon{width:4rem;height:4rem;color:rgba(184,115,51,.2);margin:0 auto .75rem}
 .ty-empty h3{font-size:1.05rem;color:var(--public-muted);margin-bottom:.35rem}
 .ty-empty p{font-size:.82rem;color:var(--public-text-soft)}
 </style>

 <PublicPageIntro
 eyebrow="Şanlıurfa Tarih Rehberi"
 title="Tarihi Yerler"
 description="Tarihin sıfır noktası Şanlıurfa'nın eşsiz mirasını, arkeolojik alanlarını ve kültürel duraklarını keşfedin."
 searchAction="/tarihi-yerler"
 searchName="q"
 searchValue={queryParam}
 searchPlaceholder="Tarihi yer ara..."
 searchAriaLabel="Tarihi yer arama"
 quickAnswerTitle="Hızlı cevap"
 quickAnswerText="Göbeklitepe, Harran, Balıklıgöl ve Şanlıurfa Kalesi şehirde ilk görülmesi gereken tarihi alanlardır."
 actions={[
  { href: '/tarihi-yerler/gobeklitepe', label: 'Göbeklitepe' },
  { href: '/tarihi-yerler/harran-kubbeli-evler', label: 'Harran' },
  { href: '/tarihi-yerler/balikligol', label: 'Balıklıgöl' },
 ]}
 />

 <!-- Grid -->
 <div class="ty-body">
 <div class="sf-container">
 <div class="ty-grid">
 {sites.map((site) => (
 <article class="ty-card">
 <a href={`/tarihi-yerler/${site.slug}`}>
 <div class="ty-card-img">
 <Image
 src={getHistoricalImage(site) || historicalFallbacks[Math.abs(Number(site.id || 0)) % historicalFallbacks.length]}
 alt={site.name}
 class="ty-card-img-el"
 loading="lazy"
 width={800}
 height={600}
 />
 {site.is_unesco && <span class="ty-badge ty-badge-unesco">UNESCO</span>}
 {site.is_featured && <span class="ty-badge-feat ty-badge-featured">Öne Çıkan</span>}
 </div>
 <div class="ty-card-body">
 <h3 class="ty-card-title">{site.name}</h3>
 <p class="ty-card-meta"><Icon name="lucide:map-pin" style="width:.85rem;height:.85rem" />{site.location}</p>
 {site.period && <p class="ty-card-meta"><Icon name="lucide:clock" style="width:.85rem;height:.85rem" />{site.period}</p>}
 <p class="ty-card-desc">{site.short_description || site.description}</p>
 <div class="ty-card-foot">
 <span style="display:flex;align-items:center;gap:.3rem"><Icon name="lucide:camera" style="width:.8rem;height:.8rem" />{site.images?.length || 0} fotoğraf</span>
 <span>Detaylar →</span>
 </div>
 </div>
 </a>
 </article>
 ))}
 </div>

 {sites.length === 0 && (
 <div class="ty-empty">
 <Icon name="lucide:search" class="ty-empty-icon" />
 <h3>Sonuç bulunamadı</h3>
 <p>Farklı bir arama terimi deneyin.</p>
 </div>
 )}
 </div>
 </div>

 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'CollectionPage',
 name: 'Şanlıurfa Tarihi Yerler',
 description: 'Şanlıurfa\'daki tarihi mekanlar, müzeler ve kültürel miras alanları.',
 url: `${baseUrl}/tarihi-yerler`,
 about: { '@type': 'City', name: 'Şanlıurfa' },
 itemListElement: sites.slice(0, 10).map((s: any, i: number) => ({
 '@type': 'ListItem',
 position: i + 1,
 item: {
 '@type': 'LandmarksOrHistoricalBuildings',
 name: s.name,
 url: `${baseUrl}/tarihi-yerler/${s.slug}`,
 },
 })),
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'Tarihi Yerler', item: `${baseUrl}/tarihi-yerler` },
 ],
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqItems.map((item) => ({
 '@type': 'Question',
 name: item.S,
 acceptedAnswer: { '@type': 'Answer', text: item.C },
 })),
 })} is:inline />
</Layout>
