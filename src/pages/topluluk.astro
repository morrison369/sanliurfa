---

import Layout from '../layouts/Layout.astro';
import { SocialFeatures } from '../components/SocialFeatures';
import { requireAuth } from '../lib/auth';
import { getSiteBranding } from '../lib/site-branding';
const { baseUrl } = await getSiteBranding();

const auth = await requireAuth(Astro.request);
const isAuthenticated = Boolean(auth.user);

const seo = {
  title: 'Şanlıurfa Topluluk Özellikleri | Takip, Mesajlaşma ve Trendler',
  description:
    'Şanlıurfa topluluk sayfasında aktivite akışı, trend etiketler, takipçi yönetimi, mesajlaşma ve eşleşme özellikleri.',
  keywords: ['şanlıurfa topluluk', 'urfa sosyal ağ', 'şanlıurfa üyeler', 'urfa yerel sosyal', 'şanlıurfa takip et'],
  ogImage: '/images/hero/hero-home.webp',
  canonical: '/topluluk',
};

const cards = [
  {
    title: 'Takipçi Ağı',
    desc: 'Kullanıcıları takip edin, profil etkileşimini artırın.',
    href: isAuthenticated ? '/takipciler' : '/kayit?redirect=/takipciler',
  },
  {
    title: 'Mesajlaşma',
    desc: 'Topluluk üyeleriyle doğrudan mesajlaşma deneyimi.',
    href: isAuthenticated ? '/mesajlar' : '/kayit?redirect=/mesajlar',
  },
  {
    title: 'Eşleşme',
    desc: '4 fotoğraflı profil ile sağa/sola kaydırarak üyelerle eşleşin.',
    href: '/eslesme',
  },
  {
    title: 'Üyelik ve Planlar',
    desc: 'İlk aşama ücretsiz erişim ve gelecek premium plan detaylarını inceleyin.',
    href: '/fiyatlandirma',
  },
];

const faqItems = [
  {
    S: 'Şanlıurfa topluluk özellikleri ücretsiz mi?',
    C: 'İlk aşamada takip, mesajlaşma, mekan ekleme, yorum ve eşleşme özellikleri ücretsiz olarak açık tutulur.',
  },
  {
    S: 'Üyeler birbirine mesaj atabilir mi?',
    C: 'Evet. Kayıtlı üyeler mesajlaşma akışı üzerinden birbirleriyle doğrudan iletişim kurabilir.',
  },
  {
    S: 'Eşleşme özelliğinde kaç fotoğraf kullanılabilir?',
    C: 'Eşleşme profilinde 4 fotoğrafa kadar görsel kullanılabilir ve üyeler sağa/sola kaydırma deneyimiyle eşleşebilir.',
  },
];
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50">
    <section class="bg-gradient-to-br from-indigo-900 to-slate-900 text-white py-14">
      <div class="container mx-auto px-4">
        <h1 class="text-4xl md:text-5xl font-bold">Şanlıurfa Topluluk Özellikleri</h1>
        <p class="mt-3 text-indigo-100 max-w-3xl">
          Şanlıurfa kullanıcı topluluğu için takip, trend ve etkileşim alanlarını tek sayfada yönetin.
        </p>
      </div>
    </section>

    <section class="py-10">
      <div class="container mx-auto px-4">
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
          {cards.map((card) => (
            <a
              href={card.href}
              class="rounded-2xl border border-gray-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"
            >
              <h2 class="text-lg font-bold text-gray-900">{card.title}</h2>
              <p class="mt-1 text-sm text-gray-600">{card.desc}</p>
            </a>
          ))}
        </div>

        {isAuthenticated ? (
          <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
            <h2 class="text-2xl font-bold text-gray-900 mb-2">Aktivite, Trend ve Takip</h2>
            <p class="text-sm text-gray-600 mb-6">
              Aşağıdaki modülde topluluk hareketlerini ve popüler etiketleri takip edebilirsiniz.
            </p>
            <SocialFeatures client:visible={{ rootMargin: '200px' }} />
          </div>
        ) : (
          <div class="rounded-3xl border border-indigo-100 bg-white p-7 shadow-sm">
            <p class="text-sm font-semibold uppercase tracking-wide text-indigo-700">Ücretsiz topluluk erişimi</p>
            <h2 class="mt-2 text-3xl font-bold text-gray-900">Takip, mesajlaşma ve eşleşme için ücretsiz hesap açın</h2>
            <p class="mt-3 max-w-2xl text-gray-600">
              Topluluk özellikleri ilk aşamada ücretsizdir. Hesap açtıktan sonra kullanıcıları takip edebilir,
              mesajlaşabilir, mekan ekleyebilir, yorum yapabilir ve eşleşme modülünü kullanabilirsiniz.
            </p>
            <div class="mt-5 flex flex-wrap gap-3">
              <a href="/kayit?redirect=/topluluk" class="rounded-xl bg-indigo-700 px-5 py-3 font-semibold text-white hover:bg-indigo-800">
                Ücretsiz Hesap Aç
              </a>
              <a href="/giris?redirect=/topluluk" class="rounded-xl border border-gray-300 px-5 py-3 font-semibold text-gray-800 hover:bg-gray-50">
                Giriş Yap
              </a>
              <a href="/eslesme" class="rounded-xl border border-indigo-200 px-5 py-3 font-semibold text-indigo-800 hover:bg-indigo-50">
                Eşleşme Modülünü Gör
              </a>
            </div>
          </div>
        )}

        <section class="mt-8 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
          <p class="text-sm font-semibold uppercase tracking-wide text-indigo-700">Hızlı Cevap</p>
          <h2 class="mt-1 text-2xl font-bold text-gray-900">Şanlıurfa topluluk platformunda neler yapılır?</h2>
          <p class="mt-2 max-w-3xl text-sm leading-6 text-gray-600">
            Üyeler birbirini takip edebilir, arkadaş olarak ekleyebilir, mesaj atabilir, mekan ekleyebilir,
            mekanlara puan ve yorum bırakabilir. Eşleşme modülünde 4 fotoğraflı profil ile sağa/sola kaydırma deneyimi sunulur.
          </p>
        </section>
      </div>
    </section>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.C,
      },
    })),
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Topluluk', item: `${baseUrl}/topluluk` },
    ],
  })} is:inline />
</Layout>
