---
import { Icon } from 'astro-icon/components';
import Layout from '../../layouts/Layout.astro';
import { query } from '../../lib/postgres';
import { getPublicAppUrl } from '../../lib/public-app-url';
import FeaturedFoods from '../../components/food/FeaturedFoods.astro';
import Image from '../../components/Image.astro';
import { logger } from '../../lib/logging';
import { resolvePlaceImage } from '../../lib/public-image-resolvers';
import PublicFaqList from '../../components/public/PublicFaqList.astro';
import { getCachedPublicRouteData } from '../../lib/public-route-cache';
const baseUrl = getPublicAppUrl();

let restaurants: any[] = [];
let restaurantCount = 0;

try {
 const data = await getCachedPublicRouteData('page:gastronomi:index:v2', async () => {
  const [result, countResult] = await Promise.all([
  query(`
   SELECT p.*, c.name AS cat_name FROM places p
   LEFT JOIN categories c ON p.category_id = c.id
   WHERE p.status = 'active'
     AND (
       c.parent_id = (SELECT id FROM categories WHERE slug = 'yeme-icme' LIMIT 1)
       OR c.slug = 'yeme-icme'
       OR p.category = 'restaurant'
     )
   ORDER BY p.rating DESC NULLS LAST, p.review_count DESC NULLS LAST
   LIMIT 6
  `),
  query(`
   SELECT COUNT(*) FROM places p
   LEFT JOIN categories c ON p.category_id = c.id
   WHERE p.status = 'active'
     AND (
       c.parent_id = (SELECT id FROM categories WHERE slug = 'yeme-icme' LIMIT 1)
       OR c.slug = 'yeme-icme'
       OR p.category = 'restaurant'
     )
  `),
  ]);
  return {
   restaurants: result.rows,
   restaurantCount: parseInt(countResult.rows[0]?.count || '0'),
  };
 });
 restaurants = data.restaurants;
 restaurantCount = data.restaurantCount;
} catch (e) {
 logger.error('Error loading gastronomi:', e instanceof Error ? e : new Error(String(e)));
}

const seo = {
 title: 'Gastronomi Rehberi - Urfa Lezzetleri',
 description: 'Şanlıurfa mutfağının eşsiz lezzetlerini keşfedin. Ciğer kebabı, çiğ köfte, isot ve daha fazlası.',
 keywords: ['urfa mutfağı', 'şanlıurfa gastronomi', 'urfa kebabı', 'şanlıurfa yemekleri', 'urfa çiğ köfte', 'şanlıurfa isot', 'urfa lezzetleri', 'şanlıurfa yöresel yemekler'],
 ogImage: '/images/blog/sanliurfa-lezzetler-2026.webp',
 canonical: '/gastronomi',
};

const faqItems = [
 {
  S: "Şanlıurfa'nın en meşhur yemekleri neler?",
  C: "Şanlıurfa mutfağının başında çiğ köfte, Urfa kebabı, tandır ciğeri, lahmacun ve borani gelmektedir. İsot (kurutulmuş kırmızı biber) Urfa mutfağının vazgeçilmez lezzetidir; kebaptan çorbalara kadar pek çok yemekte bölgeye özgü bu baharat belirleyici bir rol üstlenir.",
 },
 {
  S: 'Şanlıurfa mutfağı neden ünlüdür?',
  C: "Mezopotamya'nın merkezinde yer alan Şanlıurfa, binlerce yıllık yemek kültürüne ev sahipliği yapar. Baharatlı et yemekleri, tahıl bazlı tarifler ve yöresel tatlılarıyla UNESCO Gastronomi Şehri adayları arasındadır. Yöresel ürünler ve geleneksel tarif aktarımı kültürel mirasın canlı bir parçasıdır.",
 },
 {
  S: "Şanlıurfa'da isot nereden alınır?",
  C: "İsot, Şanlıurfa'nın kapalı çarşısı ve tarihi Gümrük Hanı çevresindeki aktarlardan ve yöresel ürün dükkanlarından satın alınabilir. Hasat sonrası kurutulup öğütülen isot'u taze veya yağda işlenmiş olarak tercih edebilirsiniz; her iki formda da şehrin pek çok pazarında kolayca bulunur.",
 },
 {
  S: "Şanlıurfa'da gastronomi turu için en iyi zaman ne zaman?",
  C: "İlkbahar ve sonbahar ayları Şanlıurfa gastronomi turu için en uygun mevsimdir. Açık hava lezzetlerini ve pazar atmosferini birlikte yaşamak için Mart–Mayıs ile Eylül–Kasım dönemleri önerilir. Yaz aylarında ise geleneksel sıra gecelerinde yöresel yemek kültürünü daha samimi bir ortamda deneyimleyebilirsiniz.",
 },
];
---

<Layout seo={seo}>
 <style is:inline>
 .gs-hero{position:relative;overflow:hidden;border-bottom:1px solid rgba(184,115,51,0.12);padding:clamp(3rem,6vw,5rem) 0;background:radial-gradient(circle at 18% 0%,rgba(212,151,24,0.10) 0%,transparent 42%),radial-gradient(circle at 82% 100%,rgba(44,122,82,0.08) 0%,transparent 40%),linear-gradient(180deg,#fbf6ec 0%,#f4ecd8 58%,#fbf6ec 100%)}
 .gs-hero-inner{max-width:52rem;margin:0 auto}
 .gs-eyebrow{font-size:.7rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--public-muted);margin-bottom:.75rem}
 .gs-badge{display:inline-flex;align-items:center;gap:.5rem;padding:.4rem 1rem;background:rgba(184,115,51,.08);border:1px solid rgba(184,115,51,.18);font-size:.82rem;color:var(--public-accent);margin-bottom:1.5rem}
 .gs-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(2.5rem,6vw,4rem);font-weight:600;color:var(--public-text);margin-bottom:1.5rem;line-height:1.15}
 .gs-h1-sub{color:var(--public-accent)}
 .gs-sub{font-size:.95rem;color:var(--public-muted);max-width:38rem;line-height:1.8;margin-bottom:2rem}
 .gs-hero-btns{display:flex;flex-wrap:wrap;gap:1rem;margin-bottom:3rem}
 .gs-btn-primary{display:inline-flex;align-items:center;gap:.5rem;padding:.7rem 1.5rem;background:var(--public-accent);color:var(--public-text);font-size:.85rem;font-weight:600;transition:background .15s,color .15s}
 .gs-btn-primary:hover{background:var(--public-accent-strong);color:#fff}
 .gs-btn-ghost{display:inline-flex;align-items:center;gap:.5rem;padding:.7rem 1.5rem;background:transparent;border:1px solid rgba(192,87,31,.35);color:var(--public-text);font-size:.85rem;font-weight:600;transition:background .15s,border-color .15s}
 .gs-btn-ghost:hover{background:rgba(192,87,31,.08);border-color:rgba(192,87,31,.6)}
 .gs-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:1.5rem}
 .gs-stat-val{font-size:2.25rem;font-weight:700;color:var(--public-text)}
 .gs-stat-label{font-size:.8rem;color:var(--public-muted)}
 .gs-section{padding:3rem 0}
 .gs-section-header{text-align:center;max-width:36rem;margin:0 auto 2.5rem}
 .gs-section-eyebrow{display:inline-flex;align-items:center;gap:.4rem;font-size:.82rem;color:var(--public-accent);font-weight:600;margin-bottom:.4rem}
 .gs-section-title{font-family:'Cormorant Garamond',serif;font-size:1.85rem;font-weight:600;color:var(--public-text)}
 .gs-section-sub{font-size:.82rem;color:var(--public-muted);margin-top:.35rem}
 .gs-restaurants{border-top:1px solid rgba(184,115,51,.12);background:var(--bg-card);padding:3rem 0}
 .gs-restaurants-header{display:flex;flex-wrap:wrap;align-items:flex-end;justify-content:space-between;gap:1rem;margin-bottom:2.5rem}
 .gs-restaurants-title{font-family:'Cormorant Garamond',serif;font-size:1.85rem;font-weight:600;color:var(--public-text)}
 .gs-restaurants-sub{font-size:.82rem;color:var(--public-muted);max-width:36rem;margin-top:.35rem}
 .gs-all-link{display:inline-flex;align-items:center;gap:.4rem;padding:.5rem 1rem;border:1px solid rgba(184,115,51,.25);color:var(--public-muted);font-size:.8rem;transition:border-color .15s,color .15s;flex-shrink:0}
 .gs-all-link:hover{border-color:var(--public-accent);color:var(--public-accent)}
 .gs-rest-grid{display:grid;gap:1rem;grid-template-columns:repeat(auto-fill,minmax(280px,1fr))}
 .gs-rest-card{background:var(--bg);border:1px solid rgba(184,115,51,.14);overflow:hidden;transition:border-color .15s}
 .gs-rest-card:hover{border-color:var(--public-accent)}
 .gs-rest-img-wrap{position:relative;aspect-ratio:16/9;overflow:hidden}
 .gs-rest-img{width:100%;height:100%;object-fit:cover;transition:transform .5s}
 .gs-rest-card:hover .gs-rest-img{transform:scale(1.06)}
 .gs-rest-rating{position:absolute;top:.6rem;right:.6rem;display:flex;align-items:center;gap:.3rem;background:rgba(13,10,8,.85);padding:.2rem .55rem;font-size:.78rem;font-weight:600;color:var(--public-text)}
 .gs-rest-body{padding:1rem}
 .gs-rest-name{font-size:.92rem;font-weight:700;color:var(--public-text);margin-bottom:.25rem;transition:color .15s}
 .gs-rest-card:hover .gs-rest-name{color:var(--public-accent)}
 .gs-rest-addr{display:flex;align-items:center;gap:.3rem;font-size:.75rem;color:var(--public-accent);margin-bottom:.35rem}
 .gs-rest-reviews{font-size:.72rem;color:var(--public-text-soft)}
 .gs-empty{color:var(--public-muted);font-size:.85rem;padding:3rem 1rem;text-align:center}
 </style>

 <!-- Hero -->
 <div class="gs-hero">
 <div class="sf-container">
 <div class="gs-hero-inner">
 <p class="gs-eyebrow">Gastronomi Rehberi</p>
 <div class="gs-badge">
 <Icon name="lucide:chef-hat" style="width:1rem;height:1rem" />
 2029 Gastronomi Şehri Adayı
 </div>
 <h1 class="gs-h1">
 Şanlıurfa<br />
 <span class="gs-h1-sub">Gastronomi Rehberi</span>
 </h1>
 <p class="gs-sub">UNESCO Gastronomi Şehri adayı Şanlıurfa'nın dünyaca ünlü mutfağını keşfedin.</p>
 <div class="gs-hero-btns">
 <a href="#yemekler" class="gs-btn-primary">
 Lezzetleri Keşfet
 <Icon name="lucide:arrow-right" style="width:1rem;height:1rem" />
 </a>
 <a href="#restoranlar" class="gs-btn-ghost">En İyi Restoranlar</a>
 </div>
 <div class="gs-stats">
 <div>
 <div class="gs-stat-val">100+</div>
 <div class="gs-stat-label">Yöresel Yemek</div>
 </div>
 <div>
 <div class="gs-stat-val">{restaurantCount}+</div>
 <div class="gs-stat-label">Restoran</div>
 </div>
 <div>
 <div class="gs-stat-val">12</div>
 <div class="gs-stat-label">Yıllık Festival</div>
 </div>
 <div>
 <div class="gs-stat-val">4.9</div>
 <div class="gs-stat-label">Ortalama Puan</div>
 </div>
 </div>
 </div>
 </div>
 </div>

 <!-- Yöresel Lezzetler -->
 <section id="yemekler" class="gs-section" style="background:var(--bg)">
 <div class="sf-container">
 <div class="gs-section-header">
 <div class="gs-section-eyebrow">
 <Icon name="lucide:utensils" style="width:1rem;height:1rem" />
 Yöresel Lezzetler
 </div>
 <h2 class="gs-section-title">Efsane Lezzetler</h2>
 <p class="gs-section-sub">Şanlıurfa mutfağının vazgeçilmez lezzetlerini keşfedin.</p>
 </div>

 <FeaturedFoods />
 </div>
 </section>

 <!-- Restoranlar -->
 <section id="restoranlar" class="gs-restaurants">
 <div class="sf-container">
 <div class="gs-restaurants-header">
 <div>
 <div class="gs-section-eyebrow">
 <Icon name="lucide:chef-hat" style="width:1rem;height:1rem" />
 Restoranlar
 </div>
 <h2 class="gs-restaurants-title">En İyi Restoranlar</h2>
 <p class="gs-restaurants-sub">Usta ellerden çıkan, geleneksel tariflerle hazırlanan lezzetleri sunan en iyi restoranlar.</p>
 </div>
 <a href="/mekanlar?category=restaurant" class="gs-all-link">
 Tüm Restoranları Gör
 <Icon name="lucide:arrow-right" style="width:.9rem;height:.9rem" />
 </a>
 </div>

 <div class="gs-rest-grid">
 {restaurants?.map((restaurant) => (
 <a href={`/isletme/${restaurant.slug}`} class="gs-rest-card">
 <div class="gs-rest-img-wrap">
<Image
 src={resolvePlaceImage(restaurant)}
 alt={restaurant.name}
 class="gs-rest-img"
 loading="lazy"
 width={480}
 height={270}
 />
 <div class="gs-rest-rating">
 <Icon name="lucide:star" style="width:.85rem;height:.85rem;color:var(--public-accent)" />
 {restaurant.rating || '4.5'}
 </div>
 </div>
 <div class="gs-rest-body">
 <p class="gs-rest-name">{restaurant.name}</p>
 <p class="gs-rest-addr">
 <Icon name="lucide:map-pin" style="width:.75rem;height:.75rem" />
 {restaurant.address}
 </p>
 <p class="gs-rest-reviews">{restaurant.review_count || 0} değerlendirme</p>
 </div>
 </a>
 ))}
 {(!restaurants || restaurants.length === 0) && (
 <p class="gs-empty">Henüz restoran bulunmuyor.</p>
 )}
 </div>
 </div>
 </section>

 {faqItems.length > 0 && (
  <section style="padding:0 0 3rem;background:var(--bg)">
   <div class="sf-container">
    <PublicFaqList items={faqItems} />
   </div>
  </section>
 )}

 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'ItemList',
 name: 'Şanlıurfa Gastronomi Rehberi',
 description: "Şanlıurfa'nın en iyi restoranları, kebapçıları ve yöresel lezzetleri",
 url: `${baseUrl}/gastronomi`,
 itemListElement: restaurants.slice(0, 10).map((r: any, i: number) => ({
 '@type': 'ListItem',
 position: i + 1,
 item: {
 '@type': 'Restaurant',
 name: r.name,
 url: `${baseUrl}/isletme/${r.slug}`,
 address: { '@type': 'PostalAddress', addressLocality: 'Şanlıurfa', addressCountry: 'TR' },
 },
 })),
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'Gastronomi', item: `${baseUrl}/gastronomi` },
 ],
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqItems.map((item) => ({
 '@type': 'Question',
 name: item.S,
 acceptedAnswer: { '@type': 'Answer', text: item.C },
 })),
 })} is:inline />
</Layout>
