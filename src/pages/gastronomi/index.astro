---
import { Icon } from 'astro-icon/components';
import Layout from '../../layouts/Layout.astro';
import { query } from '../../lib/postgres';
import { getSiteBranding } from '../../lib/site-branding';
import FeaturedFoods from '../../components/food/FeaturedFoods.astro';
import { logger } from '../../lib/logging';
const { baseUrl } = await getSiteBranding();

let restaurants: any[] = [];
let restaurantCount = 0;

try {
  const [result, countResult] = await Promise.all([
    query("SELECT * FROM places WHERE category = 'restaurant' AND status = 'active' ORDER BY rating DESC LIMIT 6"),
    query("SELECT COUNT(*) FROM places WHERE category = 'restaurant' AND status = 'active'"),
  ]);
  restaurants = result.rows;
  restaurantCount = parseInt(countResult.rows[0]?.count || '0');
} catch (e) {
  logger.error('Error loading gastronomi:', e instanceof Error ? e : new Error(String(e)));
}

const seo = {
  title: 'Gastronomi Rehberi - Urfa Lezzetleri',
  description: 'Şanlıurfa mutfağının eşsiz lezzetlerini keşfedin. Ciğer kebabı, çiğ köfte, isot ve daha fazlası.',
  keywords: ['urfa mutfağı', 'şanlıurfa gastronomi', 'urfa kebabı', 'şanlıurfa yemekleri', 'urfa çiğ köfte', 'şanlıurfa isot', 'urfa lezzetleri', 'şanlıurfa yöresel yemekler'],
  ogImage: '/images/blog/sanliurfa-lezzetler-2026.webp',
  canonical: '/gastronomi',
};

// Featured foods query moved to <FeaturedFoods server:defer> below.

const faqItems = [
  {
    S: 'Şanlıurfa\'nın en meşhur yemekleri neler?',
    C: 'Şanlıurfa mutfağının başında çiğ köfte, Urfa kebabı, tandır ciğeri, lahmacun ve borani gelmektedir. İsot (kurutulmuş kırmızı biber), Urfa mutfağının vazgeçilmez lezzetidir.',
  },
  {
    S: 'Şanlıurfa mutfağı neden ünlüdür?',
    C: 'Mezopotamya\'nın merkezinde yer alan Şanlıurfa, binlerce yıllık yemek kültürüne ev sahipliği yapar. Baharatlı et yemekleri, tahıl bazlı tarifler ve yöresel tatlılarıyla UNESCO Gastronomi Şehri adayları arasındadır.',
  },
  {
    S: 'Şanlıurfa\'da isot nereden alınır?',
    C: 'İsot, Şanlıurfa\'nın kapalı çarşısı ve tarihi Gümrük Hanı çevresindeki aktarlardan ve yöresel ürün dükkanlarından satın alınabilir.',
  },
];
---


<Layout seo={seo}>
  <div class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)] text-white py-24 lg:py-32">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-widest text-[#9A8470] mb-2">GASTRONOMİ REHBERİ</p>
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-[rgba(200,160,100,0.1)] border border-[rgba(200,160,100,0.2)] rounded-sm text-[#C4B49A] text-sm mb-6">
          <Icon name="lucide:chef-hat" class="w-5 h-5" />
          2029 Gastronomi Şehri Adayı
        </span>
        <h1 class="text-4xl lg:text-6xl font-display font-bold text-[#F5EDD6] mb-6">
          Şanlıurfa<br />
          <span class="text-[#C4B49A]">Gastronomi Rehberi</span>
        </h1>
        <p class="text-xl text-[#9A8470] mb-8 leading-relaxed">
          UNESCO Gastronomi Şehri adayı Şanlıurfa'nın dünyaca ünlü mutfağını keşfedin.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#yemekler" class="inline-flex items-center gap-2 px-6 py-3 bg-urfa-600 text-white rounded-sm font-medium hover:bg-urfa-700 transition-colors">
            Lezzetleri Keşfet
            <Icon name="lucide:arrow-right" class="w-5 h-5" />
          </a>
          <a href="#restoranlar" class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 text-white rounded-sm font-medium hover:bg-white/20 transition-colors">
            En İyi Restoranlar
          </a>
        </div>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 mt-16">
        <div class="text-center">
          <div class="text-4xl font-bold text-[#F5EDD6]">100+</div>
          <div class="text-[#9A8470]">Yöresel Yemek</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-[#F5EDD6]">{restaurantCount}+</div>
          <div class="text-[#9A8470]">Restoran</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-[#F5EDD6]">12</div>
          <div class="text-[#9A8470]">Yıllık Festival</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-[#F5EDD6]">4.9</div>
          <div class="text-[#9A8470]">Ortalama Puan</div>
        </div>
      </div>
    </div>
  </div>

  <section id="yemekler" class="py-12 bg-[#FDFAF3]">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <span class="inline-flex items-center gap-2 text-urfa-600 font-medium mb-2">
          <Icon name="lucide:utensils" class="w-5 h-5" />
          Yöresel Lezzetler
        </span>
        <h2 class="text-3xl font-bold text-[#1A1008]">Efsane Lezzetler</h2>
        <p class="text-[#9A8470] mt-2">
          Şanlıurfa mutfağının vazgeçilmez lezzetlerini keşfedin.
        </p>
      </div>

      <FeaturedFoods server:defer>
        <div slot="fallback" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="aspect-square bg-[rgba(200,160,100,0.08)] rounded-sm animate-pulse"></div>
          <div class="aspect-square bg-[rgba(200,160,100,0.08)] rounded-sm animate-pulse"></div>
          <div class="aspect-square bg-[rgba(200,160,100,0.08)] rounded-sm animate-pulse"></div>
          <div class="aspect-square bg-[rgba(200,160,100,0.08)] rounded-sm animate-pulse"></div>
        </div>
      </FeaturedFoods>
    </div>
  </section>

  <section id="restoranlar" class="py-12 bg-white border-t border-[rgba(200,160,100,0.14)]">
    <div class="container mx-auto px-4">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4 mb-10">
        <div>
          <span class="inline-flex items-center gap-2 text-urfa-600 font-medium mb-2">
            <Icon name="lucide:chef-hat" class="w-5 h-5" />
            Restoranlar
          </span>
          <h2 class="text-3xl font-bold text-[#1A1008]">En İyi Restoranlar</h2>
          <p class="text-[#9A8470] max-w-2xl mt-2">
            Usta ellerden çıkan, geleneksel tariflerle hazırlanan lezzetleri sunan en iyi restoranlar.
          </p>
        </div>
        <a href="/mekanlar?category=restaurant" class="inline-flex items-center gap-2 px-4 py-2 border border-[rgba(200,160,100,0.3)] text-[#6B5540] rounded-sm hover:bg-[rgba(200,160,100,0.06)] transition-colors">
          Tüm Restoranları Gör
          <Icon name="lucide:arrow-right" class="w-5 h-5" />
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {restaurants?.map((restaurant) => (
          <article class="bg-white rounded-sm overflow-hidden border border-[rgba(200,160,100,0.18)] shadow-sm hover:shadow-md hover:border-urfa-300 transition-all group">
            <a href={`/isletme/${restaurant.slug}`}>
              <div class="relative aspect-video overflow-hidden">
                <img
                  src={restaurant.images?.[0] || '/images/placeholder-place.jpg'}
                  alt={restaurant.name}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                  loading="lazy"
                />
                <div class="absolute top-3 right-3">
                  <div class="flex items-center gap-1 bg-white/90 px-2 py-1 rounded-sm">
                    <Icon name="lucide:star" class="w-4 h-4 text-yellow-400 fill-current" />
                    <span class="font-semibold text-sm text-[#1A1008]">{restaurant.rating || '4.5'}</span>
                  </div>
                </div>
              </div>
              <div class="p-5">
                <h3 class="font-semibold text-[#1A1008] group-hover:text-urfa-700 transition-colors">
                  {restaurant.name}
                </h3>
                <p class="text-sm text-urfa-600 mt-1 flex items-center gap-1">
                  <Icon name="lucide:map-pin" class="w-4 h-4" />
                  {restaurant.address}
                </p>
                <p class="text-sm text-[#9A8470] mt-2">
                  {restaurant.review_count || 0} değerlendirme
                </p>
              </div>
            </a>
          </article>
        ))}

        {(!restaurants || restaurants.length === 0) && (
          <div class="col-span-full text-center py-12 text-[#9A8470]">
            Henüz restoran bulunmuyor.
          </div>
        )}
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Şanlıurfa Gastronomi Rehberi',
    description: 'Şanlıurfa\'nın en iyi restoranları, kebapçıları ve yöresel lezzetleri',
    url: `${baseUrl}/gastronomi`,
    itemListElement: restaurants.slice(0, 10).map((r: any, i: number) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Restaurant',
        name: r.name,
        url: `${baseUrl}/isletme/${r.slug}`,
        address: { '@type': 'PostalAddress', addressLocality: 'Şanlıurfa', addressCountry: 'TR' },
      },
    })),
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Gastronomi', item: `${baseUrl}/gastronomi` },
    ],
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: { '@type': 'Answer', text: item.C },
    })),
  })} is:inline />
</Layout>
