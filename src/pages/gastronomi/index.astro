---
import Layout from '../../layouts/Layout.astro';
import { query } from '../../lib/postgres';

const icons = {
  Utensils: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>',
  Flame: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>',
  ChefHat: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 13.87V4a2 2 0 0 1 3.07-1.67c1.14-.36 2.4-.36 3.54 0A2 2 0 0 1 15.67 4v1.13c1.15.17 2.22.73 3.03 1.6a6 6 0 0 1-1.55 10.14V20a2 2 0 0 1-2 2H8.86a2 2 0 0 1-2-2v-3.13a6 6 0 0 1-1.55-10.14c.8-.87 1.88-1.43 3.03-1.6z"/><line x1="6" x2="18" y1="17" y2="17"/></svg>',
  Star: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>',
  MapPin: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 4.993-5.538 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 1 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>',
  ArrowRight: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>',
};

let restaurants: any[] = [];
let restaurantCount = 0;

try {
  const result = await query(
    "SELECT * FROM places WHERE category = 'restaurant' AND status = 'active' ORDER BY rating DESC LIMIT 6"
  );
  restaurants = result.rows;

  const countResult = await query(
    "SELECT COUNT(*) FROM places WHERE category = 'restaurant' AND status = 'active'"
  );
  restaurantCount = parseInt(countResult.rows[0]?.count || '0');
} catch (e) {
  console.error('Error loading gastronomi:', e);
}

const seo = {
  title: 'Gastronomi Rehberi - Urfa Lezzetleri',
  description: 'Şanlıurfa mutfağının eşsiz lezzetlerini keşfedin. Ciğer kebabı, çiğ köfte, isot ve daha fazlası.',
};

const featuredFoods = [
  {
    id: 'urfa-kebabi',
    name: 'Urfa Kebabı',
    description: 'Baharatlı kıymanın odun ateşinde pişirilmesiyle hazırlanan, dünyaca ünlü efsane lezzet.',
    image: '/images/foods/urfa-kebabi.jpg',
    isSpicy: false,
    difficulty: 'Zor',
    rating: 4.9,
  },
  {
    id: 'cig-kofte',
    name: 'Çiğ Köfte',
    description: 'İsot ve bulgurun karataşta yoğrulmasıyla yapılan geleneksel lezzet. UNESCO Somut Olmayan Kültür Mirası.',
    image: '/images/foods/cig-kofte.jpg',
    isSpicy: true,
    difficulty: 'Çok Zor',
    rating: 4.8,
  },
  {
    id: 'isot',
    name: 'Urfa İsotu',
    description: 'Güneşte kurutulmuş, yağda kavrulmuş, Şanlıurfa\'ya özgü eşsiz baharat.',
    image: '/images/foods/isot.jpg',
    isSpicy: true,
    difficulty: 'Orta',
    rating: 4.9,
  },
  {
    id: 'sillik-tatlisi',
    name: 'Şıllık Tatlısı',
    description: 'Cevizli, kremalı geleneksel Urfa tatlısı. İnce hamur ve özel şerbetle hazırlanır.',
    image: '/images/foods/sillik-tatlisi.jpg',
    isSpicy: false,
    difficulty: 'Zor',
    rating: 4.7,
  },
];
---

<Layout seo={seo}>
  <section class="relative py-24 lg:py-32 bg-gradient-to-br from-urfa-800 to-urfa-900 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <img src="/images/foods/pattern.jpg" alt="" class="w-full h-full object-cover" />
    </div>
    <div class="relative container-custom">
      <div class="max-w-3xl">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-isot-500/20 rounded-full text-isot-300 text-sm mb-6">
          <span set:html={icons.ChefHat}></span>
          2029 Gastronomi Şehri Adayı
        </span>
        <h1 class="text-4xl lg:text-6xl font-display font-bold text-white mb-6">
          Şanlıurfa<br />
          <span class="text-urfa-200">Gastronomi Rehberi</span>
        </h1>
        <p class="text-xl text-urfa-100 mb-8 leading-relaxed">
          UNESCO Gastronomi Şehri adayı Şanlıurfa'nın dünyaca ünlü mutfağını keşfedin.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#yemekler" class="btn-accent">
            Lezzetleri Keşfet
            <span set:html={icons.ArrowRight}></span>
          </a>
          <a href="#restoranlar" class="btn bg-white/10 text-white hover:bg-white/20">
            En İyi Restoranlar
          </a>
        </div>
      </div>
      
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 mt-16">
        <div class="text-center">
          <div class="text-4xl font-bold text-white">100+</div>
          <div class="text-urfa-200">Yöresel Yemek</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-white">{restaurantCount}+</div>
          <div class="text-urfa-200">Restoran</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-white">12</div>
          <div class="text-urfa-200">Yıllık Festival</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-white">4.9</div>
          <div class="text-urfa-200">Ortalama Puan</div>
        </div>
      </div>
    </div>
  </section>
  
  <section id="yemekler" class="section bg-white dark:bg-gray-900">
    <div class="container-custom">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <span class="inline-flex items-center gap-2 text-isot-600 font-medium mb-2">
          <span set:html={icons.Utensils}></span>
          Yöresel Lezzetler
        </span>
        <h2 class="section-title dark:text-white">Efsane Lezzetler</h2>
        <p class="section-subtitle dark:text-gray-400">
          Şanlıurfa mutfağının vazgeçilmez lezzetlerini keşfedin.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {featuredFoods.map((food) => (
          <article class="card-hover bg-white dark:bg-gray-800 rounded-2xl overflow-hidden group">
            <a href={`/gastronomi/${food.id}`}>
              <div class="relative aspect-square overflow-hidden">
                <img 
                  src={food.image}
                  alt={food.name}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent" />
                
                {food.isSpicy && (
                  <div class="absolute top-3 left-3">
                    <span class="badge bg-isot-600 text-white flex items-center gap-1">
                      <span set:html={icons.Flame}></span>
                      Acılı
                    </span>
                  </div>
                )}
                
                <div class="absolute bottom-0 left-0 right-0 p-4">
                  <h3 class="font-display font-bold text-xl text-white">{food.name}</h3>
                  <div class="flex items-center gap-3 mt-2 text-sm text-white/80">
                    <span class="flex items-center gap-1">
                      <span set:html={icons.Star}></span>
                      {food.rating}
                    </span>
                    <span>â€¢</span>
                    <span>{food.difficulty}</span>
                  </div>
                </div>
              </div>
              <div class="p-4">
                <p class="text-gray-600 dark:text-gray-400 text-sm line-clamp-2">{food.description}</p>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
  
  <section id="restoranlar" class="section bg-gray-50 dark:bg-gray-800">
    <div class="container-custom">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4 mb-10">
        <div>
          <span class="inline-flex items-center gap-2 text-urfa-600 font-medium mb-2">
            <span set:html={icons.ChefHat}></span>
            Restoranlar
          </span>
          <h2 class="section-title dark:text-white">En İyi Restoranlar</h2>
          <p class="section-subtitle max-w-2xl dark:text-gray-400">
            Usta ellerden çıkan, geleneksel tariflerle hazırlanan lezzetleri sunan en iyi restoranlar.
          </p>
        </div>
        <a href="/places?category=restaurant" class="btn-outline inline-flex items-center gap-2">
          Tüm Restoranları Gör
          <span set:html={icons.ArrowRight}></span>
        </a>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {restaurants?.map((restaurant) => (
          <article class="card-hover bg-white dark:bg-gray-800 rounded-xl overflow-hidden group">
            <a href={`/places/${restaurant.slug}`}>
              <div class="relative aspect-video overflow-hidden">
                <img 
                  src={restaurant.images?.[0] || '/images/placeholder-place.jpg'}
                  alt={restaurant.name}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                  loading="lazy"
                />
                <div class="absolute top-3 right-3">
                  <div class="flex items-center gap-1 bg-white/90 dark:bg-gray-800/90 px-2 py-1 rounded-lg">
                    <span set:html={icons.Star}></span>
                    <span class="font-semibold text-sm text-gray-900 dark:text-white">{restaurant.rating || '4.5'}</span>
                  </div>
                </div>
              </div>
              <div class="p-5">
                <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-urfa-600 dark:group-hover:text-urfa-400 transition-colors">
                  {restaurant.name}
                </h3>
                <p class="text-sm text-urfa-600 dark:text-urfa-400 mt-1 flex items-center gap-1">
                  <span set:html={icons.MapPin}></span>
                  {restaurant.address}
                </p>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-2">
                  {restaurant.review_count || 0} değerlendirme
                </p>
              </div>
            </a>
          </article>
        ))}
        
        {(!restaurants || restaurants.length === 0) && (
          <div class="col-span-full text-center py-12 text-gray-500 dark:text-gray-400">
            Henüz restoran bulunmuyor.
          </div>
        )}
      </div>
    </div>
  </section>
</Layout>
