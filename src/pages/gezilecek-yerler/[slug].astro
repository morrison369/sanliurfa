---
import DetailTemplate from '../../components/templates/DetailTemplate.astro';
import PublicDetailHero from '../../components/public/PublicDetailHero.astro';
import PublicDetailBody from '../../components/public/PublicDetailBody.astro';
import PublicSidebarCard from '../../components/public/PublicSidebarCard.astro';
import PublicFaqList from '../../components/public/PublicFaqList.astro';
import PublicInfoGrid from '../../components/public/PublicInfoGrid.astro';
import PublicRelatedGrid from '../../components/public/PublicRelatedGrid.astro';
import PublicContentSection from '../../components/public/PublicContentSection.astro';
import PublicRichProse from '../../components/public/PublicRichProse.astro';
import PublicInfoRows from '../../components/public/PublicInfoRows.astro';
import { query, queryOne } from '../../lib/postgres';
import { getCachedPublicRouteData } from '../../lib/public-route-cache';
import { getPublicAppUrl } from '../../lib/public-app-url';
import { logger } from '../../lib/logging';
import { buildPageSeo } from '../../lib/seo/pageSeo';
import { resolveHistoricalImage } from '../../lib/public-image-resolvers';
const baseUrl = getPublicAppUrl();

const { slug } = Astro.params;
let site: any = null;
let relatedSites: any[] = [];

try {
 const data = await getCachedPublicRouteData(`page:gezilecek-yerler:detail:${slug || 'unknown'}`, async () => {
  const siteRow = await queryOne(
   "SELECT * FROM historical_sites WHERE slug = $1 AND status = 'published'",
   [slug]
  );
  if (!siteRow) return { site: null, relatedSites: [] };
  const related = await query(
   "SELECT id, name, slug, location, short_description FROM historical_sites WHERE status = 'published' AND id != $1 LIMIT 4",
   [siteRow.id]
  );
  return { site: siteRow, relatedSites: related.rows };
 });
 site = data.site;
 relatedSites = data.relatedSites;

 if (site) {
 } else {
 const categoryRedirects: Record<string, string> = {
 muzeler: '/tarihi-yerler',
 'tarihi-yerler': '/tarihi-yerler',
 };
 if (slug && categoryRedirects[String(slug)]) {
 return Astro.redirect(categoryRedirects[String(slug)]);
 }
 return Astro.redirect(
 ['gobeklitepe', 'balikligol', 'harran', 'halfeti', 'urfa-kalesi', 'ayna-carsi', 'kapali-carsi'].includes(String(slug))
 ? `/isletme/${slug}`
 : `/mekanlar/${slug}`,
 );
 }
} catch (e) {
 logger.error('Error:', e instanceof Error ? e : new Error(String(e)));
}

if (!site) return Astro.redirect('/gezilecek-yerler');

const getHistoricalImage = (item: any) =>
 resolveHistoricalImage({
  slug: item?.slug,
  image_url: item?.image_url ?? null,
  cover_image: item?.cover_image ?? null,
  image: item?.images?.[0] ?? null,
 });

const gzHistoricalImage = getHistoricalImage(site);
const seo = buildPageSeo({
 title: `${site.name} - Şanlıurfa Gezilecek Yerler`,
 description: site.short_description || site.description,
 ogImage: gzHistoricalImage.includes('placeholder') ? undefined : gzHistoricalImage,
 keywords: [site.name, site.name + ' şanlıurfa', 'şanlıurfa gezilecek yerler', 'urfa ' + site.name.toLowerCase()],
 canonical: `/tarihi-yerler/${Astro.params.slug}`,
});

const faqItems = [
 {
  S: `${site.name} nerede?`,
  C: `${site.name}, ${site.location || 'Şanlıurfa'} konumunda yer almaktadır. Tarihi alana ulaşmak için Şanlıurfa şehir merkezinden özel araç, taksi ya da tur servisleri tercih edilebilir. Konuma ait yol tarifi için sayfadaki harita bilgisini kullanabilirsiniz.`,
 },
 {
  S: `${site.name} ziyaret saatleri nedir?`,
  C: site.visiting_hours || `${site.name} ziyaret saatleri mevsim ve resmi tatil dönemlerine göre farklılık gösterebilir. Güncel açılış-kapanış saatleri için Kültür ve Turizm Bakanlığı'na veya yerel turizm danışma ofislerine başvurabilirsiniz.`,
 },
 {
  S: `${site.name} giriş ücreti var mı?`,
  C: site.entrance_fee || `${site.name} giriş ücreti vatandaş, öğrenci ve yabancı ziyaretçiler için farklılık gösterebilir. Müze Kart sahipleri ücretsiz ya da indirimli giriş imkânından yararlanabilir. Güncel tarife için Kültür ve Turizm Bakanlığı'nın resmi sitesini incelemenizi öneririz.`,
 },
 {
  S: `${site.name} nasıl gidilir?`,
  C: `${site.name} ziyareti için Şanlıurfa şehir merkezinden özel araç, taksi veya organize tur seçenekleri mevcuttur. Günübirlik tur programları, birden fazla tarihi mekanı tek güzergahta görme imkânı sunar. Toplu taşıma için Büyükşehir Belediyesi ulaşım hatlarını takip edebilirsiniz.`,
 },
];

const detailImagePool = [
 '/images/tarihi-yerler/harran-kumbet-evleri.jpg',
 '/images/blog/gobeklitepe.jpg',
 '/images/blog/balikligol.jpg',
 '/images/blog/halfeti.jpg',
 '/images/blog/urfa-kalesi.jpg',
];
const detailHeroImage = getHistoricalImage(site) || detailImagePool[Math.abs(Number(site.id || 0)) % detailImagePool.length];
---

<DetailTemplate
 seo={seo}
 breadcrumbItems={[
  { href: '/', label: 'Ana Sayfa' },
  { href: '/gezilecek-yerler', label: 'Gezilecek Yerler' },
  { label: site.name },
 ]}
>
 <style is:inline>
 .gd-qa-label{font-size:.7rem;text-transform:uppercase;letter-spacing:.16em;color:var(--public-text-soft);margin-bottom:.25rem}
 .gd-side-text{margin:0;color:var(--public-muted);line-height:1.7;font-size:.88rem}
 </style>

 <PublicDetailHero
  imageSrc={detailHeroImage}
  imageAlt={site.name}
  title={site.name}
  subtitle={site.short_description || site.location || 'Şanlıurfa gezi noktası'}
  badges={[{ label: 'Gezi Noktası', tone: 'dark' }]}
  metaItems={[
   ...(site.location ? [{ label: String(site.location), icon: 'lucide:map-pin' }] : []),
   ...(site.visiting_hours ? [{ label: String(site.visiting_hours), icon: 'lucide:clock-3' }] : []),
  ]}
 />

 <PublicDetailBody compactSidebar>
 <article>
 <PublicContentSection eyebrow="Şanlıurfa Gezi Noktası">
 <PublicRichProse>
  <h2>{site.name} Şanlıurfa Gezilecek Yerler</h2>
  {site.location && <p>📍 {site.location}</p>}
 </PublicRichProse>
 </PublicContentSection>

 <PublicContentSection title="Detaylı Bilgi">
  <PublicRichProse html={site.description || site.history || ''} />
 </PublicContentSection>

 <PublicInfoGrid
  items={[
   ...(site.visiting_hours ? [{ title: 'Ziyaret Saatleri', value: site.visiting_hours }] : []),
   ...(site.entrance_fee ? [{ title: 'Giriş Ücreti', value: site.entrance_fee }] : []),
  ]}
 />

 <PublicFaqList items={faqItems} />

 <PublicRelatedGrid
  title="Diğer Gezilecek Yerler"
  items={relatedSites.map((site) => ({
   href: `/gezilecek-yerler/${site.slug}`,
   title: site.name,
   description: site.short_description || site.location || undefined,
  }))}
 />
</article>
 <Fragment slot="sidebar">
  <PublicSidebarCard title="Ziyaret Özeti">
   <p class="gd-side-text">
    {site.short_description || site.location || `${site.name} için ziyaret özeti ve pratik bilgileri bu sayfada bulabilirsiniz.`}
   </p>
  </PublicSidebarCard>
  {(site.visiting_hours || site.entrance_fee) && (
   <PublicSidebarCard title="Pratik Bilgiler">
    <PublicInfoRows
     rows={[
      ...(site.visiting_hours ? [{ icon: 'lucide:clock-3', label: 'Ziyaret', value: site.visiting_hours }] : []),
      ...(site.entrance_fee ? [{ icon: 'lucide:ticket', label: 'Ücret', value: site.entrance_fee }] : []),
     ]}
    />
   </PublicSidebarCard>
  )}
 </Fragment>
 </PublicDetailBody>

 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'Gezilecek Yerler', item: `${baseUrl}/gezilecek-yerler` },
 { '@type': 'ListItem', position: 3, name: site.name, item: `${baseUrl}/gezilecek-yerler/${site.slug}` },
 ],
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'TouristAttraction',
 name: site.name,
 description: site.short_description || site.description,
 url: `${baseUrl}/gezilecek-yerler/${site.slug}`,
 image: (() => { const img = getHistoricalImage(site); return img.startsWith('http') ? img : `${baseUrl}${img}`; })(),
 address: {
 '@type': 'PostalAddress',
 addressLocality: site.location || 'Şanlıurfa',
 addressRegion: 'Şanlıurfa',
 addressCountry: 'TR',
 },
 containedInPlace: { '@type': 'City', name: 'Şanlıurfa', url: `${baseUrl}` },
 touristType: 'Kültür Turizmi',
 ...(site.visiting_hours ? { openingHours: site.visiting_hours } : {}),
 ...(site.entrance_fee ? { priceRange: site.entrance_fee } : {}),
 ...(site.latitude && site.longitude ? { geo: { '@type': 'GeoCoordinates', latitude: site.latitude, longitude: site.longitude } } : {}),
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqItems.map((item) => ({
 '@type': 'Question',
 name: item.S,
 acceptedAnswer: { '@type': 'Answer', text: item.C },
 })),
 })} is:inline />
</DetailTemplate>
