---
// Gezilecek yerler alt kategori veya site detay
// /gezilecek-yerler/gobeklitepe → historical_sites'dan veya categories'den
import Layout from '../../layouts/Layout.astro';
import { query, queryOne } from '../../lib/postgres';

const { slug } = Astro.params;
let site: any = null;
let relatedSites: any[] = [];

try {
  // Önce historical_sites'da ara
  site = await queryOne(
    "SELECT * FROM historical_sites WHERE slug = $1 AND status = 'active'",
    [slug]
  );

  if (site) {
    const related = await query(
      "SELECT id, name, slug, location, short_description FROM historical_sites WHERE status = 'active' AND id != $1 LIMIT 4",
      [site.id]
    );
    relatedSites = related.rows;
  } else {
    // Yoksa category olarak redirect et
    return Astro.redirect(`/mekanlar/${slug}`);
  }
} catch (e) {
  console.error('Error:', e);
}

if (!site) return Astro.redirect('/gezilecek-yerler');

const seo = {
  title: `${site.name} - Şanlıurfa Gezilecek Yerler`,
  description: site.short_description || site.description,
  image: site.cover_image || site.images?.[0],
};
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50">
    <div class="bg-white border-b">
      <div class="container mx-auto px-4 py-3">
        <nav class="flex items-center gap-2 text-sm text-gray-500">
          <a href="/" class="hover:text-red-600">Ana Sayfa</a><span>/</span>
          <a href="/gezilecek-yerler" class="hover:text-red-600">Gezilecek Yerler</a><span>/</span>
          <span class="text-gray-900 font-medium">{site.name}</span>
        </nav>
      </div>
    </div>

    <article class="container mx-auto px-4 py-8 max-w-4xl">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">{site.name}</h1>

      {site.location && <p class="text-gray-500 mb-6">📍 {site.location}</p>}

      {site.cover_image && (
        <img src={site.cover_image} alt={site.name} class="w-full rounded-2xl mb-8 shadow-lg" />
      )}

      <div class="prose prose-lg max-w-none" set:html={site.description || site.history || ''} />

      {/* Ziyaret Bilgileri */}
      <div class="grid md:grid-cols-2 gap-4 mt-8">
        {site.visiting_hours && (
          <div class="bg-white rounded-xl p-5 border">
            <h3 class="font-bold text-gray-900 mb-2">🕐 Ziyaret Saatleri</h3>
            <p class="text-gray-600">{site.visiting_hours}</p>
          </div>
        )}
        {site.entrance_fee && (
          <div class="bg-white rounded-xl p-5 border">
            <h3 class="font-bold text-gray-900 mb-2">🎫 Giriş Ücreti</h3>
            <p class="text-gray-600">{site.entrance_fee}</p>
          </div>
        )}
      </div>

      {/* İlgili Yerler */}
      {relatedSites.length > 0 && (
        <div class="mt-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Diğer Gezilecek Yerler</h2>
          <div class="grid md:grid-cols-2 gap-4">
            {relatedSites.map((r) => (
              <a href={`/gezilecek-yerler/${r.slug}`} class="bg-white rounded-xl p-5 border hover:shadow-lg transition-all group">
                <h3 class="font-bold text-gray-900 group-hover:text-amber-600">{r.name}</h3>
                <p class="text-sm text-gray-500 mt-1">{r.short_description || r.location}</p>
              </a>
            ))}
          </div>
        </div>
      )}
    </article>
  </div>
</Layout>
