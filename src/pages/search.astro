---
const target = new URL('/arama', Astro.url);
const query = Astro.url.searchParams.get('q') || Astro.url.searchParams.get('query');

if (query) {
  target.searchParams.set('q', query);
}

return new Response(null, {
  status: 301,
  headers: {
    Location: `${target.pathname}${target.search}`,
  },
});
---
