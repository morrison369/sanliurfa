---

// Category Detail Page
import { Icon } from 'astro-icon/components';
import Layout from '../../layouts/Layout.astro';
import { getPlaces } from '../../lib/places/db';
import { query } from '../../lib/postgres';
import OptimizedImage from '../../components/OptimizedImage.astro';
import { getSiteBranding } from '../../lib/site-branding';
import { logger } from '../../lib/logging';
const { baseUrl } = await getSiteBranding();

const { slug } = Astro.params;
if (!slug) {
  return Astro.redirect('/');
}

let catRow: any = null;
let places: any[] = [];

try {
  const catResult = await query(
    `SELECT id, slug, name, description, icon, is_active FROM categories WHERE slug = $1`,
    [slug]
  );
  catRow = catResult.rows[0];
} catch (e) {
  logger.error('Category query failed:', e instanceof Error ? e : new Error(String(e)));
}

if (!catRow) {
  return Astro.redirect('/404');
}

const category = {
  ...catRow,
  metaDescription: catRow.description,
};

try {
  const result = await getPlaces({ category: slug, status: 'active', limit: 50, sortBy: 'rating' });
  places = result.places;
} catch (e) {
  logger.error('Places query failed:', e instanceof Error ? e : new Error(String(e)));
}

const seo = {
  title: `${category.name} - Şanlıurfa Rehberi`,
  description: category.metaDescription || `${category.name} kategorisindeki en iyi mekanları keşfedin. ${places.length}+ mekan, yorumlar ve puanlamalar.`,
  keywords: ['şanlıurfa ' + category.name.toLowerCase(), 'urfa ' + category.name.toLowerCase(), category.name + ' listesi'],
  ogImage: '/images/hero/hero-home.webp',
  canonical: `/kategori/${Astro.params.slug}`,
};
const faqItems = [
  { S: `Şanlıurfa'da ${category.name.toLowerCase()} kategorisinde hangi mekanlar var?`, C: `${category.name} kategorisindeki tüm aktif mekanlar puan ve öne çıkarılma durumuna göre listelenmektedir.` },
  { S: `${category.name} mekanlarına nasıl yorum yazabilirim?`, C: 'Mekan sayfasına girerek kullanıcı hesabınızla değerlendirme bırakabilirsiniz.' },
  { S: `Yeni bir ${category.name.toLowerCase()} mekanı ekleyebilir miyim?`, C: 'İşletme Ekle sayfasından ücretsiz başvuru yapabilirsiniz. Onaylanan mekanlar rehberde yayımlanır.' },
];
---

<Layout seo={seo}>
  <div class="min-h-screen bg-[#FDFAF3]">
    <!-- Breadcrumb -->
    <div class="bg-[#FDFAF3] border-b border-[rgba(200,160,100,0.14)]">
      <div class="container mx-auto px-4 py-3">
        <nav class="flex items-center gap-2 text-sm text-[#9A8470]">
          <a href="/" class="hover:text-urfa-600">Ana Sayfa</a>
          <span>/</span>
          <span class="text-[#1A1008] font-medium">{category.name}</span>
        </nav>
      </div>
    </div>

    <!-- Hero -->
    <div class="bg-[rgba(200,160,100,0.04)] border-b border-[rgba(200,160,100,0.14)] py-12">
      <div class="container mx-auto px-4">
        <h1 class="text-4xl md:text-5xl font-bold text-[#1A1008] mb-4">{category.name}</h1>
        <p class="text-xl text-[#6B5540] max-w-2xl">{category.description}</p>

        <div class="flex items-center gap-6 mt-6">
          <span class="text-[#9A8470]">
            <strong class="text-[#1A1008]">{places.length}</strong> mekan
          </span>
          <span class="text-[#9A8470]">
            <strong class="text-[#1A1008]">{places.filter(p => p.rating >= 4).length}</strong> yüksek puanlı
          </span>
        </div>
      </div>
    </div>

    <!-- Filters & Results -->
    <div class="py-12">
      <div class="container mx-auto px-4">
        <div class="flex flex-col lg:flex-row gap-8">
          <!-- Sidebar Filters -->
          <aside class="lg:w-64 flex-shrink-0">
            <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6 sticky top-4">
              <h3 class="font-bold text-lg text-[#1A1008] mb-4">Filtreler</h3>

              <!-- Price Range -->
              <div class="mb-6">
                <h4 class="font-medium text-[#1A1008] mb-2">Fiyat Aralığı</h4>
                <div class="space-y-2">
                  {['₺', '₺₺', '₺₺₺', '₺₺₺₺'].map((price, i) => (
                    <label class="flex items-center gap-2 cursor-pointer">
                      <input type="checkbox" name="price" value={i} class="rounded-sm border-[rgba(200,160,100,0.3)]" />
                      <span class="text-[#4A3828]">{price}</span>
                    </label>
                  ))}
                </div>
              </div>

              <!-- Rating -->
              <div class="mb-6">
                <h4 class="font-medium text-[#1A1008] mb-2">Puan</h4>
                <div class="space-y-2">
                  {[5, 4, 3].map(rating => (
                    <label class="flex items-center gap-2 cursor-pointer">
                      <input type="checkbox" name="rating" value={rating} class="rounded-sm border-[rgba(200,160,100,0.3)]" />
                      <div class="flex text-yellow-400 text-sm">
                        {'★'.repeat(rating)}
                        <span class="text-[rgba(200,160,100,0.25)]">{'★'.repeat(5 - rating)}</span>
                      </div>
                      <span class="text-[#9A8470] text-sm">ve üzeri</span>
                    </label>
                  ))}
                </div>
              </div>

              <!-- Features -->
              <div class="mb-6">
                <h4 class="font-medium text-[#1A1008] mb-2">Özellikler</h4>
                <div class="space-y-2">
                  {['WiFi', 'Otopark', 'Engelli Erişimi', 'Açık Alan'].map(feature => (
                    <label class="flex items-center gap-2 cursor-pointer">
                      <input type="checkbox" name="feature" value={feature} class="rounded-sm border-[rgba(200,160,100,0.3)]" />
                      <span class="text-[#4A3828] text-sm">{feature}</span>
                    </label>
                  ))}
                </div>
              </div>

              <button
                onclick="applyFilters()"
                class="w-full py-2 bg-urfa-600 text-white rounded-sm hover:bg-urfa-700 transition-colors text-sm font-semibold"
              >
                Filtrele
              </button>
            </div>
          </aside>

          <!-- Results -->
          <div class="flex-1">
            <!-- Sort -->
            <div class="flex justify-between items-center mb-6">
              <p class="text-[#6B5540]">{places.length} sonuç bulundu</p>
              <select id="sort" onchange="sortResults()" class="px-4 py-2 border border-[rgba(200,160,100,0.3)] rounded-sm text-[#1A1008] bg-white text-sm">
                <option value="rating">En Yüksek Puan</option>
                <option value="popular">En Popüler</option>
                <option value="newest">En Yeni</option>
                <option value="name">İsim (A-Z)</option>
              </select>
            </div>

            <!-- Places Grid -->
            {places.length > 0 ? (
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {places.map(place => (
                  <a href={`/isletme/${place.slug}`} class="group">
                    <article class="bg-white rounded-sm overflow-hidden border border-[rgba(200,160,100,0.18)] shadow-sm hover:shadow-md hover:border-urfa-300 transition-all flex flex-col md:flex-row">
                      <div class="md:w-2/5 h-48 md:h-auto bg-[rgba(200,160,100,0.08)]">
                        {place.thumbnail ? (
                          <OptimizedImage
                            src={place.thumbnail}
                            alt={place.name}
                            width={400}
                            height={300}
                            class="w-full h-full object-cover group-hover:scale-105 transition-transform"
                            loading="lazy"
                          />
                        ) : (
                          <div class="w-full h-full flex items-center justify-center text-[#9A8470] text-4xl">
                            📍
                          </div>
                        )}
                      </div>
                      <div class="md:w-3/5 p-5">
                        <div class="flex items-center justify-between mb-2">
                          <span class="text-xs text-[#9A8470] uppercase tracking-wider">{category.name}</span>
                          {place.is_verified && (
                            <Icon name="lucide:badge-check" class="w-5 h-5 text-urfa-600" />
                          )}
                        </div>

                        <h3 class="font-bold text-lg text-[#1A1008] group-hover:text-urfa-700 transition-colors">{place.name}</h3>

                        <div class="flex items-center gap-2 mt-2">
                          <div class="flex text-yellow-400">
                            {'★'.repeat(Math.floor(place.rating || 0))}
                            <span class="text-[rgba(200,160,100,0.25)]">{'★'.repeat(5 - Math.floor(place.rating || 0))}</span>
                          </div>
                          <span class="text-sm text-[#9A8470]">{place.rating?.toFixed(1) || '-'}</span>
                          <span class="text-sm text-[#9A8470]">({place.review_count} yorum)</span>
                        </div>

                        <p class="text-[#6B5540] text-sm mt-2 line-clamp-2">{place.short_description}</p>

                        <div class="flex items-center gap-4 mt-4 text-sm text-[#9A8470]">
                          {place.price_range && (
                            <span class="font-medium text-[#1A1008]">{place.price_range}</span>
                          )}
                          {place.address && (
                            <span class="truncate">{place.address}</span>
                          )}
                        </div>

                        {place.features && place.features.length > 0 && (
                          <div class="flex flex-wrap gap-2 mt-3">
                            {place.features.slice(0, 3).map((feature: string) => (
                              <span class="px-2 py-1 bg-[rgba(200,160,100,0.1)] text-[#6B5540] text-xs rounded-sm">
                                {feature}
                              </span>
                            ))}
                          </div>
                        )}
                      </div>
                    </article>
                  </a>
                ))}
              </div>
            ) : (
              <div class="text-center py-16">
                <div class="text-6xl mb-4">🔍</div>
                <h3 class="text-xl font-bold text-[#1A1008] mb-2">Mekan Bulunamadı</h3>
                <p class="text-[#9A8470]">Bu kategoride henüz mekan eklenmemiş.</p>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: `${category.name} - Şanlıurfa Rehberi`,
    description: category.metaDescription || `${category.name} kategorisindeki mekanlar.`,
    url: `${baseUrl}/kategori/${slug}`,
    about: { '@type': 'City', name: 'Şanlıurfa' },
    itemListElement: places.slice(0, 10).map((p: any, i: number) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'LocalBusiness',
        '@id': `${baseUrl}/isletme/${p.slug}`,
        name: p.name,
        url: `${baseUrl}/isletme/${p.slug}`,
        ...(p.rating ? { aggregateRating: { '@type': 'AggregateRating', ratingValue: p.rating, bestRating: 5 } } : {}),
      },
    })),
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Mekanlar', item: `${baseUrl}/mekanlar` },
      { '@type': 'ListItem', position: 3, name: category.name, item: `${baseUrl}/kategori/${slug}` },
    ],
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: { '@type': 'Answer', text: item.C },
    })),
  })} is:inline />
</Layout>
