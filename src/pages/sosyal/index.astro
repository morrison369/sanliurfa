---
import Layout from '../../layouts/Layout.astro';
import ActivityFeed from '../../components/ActivityFeed';
import UserSuggestionsPanel from '../../components/UserSuggestionsPanel';
import HashtagExplorer from '../../components/HashtagExplorer';

// Auth check
const userId = Astro.locals.user?.id;
if (!userId) {
  return Astro.redirect('/giris?redirect=/sosyal');
}

// Get initial hashtag from URL params
const initialTag = Astro.url.searchParams.get('tag') || undefined;
---

<Layout seo={{ title: "Sosyal - Şanlıurfa", noIndex: true }}>
  <div class="min-h-screen bg-[#FDFAF3]">
    <div class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)] text-white py-12">
      <div class="container mx-auto px-4">
        <p class="text-sm font-semibold uppercase tracking-widest text-[#9A8470] mb-2">Şanlıurfa Platformu</p>
        <h1 class="text-4xl font-bold text-[#F5EDD6] mb-2">Sosyal</h1>
        <p class="text-[#C4B49A]">Şanlıurfa sosyal akışı, trend konular ve kullanıcı önerileri</p>
      </div>
    </div>

    <div class="container mx-auto px-4 py-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {/* Left Sidebar */}
        <div class="space-y-6">
          <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
            <h2 class="text-lg font-semibold text-[#1A1008] mb-4">
              Sizi Tanıyabileceğiniz Kişiler
            </h2>
            <UserSuggestionsPanel client:visible={{ rootMargin: '140px' }} />
          </div>
        </div>

        {/* Main Content */}
        <div class="lg:col-span-2">
          {/* Tab Bar */}
          <div class="flex gap-4 border-b border-[rgba(200,160,100,0.14)] mb-6">
            <button
              data-tab-btn="feed"
              class="px-4 py-2 font-semibold text-[#1A1008] border-b-2 border-urfa-600"
            >
              Aktivite Akışı
            </button>
            <button
              data-tab-btn="hashtag"
              class="px-4 py-2 font-semibold text-[#9A8470] border-b-2 border-transparent hover:text-[#1A1008]"
            >
              Hashtag Keşfet
            </button>
          </div>

          {/* Tab Content */}
          <div id="tab-feed" class="tab-content space-y-4">
            <ActivityFeed client:visible={{ rootMargin: '120px' }} userId={userId} />
          </div>

          <div id="tab-hashtag" class="tab-content hidden">
            <HashtagExplorer client:idle initialSlug={initialTag} />
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    {
      // Tab switching logic
      const tabButtons = document.querySelectorAll('[data-tab-btn]');

      tabButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          const tabName = btn.getAttribute('data-tab-btn');

          // Hide all tabs
          document.querySelectorAll('.tab-content').forEach(el => {
            el.classList.add('hidden');
          });

          // Remove active styles from all buttons
          tabButtons.forEach(b => {
            b.classList.remove('border-urfa-600', 'text-[#1A1008]');
            b.classList.add('border-transparent', 'text-[#9A8470]');
          });

          // Show selected tab
          const selectedTab = document.getElementById(`tab-${tabName}`);
          if (selectedTab) {
            selectedTab.classList.remove('hidden');
          }

          // Style selected button
          btn.classList.remove('border-transparent', 'text-[#9A8470]');
          btn.classList.add('border-urfa-600', 'text-[#1A1008]');
        });
      });

      // If hashtag tab is selected via initialTag, switch to it
      if (document.location.search.includes('tag=')) {
        const hashtagBtn = document.querySelector('[data-tab-btn="hashtag"]');
        if (hashtagBtn) {
          hashtagBtn.click();
        }
      }
    }
  </script>
</Layout>
