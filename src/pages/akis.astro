---
/**
 * Activity Feed Page
 * Show personalized feed of activity from followed users
 */

import Layout from '../layouts/Layout.astro';
import ActivityFeed from '../components/ActivityFeed';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/giris?redirect=/akis');
}
---

<Layout seo={{ title: "Aktivite Akışı - Sanliurfa.com", noIndex: true }}>
  <div class="min-h-screen bg-[#FDFAF3]">
    <div class="container mx-auto px-4 py-8">
      <div class="mb-8">
        <h1 class="text-3xl font-bold text-[#1A1008]">Aktivite Akışı</h1>
        <p class="text-[#9A8470] mt-2">Takip ettiğin kullanıcıların aktivitelerini gör</p>
      </div>

      <ActivityFeed client:visible={{ rootMargin: '130px' }} userId={Astro.locals.user.id} />
    </div>
  </div>
</Layout>
