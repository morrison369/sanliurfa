---
import Layout from "../layouts/Layout.astro";
import WebhookManager from "../components/WebhookManager";
import WebhookAnalyticsDashboard from "../components/WebhookAnalyticsDashboard";
import AuthFeatureLanding from "../components/AuthFeatureLanding.astro";

const user = Astro.locals.user;

const authToken = Astro.cookies.get("auth-token")?.value || "";
---

<Layout title="Webhook entegrasyonları" noindex>
  {
    !user ? (
      <AuthFeatureLanding
        eyebrow="Geliştirici entegrasyonları"
        title="sanliurfa.com olaylarını kendi sistemlerinize bağlayın"
        description="Mekân, yorum, kampanya ve bildirim olaylarını webhook altyapısıyla dış sistemlere aktarabilirsiniz. Bu alan işletme ve yönetim kullanıcıları için hesapla birlikte açılır."
        loginRedirect="/webhooks"
        features={[
          {
            title: "Olay tabanlı entegrasyon",
            description:
              "Mekân, yorum, kampanya ve abonelik olaylarını HTTPS uç noktalarına gönderin.",
          },
          {
            title: "İmzalı istekler",
            description:
              "Webhook istekleri gizli anahtar ve imza doğrulama modeliyle korunur.",
          },
          {
            title: "Teslimat takibi",
            description:
              "Başarılı ve başarısız teslimleri analitik panelinden izleyin.",
          },
        ]}
      />
    ) : (
      <div class="max-w-7xl mx-auto px-4 py-8">
        <div class="mb-8">
          <h1 class="text-4xl font-bold text-gray-900">
            Webhook entegrasyonları
          </h1>
          <p class="text-gray-600 mt-2">
            Uygulamalarınızı gerçek zamanlı olaylarla entegre edin.
          </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
          <div class="bg-gradient-to-br from-urfa-50 to-urfa-100 rounded-lg p-6 border border-urfa-200">
            <h3 class="font-semibold text-urfa-900 mb-2">Webhook nedir?</h3>
            <p class="text-sm text-urfa-800">
              Webhook kayıtları, belirli olaylar gerçekleştiğinde URL'nize HTTP
              POST istekleri göndererek sisteminizi güncel tutar.
            </p>
          </div>

          <div class="bg-gradient-to-br from-isot-50 to-isot-100 rounded-lg p-6 border border-isot-200">
            <h3 class="font-semibold text-isot-900 mb-2">Güvenlik</h3>
            <p class="text-sm text-isot-800">
              Webhook istekleri HMAC-SHA256 imzası ile doğrulanır. İmza başlığı
              istekle birlikte gönderilir.
            </p>
          </div>

          <div class="bg-gradient-to-br from-gray-50 to-gray-100 rounded-lg p-6 border border-gray-200">
            <h3 class="font-semibold text-gray-900 mb-2">
              Otomatik yeniden deneme
            </h3>
            <p class="text-sm text-gray-700">
              Başarısız teslimler kontrollü gecikmelerle yeniden denenir ve
              analitik panelinde izlenir.
            </p>
          </div>
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6 mb-8">
          <WebhookManager client:load userId={user.id} token={authToken} />
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6 mb-8">
          <WebhookAnalyticsDashboard client:load token={authToken} />
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">
            Başlangıç rehberi
          </h2>

          <div class="space-y-6">
            <div>
              <h3 class="text-lg font-semibold text-gray-900 mb-2">
                1. Webhook oluşturun
              </h3>
              <p class="text-gray-600 mb-2">
                Yukarıdaki “Yeni webhook” düğmesine tıklayarak olay türü, URL ve
                isteğe bağlı gizli anahtar bilgisini girin.
              </p>
              <div class="bg-gray-50 rounded p-3 text-sm font-mono">
                Event: place.created
                <br />
                URL: https://ornek-uygulama.com/webhooks/places
                <br />
                Secret: guclu-gizli-anahtar
              </div>
            </div>

            <div>
              <h3 class="text-lg font-semibold text-gray-900 mb-2">
                2. İmzayı doğrulayın
              </h3>
              <p class="text-gray-600 mb-2">
                Her webhook isteği imza başlığında HMAC-SHA256 imzası ile gelir.
              </p>
              <div class="bg-gray-50 rounded p-3 text-sm font-mono overflow-x-auto">
                const crypto = require('crypto');
                <br />
                const signature = crypto
                <br />
                &nbsp;&nbsp;.createHmac('sha256', secret)
                <br />
                &nbsp;&nbsp;.update(JSON.stringify(body))
                <br />
                &nbsp;&nbsp;.digest('hex');
              </div>
            </div>

            <div>
              <h3 class="text-lg font-semibold text-gray-900 mb-2">
                3. Deneme gönderin
              </h3>
              <p class="text-gray-600">
                Webhook listesinden kayıt seçerek “Deneme gönder” düğmesiyle
                örnek olay gönderin.
              </p>
            </div>

            <div>
              <h3 class="text-lg font-semibold text-gray-900 mb-2">
                4. Teslimatı izleyin
              </h3>
              <p class="text-gray-600">
                Analitikler sekmesinden webhook teslim oranını, başarısız
                olayları ve performans metriklerini izleyin.
              </p>
            </div>
          </div>

          <div class="mt-6 p-4 bg-urfa-50 rounded-lg border border-urfa-200">
            <p class="text-sm text-urfa-800">
              <strong>İpucu:</strong> Webhook URL'niz geçerli bir HTTPS adresi
              olmalı ve 200-299 arasında HTTP durum kodu döndürmelidir.
            </p>
          </div>
        </div>
      </div>
    )
  }
</Layout>
