---
import Layout from '../layouts/Layout.astro';
import WebhookManager from '../components/WebhookManager';
import WebhookAnalyticsDashboard from '../components/WebhookAnalyticsDashboard';

// Check if user is authenticated
const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/giris?redirect=/webhooks');
}

// Get auth token from session
const authToken = Astro.cookies.get('token')?.value || '';
---

<Layout seo={{ title: "Webhooks", noIndex: true }}>
  <div class="min-h-screen bg-[#FDFAF3]">
    <div class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)] text-white py-10">
      <div class="container mx-auto px-4">
        <p class="text-sm font-semibold uppercase tracking-widest text-[#9A8470] mb-2">ENTEGRASYON</p>
        <h1 class="text-3xl font-bold text-[#F5EDD6]">Webhooks</h1>
        <p class="text-[#9A8470] mt-1">Uygulamalarınızı gerçek zamanlı olaylarla entegre edin</p>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 py-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
        <div class="bg-[rgba(200,160,100,0.06)] border border-[rgba(200,160,100,0.2)] rounded-sm p-6">
          <h3 class="font-semibold text-[#1A1008] mb-2">Webhook Nedir?</h3>
          <p class="text-sm text-[#6B5540]">
            Webhooks, belirli olaylar gerçekleştiğinde URL'nize HTTP POST istekleri göndererek sisteminizi güncellenmiş tutar.
          </p>
        </div>

        <div class="bg-[rgba(200,160,100,0.06)] border border-[rgba(200,160,100,0.2)] rounded-sm p-6">
          <h3 class="font-semibold text-[#1A1008] mb-2">Güvenlik</h3>
          <p class="text-sm text-[#6B5540]">
            Tüm webhook istekleri HMAC-SHA256 imzası ile doğrulanır. X-Signature başlığında bulunur.
          </p>
        </div>

        <div class="bg-[rgba(200,160,100,0.06)] border border-[rgba(200,160,100,0.2)] rounded-sm p-6">
          <h3 class="font-semibold text-[#1A1008] mb-2">Otomatik Yeniden Deneme</h3>
          <p class="text-sm text-[#6B5540]">
            Başarısız teslimler otomatik olarak katlanarak artan gecikmelerle yeniden denenilir.
          </p>
        </div>
      </div>

      <!-- Webhook Manager -->
      <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6 mb-8">
        <WebhookManager client:visible token={authToken} />
      </div>

      <!-- Webhook Analytics Dashboard -->
      <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6 mb-8">
        <WebhookAnalyticsDashboard client:visible token={authToken} />
      </div>

      <!-- Documentation -->
      <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
        <h2 class="text-2xl font-bold text-[#1A1008] mb-6">Başlangıç Rehberi</h2>

        <div class="space-y-6">
          <div>
            <h3 class="text-lg font-semibold text-[#1A1008] mb-2">1. Webhook Oluşturun</h3>
            <p class="text-[#6B5540] mb-2">
              Yukarıdaki "Yeni Webhook" butonuna tıklayarak yeni webhook oluşturun.
              Olay türü, URL ve (isteğe bağlı) secret sağlayın.
            </p>
            <div class="bg-[rgba(200,160,100,0.04)] rounded-sm p-3 text-sm font-mono text-[#6B5540]">
              Event: place.created<br/>
              URL: https://sanliurfa.com/webhooks/places<br/>
              Secret: webhook-secret
            </div>
          </div>

          <div>
            <h3 class="text-lg font-semibold text-[#1A1008] mb-2">2. İmzayı Doğrulayın</h3>
            <p class="text-[#6B5540] mb-2">
              Her webhook isteği X-Signature başlığında HMAC-SHA256 imzası ile gelir.
            </p>
            <div class="bg-[rgba(200,160,100,0.04)] rounded-sm p-3 text-sm font-mono text-[#6B5540] overflow-x-auto">
              const crypto = require('crypto');<br/>
              const signature = crypto<br/>
              &nbsp;&nbsp;.createHmac('sha256', secret)<br/>
              &nbsp;&nbsp;.update(JSON.stringify(body))<br/>
              &nbsp;&nbsp;.digest('hex');
            </div>
          </div>

          <div>
            <h3 class="text-lg font-semibold text-[#1A1008] mb-2">3. Test Edin</h3>
            <p class="text-[#6B5540]">
              Webhook listesinden webhook seçerek "Test Et" butonuyla örnek olay gönderin.
            </p>
          </div>

          <div>
            <h3 class="text-lg font-semibold text-[#1A1008] mb-2">4. İzleyin</h3>
            <p class="text-[#6B5540]">
              "Analitikler" sekmesinden webhook teslim oranını, başarısız olayları ve performans metriklerini izleyin.
            </p>
          </div>
        </div>

        <div class="mt-6 p-4 bg-[rgba(200,160,100,0.06)] rounded-sm border border-[rgba(200,160,100,0.2)]">
          <p class="text-sm text-[#6B5540]">
            <strong class="text-[#1A1008]">İpucu:</strong> Webhook URL'niz geçerli bir HTTPS adresi olmalı ve 200-299 arasında HTTP durum kodu döndürmelidir.
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>
