---
import Layout from '../layouts/Layout.astro';
import CategoryHub from '../components/public/CategoryHub.astro';
import { CITY_TAXONOMY_CATEGORIES } from '../data/city-taxonomy';
import { getPublicAppUrl } from '../lib/public-app-url';
const category = CITY_TAXONOMY_CATEGORIES.find((item) => item.slug === 'hukuk-ve-finans')!;
const baseUrl = getPublicAppUrl();

const faqItems = [
 {
  S: "Şanlıurfa'da avukat nasıl bulunur?",
  C: "Hukuk ve Finans kategorisinde Şanlıurfa Barosu'na kayıtlı avukatlar ve hukuk büroları listelenmiştir. Uzmanlık alanına (aile hukuku, ceza, ticaret vb.) göre filtreleyerek uygun avukate ulaşabilirsiniz.",
 },
 {
  S: "Şanlıurfa'daki banka şubeleri nerede?",
  C: "Şanlıurfa genelindeki banka şubeleri ve ATM'ler adres ve telefon bilgileriyle Hukuk ve Finans kategorisinde yer almaktadır. İlçe bazında arama yaparak size en yakın şubeyi bulabilirsiniz.",
 },
 {
  S: "Şanlıurfa'da sigorta acentesi nasıl bulunur?",
  C: "Sigorta acenteleri ve şirket ofisleri Hukuk ve Finans kategorisinde listelenmektedir. Araç sigortası, sağlık sigortası ve konut sigortası gibi hizmet türlerine göre arama yapabilirsiniz.",
 },
];
---
<Layout seo={{ title: 'Şanlıurfa Hukuk ve Finans Rehberi | Avukat, Banka ve Sigorta', description: category.description, canonical: '/hukuk-ve-finans' }}>
 <style is:inline>
 details summary{list-style:none}
 details summary::-webkit-details-marker{display:none}
 details[open] .faq-arrow{transform:rotate(180deg)}
 </style>
 <CategoryHub category={category} />
 {faqItems.length > 0 && (
 <div style="padding:2rem 0 3rem;border-top:1px solid rgba(184,115,51,.12)">
 <div class="sf-container">
 <h2 style="font-size:1.25rem;font-weight:700;color:#1F1410;margin-bottom:1.25rem">Sık Sorulan Sorular</h2>
 <div style="display:flex;flex-direction:column;gap:.75rem">
 {faqItems.map((item) => (
 <details style="background:var(--bg-card);border:1px solid rgba(184,115,51,.14);border-radius:.375rem;overflow:hidden">
 <summary style="padding:1rem 1.25rem;font-weight:600;color:#1F1410;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:1rem">
 {item.S}
 <span style="flex-shrink:0;color:#B87333;font-size:1.25rem;transition:transform .2s" class="faq-arrow">▾</span>
 </summary>
 <div style="padding:.75rem 1.25rem 1rem;color:#4A3828;font-size:.95rem;line-height:1.7;border-top:1px solid rgba(184,115,51,.08)">
 {item.C}
 </div>
 </details>
 ))}
 </div>
 </div>
 </div>
 )}
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqItems.map((item) => ({
 '@type': 'Question',
 name: item.S,
 acceptedAnswer: { '@type': 'Answer', text: item.C },
 })),
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'Hukuk ve Finans', item: `${baseUrl}/hukuk-ve-finans` },
 ],
 })} is:inline />
</Layout>
