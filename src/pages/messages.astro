---
// Messages Page
import Layout from '../layouts/Layout.astro';
import { requireAuth } from '../lib/auth';
import { getUserConversations, getTotalUnreadCount } from '../lib/social/messaging-db';

const auth = await requireAuth(Astro.request);
if (auth instanceof Response) return auth;

const [conversations, unreadCount] = await Promise.all([
  getUserConversations(auth.user.id),
  getTotalUnreadCount(auth.user.id),
]);
---

<Layout title={`Mesajlar ${unreadCount > 0 ? `(${unreadCount})` : ''} - Şanlıurfa Rehberi`}>
  <div class="min-h-screen bg-gray-50">
    <div class="container-custom py-8">
      <div class="bg-white rounded-2xl shadow-sm overflow-hidden min-h-[600px]">
        <div class="flex h-[600px]">
          {/* Sidebar - Conversations */}
          <div class="w-80 border-r flex flex-col">
            <div class="p-4 border-b">
              <h1 class="text-xl font-bold">Mesajlar</h1>
              {unreadCount > 0 && (
                <span class="text-sm text-amber-600">{unreadCount} okunmamış</span>
              )}
            </div>
            
            <div class="flex-1 overflow-y-auto">
              {conversations.length > 0 ? (
                <div class="divide-y">
                  {conversations.map(conv => (
                    <button
                      onclick={`loadConversation('${conv.id}')`}
                      class={`w-full p-4 flex items-center gap-3 hover:bg-gray-50 transition-colors text-left ${conv.unread_count > 0 ? 'bg-amber-50' : ''}`}
                      data-conversation={conv.id}
                    >
                      <div class="w-12 h-12 rounded-full bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center text-white font-bold">
                        {conv.is_group ? '👥' : (conv.other_user?.full_name?.charAt(0).toUpperCase() || 'U')}
                      </div>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center justify-between">
                          <span class="font-medium truncate">
                            {conv.is_group ? conv.group_name : conv.other_user?.full_name}
                          </span>
                          {conv.last_message && (
                            <span class="text-xs text-gray-400">
                              {new Date(conv.last_message.created_at).toLocaleDateString('tr-TR', { hour: '2-digit', minute: '2-digit' })}
                            </span>
                          )}
                        </div>
                        {conv.last_message && (
                          <p class={`text-sm truncate ${conv.unread_count > 0 ? 'font-medium text-gray-900' : 'text-gray-500'}`}>
                            {conv.last_message.content}
                          </p>
                        )}
                      </div>
                      {conv.unread_count > 0 && (
                        <span class="w-5 h-5 bg-amber-600 text-white text-xs rounded-full flex items-center justify-center">
                          {conv.unread_count}
                        </span>
                      )}
                    </button>
                  ))}
                </div>
              ) : (
                <div class="text-center py-12 text-gray-500">
                  <div class="text-4xl mb-2">💬</div>
                  <p>Henüz mesaj yok</p>
                </div>
              )}
            </div>
            
            <div class="p-4 border-t">
              <button
                onclick="startNewConversation()"
                class="w-full py-2 bg-amber-600 text-white rounded-lg hover:bg-amber-700 transition-colors"
              >
                Yeni Mesaj
              </button>
            </div>
          </div>
          
          {/* Chat Area */}
          <div class="flex-1 flex flex-col" id="chat-area">
            <div class="flex-1 flex items-center justify-center text-gray-400">
              <div class="text-center">
                <div class="text-6xl mb-4">💬</div>
                <p>Bir sohbet seçin veya yeni mesaj başlatın</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    let currentConversation = null;
    let refreshInterval = null;

    async function loadConversation(conversationId) {
      currentConversation = conversationId;
      
      // Update active state
      document.querySelectorAll('[data-conversation]').forEach(btn => {
        btn.classList.remove('bg-amber-50', 'border-l-4', 'border-amber-600');
      });
      document.querySelector(`[data-conversation="${conversationId}"]`)?.classList.add('bg-amber-50', 'border-l-4', 'border-amber-600');
      
      try {
        const response = await fetch(`/api/social/messages?conversationId=${conversationId}`);
        const data = await response.json();
        
        renderChat(data.messages, conversationId);
        
        // Start auto-refresh
        if (refreshInterval) clearInterval(refreshInterval);
        refreshInterval = setInterval(() => refreshMessages(conversationId), 5000);
        
      } catch (error) {
        console.error('Failed to load conversation:', error);
      }
    }

    function renderChat(messages, conversationId) {
      const chatArea = document.getElementById('chat-area');
      
      chatArea.innerHTML = `
        <div class="flex flex-col h-full">
          {/* Header */}
          <div class="p-4 border-b flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center text-white font-bold">
                U
              </div>
              <div>
                <div class="font-medium">Sohbet</div>
                <div class="text-sm text-gray-500">Çevrimiçi</div>
              </div>
            </div>
            <button onclick="sharePlace()" class="text-gray-500 hover:text-amber-600">
              📍 Mekan Paylaş
            </button>
          </div>
          
          {/* Messages */}
          <div id="messages-list" class="flex-1 overflow-y-auto p-4 space-y-4">
            ${messages.map(msg => `
              <div class="flex ${msg.sender_id === '${conversationId}' ? 'justify-start' : 'justify-end'}">
                <div class="max-w-[70%] ${msg.sender_id === '${conversationId}' ? 'bg-gray-100' : 'bg-amber-600 text-white'} rounded-2xl px-4 py-2">
                  <p>${msg.content}</p>
                  <span class="text-xs ${msg.sender_id === '${conversationId}' ? 'text-gray-500' : 'text-amber-200'} mt-1">
                    ${new Date(msg.created_at).toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit' })}
                  </span>
                </div>
              </div>
            `).join('')}
          </div>
          
          {/* Input */}
          <div class="p-4 border-t">
            <form onsubmit="sendMessage(event, '${conversationId}')" class="flex gap-2">
              <input
                type="text"
                id="message-input"
                placeholder="Mesaj yaz..."
                class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-500 focus:border-transparent"
                autocomplete="off"
              />
              <button type="submit" class="px-6 py-2 bg-amber-600 text-white rounded-lg hover:bg-amber-700">
                Gönder
              </button>
            </form>
          </div>
        </div>
      `;
      
      // Scroll to bottom
      const messagesList = document.getElementById('messages-list');
      if (messagesList) messagesList.scrollTop = messagesList.scrollHeight;
    }

    async function refreshMessages(conversationId) {
      if (!currentConversation || currentConversation !== conversationId) return;
      
      try {
        const response = await fetch(`/api/social/messages?conversationId=${conversationId}`);
        const data = await response.json();
        
        // Update messages without full re-render
        // This is a simplified version - in production, compare and update only new messages
      } catch (error) {
        console.error('Failed to refresh:', error);
      }
    }

    async function sendMessage(event, conversationId) {
      event.preventDefault();
      
      const input = document.getElementById('message-input');
      const content = input.value.trim();
      if (!content) return;
      
      try {
        const response = await fetch('/api/social/messages', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ conversationId, content }),
        });
        
        if (response.ok) {
          input.value = '';
          loadConversation(conversationId); // Reload to show new message
        }
      } catch (error) {
        alert('Mesaj gönderilemedi');
      }
    }

    function startNewConversation() {
      const username = prompt('Kullanıcı adı veya e-posta girin:');
      if (!username) return;
      
      // Search user and start conversation
      // Implementation needed
    }

    function sharePlace() {
      const placeId = prompt('Paylaşmak istediğiniz mekan ID:');
      if (!placeId) return;
      
      fetch('/api/social/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          action: 'sharePlace',
          conversationId: currentConversation,
          placeId,
          placeName: 'Mekan Adı' // Get from place data
        }),
      });
    }

    // Cleanup on page unload
    window.addEventListener('beforeunload', () => {
      if (refreshInterval) clearInterval(refreshInterval);
    });
  </script>
</Layout>
