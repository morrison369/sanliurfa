---
import Layout from '../layouts/Layout.astro';

const seo = {
 title: '404 — Sayfa Bulunamadı | Sanliurfa.com',
 description: 'Aradığınız sayfa bulunamadı. Ana sayfaya dönün veya Şanlıurfa\'nın mekanlarını keşfedin.',
 noIndex: true,
};
---
<Layout seo={seo}>
 <style is:inline>
 .e-wrap{min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--bg);padding:2rem;padding-top:6rem}
 .e-box{text-align:center;max-width:480px}
 .e-num{font-family:'Cormorant Garamond',serif;font-size:clamp(5rem,18vw,9rem);font-weight:600;font-style:italic;color:rgba(184,115,51,0.18);line-height:1;margin-bottom:.5rem;letter-spacing:-.02em}
 .e-title{font-family:'Cormorant Garamond',serif;font-size:clamp(1.4rem,3vw,2rem);font-weight:600;color:var(--public-text);margin-bottom:.75rem}
 .e-desc{font-size:.88rem;color:var(--public-muted);line-height:1.7;margin-bottom:2rem;max-width:360px;margin-inline:auto}
 .e-actions{display:flex;flex-wrap:wrap;gap:.75rem;justify-content:center;margin-bottom:2.5rem}
 .e-sep{width:2rem;height:1px;background:rgba(184,115,51,.15);margin:.75rem auto}
 .e-lbl{font-size:.65rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--public-text-soft);margin-bottom:.85rem}
 .e-links{display:flex;flex-wrap:wrap;gap:.5rem;justify-content:center}
 .e-link{font-size:.78rem;color:var(--public-muted);border:1px solid rgba(184,115,51,.12);padding:.3rem .8rem;border-radius:.125rem;text-decoration:none;transition:color .15s,border-color .15s}
 .e-link:hover{color:var(--public-accent);border-color:rgba(184,115,51,.3)}
 </style>
 <div class="e-wrap">
 <div class="e-box">
 <div class="e-num" aria-hidden="true">404</div>
 <h1 class="e-title">Bu sayfa Halfeti gibi sular altında kalmış...</h1>
 <p class="e-desc">Aradığınız sayfa taşınmış, silinmiş veya hiç var olmamış olabilir. Şanlıurfa rehberinin başka bir köşesini keşfedin.</p>
 <div class="e-actions">
 <a href="/" class="sf-btn-primary">Ana Sayfaya Dön</a>
 <a href="/mekanlar" class="sf-btn-ghost">Mekanları Keşfet</a>
 <a href="/arama" class="sf-btn-ghost">Arama Yap</a>
 </div>
 <div class="e-sep" aria-hidden="true"></div>
 <p class="e-lbl">Popüler Sayfalar</p>
 <nav class="e-links" aria-label="Popüler sayfalar">
 <a href="/blog" class="e-link">Blog</a>
 <a href="/etkinlikler" class="e-link">Etkinlikler</a>
 <a href="/saglik/nobetci-eczaneler" class="e-link">Nöbetçi Eczane</a>
 <a href="/ulasim/otobus-saatleri" class="e-link">Otobüs Saatleri</a>
 <a href="/yemek-tarifleri" class="e-link">Yemek Tarifleri</a>
 <a href="/tarihi-yerler" class="e-link">Tarihi Yerler</a>
 <a href="/ilceler/halfeti" class="e-link">Halfeti</a>
 <a href="/tarihi-yerler/gobeklitepe" class="e-link">Göbeklitepe</a>
 <a href="/iletisim" class="e-link">İletişim</a>
 </nav>
 </div>
 </div>
</Layout>
