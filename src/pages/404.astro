---
import Layout from '../layouts/Layout.astro';

const seo = {
  title: 'Sayfa Bulunamadı - Sanliurfa.com',
  description: 'Aradığınız sayfa bulunamadı',
  noIndex: true,
};
---
<Layout seo={seo}>
  <div class="min-h-screen flex items-center justify-center bg-gray-50 pt-20">
    <div class="text-center px-4">
      <div class="text-8xl mb-4">🔍</div>
      <h1 class="text-6xl font-bold text-gray-900 mb-4">404</h1>
      <h2 class="text-2xl font-medium text-gray-700 mb-4">Sayfa Bulunamadı</h2>
      <p class="text-gray-500 mb-8 max-w-md mx-auto">
        Aradığınız sayfa taşınmış, silinmiş veya hiç var olmamış olabilir.
      </p>
      <div class="flex gap-4 justify-center">
        <a href="/" class="px-6 py-3 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors">
          Ana Sayfaya Dön
        </a>
        <a href="/mekanlar" class="px-6 py-3 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors">
          Mekanları Keşfet
        </a>
      </div>

      {/* Popüler Sayfalar */}
      <div class="mt-12">
        <p class="text-gray-400 text-sm mb-4">Popüler Sayfalar</p>
        <div class="flex flex-wrap justify-center gap-2">
          <a href="/mekanlar?category=restaurant" class="px-4 py-2 bg-white rounded-full text-gray-600 hover:bg-red-50 hover:text-red-600 transition-colors">Restoranlar</a>
          <a href="/mekanlar?category=hotel" class="px-4 py-2 bg-white rounded-full text-gray-600 hover:bg-red-50 hover:text-red-600 transition-colors">Oteller</a>
          <a href="/tarihi-yerler" class="px-4 py-2 bg-white rounded-full text-gray-600 hover:bg-red-50 hover:text-red-600 transition-colors">Göbeklitepe</a>
          <a href="/blog" class="px-4 py-2 bg-white rounded-full text-gray-600 hover:bg-red-50 hover:text-red-600 transition-colors">Blog</a>
          <a href="/iletisim" class="px-4 py-2 bg-white rounded-full text-gray-600 hover:bg-red-50 hover:text-red-600 transition-colors">İletişim</a>
        </div>
      </div>
    </div>
  </div>
</Layout>
