---
import Layout from '../layouts/Layout.astro';

const seo = {
  title: 'Sayfa Bulunamadı - Sanliurfa.com',
  description: 'Aradığınız sayfa bulunamadı. Ana sayfaya dönün veya Şanlıurfa\'nın mekanlarını, etkinliklerini ve rehberini keşfedin.',
  noIndex: true,
};
---
<Layout seo={seo}>
  <div class="min-h-screen flex items-center justify-center bg-[#FDFAF3] pt-20">
    <div class="text-center px-4">
      <div class="text-8xl mb-4">🔍</div>
      <h1 class="text-6xl font-bold text-[#1A1008] mb-4">404</h1>
      <h2 class="text-2xl font-medium text-[#4A3828] mb-4">Sayfa Bulunamadı</h2>
      <p class="text-[#9A8470] mb-8 max-w-md mx-auto">
        Aradığınız sayfa taşınmış, silinmiş veya hiç var olmamış olabilir.
      </p>
      <div class="flex gap-4 justify-center">
        <a href="/" class="px-6 py-3 bg-urfa-600 text-white rounded-sm hover:bg-urfa-700 transition-colors tracking-wide font-semibold">
          Ana Sayfaya Dön
        </a>
        <a href="/mekanlar" class="px-6 py-3 border border-[rgba(200,160,100,0.3)] text-[#4A3828] rounded-sm hover:border-urfa-400 hover:text-urfa-700 transition-colors font-semibold">
          Mekanları Keşfet
        </a>
      </div>

      {/* Popüler Sayfalar */}
      <div class="mt-12">
        <p class="text-[#9A8470] text-xs font-semibold tracking-widest uppercase mb-4">Popüler Sayfalar</p>
        <div class="flex flex-wrap justify-center gap-2">
          <a href="/mekanlar?category=restaurant" class="px-4 py-2 bg-white border border-[rgba(200,160,100,0.2)] rounded-sm text-[#6B5540] hover:border-urfa-400 hover:text-urfa-700 transition-colors text-sm">Restoranlar</a>
          <a href="/mekanlar?category=hotel" class="px-4 py-2 bg-white border border-[rgba(200,160,100,0.2)] rounded-sm text-[#6B5540] hover:border-urfa-400 hover:text-urfa-700 transition-colors text-sm">Oteller</a>
          <a href="/tarihi-yerler" class="px-4 py-2 bg-white border border-[rgba(200,160,100,0.2)] rounded-sm text-[#6B5540] hover:border-urfa-400 hover:text-urfa-700 transition-colors text-sm">Göbeklitepe</a>
          <a href="/blog" class="px-4 py-2 bg-white border border-[rgba(200,160,100,0.2)] rounded-sm text-[#6B5540] hover:border-urfa-400 hover:text-urfa-700 transition-colors text-sm">Blog</a>
          <a href="/iletisim" class="px-4 py-2 bg-white border border-[rgba(200,160,100,0.2)] rounded-sm text-[#6B5540] hover:border-urfa-400 hover:text-urfa-700 transition-colors text-sm">İletişim</a>
        </div>
      </div>
    </div>
  </div>
</Layout>
