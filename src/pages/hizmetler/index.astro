---
import Layout from '../../layouts/Layout.astro';
import { queryReadMany } from '../../lib/postgres';
import { getCachedPublicRouteData } from '../../lib/public-route-cache';
import { getPublicAppUrl } from '../../lib/public-app-url';
import { logger } from '../../lib/logging';
import PublicFaqList from '../../components/public/PublicFaqList.astro';

type FeaturedPlace = {
 slug: string;
 name: string;
 address: string | null;
 phone: string | null;
 category_name: string | null;
};

const HIZMETLER_CACHE_TTL_MS = 300_000;

let featuredPlaces: FeaturedPlace[] = [];

const hizmetlerCategories = [
 { slug: 'kuaforler', name: 'Kuaförler', icon: '💇', desc: 'Bayan kuaförleri' },
 { slug: 'berberler', name: 'Berberler', icon: '✂️', desc: 'Erkek berberleri' },
 { slug: 'temizlik-firmalari', name: 'Temizlik Firmaları', icon: '🧹', desc: 'Ev ve ofis temizliği' },
 { slug: 'nakliyat', name: 'Nakliyat', icon: '🚚', desc: 'Taşımacılık firmaları' },
 { slug: 'cilingir', name: 'Çilingir', icon: '🔑', desc: '7/24 çilingir hizmeti' },
 { slug: 'elektrikci', name: 'Elektrikçi', icon: '⚡', desc: 'Elektrik tadilat ve tamir' },
 { slug: 'tesisatci', name: 'Tesisatçı', icon: '🔧', desc: 'Su ve doğalgaz tesisatı' },
];

const acilHizmetler = [
 { slug: 'cilingir', icon: '🔑', name: '7/24 Çilingir' },
 { slug: 'elektrikci', icon: '⚡', name: 'Elektrikçi' },
 { slug: 'tesisatci', icon: '🔧', name: 'Tesisatçı' },
];

try {
 featuredPlaces = await getCachedPublicRouteData('page:hizmetler:index', async () => {
  return queryReadMany<FeaturedPlace>(
   `SELECT
      p.slug,
      p.name,
      p.address,
      p.phone,
      c.name AS category_name
    FROM places p
    LEFT JOIN categories c ON p.category_id = c.id
    WHERE c.slug IN ('kuaforler','berberler','temizlik-firmalari','nakliyat','cilingir','elektrikci','tesisatci')
      AND p.status = 'active'
    ORDER BY p.rating DESC NULLS LAST, p.review_count DESC NULLS LAST
    LIMIT 6`,
  );
 }, HIZMETLER_CACHE_TTL_MS);
} catch (e) {
 logger.error('Error loading hizmetler:', e instanceof Error ? e : new Error(String(e)));
}

const seo = {
 title: 'Şanlıurfa Hizmetler Rehberi | Kuaför, Temizlik, Nakliyat ve Teknik Servis',
 description: "Şanlıurfa'da hizmet firmaları: kuaförler, berberler, temizlik şirketleri, nakliyat, çilingir, elektrikçi ve tesisatçı.",
 keywords: ['şanlıurfa kuaför', 'urfa berber', 'şanlıurfa temizlik', 'urfa nakliyat', 'şanlıurfa çilingir', 'urfa elektrikçi', 'şanlıurfa tesisatçı', 'urfa hizmetler'],
 ogImage: '/images/places/balikligol.jpg',
 canonical: '/hizmetler',
};
const baseUrl = getPublicAppUrl();

const faqItems = [
 {
 S: "Şanlıurfa'da 7/24 çilingir hizmeti nasıl bulunur?",
 C: "Hizmetler rehberindeki çilingir kategorisinden Şanlıurfa'da 7/24 hizmet veren çilingir firmalarına ulaşabilirsiniz.",
 },
 {
 S: "Şanlıurfa'da elektrikçi ve tesisatçı bulabilir miyim?",
 C: "Evet. Hizmetler rehberinde elektrikçi ve tesisatçı kategorileri altında Şanlıurfa'da hizmet veren usta ve firmalar listelenmektedir.",
 },
 {
 S: "Şanlıurfa'da ev temizlik firması ve nakliyat şirketi arayışında ne yapmalıyım?",
 C: 'Hizmetler rehberindeki temizlik firmaları ve nakliyat kategorilerinden iletişim bilgileri ve adres bilgilerine ulaşabilirsiniz.',
 },
];
---

<Layout seo={seo}>
 <style is:inline>
 .hz-hero{position:relative;overflow:hidden;border-bottom:1px solid rgba(184,115,51,0.12);padding:clamp(3rem,6vw,5rem) 0;background:radial-gradient(circle at 18% 0%,rgba(212,151,24,0.10) 0%,transparent 42%),radial-gradient(circle at 82% 100%,rgba(44,122,82,0.08) 0%,transparent 40%),linear-gradient(180deg,#fbf6ec 0%,#f4ecd8 58%,#fbf6ec 100%)}
 .hz-eyebrow{font-size:.7rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--public-muted);margin-bottom:.5rem}
 .hz-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.9rem,4vw,3rem);font-weight:600;color:var(--public-text);margin-bottom:.5rem}
 .hz-sub{font-size:.9rem;color:var(--public-muted);max-width:38rem;line-height:1.75}
 .hz-body{background:var(--bg);padding:2.5rem 0 5rem}
 .hz-acil-grid{display:grid;gap:.85rem;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));margin-bottom:2rem}
 .hz-acil-card{background:rgba(184,115,51,.05);border:1px solid rgba(184,115,51,.18);padding:1.1rem;text-align:center}
 .hz-acil-icon{font-size:1.75rem;margin-bottom:.4rem}
 .hz-acil-name{font-size:.85rem;font-weight:700;color:var(--public-text);margin-bottom:.35rem}
 .hz-acil-link{font-size:.75rem;color:var(--public-accent);font-weight:600;transition:color .15s}
 .hz-acil-link:hover{color:var(--public-accent-strong)}
 .hz-section-title{font-family:'Cormorant Garamond',serif;font-size:1.25rem;font-weight:600;color:var(--public-text);margin-bottom:1.1rem}
 .hz-cat-grid{display:grid;gap:.85rem;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));margin-bottom:2.5rem}
 .hz-cat-card{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);padding:1.1rem;transition:border-color .15s,transform .15s}
 .hz-cat-card:hover{border-color:var(--public-accent);transform:translateY(-2px)}
 .hz-cat-icon{font-size:1.5rem;margin-bottom:.4rem}
 .hz-cat-name{font-size:.82rem;font-weight:700;color:var(--public-text);margin-bottom:.15rem;transition:color .15s}
 .hz-cat-card:hover .hz-cat-name{color:var(--public-accent)}
 .hz-cat-desc{font-size:.7rem;color:var(--public-muted)}
 .hz-feat-grid{display:grid;gap:.85rem;grid-template-columns:repeat(auto-fill,minmax(240px,1fr))}
 .hz-feat-card{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);padding:1rem;transition:border-color .15s}
 .hz-feat-card:hover{border-color:var(--public-accent)}
 .hz-feat-name{font-size:.88rem;font-weight:700;color:var(--public-text);margin-bottom:.15rem;transition:color .15s}
 .hz-feat-card:hover .hz-feat-name{color:var(--public-accent)}
 .hz-feat-cat{font-size:.7rem;color:var(--public-accent);font-weight:600;margin-bottom:.3rem}
 .hz-feat-meta{font-size:.72rem;color:var(--public-text-soft);margin-top:.15rem}
 .hz-hero-inner{max-width:50rem;margin:0 auto}
 </style>

 <div class="hz-hero">
 <div class="sf-container">
 <div class="hz-hero-inner">
 <p class="hz-eyebrow">Hizmetler Rehberi</p>
 <h1 class="hz-h1">Hizmetler Rehberi</h1>
 <p class="hz-sub">Şanlıurfa'da kuaförlerden çilingire, nakliyattan elektrikçiye tüm hizmetler</p>
 </div>
 </div>
 </div>

 <div class="hz-body">
 <div class="sf-container">
 <div class="hz-acil-grid">
 {acilHizmetler.map(h => (
 <div class="hz-acil-card">
 <div class="hz-acil-icon">{h.icon}</div>
 <p class="hz-acil-name">{h.name}</p>
 <a href={`/hizmetler/${h.slug}`} class="hz-acil-link">Hemen Bul →</a>
 </div>
 ))}
 </div>

 <h2 class="hz-section-title">Hizmet Kategorileri</h2>
 <div class="hz-cat-grid">
 {hizmetlerCategories.map((cat) => (
 <a href={`/hizmetler/${cat.slug}`} class="hz-cat-card">
 <div class="hz-cat-icon">{cat.icon}</div>
 <p class="hz-cat-name">{cat.name}</p>
 <p class="hz-cat-desc">{cat.desc}</p>
 </a>
 ))}
 </div>

 {featuredPlaces.length > 0 && (
 <div>
 <h2 class="hz-section-title">Öne Çıkan Hizmet Firmaları</h2>
 <div class="hz-feat-grid">
 {featuredPlaces.map((place) => (
 <a href={`/isletme/${place.slug}`} class="hz-feat-card">
 <p class="hz-feat-name">{place.name}</p>
 <p class="hz-feat-cat">{place.category_name}</p>
 {place.address && <p class="hz-feat-meta">📍 {place.address}</p>}
 {place.phone && <p class="hz-feat-meta">📞 {place.phone}</p>}
 </a>
 ))}
 </div>
 </div>
 )}

 {faqItems.length > 0 && (
  <div style="margin-top:3rem">
   <PublicFaqList items={faqItems} />
  </div>
 )}
 </div>
 </div>

 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'CollectionPage',
 name: 'Şanlıurfa Hizmetler Rehberi',
 description: "Şanlıurfa'da çilingir, elektrikçi, tesisatçı, kuaför ve diğer hizmet işletmeleri.",
 url: `${baseUrl}/hizmetler`,
 about: { '@type': 'City', name: 'Şanlıurfa' },
 itemListElement: featuredPlaces.slice(0, 10).map((p: any, i: number) => ({
 '@type': 'ListItem',
 position: i + 1,
 item: { '@type': 'LocalBusiness', '@id': `${baseUrl}/isletme/${p.slug}`, name: p.name, url: `${baseUrl}/isletme/${p.slug}` },
 })),
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'Hizmetler', item: `${baseUrl}/hizmetler` },
 ],
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqItems.map((item) => ({
 '@type': 'Question',
 name: item.S,
 acceptedAnswer: { '@type': 'Answer', text: item.C },
 })),
 })} is:inline />
</Layout>
