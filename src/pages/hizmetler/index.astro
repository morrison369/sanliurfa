---
import Layout from '../../layouts/Layout.astro';
import { query } from '../../lib/postgres';
import { getSiteBranding } from '../../lib/site-branding';
import { logger } from '../../lib/logging';

let featuredPlaces: any[] = [];

const hizmetlerCategories = [
  { slug: 'kuaforler', name: 'Kuaförler', icon: '💇', desc: 'Bayan kuaförleri' },
  { slug: 'berberler', name: 'Berberler', icon: '✂️', desc: 'Erkek berberleri' },
  { slug: 'temizlik-firmalari', name: 'Temizlik Firmaları', icon: '🧹', desc: 'Ev ve ofis temizliği' },
  { slug: 'nakliyat', name: 'Nakliyat', icon: '🚚', desc: 'Taşımacılık firmaları' },
  { slug: 'cilingir', name: 'Çilingir', icon: '🔑', desc: '7/24 çilingir hizmeti' },
  { slug: 'elektrikci', name: 'Elektrikçi', icon: '⚡', desc: 'Elektrik tadilat ve tamir' },
  { slug: 'tesisatci', name: 'Tesisatçı', icon: '🔧', desc: 'Su ve doğalgaz tesisatı' },
];

try {
  const placesResult = await query(
    `SELECT p.*, c.name as category_name FROM places p
     LEFT JOIN categories c ON p.category_id = c.id
     WHERE c.slug IN ('kuaforler','berberler','temizlik-firmalari','nakliyat','cilingir','elektrikci','tesisatci')
     AND p.status = 'active'
     ORDER BY p.rating DESC LIMIT 6`
  );
  featuredPlaces = placesResult.rows;
} catch (e) {
  logger.error('Error loading hizmetler:', e instanceof Error ? e : new Error(String(e)));
}

const seo = {
  title: 'Şanlıurfa Hizmetler Rehberi | Kuaför, Temizlik, Nakliyat ve Teknik Servis',
  description: 'Şanlıurfa\'da hizmet firmaları: kuaförler, berberler, temizlik şirketleri, nakliyat, çilingir, elektrikçi ve tesisatçı.',
  keywords: ['şanlıurfa kuaför', 'urfa berber', 'şanlıurfa temizlik', 'urfa nakliyat', 'şanlıurfa çilingir', 'urfa elektrikçi', 'şanlıurfa tesisatçı', 'urfa hizmetler'],
  ogImage: '/images/hero/hero-home.webp',
  canonical: '/hizmetler',
};
const { baseUrl } = await getSiteBranding();

const faqItems = [
  {
    S: 'Şanlıurfa\'da 7/24 çilingir hizmeti nasıl bulunur?',
    C: 'Hizmetler rehberindeki çilingir kategorisinden Şanlıurfa\'da 7/24 hizmet veren çilingir firmalarına ulaşabilirsiniz.',
  },
  {
    S: 'Şanlıurfa\'da elektrikçi ve tesisatçı bulabilir miyim?',
    C: 'Evet. Hizmetler rehberinde elektrikçi ve tesisatçı kategorileri altında Şanlıurfa\'da hizmet veren usta ve firmalar listelenmektedir.',
  },
  {
    S: 'Şanlıurfa\'da ev temizlik firması ve nakliyat şirketi arayışında ne yapmalıyım?',
    C: 'Hizmetler rehberindeki temizlik firmaları ve nakliyat kategorilerinden iletişim bilgileri ve adres bilgilerine ulaşabilirsiniz.',
  },
];
---

<Layout seo={seo}>
  <div class="min-h-screen bg-[#FDFAF3]">
    <div class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)] text-white py-16">
      <div class="container mx-auto px-4">
        <p class="text-sm font-semibold uppercase tracking-widest text-[#9A8470] mb-2">HİZMETLER REHBERİ</p>
        <h1 class="text-4xl md:text-5xl font-bold text-[#F5EDD6] mb-4">Hizmetler Rehberi</h1>
        <p class="text-xl text-[#C4B49A] max-w-2xl">
          Şanlıurfa'da kuaförlerden çilingire, nakliyattan elektrikçiye tüm hizmetler
        </p>
      </div>
    </div>

    <div class="container mx-auto px-4 py-12">
      <!-- Acil Hizmetler -->
      <div class="grid md:grid-cols-3 gap-4 mb-10">
        <div class="bg-[rgba(200,160,100,0.06)] border border-[rgba(200,160,100,0.2)] rounded-sm p-5 text-center">
          <div class="text-3xl mb-2">🔑</div>
          <h3 class="font-bold text-[#1A1008]">7/24 Çilingir</h3>
          <a href="/hizmetler/cilingir" class="text-urfa-600 text-sm hover:underline">Hemen Bul →</a>
        </div>
        <div class="bg-[rgba(200,160,100,0.06)] border border-[rgba(200,160,100,0.2)] rounded-sm p-5 text-center">
          <div class="text-3xl mb-2">⚡</div>
          <h3 class="font-bold text-[#1A1008]">Elektrikçi</h3>
          <a href="/hizmetler/elektrikci" class="text-urfa-600 text-sm hover:underline">Hemen Bul →</a>
        </div>
        <div class="bg-[rgba(200,160,100,0.06)] border border-[rgba(200,160,100,0.2)] rounded-sm p-5 text-center">
          <div class="text-3xl mb-2">🔧</div>
          <h3 class="font-bold text-[#1A1008]">Tesisatçı</h3>
          <a href="/hizmetler/tesisatci" class="text-urfa-600 text-sm hover:underline">Hemen Bul →</a>
        </div>
      </div>

      <!-- Tüm Kategoriler -->
      <h2 class="text-2xl font-bold text-[#1A1008] mb-6">Hizmet Kategorileri</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
        {hizmetlerCategories.map((cat) => (
          <a
            href={`/hizmetler/${cat.slug}`}
            class="bg-white rounded-sm p-5 border border-[rgba(200,160,100,0.18)] shadow-sm hover:shadow-md hover:border-urfa-300 hover:-translate-y-1 transition-all group"
          >
            <div class="text-2xl mb-2">{cat.icon}</div>
            <h3 class="font-bold text-[#1A1008] group-hover:text-urfa-700 transition-colors text-sm">{cat.name}</h3>
            <p class="text-xs text-[#9A8470] mt-1">{cat.desc}</p>
          </a>
        ))}
      </div>

      {featuredPlaces.length > 0 && (
        <div>
          <h2 class="text-2xl font-bold text-[#1A1008] mb-6">Öne Çıkan Hizmet Firmaları</h2>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
            {featuredPlaces.map((place) => (
              <a href={`/isletme/${place.slug}`} class="bg-white rounded-sm p-5 border border-[rgba(200,160,100,0.18)] shadow-sm hover:shadow-md hover:border-urfa-300 transition-all group">
                <h3 class="font-bold text-[#1A1008] group-hover:text-urfa-700">{place.name}</h3>
                <span class="text-xs text-urfa-600">{place.category_name}</span>
                {place.address && <p class="text-xs text-[#9A8470] mt-2">📍 {place.address}</p>}
                {place.phone && <p class="text-xs text-[#9A8470]">📞 {place.phone}</p>}
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Şanlıurfa Hizmetler Rehberi',
    description: 'Şanlıurfa\'da çilingir, elektrikçi, tesisatçı, kuaför ve diğer hizmet işletmeleri.',
    url: `${baseUrl}/hizmetler`,
    about: { '@type': 'City', name: 'Şanlıurfa' },
    itemListElement: featuredPlaces.slice(0, 10).map((p: any, i: number) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: { '@type': 'LocalBusiness', '@id': `${baseUrl}/isletme/${p.slug}`, name: p.name, url: `${baseUrl}/isletme/${p.slug}` },
    })),
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Hizmetler', item: `${baseUrl}/hizmetler` },
    ],
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: { '@type': 'Answer', text: item.C },
    })),
  })} is:inline />
</Layout>
