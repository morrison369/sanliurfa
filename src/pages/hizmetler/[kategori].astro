---
import Layout from '../../layouts/Layout.astro';
import { query } from '../../lib/postgres';
import { getCachedPublicRouteData } from '../../lib/public-route-cache';
import { getPublicAppUrl } from '../../lib/public-app-url';
import { logger } from '../../lib/logging';
const baseUrl = getPublicAppUrl();

const { kategori } = Astro.params;

const categoryMeta: Record<string, { name: string; icon: string }> = {
 'kuaforler': { name: 'Kuaförler', icon: '💇' },
 'berberler': { name: 'Berberler', icon: '✂️' },
 'temizlik-firmalari': { name: 'Temizlik Firmaları', icon: '🧹' },
 'nakliyat': { name: 'Nakliyat', icon: '🚚' },
 'cilingir': { name: 'Çilingir', icon: '🔑' },
 'elektrikci': { name: 'Elektrikçi', icon: '⚡' },
 'tesisatci': { name: 'Tesisatçı', icon: '🔧' },
};

const meta = categoryMeta[kategori || ''] || { name: kategori || '', icon: '🛠️' };

let places: any[] = [];

try {
 places = await getCachedPublicRouteData(`page:hizmetler:${kategori || 'unknown'}`, async () => {
  const result = await query(
   `SELECT p.*, d.name as district_name FROM places p
 LEFT JOIN categories c ON p.category_id = c.id
 LEFT JOIN districts d ON p.district_id = d.id
 WHERE c.slug = $1 AND p.status = 'active'
 ORDER BY p.is_featured DESC, p.rating DESC`,
   [kategori]
  );
  return result.rows;
 });
} catch (e) {
 logger.error('Error loading hizmetler kategori:', e instanceof Error ? e : new Error(String(e)));
}

const seo = {
 title: `Şanlıurfa ${meta.name} | Hizmetler Rehberi`,
 description: `Şanlıurfa'da ${meta.name.toLowerCase()}. Adres, telefon ve iletişim bilgileri.`,
 keywords: ['şanlıurfa ' + meta.name.toLowerCase(), 'urfa ' + meta.name.toLowerCase(), meta.name + ' şanlıurfa', 'şanlıurfa hizmetler'],
 ogImage: '/images/places/balikligol.jpg',
 canonical: `/hizmetler/${kategori}`,
};
const faqItems = [
 { S: `Şanlıurfa'da ${meta.name.toLowerCase()} seçenekleri nelerdir?`, C: `Şanlıurfa'da ${meta.name.toLowerCase()} için güncel liste ve değerlendirmeler rehberimizde yer almaktadır.` },
 { S: `${meta.name} için hangi ilçeler öne çıkıyor?`, C: `Eyyübiye, Haliliye ve Karaköprü ilçeleri hizmet yoğunluğu açısından öne çıkan bölgeler arasındadır.` },
 { S: `${meta.name} bilgilerini nasıl güncelleyebilirim?`, C: `Mekan sayfasına giriş yaparak güncelleme talebinde bulunabilir veya iletişim formu üzerinden bildirimde bulunabilirsiniz.` },
];
---

<Layout seo={seo}>
 <style is:inline>
 .hk-breadcrumb{background:var(--bg);border-bottom:1px solid rgba(184,115,51,.14);padding:.75rem 0}
 .hk-breadcrumb nav{display:flex;align-items:center;gap:.5rem;font-size:.8rem;color:var(--public-muted)}
 .hk-breadcrumb a{color:var(--public-muted);transition:color .15s}.hk-breadcrumb a:hover{color:var(--public-accent)}
 .hk-breadcrumb span:last-child{color:var(--public-accent);font-weight:500}
 .hk-hero{position:relative;overflow:hidden;border-bottom:1px solid rgba(184,115,51,0.12);padding:clamp(3rem,6vw,5rem) 0;background:radial-gradient(circle at 18% 0%,rgba(212,151,24,0.10) 0%,transparent 42%),radial-gradient(circle at 82% 100%,rgba(44,122,82,0.08) 0%,transparent 40%),linear-gradient(180deg,#fbf6ec 0%,#f4ecd8 58%,#fbf6ec 100%)}
 .hk-hero-inner{display:flex;align-items:center;gap:1rem}
 .hk-hero-icon{font-size:3rem;line-height:1}
 .hk-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.6rem,4vw,2.5rem);font-weight:600;color:var(--public-text)}
 .hk-count{font-size:.85rem;color:var(--public-muted);margin-top:.25rem}
 .hk-body{background:var(--bg);padding:2rem 0 4rem}
 .hk-grid{display:grid;gap:1rem;grid-template-columns:repeat(auto-fill,minmax(280px,1fr))}
 .hk-card{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);padding:1.25rem;display:flex;align-items:flex-start;gap:.85rem;transition:border-color .15s}
 .hk-card:hover{border-color:var(--public-accent)}
 .hk-card-icon{font-size:2rem;flex-shrink:0;line-height:1}
 .hk-card-content{flex:1;min-width:0}
 .hk-card-name{font-size:.92rem;font-weight:700;color:var(--public-text);margin-bottom:.2rem;transition:color .15s}
 .hk-card:hover .hk-card-name{color:var(--public-accent)}
 .hk-district{font-size:.72rem;color:var(--public-text-soft)}
 .hk-addr{font-size:.75rem;color:var(--public-muted);margin-top:.2rem}
 .hk-phone{font-size:.75rem;color:var(--public-muted)}
 .hk-empty{text-align:center;padding:4rem 1rem;color:var(--public-muted)}
 .hk-empty-icon{font-size:3.5rem;margin-bottom:.75rem}
 .hk-empty-link{display:inline-block;margin-top:.75rem;color:var(--public-accent);font-size:.85rem;transition:color .15s}
 .hk-empty-link:hover{color:var(--public-accent-strong)}
 </style>

 <div class="hk-breadcrumb">
 <div class="sf-container">
 <nav>
 <a href="/">Ana Sayfa</a>
 <span>/</span>
 <a href="/hizmetler">Hizmetler</a>
 <span>/</span>
 <span>{meta.name}</span>
 </nav>
 </div>
 </div>

 <div class="hk-hero">
 <div class="sf-container">
 <div class="hk-hero-inner">
 <span class="hk-hero-icon">{meta.icon}</span>
 <div>
 <h1 class="hk-h1">Şanlıurfa {meta.name}</h1>
 <p class="hk-count">{places.length} firma bulundu</p>
 </div>
 </div>
 </div>
 </div>

 <div class="hk-body">
 <div class="sf-container">
 {places.length > 0 ? (
 <div class="hk-grid">
 {places.map((place) => (
 <a href={`/isletme/${place.slug}`} class="hk-card">
 <span class="hk-card-icon">{meta.icon}</span>
 <div class="hk-card-content">
 <p class="hk-card-name">{place.name}</p>
 {place.district_name && <p class="hk-district">{place.district_name}</p>}
 {place.address && <p class="hk-addr">📍 {place.address}</p>}
 {place.phone && <p class="hk-phone">📞 {place.phone}</p>}
 </div>
 </a>
 ))}
 </div>
 ) : (
 <div class="hk-empty">
 <div class="hk-empty-icon">{meta.icon}</div>
 <p>Bu kategoride henüz kayıt bulunmuyor.</p>
 <a href="/hizmetler" class="hk-empty-link">Hizmetler Rehberine Dön →</a>
 </div>
 )}
 </div>
 </div>

 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'CollectionPage',
 name: `Şanlıurfa ${meta.name}`,
 description: `Şanlıurfa'da ${meta.name.toLowerCase()}. Adres, telefon ve iletişim bilgileri.`,
 url: `${baseUrl}/hizmetler/${kategori}`,
 about: { '@type': 'City', name: 'Şanlıurfa' },
 itemListElement: places.slice(0, 10).map((p: any, i: number) => ({
 '@type': 'ListItem',
 position: i + 1,
 item: {
 '@type': 'LocalBusiness',
 '@id': `${baseUrl}/isletme/${p.slug}`,
 name: p.name,
 url: `${baseUrl}/isletme/${p.slug}`,
 ...(p.address ? { address: p.address } : {}),
 ...(p.phone ? { telephone: p.phone } : {}),
 },
 })),
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'Hizmetler', item: `${baseUrl}/hizmetler` },
 { '@type': 'ListItem', position: 3, name: meta.name, item: `${baseUrl}/hizmetler/${kategori}` },
 ],
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqItems.map((item) => ({
 '@type': 'Question',
 name: item.S,
 acceptedAnswer: { '@type': 'Answer', text: item.C },
 })),
 })} is:inline />
</Layout>
