---
import Layout from '../../layouts/Layout.astro';
import CollectionsManager from '../../components/CollectionsManager';
import PublicPageIntro from '../../components/public/PublicPageIntro.astro';

const user = Astro.locals.user;
if (!user) {
 return Astro.redirect('/giris?redirect=/koleksiyonlar');
}
---

<Layout seo={{ title: "Koleksiyonlarım - Şanlıurfa", noIndex: true }}>
 <div class="ko-page">
 <PublicPageIntro
 eyebrow="Hesabım"
 title="Koleksiyonlarım"
 description="Gezilecek yerleri, restoranları ve şehir notlarını kişisel listelerde düzenle."
 quickAnswerTitle="Hızlı cevap"
 quickAnswerText="Koleksiyonlar, Şanlıurfa planlarını kategori ve rota bazında saklamak için kullanılır."
 actions={[
 { href: '/mekanlar', label: 'Mekan Keşfet' },
 { href: '/oneriler', label: 'Öneriler' },
 ]}
 />
 <div class="ko-body">
 <div class="sf-container">
 <CollectionsManager client:visible={{ rootMargin: '140px' }} userId={user.id} />
 </div>
 </div>
 </div>
</Layout>

<style>
 .ko-page {
 background: var(--public-bg);
 min-height: 100vh;
 }

 .ko-body {
 padding: 2rem 0 4rem;
 }
</style>
