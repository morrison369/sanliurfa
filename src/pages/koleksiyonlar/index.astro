---
import Layout from "../../layouts/Layout.astro";
import CollectionsManager from "../../components/CollectionsManager";
import { curatedCollections } from "../../data/curated-collections";

const user = Astro.locals.user;
---

<Layout
  seo={{
    title: user
      ? "Koleksiyonlarım - Şanlıurfa"
      : "Şanlıurfa Koleksiyonları - Rotalar ve Listeler",
    description:
      "Şanlıurfa tarihi yerler, gastronomi ve şehir keşfi için hazırlanmış koleksiyonları inceleyin.",
    canonicalUrl: "https://sanliurfa.com/koleksiyonlar",
    noindex: Boolean(user),
  }}
>
  <section
    class="bg-gradient-to-br from-urfa-950 via-urfa-900 to-isot-900 text-white"
  >
    <div class="container-custom py-14">
      <p class="text-sm uppercase tracking-wide text-urfa-200">
        Şanlıurfa koleksiyonları
      </p>
      <h1 class="mt-3 text-4xl md:text-5xl font-display font-bold">
        {user ? "Koleksiyonlarım" : "Şehri rotalarla keşfedin"}
      </h1>
      <p class="mt-4 max-w-3xl text-lg text-urfa-100">
        Mekânları, tarihi durakları ve yöresel lezzetleri tematik listelerle
        düzenleyin.
      </p>
    </div>
  </section>

  <div class="container-custom py-10">
    {
      user ? (
        <CollectionsManager client:load userId={user.id} />
      ) : (
        <div class="space-y-8">
          <div class="grid gap-6 md:grid-cols-3">
            {curatedCollections.map((collection) => (
              <article class="rounded-3xl border border-gray-100 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-xl dark:border-gray-800 dark:bg-gray-800">
                <div class="text-4xl">{collection.icon}</div>
                <h2 class="mt-4 text-xl font-display font-bold text-gray-900 dark:text-white">
                  {collection.name}
                </h2>
                <p class="mt-3 text-sm leading-6 text-gray-600 dark:text-gray-400">
                  {collection.description}
                </p>
                <div class="mt-5 flex items-center justify-between border-t border-gray-100 pt-4 text-sm text-gray-500 dark:border-gray-700 dark:text-gray-400">
                  <span>{collection.place_count} durak</span>
                  <span>{collection.follower_count} takipçi</span>
                </div>
                <a href={collection.href} class="btn-primary mt-5 w-full">
                  Koleksiyonu keşfet
                </a>
              </article>
            ))}
          </div>

          <div class="rounded-3xl bg-amber-50 p-8 text-center dark:bg-urfa-950/40">
            <h2 class="text-2xl font-display font-bold text-gray-900 dark:text-white">
              Kendi Şanlıurfa listenizi oluşturun
            </h2>
            <p class="mx-auto mt-3 max-w-2xl text-gray-600 dark:text-gray-400">
              Favori mekânlarınızı, gezilecek yerleri ve lezzet duraklarını
              kişisel koleksiyonlarda toplayabilirsiniz.
            </p>
            <div class="mt-6 flex flex-wrap justify-center gap-3">
              <a href="/kayit" class="btn-primary">
                Ücretsiz hesap oluştur
              </a>
              <a href="/giris?redirect=/koleksiyonlar" class="btn-outline">
                Giriş yap
              </a>
            </div>
          </div>
        </div>
      )
    }
  </div>
</Layout>
