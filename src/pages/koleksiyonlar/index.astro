---
import Layout from '../../layouts/Layout.astro';
import CollectionsManager from '../../components/CollectionsManager';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/giris?redirect=/koleksiyonlar');
}
---

<Layout seo={{ title: "Koleksiyonlarım - Şanlıurfa", noIndex: true }}>
  <div class="min-h-screen bg-[#FDFAF3]">
    <div class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)] text-white py-12">
      <div class="container mx-auto px-4 max-w-6xl">
        <p class="text-sm font-semibold uppercase tracking-widest text-[#9A8470] mb-2">Hesabım</p>
        <h1 class="text-4xl font-bold text-[#F5EDD6] mb-2">Koleksiyonlarım</h1>
        <p class="text-[#C4B49A]">Mekanları organize edebileceğiniz kişisel listeleriniz</p>
      </div>
    </div>

    <div class="container mx-auto px-4 py-8 max-w-6xl">
      <CollectionsManager client:visible={{ rootMargin: '140px' }} userId={user.id} />
    </div>
  </div>
</Layout>
