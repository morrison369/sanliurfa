---
import Layout from '../../layouts/Layout.astro';
import { query } from '../../lib/postgres';
import { getCachedPublicRouteData } from '../../lib/public-route-cache';
import { getPublicAppUrl } from '../../lib/public-app-url';
import { logger } from '../../lib/logging';
const baseUrl = getPublicAppUrl();

const { kategori } = Astro.params;

const categoryMeta: Record<string, { name: string; icon: string; desc: string }> = {
 'otogar': { name: 'Otogar', icon: '🚌', desc: 'GAP Otogarı ve otobüs firmaları' },
 'havalimani': { name: 'Havalimanı', icon: '✈️', desc: 'GAP Havalimanı ulaşım bilgileri' },
 'taksi-duraklari': { name: 'Taksi Durakları', icon: '🚕', desc: 'Taksi durakları ve ücret tarifeleri' },
 'arac-kiralama': { name: 'Araç Kiralama', icon: '🚗', desc: 'Rent-a-car firmaları' },
 'otobus-hatlari': { name: 'Otobüs Hatları', icon: '🚎', desc: 'Şehir içi toplu taşıma' },
};

const meta = categoryMeta[kategori || ''] || { name: kategori || '', icon: '🚌', desc: '' };

let places: any[] = [];

try {
 places = await getCachedPublicRouteData(`page:ulasim:${kategori || 'unknown'}`, async () => {
  const result = await query(
   `SELECT p.*, d.name as district_name FROM places p
 LEFT JOIN categories c ON p.category_id = c.id
 LEFT JOIN districts d ON p.district_id = d.id
 WHERE c.slug = $1 AND p.status = 'active'
 ORDER BY p.is_featured DESC, p.rating DESC`,
   [kategori]
  );
  return result.rows;
 });
} catch (e) {
 logger.error('Error loading ulasim kategori:', e instanceof Error ? e : new Error(String(e)));
}

const seo = {
 title: `Şanlıurfa ${meta.name} | Ulaşım Rehberi`,
 description: `Şanlıurfa'da ${meta.name.toLowerCase()}. ${meta.desc}`,
 keywords: ['şanlıurfa ' + meta.name.toLowerCase(), 'urfa ' + meta.name.toLowerCase(), meta.name + ' şanlıurfa', 'şanlıurfa ulaşım'],
 ogImage: '/images/places/balikligol.jpg',
 canonical: `/ulasim/${kategori}`,
};
const faqItems = [
 { S: `Şanlıurfa'da ${meta.name.toLowerCase()} seçenekleri nelerdir?`, C: `Şanlıurfa'da ${meta.name.toLowerCase()} için güncel liste ve değerlendirmeler rehberimizde yer almaktadır.` },
 { S: `${meta.name} için hangi ilçeler öne çıkıyor?`, C: `Eyyübiye, Haliliye ve Karaköprü ilçeleri hizmet yoğunluğu açısından öne çıkan bölgeler arasındadır.` },
 { S: `${meta.name} bilgilerini nasıl güncelleyebilirim?`, C: `Mekan sayfasına giriş yaparak güncelleme talebinde bulunabilir veya iletişim formu üzerinden bildirimde bulunabilirsiniz.` },
];
---

<Layout seo={seo}>
 <style is:inline>
 .uk-breadcrumb{background:var(--bg);border-bottom:1px solid rgba(184,115,51,.14);padding:.75rem 0}
 .uk-breadcrumb nav{display:flex;align-items:center;gap:.5rem;font-size:.8rem;color:var(--public-muted)}
 .uk-breadcrumb a{color:var(--public-muted);transition:color .15s}.uk-breadcrumb a:hover{color:var(--public-accent)}
 .uk-breadcrumb span:last-child{color:var(--public-accent);font-weight:500}
 .uk-hero{position:relative;overflow:hidden;border-bottom:1px solid rgba(184,115,51,0.12);padding:clamp(3rem,6vw,5rem) 0;background:radial-gradient(circle at 18% 0%,rgba(212,151,24,0.10) 0%,transparent 42%),radial-gradient(circle at 82% 100%,rgba(44,122,82,0.08) 0%,transparent 40%),linear-gradient(180deg,#fbf6ec 0%,#f4ecd8 58%,#fbf6ec 100%)}
 .uk-hero-inner{display:flex;align-items:center;gap:1rem}
 .uk-hero-icon{font-size:3rem;line-height:1}
 .uk-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.6rem,4vw,2.5rem);font-weight:600;color:var(--public-text)}
 .uk-desc{font-size:.85rem;color:var(--public-muted);margin-top:.25rem}
 .uk-body{background:var(--bg);padding:2rem 0 4rem}
 .uk-grid{display:grid;gap:1rem;grid-template-columns:repeat(auto-fill,minmax(320px,1fr))}
 .uk-card{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);padding:1.25rem;display:flex;align-items:flex-start;gap:1rem;transition:border-color .15s}
 .uk-card:hover{border-color:var(--public-accent)}
 .uk-card-icon{font-size:2.25rem;flex-shrink:0;line-height:1}
 .uk-card-name{font-size:.92rem;font-weight:700;color:var(--public-text);margin-bottom:.25rem;transition:color .15s}
 .uk-card:hover .uk-card-name{color:var(--public-accent)}
 .uk-card-addr{font-size:.78rem;color:var(--public-muted);margin-top:.2rem}
 .uk-card-phone{font-size:.78rem;color:var(--public-muted)}
 .uk-card-short{font-size:.78rem;color:var(--public-text-soft);margin-top:.3rem;line-height:1.55}
 .uk-empty{text-align:center;padding:4rem 1rem;color:var(--public-muted)}
 .uk-empty-icon{font-size:3.5rem;margin-bottom:.75rem}
 .uk-empty-link{display:inline-block;margin-top:.75rem;color:var(--public-accent);font-size:.85rem;transition:color .15s}
 .uk-empty-link:hover{color:var(--public-accent-strong)}
 </style>

 <div class="uk-breadcrumb">
 <div class="sf-container">
 <nav>
 <a href="/">Ana Sayfa</a>
 <span>/</span>
 <a href="/ulasim">Ulaşım</a>
 <span>/</span>
 <span>{meta.name}</span>
 </nav>
 </div>
 </div>

 <div class="uk-hero">
 <div class="sf-container">
 <div class="uk-hero-inner">
 <span class="uk-hero-icon">{meta.icon}</span>
 <div>
 <h1 class="uk-h1">Şanlıurfa {meta.name}</h1>
 <p class="uk-desc">{meta.desc}</p>
 </div>
 </div>
 </div>
 </div>

 <div class="uk-body">
 <div class="sf-container">
 {places.length > 0 ? (
 <div class="uk-grid">
 {places.map((place) => (
 <a href={`/isletme/${place.slug}`} class="uk-card">
 <span class="uk-card-icon">{meta.icon}</span>
 <div>
 <p class="uk-card-name">{place.name}</p>
 {place.address && <p class="uk-card-addr">📍 {place.address}</p>}
 {place.phone && <p class="uk-card-phone">📞 {place.phone}</p>}
 {place.short_description && <p class="uk-card-short">{place.short_description}</p>}
 </div>
 </a>
 ))}
 </div>
 ) : (
 <div class="uk-empty">
 <div class="uk-empty-icon">{meta.icon}</div>
 <p>Bu kategoride henüz kayıt bulunmuyor.</p>
 <a href="/ulasim" class="uk-empty-link">Ulaşım Rehberine Dön →</a>
 </div>
 )}
 </div>
 </div>

 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'CollectionPage',
 name: `Şanlıurfa ${meta.name}`,
 description: `Şanlıurfa'da ${meta.name.toLowerCase()}. ${meta.desc}`,
 url: `${baseUrl}/ulasim/${kategori}`,
 about: { '@type': 'City', name: 'Şanlıurfa' },
 itemListElement: places.slice(0, 10).map((p: any, i: number) => ({
 '@type': 'ListItem',
 position: i + 1,
 item: {
 '@type': 'LocalBusiness',
 '@id': `${baseUrl}/isletme/${p.slug}`,
 name: p.name,
 url: `${baseUrl}/isletme/${p.slug}`,
 ...(p.address ? { address: p.address } : {}),
 ...(p.phone ? { telephone: p.phone } : {}),
 },
 })),
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'Ulaşım', item: `${baseUrl}/ulasim` },
 { '@type': 'ListItem', position: 3, name: meta.name, item: `${baseUrl}/ulasim/${kategori}` },
 ],
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqItems.map((item) => ({
 '@type': 'Question',
 name: item.S,
 acceptedAnswer: { '@type': 'Answer', text: item.C },
 })),
 })} is:inline />
</Layout>
