---

import Layout from '../../layouts/Layout.astro';
import { query } from '../../lib/postgres';
import { getSiteBranding } from '../../lib/site-branding';
const { baseUrl } = await getSiteBranding();

const seo = {
  title: 'Şanlıurfa Otobüs Saatleri | Güncel Toplu Taşıma Rehberi',
  description: 'Şanlıurfa otobüs saatleri, yoğun saat aralıkları, aktarma noktaları ve ulaşım önerileri. Güncel şehir içi toplu taşıma rehberi.',
  keywords: ['Şanlıurfa otobüs saatleri', 'Şanlıurfa toplu taşıma', 'Şanlıurfa ulaşım', 'Şanlıurfa EGO'],
  ogImage: '/images/hero/hero-home.webp',
  canonical: '/ulasim/otobus-saatleri',
};

let dbRoutes: any[] = [];
try {
  const result = await query(
    `SELECT r.id, r.route_no, r.name, r.start_stop, r.end_stop, r.notes,
            array_agg(s.departure_time::TEXT ORDER BY s.departure_time) FILTER (WHERE s.day_type = 'weekday' AND s.direction = 'outbound') as weekday_times
     FROM bus_routes r
     LEFT JOIN bus_schedules s ON s.route_id = r.id
     WHERE r.is_active = true
     GROUP BY r.id
     ORDER BY r.route_no`,
    [],
  );
  dbRoutes = result.rows;
} catch { /* migration henüz çalışmamış olabilir, fallback göster */ }

const timeBands = [
  { label: 'Sabah', range: '06:00 - 09:00', note: 'İşe / okula gidiş yoğunluğu' },
  { label: 'Öğle', range: '12:00 - 14:00', note: 'Orta seviye yoğunluk' },
  { label: 'Akşam', range: '17:00 - 20:00', note: 'Dönüş saatlerinde yoğunluk' },
  { label: 'Gece', range: '21:00 - 23:30', note: 'Seyrek sefer aralığı' },
];

const keyStops = [
  'Topçu Meydanı',
  'Abide Kavşağı',
  'Balıklıgöl Çevresi',
  'Karaköprü Merkez',
  'Haliliye Devlet Hastanesi',
  'GAP Otogarı',
];

const faqItems = [
  {
    q: 'Şanlıurfa otobüs saatleri nasıl takip edilir?',
    a: 'Hat bazlı saatleri ilgili ulaşım sayfalarından kontrol ederek en güncel planı görebilirsiniz.',
  },
  {
    q: 'Yoğun saatlerde sefer aralığı nasıl değişir?',
    a: 'Sabah ve akşam yoğun saatlerinde sefer aralıkları sıklaşabilir, gece saatlerinde seyrekleşir.',
  },
  {
    q: 'Otobüs saatleri mevsime göre değişir mi?',
    a: 'Evet, yaz-kış dönemleri ve resmi günlerde sefer planları güncellenebilir; son tabloyu hat sayfasından doğrulayın.',
  },
];
---

<Layout seo={seo}>
  <div class="min-h-screen bg-[#FDFAF3]">
    <section class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)] text-white py-14">
      <div class="container mx-auto px-4">
        <h1 class="text-4xl font-bold text-[#F5EDD6] mb-3">Şanlıurfa Otobüs Saatleri</h1>
        <p class="text-[#C4B49A] max-w-2xl">
          Şanlıurfa şehir içi toplu taşıma için saat aralıkları, yoğunluk bilgileri ve ana aktarma noktaları.
        </p>
        <p id="transport-freshness" class="mt-2 text-xs text-[#9A8470]">Veri tazeliği kontrol ediliyor...</p>
        <div class="mt-5 flex flex-wrap gap-3">
          <a href="/ulasim/otobus-hatlari" class="px-4 py-2 rounded-sm bg-[#F5EDD6] text-[#1A1008] font-semibold hover:bg-[#EDE0C4]">
            Otobüs Hatları
          </a>
          <a href="/ulasim" class="px-4 py-2 rounded-sm border border-white/40 hover:bg-white/10">
            Ulaşım Rehberi
          </a>
        </div>
      </div>
    </section>

    <section class="py-10">
      <div class="container mx-auto px-4 grid lg:grid-cols-3 gap-6">
        <div class="lg:col-span-3 bg-[rgba(200,160,100,0.06)] border border-[rgba(200,160,100,0.2)] rounded-sm p-5">
          <p class="text-sm font-semibold uppercase tracking-wide text-[#9A8470]">Hızlı Cevap</p>
          <h2 class="mt-1 text-xl font-bold text-[#1A1008]">Şanlıurfa otobüs saatleri nereden takip edilir?</h2>
          <p class="mt-2 text-sm leading-6 text-[#6B5540]">
            Şanlıurfa otobüs saatleri için yoğun saat aralıklarını, ana aktarma noktalarını ve ulaşım bağlantılarını
            bu sayfadan kontrol edebilirsiniz. Kesin hat saatleri değişebileceği için son tazelik bilgisi ayrıca gösterilir.
          </p>
        </div>

        {dbRoutes.length > 0 && (
          <div class="lg:col-span-2 bg-white rounded-sm border border-[rgba(200,160,100,0.18)] p-6 shadow-sm mb-6">
            <h2 class="text-2xl font-bold text-[#1A1008] mb-4">Hat Saatleri (DB)</h2>
            <div class="space-y-4">
              {dbRoutes.map((route: any) => (
                <div class="border border-[rgba(200,160,100,0.18)] rounded-sm p-4">
                  <div class="flex items-center gap-2 mb-2">
                    <span class="font-bold text-lg text-urfa-600">{route.route_no}</span>
                    <span class="font-medium text-[#1A1008]">{route.name}</span>
                    <span class="text-xs text-[#9A8470] ml-auto">{route.start_stop} → {route.end_stop}</span>
                  </div>
                  {route.weekday_times?.length > 0 && (
                    <div class="flex flex-wrap gap-1.5 mt-1">
                      {route.weekday_times.slice(0, 12).map((t: string) => (
                        <span class="text-xs bg-[rgba(200,160,100,0.08)] text-[#6B5540] px-2 py-0.5 rounded-sm font-mono">{t.slice(0,5)}</span>
                      ))}
                      {route.weekday_times.length > 12 && (
                        <span class="text-xs text-[#9A8470]">+{route.weekday_times.length - 12} daha…</span>
                      )}
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        )}

        <div class="lg:col-span-2 bg-white rounded-sm border border-[rgba(200,160,100,0.18)] p-6 shadow-sm">
          <h2 class="text-2xl font-bold text-[#1A1008] mb-4">Yoğunluk ve Saat Aralıkları</h2>
          <div class="space-y-3">
            {timeBands.map((item) => (
              <div class="border border-[rgba(200,160,100,0.18)] rounded-sm p-4">
                <div class="flex items-center justify-between gap-4">
                  <p class="font-semibold text-[#1A1008]">{item.label}</p>
                  <span class="text-sm text-[#6B5540] bg-[rgba(200,160,100,0.08)] px-3 py-1 rounded-sm">{item.range}</span>
                </div>
                <p class="text-sm text-[#6B5540] mt-1">{item.note}</p>
              </div>
            ))}
          </div>
          <p class="text-xs text-[#9A8470] mt-4">
            Not: Hat bazlı kesin sefer saatleri dönemsel olarak güncellenebilir. Son doğrulama için ilgili hat sayfasını kontrol edin.
          </p>
        </div>

        <aside class="space-y-4">
          <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] p-5 shadow-sm">
            <h3 class="font-bold text-[#1A1008] mb-3">Ana Aktarma Noktaları</h3>
            <ul class="space-y-2 text-sm text-[#6B5540]">
              {keyStops.map((stop) => (
                <li class="flex items-center gap-2"><span>📍</span><span>{stop}</span></li>
              ))}
            </ul>
          </div>
          <div class="bg-[rgba(200,160,100,0.06)] border border-[rgba(200,160,100,0.2)] rounded-sm p-5">
            <h3 class="font-bold text-[#1A1008]">Hızlı Erişim</h3>
            <div class="mt-3 space-y-2 text-sm">
              <a href="/saglik/nobetci-eczaneler" class="block text-urfa-600 hover:underline">Nöbetçi Eczaneler</a>
              <a href="/etkinlikler" class="block text-urfa-600 hover:underline">Etkinlik Takvimi</a>
              <a href="/mekanlar" class="block text-urfa-600 hover:underline">Mekan Rehberi</a>
            </div>
          </div>
        </aside>
      </div>
    </section>
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqItems.map((item) => ({
        '@type': 'Question',
        name: item.q,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.a,
        },
      })),
    })} is:inline />
  </div>
  <script is:inline>
    async function loadTransportFreshness() {
      try {
        const res = await fetch('/api/transport/status');
        if (!res.ok) return;
        const json = await res.json();
        const el = document.getElementById('transport-freshness');
        if (!el || !json?.success) return;
        const updatedAt = json?.data?.updatedAt;
        const stale = Boolean(json?.data?.stale);
        el.textContent = updatedAt
          ? `Son güncelleme: ${new Date(updatedAt).toLocaleString('tr-TR')} (${stale ? 'eski veri' : 'güncel'})`
          : 'Son güncelleme bilgisi yok';
      } catch {
        // silent
      }
    }
    void loadTransportFreshness();
  </script>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Ulaşım', item: `${baseUrl}/ulasim` },
      { '@type': 'ListItem', position: 3, name: 'Otobüs Saatleri', item: `${baseUrl}/ulasim/otobus-saatleri` },
    ],
  })} is:inline />
</Layout>
