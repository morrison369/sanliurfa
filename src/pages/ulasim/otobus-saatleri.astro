---

import Layout from '../../layouts/Layout.astro';
import StatusStrip from '../../components/ui/StatusStrip.astro';
import { query } from '../../lib/postgres';
import { getPublicAppUrl } from '../../lib/public-app-url';
import { buildFreshnessUiState } from '../../lib/city-service-freshness';
import { getTransportStatusSnapshot } from '../../lib/transport/status';
import { getCachedPublicRouteData } from '../../lib/public-route-cache';
const baseUrl = getPublicAppUrl();

const seo = {
 title: 'Şanlıurfa Otobüs Saatleri | Güncel Toplu Taşıma Rehberi',
 description: 'Şanlıurfa otobüs saatleri, yoğun saat aralıkları, aktarma noktaları ve ulaşım önerileri. Güncel şehir içi toplu taşıma rehberi.',
 keywords: ['Şanlıurfa otobüs saatleri', 'Şanlıurfa toplu taşıma', 'Şanlıurfa ulaşım', 'Şanlıurfa EGO'],
 ogImage: '/images/places/balikligol.jpg',
 canonical: '/ulasim/otobus-saatleri',
};

type BusRouteRow = {
 id: string;
 route_no: string | number;
 name: string;
 start_stop?: string | null;
 end_stop?: string | null;
 notes?: string | null;
 weekday_times?: string[] | null;
};

let dbRoutes: BusRouteRow[] = [];
const transportStatus = await getTransportStatusSnapshot().catch(() => null);
try {
 const data = await getCachedPublicRouteData('page:ulasim:otobus-saatleri', async () => {
  const result = await query(
  `SELECT r.id, r.route_no, r.name, r.start_stop, r.end_stop, r.notes,
  array_agg(s.departure_time::TEXT ORDER BY s.departure_time) FILTER (WHERE s.day_type = 'weekday' AND s.direction = 'outbound') as weekday_times
  FROM bus_routes r
  LEFT JOIN bus_schedules s ON s.route_id = r.id
  WHERE r.is_active = true
  GROUP BY r.id
  ORDER BY r.route_no`,
  [],
  );
  return { dbRoutes: result.rows };
 });
 dbRoutes = data.dbRoutes;
} catch { /* migration henüz çalışmamış olabilir, fallback göster */ }

const transportFreshnessUi = buildFreshnessUiState(
 transportStatus?.updatedAt || null,
 transportStatus?.stale ?? true,
);
const transportFreshnessValue = transportStatus
 ? `${transportFreshnessUi.text.replace('Veri durumu: ', '')} • ${transportStatus.busRoutesCount} hat / ${transportStatus.busSchedulesCount} sefer`
 : 'Güncelleme bilgisi alınamadı';
const nextBusLabel = transportStatus?.nextBus?.route_name
 ? `${String(transportStatus.nextBus.route_no || '').trim()} · ${(transportStatus.nextBus.departure || '').slice(0, 5)}`
 : 'Sonraki sefer bilgisi yok';

const timeBands = [
 { label: 'Sabah', range: '06:00 - 09:00', note: 'İşe / okula gidiş yoğunluğu' },
 { label: 'Öğle', range: '12:00 - 14:00', note: 'Orta seviye yoğunluk' },
 { label: 'Akşam', range: '17:00 - 20:00', note: 'Dönüş saatlerinde yoğunluk' },
 { label: 'Gece', range: '21:00 - 23:30', note: 'Seyrek sefer aralığı' },
];

const keyStops = [
 'Topçu Meydanı',
 'Abide Kavşağı',
 'Balıklıgöl Çevresi',
 'Karaköprü Merkez',
 'Haliliye Devlet Hastanesi',
 'GAP Otogarı',
];

const faqItems = [
 {
 q: 'Şanlıurfa otobüs saatleri nasıl takip edilir?',
 a: 'Hat bazlı saatleri ilgili ulaşım sayfalarından kontrol ederek en güncel planı görebilirsiniz.',
 },
 {
 q: 'Yoğun saatlerde sefer aralığı nasıl değişir?',
 a: 'Sabah ve akşam yoğun saatlerinde sefer aralıkları sıklaşabilir, gece saatlerinde seyrekleşir.',
 },
 {
 q: 'Otobüs saatleri mevsime göre değişir mi?',
 a: 'Evet, yaz-kış dönemleri ve resmi günlerde sefer planları güncellenebilir; son tabloyu hat sayfasından doğrulayın.',
 },
];
---

<Layout seo={seo}>
 <style is:inline>
 .os-hero{position:relative;overflow:hidden;border-bottom:1px solid rgba(184,115,51,0.12);padding:clamp(3rem,6vw,5rem) 0;background:radial-gradient(circle at 18% 0%,rgba(212,151,24,0.10) 0%,transparent 42%),radial-gradient(circle at 82% 100%,rgba(44,122,82,0.08) 0%,transparent 40%),linear-gradient(180deg,#fbf6ec 0%,#f4ecd8 58%,#fbf6ec 100%)}
 .os-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.8rem,4vw,2.8rem);font-weight:700;color:var(--public-text);margin-bottom:.5rem}
 .os-hero-desc{color:var(--public-muted);max-width:40rem;font-size:.9rem}
 .os-hero-btns{margin-top:1.25rem;display:flex;flex-wrap:wrap;gap:.75rem}
 .os-btn-primary{padding:.5rem 1rem;background:var(--public-text);color:#0D0A08;font-weight:600;font-size:.85rem;transition:background .15s}
 .os-btn-primary:hover{background:var(--public-accent)}
 .os-btn-ghost{padding:.5rem 1rem;border:1px solid rgba(237,224,198,.3);color:var(--public-text);font-size:.85rem;transition:background .15s}
 .os-btn-ghost:hover{background:rgba(237,224,198,.08)}
 .os-body{background:var(--bg);padding:2.5rem 0 4rem}
 .os-grid{display:grid;gap:1.5rem}
 @media(min-width:64rem){.os-grid{grid-template-columns:1fr 1fr 1fr}}
 .os-span2{grid-column:span 1}
 @media(min-width:64rem){.os-span2{grid-column:span 2}}
 .os-qa{background:rgba(184,115,51,.05);border:1px solid rgba(184,115,51,.2);padding:1.25rem;margin-bottom:1.5rem}
 .os-qa-label{font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:var(--public-text-soft)}
 .os-qa-h2{font-size:1.1rem;font-weight:700;color:var(--public-text);margin:.25rem 0}
 .os-qa-p{font-size:.8rem;line-height:1.7;color:var(--public-muted)}
 .os-card{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);padding:1.5rem;margin-bottom:1rem}
 .os-card-title{font-size:1.2rem;font-weight:700;color:var(--public-text);margin-bottom:1rem}
 .os-route-item{border:1px solid rgba(184,115,51,.14);padding:1rem;margin-bottom:.75rem}
 .os-route-item:last-child{margin-bottom:0}
 .os-route-top{display:flex;align-items:center;gap:.5rem;margin-bottom:.5rem}
 .os-route-no{font-size:1.1rem;font-weight:800;color:var(--public-accent)}
 .os-route-name{font-size:.9rem;font-weight:600;color:var(--public-text)}
 .os-route-ends{font-size:.72rem;color:var(--public-text-soft);margin-left:auto}
 .os-times{display:flex;flex-wrap:wrap;gap:.3rem;margin-top:.25rem}
 .os-time-chip{font-size:.7rem;background:rgba(184,115,51,.08);color:var(--public-muted);padding:.1rem .45rem;font-family:monospace}
 .os-times-more{font-size:.7rem;color:var(--public-text-soft);align-self:center}
 .os-band-item{border:1px solid rgba(184,115,51,.14);padding:1rem;margin-bottom:.5rem}
 .os-band-item:last-child{margin-bottom:0}
 .os-band-row{display:flex;align-items:center;justify-content:space-between;gap:1rem}
 .os-band-label{font-size:.9rem;font-weight:600;color:var(--public-text)}
 .os-band-range{font-size:.8rem;color:var(--public-muted);background:rgba(184,115,51,.08);padding:.2rem .65rem}
 .os-band-note{font-size:.78rem;color:var(--public-muted);margin-top:.25rem}
 .os-note{font-size:.7rem;color:var(--public-text-soft);margin-top:.75rem}
 .os-sidebar{display:flex;flex-direction:column;gap:1rem}
 .os-sidebar-card{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);padding:1.25rem}
 .os-sidebar-title{font-size:.9rem;font-weight:700;color:var(--public-text);margin-bottom:.75rem}
 .os-stop{display:flex;align-items:center;gap:.5rem;font-size:.8rem;color:var(--public-muted);padding:.2rem 0}
 .os-quick-card{background:rgba(184,115,51,.05);border:1px solid rgba(184,115,51,.2);padding:1.25rem}
 .os-quick-title{font-size:.9rem;font-weight:700;color:var(--public-text);margin-bottom:.5rem}
 .os-link{display:block;font-size:.8rem;color:var(--public-accent);padding:.15rem 0;transition:color .15s}
 .os-link:hover{color:var(--public-accent-strong)}
 </style>

 <div class="os-hero">
 <div class="sf-container">
 <h1 class="os-h1">Şanlıurfa Otobüs Saatleri</h1>
 <p class="os-hero-desc">
 Şanlıurfa şehir içi toplu taşıma için saat aralıkları, yoğunluk bilgileri ve ana aktarma noktaları.
 </p>
 <p class="os-hero-desc" style="margin-top:.45rem">Sonraki otobüs: {nextBusLabel}</p>
 <div style="margin-top:.5rem">
 <StatusStrip
 label="Veri"
 value={transportFreshnessValue}
 statusLabel={transportFreshnessUi.statusLabel}
 toneClass={transportFreshnessUi.toneClass}
 />
 </div>
 <div class="os-hero-btns">
 <a href="/ulasim/otobus-hatlari" class="os-btn-primary">Otobüs Hatları</a>
 <a href="/ulasim" class="os-btn-ghost">Ulaşım Rehberi</a>
 </div>
 </div>
 </div>

 <div class="os-body">
 <div class="sf-container">
 <div class="os-qa">
 <p class="os-qa-label">Hızlı Cevap</p>
 <h2 class="os-qa-h2">Şanlıurfa otobüs saatleri nereden takip edilir?</h2>
 <p class="os-qa-p">
 Şanlıurfa otobüs saatleri için yoğun saat aralıklarını, ana aktarma noktalarını ve ulaşım bağlantılarını
 bu sayfadan kontrol edebilirsiniz. Kesin hat saatleri değişebileceği için son tazelik bilgisi ayrıca gösterilir.
 </p>
 </div>

 <div class="os-grid">
 <div class="os-span2">
 {dbRoutes.length > 0 && (
 <div class="os-card">
 <h2 class="os-card-title">Hat Saatleri</h2>
 {dbRoutes.map((route) => {
 const weekdayTimes = route.weekday_times ?? [];
 return (
 <div class="os-route-item">
 <div class="os-route-top">
 <span class="os-route-no">{route.route_no}</span>
 <span class="os-route-name">{route.name}</span>
 <span class="os-route-ends">{route.start_stop} → {route.end_stop}</span>
 </div>
 {weekdayTimes.length > 0 && (
 <div class="os-times">
 {weekdayTimes.slice(0, 12).map((t: string) => (
 <span class="os-time-chip">{t.slice(0,5)}</span>
 ))}
 {weekdayTimes.length > 12 && (
 <span class="os-times-more">+{weekdayTimes.length - 12} daha…</span>
 )}
 </div>
 )}
 </div>
 );
 })}
 </div>
 )}

 <div class="os-card">
 <h2 class="os-card-title">Yoğunluk ve Saat Aralıkları</h2>
 {timeBands.map((item) => (
 <div class="os-band-item">
 <div class="os-band-row">
 <p class="os-band-label">{item.label}</p>
 <span class="os-band-range">{item.range}</span>
 </div>
 <p class="os-band-note">{item.note}</p>
 </div>
 ))}
 <p class="os-note">
 Not: Hat bazlı kesin sefer saatleri dönemsel olarak güncellenebilir. Son doğrulama için ilgili hat sayfasını kontrol edin.
 </p>
 </div>
 </div>

 <div class="os-sidebar">
 <div class="os-sidebar-card">
 <h3 class="os-sidebar-title">Ana Aktarma Noktaları</h3>
 {keyStops.map((stop) => (
 <div class="os-stop">📍 <span>{stop}</span></div>
 ))}
 </div>
 <div class="os-quick-card">
 <h3 class="os-quick-title">Hızlı Erişim</h3>
 <a href="/saglik/nobetci-eczaneler" class="os-link" style="margin-top:.5rem">Nöbetçi Eczaneler</a>
 <a href="/etkinlikler" class="os-link">Etkinlik Takvimi</a>
 <a href="/mekanlar" class="os-link">Mekan Rehberi</a>
 </div>
 </div>
 </div>
 </div>
 </div>

 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqItems.map((item) => ({
 '@type': 'Question',
 name: item.q,
 acceptedAnswer: { '@type': 'Answer', text: item.a },
 })),
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'Ulaşım', item: `${baseUrl}/ulasim` },
 { '@type': 'ListItem', position: 3, name: 'Otobüs Saatleri', item: `${baseUrl}/ulasim/otobus-saatleri` },
 ],
 })} is:inline />
</Layout>
