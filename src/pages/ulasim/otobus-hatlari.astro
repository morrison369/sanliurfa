---

import Layout from '../../layouts/Layout.astro';
import { query } from '../../lib/postgres';
import { getSiteBranding } from '../../lib/site-branding';
const { baseUrl } = await getSiteBranding();

const seo = {
  title: 'Şanlıurfa Otobüs Hatları | Şehir İçi Ulaşım Rehberi',
  description: 'Şanlıurfa şehir içi otobüs hatları, güzergahlar, duraklar ve sefer bilgileri. Güncel hat listesi ve toplu taşıma rehberi.',
  keywords: ['Şanlıurfa otobüs hatları', 'Şanlıurfa toplu taşıma', 'Şanlıurfa otobüs güzergahı'],
  ogImage: '/images/hero/hero-home.webp',
  canonical: '/ulasim/otobus-hatlari',
};

let routes: any[] = [];
try {
  const result = await query(
    `SELECT r.id, r.route_no, r.name, r.start_stop, r.end_stop, r.notes,
            COUNT(s.id) FILTER (WHERE s.day_type = 'weekday') as weekday_count,
            array_agg(s.departure_time::TEXT ORDER BY s.departure_time) FILTER (WHERE s.day_type = 'weekday' AND s.direction = 'outbound') as weekday_times
     FROM bus_routes r
     LEFT JOIN bus_schedules s ON s.route_id = r.id
     WHERE r.is_active = true
     GROUP BY r.id
     ORDER BY r.route_no`,
    [],
  );
  routes = result.rows;
} catch { /* migration henüz çalışmamış olabilir */ }

const faqItems = [
  {
    S: 'Şanlıurfa otobüs hatları kaç tanedir?',
    C: `Şanlıurfa'da şu an ${routes.length > 0 ? routes.length + ' aktif' : 'çok sayıda'} şehir içi otobüs hattı hizmet vermektedir.`,
  },
  {
    S: 'Şanlıurfa otobüs hatları ne zaman çalışır?',
    C: "Şanlıurfa şehir içi otobüsleri genellikle sabah 06:00\'dan gece 23:30\'a kadar sefer yapmaktadır. Hat ve güne göre seferler değişebilir.",
  },
  {
    S: 'Şanlıurfa otobüs ücretleri ne kadardır?',
    C: 'Ücretler belediye tarifesine göre belirlenir ve Kent Kart ile indirimli binme imkânı sunulur.',
  },
];
---

<Layout seo={seo}>
  <div class="min-h-screen bg-[#FDFAF3]">
    <section class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)] text-white py-14">
      <div class="container mx-auto px-4">
        <nav class="text-sm text-[#9A8470] mb-4">
          <a href="/" class="hover:text-white">Ana Sayfa</a> /
          <a href="/ulasim" class="hover:text-white ml-1">Ulaşım</a> /
          <span class="ml-1 text-[#C4B49A]">Otobüs Hatları</span>
        </nav>
        <h1 class="text-4xl font-bold text-[#F5EDD6] mb-3">Şanlıurfa Otobüs Hatları</h1>
        <p class="text-[#C4B49A] max-w-2xl">
          Şanlıurfa şehir içi toplu taşıma hatları, güzergahlar ve sefer saatleri.
          {routes.length > 0 && <span class="font-semibold"> {routes.length} aktif hat.</span>}
        </p>
        <div class="mt-5 flex flex-wrap gap-3">
          <a href="/ulasim/otobus-saatleri" class="px-4 py-2 rounded-sm bg-[#F5EDD6] text-[#1A1008] font-semibold hover:bg-[#EDE0C4] text-sm">
            Saat Tabloları
          </a>
          <a href="/ulasim" class="px-4 py-2 rounded-sm border border-white/40 hover:bg-white/10 text-sm">
            Ulaşım Rehberi
          </a>
        </div>
      </div>
    </section>

    <div class="container mx-auto px-4 py-10">
      {routes.length > 0 ? (
        <div class="space-y-4 mb-12">
          <h2 class="text-2xl font-bold text-[#1A1008]">Aktif Hatlar</h2>
          <div class="grid md:grid-cols-2 gap-4">
            {routes.map((route) => (
              <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-5">
                <div class="flex items-center gap-3 mb-3">
                  <span class="text-2xl font-extrabold text-urfa-600 min-w-[2.5rem]">{route.route_no}</span>
                  <div>
                    <p class="font-semibold text-[#1A1008]">{route.name}</p>
                    {route.start_stop && route.end_stop && (
                      <p class="text-xs text-[#9A8470]">{route.start_stop} → {route.end_stop}</p>
                    )}
                  </div>
                </div>
                {route.weekday_times?.length > 0 && (
                  <div>
                    <p class="text-xs font-medium text-[#9A8470] mb-1.5">Hafta içi gidiş saatleri:</p>
                    <div class="flex flex-wrap gap-1.5">
                      {route.weekday_times.slice(0, 10).map((t: string) => (
                        <span class="text-xs bg-[rgba(200,160,100,0.08)] text-[#6B5540] px-2 py-0.5 rounded-sm font-mono">{t.slice(0,5)}</span>
                      ))}
                      {route.weekday_times.length > 10 && (
                        <span class="text-xs text-[#9A8470] self-center">+{route.weekday_times.length - 10} daha</span>
                      )}
                    </div>
                  </div>
                )}
                {route.notes && (
                  <p class="text-xs text-[#9A8470] mt-3 italic">{route.notes}</p>
                )}
              </div>
            ))}
          </div>
        </div>
      ) : (
        <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] p-8 text-center shadow-sm mb-12">
          <div class="text-5xl mb-3">🚌</div>
          <h2 class="text-xl font-bold text-[#1A1008] mb-2">Hat Bilgileri Yükleniyor</h2>
          <p class="text-[#9A8470] text-sm">Otobüs hat verileri yakında sisteme eklenecektir.</p>
        </div>
      )}

      {/* Genel bilgi */}
      <div class="grid md:grid-cols-3 gap-4 mb-12">
        <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] p-5 shadow-sm">
          <div class="text-3xl mb-2">🕐</div>
          <h3 class="font-bold text-[#1A1008] mb-1">Çalışma Saatleri</h3>
          <p class="text-sm text-[#6B5540]">Genellikle 06:00 – 23:30 arası. Hat ve güne göre değişir.</p>
        </div>
        <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] p-5 shadow-sm">
          <div class="text-3xl mb-2">💳</div>
          <h3 class="font-bold text-[#1A1008] mb-1">Kent Kart</h3>
          <p class="text-sm text-[#6B5540]">İndirimli binme için Kent Kart kullanabilirsiniz.</p>
        </div>
        <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] p-5 shadow-sm">
          <div class="text-3xl mb-2">📍</div>
          <h3 class="font-bold text-[#1A1008] mb-1">Ana Aktarma</h3>
          <p class="text-sm text-[#6B5540]">Topçu Meydanı, Abide Kavşağı, GAP Otogarı.</p>
        </div>
      </div>

      {/* FAQ */}
      <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
        <h2 class="text-xl font-bold text-[#1A1008] mb-4">Sık Sorulan Sorular</h2>
        <div class="space-y-4">
          {faqItems.map((faq) => (
            <div class="border-b border-[rgba(200,160,100,0.14)] pb-4 last:border-0 last:pb-0">
              <h3 class="font-semibold text-[#1A1008] mb-1">{faq.S}</h3>
              <p class="text-sm text-[#6B5540]">{faq.C}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: { '@type': 'Answer', text: item.C },
    })),
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Ulaşım', item: `${baseUrl}/ulasim` },
      { '@type': 'ListItem', position: 3, name: 'Otobüs Hatları', item: `${baseUrl}/ulasim/otobus-hatlari` },
    ],
  })} is:inline />
</Layout>
