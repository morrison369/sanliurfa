---

import Layout from '../../layouts/Layout.astro';
import { getSiteBranding } from '../../lib/site-branding';
const { baseUrl } = await getSiteBranding();

const seo = {
  title: 'Şanlıurfa Uçak Saatleri | GAP Havalimanı Uçuş Rehberi',
  description:
    'Şanlıurfa uçak saatleri için GAP Havalimanı rehberi. Uçuş planlama, terminal hazırlık adımları ve havalimanı ulaşım önerileri.',
  keywords: ['şanlıurfa uçak saatleri', 'gap havalimanı uçuşlar', 'şanlıurfa istanbul uçak', 'urfa havalimanı', 'şanlıurfa uçak bileti', 'gap havalimanı ulaşım'],
  ogImage: '/images/hero/hero-home.webp',
  canonical: '/ulasim/ucak-saatleri',
};

const flightBands = [
  { label: 'Sabah Uçuşları', range: '06:00 - 09:30', note: 'İş ve bağlantılı seferler için yoğun saat aralığı.' },
  { label: 'Öğle Uçuşları', range: '11:00 - 15:00', note: 'Şehirler arası düzenli sefer yoğunluğu.' },
  { label: 'Akşam Uçuşları', range: '17:00 - 22:30', note: 'Gün sonu dönüş ve bağlantı uçuşları.' },
];

const planningChecklist = [
  'Uçuştan en az 2 saat önce havalimanında olun.',
  'Bilet ve kimlik doğrulamasını online check-in ile önceden tamamlayın.',
  'Şehir merkezinden GAP Havalimanı transfer süresi için trafik payı bırakın.',
  'Bagaj kurallarını havayolu şirketine göre kontrol edin.',
];

const faqItems = [
  {
    S: 'Şanlıurfa uçak saatlerini nereden takip edebilirim?',
    C: 'GAP Havalimanı ve havayolu şirketlerinin güncel planları üzerinden uçuş saatlerini takip edebilirsiniz.',
  },
  {
    S: 'Şehir merkezinden GAP Havalimanı kaç dakika sürer?',
    C: 'Trafik durumuna göre ortalama 45-60 dakika sürebilir.',
  },
  {
    S: 'Uçuş öncesi havalimanına ne kadar erken gitmeliyim?',
    C: 'İç hat uçuşlarında en az 2 saat önce havalimanında olmanız önerilir.',
  },
];
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50">
    <section class="bg-gradient-to-br from-sky-900 to-slate-900 text-white py-14">
      <div class="container mx-auto px-4">
        <h1 class="text-4xl font-bold mb-3">Şanlıurfa Uçak Saatleri</h1>
        <p class="text-sky-100 max-w-2xl">
          Şanlıurfa GAP Havalimanı için uçuş planlama rehberi, yoğun saat aralıkları ve pratik ulaşım bilgileri.
        </p>
        <p id="transport-freshness" class="mt-2 text-xs text-sky-100">Veri tazeliği kontrol ediliyor...</p>
        <div class="mt-5 flex flex-wrap gap-3">
          <a href="/ulasim/havalimani" class="px-4 py-2 rounded-lg bg-white text-slate-900 font-semibold hover:bg-slate-100">
            Havalimanı Detayı
          </a>
          <a href="/ulasim" class="px-4 py-2 rounded-lg border border-white/40 hover:bg-white/10">
            Ulaşım Rehberi
          </a>
        </div>
      </div>
    </section>

    <section class="py-10">
      <div class="container mx-auto px-4 grid lg:grid-cols-3 gap-6">
        <div class="lg:col-span-3 rounded-2xl border border-sky-200 bg-white p-5 shadow-sm">
          <p class="text-sm font-semibold uppercase tracking-wide text-sky-700">Hızlı Cevap</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">Şanlıurfa uçak saatleri nasıl planlanır?</h2>
          <p class="mt-2 text-sm leading-6 text-gray-700">
            Şanlıurfa uçak saatleri için GAP Havalimanı hazırlık adımlarını, yoğun uçuş aralıklarını ve şehir merkezi
            ulaşım notlarını bu sayfadan takip edebilirsiniz. Kesin sefer bilgisi havayolu ve resmi uçuş ekranıyla doğrulanmalıdır.
          </p>
        </div>

        <div class="lg:col-span-2 bg-white rounded-2xl p-6 shadow-sm">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Uçuş Yoğunluk Aralıkları</h2>
          <div class="space-y-3">
            {flightBands.map((item) => (
              <div class="border border-gray-100 rounded-xl p-4">
                <div class="flex items-center justify-between gap-4">
                  <p class="font-semibold text-gray-900">{item.label}</p>
                  <span class="text-sm text-sky-700 bg-sky-100 px-3 py-1 rounded-full">{item.range}</span>
                </div>
                <p class="text-sm text-gray-600 mt-1">{item.note}</p>
              </div>
            ))}
          </div>
          <p class="text-xs text-gray-500 mt-4">
            Not: Kesin uçuş saatleri havayolu operasyonlarına göre değişebilir. Son bilgiyi resmi uçuş ekranından doğrulayın.
          </p>
        </div>

        <aside class="space-y-4">
          <div class="bg-white rounded-2xl p-5 shadow-sm">
            <h3 class="font-bold text-gray-900 mb-3">Uçuş Öncesi Kontrol Listesi</h3>
            <ul class="space-y-2 text-sm text-gray-700">
              {planningChecklist.map((item) => (
                <li class="flex items-start gap-2"><span>•</span><span>{item}</span></li>
              ))}
            </ul>
          </div>
          <div class="bg-sky-50 border border-sky-200 rounded-2xl p-5">
            <h3 class="font-bold text-sky-800">Hızlı Erişim</h3>
            <div class="mt-3 space-y-2 text-sm">
              <a href="/ulasim/otobus-saatleri" class="block text-sky-700 hover:underline">Otobüs Saatleri</a>
              <a href="/ulasim/havalimani" class="block text-sky-700 hover:underline">GAP Havalimanı</a>
              <a href="/saglik/nobetci-eczaneler" class="block text-sky-700 hover:underline">Nöbetçi Eczaneler</a>
            </div>
          </div>
        </aside>
      </div>
    </section>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.C,
      },
    })),
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Ulaşım', item: `${baseUrl}/ulasim` },
      { '@type': 'ListItem', position: 3, name: 'Uçak Saatleri', item: `${baseUrl}/ulasim/ucak-saatleri` },
    ],
  })} is:inline />
</Layout>
<script is:inline>
  async function loadTransportFreshness() {
    try {
      const res = await fetch('/api/transport/status');
      if (!res.ok) return;
      const json = await res.json();
      const el = document.getElementById('transport-freshness');
      if (!el || !json?.success) return;
      const updatedAt = json?.data?.updatedAt;
      const stale = Boolean(json?.data?.stale);
      el.textContent = updatedAt
        ? `Son güncelleme: ${new Date(updatedAt).toLocaleString('tr-TR')} (${stale ? 'eski veri' : 'güncel'})`
        : 'Son güncelleme bilgisi yok';
    } catch {
      // silent
    }
  }
  void loadTransportFreshness();
</script>
