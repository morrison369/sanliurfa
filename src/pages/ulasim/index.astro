---
import { Icon } from 'astro-icon/components';
import Layout from '../../layouts/Layout.astro';
import { query } from '../../lib/postgres';
import { getPublicAppUrl } from '../../lib/public-app-url';
import { logger } from '../../lib/logging';
import { getCachedPublicRouteData } from '../../lib/public-route-cache';

let featuredPlaces: any[] = [];

const ulasimCategories = [
 { slug: 'otogar', name: 'Otogar', icon: '🚌', desc: 'GAP Otogarı ve otobüs firmaları' },
 { slug: 'havalimani', name: 'Havalimanı', icon: '✈️', desc: 'GAP Havalimanı bilgileri' },
 { slug: 'ucak-saatleri', name: 'Uçak Saatleri', icon: '🛫', desc: 'Güncel uçuş saatleri', href: '/ulasim/ucak-saatleri' },
 { slug: 'taksi-duraklari', name: 'Taksi Durakları', icon: '🚕', desc: 'Taksi durakları ve ücretler' },
 { slug: 'arac-kiralama', name: 'Araç Kiralama', icon: '🚗', desc: 'Rent-a-car firmaları' },
 { slug: 'otobus-hatlari', name: 'Otobüs Hatları', icon: '🚎', desc: 'Şehir içi otobüs hatları', href: '/ulasim/otobus-hatlari' },
];

try {
 const data = await getCachedPublicRouteData('page:ulasim:index', async () => {
  const placesResult = await query(
  `SELECT p.*, c.name as category_name FROM places p
  LEFT JOIN categories c ON p.category_id = c.id
  WHERE c.slug IN ('otogar','havalimani','taksi-duraklari','arac-kiralama','otobus-hatlari')
  AND p.status = 'active'
  ORDER BY p.rating DESC LIMIT 6`
  );
  return { featuredPlaces: placesResult.rows };
 });
 featuredPlaces = data.featuredPlaces;
} catch (e) {
 logger.error('Error loading ulasim:', e instanceof Error ? e : new Error(String(e)));
}

const seo = {
 title: 'Şanlıurfa Ulaşım Rehberi | Otogar, Havalimanı, Taksi ve Otobüs',
 description: "Şanlıurfa\'da ulaşım bilgileri. GAP Otogarı, GAP Havalimanı, taksi durakları, araç kiralama ve şehir içi otobüs hatları.",
 keywords: ['şanlıurfa ulaşım', 'gap otogarı', 'gap havalimanı', 'şanlıurfa taksi', 'urfa otobüs', 'şanlıurfa araç kiralama', 'urfa şehir içi ulaşım'],
 ogImage: '/images/places/balikligol.jpg',
 canonical: '/ulasim',
};
const baseUrl = getPublicAppUrl();

const faqItems = [
 {
 S: 'Şanlıurfa otobüs saatleri nereden takip edilir?',
 C: 'Ulaşım rehberindeki otobüs saatleri bağlantısından şehir içi hat bilgilerine erişebilirsiniz.',
 },
 {
 S: 'Şanlıurfa uçak saatlerini nereden görebilirim?',
 C: 'Ulaşım sayfasındaki uçak saatleri bağlantısından /ulasim/ucak-saatleri ekranına giderek uçuş planlama bilgilerine ulaşabilirsiniz.',
 },
 {
 S: 'GAP Havalimanı şehir merkezine uzak mı?',
 C: 'GAP Havalimanı şehir merkezine yaklaşık 40 km mesafededir ve transfer alternatifleri ulaşım rehberinde yer alır.',
 },
 {
 S: "Şanlıurfa'da taksi ve araç kiralama bilgileri var mı?",
 C: 'Evet. Taksi durakları ve araç kiralama başlıkları altında ilgili ulaşım noktaları listelenir.',
 },
];
---

<Layout seo={seo}>
 <style is:inline>
 .ul-hero{position:relative;overflow:hidden;border-bottom:1px solid rgba(184,115,51,0.12);padding:clamp(3rem,6vw,5rem) 0;background:radial-gradient(circle at 18% 0%,rgba(212,151,24,0.10) 0%,transparent 42%),radial-gradient(circle at 82% 100%,rgba(44,122,82,0.08) 0%,transparent 40%),linear-gradient(180deg,#fbf6ec 0%,#f4ecd8 58%,#fbf6ec 100%)}
 .ul-hero-inner{max-width:50rem;margin:0 auto}
 .ul-eyebrow{font-size:.67rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--public-muted);margin-bottom:.5rem}
 .ul-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.9rem,4vw,3rem);font-weight:600;color:var(--public-text);margin-bottom:.5rem}
 .ul-sub{font-size:.88rem;color:var(--public-accent);line-height:1.75;max-width:560px}
 .ul-body{background:var(--bg);padding:2.5rem 0 5rem}
 .ul-quick-box{background:rgba(184,115,51,.05);border:1px solid rgba(184,115,51,.18);padding:1.1rem 1.4rem;margin-bottom:1.75rem}
 .ul-quick-title{font-size:.8rem;font-weight:700;color:var(--public-accent);margin-bottom:.25rem}
 .ul-quick-text{font-size:.78rem;color:var(--public-muted);line-height:1.65}
 .ul-info-grid{display:grid;gap:1rem;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));margin-bottom:2.5rem}
 .ul-info-box{background:rgba(184,115,51,.05);border:1px solid rgba(184,115,51,.18);padding:1.25rem 1.4rem}
 .ul-info-box-wide{grid-column:1/-1}
 .ul-info-title{font-size:1rem;font-weight:700;color:var(--public-text);margin-bottom:.4rem}
 .ul-info-text{font-size:.8rem;color:var(--public-muted);line-height:1.7;margin-bottom:.6rem}
 .ul-info-link{display:block;font-size:.8rem;color:var(--public-accent);font-weight:600;margin-top:.3rem;transition:color .15s}
 .ul-info-link:hover{color:var(--public-accent-strong)}
 .ul-section-title{font-family:'Cormorant Garamond',serif;font-size:1.25rem;font-weight:600;color:var(--public-text);margin-bottom:1.1rem}
 .ul-cat-grid{display:grid;gap:.85rem;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));margin-bottom:2.75rem}
 .ul-cat-card{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);padding:1.25rem;text-align:center;transition:border-color .15s,transform .15s}
 .ul-cat-card:hover{border-color:var(--public-accent);transform:translateY(-2px)}
 .ul-cat-icon{font-size:1.85rem;margin-bottom:.65rem}
 .ul-cat-name{font-size:.82rem;font-weight:700;color:var(--public-text);margin-bottom:.2rem;transition:color .15s}
 .ul-cat-card:hover .ul-cat-name{color:var(--public-accent)}
 .ul-cat-desc{font-size:.7rem;color:var(--public-muted)}
 .ul-feat-grid{display:grid;gap:.85rem;grid-template-columns:repeat(auto-fill,minmax(240px,1fr))}
 .ul-feat-card{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);padding:1.1rem;transition:border-color .15s}
 .ul-feat-card:hover{border-color:var(--public-accent)}
 .ul-feat-name{font-size:.88rem;font-weight:700;color:var(--public-text);margin-bottom:.15rem;transition:color .15s}
 .ul-feat-card:hover .ul-feat-name{color:var(--public-accent)}
 .ul-feat-cat{font-size:.7rem;color:var(--public-accent);font-weight:600;margin-bottom:.3rem}
 .ul-feat-meta{display:flex;align-items:center;gap:.3rem;font-size:.72rem;color:var(--public-text-soft);margin-top:.2rem}
 </style>

 <!-- Hero -->
 <div class="ul-hero">
 <div class="sf-container">
 <div class="ul-hero-inner">
 <p class="ul-eyebrow">Ulaşım Rehberi</p>
 <h1 class="ul-h1">Ulaşım Rehberi</h1>
 <p class="ul-sub">Şanlıurfa'ya nasıl gelinir? Şehir içi ulaşım ve tüm ulaşım bilgileri</p>
 </div>
 </div>
 </div>

 <!-- Body -->
 <div class="ul-body">
 <div class="sf-container">
 <div class="ul-quick-box">
 <p class="ul-quick-title">Hızlı Cevap</p>
 <p class="ul-quick-text">
 Şanlıurfa ulaşım rehberinde havalimanı, otogar, taksi durakları, araç kiralama ve otobüs hat bilgilerini tek sayfada bulabilirsiniz.
 </p>
 </div>

 <!-- Önemli Bilgi Kutuları -->
 <div class="ul-info-grid">
 <div class="ul-info-box">
 <p class="ul-info-title">✈️ GAP Havalimanı</p>
 <p class="ul-info-text">Şanlıurfa Merkeze ~40 km. Türk Hava Yolları, Pegasus ve SunExpress seferleri.</p>
 <a href="/ulasim/havalimani" class="ul-info-link">Detaylar →</a>
 <a href="/ulasim/ucak-saatleri" class="ul-info-link">Uçak Saatleri →</a>
 </div>
 <div class="ul-info-box">
 <p class="ul-info-title">🚌 GAP Otogarı</p>
 <p class="ul-info-text">Türkiye'nin dört bir yanına düzenli otobüs seferleri. Şehir merkezine yakın konum.</p>
 <a href="/ulasim/otogar" class="ul-info-link">Detaylar →</a>
 </div>
 <div class="ul-info-box ul-info-box-wide">
 <p class="ul-info-title">🕒 Otobüs Saatleri</p>
 <p class="ul-info-text">Şehir içi hat yoğunlukları, ana aktarma noktaları ve güncel saat aralıkları.</p>
 <a href="/ulasim/otobus-saatleri" class="ul-info-link">Otobüs Saatlerini Gör →</a>
 </div>
 </div>

 <!-- Kategoriler -->
 <h2 class="ul-section-title">Ulaşım Kategorileri</h2>
 <div class="ul-cat-grid">
 {ulasimCategories.map((cat) => (
 <a href={cat.href || `/ulasim/${cat.slug}`} class="ul-cat-card">
 <div class="ul-cat-icon">{cat.icon}</div>
 <p class="ul-cat-name">{cat.name}</p>
 <p class="ul-cat-desc">{cat.desc}</p>
 </a>
 ))}
 </div>

 <!-- Ulaşım Noktaları -->
 {featuredPlaces.length > 0 && (
 <div>
 <h2 class="ul-section-title">Ulaşım Noktaları</h2>
 <div class="ul-feat-grid">
 {featuredPlaces.map((place) => (
 <a href={`/isletme/${place.slug}`} class="ul-feat-card">
 <p class="ul-feat-name">{place.name}</p>
 <p class="ul-feat-cat">{place.category_name}</p>
 {place.address && (
 <p class="ul-feat-meta">
 <Icon name="lucide:map-pin" style="width:.7rem;height:.7rem" />
 {place.address}
 </p>
 )}
 {place.phone && (
 <p class="ul-feat-meta">
 <Icon name="lucide:phone" style="width:.7rem;height:.7rem" />
 {place.phone}
 </p>
 )}
 </a>
 ))}
 </div>
 </div>
 )}
 </div>
 </div>

 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqItems.map((item) => ({
 '@type': 'Question',
 name: item.S,
 acceptedAnswer: { '@type': 'Answer', text: item.C },
 })),
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'ItemList',
 name: 'Şanlıurfa Ulaşım Kategorileri',
 itemListElement: ulasimCategories.map((cat, index) => ({
 '@type': 'ListItem',
 position: index + 1,
 name: cat.name,
 url: `${baseUrl}${cat.href || `/ulasim/${cat.slug}`}`,
 })),
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'Ulaşım', item: `${baseUrl}/ulasim` },
 ],
 })} is:inline />
</Layout>
