---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import Image from '../components/Image.astro';
import SwipeMatchExperience from '../components/SwipeMatchExperience';
import { requireAuth } from '../lib/auth';
import { getPublicAppUrl } from '../lib/public-app-url';
import { query } from '../lib/postgres';
import PublicFaqList from '../components/public/PublicFaqList.astro';

const auth = await requireAuth(Astro.request);
const isAuthenticated = Boolean(auth.user);
const baseUrl = getPublicAppUrl();

// Public social stats (privacy-safe: sadece aggregate sayılar)
let socialStats = { activeProfiles: 0, matchesLast30Days: 0, swipesLast7Days: 0 };
try {
  const [a, b, c] = await Promise.all([
    query<{ c: string }>(`SELECT COUNT(*) AS c FROM user_match_profiles WHERE is_discoverable = true`).catch(() => ({ rows: [{ c: '0' }] })),
    query<{ c: string }>(`SELECT COUNT(*) AS c FROM social_matches WHERE created_at > NOW() - INTERVAL '30 days'`).catch(() => ({ rows: [{ c: '0' }] })),
    query<{ c: string }>(`SELECT COUNT(*) AS c FROM social_swipes WHERE created_at > NOW() - INTERVAL '7 days'`).catch(() => ({ rows: [{ c: '0' }] })),
  ]);
  socialStats = {
    activeProfiles: parseInt(a.rows[0]?.c || '0', 10),
    matchesLast30Days: parseInt(b.rows[0]?.c || '0', 10),
    swipesLast7Days: parseInt(c.rows[0]?.c || '0', 10),
  };
} catch { /* sessiz */ }

const seo = {
  title: 'Şanlıurfa Eşleşme | Swipe, Profil ve Mesajlaşma',
  description: 'Şanlıurfa topluluğunda profil oluştur, üyeleri kaydır, karşılıklı beğenide eşleş ve mesajlaşmaya başla.',
  canonical: '/eslesme',
  ogImage: '/images/places/balikligol.jpg',
  keywords: ['Şanlıurfa eşleşme', 'Şanlıurfa topluluk', 'Urfa sosyal ağ', 'Şanlıurfa mesajlaşma'],
};

const steps = [
  ['Profilini Tamamla', '4 fotoğrafa kadar görsel ekle, kısa tanıtımını yaz ve şehir içi sosyal keşfe hazır ol.'],
  ['Kaydır ve Seç', 'Sağa beğen, sola geç; akış güvenlik limitleriyle sade ve kontrollü ilerler.'],
  ['Eşleş ve Yazış', 'Karşılıklı beğeni oluştuğunda mesajlaşma akışına geçip sohbeti başlat.'],
];

const faqItems = [
  { S: 'Şanlıurfa eşleşme özelliği ücretsiz mi?', C: 'Evet. İlk aşamada eşleşme, profil görüntüleme ve mesajlaşma başlangıcı ücretsiz olarak açık tutulur.' },
  { S: 'Eşleşme profilinde kaç fotoğraf olabilir?', C: 'Kullanıcılar eşleşme profiline en fazla 4 fotoğraf ekleyebilir.' },
  { S: 'Eşleşme sonrası mesajlaşma yapılabilir mi?', C: 'Karşılıklı eşleşme sonrası üyeler mesajlaşma akışına geçebilir.' },
];
---

<Layout seo={seo}>
  <section class="bg-[radial-gradient(circle_at_top_left,#f0d8b7_0,#fff8ec_36%,#f8eddb_100%)] text-[#201711]">
    <div class="mx-auto grid min-h-[calc(100svh-4rem)] w-full max-w-7xl items-center gap-10 px-4 py-12 sm:px-6 lg:grid-cols-[0.95fr_1.05fr] lg:px-8">
      <div>
        <p class="inline-flex rounded-full border border-[#e1c59d] bg-white/75 px-4 py-2 text-sm font-black text-[#8a3d22]">
          Şanlıurfa sosyal keşif
        </p>
        <h1 class="mt-5 font-display text-4xl font-semibold leading-[1.08] text-[#201711] sm:text-5xl lg:text-6xl">
          Şanlıurfa’da Eşleş, Kaydır ve Mesajlaş
        </h1>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-[#5e4a38]">
          Şehir rehberi içindeki topluluk deneyimiyle profilini oluştur, Şanlıurfa’daki üyeleri kaydır, karşılıklı beğenide eşleş ve sohbeti başlat.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          {isAuthenticated ? (
            <a href="#swipe-deneyimi" class="inline-flex min-h-12 items-center justify-center rounded-full bg-[#78331d] px-6 text-sm font-black text-white shadow-lg shadow-[#78331d]/20 hover:bg-[#652918]">
              Eşleşme Akışını Aç
            </a>
          ) : (
            <>
              <a href="/kayit?redirect=/eslesme" class="inline-flex min-h-12 items-center justify-center rounded-full bg-[#78331d] px-6 text-sm font-black text-white shadow-lg shadow-[#78331d]/20 hover:bg-[#652918]">
                Ücretsiz Profil Oluştur
              </a>
              <a href="/giris?redirect=/eslesme" class="inline-flex min-h-12 items-center justify-center rounded-full border border-[#c99b6d] bg-white/75 px-6 text-sm font-black text-[#7c3b24] hover:bg-white">
                Giriş Yap
              </a>
            </>
          )}
          <a href="/topluluk" class="inline-flex min-h-12 items-center justify-center rounded-full border border-[#c99b6d] bg-white/75 px-6 text-sm font-black text-[#7c3b24] hover:bg-white">
            Topluluğu Gör
          </a>
        </div>
      </div>

      <div class="relative">
        <div class="grid grid-cols-2 gap-4">
          <div class="overflow-hidden rounded-3xl border border-white/80 bg-white shadow-2xl shadow-[#78331d]/12">
            <Image src="/images/places/balikligol.jpg" alt="Şanlıurfa topluluk ve Balıklıgöl çevresi" width={520} height={640} loading="eager" class="h-72 w-full object-cover" />
            <div class="p-4">
              <p class="text-xs font-black uppercase tracking-[0.14em] text-[#8a3d22]">Profil</p>
              <p class="mt-1 text-lg font-black text-[#201711]">4 fotoğraflı tanıtım</p>
            </div>
          </div>
          <div class="mt-10 overflow-hidden rounded-3xl border border-white/80 bg-white shadow-2xl shadow-[#155344]/12">
            <Image src="/images/foods/homepage/urfa-kebabi-card.png" alt="Şanlıurfa sosyal buluşma ve Urfa kebabı" width={520} height={640} loading="eager" class="h-72 w-full object-cover" />
            <div class="p-4">
              <p class="text-xs font-black uppercase tracking-[0.14em] text-[#155344]">Eşleşme</p>
              <p class="mt-1 text-lg font-black text-[#201711]">Karşılıklı beğeni</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Proof Stats Bar -->
  <section class="bg-[#f6ead6] px-4 py-8 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-3 gap-4 rounded-2xl border border-[#e2c79d] bg-white/85 p-4 shadow-sm sm:p-6">
        <div class="text-center">
          <p class="font-display text-3xl font-semibold text-[#78331d] sm:text-4xl">{socialStats.activeProfiles}+</p>
          <p class="mt-1 text-xs font-bold uppercase tracking-[0.08em] text-[#66513d] sm:text-sm">Aktif Profil</p>
        </div>
        <div class="text-center">
          <p class="font-display text-3xl font-semibold text-[#155344] sm:text-4xl">{socialStats.matchesLast30Days}</p>
          <p class="mt-1 text-xs font-bold uppercase tracking-[0.08em] text-[#66513d] sm:text-sm">Son 30 Gün Eşleşme</p>
        </div>
        <div class="text-center">
          <p class="font-display text-3xl font-semibold text-[#8a3d22] sm:text-4xl">{socialStats.swipesLast7Days}</p>
          <p class="mt-1 text-xs font-bold uppercase tracking-[0.08em] text-[#66513d] sm:text-sm">Son 7 Gün Aktivite</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#fff8ec] px-4 py-14 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-5 md:grid-cols-3">
      {steps.map(([title, desc], index) => (
        <article class="rounded-2xl border border-[#eadcc4] bg-white p-6 shadow-sm">
          <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-[#f3e4cc] text-[#78331d]">
            <Icon name={index === 0 ? 'image-plus' : index === 1 ? 'move-horizontal' : 'message-circle'} size={22} />
          </span>
          <h2 class="mt-4 font-display text-2xl font-semibold text-[#201711]">{title}</h2>
          <p class="mt-2 text-sm leading-6 text-[#66513d]">{desc}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="bg-[#f6ead6] px-4 py-14 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl rounded-[1.75rem] border border-[#e2c79d] bg-white p-6 shadow-xl shadow-[#78331d]/8 sm:p-8">
      <p class="text-sm font-black uppercase tracking-[0.14em] text-[#8a3d22]">Hızlı Cevap</p>
      <h2 class="mt-3 font-display text-3xl font-semibold text-[#201711]">Şanlıurfa eşleşme modülünde nasıl başlanır?</h2>
      <p class="mt-3 max-w-3xl text-base leading-7 text-[#66513d]">
        Ücretsiz hesap açtıktan sonra profilini tamamlayabilir, Şanlıurfa topluluğundaki üyeleri sağa veya sola kaydırarak değerlendirebilir ve karşılıklı eşleşme sonrası mesajlaşmaya başlayabilirsin.
      </p>
    </div>
  </section>

  {isAuthenticated && (
    <section id="swipe-deneyimi" class="bg-[#fffdf7] px-4 py-14 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <SwipeMatchExperience client:idle />
      </div>
    </section>
  )}

  {faqItems.length > 0 && (
    <section class="bg-[var(--bg)] px-4 py-12 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <PublicFaqList items={faqItems} />
      </div>
    </section>
  )}

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: { '@type': 'Answer', text: item.C },
    })),
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Şanlıurfa Eşleşme',
    url: `${baseUrl}/eslesme`,
    description: seo.description,
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Ana Sayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Eşleşme', item: `${baseUrl}/eslesme` },
    ],
  })} is:inline />
</Layout>
