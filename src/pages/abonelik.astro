---
import Layout from '../layouts/Layout.astro';
import { SubscriptionManager } from '../components/SubscriptionManager';

// Require authentication
if (!Astro.locals.user) {
  return Astro.redirect('/giris');
}
---

<Layout title="Üyelik Durumu - Şanlıurfa">
  <div class="max-w-4xl mx-auto px-4 py-8">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">
        Üyelik Durumu
      </h1>
      <p class="text-gray-600 dark:text-gray-400">
        Faz 1 açık erişim döneminde tüm özellikler ücretsiz olarak sunulmaktadır.
      </p>
    </div>

    <!-- Subscription Manager -->
    <div class="mb-12">
      <SubscriptionManager
        client:visible={{ rootMargin: '140px' }}
        onUpgrade={() => window.location.href = '/fiyatlandirma'}
      />
    </div>

    <!-- Billing History -->
    <div class="mb-8">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">
        Bilgilendirme
      </h2>
      <div class="rounded-lg border border-green-200 bg-green-50 p-4 text-green-900">
        Bu aşamada ücretli faturalama devre dışı. Ödeme geçmişi ekranı daha sonraki fazlarda aktif edilecektir.
      </div>
    </div>

    <!-- Help Section -->
    <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-blue-900 dark:text-blue-300 mb-2">
        Yardıma İhtiyacınız var mı?
      </h3>
      <p class="text-blue-800 dark:text-blue-400 mb-4">
        Üyelik modeliyle ilgili sorularınız için bizimle iletişime geçebilirsiniz.
      </p>
      <a
        href="mailto:support@sanliurfa.com"
        class="text-blue-600 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300 font-medium"
      >
        Destek E-postası Gönder →
      </a>
    </div>
  </div>
</Layout>
