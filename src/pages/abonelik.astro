---
import Layout from "../layouts/Layout.astro";
import { SubscriptionManager } from "../components/SubscriptionManager";
import BillingHistory from "../components/BillingHistory";
import AuthFeatureLanding from "../components/AuthFeatureLanding.astro";

const user = Astro.locals.user;
---

<Layout title="Abonelik Yönetimi - Şanlıurfa" noindex>
  {
    !user ? (
      <AuthFeatureLanding
        eyebrow="Üyelik ve abonelik"
        title="Şanlıurfa hesabınızla üyelik avantajlarını yönetin"
        description="İlk aşamada temel topluluk, mekân ekleme, yorum ve sosyal özellikler ücretsiz açıktır. Hesap oluşturduğunuzda abonelik durumunuzu, ödeme geçmişinizi ve ileride açılacak premium seçenekleri tek panelden takip edebilirsiniz."
        loginRedirect="/abonelik"
        features={[
          {
            title: "Ücretsiz başlangıç",
            description:
              "Mekân keşfi, yorum, favori, takip, mesajlaşma ve sosyal etkileşim akışları üyeler için açık tutulur.",
          },
          {
            title: "Plan takibi",
            description:
              "Aktif plan, ödeme geçmişi ve yükseltme seçenekleri tek ekranda sade şekilde yönetilir.",
          },
          {
            title: "Güvenli hesap",
            description:
              "İki faktörlü doğrulama varsayılan olarak kapalıdır; isteyen kullanıcı ayarlardan açabilir.",
          },
        ]}
      />
    ) : (
      <div class="max-w-4xl mx-auto px-4 py-8">
        <div class="mb-8">
          <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">
            Abonelik yönetimi
          </h1>
          <p class="text-gray-600 dark:text-gray-400">
            Aktif aboneliğinizi yönetin, planınızı değiştirin veya ödeme
            geçmişinizi görüntüleyin.
          </p>
        </div>

        <div class="mb-12">
          <SubscriptionManager
            client:load
            onUpgrade={() => (window.location.href = "/fiyatlandirma")}
          />
        </div>

        <div class="mb-8">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">
            Ödeme geçmişi
          </h2>
          <BillingHistory client:load />
        </div>

        <div class="bg-urfa-50 dark:bg-urfa-900/20 border border-urfa-200 dark:border-urfa-800 rounded-lg p-6">
          <h3 class="text-lg font-semibold text-urfa-900 dark:text-urfa-300 mb-2">
            Yardıma ihtiyacınız var mı?
          </h3>
          <p class="text-urfa-800 dark:text-urfa-400 mb-4">
            Abonelik ve ödeme konularında iletişim sayfasından bize
            ulaşabilirsiniz.
          </p>
          <a
            href="/iletisim"
            class="text-urfa-700 hover:text-urfa-800 dark:text-urfa-300 dark:hover:text-urfa-200 font-medium"
          >
            İletişime geç
          </a>
        </div>
      </div>
    )
  }
</Layout>
