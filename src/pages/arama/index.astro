---
import Layout from "../../layouts/Layout.astro";
import SearchResults from "../../components/SearchResults";

const query = Astro.url.searchParams.get("q") || "";
const seo = {
  title: "Arama - sanliurfa.com",
  description:
    "Şanlıurfa mekânları, etkinlikleri ve yerel içerikleri hızlıca arayın.",
  canonicalUrl: "https://sanliurfa.com/arama",
  noindex: true,
};
---

<Layout seo={seo}>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <div class="mb-8">
      <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-2">
        Arama
      </h1>
      <p class="text-gray-600 dark:text-gray-400">
        Mekânları, kullanıcıları ve koleksiyonları bul
      </p>
      <a
        class="inline-flex mt-4 text-sm font-semibold text-blue-700 hover:underline"
        href={`/arama/gelismis${query ? `?q=${encodeURIComponent(query)}` : ""}`}
      >
        Gelişmiş aramaya geç
      </a>
    </div>
    <SearchResults client:load query={query} />
  </div>
</Layout>
