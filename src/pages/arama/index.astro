---

import Layout from "../../layouts/Layout.astro";
import SearchResults from "../../components/SearchResults";
import { getSiteBranding } from '../../lib/site-branding';
const { baseUrl } = await getSiteBranding();

const query = Astro.url.searchParams.get("q") || "";

const seo = {
  title: 'Arama - Şanlıurfa Rehberi',
  description: 'Şanlıurfa\'daki mekanları, işletmeleri ve içerikleri arayın.',
  keywords: ['şanlıurfa arama', 'urfa mekan ara', 'şanlıurfa mekan bul'],
  ogImage: '/images/hero/hero-home.webp',
  canonical: '/arama',
  noIndex: true,
};
const faqItems = [
  { S: 'Şanlıurfa arama sayfasında ne arayabilirim?', C: 'Mekan adı, kategori, ilçe veya mahalle gibi anahtar kelimelerle Şanlıurfa genelinde arama yapabilirsiniz.' },
  { S: 'Arama sonuçları nasıl sıralanıyor?', C: 'Sonuçlar alaka düzeyi, kullanıcı puanı ve aktiflik durumuna göre sıralanır.' },
  { S: 'Arama yaparken filtre kullanabilir miyim?', C: 'Kategori, ilçe ve puan filtrelerini kullanarak sonuçları daraltabilirsiniz.' },
];
---

<Layout seo={seo}>
  <div class="min-h-screen bg-[#FDFAF3]">
    <div class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)] py-10">
      <div class="container mx-auto px-4">
        <h1 class="text-4xl font-bold text-[#F5EDD6] mb-2">Arama</h1>
        <p class="text-[#9A8470]">Mekanları, kullanıcıları ve koleksiyonları bul</p>
      </div>
    </div>
    <div class="container mx-auto px-4 py-8 max-w-4xl">
      <SearchResults client:visible={{ rootMargin: '140px' }} query={query} />
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Sanliurfa.com',
    url: `${baseUrl}`,
    potentialAction: {
      '@type': 'SearchAction',
      target: `${baseUrl}/arama?q={search_term_string}`,
      'query-input': 'required name=search_term_string',
    },
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Arama', item: `${baseUrl}/arama` },
    ],
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: { '@type': 'Answer', text: item.C },
    })),
  })} is:inline />
</Layout>
