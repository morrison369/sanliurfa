---
import Layout from "../../layouts/Layout.astro";
import SearchResults from "../../components/SearchResults";

const query = Astro.url.searchParams.get("q") || "";
const seo = {
  title: "Gelişmiş Arama - sanliurfa.com",
  description:
    "Şanlıurfa mekân, etkinlik ve içeriklerini gelişmiş filtrelerle arayın.",
  canonicalUrl: "https://sanliurfa.com/arama/gelismis",
  noindex: true,
};
---

<Layout seo={seo}>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="mb-8">
      <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-2">
        Gelişmiş Arama
      </h1>
      <p class="text-gray-600 dark:text-gray-400">
        Mekân, etkinlik ve içerikleri filtrelerle daha hızlı bulun.
      </p>
    </div>
    <SearchResults client:load query={query} />
  </div>
</Layout>
