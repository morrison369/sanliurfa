---
import Layout from '../layouts/Layout.astro';
import { query } from '../lib/postgres';
import { getCachedPublicRouteData } from '../lib/public-route-cache';
import { getPublicAppUrl } from '../lib/public-app-url';
import { logger } from '../lib/logging';
import { ILCE_GEZI_REHBERI } from '../data/ilce-gezi-rehberi';

const { ilce } = Astro.params;
const config = ilce ? ILCE_GEZI_REHBERI[ilce] : undefined;
if (!config) return Astro.redirect('/404');

const baseUrl = getPublicAppUrl();
const pagePath = `/${config.slug}-gezi-rehberi`;

interface PlaceRow { slug: string; name: string; address: string | null; rating: number | null; review_count: number | null; short_description: string | null; }
interface BlogRow { slug: string; title: string; }

let places: PlaceRow[] = [];
let blogPosts: BlogRow[] = [];
try {
  const data = await getCachedPublicRouteData(`page:guide:${config.slug}-gezi`, async () => {
    const [placesResult, blogResult] = await Promise.all([
      query<PlaceRow>(
        `SELECT p.slug, p.name, p.address, p.rating, p.review_count, p.short_description
         FROM places p
         WHERE p.status = 'active' AND p.district_id = $1
         ORDER BY p.rating DESC NULLS LAST, p.review_count DESC NULLS LAST
         LIMIT 12`,
        [config.districtId],
      ),
      query<BlogRow>(
        `SELECT slug, title FROM blog_posts
         WHERE status = 'published' AND published_at <= CURRENT_DATE
           AND (tags && $1::text[] OR title ILIKE $2)
         ORDER BY published_at DESC LIMIT 5`,
        [config.blogTags, `%${config.label}%`],
      ).catch(() => ({ rows: [] as BlogRow[] })),
    ]);
    return { places: placesResult.rows, blogPosts: blogResult.rows };
  });
  places = data.places;
  blogPosts = data.blogPosts;
} catch (e) {
  logger.error(`${config.label} rehberi yüklenemedi:`, e instanceof Error ? e : new Error(String(e)));
}

const seo = {
  title: `${config.heroH1} | ${config.label} Gezilecek Yerler`,
  description: config.seoDescription,
  keywords: config.seoKeywords,
  ogImage: config.ogImage,
  canonical: pagePath,
};
---

<Layout seo={seo}>
  <style is:inline>
    .hr-hero{background:linear-gradient(135deg,#0a1f0e 0%,#1a3a20 50%,#0a1f0e 100%);border-bottom:1px solid rgba(44,122,82,.2);padding:4rem 0 3rem}
    .hr-eyebrow{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.14em;color:#2C7A52;margin-bottom:.75rem}
    .hr-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(2rem,5vw,3.25rem);font-weight:700;color:#e8caa9;margin:0 0 1rem;line-height:1.15}
    .hr-desc{font-size:1rem;color:rgba(232,202,169,.75);max-width:600px;line-height:1.65;margin-bottom:2rem}
    .hr-badges{display:flex;flex-wrap:wrap;gap:.5rem}
    .hr-badge{display:inline-flex;align-items:center;gap:.35rem;padding:.4rem .85rem;background:rgba(44,122,82,.15);border:1px solid rgba(44,122,82,.3);color:#2C7A52;font-size:.78rem;font-weight:600;border-radius:999px}
    .hr-body{background:#FBF6EC;padding:3rem 0 5rem}
    .hr-grid{display:grid;gap:2.5rem}
    @media(min-width:64rem){.hr-grid{grid-template-columns:2fr 1fr}}
    .hr-section-title{font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-weight:700;color:#1F1410;margin:0 0 1.25rem;padding-bottom:.65rem;border-bottom:2px solid rgba(192,87,31,.15)}
    .hr-places{display:flex;flex-direction:column;gap:.75rem}
    .hr-place{display:flex;align-items:flex-start;gap:1rem;background:#fff;border:1px solid rgba(192,87,31,.12);padding:1rem 1.25rem;border-radius:8px;text-decoration:none;transition:border-color .15s,box-shadow .15s}
    .hr-place:hover{border-color:#C0571F;box-shadow:0 2px 8px rgba(192,87,31,.1)}
    .hr-place-icon{width:2.5rem;height:2.5rem;background:rgba(44,122,82,.1);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0;margin-top:.1rem}
    .hr-place-name{font-weight:700;color:#1F1410;font-size:.95rem;margin-bottom:.2rem}
    .hr-place-desc{font-size:.8rem;color:#7A6448;line-height:1.4}
    .hr-place-rating{font-size:.82rem;color:#C0571F;font-weight:700;white-space:nowrap;margin-left:auto;padding-left:.5rem}
    .hr-tips{background:#fff;border:1px solid rgba(44,122,82,.15);border-radius:8px;padding:1.5rem;margin-bottom:1.5rem}
    .hr-tips-title{font-weight:700;color:#1F1410;margin-bottom:.85rem;font-size:.95rem}
    .hr-tip{display:flex;align-items:flex-start;gap:.6rem;font-size:.85rem;color:#2C1810;line-height:1.5;margin-bottom:.6rem}
    .hr-tip-dot{width:.4rem;height:.4rem;background:#2C7A52;border-radius:50%;flex-shrink:0;margin-top:.55rem}
    .hr-faq{margin-top:2rem}
    .hr-faq-item{border:1px solid rgba(192,87,31,.12);border-radius:8px;margin-bottom:.65rem;overflow:hidden;background:#fff}
    .hr-faq-q{padding:1rem 1.25rem;font-weight:700;font-size:.9rem;color:#1F1410;cursor:default}
    .hr-faq-a{padding:0 1.25rem 1rem;font-size:.85rem;color:#2C1810;line-height:1.6}
    .hr-blog-links{display:flex;flex-direction:column;gap:.4rem;margin-top:.75rem}
    .hr-blog-link{font-size:.85rem;color:#C0571F;text-decoration:none;padding:.4rem .6rem;border-radius:4px;transition:background .12s}
    .hr-blog-link:hover{background:rgba(192,87,31,.08)}
  </style>

  <div class="hr-hero">
    <div class="sf-container">
      <p class="hr-eyebrow">{config.heroLabel}</p>
      <h1 class="hr-h1">{config.heroH1}</h1>
      <p class="hr-desc">{config.heroDesc}</p>
      <div class="hr-badges">
        {config.badges.map((b) => (
          <span class="hr-badge">{b.emoji && <span>{b.emoji}</span>} {b.text}</span>
        ))}
      </div>
    </div>
  </div>

  <div class="hr-body">
    <div class="sf-container">
      <div class="hr-grid">
        <div>
          <h2 class="hr-section-title">{config.label}'de Popüler Mekanlar</h2>
          {places.length > 0 ? (
            <div class="hr-places">
              {places.map((p) => (
                <a href={`/isletme/${p.slug}`} class="hr-place">
                  <div class="hr-place-icon">📍</div>
                  <div style="flex:1">
                    <div class="hr-place-name">{p.name}</div>
                    {p.short_description && <div class="hr-place-desc">{p.short_description}</div>}
                  </div>
                  {p.rating && <div class="hr-place-rating">★ {p.rating}</div>}
                </a>
              ))}
            </div>
          ) : (
            <p style="color:#7A6448;font-size:.9rem">{config.label} mekan listesi yükleniyor…</p>
          )}

          <div class="hr-faq" style="margin-top:2.5rem">
            <h2 class="hr-section-title">Sık Sorulan Sorular</h2>
            {config.faq.map((item) => (
              <div class="hr-faq-item">
                <div class="hr-faq-q">{item.q}</div>
                <div class="hr-faq-a">{item.a}</div>
              </div>
            ))}
          </div>
        </div>

        <aside>
          <div class="hr-tips">
            <div class="hr-tips-title">💡 Pratik Bilgiler</div>
            {config.tips.map((t) => (
              <div class="hr-tip">
                <span class="hr-tip-dot"></span>
                <span><strong>{t.label}:</strong> {t.value}</span>
              </div>
            ))}
          </div>

          {blogPosts.length > 0 && (
            <div class="hr-tips">
              <div class="hr-tips-title">📖 İlgili Rehber Yazılar</div>
              <div class="hr-blog-links">
                {blogPosts.map((p) => (
                  <a href={`/blog/${p.slug}`} class="hr-blog-link">{p.title}</a>
                ))}
              </div>
            </div>
          )}

          <div class="hr-tips">
            <div class="hr-tips-title">🗺️ Yakın Güzergahlar</div>
            <div class="hr-blog-links">
              {config.nearbyLinks.map((link) => (
                <a href={link.href} class="hr-blog-link">{link.text}</a>
              ))}
            </div>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'TouristDestination',
    name: config.label,
    description: config.schemaDescription,
    url: `${baseUrl}${pagePath}`,
    touristType: config.touristType,
    containedInPlace: { '@type': 'City', name: 'Şanlıurfa' },
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: config.faq.map((item) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: { '@type': 'Answer', text: item.a },
    })),
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Ana Sayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'İlçe Rehberleri', item: `${baseUrl}/ilceler` },
      { '@type': 'ListItem', position: 3, name: config.heroH1, item: `${baseUrl}${pagePath}` },
    ],
  })} is:inline />
</Layout>
