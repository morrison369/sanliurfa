---
import { Icon } from 'astro-icon/components';
import Layout from '../../layouts/Layout.astro';
import PublicPageIntro from '../../components/public/PublicPageIntro.astro';
import PublicCollectionList from '../../components/public/PublicCollectionList.astro';
import PublicFaqList from '../../components/public/PublicFaqList.astro';
import EventCalendarToggle from '../../components/events/EventCalendarToggle';
import { queryReadMany } from '../../lib/postgres';
import { getCachedPublicRouteData } from '../../lib/public-route-cache';
import { getPublicAppUrl } from '../../lib/public-app-url';
import { logger } from '../../lib/logging';
import { resolveEventImage } from '../../lib/public-image-resolvers';

const queryParam = Astro.url.searchParams.get('q') || '';
const kategoriParam = Astro.url.searchParams.get('kategori') || '';
const ayParam = Astro.url.searchParams.get('ay') || '';
const validAy = /^\d{4}-(0[1-9]|1[0-2])$/.test(ayParam) ? ayParam : '';
const EVENTS_PAGE_CACHE_TTL_MS = 300_000;
const EVENT_LIST_LIMIT = 80;
const CALENDAR_EVENT_LIMIT = 42;

type EventListRow = {
 id: string;
 title: string;
 slug: string;
 description: string | null;
 start_date: string | Date;
 end_date: string | Date | null;
 location: string | null;
 category: string | null;
 is_featured: boolean;
 is_free: boolean;
 image_url: string | null;
};

const values: Array<string> = [];
const conditions: string[] = [
  "status = 'published'",
  "(end_date IS NULL OR end_date >= CURRENT_DATE)",
];

if (validAy) {
  values.push(`${validAy}-01`);
  conditions.push(`DATE_TRUNC('month', start_date) = DATE_TRUNC('month', $${values.length}::date)`);
} else {
  conditions.push("start_date <= CURRENT_DATE + INTERVAL '180 days'");
}

if (queryParam) {
  values.push(`%${queryParam}%`);
  conditions.push(`(title ILIKE $${values.length} OR description ILIKE $${values.length} OR location ILIKE $${values.length})`);
}

if (kategoriParam) {
  values.push(kategoriParam);
  conditions.push(`category = $${values.length}`);
}

const sql = `SELECT
 id,
 title,
 slug,
 LEFT(COALESCE(description, ''), 220) AS description,
 start_date,
 end_date,
 location,
 category,
 COALESCE(is_featured, false) AS is_featured,
 COALESCE(is_free, false) AS is_free,
 image_url
FROM events
WHERE ${conditions.join(' AND ')}
ORDER BY is_featured DESC, start_date ASC
LIMIT ${EVENT_LIST_LIMIT}`;
const filterKey = [queryParam, kategoriParam, validAy].filter(Boolean).join(':') || 'all';

let events: EventListRow[] = [];
let availableCategories: string[] = [];
let availableMonths: { label: string; value: string }[] = [];

const formatDate = (dateValue: string | Date) =>
 new Date(dateValue).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' });

const getEventImage = (event: EventListRow) => resolveEventImage(event);
const showCalendarToggle = !queryParam && !kategoriParam && !validAy;

function summarizeDescription(value: string | null): string | undefined {
 if (typeof value !== 'string') return undefined;
 const normalized = value.replace(/\s+/g, ' ').trim();
 if (!normalized) return undefined;
 return normalized.length > 180 ? `${normalized.slice(0, 177).trimEnd()}...` : normalized;
}

function toCalendarEvent(event: EventListRow) {
 return {
  id: String(event.id),
  title: event.title,
  slug: event.slug,
  start_date: event.start_date instanceof Date ? event.start_date.toISOString() : String(event.start_date ?? ''),
  ...(event.end_date ? { end_date: event.end_date instanceof Date ? event.end_date.toISOString() : String(event.end_date) } : {}),
  ...(event.location ? { location: event.location } : {}),
  ...(event.category ? { category: event.category } : {}),
  is_free: event.is_free,
  ...(event.image_url ? { image_url: event.image_url } : {}),
 };
}

function toCollectionItem(event: EventListRow) {
 const description = summarizeDescription(event.description);
 return {
  href: `/etkinlikler/${event.slug}`,
  title: event.title,
  ...(description ? { description } : {}),
  imageSrc: getEventImage(event),
  imageAlt: event.title,
  badges: [
   ...(event.category ? [{ label: event.category }] : []),
   ...(event.is_featured ? [{ label: 'Öne Çıkan', tone: 'accent' as const }] : []),
  ],
  metaItems: [
   { label: `${formatDate(event.start_date)}${event.end_date ? ` — ${formatDate(event.end_date)}` : ''}`, icon: 'lucide:calendar' },
   ...(event.location ? [{ label: event.location, icon: 'lucide:map-pin' }] : []),
  ],
 };
}

const seo = {
 title: 'Etkinlikler — Şanlıurfa\'da Bugün ve Yakında',
 description: 'Şanlıurfa\'daki konserler, festivaller, sergiler ve diğer etkinlikler. Kültürel etkinlikleri takip edin.',
 keywords: ['şanlıurfa etkinlikler', 'urfa konser', 'şanlıurfa festival', 'urfa kültür etkinlikleri', 'şanlıurfa bugün ne var', 'urfa sergi', 'şanlıurfa organizasyon'],
 canonical: '/etkinlikler',
};

const baseUrl = getPublicAppUrl();

const faqItems = [
 { S: 'Şanlıurfa etkinlik takvimi nasıl takip edilir?', C: "Etkinlikler sayfasında yayınlanan aktif etkinlikler tarih sırasına göre listelenir ve arama kutusuyla filtrelenebilir. Sayfayı düzenli kontrol ederek veya tarayıcı favorilerinize ekleyerek yaklaşan konser, festival ve kültürel etkinliklerden haberdar olabilirsiniz." },
 { S: 'Konser ve festival etkinlikleri bu sayfada yer alıyor mu?', C: "Evet. Konser, festival, sergi, toplantı ve benzeri etkinlik içerikleri kategori etiketleriyle birlikte gösterilir. Şanlıurfa'daki kültürel ve sanatsal etkinliklere ait detaylı bilgi; tarih, saat, mekan ve katılım koşullarıyla birlikte her etkinlik detay sayfasında sunulmaktadır." },
 { S: 'Etkinlik detayına nasıl giderim?', C: "Listede yer alan herhangi bir etkinlik kartına tıklayarak detay sayfasına geçebilirsiniz. Detay sayfasında etkinliğin tarihi, konumu, kategorisi, açıklaması ve varsa katılım bilgileri yer almaktadır. Ücretsiz etkinlikler için ayrıca özel bir etiket gösterilmektedir." },
 { S: "Şanlıurfa'da hangi tür etkinlikler düzenleniyor?", C: "Şanlıurfa'da yıl boyu müzik konserleri, Nevruz kutlamaları, Uluslararası Divan Şiiri Festivali, tarım fuarları, spor organizasyonları ve geleneksel sıra geceleri düzenlenmektedir. Kültürel çeşitliliğiyle Şanlıurfa, tarih turizminin yanı sıra canlı bir etkinlik takvimine ev sahipliği yapar." },
];

try {
 const [eventsData, categoriesData, monthsData] = await Promise.all([
  getCachedPublicRouteData(
   `page:etkinlikler:index:${filterKey}:events`,
   () => queryReadMany<EventListRow>(sql, values),
   EVENTS_PAGE_CACHE_TTL_MS,
  ),
  getCachedPublicRouteData(
   'page:etkinlikler:index:categories',
   async () => {
    const rows = await queryReadMany<{ category: string }>(
     `SELECT DISTINCT category
      FROM events
      WHERE status = 'published'
        AND category IS NOT NULL
        AND category <> ''
      ORDER BY category`,
    );
    return rows.map((row) => row.category);
   },
   EVENTS_PAGE_CACHE_TTL_MS,
  ),
  getCachedPublicRouteData(
   'page:etkinlikler:index:months',
   async () => {
    const rows = await queryReadMany<{ m: string }>(
     `SELECT DISTINCT TO_CHAR(DATE_TRUNC('month', start_date), 'YYYY-MM') AS m
      FROM events
      WHERE status = 'published'
        AND start_date >= CURRENT_DATE
      ORDER BY m
      LIMIT 12`,
    );
    return rows.map((row) => row.m);
   },
   EVENTS_PAGE_CACHE_TTL_MS,
  ),
 ]);
 events = eventsData;
 availableCategories = categoriesData;
 availableMonths = monthsData.map((m: string) => {
  const [y, mo] = m.split('-');
  const label = new Date(parseInt(y), parseInt(mo) - 1, 1).toLocaleDateString('tr-TR', { month: 'long', year: 'numeric' });
  return { label, value: m };
 });
} catch (e) {
 logger.error('Error loading events:', e instanceof Error ? e : new Error(String(e)));
}
---

<Layout seo={seo}>
 <style is:inline>
 .et-body{padding:2.5rem 0 5rem}
 .et-filters{display:flex;flex-wrap:wrap;gap:.4rem .5rem;margin-bottom:1.25rem;align-items:center}
 .et-filter-label{font-size:.7rem;color:var(--public-muted);margin-right:.15rem;white-space:nowrap}
 .et-filter-chip{font-size:.7rem;font-weight:600;padding:.28rem .65rem;border:1px solid rgba(184,115,51,.22);color:var(--public-text-soft);text-decoration:none;transition:all .15s;background:transparent}
 .et-filter-chip:hover{border-color:rgba(184,115,51,.5);color:var(--public-text)}
 .et-filter-chip.active{background:rgba(184,115,51,.15);border-color:rgba(184,115,51,.5);color:var(--public-accent)}
 .et-filter-sep{width:1px;height:1rem;background:rgba(184,115,51,.2);align-self:center;margin:0 .25rem}
 .et-empty{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);padding:3rem 2rem;text-align:center}
 .et-empty-icon{width:2.5rem;height:2.5rem;margin:0 auto .75rem;color:var(--public-accent)}
 .et-empty-title{font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:600;color:var(--public-text);margin-bottom:.5rem}
 .et-empty-desc{font-size:.82rem;color:var(--public-muted);line-height:1.7;max-width:440px;margin:0 auto 1.25rem}
 .et-empty-links{display:flex;flex-wrap:wrap;justify-content:center;gap:.75rem}
 </style>

 <PublicPageIntro
  eyebrow="Şanlıurfa"
  title="Şanlıurfa Etkinlikleri"
  description="Şanlıurfa'daki kültürel etkinlikleri keşfedin."
  searchAction="/etkinlikler"
  searchValue={queryParam}
  searchPlaceholder="Etkinlik ara…"
  searchAriaLabel="Etkinlik arama terimi"
  quickAnswerTitle="Hızlı Cevap"
  quickAnswerText="Şanlıurfa Etkinlikleri sayfası, aktif konser, festival, sergi ve topluluk buluşmalarını tarih sırasıyla listeler."
 />

 <!-- Takvim / Liste toggle -->
 <div class="sf-container et-body">

 <!-- Filtreler -->
 {(availableCategories.length > 0 || availableMonths.length > 0) && (
  <div class="et-filters">
   {availableCategories.length > 0 && (
    <>
     <span class="et-filter-label">Kategori:</span>
     <a href={`/etkinlikler${queryParam ? `?q=${encodeURIComponent(queryParam)}` : ''}${validAy ? `${queryParam ? '&' : '?'}ay=${validAy}` : ''}`}
      class:list={['et-filter-chip', { active: !kategoriParam }]}>Tümü</a>
     {availableCategories.map(cat => {
      const base = new URLSearchParams();
      if (queryParam) base.set('q', queryParam);
      if (validAy) base.set('ay', validAy);
      base.set('kategori', cat);
      return <a href={`/etkinlikler?${base.toString()}`} class:list={['et-filter-chip', { active: kategoriParam === cat }]}>{cat}</a>;
     })}
    </>
   )}
   {availableCategories.length > 0 && availableMonths.length > 0 && <span class="et-filter-sep" />}
   {availableMonths.length > 0 && (
    <>
     <span class="et-filter-label">Ay:</span>
     <a href={`/etkinlikler${queryParam ? `?q=${encodeURIComponent(queryParam)}` : ''}${kategoriParam ? `${queryParam ? '&' : '?'}kategori=${encodeURIComponent(kategoriParam)}` : ''}`}
      class:list={['et-filter-chip', { active: !validAy }]}>Tümü</a>
     {availableMonths.map(({ label, value }) => {
      const base = new URLSearchParams();
      if (queryParam) base.set('q', queryParam);
      if (kategoriParam) base.set('kategori', kategoriParam);
      base.set('ay', value);
      return <a href={`/etkinlikler?${base.toString()}`} class:list={['et-filter-chip', { active: validAy === value }]}>{label}</a>;
     })}
    </>
   )}
  </div>
 )}

 {events.length > 0 && showCalendarToggle && (
 <EventCalendarToggle
  client:visible={{ rootMargin: '200px' }}
   events={events.slice(0, CALENDAR_EVENT_LIMIT).map((event) => toCalendarEvent(event))}
  />
 )}
 {events.length > 0 ? (
 <PublicCollectionList
  items={events.map((event) => toCollectionItem(event))}
 />
 ) : (
 <div class="et-empty">
 <Icon name="lucide:calendar" class="et-empty-icon" />
 <h2 class="et-empty-title">Aktif etkinlik bulunamadı</h2>
 <p class="et-empty-desc">
 {queryParam
 ? `"${queryParam}" için etkinlik bulunamadı. Farklı bir arama deneyin.`
 : 'Bugün için veritabanında yayınlanmış etkinlik kaydı yok. Şanlıurfa gezi planınızı mekan rehberi ve tarihi yerlerle tamamlayabilirsiniz.'}
 </p>
 <div class="et-empty-links">
 <a href="/isletme" class="sf-btn-primary">Mekanları Keşfet</a>
 <a href="/tarihi-yerler" class="sf-btn-ghost">Tarihi Yerler</a>
 </div>
 </div>
 )}

 {faqItems.length > 0 && (
  <div style="margin-top:3rem">
   <PublicFaqList items={faqItems} />
  </div>
 )}
 </div>

 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org', '@type': 'FAQPage',
 mainEntity: faqItems.map(item => ({
 '@type': 'Question', name: item.S,
 acceptedAnswer: { '@type': 'Answer', text: item.C },
 })),
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org', '@type': 'ItemList',
 name: 'Şanlıurfa Etkinlik Listesi',
 itemListElement: events.slice(0, 8).map((event, index) => ({
 '@type': 'ListItem', position: index + 1,
 name: event.title, url: `${baseUrl}/etkinlikler/${event.slug}`,
 })),
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org', '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'Etkinlikler', item: `${baseUrl}/etkinlikler` },
 ],
 })} is:inline />
</Layout>
