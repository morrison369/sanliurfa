---
import { Icon } from 'astro-icon/components';
import Layout from '../../layouts/Layout.astro';
import Image from '../../components/Image.astro';
import { query } from '../../lib/postgres';
import { resolveContentImage } from '../../lib/content-images';
import { getSiteBranding } from '../../lib/site-branding';
import { logger } from '../../lib/logging';

const queryParam = Astro.url.searchParams.get('q') || '';

let sql = "SELECT * FROM events WHERE status = 'published' AND (end_date IS NULL OR end_date >= CURRENT_DATE)";
const values: any[] = [];

if (queryParam) {
  sql += " AND (title ILIKE $1 OR description ILIKE $1 OR location ILIKE $1)";
  values.push(`%${queryParam}%`);
}

sql += " ORDER BY is_featured DESC, start_date ASC";

let events: any[] = [];

const formatDate = (dateStr: string) => {
  return new Date(dateStr).toLocaleDateString('tr-TR', {
    day: 'numeric', month: 'long', year: 'numeric'
  });
};

const getEventImage = (event: any) =>
  resolveContentImage({
    category: 'etkinlikler',
    slug: event?.slug,
    explicit: event?.image_url,
    placeholder: '/images/placeholder-event.jpg',
  });

const seo = {
  title: 'Etkinlikler - Şanlıurfa\'da Bugün ve Yakında',
  description: 'Şanlıurfa\'daki konserler, festivaller, sergiler ve diğer etkinlikler. Kültürel etkinlikleri takip edin.',
  keywords: ['şanlıurfa etkinlikler', 'urfa konser', 'şanlıurfa festival', 'urfa kültür etkinlikleri', 'şanlıurfa bugün ne var', 'urfa sergi', 'şanlıurfa organizasyon'],
  ogImage: '/images/hero/hero-home.webp',
  canonical: '/etkinlikler',
};
const { baseUrl } = await getSiteBranding();

const faqItems = [
  {
    S: 'Şanlıurfa etkinlik takvimi nasıl takip edilir?',
    C: 'Etkinlikler sayfasında yayınlanan aktif etkinlikler tarih sırasına göre listelenir ve arama kutusuyla filtrelenebilir.',
  },
  {
    S: 'Konser ve festival etkinlikleri bu sayfada yer alıyor mu?',
    C: 'Evet. Konser, festival, sergi ve benzeri etkinlik içerikleri kategori etiketleriyle birlikte gösterilir.',
  },
  {
    S: 'Etkinlik detayına nasıl giderim?',
    C: 'Listede yer alan herhangi bir etkinlik kartına tıklayarak detay sayfasına geçebilirsiniz.',
  },
];

try {
  const result = await query(sql, values);
  events = result.rows;
} catch (e) {
  logger.error('Error loading events:', e instanceof Error ? e : new Error(String(e)));
}
---

<Layout seo={seo}>
  <!-- Hero -->
  <div class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)] text-white py-16">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4 text-[#F5EDD6]">Şanlıurfa Etkinlikleri</h1>
        <p class="text-xl text-[#9A8470] max-w-2xl mx-auto">
          Şanlıurfa'daki kültürel etkinlikleri keşfedin.
        </p>
        <div class="mt-8 max-w-2xl mx-auto">
          <form action="/etkinlikler" class="relative">
            <input
              type="search"
              name="q"
              value={queryParam}
              placeholder="Etkinlik ara..."
              class="w-full pl-12 pr-4 py-4 rounded-sm bg-white/10 backdrop-blur-sm text-white placeholder-white/60 border border-white/20 focus:outline-none focus:border-white/40"
            />
            <Icon name="lucide:search" class="w-5 h-5 absolute left-4 top-1/2 -translate-y-1/2 text-white/60" />
          </form>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-[#FDFAF3]">
    <div class="container mx-auto px-4 py-12">
      <div class="rounded-sm border border-[rgba(200,160,100,0.2)] bg-[rgba(200,160,100,0.06)] p-5 mb-8">
        <h2 class="text-lg font-bold text-[#1A1008]">Hızlı Cevap</h2>
        <p class="text-sm text-[#6B5540] mt-1">
          Şanlıurfa etkinlik takvimini bu sayfadan takip edebilir, tarih ve konuma göre uygun etkinliği hızlıca bulabilirsiniz.
        </p>
      </div>

      <div class="space-y-6">
        {events.map((event) => (
          <a href={`/etkinlikler/${event.slug}`} class="group block">
            <article class="bg-white border border-[rgba(200,160,100,0.18)] rounded-sm overflow-hidden shadow-sm hover:shadow-md hover:border-urfa-300 transition-all">
              <div class="flex flex-col md:flex-row">
                <div class="md:w-1/3 aspect-video md:aspect-auto overflow-hidden bg-[rgba(200,160,100,0.08)]">
                  <Image
                    src={getEventImage(event)}
                    alt={event.title}
                    class="w-full h-full object-cover"
                    loading="lazy"
                    width={960}
                    height={540}
                  />
                </div>

                <div class="flex-1 p-6">
                  <div class="flex flex-wrap items-center gap-2 mb-2">
                    <span class="px-2 py-0.5 bg-[rgba(200,160,100,0.1)] border border-[rgba(200,160,100,0.25)] text-urfa-700 text-xs font-medium rounded-sm">{event.category}</span>
                    {event.is_featured && (
                      <span class="px-2 py-0.5 bg-urfa-600 text-white text-xs font-medium rounded-sm">Öne Çıkan</span>
                    )}
                  </div>

                  <h3 class="font-bold text-xl text-[#1A1008] group-hover:text-urfa-700 transition-colors">
                    {event.title}
                  </h3>

                  <p class="text-[#9A8470] mt-2 line-clamp-2">
                    {event.description}
                  </p>

                  <div class="flex flex-wrap items-center gap-4 mt-4 text-sm text-[#9A8470]">
                    <span class="flex items-center gap-1">
                      <Icon name="lucide:calendar" class="w-4 h-4" />
                      {formatDate(event.start_date)}
                      {event.end_date && ` - ${formatDate(event.end_date)}`}
                    </span>
                    <span class="flex items-center gap-1">
                      <Icon name="lucide:map-pin" class="w-4 h-4" />
                      {event.location}
                    </span>
                  </div>
                </div>
              </div>
            </article>
          </a>
        ))}
      </div>

      {events.length === 0 && (
        <div class="rounded-sm border border-[rgba(200,160,100,0.18)] bg-white p-8 text-center shadow-sm">
          <span class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-sm bg-[rgba(200,160,100,0.1)] text-urfa-600">
            <Icon name="lucide:calendar" class="w-5 h-5" />
          </span>
          <h3 class="text-xl font-semibold text-[#1A1008] mb-2">Aktif etkinlik bulunamadı</h3>
          <p class="mx-auto max-w-2xl text-[#9A8470]">
            Bugün için veritabanında yayınlanmış etkinlik kaydı yok. Şanlıurfa gezi planınızı
            mekan rehberi, tarihi yerler ve yemek önerileriyle tamamlayabilirsiniz.
          </p>
          <div class="mt-6 flex flex-wrap justify-center gap-3">
            <a href="/mekanlar" class="rounded-sm bg-urfa-600 px-5 py-3 font-semibold text-white transition-colors hover:bg-urfa-700">
              Mekanları Keşfet
            </a>
            <a href="/tarihi-yerler" class="rounded-sm border border-[rgba(200,160,100,0.2)] px-5 py-3 font-semibold text-[#4A3828] transition-colors hover:border-urfa-300 hover:text-urfa-700">
              Tarihi Yerler
            </a>
          </div>
        </div>
      )}
    </div>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.C,
      },
    })),
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Şanlıurfa Etkinlik Listesi',
    itemListElement: events.slice(0, 12).map((event, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: event.title,
      url: `${baseUrl}/etkinlikler/${event.slug}`,
    })),
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Etkinlikler', item: `${baseUrl}/etkinlikler` },
    ],
  })} is:inline />
</Layout>
