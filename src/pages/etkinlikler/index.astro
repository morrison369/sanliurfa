---
import Layout from '../../layouts/Layout.astro';
import Image from '../../components/Image.astro';
import { query } from '../../lib/postgres';
import { resolveContentImage } from '../../lib/content-images';
import { getSiteBranding } from '../../lib/site-branding';

const queryParam = Astro.url.searchParams.get('q') || '';

// SVG ikonlar
const icons = {
  search: `<svg class="w-5 h-5 absolute left-4 top-1/2 -translate-y-1/2 text-white/60" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`,
  calendar: `<svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
  mapPin: `<svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
  clock: `<svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
};

let sql = "SELECT * FROM events WHERE status = 'published' AND (end_date IS NULL OR end_date >= CURRENT_DATE)";
const values: any[] = [];

if (queryParam) {
  sql += " AND (title ILIKE $1 OR description ILIKE $1 OR location ILIKE $1)";
  values.push(`%${queryParam}%`);
}

sql += " ORDER BY is_featured DESC, start_date ASC";

let events: any[] = [];

const formatDate = (dateStr: string) => {
  return new Date(dateStr).toLocaleDateString('tr-TR', {
    day: 'numeric', month: 'long', year: 'numeric'
  });
};

const getEventImage = (event: any) =>
  resolveContentImage({
    category: 'etkinlikler',
    slug: event?.slug,
    explicit: event?.image_url,
    placeholder: '/images/placeholder-event.jpg',
  });

const seo = {
  title: 'Etkinlikler - Şanlıurfa\'da Bugün ve Yakında',
  description: 'Şanlıurfa\'daki konserler, festivaller, sergiler ve diğer etkinlikler. Kültürel etkinlikleri takip edin.',
  keywords: ['şanlıurfa etkinlikler', 'urfa konser', 'şanlıurfa festival', 'urfa kültür etkinlikleri', 'şanlıurfa bugün ne var', 'urfa sergi', 'şanlıurfa organizasyon'],
  ogImage: '/images/hero/hero-home.webp',
  canonical: '/etkinlikler',
};
const { baseUrl } = await getSiteBranding();

const faqItems = [
  {
    S: 'Şanlıurfa etkinlik takvimi nasıl takip edilir?',
    C: 'Etkinlikler sayfasında yayınlanan aktif etkinlikler tarih sırasına göre listelenir ve arama kutusuyla filtrelenebilir.',
  },
  {
    S: 'Konser ve festival etkinlikleri bu sayfada yer alıyor mu?',
    C: 'Evet. Konser, festival, sergi ve benzeri etkinlik içerikleri kategori etiketleriyle birlikte gösterilir.',
  },
  {
    S: 'Etkinlik detayına nasıl giderim?',
    C: 'Listede yer alan herhangi bir etkinlik kartına tıklayarak detay sayfasına geçebilirsiniz.',
  },
];

try {
  const result = await query(sql, values);
  events = result.rows;
} catch (e) {
  console.error('Error loading events:', e);
}
---

<Layout seo={seo}>
  <div class="page-header">
    <div class="page-header-content">
      <h1 class="page-header-title">Şanlıurfa Etkinlikleri</h1>
      <p class="page-header-description">
        Şanlıurfa’daki kültürel etkinlikleri keşfedin.
      </p>
      
      <div class="mt-8 max-w-2xl mx-auto">
        <form action="/etkinlikler" class="relative">
          <input 
            type="search"
            name="q"
            value={queryParam}
            placeholder="Etkinlik ara..."
            class="w-full pl-12 pr-4 py-4 rounded-xl bg-white/10 backdrop-blur-sm text-white placeholder-white/60 border border-white/20 focus:outline-none focus:border-white/40"
          />
          <span set:html={icons.search}></span>
        </form>
      </div>
    </div>
  </div>
  
  <div class="section bg-gray-50 dark:bg-gray-900">
    <div class="container-custom">
      <div class="rounded-2xl border border-indigo-100 bg-indigo-50 dark:border-indigo-900/40 dark:bg-indigo-950/20 p-5 mb-8">
        <h2 class="text-lg font-bold text-indigo-900 dark:text-indigo-200">Hızlı Cevap</h2>
        <p class="text-sm text-indigo-800 dark:text-indigo-300 mt-1">
          Şanlıurfa etkinlik takvimini bu sayfadan takip edebilir, tarih ve konuma göre uygun etkinliği hızlıca bulabilirsiniz.
        </p>
      </div>

      <div class="space-y-6">
        {events.map((event) => (
          <article class="card-hover bg-white dark:bg-gray-800 rounded-2xl overflow-hidden">
            <a href={`/etkinlikler/${event.slug}`} class="flex flex-col md:flex-row">
              <div class="md:w-1/3 aspect-video md:aspect-auto overflow-hidden">
                <Image
                  src={getEventImage(event)}
                  alt={event.title}
                  class="w-full h-full object-cover"
                  loading="lazy"
                  width={960}
                  height={540}
                />
              </div>
              
              <div class="flex-1 p-6">
                <div class="flex flex-wrap items-center gap-2 mb-2">
                  <span class="badge-primary">{event.category}</span>
                  {event.is_featured && (
                    <span class="badge bg-urfa-600 text-white">Öne Çıkan</span>
                  )}
                </div>
                
                <h3 class="font-display font-bold text-xl text-gray-900 dark:text-white hover:text-urfa-600 dark:hover:text-urfa-400 transition-colors">
                  {event.title}
                </h3>
                
                <p class="text-gray-600 dark:text-gray-400 mt-2 line-clamp-2">
                  {event.description}
                </p>
                
                <div class="flex flex-wrap items-center gap-4 mt-4 text-sm text-gray-500 dark:text-gray-400">
                  <span class="flex items-center gap-1">
                    <span set:html={icons.calendar}></span>
                    {formatDate(event.start_date)}
                    {event.end_date && ` - ${formatDate(event.end_date)}`}
                  </span>
                  <span class="flex items-center gap-1">
                    <span set:html={icons.mapPin}></span>
                    {event.location}
                  </span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>

      {events.length === 0 && (
        <div class="rounded-2xl border border-indigo-100 bg-white p-8 text-center shadow-sm dark:border-indigo-900/40 dark:bg-gray-800">
          <span class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-indigo-50 text-indigo-700 dark:bg-indigo-950/40 dark:text-indigo-300" set:html={icons.calendar}></span>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">Aktif etkinlik bulunamadı</h3>
          <p class="mx-auto max-w-2xl text-gray-600 dark:text-gray-400">
            Bugün için veritabanında yayınlanmış etkinlik kaydı yok. Şanlıurfa gezi planınızı
            mekan rehberi, tarihi yerler ve yemek önerileriyle tamamlayabilirsiniz.
          </p>
          <div class="mt-6 flex flex-wrap justify-center gap-3">
            <a href="/mekanlar" class="rounded-xl bg-urfa-600 px-5 py-3 font-semibold text-white transition-colors hover:bg-urfa-700">
              Mekanları Keşfet
            </a>
            <a href="/tarihi-yerler" class="rounded-xl border border-gray-200 px-5 py-3 font-semibold text-gray-700 transition-colors hover:border-urfa-200 hover:text-urfa-700 dark:border-gray-700 dark:text-gray-200">
              Tarihi Yerler
            </a>
          </div>
        </div>
      )}
    </div>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.C,
      },
    })),
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Şanlıurfa Etkinlik Listesi',
    itemListElement: events.slice(0, 12).map((event, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: event.title,
      url: `${baseUrl}/etkinlikler/${event.slug}`,
    })),
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Etkinlikler', item: `${baseUrl}/etkinlikler` },
    ],
  })} is:inline />
</Layout>