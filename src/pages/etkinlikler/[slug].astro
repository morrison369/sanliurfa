---
import { Icon } from 'astro-icon/components';
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Image from '../../components/Image.astro';
import { query, queryOne } from '../../lib/postgres';
import { resolveContentImage } from '../../lib/content-images';
import { getSiteBranding } from '../../lib/site-branding';
import RelatedEvents from '../../components/events/RelatedEvents.astro';
import { logger } from '../../lib/logging';
const { baseUrl } = await getSiteBranding();

// Kategori (tur) sayfaları — slug bir etkinlik kategorisi ise bu listesi gösterilir
const ETKINLIK_TURLERI: Record<string, { name: string; icon: string; category?: string; dateFilter?: string }> = {
  'konserler': { name: 'Konserler', icon: '🎵', category: 'konser' },
  'sira-geceleri': { name: 'Sıra Geceleri', icon: '🎶', category: 'sira-gecesi' },
  'festivaller': { name: 'Festivaller', icon: '🎉', category: 'festival' },
  'sergiler': { name: 'Sergiler', icon: '🖼️', category: 'sergi' },
  'belediye-etkinlikleri': { name: 'Belediye Etkinlikleri', icon: '🏛️', category: 'belediye' },
  'bugun': { name: 'Bugünkü Etkinlikler', icon: '📅', dateFilter: 'today' },
  'hafta-sonu': { name: 'Hafta Sonu Etkinlikleri', icon: '🗓️', dateFilter: 'weekend' },
};

const turMeta = ETKINLIK_TURLERI[Astro.params.slug || ''];
let turEvents: any[] = [];

if (turMeta) {
  try {
    let sql = `SELECT * FROM events WHERE status = 'published' AND (end_date IS NULL OR end_date >= CURRENT_DATE)`;
    const vals: any[] = [];
    if (turMeta.category) { sql += ` AND category = $${vals.length+1}`; vals.push(turMeta.category); }
    if (turMeta.dateFilter === 'today') { sql += ` AND start_date::date = CURRENT_DATE`; }
    else if (turMeta.dateFilter === 'weekend') { sql += ` AND EXTRACT(DOW FROM start_date) IN (0, 6)`; }
    sql += ` ORDER BY is_featured DESC, start_date ASC LIMIT 20`;
    const r = await query(sql, vals);
    turEvents = r.rows;
  } catch(e) { logger.error('tur events error', e instanceof Error ? e : new Error(String(e))); }
}

const formatTurDate = (d: string) => new Date(d).toLocaleDateString('tr-TR', { day:'numeric', month:'long', year:'numeric' });
const getEventImage = (ev: any, thumb = false) =>
  resolveContentImage({
    category: 'etkinlikler',
    slug: ev?.slug,
    explicit: ev?.image_url,
    placeholder: '/images/placeholder-event.jpg',
    thumb,
  });

let event: any = null;
let isPast = false;
let breadcrumbItems: any[] = [];

const getCategoryLabel = (category: string) => {
  const labels: Record<string, string> = {
    'kultur-sanat': 'Kültür & Sanat', 'gastronomi': 'Gastronomi', 'muzik': 'Müzik',
    'spor': 'Spor', 'egitim': 'Eğitim', 'diger': 'Diğer',
  };
  return labels[category] || category;
};

try {
  const { slug } = Astro.params;

  event = await queryOne(
    `SELECT e.*, u.full_name as creator_name
     FROM events e
     LEFT JOIN users u ON e.created_by = u.id
     WHERE e.slug = $1 AND e.status = 'published'`,
    [slug]
  );

  if (!event) {
    return Astro.redirect('/etkinlikler');
  }

  // Related events query moved to <RelatedEvents server:defer> below — runs
  // alongside the main render instead of blocking the event detail HTML.
  isPast = new Date(event.start_date) < new Date();

  breadcrumbItems = [
    { label: 'Ana Sayfa', href: '/' },
    { label: 'Etkinlikler', href: '/etkinlikler' },
    { label: getCategoryLabel(event.category), href: `/etkinlikler?category=${event.category}` },
    { label: event.title, href: `/etkinlikler/${event.slug}` },
  ];
} catch (e) {
  logger.error('Error loading event detail:', e instanceof Error ? e : new Error(String(e)));
}

const seo = turMeta ? {
  title: `Şanlıurfa ${turMeta.name} | Etkinlikler Rehberi`,
  description: `Şanlıurfa'daki ${turMeta.name.toLowerCase()}. Güncel program ve konum bilgileri.`,
  keywords: ['şanlıurfa ' + turMeta.name.toLowerCase(), 'urfa etkinlikler', turMeta.name + ' şanlıurfa'],
  ogImage: '/images/hero/hero-home.webp',
  canonical: `/etkinlikler/${Astro.params.slug}`,
} : {
  title: event ? `${event.title} - Şanlıurfa Etkinlikleri` : 'Etkinlik - Şanlıurfa',
  description: event?.description || 'Şanlıurfa etkinlikleri',
  ogImage: event ? getEventImage(event) : '/images/placeholder-event.jpg',
  keywords: event ? [event.title, 'şanlıurfa etkinlik', 'urfa ' + (event.event_type || 'etkinlik')] : ['şanlıurfa etkinlikler', 'urfa organizasyon'],
  canonical: `/etkinlikler/${Astro.params.slug}`,
};
const faqItems = event ? [
  { S: `${event.title} ne zaman?`, C: event.start_date ? `${event.title} etkinliği ${new Date(event.start_date).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' })} tarihinde gerçekleşmektedir.` : `${event.title} için tarih bilgisini sayfada bulabilirsiniz.` },
  { S: `${event.title} nerede düzenleniyor?`, C: event.location ? `Etkinlik ${event.location} adresinde düzenlenmektedir.` : 'Etkinlik yeri için sayfamızdaki konum bilgisini inceleyebilirsiniz.' },
  { S: `${event.title} ücretsiz mi?`, C: event.price_info || 'Etkinlik ücreti ve bilet bilgisi için organizatörle iletişime geçebilirsiniz.' },
] : [
  { S: 'Şanlıurfa etkinlikleri nerede listeleniyor?', C: 'Güncel tüm etkinliklere /etkinlikler sayfasından ulaşabilirsiniz.' },
  { S: 'Şanlıurfa etkinliklerine nasıl katılabilirim?', C: 'Etkinlik sayfasındaki iletişim bilgilerini kullanarak organizatörle iletişime geçebilirsiniz.' },
  { S: 'Yeni etkinlikleri nasıl takip edebilirim?', C: 'Etkinlikler sayfamızı düzenli ziyaret ederek ya da topluluğumuza katılarak yeni etkinlikleri takip edebilirsiniz.' },
];

---

<Layout seo={seo}>
  {turMeta ? (
    <div class="min-h-screen bg-[#FDFAF3]">
      <div class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)]">
        <div class="container mx-auto px-4 py-3">
          <nav class="flex items-center gap-2 text-sm text-[#9A8470]">
            <a href="/" class="hover:text-urfa-400 transition-colors">Ana Sayfa</a>
            <span>/</span>
            <a href="/etkinlikler" class="hover:text-urfa-400 transition-colors">Etkinlikler</a>
            <span>/</span>
            <span class="text-[#F5EDD6] font-medium">{turMeta.name}</span>
          </nav>
        </div>
      </div>
      <div class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)] text-white py-12">
        <div class="container mx-auto px-4">
          <div class="flex items-center gap-4">
            <span class="text-5xl">{turMeta.icon}</span>
            <div>
              <h1 class="text-3xl md:text-4xl font-bold text-[#F5EDD6]">Şanlıurfa {turMeta.name}</h1>
              <p class="text-[#9A8470] mt-1">{turEvents.length} etkinlik bulundu</p>
            </div>
          </div>
        </div>
      </div>
      <div class="container mx-auto px-4 py-8">
        {turEvents.length > 0 ? (
          <div class="space-y-4">
            {turEvents.map((ev: any) => (
              <a href={`/etkinlikler/${ev.slug}`} class="block bg-white border border-[rgba(200,160,100,0.18)] rounded-sm p-6 shadow-sm hover:shadow-md hover:border-urfa-300 transition-all group">
                <div class="flex items-start gap-4">
                  <div class="w-14 h-14 bg-[rgba(200,160,100,0.1)] rounded-sm flex items-center justify-center flex-shrink-0 text-2xl">{turMeta.icon}</div>
                  <div class="flex-1">
                    <h2 class="font-bold text-lg text-[#1A1008] group-hover:text-urfa-600 transition-colors">{ev.title}</h2>
                    {ev.description && <p class="text-sm text-[#9A8470] mt-1 line-clamp-2">{ev.description}</p>}
                    <div class="flex flex-wrap gap-4 mt-2 text-sm text-[#9A8470]">
                      {ev.start_date && <span>📅 {formatTurDate(ev.start_date)}</span>}
                      {ev.location && <span>📍 {ev.location}</span>}
                    </div>
                  </div>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <div class="text-center py-16">
            <div class="text-6xl mb-4">{turMeta.icon}</div>
            <p class="text-[#9A8470] text-lg">Bu kategoride yaklaşan etkinlik bulunmuyor.</p>
            <a href="/etkinlikler" class="mt-4 inline-block text-urfa-600 hover:underline">Tüm Etkinliklere Bak →</a>
          </div>
        )}
      </div>
    </div>
  ) : (
  <div class="min-h-screen bg-[#FDFAF3]">
    <div class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)]">
      <div class="container mx-auto px-4 py-4">
        <Breadcrumb items={breadcrumbItems} />
      </div>
    </div>

    <div class="relative h-[400px] lg:h-[500px]">
      <Image
        src={getEventImage(event)}
        alt={event.title}
        width={1920}
        height={1080}
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent" />

      <div class="absolute bottom-0 left-0 right-0">
        <div class="container mx-auto px-4 py-8">
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="inline-block px-3 py-1 bg-urfa-600 text-white text-sm rounded-sm">
              {getCategoryLabel(event.category)}
            </span>
            {isPast && (
              <span class="inline-block px-3 py-1 bg-white/20 border border-white/30 text-white text-sm rounded-sm">
                Geçmiş Etkinlik
              </span>
            )}
          </div>
          <h1 class="text-3xl lg:text-5xl font-bold text-white max-w-3xl">
            {event.title}
          </h1>
        </div>
      </div>
    </div>

    <div class="container mx-auto px-4 py-8">
      <div class="grid lg:grid-cols-3 gap-8">
        <article class="lg:col-span-2">
          <div class="bg-white rounded-sm shadow-sm border border-[rgba(200,160,100,0.18)] p-8">
            <div class="grid sm:grid-cols-3 gap-4 mb-8 pb-8 border-b border-[rgba(200,160,100,0.2)]">
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 bg-[rgba(200,160,100,0.1)] rounded-sm flex items-center justify-center">
                  <Icon name="lucide:calendar" class="w-6 h-6 text-urfa-600" />
                </div>
                <div>
                  <p class="text-sm text-[#9A8470]">Tarih</p>
                  <p class="font-medium text-[#1A1008]">
                    {new Date(event.start_date).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' })}
                  </p>
                  {event.end_date && event.end_date !== event.start_date && (
                    <p class="text-sm text-[#9A8470]">
                      - {new Date(event.end_date).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long' })}
                    </p>
                  )}
                </div>
              </div>

              <div class="flex items-center gap-3">
                <div class="w-12 h-12 bg-[rgba(200,160,100,0.1)] rounded-sm flex items-center justify-center">
                  <Icon name="lucide:clock" class="w-6 h-6 text-urfa-600" />
                </div>
                <div>
                  <p class="text-sm text-[#9A8470]">Saat</p>
                  <p class="font-medium text-[#1A1008]">
                    {event.start_time || '10:00'}
                  </p>
                </div>
              </div>

              <div class="flex items-center gap-3">
                <div class="w-12 h-12 bg-[rgba(200,160,100,0.1)] rounded-sm flex items-center justify-center">
                  <Icon name="lucide:map-pin" class="w-6 h-6 text-urfa-600" />
                </div>
                <div>
                  <p class="text-sm text-[#9A8470]">Konum</p>
                  <p class="font-medium text-[#1A1008]">{event.location}</p>
                </div>
              </div>
            </div>

            <div class="prose max-w-none">
              <h2 class="text-2xl font-bold text-[#1A1008] mb-4">Etkinlik Hakkında</h2>
              <p class="text-[#4A3828] whitespace-pre-line">{event.description}</p>
            </div>

            <div class="flex items-center justify-between mt-8 pt-6 border-t border-[rgba(200,160,100,0.2)]">
              <a href="/etkinlikler" class="flex items-center gap-2 text-[#6B5540] hover:text-urfa-600 transition-colors">
                <Icon name="lucide:arrow-left" class="w-4 h-4" />
                Tüm Etkinlikler
              </a>
              <button class="p-2 text-[#9A8470] hover:text-urfa-600 transition-colors" aria-label="Paylaş">
                <Icon name="lucide:share-2" class="w-5 h-5" />
              </button>
            </div>
          </div>
        </article>

        <aside class="space-y-6">
          <div class="bg-white rounded-sm shadow-sm border border-[rgba(200,160,100,0.18)] p-6">
            <h3 class="font-semibold text-[#1A1008] mb-4">Etkinlik Bilgileri</h3>
            <div class="space-y-3 text-sm">
              <div class="flex justify-between">
                <span class="text-[#9A8470]">Durum</span>
                <span class={`font-medium ${isPast ? 'text-[#9A8470]' : 'text-green-600'}`}>
                  {isPast ? 'Tamamlandı' : 'Aktif'}
                </span>
              </div>
              <div class="flex justify-between">
                <span class="text-[#9A8470]">Kategori</span>
                <span class="font-medium text-[#1A1008]">{getCategoryLabel(event.category)}</span>
              </div>
              {event.creator_name && (
                <div class="flex justify-between">
                  <span class="text-[#9A8470]">Organizatör</span>
                  <span class="font-medium text-[#1A1008]">{event.creator_name}</span>
                </div>
              )}
            </div>

            {!isPast && (
              <button class="w-full mt-6 py-3 bg-urfa-600 text-white rounded-sm font-medium tracking-wide hover:bg-urfa-700 transition-colors">
                Katılım İçin Bilgi Al
              </button>
            )}
          </div>

          <RelatedEvents category={event.category} excludeId={event.id} server:defer>
            <div slot="fallback" class="bg-white rounded-sm shadow-sm border border-[rgba(200,160,100,0.18)] p-6 animate-pulse">
              <div class="h-5 bg-[rgba(200,160,100,0.1)] rounded-sm w-40 mb-4"></div>
              <div class="space-y-4">
                <div class="h-16 bg-[rgba(200,160,100,0.06)] rounded-sm"></div>
                <div class="h-16 bg-[rgba(200,160,100,0.06)] rounded-sm"></div>
                <div class="h-16 bg-[rgba(200,160,100,0.06)] rounded-sm"></div>
              </div>
            </div>
          </RelatedEvents>
        </aside>
      </div>
    </div>
  </div>
  )}

  {event && (
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
        { '@type': 'ListItem', position: 2, name: 'Etkinlikler', item: `${baseUrl}/etkinlikler` },
        { '@type': 'ListItem', position: 3, name: event.title, item: `${baseUrl}/etkinlikler/${event.slug}` },
      ],
    })} is:inline />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Event',
      name: event.title,
      description: event.description,
      startDate: event.start_date,
      endDate: event.end_date || event.start_date,
      location: {
        '@type': 'Place',
        name: event.location || 'Şanlıurfa',
        address: { '@type': 'PostalAddress', addressLocality: 'Şanlıurfa', addressCountry: 'TR' },
      },
      image: event.image_url ? `${baseUrl}${event.image_url}` : `${baseUrl}/images/hero/hero-home.webp`,
      organizer: { '@type': 'Organization', name: 'Sanliurfa.com', url: `${baseUrl}` },
      eventStatus: 'https://schema.org/EventScheduled',
      eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
      url: `${baseUrl}/etkinlikler/${event.slug}`,
    })} is:inline />
  )}
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: { '@type': 'Answer', text: item.C },
    })),
  })} is:inline />
</Layout>
