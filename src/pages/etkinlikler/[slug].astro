---

import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Image from '../../components/Image.astro';
import { query, queryOne } from '../../lib/postgres';
import { resolveContentImage } from '../../lib/content-images';
import { getSiteBranding } from '../../lib/site-branding';
const { baseUrl } = await getSiteBranding();

// SVG ikonlar
const icons = {
  calendar: `<svg class="w-6 h-6 text-urfa-600 dark:text-urfa-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
  clock: `<svg class="w-6 h-6 text-urfa-600 dark:text-urfa-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  mapPin: `<svg class="w-6 h-6 text-urfa-600 dark:text-urfa-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
  arrowLeft: `<svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>`,
  share2: `<svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>`,
};

// Kategori (tur) sayfaları — slug bir etkinlik kategorisi ise bu listesi gösterilir
const ETKINLIK_TURLERI: Record<string, { name: string; icon: string; category?: string; dateFilter?: string }> = {
  'konserler': { name: 'Konserler', icon: '🎵', category: 'konser' },
  'sira-geceleri': { name: 'Sıra Geceleri', icon: '🎶', category: 'sira-gecesi' },
  'festivaller': { name: 'Festivaller', icon: '🎉', category: 'festival' },
  'sergiler': { name: 'Sergiler', icon: '🖼️', category: 'sergi' },
  'belediye-etkinlikleri': { name: 'Belediye Etkinlikleri', icon: '🏛️', category: 'belediye' },
  'bugun': { name: 'Bugünkü Etkinlikler', icon: '📅', dateFilter: 'today' },
  'hafta-sonu': { name: 'Hafta Sonu Etkinlikleri', icon: '🗓️', dateFilter: 'weekend' },
};

const turMeta = ETKINLIK_TURLERI[Astro.params.slug || ''];
let turEvents: any[] = [];

if (turMeta) {
  try {
    let sql = `SELECT * FROM events WHERE status = 'published' AND (end_date IS NULL OR end_date >= CURRENT_DATE)`;
    const vals: any[] = [];
    if (turMeta.category) { sql += ` AND category = $${vals.length+1}`; vals.push(turMeta.category); }
    if (turMeta.dateFilter === 'today') { sql += ` AND start_date::date = CURRENT_DATE`; }
    else if (turMeta.dateFilter === 'weekend') { sql += ` AND EXTRACT(DOW FROM start_date) IN (0, 6)`; }
    sql += ` ORDER BY is_featured DESC, start_date ASC LIMIT 20`;
    const r = await query(sql, vals);
    turEvents = r.rows;
  } catch(e) { console.error('tur events error', e); }
}

const formatTurDate = (d: string) => new Date(d).toLocaleDateString('tr-TR', { day:'numeric', month:'long', year:'numeric' });
const getEventImage = (ev: any, thumb = false) =>
  resolveContentImage({
    category: 'etkinlikler',
    slug: ev?.slug,
    explicit: ev?.image_url,
    placeholder: '/images/placeholder-event.jpg',
    thumb,
  });

let event: any = null;
let relatedEvents: any[] = [];
let isPast = false;
let breadcrumbItems: any[] = [];

const getCategoryLabel = (category: string) => {
  const labels: Record<string, string> = {
    'kultur-sanat': 'Kültür & Sanat', 'gastronomi': 'Gastronomi', 'muzik': 'Müzik',
    'spor': 'Spor', 'egitim': 'Eğitim', 'diger': 'Diğer',
  };
  return labels[category] || category;
};

try {
  const { slug } = Astro.params;

  event = await queryOne(
    `SELECT e.*, u.full_name as creator_name
     FROM events e
     LEFT JOIN users u ON e.created_by = u.id
     WHERE e.slug = $1 AND e.status = 'published'`,
    [slug]
  );

  if (!event) {
    return Astro.redirect('/etkinlikler');
  }

  const relatedResult = await query(
    `SELECT id, title, slug, image_url, start_date, location
     FROM events
     WHERE status = 'published' AND category = $1 AND id != $2
     AND start_date >= CURRENT_DATE
     LIMIT 3`,
    [event.category, event.id]
  );
  relatedEvents = relatedResult.rows;

  isPast = new Date(event.start_date) < new Date();

  breadcrumbItems = [
    { label: 'Ana Sayfa', href: '/' },
    { label: 'Etkinlikler', href: '/etkinlikler' },
    { label: getCategoryLabel(event.category), href: `/etkinlikler?category=${event.category}` },
    { label: event.title, href: `/etkinlikler/${event.slug}` },
  ];
} catch (e) {
  console.error('Error loading event detail:', e);
}

const seo = turMeta ? {
  title: `Şanlıurfa ${turMeta.name} | Etkinlikler Rehberi`,
  description: `Şanlıurfa'daki ${turMeta.name.toLowerCase()}. Güncel program ve konum bilgileri.`,
  keywords: ['şanlıurfa ' + turMeta.name.toLowerCase(), 'urfa etkinlikler', turMeta.name + ' şanlıurfa'],
  ogImage: '/images/hero/hero-home.webp',
  canonical: `/etkinlikler/${Astro.params.slug}`,
} : {
  title: event ? `${event.title} - Şanlıurfa Etkinlikleri` : 'Etkinlik - Şanlıurfa',
  description: event?.description || 'Şanlıurfa etkinlikleri',
  ogImage: event ? getEventImage(event) : '/images/placeholder-event.jpg',
  keywords: event ? [event.title, 'şanlıurfa etkinlik', 'urfa ' + (event.event_type || 'etkinlik')] : ['şanlıurfa etkinlikler', 'urfa organizasyon'],
  canonical: `/etkinlikler/${Astro.params.slug}`,
};
const faqItems = event ? [
  { S: `${event.title} ne zaman?`, C: event.start_date ? `${event.title} etkinliği ${new Date(event.start_date).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' })} tarihinde gerçekleşmektedir.` : `${event.title} için tarih bilgisini sayfada bulabilirsiniz.` },
  { S: `${event.title} nerede düzenleniyor?`, C: event.location ? `Etkinlik ${event.location} adresinde düzenlenmektedir.` : 'Etkinlik yeri için sayfamızdaki konum bilgisini inceleyebilirsiniz.' },
  { S: `${event.title} ücretsiz mi?`, C: event.price_info || 'Etkinlik ücreti ve bilet bilgisi için organizatörle iletişime geçebilirsiniz.' },
] : [
  { S: 'Şanlıurfa etkinlikleri nerede listeleniyor?', C: 'Güncel tüm etkinliklere /etkinlikler sayfasından ulaşabilirsiniz.' },
  { S: 'Şanlıurfa etkinliklerine nasıl katılabilirim?', C: 'Etkinlik sayfasındaki iletişim bilgilerini kullanarak organizatörle iletişime geçebilirsiniz.' },
  { S: 'Yeni etkinlikleri nasıl takip edebilirim?', C: 'Etkinlikler sayfamızı düzenli ziyaret ederek ya da topluluğumuza katılarak yeni etkinlikleri takip edebilirsiniz.' },
];

---

<Layout seo={seo}>
  {turMeta ? (
    <div class="min-h-screen bg-gray-50">
      <div class="bg-white border-b">
        <div class="container mx-auto px-4 py-3">
          <nav class="flex items-center gap-2 text-sm text-gray-500">
            <a href="/" class="hover:text-purple-600">Ana Sayfa</a>
            <span>/</span>
            <a href="/etkinlikler" class="hover:text-purple-600">Etkinlikler</a>
            <span>/</span>
            <span class="text-gray-900 font-medium">{turMeta.name}</span>
          </nav>
        </div>
      </div>
      <div class="bg-gradient-to-br from-purple-700 to-indigo-800 text-white py-12">
        <div class="container mx-auto px-4">
          <div class="flex items-center gap-4">
            <span class="text-5xl">{turMeta.icon}</span>
            <div>
              <h1 class="text-3xl md:text-4xl font-bold">Şanlıurfa {turMeta.name}</h1>
              <p class="text-purple-100 mt-1">{turEvents.length} etkinlik bulundu</p>
            </div>
          </div>
        </div>
      </div>
      <div class="container mx-auto px-4 py-8">
        {turEvents.length > 0 ? (
          <div class="space-y-4">
            {turEvents.map((ev: any) => (
              <a href={`/etkinlikler/${ev.slug}`} class="block bg-white rounded-xl p-6 shadow-sm hover:shadow-lg transition-all group">
                <div class="flex items-start gap-4">
                  <div class="w-14 h-14 bg-purple-100 rounded-xl flex items-center justify-center flex-shrink-0 text-2xl">{turMeta.icon}</div>
                  <div class="flex-1">
                    <h2 class="font-bold text-lg text-gray-900 group-hover:text-purple-600">{ev.title}</h2>
                    {ev.description && <p class="text-sm text-gray-600 mt-1 line-clamp-2">{ev.description}</p>}
                    <div class="flex flex-wrap gap-4 mt-2 text-sm text-gray-500">
                      {ev.start_date && <span>📅 {formatTurDate(ev.start_date)}</span>}
                      {ev.location && <span>📍 {ev.location}</span>}
                    </div>
                  </div>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <div class="text-center py-16">
            <div class="text-6xl mb-4">{turMeta.icon}</div>
            <p class="text-gray-500 text-lg">Bu kategoride yaklaşan etkinlik bulunmuyor.</p>
            <a href="/etkinlikler" class="mt-4 inline-block text-purple-600 hover:underline">Tüm Etkinliklere Bak →</a>
          </div>
        )}
      </div>
    </div>
  ) : (
  <div class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <div class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
      <div class="container-custom py-4">
        <Breadcrumb items={breadcrumbItems} />
      </div>
    </div>
    
    <div class="relative h-[400px] lg:h-[500px]">
      <Image
        src={getEventImage(event)}
        alt={event.title}
        width={1920}
        height={1080}
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent" />
      
      <div class="absolute bottom-0 left-0 right-0">
        <div class="container-custom py-8">
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="inline-block px-3 py-1 bg-urfa-600 text-white text-sm rounded-full">
              {getCategoryLabel(event.category)}
            </span>
            {isPast && (
              <span class="inline-block px-3 py-1 bg-gray-600 text-white text-sm rounded-full">
                Geçmiş Etkinlik
              </span>
            )}
          </div>
          <h1 class="text-3xl lg:text-5xl font-display font-bold text-white max-w-3xl">
            {event.title}
          </h1>
        </div>
      </div>
    </div>
    
    <div class="container-custom py-8">
      <div class="grid lg:grid-cols-3 gap-8">
        <article class="lg:col-span-2">
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-8">
            <div class="grid sm:grid-cols-3 gap-4 mb-8 pb-8 border-b border-gray-200 dark:border-gray-700">
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 bg-urfa-100 dark:bg-urfa-900/30 rounded-xl flex items-center justify-center">
                  <span set:html={icons.calendar}></span>
                </div>
                <div>
                  <p class="text-sm text-gray-500 dark:text-gray-400">Tarih</p>
                  <p class="font-medium text-gray-900 dark:text-white">
                    {new Date(event.start_date).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' })}
                  </p>
                  {event.end_date && event.end_date !== event.start_date && (
                    <p class="text-sm text-gray-500 dark:text-gray-400">
                      - {new Date(event.end_date).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long' })}
                    </p>
                  )}
                </div>
              </div>
              
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 bg-urfa-100 dark:bg-urfa-900/30 rounded-xl flex items-center justify-center">
                  <span set:html={icons.clock}></span>
                </div>
                <div>
                  <p class="text-sm text-gray-500 dark:text-gray-400">Saat</p>
                  <p class="font-medium text-gray-900 dark:text-white">
                    {event.start_time || '10:00'}
                  </p>
                </div>
              </div>
              
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 bg-urfa-100 dark:bg-urfa-900/30 rounded-xl flex items-center justify-center">
                  <span set:html={icons.mapPin}></span>
                </div>
                <div>
                  <p class="text-sm text-gray-500 dark:text-gray-400">Konum</p>
                  <p class="font-medium text-gray-900 dark:text-white">{event.location}</p>
                </div>
              </div>
            </div>
            
            <div class="prose dark:prose-invert max-w-none">
              <h2 class="text-2xl font-display font-bold text-gray-900 dark:text-white mb-4">Etkinlik Hakkında</h2>
              <p class="text-gray-600 dark:text-gray-400 whitespace-pre-line">{event.description}</p>
            </div>
            
            <div class="flex items-center justify-between mt-8 pt-6 border-t border-gray-200 dark:border-gray-700">
              <a href="/etkinlikler" class="flex items-center gap-2 text-gray-600 dark:text-gray-400 hover:text-urfa-600 dark:hover:text-urfa-400 transition-colors">
                <span set:html={icons.arrowLeft}></span>
                Tüm Etkinlikler
              </a>
              <button class="p-2 text-gray-500 dark:text-gray-400 hover:text-urfa-600 dark:hover:text-urfa-400 transition-colors" aria-label="Paylaş">
                <span set:html={icons.share2}></span>
              </button>
            </div>
          </div>
        </article>
        
        <aside class="space-y-6">
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
            <h3 class="font-semibold text-gray-900 dark:text-white mb-4">Etkinlik Bilgileri</h3>
            <div class="space-y-3 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-500 dark:text-gray-400">Durum</span>
                <span class={`font-medium ${isPast ? 'text-gray-500' : 'text-green-600'}`}>
                  {isPast ? 'Tamamlandı' : 'Aktif'}
                </span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500 dark:text-gray-400">Kategori</span>
                <span class="font-medium text-gray-900 dark:text-white">{getCategoryLabel(event.category)}</span>
              </div>
              {event.creator_name && (
                <div class="flex justify-between">
                  <span class="text-gray-500 dark:text-gray-400">Organizatör</span>
                  <span class="font-medium text-gray-900 dark:text-white">{event.creator_name}</span>
                </div>
              )}
            </div>
            
            {!isPast && (
              <button class="w-full mt-6 btn-primary">
                Katılım İçin Bilgi Al
              </button>
            )}
          </div>
          
          {relatedEvents && relatedEvents.length > 0 && (
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
              <h3 class="font-semibold text-gray-900 dark:text-white mb-4">Benzer Etkinlikler</h3>
              <div class="space-y-4">
                {relatedEvents.map((related: any) => (
                  <a href={`/etkinlikler/${related.slug}`} class="flex gap-3 group">
                    <Image
                      src={getEventImage(related, true)}
                      alt={related.title}
                      width={320}
                      height={256}
                      class="w-20 h-16 rounded-lg object-cover flex-shrink-0"
                    />
                    <div>
                      <span class="text-xs text-urfa-600 dark:text-urfa-400">
                        {new Date(related.start_date).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long' })}
                      </span>
                      <h4 class="font-medium text-gray-900 dark:text-white text-sm group-hover:text-urfa-600 dark:group-hover:text-urfa-400 transition-colors line-clamp-2">
                        {related.title}
                      </h4>
                      <p class="text-xs text-gray-500 dark:text-gray-400">{related.location}</p>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}
        </aside>
      </div>
    </div>
  </div>
  )}

  {event && (
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
        { '@type': 'ListItem', position: 2, name: 'Etkinlikler', item: `${baseUrl}/etkinlikler` },
        { '@type': 'ListItem', position: 3, name: event.title, item: `${baseUrl}/etkinlikler/${event.slug}` },
      ],
    })} is:inline />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Event',
      name: event.title,
      description: event.description,
      startDate: event.start_date,
      endDate: event.end_date || event.start_date,
      location: {
        '@type': 'Place',
        name: event.location || 'Şanlıurfa',
        address: { '@type': 'PostalAddress', addressLocality: 'Şanlıurfa', addressCountry: 'TR' },
      },
      image: event.image_url ? `${baseUrl}${event.image_url}` : `${baseUrl}/images/hero/hero-home.webp`,
      organizer: { '@type': 'Organization', name: 'Sanliurfa.com', url: `${baseUrl}` },
      eventStatus: 'https://schema.org/EventScheduled',
      eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
      url: `${baseUrl}/etkinlikler/${event.slug}`,
    })} is:inline />
  )}
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: { '@type': 'Answer', text: item.C },
    })),
  })} is:inline />
</Layout>
