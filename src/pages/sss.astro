---
import Layout from '../layouts/Layout.astro';
import { getPublicAppUrl } from '../lib/public-app-url';

const baseUrl = getPublicAppUrl();

const seo = {
 title: 'Sık Sorulan Sorular | Sanliurfa.com',
 description: 'Sanliurfa.com şehir rehberi, mekan ekleme, yorumlar, üyelik, eşleşme ve içerik yönetimi hakkında sık sorulan sorular.',
 keywords: ['sanliurfa.com sss', 'şanlıurfa rehber sorular', 'urfa mekan ekleme nasıl', 'sanliurfa.com yardım', 'şanlıurfa üyelik'],
 ogImage: '/images/places/balikligol.jpg',
 canonical: '/sss',
};

const faqs = [
 {
 S: 'Sanliurfa.com nedir?',
 C: 'Sanliurfa.com; Şanlıurfa mekanları, gezilecek yerleri, ulaşım, sağlık, yemek tarifleri ve topluluk özelliklerini tek yerde sunan yerel şehir rehberidir.',
 },
 {
 S: 'Mekan eklemek ücretli mi?',
 C: 'Mekan ekleme, yorum yapma, puan verme ve temel topluluk özellikleri ücretsizdir. Öne çıkarma ve ek görünürlük için premium abonelik seçenekleri mevcuttur.',
 },
 {
 S: 'Yorum ve puanlama nasıl çalışır?',
 C: 'Kayıtlı kullanıcılar mekan detay sayfalarında 1–5 yıldız puan verebilir ve yorum yazabilir. Yorumlar moderasyon sürecinden geçer; uygunsuz içerikler kaldırılır.',
 },
 {
 S: 'Nöbetçi eczane bilgisi nereden güncelleniyor?',
 C: 'Nöbetçi eczane listesi, admin paneli üzerinden yetkili kullanıcılar tarafından günlük olarak güncellenir. Sayfaya doğrudan /saglik/nobetci-eczaneler adresinden ulaşabilirsiniz.',
 },
 {
 S: 'Şanlıurfa otobüs saatleri güncel mi?',
 C: 'Otobüs sefer saatleri ve hat bilgileri /ulasim/otobus-saatleri sayfasında, hat detayları ise /ulasim/otobus-hatlari sayfasında yayınlanmaktadır. Bilgiler dönemsel olarak güncellenir.',
 },
 {
 S: 'İşletmemi nasıl ekleyebilirim?',
 C: 'İşletme Ekle (/isletme-kayit) sayfasından formu doldurarak başvurabilirsiniz. Başvurular admin onayından geçtikten sonra yayınlanır.',
 },
 {
 S: 'İşletme doğrulama nedir?',
 C: 'Doğrulanmış işletmeler, mavi onay rozeti alarak daha güvenilir görünür. Doğrulama talebi, işletme sahibi hesabıyla admin portalı üzerinden iletilir.',
 },
 {
 S: 'Eşleşme özelliği nedir?',
 C: 'Eşleşme özelliği (/eslesme), kullanıcıların ilgi alanlarına göre topluluk içinde yeni kişiler keşfetmesini sağlayan sosyal bir araçtır.',
 },
 {
 S: "Göbeklitepe'ye nasıl gidilir?",
 C: "Göbeklitepe, Şanlıurfa şehir merkezine yaklaşık 18 km uzaklıktadır. Şehir merkezinden taksi veya özel araçla ulaşabilirsiniz. Ziyaret saatleri ve bilet bilgileri için /isletme/gobeklitepe sayfasını inceleyebilirsiniz.",
 },
 {
 S: "Halfeti'ye nasıl gidilir?",
 C: "Halfeti, Şanlıurfa'ya 120 km uzaklıkta Fırat kıyısında yer alan bir ilçedir. Şanlıurfa Otogarı'ndan düzenli seferler bulunmaktadır. Tekne turu ve konaklama bilgileri için /ilceler/halfeti sayfasını inceleyebilirsiniz.",
 },
 {
 S: 'Urfa kebabı tarifi var mı?',
 C: 'Evet, /yemek-tarifleri/urfa-kebabi adresinde adım adım Urfa kebabı tarifi bulabilirsiniz. Ayrıca çiğ köfte, borani ve şıllık gibi yöresel tarifler de /yemek-tarifleri sayfasında mevcuttur.',
 },
 {
 S: 'Yanlış veya eksik bilgi nasıl bildirilebilir?',
 C: 'Hatalı içerikleri /iletisim sayfasındaki formu kullanarak ya da mekan detay sayfasındaki "Raporla" butonuyla bildirebilirsiniz. Moderasyon ekibimiz en kısa sürede inceler.',
 },
];
---

<Layout seo={seo}>
 <style is:inline>
 .ss-hero{padding:4rem 0 3rem;border-bottom:1px solid rgba(184,115,51,.1)}
 .ss-eyebrow{font-size:.68rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--public-accent);margin-bottom:.75rem}
 .ss-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.9rem,4vw,2.9rem);font-weight:600;color:var(--public-text);line-height:1.15;margin-bottom:.75rem}
 .ss-sub{font-size:.9rem;color:var(--public-muted);line-height:1.7;max-width:560px}
 .ss-body{padding:2.5rem 0 5rem}
 .ss-grid{display:grid;gap:1rem;grid-template-columns:1fr}
 @media(min-width:640px){.ss-grid{grid-template-columns:1fr 1fr}}
 .ss-card{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);padding:1.5rem}
 .ss-q{font-size:.9rem;font-weight:700;color:var(--public-text);margin-bottom:.5rem;line-height:1.4}
 .ss-a{font-size:.82rem;color:var(--public-muted);line-height:1.7}
 </style>

 <!-- Hero -->
 <div class="ss-hero">
 <div class="sf-container">
 <p class="ss-eyebrow">Yardım Merkezi</p>
 <h1 class="ss-h1">Sık Sorulan Sorular</h1>
 <p class="ss-sub">
 Şanlıurfa şehir rehberi, üyelik, mekan ekleme ve topluluk özellikleriyle ilgili temel cevaplar.
 </p>
 </div>
 </div>

 <!-- FAQ Grid -->
 <div class="sf-container ss-body">
 <div class="ss-grid">
 {faqs.map((item) => (
 <article class="ss-card">
 <h2 class="ss-q">{item.S}</h2>
 <p class="ss-a">{item.C}</p>
 </article>
 ))}
 </div>
 </div>

 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqs.map((item) => ({
 '@type': 'Question',
 name: item.S,
 acceptedAnswer: { '@type': 'Answer', text: item.C },
 })),
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'SSS', item: `${baseUrl}/sss` },
 ],
 })} is:inline />
</Layout>
