---

import Layout from '../layouts/Layout.astro';
import { getPublicAppUrl } from '../lib/public-app-url';
const baseUrl = getPublicAppUrl();

const seo = {
 title: 'Çerez Politikası | Sanliurfa.com',
 description:
 'Sanliurfa.com çerez politikası: zorunlu çerezler, oturum yönetimi, analitik tercihleri ve kullanıcı kontrolü.',
 keywords: ['şanlıurfa.com çerez politikası', 'çerez kullanımı', 'gizlilik ayarları'],
 ogImage: '/images/places/balikligol.jpg',
 canonical: '/cerez-politikasi',
};

const sections = [
 {
 title: 'Zorunlu Çerezler',
 text: 'Oturum güvenliği, giriş durumu, CSRF koruması ve temel site işlevleri için gerekli çerezler kullanılır.',
 },
 {
 title: 'Tercih Çerezleri',
 text: 'Kullanıcının tema, bildirim ve arayüz tercihlerini hatırlamak için tercih çerezleri kullanılabilir.',
 },
 {
 title: 'Analitik ve Performans',
 text: 'Site performansını, popüler içerikleri ve teknik hataları anlamak için anonimleştirilmiş ölçüm verileri kullanılabilir.',
 },
 {
 title: 'Kontrol ve Silme',
 text: 'Kullanıcılar tarayıcı ayarlarından çerezleri silebilir veya engelleyebilir. Zorunlu çerezler kapatılırsa bazı özellikler çalışmayabilir.',
 },
];
const faqItems = [
 { S: "Sanliurfa.com çerez politikası nasıl çalışır?", C: "Sanliurfa.com, site işlevselliği ve kullanıcı deneyimini iyileştirmek amacıyla zorunlu ve analitik çerezler kullanmaktadır." },
 { S: "Çerezleri nasıl kapatabilir veya silebilirim?", C: "Tarayıcı ayarlarınızdan çerezleri yönetebilir, sınırlayabilir ya da tamamen silebilirsiniz." },
 { S: "Çerez kullanımına itiraz etme hakkım var mı?", C: "KVKK kapsamında zorunlu olmayan çerezleri reddetme hakkınız bulunmaktadır." },
];
---

<Layout seo={seo}>
 <style is:inline>
 .cp-hero{padding:3rem 0 2.5rem;border-bottom:1px solid rgba(184,115,51,.1)}
 .cp-eyebrow{font-size:.68rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--public-muted);margin-bottom:.5rem}
 .cp-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.7rem,4vw,2.5rem);font-weight:600;color:var(--public-text);margin-bottom:.4rem}
 .cp-sub{font-size:.85rem;color:var(--public-muted);line-height:1.75;max-width:600px}
 .cp-body{background:var(--bg);padding:2.5rem 0 5rem}
 .cp-inner{max-width:720px;margin:0 auto}
 .cp-section{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);padding:1.5rem 1.75rem;margin-bottom:.85rem}
 .cp-section-title{font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-weight:600;color:var(--public-text);margin-bottom:.6rem}
 .cp-section-text{font-size:.855rem;color:var(--public-muted);line-height:1.8}
 .cp-contact{background:rgba(184,115,51,.05);border:1px solid rgba(184,115,51,.2);padding:1.25rem 1.75rem;margin-top:.5rem}
 .cp-contact-title{font-size:.85rem;font-weight:700;color:var(--public-accent);margin-bottom:.35rem}
 .cp-contact-text{font-size:.82rem;color:var(--public-muted);line-height:1.7}
 .cp-contact-link{color:var(--public-accent);font-weight:600;text-decoration:underline;text-underline-offset:3px}
 .cp-contact-link:hover{color:var(--public-accent-strong)}
 </style>

 <!-- Hero -->
 <div class="cp-hero">
 <div class="sf-container">
 <p class="cp-eyebrow">Gizlilik</p>
 <h1 class="cp-h1">Çerez Politikası</h1>
 <p class="cp-sub">Sanliurfa.com üzerinde kullanılan çerez türleri ve kullanıcı kontrol seçenekleri.</p>
 </div>
 </div>

 <!-- Content -->
 <div class="cp-body">
 <div class="sf-container">
 <div class="cp-inner">
 {sections.map((section) => (
 <article class="cp-section">
 <h2 class="cp-section-title">{section.title}</h2>
 <p class="cp-section-text">{section.text}</p>
 </article>
 ))}

 <div class="cp-contact">
 <p class="cp-contact-title">İletişim</p>
 <p class="cp-contact-text">
 Çerezler ve kişisel verilerle ilgili talepler için <a href="/iletisim" class="cp-contact-link">iletişim sayfasını</a> kullanabilirsiniz.
 </p>
 </div>
 </div>
 </div>
 </div>

 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'WebPage',
 name: 'Çerez Politikası',
 url: `${baseUrl}/cerez-politikasi`,
 publisher: {
 '@type': 'Organization',
 name: 'Sanliurfa.com',
 url: baseUrl,
 },
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'Çerez Politikası', item: `${baseUrl}/cerez-politikasi` },
 ],
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqItems.map((item) => ({
 '@type': 'Question',
 name: item.S,
 acceptedAnswer: { '@type': 'Answer', text: item.C },
 })),
 })} is:inline />
</Layout>
