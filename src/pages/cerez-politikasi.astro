---

import Layout from '../layouts/Layout.astro';
import { getSiteBranding } from '../lib/site-branding';
const { baseUrl } = await getSiteBranding();

const seo = {
  title: 'Çerez Politikası | Sanliurfa.com',
  description:
    'Sanliurfa.com çerez politikası: zorunlu çerezler, oturum yönetimi, analitik tercihleri ve kullanıcı kontrolü.',
  keywords: ['şanlıurfa.com çerez politikası', 'çerez kullanımı', 'gizlilik ayarları'],
  ogImage: '/images/hero/hero-home.webp',
  canonical: '/cerez-politikasi',
};

const sections = [
  {
    title: 'Zorunlu Çerezler',
    text: 'Oturum güvenliği, giriş durumu, CSRF koruması ve temel site işlevleri için gerekli çerezler kullanılır.',
  },
  {
    title: 'Tercih Çerezleri',
    text: 'Kullanıcının tema, bildirim ve arayüz tercihlerini hatırlamak için tercih çerezleri kullanılabilir.',
  },
  {
    title: 'Analitik ve Performans',
    text: 'Site performansını, popüler içerikleri ve teknik hataları anlamak için anonimleştirilmiş ölçüm verileri kullanılabilir.',
  },
  {
    title: 'Kontrol ve Silme',
    text: 'Kullanıcılar tarayıcı ayarlarından çerezleri silebilir veya engelleyebilir. Zorunlu çerezler kapatılırsa bazı özellikler çalışmayabilir.',
  },
];
const faqItems = [
  { S: "Sanliurfa.com çerez politikası nasıl çalışır?", C: "Sanliurfa.com, site işlevselliği ve kullanıcı deneyimini iyileştirmek amacıyla zorunlu ve analitik çerezler kullanmaktadır." },
  { S: "Çerezleri nasıl kapatabilir veya silebilirim?", C: "Tarayıcı ayarlarınızdan çerezleri yönetebilir, sınırlayabilir ya da tamamen silebilirsiniz." },
  { S: "Çerez kullanımına itiraz etme hakkım var mı?", C: "KVKK kapsamında zorunlu olmayan çerezleri reddetme hakkınız bulunmaktadır." },
];

---

<Layout seo={seo}>
  <main class="min-h-screen bg-[#FDFAF3]">
    <div class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)] text-white">
      <div class="container mx-auto px-4 py-14">
        <p class="text-sm font-semibold uppercase tracking-wider text-[#9A8470]">Gizlilik</p>
        <h1 class="mt-3 text-4xl md:text-5xl font-bold text-[#F5EDD6]">Çerez Politikası</h1>
        <p class="mt-4 max-w-3xl text-lg text-[#9A8470]">
          Sanliurfa.com üzerinde kullanılan çerez türleri ve kullanıcı kontrol seçenekleri.
        </p>
      </div>
    </div>

    <section class="container mx-auto px-4 py-12">
      <div class="mx-auto max-w-4xl space-y-5">
        {sections.map((section) => (
          <article class="rounded-sm border border-[rgba(200,160,100,0.18)] bg-white p-6 shadow-sm">
            <h2 class="text-xl font-bold text-[#1A1008]">{section.title}</h2>
            <p class="mt-3 leading-7 text-[#4A3828]">{section.text}</p>
          </article>
        ))}

        <div class="rounded-sm border border-[rgba(200,160,100,0.2)] bg-[rgba(200,160,100,0.06)] p-6">
          <h2 class="text-lg font-bold text-[#1A1008]">İletişim</h2>
          <p class="mt-2 text-[#4A3828]">
            Çerezler ve kişisel verilerle ilgili talepler için <a href="/iletisim" class="font-semibold text-urfa-600 underline">iletişim sayfasını</a> kullanabilirsiniz.
          </p>
        </div>
      </div>
    </section>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Çerez Politikası',
    url: `${baseUrl}/cerez-politikasi`,
    publisher: {
      '@type': 'Organization',
      name: 'Sanliurfa.com',
      url: `${baseUrl}`,
    },
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Çerez Politikası', item: `${baseUrl}/cerez-politikasi` },
    ],
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: { '@type': 'Answer', text: item.C },
    })),
  })} is:inline />
</Layout>
