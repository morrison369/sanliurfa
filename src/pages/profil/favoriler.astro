---
import { Icon } from 'astro-icon/components';
import Layout from '../../layouts/Layout.astro';
import Image from '../../components/Image.astro';
import ProfileSidebar from '../../components/profile/ProfileSidebar.astro';
import { query } from '../../lib/postgres';
import { logger } from '../../lib/logging';

const user = Astro.locals.user;

if (!user) {
 return Astro.redirect('/giris?redirect=/profil/favoriler');
}

let favorites: any[] = [];
const seo = {
 title: 'Favorilerim - Sanliurfa.com',
 description: 'Favori mekanlarınızı görüntüleyin.',
 noIndex: true,
};

try {
 const result = await query(
 `SELECT f.*, p.name as place_name, p.slug as place_slug, p.images as place_images,
 p.rating as place_rating, p.address as place_address
 FROM user_favorites f
 JOIN places p ON f.place_id = p.id
 WHERE f.user_id = $1
 ORDER BY f.created_at DESC`,
 [user.id]
 );
 favorites = result.rows;
} catch (e) {
 logger.error('Error loading data:', e instanceof Error ? e : new Error(String(e)));
}
---

<Layout seo={seo}>
 <style>
 .pf-page{background:var(--public-bg);min-height:100vh;padding:2rem 0 4rem}
 .pf-grid{display:grid;gap:2rem}
 @media(min-width:64rem){.pf-grid{grid-template-columns:1fr 3fr}}
 .pf-card{background:var(--public-surface);border:1px solid var(--public-border);padding:1.5rem}
 .pf-h2{font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:700;color:var(--public-text);margin-bottom:1rem}
 .pf-fav{display:flex;gap:1rem;padding:1rem;background:var(--public-accent-soft);border:1px solid var(--public-border-soft)}
 .pf-fav+.pf-fav{margin-top:.75rem}
 .pf-fav-img{width:6rem;height:6rem;object-fit:cover;flex-shrink:0}
 .pf-fav-body{flex:1;min-width:0}
 .pf-place-link{font-weight:600;color:var(--public-text);transition:color .15s;display:block}
 .pf-place-link:hover{color:var(--public-accent-strong)}
 .pf-address{display:flex;align-items:center;gap:.25rem;font-size:.8rem;color:var(--public-muted);margin-top:.25rem}
 .pf-rating{display:flex;align-items:center;gap:.25rem;font-size:.82rem;color:var(--public-accent);margin-top:.4rem}
 .pf-del-btn{color:var(--public-muted);padding:.4rem;transition:color .15s;align-self:flex-start;flex-shrink:0;background:none;border:none;cursor:pointer}
 .pf-del-btn:hover{color:var(--public-accent-strong)}
 .pf-empty{text-align:center;padding:3rem 1rem}
 .pf-empty-icon{color:var(--public-border);display:block;margin:0 auto 1rem}
 .pf-empty-title{font-size:1.1rem;font-weight:700;color:var(--public-text);margin-bottom:.5rem}
 .pf-empty-desc{color:var(--public-muted);margin-bottom:1.25rem;font-size:.88rem}
 .pf-btn{display:inline-block;padding:.6rem 1.5rem;background:var(--public-accent);color:white;font-size:.85rem;font-weight:600;transition:background .15s}
 .pf-btn:hover{background:var(--public-accent-strong)}
 </style>

 <div class="pf-page">
 <div class="sf-container">
 <div class="pf-grid">
 <ProfileSidebar activeKey="favorites" favoritesCount={favorites.length} />

 <div>
 <div class="pf-card">
 <h2 class="pf-h2">Favorilerim</h2>
 {favorites.length > 0 ? (
 <div>
 {favorites.map((fav) => (
 <div class="pf-fav">
 <Image
 src={fav.place_images?.[0] || '/images/placeholder.jpg'}
 alt={fav.place_name}
 width={96}
 height={96}
 class="pf-fav-img"
 loading="lazy"
 />
 <div class="pf-fav-body">
 <a href={`/isletme/${fav.place_slug}`} class="pf-place-link">
 {fav.place_name}
 </a>
 <p class="pf-address">
 <Icon name="lucide:map-pin" class="w-3.5 h-3.5" />
 {fav.place_address || 'Şanlıurfa'}
 </p>
 <p class="pf-rating">
 <Icon name="lucide:star" style="width:1rem;height:1rem;fill:currentColor" />
 {fav.place_rating || '-'}
 </p>
 </div>
 <button
 class="pf-del-btn remove-fav-btn"
 data-favorite-id={fav.id}
 title="Favorilerden Kaldır"
 >
 <Icon name="lucide:trash-2" class="w-5 h-5" />
 </button>
 </div>
 ))}
 </div>
 ) : (
 <div class="pf-empty">
 <Icon name="lucide:heart" class="pf-empty-icon" style="width:4rem;height:4rem" />
 <h3 class="pf-empty-title">Henüz favori yok</h3>
 <p class="pf-empty-desc">Beğendiğiniz mekanları favorilere ekleyin.</p>
 <a href="/mekanlar" class="pf-btn">Mekanları Keşfet</a>
 </div>
 )}
 </div>
 </div>
 </div>
 </div>
 </div>

 <script>
 document.addEventListener('click', async (e: Event) => {
 const target = e.target as HTMLElement | null;
 const btn = target?.closest('.remove-fav-btn') as HTMLElement | null;
 if (!btn) return;

 const id = btn.dataset.favoriteId;
 if (!window.showConfirm) return;
 if (!await window.showConfirm('Favorilerden kaldırmak istediğinize emin misiniz?')) return;

 try {
 const response = await fetch(`/api/favorites/${id}`, {
 method: 'DELETE',
 });

 if (response.ok) {
 btn.closest('.pf-fav')?.remove();
 window.location.reload();
 } else {
 window.toast?.error('İşlem başarısız');
 }
 } catch (error) {
 window.toast?.error('Bir hata oluştu');
 }
 });
 </script>
</Layout>
