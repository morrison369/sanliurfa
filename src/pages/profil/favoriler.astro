---
import { Icon } from 'astro-icon/components';
import Layout from '../../layouts/Layout.astro';
import ProfileSidebar from '../../components/profile/ProfileSidebar.astro';
import { query } from '../../lib/postgres';
import { logger } from '../../lib/logging';

const user = Astro.locals.user;

if (!user) {
  return Astro.redirect('/giris?redirect=/profil/favoriler');
}

let favorites: any[] = [];
const seo = {
    title: 'Favorilerim - Sanliurfa.com',
    description: 'Favori mekanlarınızı görüntüleyin.',
    noIndex: true,
  };

try {
  const result = await query(
    `SELECT f.*, p.name as place_name, p.slug as place_slug, p.images as place_images,
            p.rating as place_rating, p.address as place_address
     FROM favorites f
     JOIN places p ON f.place_id = p.id
     WHERE f.user_id = $1
     ORDER BY f.created_at DESC`,
    [user.id]
  );
  favorites = result.rows;
} catch (e) {
  logger.error('Error loading data:', e instanceof Error ? e : new Error(String(e)));
}
---

<Layout seo={seo}>
  <div class="min-h-screen bg-[#FDFAF3] py-8">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-4 gap-8">
        <ProfileSidebar activeKey="favorites" favoritesCount={favorites.length} />

        <main class="lg:col-span-3">
          <div class="bg-white rounded-sm shadow-sm border border-[rgba(200,160,100,0.18)] p-6">
            <h2 class="font-bold text-xl text-[#1A1008] mb-4">Favorilerim</h2>

            {favorites.length > 0 ? (
              <div class="space-y-4">
                {favorites.map((fav) => (
                  <div class="flex gap-4 p-4 bg-[rgba(200,160,100,0.04)] rounded-sm border border-[rgba(200,160,100,0.12)]">
                    <img
                      src={fav.place_images?.[0] || '/images/placeholder.jpg'}
                      alt={fav.place_name}
                      class="w-24 h-24 rounded-sm object-cover flex-shrink-0"
                      onerror="this.setAttribute('src','/images/placeholder.jpg')"
                    />
                    <div class="flex-1 min-w-0">
                      <a href={`/isletme/${fav.place_slug}`} class="font-semibold text-[#1A1008] hover:text-urfa-600">
                        {fav.place_name}
                      </a>
                      <div class="flex items-center gap-1 text-sm text-[#9A8470] mt-1">
                        <Icon name="lucide:map-pin" class="w-3.5 h-3.5" />
                        {fav.place_address || 'Şanlıurfa'}
                      </div>
                      <div class="flex items-center gap-1 text-sm text-yellow-500 mt-2">
                        <Icon name="lucide:star" class="w-4 h-4 fill-current" />
                        <span>{fav.place_rating || '-'}</span>
                      </div>
                    </div>
                    <button
                      class="remove-fav-btn text-isot-500 hover:text-isot-600 self-start p-2"
                      data-favorite-id={fav.id}
                      title="Favorilerden Kaldır"
                    >
                      <Icon name="lucide:trash-2" class="w-5 h-5" />
                    </button>
                  </div>
                ))}
              </div>
            ) : (
              <div class="text-center py-12">
                <Icon name="lucide:heart" class="w-16 h-16 text-[rgba(200,160,100,0.3)] mx-auto mb-4" />
                <h3 class="text-xl font-semibold text-[#1A1008] mb-2">Henüz favori yok</h3>
                <p class="text-[#6B5540] mb-4">Beğendiğiniz mekanları favorilere ekleyin.</p>
                <a href="/mekanlar" class="inline-block px-6 py-3 bg-urfa-600 text-white rounded-sm font-medium hover:bg-urfa-700 transition-colors">
                  Mekanları Keşfet
                </a>
              </div>
            )}
          </div>
        </main>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('click', async (e: Event) => {
      const target = e.target as HTMLElement | null;
      const btn = target?.closest('.remove-fav-btn') as HTMLElement | null;
      if (!btn) return;

      const id = btn.dataset.favoriteId;
      if (!await window.showConfirm('Favorilerden kaldırmak istediğinize emin misiniz?')) return;

      try {
        const response = await fetch(`/api/favorites/${id}`, {
          method: 'DELETE',
        });

        if (response.ok) {
          btn.closest('.flex')?.remove();
          window.location.reload();
        } else {
          window.toast?.error('İşlem başarısız');
        }
      } catch (error) {
        window.toast?.error('Bir hata oluştu');
      }
    });
  </script>
</Layout>
