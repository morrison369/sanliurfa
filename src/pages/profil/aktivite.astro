---
import { Icon } from 'astro-icon/components';
import Layout from '../../layouts/Layout.astro';
import ProfileSidebar from '../../components/profile/ProfileSidebar.astro';
import { query } from '../../lib/postgres';
import { logger } from '../../lib/logging';

const user = Astro.locals.user;

if (!user) {
 return Astro.redirect('/giris?redirect=/profil/aktivite');
}

let activities: any[] = [];
let activityTypeConfig: Record<string, { iconName: string; color: string; label: string; actionText: string }> = {};
const seo = {
 title: 'Aktivite Geçmişim - Sanliurfa.com',
 description: 'Tüm aktivite geçmişinizi görüntüleyin.',
 noIndex: true,
};

function getTimeAgo(date: Date): string {
 const now = new Date();
 const diffMs = now.getTime() - date.getTime();
 const diffMins = Math.floor(diffMs / 60000);
 const diffHours = Math.floor(diffMs / 3600000);
 const diffDays = Math.floor(diffMs / 86400000);
 const diffWeeks = Math.floor(diffDays / 7);

 if (diffMins < 1) return 'Az önce';
 if (diffMins < 60) return `${diffMins} dakika önce`;
 if (diffHours < 24) return `${diffHours} saat önce`;
 if (diffDays < 7) return `${diffDays} gün önce`;
 if (diffWeeks < 4) return `${diffWeeks} hafta önce`;
 return date.toLocaleDateString('tr-TR');
}

try {
 const result = await query(
 `SELECT
    ua.id,
    COALESCE(ua.type, ua.activity_type) AS action_type,
    COALESCE(ua.entity_type, ua.object_type) AS reference_type,
    COALESCE(ua.entity_id::text, ua.object_id::text) AS reference_id,
    ua.metadata,
    ua.created_at,
    p.name AS place_name,
    p.slug AS place_slug
  FROM user_activities ua
  LEFT JOIN places p
    ON COALESCE(ua.entity_type, ua.object_type) = 'place'
   AND p.id::text = COALESCE(ua.entity_id::text, ua.object_id::text)
  WHERE ua.user_id = $1
  ORDER BY ua.created_at DESC
  LIMIT 50`,
 [user.id]
 );
 activities = result.rows;

 activityTypeConfig = {
 review_created: { iconName: 'message-square', color: 'pa-type-copper', label: 'Yorum', actionText: 'yorum yaptı' },
 place_visited: { iconName: 'map-pin', color: 'pa-type-sand', label: 'Ziyaret', actionText: 'ziyaret etti' },
 favorite_added: { iconName: 'heart', color: 'pa-type-isot', label: 'Favori', actionText: 'favorilere ekledi' },
 badge_earned: { iconName: 'award', color: 'pa-type-gold', label: 'Rozet', actionText: 'rozet kazandı' },
 profile_updated: { iconName: 'user', color: 'pa-type-copper', label: 'Profil', actionText: 'profilini güncelledi' },
 place_viewed: { iconName: 'eye', color: 'pa-type-dim', label: 'Görüntüleme', actionText: 'görüntüledi' },
 review_liked: { iconName: 'heart', color: 'pa-type-isot', label: 'Beğeni', actionText: 'yorumunu beğendi' },
 place_shared: { iconName: 'share-2', color: 'pa-type-copper', label: 'Paylaşım', actionText: 'mekanı paylaştı' },
 };
} catch (e) {
 logger.error('Error loading data:', e instanceof Error ? e : new Error(String(e)));
}
---

<Layout seo={seo}>
 <style>
 .pa-page{background:var(--public-bg);min-height:100vh;padding:2rem 0 4rem}
 .pa-grid{display:grid;gap:2rem}
 @media(min-width:64rem){.pa-grid{grid-template-columns:1fr 3fr}}
 .pa-card{background:var(--public-surface);border:1px solid var(--public-border);padding:1.5rem}
 .pa-h2{font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:700;color:var(--public-text);margin-bottom:1.25rem;display:flex;align-items:center;gap:.5rem}
 .pa-timeline{position:relative}
 .pa-timeline-line{position:absolute;left:1.1rem;top:0;bottom:0;width:1px;background:var(--public-border)}
 .pa-items{display:flex;flex-direction:column;gap:1rem}
 .pa-item{position:relative;display:flex;gap:1rem;padding-left:.5rem}
 .pa-icon{position:relative;z-index:1;flex-shrink:0;width:2.5rem;height:2.5rem;border-radius:50%;display:flex;align-items:center;justify-content:center}
 .pa-type-copper{background:var(--public-accent-soft);color:var(--public-accent-strong)}
 .pa-type-sand{background:var(--public-surface-muted);color:var(--public-muted)}
 .pa-type-isot{background:rgba(150,40,40,.15);color:#C07070}
 .pa-type-gold{background:var(--public-accent-soft);color:var(--public-accent)}
 .pa-type-dim{background:var(--public-surface-muted);color:var(--public-text-soft)}
 .pa-body{flex:1;min-width:0;padding-bottom:1rem}
 .pa-meta{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap}
 .pa-badge{font-size:.7rem;padding:.15rem .5rem;border-radius:50px}
 .pa-time{font-size:.78rem;color:var(--public-text-soft)}
 .pa-desc{color:var(--public-text);margin-top:.25rem;font-size:.88rem;line-height:1.6}
 .pa-place-link{font-weight:600;color:var(--public-accent);transition:color .15s}
 .pa-place-link:hover{color:var(--public-accent-strong)}
 .pa-content{color:var(--public-muted);margin-top:.25rem;font-size:.82rem;line-height:1.6;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
 .pa-stars{display:flex;align-items:center;gap:.1rem;margin-top:.25rem}
 .pa-star{width:.9rem;height:.9rem}
 .pa-star-active{color:var(--public-accent);fill:currentColor}
 .pa-star-muted{color:var(--public-border)}
 .pa-empty{text-align:center;padding:3rem 1rem}
 .pa-empty-icon{color:var(--public-border);display:block;margin:0 auto 1rem}
 .pa-empty-title{font-size:1.1rem;font-weight:700;color:var(--public-text);margin-bottom:.5rem}
 .pa-empty-desc{color:var(--public-muted);margin-bottom:1.25rem;font-size:.88rem}
 .pa-btn{display:inline-block;padding:.6rem 1.5rem;background:var(--public-accent);color:white;font-size:.85rem;font-weight:600;transition:background .15s}
 .pa-btn:hover{background:var(--public-accent-strong)}
 </style>

 <div class="pa-page">
 <div class="sf-container">
 <div class="pa-grid">
 <ProfileSidebar activeKey="activity" />

 <div>
 <div class="pa-card">
 <h2 class="pa-h2">
 <Icon name="lucide:activity" class="w-4 h-4" />
 Aktivite Geçmişi
 </h2>

 {activities.length > 0 ? (
 <div class="pa-timeline">
 <div class="pa-timeline-line"></div>
 <div class="pa-items">
 {activities.map((activity) => {
 const typeConfig = activityTypeConfig[activity.action_type] || {
 iconName: 'activity',
 color: 'pa-type-dim',
 label: 'Aktivite',
 actionText: 'aktivite gerçekleştirdi',
 };
 const timeAgo = getTimeAgo(new Date(activity.created_at));
 const metadata = activity.metadata || {};

 return (
 <div class="pa-item">
 <div class={`pa-icon ${typeConfig.color}`}>
 <Icon name={`lucide:${typeConfig.iconName}`} class="w-4 h-4" />
 </div>
 <div class="pa-body">
 <div class="pa-meta">
 <span class={`pa-badge ${typeConfig.color}`}>{typeConfig.label}</span>
 <span class="pa-time">{timeAgo}</span>
 </div>
 <p class="pa-desc">
 {activity.place_name ? (
 <>
 <a href={`/isletme/${activity.place_slug}`} class="pa-place-link">
 {activity.place_name}
 </a>
 {' '}{typeConfig.actionText}
 </>
 ) : (
 metadata.title || 'Bir aktivite gerçekleştirildi'
 )}
 </p>
 {metadata.content && (
 <p class="pa-content">{metadata.content}</p>
 )}
 {metadata.rating && (
 <div class="pa-stars">
 {[...Array(5)].map((_, i) => (
 <Icon
 name="lucide:star"
 class="pa-star"
 class:list={[i < metadata.rating ? 'pa-star-active' : 'pa-star-muted']}
 />
 ))}
 </div>
 )}
 </div>
 </div>
 );
 })}
 </div>
 </div>
 ) : (
 <div class="pa-empty">
 <Icon name="lucide:activity" class="pa-empty-icon" style="width:4rem;height:4rem" />
 <h3 class="pa-empty-title">Henüz aktivite yok</h3>
 <p class="pa-empty-desc">Şehri keşfedin, yorum yapın ve aktivite geçmişiniz dolsun!</p>
 <a href="/mekanlar" class="pa-btn">Mekanları Keşfet</a>
 </div>
 )}
 </div>
 </div>
 </div>
 </div>
 </div>
</Layout>
