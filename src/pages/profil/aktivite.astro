---
import Layout from '../../layouts/Layout.astro';
import { query } from '../../lib/postgres';

const user = Astro.locals.user;

if (!user) {
  return Astro.redirect('/giris?redirect=/profil/aktivite');
}

let activities: any[] = [];
let icons: any = {};
let activityTypeConfig: any = null;
const seo = {
    title: 'Aktivite Geçmişim - Şanlıurfa.com',
    description: 'Tüm aktivite geçmişinizi görüntüleyin.',
  };

try {

  const result = await query(
    `SELECT ua.*, p.name as place_name, p.slug as place_slug
     FROM user_activity ua
     LEFT JOIN places p ON ua.reference_type = 'place' AND ua.reference_id = p.id::text
     WHERE ua.user_id = $1
     ORDER BY ua.created_at DESC
     LIMIT 50`,
    [user.id]
  );
  activities = result.rows;

  // SVG ikonlar
  const icons = {
    user: `<svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
    star: `<svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
    heart: `<svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
    settings: `<svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`,
    activity: `<svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    activityLarge: `<svg class="w-16 h-16 text-gray-300 dark:text-gray-600 mx-auto mb-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    messageSquare: `<svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    mapPin: `<svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
    award: `<svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>`,
    eye: `<svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`,
    share: `<svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>`,
  };

  // Aktivite tipi yapılandırması
  const activityTypeConfig: Record<string, { icon: string; color: string; label: string; actionText: string }> = {
    review_created: {
      icon: icons.messageSquare,
      color: 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-600 dark:text-yellow-400',
      label: 'Yorum',
      actionText: 'yorum yaptı',
    },
    place_visited: {
      icon: icons.mapPin,
      color: 'bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-400',
      label: 'Ziyaret',
      actionText: 'ziyaret etti',
    },
    favorite_added: {
      icon: icons.heart,
      color: 'bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400',
      label: 'Favori',
      actionText: 'favorilere ekledi',
    },
    badge_earned: {
      icon: icons.award,
      color: 'bg-purple-100 dark:bg-purple-900/30 text-purple-600 dark:text-purple-400',
      label: 'Rozet',
      actionText: 'rozet kazandı',
    },
    profile_updated: {
      icon: icons.user,
      color: 'bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400',
      label: 'Profil',
      actionText: 'profilini güncelledi',
    },
    place_viewed: {
      icon: icons.eye,
      color: 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400',
      label: 'Görüntüleme',
      actionText: 'görüntüledi',
    },
    review_liked: {
      icon: icons.heart,
      color: 'bg-pink-100 dark:bg-pink-900/30 text-pink-600 dark:text-pink-400',
      label: 'Beğeni',
      actionText: 'yorumunu beğendi',
    },
    place_shared: {
      icon: icons.share,
      color: 'bg-indigo-100 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400',
      label: 'Paylaşım',
      actionText: 'mekanı paylaştı',
    },
  };

  // Yardımcı fonksiyon: zaman farkını hesapla
  function getTimeAgo(date: Date): string {
    const now = new Date();
    const diffMs = now.getTime() - date.getTime();
    const diffMins = Math.floor(diffMs / 60000);
    const diffHours = Math.floor(diffMs / 3600000);
    const diffDays = Math.floor(diffMs / 86400000);
    const diffWeeks = Math.floor(diffDays / 7);

    if (diffMins < 1) return 'Az önce';
    if (diffMins < 60) return `${diffMins} dakika önce`;
    if (diffHours < 24) return `${diffHours} saat önce`;
    if (diffDays < 7) return `${diffDays} gün önce`;
    if (diffWeeks < 4) return `${diffWeeks} hafta önce`;
    return date.toLocaleDateString('tr-TR');
  }

} catch (e) {
  console.error('Error loading data:', e);
}
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-4 gap-8">
        <aside class="lg:col-span-1">
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
            <nav class="space-y-1">
              <a href="/profil" class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300">
                <span set:html={icons.user}></span>
                Profil
              </a>
              <a href="/profil/yorumlar" class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300">
                <span set:html={icons.star}></span>
                Yorumlarım
              </a>
              <a href="/profil/favoriler" class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300">
                <span set:html={icons.heart}></span>
                Favorilerim
              </a>
              <a href="/profil/bildirimler" class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300">
                <span set:html={icons.activity}></span>
                Bildirimler
              </a>
              <a href="/profil/aktivite" class="flex items-center gap-2 p-2 rounded-lg bg-urfa-50 dark:bg-urfa-900/20 text-urfa-700 dark:text-urfa-300">
                <span set:html={icons.activity}></span>
                Aktivite Geçmişi
              </a>
              <a href="/profil/ayarlar" class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300">
                <span set:html={icons.settings}></span>
                Ayarlar
              </a>
            </nav>
          </div>
        </aside>

        <main class="lg:col-span-3">
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
            <h2 class="font-bold text-xl text-gray-900 dark:text-white mb-6 flex items-center gap-2">
              <span set:html={icons.activity}></span>
              Aktivite Geçmişi
            </h2>

            {activities.length > 0 ? (
              <div class="relative">
                {/* Timeline çizgisi */}
                <div class="absolute left-5 top-0 bottom-0 w-0.5 bg-gray-200 dark:bg-gray-700"></div>

                <div class="space-y-4">
                  {activities.map((activity) => {
                    const typeConfig = activityTypeConfig[activity.action_type] || {
                      icon: icons.activity,
                      color: 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400',
                      label: 'Aktivite',
                      actionText: 'aktivite gerçekleştirdi',
                    };
                    const timeAgo = getTimeAgo(new Date(activity.created_at));
                    const metadata = activity.metadata || {};

                    return (
                      <div class="activity-item relative flex gap-4 pl-2">
                        {/* Timeline noktası */}
                        <div class={`relative z-10 flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center ${typeConfig.color}`}>
                          <span set:html={typeConfig.icon}></span>
                        </div>

                        {/* İçerik */}
                        <div class="flex-1 min-w-0 pb-4">
                          <div class="flex items-start justify-between gap-2">
                            <div class="min-w-0">
                              <div class="flex items-center gap-2 flex-wrap">
                                <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${typeConfig.color}`}>
                                  {typeConfig.label}
                                </span>
                                <span class="text-sm text-gray-500 dark:text-gray-400">{timeAgo}</span>
                              </div>
                              <p class="text-gray-900 dark:text-white mt-1">
                                {activity.place_name ? (
                                  <>
                                    <a href={`/places/${activity.place_slug}`} class="font-medium hover:text-urfa-600 dark:hover:text-urfa-400">
                                      {activity.place_name}
                                    </a>
                                    {' '}{typeConfig.actionText}
                                  </>
                                ) : (
                                  <>
                                    {metadata.title || 'Bir aktivite gerçekleştirildi'}
                                  </>
                                )}
                              </p>
                              {metadata.content && (
                                <p class="text-gray-600 dark:text-gray-400 mt-1 text-sm line-clamp-2">
                                  {metadata.content}
                                </p>
                              )}
                              {metadata.rating && (
                                <div class="flex items-center gap-1 mt-1 text-yellow-500">
                                  {[...Array(5)].map((_, i) => (
                                    <svg class={`w-4 h-4 ${i < metadata.rating ? 'fill-current' : 'text-gray-300 dark:text-gray-600'}`} viewBox="0 0 20 20">
                                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                    </svg>
                                  ))}
                                </div>
                              )}
                            </div>
                          </div>
                        </div>
                      </div>
                    );
                  })}
                </div>
              </div>
            ) : (
              <div class="text-center py-12">
                <span set:html={icons.activityLarge}></span>
                <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">Henüz aktivite yok</h3>
                <p class="text-gray-600 dark:text-gray-400 mb-4">Şehri keşfedin, yorum yapın ve aktivite geçmişiniz dolsun!</p>
                <a href="/places" class="inline-block px-6 py-3 bg-urfa-600 text-white rounded-lg hover:bg-urfa-700 transition-colors">
                  Mekanları Keşfet
                </a>
              </div>
            )}
          </div>
        </main>
      </div>
    </div>
  </div>
</Layout>
