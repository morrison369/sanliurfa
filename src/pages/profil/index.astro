---
import { Icon } from 'astro-icon/components';
import Layout from '../../layouts/Layout.astro';
import { queryOne } from '../../lib/postgres';
import ProfileStats from '../../components/profile/ProfileStats.astro';
import ProfileSidebar from '../../components/profile/ProfileSidebar.astro';
import { logger } from '../../lib/logging';

const user = Astro.locals.user;

if (!user) {
  return Astro.redirect('/giris?redirect=/profil');
}

let profile: any = null;
const seo = {
    title: 'Profilim - Sanliurfa.com',
    description: 'Profil bilgilerinizi yönetin.',
    noIndex: true,
  };

try {
  profile = await queryOne('SELECT * FROM users WHERE id = $1', [user.id]);
  // Stats counts moved to <ProfileStats server:defer> below.
} catch (e) {
  logger.error('Error loading data:', e instanceof Error ? e : new Error(String(e)));
}
---

<Layout seo={seo}>
  <div class="min-h-screen bg-[#FDFAF3] py-8">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-4 gap-8">
        <ProfileSidebar activeKey="profile" showLogout>
          <div slot="header" class="text-center pb-4 border-b border-[rgba(200,160,100,0.2)] mb-4">
            <div class="w-24 h-24 bg-[rgba(200,160,100,0.12)] rounded-full flex items-center justify-center text-urfa-600 text-3xl font-bold mx-auto">
              {profile?.full_name?.charAt(0) || user.email?.charAt(0) || 'U'}
            </div>
            <h1 class="font-bold text-xl text-[#1A1008] mt-4">
              {profile?.full_name || 'Kullanıcı'}
            </h1>
            <p class="text-[#9A8470] text-sm">{user.email}</p>
            <div class="flex items-center justify-center gap-2 mt-2">
              <Icon name="lucide:award" class="w-4 h-4 text-urfa-500" />
              <span class="text-sm text-[#6B5540]">
                {profile?.points || 0} puan
              </span>
            </div>
          </div>
        </ProfileSidebar>

        <!-- Main Content -->
        <main class="lg:col-span-3">
          <div class="bg-white rounded-sm shadow-sm border border-[rgba(200,160,100,0.18)] p-6">
            <h2 class="font-bold text-xl text-[#1A1008] mb-4">Profil Bilgileri</h2>

            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-[#4A3828] mb-1">Ad Soyad</label>
                <p class="text-[#1A1008] mt-1">{profile?.full_name || '-'}</p>
              </div>
              <div>
                <label class="block text-sm font-medium text-[#4A3828] mb-1">E-posta</label>
                <p class="text-[#1A1008] mt-1">{user.email}</p>
              </div>
              <div>
                <label class="block text-sm font-medium text-[#4A3828] mb-1">Kullanıcı Adı</label>
                <p class="text-[#1A1008] mt-1">{profile?.username || '-'}</p>
              </div>
              <div>
                <label class="block text-sm font-medium text-[#4A3828] mb-1">Üyelik Tarihi</label>
                <p class="text-[#1A1008] mt-1">
                  {profile?.created_at ? new Date(profile.created_at).toLocaleDateString('tr-TR') : '-'}
                </p>
              </div>
            </div>

            <div class="mt-6 pt-6 border-t border-[rgba(200,160,100,0.2)]">
              <h3 class="font-medium text-[#1A1008] mb-4">İstatistikler</h3>
              <ProfileStats userId={user.id} initialPoints={profile?.points || 0} server:defer>
                <div slot="fallback" class="grid grid-cols-3 gap-4 animate-pulse">
                  <div class="h-20 bg-[rgba(200,160,100,0.06)] rounded-sm"></div>
                  <div class="h-20 bg-[rgba(200,160,100,0.06)] rounded-sm"></div>
                  <div class="h-20 bg-[rgba(200,160,100,0.06)] rounded-sm"></div>
                </div>
              </ProfileStats>
            </div>
          </div>
        </main>
      </div>
    </div>
  </div>
</Layout>
