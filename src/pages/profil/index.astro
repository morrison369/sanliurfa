---
import { Icon } from 'astro-icon/components';
import Layout from '../../layouts/Layout.astro';
import { queryOne, query } from '../../lib/postgres';
import { getUserClassifiedSummary } from '../../lib/classifieds';
import ProfileStats from '../../components/profile/ProfileStats.astro';
import ProfileSidebar from '../../components/profile/ProfileSidebar.astro';
import { logger } from '../../lib/logging';

const user = Astro.locals.user;

if (!user) {
 return Astro.redirect('/giris?redirect=/profil');
}

let profile: any = null;
let recentReviews: any[] = [];
let matchCount = 0;
let matchProfile: any = null;
let subscriptionSummary: any = null;
let classifiedSummary = {
 total_count: 0,
 active_count: 0,
 pending_count: 0,
 archived_count: 0,
 total_views: 0,
 total_contacts: 0,
};

const seo = {
 title: 'Profilim - Sanliurfa.com',
 description: 'Profil bilgilerinizi yönetin.',
 noIndex: true,
};

try {
 profile = await queryOne('SELECT * FROM users WHERE id = $1', [user.id]);
 const [revRes, matchRes, matchProfileRow, subscriptionRow, classifiedSummaryRow] = await Promise.all([
  query(
   `SELECT r.id, r.rating, r.title, r.created_at, p.name AS place_name, p.slug AS place_slug
    FROM reviews r
    JOIN places p ON p.id = r.place_id
    WHERE r.user_id = $1 AND COALESCE(r.is_hidden, false) = false
    ORDER BY r.created_at DESC LIMIT 5`,
   [user.id]
  ),
  query(
   `SELECT COUNT(*)::int AS c FROM social_matches WHERE user_a_id = $1 OR user_b_id = $1`,
   [user.id]
  ),
  queryOne(
   `SELECT is_discoverable, profile_completeness, cardinality(photos) AS photo_count, updated_at
    FROM user_match_profiles
    WHERE user_id = $1`,
   [user.id]
  ).catch(() => null),
  queryOne(
   `SELECT s.status, s.billing_cycle, s.end_date, st.display_name, st.name
    FROM subscriptions s
    LEFT JOIN subscription_tiers st ON st.id = s.tier_id
    WHERE s.user_id = $1
    ORDER BY (s.status = 'active') DESC, s.created_at DESC
   LIMIT 1`,
   [user.id]
  ).catch(() => null),
  getUserClassifiedSummary(user.id).catch(() => classifiedSummary),
 ]);
 recentReviews = revRes.rows;
 matchCount = Number(matchRes.rows[0]?.c || 0);
 matchProfile = matchProfileRow;
 subscriptionSummary = subscriptionRow;
 classifiedSummary = classifiedSummaryRow;
} catch (e) {
 logger.error('Error loading profile data:', e instanceof Error ? e : new Error(String(e)));
}

const initial = (profile?.full_name || user.email || 'U').charAt(0).toUpperCase();
const privacySettings = profile?.privacy_settings && typeof profile.privacy_settings === 'object'
 ? profile.privacy_settings
 : {};
const profileCompleteness = Number(matchProfile?.profile_completeness || 0);
const matchPhotoCount = Number(matchProfile?.photo_count || 0);
const membershipLabel = subscriptionSummary?.display_name || subscriptionSummary?.name || profile?.subscription_tier || 'Ücretsiz üye';
const membershipStatus = subscriptionSummary?.status === 'active' ? 'Aktif' : subscriptionSummary?.status ? String(subscriptionSummary.status) : 'Standart';
---

<Layout seo={seo}>
 <style>
  .pi-page{background:var(--public-bg);min-height:100vh;padding:2rem 0 4rem}
  .pi-grid{display:grid;gap:1.75rem}
  @media(min-width:64rem){.pi-grid{grid-template-columns:280px 1fr}}

  /* Sidebar header */
  .pi-side-head{text-align:center;padding-bottom:1.25rem;border-bottom:1px solid var(--public-border-soft);margin-bottom:1rem}
  .pi-avatar{width:5.5rem;height:5.5rem;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.85rem;font-weight:700;margin:0 auto;box-shadow:0 6px 18px -4px color-mix(in srgb, var(--public-accent) 35%, transparent);background:linear-gradient(135deg,var(--public-accent) 0%,var(--public-warning) 100%);overflow:hidden}
  .pi-avatar img{width:100%;height:100%;object-fit:cover}
  .pi-username{font-family:'Cormorant Garamond',serif;font-weight:700;font-size:1.2rem;color:var(--public-text);margin:.75rem 0 .15rem;text-align:center;line-height:1.2}
  .pi-email{font-size:.78rem;color:var(--public-muted);text-align:center;margin:0;word-break:break-all}
  .pi-points{display:inline-flex;align-items:center;gap:.4rem;font-size:.85rem;color:var(--public-accent);font-weight:700;margin-top:.6rem;padding:.4rem .85rem;background:var(--public-accent-soft);border:1px solid var(--public-border);border-radius:999px}

  /* Cards */
  .pi-card{background:var(--public-surface);border:1px solid var(--public-border);padding:1.5rem;border-radius:8px;box-shadow:0 2px 6px color-mix(in srgb, var(--public-text) 4%, transparent);margin-bottom:1.25rem}
  .pi-card:last-child{margin-bottom:0}
  .pi-card-h{display:flex;align-items:center;gap:.5rem;font-family:'Cormorant Garamond',serif;font-size:1.35rem;font-weight:700;color:var(--public-text);margin:0 0 .25rem;line-height:1.2}
  .pi-card-h::before{content:'';width:.3rem;height:1.2rem;background:linear-gradient(180deg,var(--public-accent),var(--public-warning));border-radius:2px;align-self:center}
  .pi-card-sub{font-size:.82rem;color:var(--public-muted);margin:0 0 1.25rem;padding-left:.6rem}

  .pi-fields{display:grid;gap:1rem}
  @media(min-width:48rem){.pi-fields{grid-template-columns:repeat(2,1fr)}}
  .pi-field{padding:.85rem;background:var(--public-surface-muted);border-radius:6px;border:1px solid var(--public-border-soft)}
  .pi-label{display:block;font-size:.7rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--public-accent);margin:0 0 .35rem}
  .pi-value{color:var(--public-text);font-size:.95rem;font-weight:500;margin:0;word-break:break-word}

  /* Quick stats */
  .pi-stats-row{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:.75rem;margin:1.25rem 0}
  @media(max-width:52rem){.pi-stats-row{grid-template-columns:repeat(2,minmax(0,1fr))}}
  .pi-stat{padding:1rem;text-align:center;background:linear-gradient(135deg,var(--public-accent-soft),var(--public-surface-muted));border:1px solid var(--public-border);border-radius:8px}
  .pi-stat-num{font-family:'Cormorant Garamond',serif;font-size:1.85rem;font-weight:800;line-height:1;background:linear-gradient(135deg,var(--public-accent),var(--public-warning));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;color:var(--public-accent)}
  .pi-stat-lbl{font-size:.7rem;font-weight:600;color:var(--public-muted);margin-top:.4rem;text-transform:uppercase;letter-spacing:.08em}
  .pi-hub-grid{display:grid;gap:.75rem}
  @media(min-width:48rem){.pi-hub-grid{grid-template-columns:repeat(2,1fr)}}
  .pi-hub{display:flex;flex-direction:column;gap:.65rem;padding:1rem;background:linear-gradient(135deg,var(--public-surface-muted),var(--public-accent-soft));border:1px solid var(--public-border);border-radius:8px}
  .pi-hub-top{display:flex;align-items:center;justify-content:space-between;gap:.75rem}
  .pi-hub-title{font-weight:800;color:var(--public-text);font-size:.95rem;margin:0}
  .pi-hub-kpi{font-family:'Cormorant Garamond',serif;font-weight:800;font-size:1.55rem;color:var(--public-accent);line-height:1}
  .pi-hub-text{font-size:.8rem;color:var(--public-muted);line-height:1.45;margin:0}
  .pi-hub-link{display:inline-flex;align-items:center;gap:.35rem;font-size:.78rem;font-weight:800;color:var(--public-accent);text-decoration:none}
  .pi-hub-link:hover{text-decoration:underline}

  /* Recent reviews */
  .pi-rev-list{display:flex;flex-direction:column;gap:.75rem}
  .pi-rev{display:flex;justify-content:space-between;gap:.75rem;padding:.75rem;background:var(--public-surface-muted);border-radius:6px;border:1px solid var(--public-border-soft);text-decoration:none;transition:all .15s}
  .pi-rev:hover{border-color:var(--public-accent);transform:translateX(2px)}
  .pi-rev-info{flex:1;min-width:0}
  .pi-rev-place{font-size:.92rem;font-weight:700;color:var(--public-text);margin:0 0 .2rem;display:block;text-overflow:ellipsis;overflow:hidden;white-space:nowrap}
  .pi-rev-title{font-size:.78rem;color:var(--public-muted);margin:0;line-height:1.4;display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden}
  .pi-rev-meta{display:flex;flex-direction:column;align-items:flex-end;gap:.2rem;flex-shrink:0}
  .pi-rev-rating{display:inline-flex;color:var(--public-warning);font-size:.85rem;letter-spacing:.5px}
  .pi-rev-date{font-size:.7rem;color:var(--public-muted)}

  .pi-empty{text-align:center;padding:1.5rem;color:var(--public-muted);font-size:.88rem;font-style:italic}

  /* Action buttons */
  .pi-actions{display:flex;flex-wrap:wrap;gap:.6rem;margin-top:1.25rem}
  .pi-btn{display:inline-flex;align-items:center;gap:.4rem;padding:.6rem 1.05rem;font-size:.85rem;font-weight:700;text-decoration:none;border-radius:6px;transition:all .15s}
  .pi-btn-primary{background:linear-gradient(135deg,var(--public-accent),var(--public-warning));color:#fff}
  .pi-btn-primary:hover{transform:translateY(-1px);box-shadow:0 6px 12px -3px color-mix(in srgb, var(--public-accent) 35%, transparent)}
  .pi-btn-outline{background:var(--public-surface);color:var(--public-accent);border:1px solid var(--public-border)}
  .pi-btn-outline:hover{background:var(--public-surface-muted);border-color:var(--public-accent)}

  .pi-skeleton-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}
  .pi-skeleton{height:4.5rem;background:linear-gradient(90deg,var(--public-accent-soft),var(--public-surface-muted),var(--public-accent-soft));border-radius:6px;animation:piSkel 1.6s infinite}
  @keyframes piSkel{0%,100%{opacity:.55}50%{opacity:1}}
 </style>

 <div class="pi-page">
  <div class="sf-container">
   <div class="pi-grid">
    <ProfileSidebar activeKey="profile" showLogout>
     <div slot="header" class="pi-side-head">
      <div class="pi-avatar">
       {profile?.avatar_url ? <img src={profile.avatar_url} alt={profile?.full_name || 'avatar'} loading="eager" /> : initial}
      </div>
      <h1 class="pi-username">{profile?.full_name || 'Kullanıcı'}</h1>
      <p class="pi-email">{user.email}</p>
      <p class="pi-points">
       <Icon name="lucide:award" style="width:.95rem;height:.95rem" />
       {profile?.points || 0} puan
       {(() => {
        const p = profile?.points || 0;
        const tier = p >= 5000 ? 'Platin' : p >= 1500 ? 'Altın' : p >= 500 ? 'Gümüş' : p >= 100 ? 'Bronz' : 'Yeni Üye';
        const tone = tier === 'Platin'
         ? { text: '#9F8EFF', background: '#9F8EFF15', border: '#9F8EFF40' }
         : tier === 'Altın'
          ? { text: '#D49718', background: '#D4971815', border: '#D4971840' }
          : tier === 'Gümüş'
           ? { text: '#9C9C9C', background: '#9C9C9C15', border: '#9C9C9C40' }
           : tier === 'Bronz'
            ? { text: '#C0571F', background: '#C0571F15', border: '#C0571F40' }
            : {
             text: 'var(--public-text-soft)',
             background: 'color-mix(in srgb, var(--public-text-soft) 14%, transparent)',
             border: 'color-mix(in srgb, var(--public-text-soft) 24%, transparent)',
            };
        return <span style={`margin-left:.5rem;padding:.15rem .55rem;background:${tone.background};color:${tone.text};border:1px solid ${tone.border};border-radius:999px;font-size:.72rem;font-weight:700`}>{tier}</span>;
       })()}
      </p>
     </div>
    </ProfileSidebar>

    <div>
     <!-- Quick stats -->
     <div class="pi-card">
      <h2 class="pi-card-h">Genel Bakış</h2>
      <p class="pi-card-sub">Aktivite özetiniz, etkileşimleriniz ve gelişiminiz.</p>
      <div class="pi-stats-row">
       <div class="pi-stat">
        <div class="pi-stat-num">{recentReviews.length}</div>
        <div class="pi-stat-lbl">Son Yorum</div>
       </div>
       <div class="pi-stat">
        <div class="pi-stat-num">{matchCount}</div>
        <div class="pi-stat-lbl">Eşleşme</div>
       </div>
       <div class="pi-stat">
        <div class="pi-stat-num">{profile?.level || 1}</div>
        <div class="pi-stat-lbl">Seviye</div>
       </div>
       <div class="pi-stat">
        <div class="pi-stat-num">{classifiedSummary.active_count}</div>
        <div class="pi-stat-lbl">Aktif İlan</div>
       </div>
      </div>
     </div>

     <!-- Membership and social hub -->
     <div class="pi-card">
      <h2 class="pi-card-h">Üyelik ve Sosyal Merkez</h2>
      <p class="pi-card-sub">Abonelik, eşleşme, mesajlaşma ve görünürlük durumunuz tek ekranda.</p>
      <div class="pi-hub-grid">
       <div class="pi-hub">
        <div class="pi-hub-top">
         <p class="pi-hub-title">Eşleşme Profili</p>
         <span class="pi-hub-kpi">%{profileCompleteness}</span>
        </div>
        <p class="pi-hub-text">{matchProfile?.is_discoverable === false ? 'Keşfedilebilirlik kapalı. Diğer üyeler sizi eşleşme kartlarında göremez.' : `Keşfedilebilirlik açık. ${matchPhotoCount}/4 fotoğraf yüklü.`}</p>
        <a href="/eslesme" class="pi-hub-link"><Icon name="lucide:sparkles" style="width:.85rem;height:.85rem" /> Eşleşmeyi geliştir</a>
       </div>
       <div class="pi-hub">
        <div class="pi-hub-top">
         <p class="pi-hub-title">Mesajlaşma</p>
         <span class="pi-hub-kpi">{matchCount}</span>
        </div>
        <p class="pi-hub-text">Eşleşmelerinizden ve sosyal etkileşimlerden gelen konuşmaları tek gelen kutusunda takip edin.</p>
        <a href="/mesajlar" class="pi-hub-link"><Icon name="lucide:mail" style="width:.85rem;height:.85rem" /> Mesajları aç</a>
       </div>
       <div class="pi-hub">
        <div class="pi-hub-top">
         <p class="pi-hub-title">Üyelik</p>
         <span class="pi-hub-kpi">{membershipStatus}</span>
        </div>
        <p class="pi-hub-text">{membershipLabel} paketi görünüyor. Premium ve işletme avantajları abonelik sayfasından yönetilir.</p>
        <a href="/abonelik" class="pi-hub-link"><Icon name="lucide:badge-check" style="width:.85rem;height:.85rem" /> Aboneliği yönet</a>
       </div>
       <div class="pi-hub">
        <div class="pi-hub-top">
         <p class="pi-hub-title">Gizlilik</p>
         <span class="pi-hub-kpi">{privacySettings?.profile_public === false ? 'Kapalı' : 'Açık'}</span>
        </div>
        <p class="pi-hub-text">Profil görünürlüğü, mesaj alma ve sosyal keşif ayarlarını düzenli kontrol edin.</p>
        <a href="/profil/ayarlar" class="pi-hub-link"><Icon name="lucide:shield" style="width:.85rem;height:.85rem" /> Gizlilik ayarları</a>
       </div>
       <div class="pi-hub">
        <div class="pi-hub-top">
         <p class="pi-hub-title">İlan Merkezi</p>
         <span class="pi-hub-kpi">{classifiedSummary.total_count}</span>
        </div>
        <p class="pi-hub-text">
         {classifiedSummary.pending_count > 0
          ? `${classifiedSummary.pending_count} ilanınız inceleme kuyruğunda. Toplam ${classifiedSummary.total_views} görüntüleme ve ${classifiedSummary.total_contacts} iletişim etkileşimi var.`
          : `Toplam ${classifiedSummary.total_views} görüntüleme ve ${classifiedSummary.total_contacts} iletişim etkileşimiyle ücretsiz ilanlarınızı yönetin.`}
        </p>
        <a href="/profil/ilanlar" class="pi-hub-link"><Icon name="lucide:badge-plus" style="width:.85rem;height:.85rem" /> İlanlarımı yönet</a>
       </div>
      </div>
     </div>

     <!-- Profile info -->
     <div class="pi-card">
      <h2 class="pi-card-h">Profil Bilgileri</h2>
      <p class="pi-card-sub">Hesap detaylarınız.</p>
      <div class="pi-fields">
       <div class="pi-field">
        <span class="pi-label">Ad Soyad</span>
        <p class="pi-value">{profile?.full_name || '—'}</p>
       </div>
       <div class="pi-field">
        <span class="pi-label">E-posta</span>
        <p class="pi-value">{user.email}</p>
       </div>
       <div class="pi-field">
        <span class="pi-label">Kullanıcı Adı</span>
        <p class="pi-value">{profile?.username ? `@${profile.username}` : '—'}</p>
       </div>
       <div class="pi-field">
        <span class="pi-label">Üyelik</span>
        <p class="pi-value">{profile?.created_at ? new Date(profile.created_at).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' }) : '—'}</p>
       </div>
      </div>
      {profile?.bio && (
       <div class="pi-field" style="margin-top:1rem">
        <span class="pi-label">Hakkımda</span>
        <p class="pi-value" style="font-weight:400;line-height:1.6">{profile.bio}</p>
       </div>
      )}
      <div class="pi-actions">
       <a href="/profil/ayarlar" class="pi-btn pi-btn-primary">
        <Icon name="lucide:settings" style="width:.95rem;height:.95rem" />
        Profili Düzenle
       </a>
       <a href="/profil/yorumlar" class="pi-btn pi-btn-outline">
        <Icon name="lucide:message-square" style="width:.95rem;height:.95rem" />
        Tüm Yorumlarım
       </a>
       <a href="/profil/favoriler" class="pi-btn pi-btn-outline">
        <Icon name="lucide:heart" style="width:.95rem;height:.95rem" />
        Favoriler
       </a>
       <a href="/profil/ilanlar" class="pi-btn pi-btn-outline">
        <Icon name="lucide:briefcase-business" style="width:.95rem;height:.95rem" />
        İlanlarım
       </a>
      </div>
     </div>

     <!-- Recent reviews -->
     <div class="pi-card">
      <h2 class="pi-card-h">Son Yorumlarım</h2>
      <p class="pi-card-sub">{recentReviews.length > 0 ? `Son ${recentReviews.length} yorumunuz.` : 'Henüz yorum yazmadınız.'}</p>
      {recentReviews.length === 0 ? (
       <p class="pi-empty">İlk yorumunuzu yazmak için bir mekan ziyaret edin.</p>
      ) : (
       <div class="pi-rev-list">
        {recentReviews.map((rev) => (
         <a href={`/isletme/${rev.place_slug}#yorumlar`} class="pi-rev">
          <div class="pi-rev-info">
           <span class="pi-rev-place">{rev.place_name}</span>
           <p class="pi-rev-title">{rev.title || '(başlıksız yorum)'}</p>
          </div>
          <div class="pi-rev-meta">
           <span class="pi-rev-rating">{'★'.repeat(rev.rating)}{'☆'.repeat(5 - rev.rating)}</span>
           <span class="pi-rev-date">{new Date(rev.created_at).toLocaleDateString('tr-TR', { day: 'numeric', month: 'short' })}</span>
          </div>
         </a>
        ))}
       </div>
      )}
     </div>

     <!-- Detailed stats island (server-rendered with defer) -->
     <div class="pi-card">
      <h2 class="pi-card-h">Detaylı İstatistikler</h2>
      <p class="pi-card-sub">Puanlar, rozetler ve aktivite geçmişi.</p>
      <ProfileStats userId={user.id} initialPoints={profile?.points || 0} server:defer>
       <div slot="fallback" class="pi-skeleton-grid">
        <div class="pi-skeleton"></div>
        <div class="pi-skeleton"></div>
        <div class="pi-skeleton"></div>
       </div>
      </ProfileStats>
     </div>
    </div>
   </div>
  </div>
 </div>
</Layout>
