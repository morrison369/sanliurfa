---
import { Icon } from 'astro-icon/components';
import Layout from '../../layouts/Layout.astro';
import ProfileSidebar from '../../components/profile/ProfileSidebar.astro';
import { query } from '../../lib/postgres';
import { logger } from '../../lib/logging';

const user = Astro.locals.user;

if (!user) {
 return Astro.redirect('/giris?redirect=/profil/yorumlar');
}

let reviews: any[] = [];
const seo = {
 title: 'Yorumlarım - Sanliurfa.com',
 description: 'Yaptığınız yorumları görüntüleyin.',
 noIndex: true,
};

try {
 const result = await query(
 `SELECT r.*, p.name as place_name, p.slug as place_slug
 FROM reviews r
 JOIN places p ON r.place_id = p.id
 WHERE r.user_id = $1
 ORDER BY r.created_at DESC`,
 [user.id]
 );
 reviews = result.rows;
} catch (e) {
 logger.error('Error loading data:', e instanceof Error ? e : new Error(String(e)));
}
---

<Layout seo={seo}>
 <style>
 .py-page{background:var(--public-bg);min-height:100vh;padding:2rem 0 4rem}
 .py-grid{display:grid;gap:2rem}
 @media(min-width:64rem){.py-grid{grid-template-columns:1fr 3fr}}
 .py-card{background:var(--public-surface);border:1px solid var(--public-border);padding:1.5rem}
 .py-h2{font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:700;color:var(--public-text);margin-bottom:1rem}
 .py-review{padding:1rem;background:var(--public-accent-soft);border:1px solid var(--public-border-soft)}
 .py-review+.py-review{margin-top:.75rem}
 .py-review-top{display:flex;align-items:flex-start;justify-content:space-between;gap:1rem}
 .py-place-link{font-weight:600;color:var(--public-text);transition:color .15s}
 .py-place-link:hover{color:var(--public-accent-strong)}
 .py-stars{display:flex;align-items:center;gap:.1rem;margin-top:.25rem}
 .py-star{width:1rem;height:1rem}
 .py-star-active{color:var(--public-accent);fill:currentColor}
 .py-star-muted{color:var(--public-border)}
 .py-date{font-size:.8rem;color:var(--public-text-soft);flex-shrink:0}
 .py-review-title{font-weight:600;color:var(--public-text);margin-top:.5rem;font-size:.88rem}
 .py-review-content{color:var(--public-muted);margin-top:.25rem;font-size:.85rem;line-height:1.65}
 .py-badge{display:inline-block;font-size:.72rem;padding:.2rem .6rem;margin-top:.5rem}
 .py-badge-approved{background:var(--public-accent-soft);color:var(--public-accent-strong)}
 .py-badge-pending{background:var(--public-surface-muted);color:var(--public-muted)}
 .py-empty{text-align:center;padding:3rem 1rem}
 .py-empty-icon{color:var(--public-border);display:block;margin:0 auto 1rem}
 .py-empty-title{font-size:1.1rem;font-weight:700;color:var(--public-text);margin-bottom:.5rem}
 .py-empty-desc{color:var(--public-muted);margin-bottom:1.25rem;font-size:.88rem}
 .py-btn{display:inline-block;padding:.6rem 1.5rem;background:var(--public-accent);color:white;font-size:.85rem;font-weight:600;transition:background .15s}
 .py-btn:hover{background:var(--public-accent-strong)}
 </style>

 <div class="py-page">
 <div class="sf-container">
 <div class="py-grid">
 <ProfileSidebar activeKey="reviews" reviewCount={reviews.length} />

 <div>
 <div class="py-card">
 <h2 class="py-h2">Yorumlarım</h2>
 {reviews.length > 0 ? (
 <div>
 {reviews.map((review) => (
 <div class="py-review">
 <div class="py-review-top">
 <div>
 <a href={`/isletme/${review.place_slug}`} class="py-place-link">
 {review.place_name}
 </a>
 <div class="py-stars">
 {[...Array(5)].map((_, i) => (
 <Icon
 name="lucide:star"
 class="py-star"
 class:list={[i < review.rating ? 'py-star-active' : 'py-star-muted']}
 />
 ))}
 </div>
 </div>
 <span class="py-date">
 {new Date(review.created_at).toLocaleDateString('tr-TR')}
 </span>
 </div>
 {review.title && <h4 class="py-review-title">{review.title}</h4>}
 <p class="py-review-content">{review.content}</p>
 <span class={review.is_approved ? 'py-badge py-badge-approved' : 'py-badge py-badge-pending'}>
 {review.is_approved ? 'Onaylandı' : 'Onay Bekliyor'}
 </span>
 </div>
 ))}
 </div>
 ) : (
 <div class="py-empty">
 <Icon name="lucide:message-square" class="py-empty-icon" style="width:4rem;height:4rem" />
 <h3 class="py-empty-title">Henüz yorum yok</h3>
 <p class="py-empty-desc">Ziyaret ettiğiniz mekanlar hakkında yorum yapın.</p>
 <a href="/mekanlar" class="py-btn">Mekanları Keşfet</a>
 </div>
 )}
 </div>
 </div>
 </div>
 </div>
 </div>
</Layout>
