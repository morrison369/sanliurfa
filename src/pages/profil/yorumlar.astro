---
import { Icon } from 'astro-icon/components';
import Layout from '../../layouts/Layout.astro';
import ProfileSidebar from '../../components/profile/ProfileSidebar.astro';
import { query } from '../../lib/postgres';
import { logger } from '../../lib/logging';

const user = Astro.locals.user;

if (!user) {
  return Astro.redirect('/giris?redirect=/profil/yorumlar');
}

let reviews: any[] = [];
const seo = {
    title: 'Yorumlarım - Sanliurfa.com',
    description: 'Yaptığınız yorumları görüntüleyin.',
    noIndex: true,
  };

try {
  const result = await query(
    `SELECT r.*, p.name as place_name, p.slug as place_slug
     FROM reviews r
     JOIN places p ON r.place_id = p.id
     WHERE r.user_id = $1
     ORDER BY r.created_at DESC`,
    [user.id]
  );
  reviews = result.rows;
} catch (e) {
  logger.error('Error loading data:', e instanceof Error ? e : new Error(String(e)));
}
---

<Layout seo={seo}>
  <div class="min-h-screen bg-[#FDFAF3] py-8">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-4 gap-8">
        <ProfileSidebar activeKey="reviews" reviewCount={reviews.length} />

        <main class="lg:col-span-3">
          <div class="bg-white rounded-sm shadow-sm border border-[rgba(200,160,100,0.18)] p-6">
            <h2 class="font-bold text-xl text-[#1A1008] mb-4">Yorumlarım</h2>

            {reviews.length > 0 ? (
              <div class="space-y-4">
                {reviews.map((review) => (
                  <div class="p-4 bg-[rgba(200,160,100,0.04)] rounded-sm border border-[rgba(200,160,100,0.12)]">
                    <div class="flex items-start justify-between">
                      <div>
                        <a href={`/isletme/${review.place_slug}`} class="font-semibold text-[#1A1008] hover:text-urfa-600">
                          {review.place_name}
                        </a>
                        <div class="flex items-center gap-0.5 mt-1">
                          {[...Array(5)].map((_, i) => (
                            <Icon name="lucide:star" class={i < review.rating ? 'w-4 h-4 fill-current text-yellow-400' : 'w-4 h-4 text-[rgba(200,160,100,0.25)]'} />
                          ))}
                        </div>
                      </div>
                      <span class="text-sm text-[#9A8470]">
                        {new Date(review.created_at).toLocaleDateString('tr-TR')}
                      </span>
                    </div>
                    {review.title && (
                      <h4 class="font-medium text-[#1A1008] mt-2">{review.title}</h4>
                    )}
                    <p class="text-[#6B5540] mt-1">{review.content}</p>
                    <div class="flex items-center gap-2 mt-2">
                      <span class={`text-xs px-2 py-1 rounded-sm ${review.is_approved ? 'bg-[rgba(200,160,100,0.15)] text-[#5A4020]' : 'bg-urfa-50 text-urfa-700'}`}>
                        {review.is_approved ? 'Onaylandı' : 'Onay Bekliyor'}
                      </span>
                    </div>
                  </div>
                ))}
              </div>
            ) : (
              <div class="text-center py-12">
                <Icon name="lucide:message-square" class="w-16 h-16 text-[rgba(200,160,100,0.3)] mx-auto mb-4" />
                <h3 class="text-xl font-semibold text-[#1A1008] mb-2">Henüz yorum yok</h3>
                <p class="text-[#6B5540] mb-4">Ziyaret ettiğiniz mekanlar hakkında yorum yapın.</p>
                <a href="/mekanlar" class="inline-block px-6 py-3 bg-urfa-600 text-white rounded-sm font-medium hover:bg-urfa-700 transition-colors">
                  Mekanları Keşfet
                </a>
              </div>
            )}
          </div>
        </main>
      </div>
    </div>
  </div>
</Layout>
