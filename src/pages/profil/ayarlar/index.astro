---
import { actions, isInputError } from 'astro:actions';
import { Icon } from 'astro-icon/components';
import Layout from '../../../layouts/Layout.astro';
import ProfileSidebar from '../../../components/profile/ProfileSidebar.astro';
import { queryOne } from '../../../lib/postgres';
import { logger } from '../../../lib/logging';

const user = Astro.locals.user;
if (!user) {
 return Astro.redirect('/giris?redirect=/profil/ayarlar');
}

let profile: any = null;
let errorMessage: string | null = null;
let successMessage: string | null = null;
let errorMessages: Record<string, string> = {};
let successMessages: Record<string, string> = {};
const profileResult = Astro.getActionResult(actions.updateProfileSettings);
const passwordResult = Astro.getActionResult(actions.changeAccountPassword);
const profileInputErrors = isInputError(profileResult?.error) ? profileResult.error.fields : {};
const passwordInputErrors = isInputError(passwordResult?.error) ? passwordResult.error.fields : {};
const profileSubmitError =
 !isInputError(profileResult?.error) && profileResult?.error?.message
 ? profileResult.error.message
 : null;
const passwordSubmitError =
 !isInputError(passwordResult?.error) && passwordResult?.error?.message
 ? passwordResult.error.message
 : null;
const seo = {
 title: 'Ayarlar - Sanliurfa.com',
 description: 'Hesap ayarlarınızı yönetin',
 noIndex: true,
};

try {
 profile = await queryOne('SELECT * FROM users WHERE id = $1', [user.id]);
 errorMessage = Astro.url.searchParams.get('error');
 successMessage = Astro.url.searchParams.get('success');
 errorMessages = {
 'update_failed': 'Profil güncellenirken bir hata oluştu.',
 'missing_fields': 'Lütfen zorunlu alanları doldurun.',
 'password_mismatch': 'Yeni şifreler eşleşmiyor.',
 'password_too_short': 'Yeni şifre en az 6 karakter olmalıdır.',
 'wrong_password': 'Mevcut şifre yanlış.',
 };
 successMessages = {
 'profile_updated': 'Profil bilgileriniz başarıyla güncellendi.',
 'password_changed': 'Şifreniz başarıyla değiştirildi.',
 };
} catch (e) {
 logger.error('Error loading data:', e instanceof Error ? e : new Error(String(e)));
}
---

<Layout seo={seo}>
 <style>
 .pas-page{background:var(--public-bg);min-height:100vh;padding:2rem 0}
 .pas-grid{display:grid;gap:2rem}
 @media(min-width:64rem){.pas-grid{grid-template-columns:1fr 3fr}}
 .pas-card{background:var(--public-surface);border:1px solid var(--public-border);padding:1.5rem;margin-bottom:1.5rem}
 .pas-card:last-child{margin-bottom:0}
 .pas-header{display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem}
 .pas-back{font-size:.82rem;color:var(--public-muted);text-decoration:none;transition:color .15s}
 .pas-back:hover{color:var(--public-accent)}
 .pas-h1{font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:700;color:var(--public-text)}
 .pas-h2{font-size:1rem;font-weight:700;color:var(--public-text);margin-bottom:1rem;display:flex;align-items:center;gap:.5rem}
 .pas-h2 svg{color:var(--public-muted)}
 .pas-alert-error{background:rgba(220,38,38,.1);border:1px solid rgba(220,38,38,.2);color:#F87171;padding:.75rem 1rem;margin-bottom:1.25rem;font-size:.85rem}
 .pas-alert-success{background:rgba(34,197,94,.1);border:1px solid rgba(34,197,94,.2);color:#4ADE80;padding:.75rem 1rem;margin-bottom:1.25rem;font-size:.85rem}
 .pas-field-error{margin-top:.4rem;font-size:.78rem;color:#F87171}
 .pas-form-grid{display:grid;gap:1rem}
 @media(min-width:48rem){.pas-form-grid{grid-template-columns:repeat(2,1fr)}}
 .pas-form-group{display:flex;flex-direction:column;gap:.5rem;margin-bottom:1rem}
 .pas-label{font-size:.82rem;font-weight:600;color:var(--public-accent)}
 .pas-input{width:100%;padding:.6rem .9rem;background:var(--public-accent-soft);border:1px solid var(--public-border);color:var(--public-text);font-size:.9rem;transition:border-color .15s}
 .pas-input:focus{outline:none;border-color:var(--public-accent)}
 .pas-input::placeholder{color:var(--public-text-soft)}
 .pas-input:disabled{color:var(--public-text-soft);cursor:not-allowed}
 .pas-textarea{width:100%;padding:.6rem .9rem;background:var(--public-accent-soft);border:1px solid var(--public-border);color:var(--public-text);font-size:.9rem;resize:none;transition:border-color .15s}
 .pas-textarea:focus{outline:none;border-color:var(--public-accent)}
 .pas-form-footer{display:flex;justify-content:flex-end;margin-top:1rem}
 .pas-btn{display:inline-flex;align-items:center;gap:.5rem;padding:.6rem 1.25rem;background:var(--public-accent);color:white;font-weight:700;font-size:.85rem;border:none;cursor:pointer;transition:background .15s}
 .pas-btn:hover{background:var(--public-accent-strong)}
 .pas-space{display:flex;flex-direction:column;gap:1.5rem}
 </style>

 <div class="pas-page">
 <div class="sf-container">
 <div class="pas-grid">
 <ProfileSidebar activeKey="settings" />

 <div>
 <div class="pas-card">
 <div class="pas-header">
 <a href="/profil" class="pas-back">← Profil</a>
 <h1 class="pas-h1">Hesap Ayarları</h1>
 </div>

 {errorMessage && (
 <div class="pas-alert-error">{errorMessages[errorMessage] || 'Bir hata oluştu.'}</div>
 )}
 {successMessage && (
 <div class="pas-alert-success">{successMessages[successMessage] || 'İşlem başarılı.'}</div>
 )}
 {profileResult?.data?.success && (
 <div class="pas-alert-success">{profileResult.data.message}</div>
 )}
 {passwordResult?.data?.success && (
 <div class="pas-alert-success">{passwordResult.data.message}</div>
 )}
 </div>

 <div class="pas-space">
 <div class="pas-card">
 <h2 class="pas-h2">
 <Icon name="lucide:user" class="w-5 h-5" />
 Profil Bilgileri
 </h2>

 {profileSubmitError && (
 <div class="pas-alert-error">{profileSubmitError}</div>
 )}

 <form action={actions.updateProfileSettings} method="POST">
 <div class="pas-form-grid">
 <div class="pas-form-group">
 <label for="full_name" class="pas-label">Ad Soyad</label>
 <input type="text" id="full_name" name="full_name" value={profile?.full_name || ''} class="pas-input" />
 {profileInputErrors.full_name && (
 <p class="pas-field-error">{profileInputErrors.full_name.join(', ')}</p>
 )}
 </div>
 <div class="pas-form-group">
 <label for="username" class="pas-label">Kullanıcı Adı</label>
 <input type="text" id="username" name="username" value={profile?.username || ''} class="pas-input" />
 {profileInputErrors.username && (
 <p class="pas-field-error">{profileInputErrors.username.join(', ')}</p>
 )}
 </div>
 </div>

 <div class="pas-form-group">
 <label for="email" class="pas-label">E-posta</label>
 <input type="email" id="email" name="email" value={user.email} disabled class="pas-input" />
 </div>

 <div class="pas-form-group">
 <label for="bio" class="pas-label">Hakkımda</label>
 <textarea id="bio" name="bio" rows="3" class="pas-textarea">{profile?.bio || ''}</textarea>
 {profileInputErrors.bio && (
 <p class="pas-field-error">{profileInputErrors.bio.join(', ')}</p>
 )}
 </div>

 <div class="pas-form-footer">
 <button type="submit" class="pas-btn">
 <Icon name="lucide:save" class="w-4 h-4" />
 Kaydet
 </button>
 </div>
 </form>
 </div>

 <div class="pas-card">
 <h2 class="pas-h2">
 <Icon name="lucide:lock" class="w-5 h-5" />
 Şifre Değiştir
 </h2>

 {passwordSubmitError && (
 <div class="pas-alert-error">{passwordSubmitError}</div>
 )}

 <form action={actions.changeAccountPassword} method="POST">
 <div class="pas-form-group">
 <label for="current_password" class="pas-label">Mevcut Şifre</label>
 <input type="password" id="current_password" name="current_password" autocomplete="current-password" required class="pas-input" />
 {passwordInputErrors.current_password && (
 <p class="pas-field-error">{passwordInputErrors.current_password.join(', ')}</p>
 )}
 </div>

 <div class="pas-form-group">
 <label for="new_password" class="pas-label">Yeni Şifre</label>
 <input type="password" id="new_password" name="new_password" autocomplete="new-password" required minlength="6" class="pas-input" />
 {passwordInputErrors.new_password && (
 <p class="pas-field-error">{passwordInputErrors.new_password.join(', ')}</p>
 )}
 </div>

 <div class="pas-form-group">
 <label for="confirm_password" class="pas-label">Yeni Şifre (Tekrar)</label>
 <input type="password" id="confirm_password" name="confirm_password" autocomplete="new-password" required class="pas-input" />
 {passwordInputErrors.confirm_password && (
 <p class="pas-field-error">{passwordInputErrors.confirm_password.join(', ')}</p>
 )}
 </div>

 <div class="pas-form-footer">
 <button type="submit" class="pas-btn">
 <Icon name="lucide:shield" class="w-4 h-4" />
 Şifreyi Güncelle
 </button>
 </div>
 </form>
 </div>
 </div>
 </div>
 </div>
 </div>
 </div>
</Layout>
