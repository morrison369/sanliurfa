---
import { actions, isInputError } from 'astro:actions';
import Layout from '../../../layouts/Layout.astro';
import { queryOne } from '../../../lib/postgres';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/giris?redirect=/profil/ayarlar');
}

let profile: any = null;
let errorMessage: string | null = null;
let successMessage: string | null = null;
let errorMessages: Record<string, string> = {};
let successMessages: Record<string, string> = {};
let icons: Record<string, string> = {};
const profileResult = Astro.getActionResult(actions.updateProfileSettings);
const passwordResult = Astro.getActionResult(actions.changeAccountPassword);
const profileInputErrors = isInputError(profileResult?.error) ? profileResult.error.fields : {};
const passwordInputErrors = isInputError(passwordResult?.error) ? passwordResult.error.fields : {};
const profileSubmitError =
  !isInputError(profileResult?.error) && profileResult?.error?.message
    ? profileResult.error.message
    : null;
const passwordSubmitError =
  !isInputError(passwordResult?.error) && passwordResult?.error?.message
    ? passwordResult.error.message
    : null;
const seo = {
    title: 'Ayarlar - Sanliurfa.com',
    description: 'Hesap ayarlarınızı yönetin',
    noIndex: true
  };

try {

  profile = await queryOne('SELECT * FROM users WHERE id = $1', [user.id]);

  errorMessage = Astro.url.searchParams.get('error');
  successMessage = Astro.url.searchParams.get('success');

  errorMessages = {
    'update_failed': 'Profil güncellenirken bir hata oluştu.',
    'missing_fields': 'Lütfen zorunlu alanları doldurun.',
    'password_mismatch': 'Yeni şifreler eşleşmiyor.',
    'password_too_short': 'Yeni şifre en az 6 karakter olmalıdır.',
    'wrong_password': 'Mevcut şifre yanlış.',
  };

  successMessages = {
    'profile_updated': 'Profil bilgileriniz başarıyla güncellendi.',
    'password_changed': 'Şifreniz başarıyla değiştirildi.',
  };

  // SVG ikonlar
  icons = {
    user: `<svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
    lock: `<svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`,
    save: `<svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>`,
    shield: `<svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    star: `<svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
    heart: `<svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
    activity: `<svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
  };

} catch (e) {
  console.error('Error loading data:', e);
}
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-4 gap-8">
        <aside class="lg:col-span-1">
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
            <nav class="space-y-1">
              <a href="/profil" class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300">
                <span set:html={icons.user}></span>
                Profil
              </a>
              <a href="/profil/yorumlar" class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300">
                <span set:html={icons.star}></span>
                Yorumlarım
              </a>
              <a href="/profil/favoriler" class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300">
                <span set:html={icons.heart}></span>
                Favorilerim
              </a>
              <a href="/profil/bildirimler" class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300">
                <span set:html={icons.activity}></span>
                Bildirimler
              </a>
              <a href="/profil/aktivite" class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300">
                <span set:html={icons.activity}></span>
                Aktivite
              </a>
              <a href="/profil/ayarlar" class="flex items-center gap-2 p-2 rounded-lg bg-urfa-50 dark:bg-urfa-900/20 text-urfa-700 dark:text-urfa-300">
                <span set:html={icons.user}></span>
                Ayarlar
              </a>
            </nav>
          </div>
        </aside>

        <main class="lg:col-span-3">
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
            <div class="flex items-center gap-4 mb-6">
              <a href="/profil" class="text-gray-600 dark:text-gray-400 hover:text-urfa-600 dark:hover:text-urfa-400">← Profil</a>
              <h1 class="text-2xl font-display font-bold text-gray-900 dark:text-white">Hesap Ayarları</h1>
            </div>

      {errorMessage && (
        <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-400 px-4 py-3 rounded-lg mb-6">
          {errorMessages[errorMessage] || 'Bir hata oluştu.'}
        </div>
      )}

      {successMessage && (
        <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 text-green-700 dark:text-green-400 px-4 py-3 rounded-lg mb-6">
          {successMessages[successMessage] || 'İşlem başarılı.'}
        </div>
      )}

      {profileResult?.data?.success && (
        <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 text-green-700 dark:text-green-400 px-4 py-3 rounded-lg mb-6">
          {profileResult.data.message}
        </div>
      )}

      {passwordResult?.data?.success && (
        <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 text-green-700 dark:text-green-400 px-4 py-3 rounded-lg mb-6">
          {passwordResult.data.message}
        </div>
      )}

      <div class="space-y-6">
        <!-- Profil Bilgileri -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
            <span set:html={icons.user}></span>
            Profil Bilgileri
          </h2>

          {profileSubmitError && (
            <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-400 px-4 py-3 rounded-lg mb-4">
              {profileSubmitError}
            </div>
          )}

          <form action={actions.updateProfileSettings} method="POST" class="space-y-4">
            <div class="grid md:grid-cols-2 gap-4">
              <div>
                <label for="full_name" class="label">Ad Soyad</label>
                <input type="text" id="full_name" name="full_name" value={profile?.full_name || ''} class="input dark:bg-gray-700 dark:border-gray-600 dark:text-white" />
                {profileInputErrors.full_name && (
                  <p class="mt-2 text-sm text-red-600 dark:text-red-400">{profileInputErrors.full_name.join(', ')}</p>
                )}
              </div>
              <div>
                <label for="username" class="label">Kullanıcı Adı</label>
                <input type="text" id="username" name="username" value={profile?.username || ''} class="input dark:bg-gray-700 dark:border-gray-600 dark:text-white" />
                {profileInputErrors.username && (
                  <p class="mt-2 text-sm text-red-600 dark:text-red-400">{profileInputErrors.username.join(', ')}</p>
                )}
              </div>
            </div>

            <div>
              <label for="email" class="label">E-posta</label>
              <input type="email" id="email" name="email" value={user.email} disabled class="input bg-gray-100 dark:bg-gray-700 dark:border-gray-600 dark:text-gray-400 cursor-not-allowed" />
            </div>

            <div>
              <label for="bio" class="label">Hakkımda</label>
              <textarea id="bio" name="bio" rows="3" class="input dark:bg-gray-700 dark:border-gray-600 dark:text-white resize-none">{profile?.bio || ''}</textarea>
              {profileInputErrors.bio && (
                <p class="mt-2 text-sm text-red-600 dark:text-red-400">{profileInputErrors.bio.join(', ')}</p>
              )}
            </div>

            <div class="flex justify-end">
              <button type="submit" class="btn-primary flex items-center gap-2">
                <span set:html={icons.save}></span>
                Kaydet
              </button>
            </div>
          </form>
        </div>

        <!-- Şifre Değiştir -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
            <span set:html={icons.lock}></span>
            Şifre Değiştir
          </h2>

          {passwordSubmitError && (
            <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-400 px-4 py-3 rounded-lg mb-4">
              {passwordSubmitError}
            </div>
          )}

          <form action={actions.changeAccountPassword} method="POST" class="space-y-4">
            <div>
              <label for="current_password" class="label">Mevcut Şifre</label>
              <input type="password" id="current_password" name="current_password" required class="input dark:bg-gray-700 dark:border-gray-600 dark:text-white" />
              {passwordInputErrors.current_password && (
                <p class="mt-2 text-sm text-red-600 dark:text-red-400">{passwordInputErrors.current_password.join(', ')}</p>
              )}
            </div>

            <div>
              <label for="new_password" class="label">Yeni Şifre</label>
              <input type="password" id="new_password" name="new_password" required minlength="6" class="input dark:bg-gray-700 dark:border-gray-600 dark:text-white" />
              {passwordInputErrors.new_password && (
                <p class="mt-2 text-sm text-red-600 dark:text-red-400">{passwordInputErrors.new_password.join(', ')}</p>
              )}
            </div>

            <div>
              <label for="confirm_password" class="label">Yeni Şifre (Tekrar)</label>
              <input type="password" id="confirm_password" name="confirm_password" required class="input dark:bg-gray-700 dark:border-gray-600 dark:text-white" />
              {passwordInputErrors.confirm_password && (
                <p class="mt-2 text-sm text-red-600 dark:text-red-400">{passwordInputErrors.confirm_password.join(', ')}</p>
              )}
            </div>

            <div class="flex justify-end">
              <button type="submit" class="btn-primary flex items-center gap-2">
                <span set:html={icons.shield}></span>
                Şifreyi Güncelle
              </button>
            </div>
          </form>
        </div>
      </div>
    </main>
    </div>
  </div>
</Layout>
