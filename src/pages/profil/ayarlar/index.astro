---
import { actions, isInputError } from 'astro:actions';
import { Icon } from 'astro-icon/components';
import Layout from '../../../layouts/Layout.astro';
import ProfileSidebar from '../../../components/profile/ProfileSidebar.astro';
import { queryOne } from '../../../lib/postgres';
import { logger } from '../../../lib/logging';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/giris?redirect=/profil/ayarlar');
}

let profile: any = null;
let errorMessage: string | null = null;
let successMessage: string | null = null;
let errorMessages: Record<string, string> = {};
let successMessages: Record<string, string> = {};
const profileResult = Astro.getActionResult(actions.updateProfileSettings);
const passwordResult = Astro.getActionResult(actions.changeAccountPassword);
const profileInputErrors = isInputError(profileResult?.error) ? profileResult.error.fields : {};
const passwordInputErrors = isInputError(passwordResult?.error) ? passwordResult.error.fields : {};
const profileSubmitError =
  !isInputError(profileResult?.error) && profileResult?.error?.message
    ? profileResult.error.message
    : null;
const passwordSubmitError =
  !isInputError(passwordResult?.error) && passwordResult?.error?.message
    ? passwordResult.error.message
    : null;
const seo = {
    title: 'Ayarlar - Sanliurfa.com',
    description: 'Hesap ayarlarınızı yönetin',
    noIndex: true
  };

try {

  profile = await queryOne('SELECT * FROM users WHERE id = $1', [user.id]);

  errorMessage = Astro.url.searchParams.get('error');
  successMessage = Astro.url.searchParams.get('success');

  errorMessages = {
    'update_failed': 'Profil güncellenirken bir hata oluştu.',
    'missing_fields': 'Lütfen zorunlu alanları doldurun.',
    'password_mismatch': 'Yeni şifreler eşleşmiyor.',
    'password_too_short': 'Yeni şifre en az 6 karakter olmalıdır.',
    'wrong_password': 'Mevcut şifre yanlış.',
  };

  successMessages = {
    'profile_updated': 'Profil bilgileriniz başarıyla güncellendi.',
    'password_changed': 'Şifreniz başarıyla değiştirildi.',
  };
} catch (e) {
  logger.error('Error loading data:', e instanceof Error ? e : new Error(String(e)));
}
---

<Layout seo={seo}>
  <div class="min-h-screen bg-[#FDFAF3] py-8">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-4 gap-8">
        <ProfileSidebar activeKey="settings" />

        <main class="lg:col-span-3">
          <div class="bg-white rounded-sm shadow-sm border border-[rgba(200,160,100,0.18)] p-6">
            <div class="flex items-center gap-4 mb-6">
              <a href="/profil" class="text-[#9A8470] hover:text-urfa-600">← Profil</a>
              <h1 class="text-2xl font-display font-bold text-[#1A1008]">Hesap Ayarları</h1>
            </div>

      {errorMessage && (
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-sm mb-6">
          {errorMessages[errorMessage] || 'Bir hata oluştu.'}
        </div>
      )}

      {successMessage && (
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-sm mb-6">
          {successMessages[successMessage] || 'İşlem başarılı.'}
        </div>
      )}

      {profileResult?.data?.success && (
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-sm mb-6">
          {profileResult.data.message}
        </div>
      )}

      {passwordResult?.data?.success && (
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-sm mb-6">
          {passwordResult.data.message}
        </div>
      )}

      <div class="space-y-6">
        <div class="bg-white rounded-sm shadow-sm border border-[rgba(200,160,100,0.18)] p-6">
          <h2 class="text-lg font-semibold text-[#1A1008] mb-4 flex items-center gap-2">
            <Icon name="lucide:user" class="w-5 h-5" />
            Profil Bilgileri
          </h2>

          {profileSubmitError && (
            <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-sm mb-4">
              {profileSubmitError}
            </div>
          )}

          <form action={actions.updateProfileSettings} method="POST" class="space-y-4">
            <div class="grid md:grid-cols-2 gap-4">
              <div>
                <label for="full_name" class="label">Ad Soyad</label>
                <input type="text" id="full_name" name="full_name" value={profile?.full_name || ''} class="input" />
                {profileInputErrors.full_name && (
                  <p class="mt-2 text-sm text-red-600">{profileInputErrors.full_name.join(', ')}</p>
                )}
              </div>
              <div>
                <label for="username" class="label">Kullanıcı Adı</label>
                <input type="text" id="username" name="username" value={profile?.username || ''} class="input" />
                {profileInputErrors.username && (
                  <p class="mt-2 text-sm text-red-600">{profileInputErrors.username.join(', ')}</p>
                )}
              </div>
            </div>

            <div>
              <label for="email" class="label">E-posta</label>
              <input type="email" id="email" name="email" value={user.email} disabled class="input bg-[rgba(200,160,100,0.04)] text-[#9A8470] cursor-not-allowed" />
            </div>

            <div>
              <label for="bio" class="label">Hakkımda</label>
              <textarea id="bio" name="bio" rows="3" class="input resize-none">{profile?.bio || ''}</textarea>
              {profileInputErrors.bio && (
                <p class="mt-2 text-sm text-red-600">{profileInputErrors.bio.join(', ')}</p>
              )}
            </div>

            <div class="flex justify-end">
              <button type="submit" class="btn-primary flex items-center gap-2">
                <Icon name="lucide:save" class="w-4 h-4" />
                Kaydet
              </button>
            </div>
          </form>
        </div>

        <div class="bg-white rounded-sm shadow-sm border border-[rgba(200,160,100,0.18)] p-6">
          <h2 class="text-lg font-semibold text-[#1A1008] mb-4 flex items-center gap-2">
            <Icon name="lucide:lock" class="w-5 h-5" />
            Şifre Değiştir
          </h2>

          {passwordSubmitError && (
            <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-sm mb-4">
              {passwordSubmitError}
            </div>
          )}

          <form action={actions.changeAccountPassword} method="POST" class="space-y-4">
            <div>
              <label for="current_password" class="label">Mevcut Şifre</label>
              <input type="password" id="current_password" name="current_password" autocomplete="current-password" required class="input" />
              {passwordInputErrors.current_password && (
                <p class="mt-2 text-sm text-red-600">{passwordInputErrors.current_password.join(', ')}</p>
              )}
            </div>

            <div>
              <label for="new_password" class="label">Yeni Şifre</label>
              <input type="password" id="new_password" name="new_password" autocomplete="new-password" required minlength="6" class="input" />
              {passwordInputErrors.new_password && (
                <p class="mt-2 text-sm text-red-600">{passwordInputErrors.new_password.join(', ')}</p>
              )}
            </div>

            <div>
              <label for="confirm_password" class="label">Yeni Şifre (Tekrar)</label>
              <input type="password" id="confirm_password" name="confirm_password" autocomplete="new-password" required class="input" />
              {passwordInputErrors.confirm_password && (
                <p class="mt-2 text-sm text-red-600">{passwordInputErrors.confirm_password.join(', ')}</p>
              )}
            </div>

            <div class="flex justify-end">
              <button type="submit" class="btn-primary flex items-center gap-2">
                <Icon name="lucide:shield" class="w-4 h-4" />
                Şifreyi Güncelle
              </button>
            </div>
          </form>
        </div>
      </div>
    </main>
    </div>
  </div>
</Layout>
