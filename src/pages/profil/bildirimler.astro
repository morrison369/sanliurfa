---
import { Icon } from 'astro-icon/components';
import Layout from '../../layouts/Layout.astro';
import ProfileSidebar from '../../components/profile/ProfileSidebar.astro';
import { query } from '../../lib/postgres';
import { logger } from '../../lib/logging';

const user = Astro.locals.user;

if (!user) {
 return Astro.redirect('/giris?redirect=/profil/bildirimler');
}

let notifications: any[] = [];
let unreadCount: any = null;
let notificationTypeConfig: Record<string, { iconName: string; color: string; label: string }> = {};
const seo = {
 title: 'Bildirimlerim - Sanliurfa.com',
 description: 'Bildirimlerinizi görüntüleyin ve yönetin.',
 noIndex: true,
};

function getTimeAgo(date: Date): string {
 const now = new Date();
 const diffMs = now.getTime() - date.getTime();
 const diffMins = Math.floor(diffMs / 60000);
 const diffHours = Math.floor(diffMs / 3600000);
 const diffDays = Math.floor(diffMs / 86400000);

 if (diffMins < 1) return 'Az önce';
 if (diffMins < 60) return `${diffMins} dakika önce`;
 if (diffHours < 24) return `${diffHours} saat önce`;
 if (diffDays < 7) return `${diffDays} gün önce`;
 return date.toLocaleDateString('tr-TR');
}

try {
 const [result, unreadResult] = await Promise.all([
 query(
 `SELECT * FROM notifications
 WHERE user_id = $1
 ORDER BY created_at DESC
 LIMIT 100`,
 [user.id]
 ),
 query(
 `SELECT COUNT(*) FROM notifications WHERE user_id = $1 AND read = false`,
 [user.id]
 ),
 ]);
 notifications = result.rows;
 unreadCount = parseInt(unreadResult.rows[0]?.count || '0');

 notificationTypeConfig = {
 review: { iconName: 'star', color: 'pb-type-copper', label: 'Yorum' },
 comment: { iconName: 'star', color: 'pb-type-copper', label: 'Yorum' },
 like: { iconName: 'heart', color: 'pb-type-isot', label: 'Beğeni' },
 follow: { iconName: 'user', color: 'pb-type-sand', label: 'Takip' },
 badge: { iconName: 'bell', color: 'pb-type-gold', label: 'Rozet' },
 system: { iconName: 'bell', color: 'pb-type-dim', label: 'Sistem' },
 booking: { iconName: 'bell', color: 'pb-type-copper', label: 'Rezervasyon' },
 promotion: { iconName: 'bell', color: 'pb-type-isot', label: 'Kampanya' },
 };
} catch (e) {
 logger.error('Error loading data:', e instanceof Error ? e : new Error(String(e)));
}
---

<Layout seo={seo}>
 <style>
 .pb-page{background:var(--public-bg);min-height:100vh;padding:2rem 0 4rem}
 .pb-grid{display:grid;gap:2rem}
 @media(min-width:64rem){.pb-grid{grid-template-columns:1fr 3fr}}
 .pb-card{background:var(--public-surface);border:1px solid var(--public-border);padding:1.5rem}
 .pb-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;gap:1rem;flex-wrap:wrap}
 .pb-h2{font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:700;color:var(--public-text);display:flex;align-items:center;gap:.5rem}
 .pb-actions{display:flex;align-items:center;gap:.75rem}
 .pb-mark-all{font-size:.8rem;padding:.35rem .85rem;border:1px solid var(--public-border);color:var(--public-muted);background:none;cursor:pointer;transition:border-color .15s,color .15s;display:flex;align-items:center;gap:.35rem}
 .pb-mark-all:hover{border-color:var(--public-accent);color:var(--public-accent)}
 .pb-clear-btn{font-size:.8rem;color:var(--public-muted);background:none;border:none;cursor:pointer;display:flex;align-items:center;gap:.35rem;transition:color .15s}
 .pb-clear-btn:hover{color:var(--public-accent-strong)}
 .pb-list{display:flex;flex-direction:column;gap:.5rem}
 .pb-notification-item{display:flex;align-items:flex-start;gap:1rem;padding:1rem;cursor:pointer;transition:background .15s;background:var(--public-accent-soft)}
 .pb-notification-item--unread{background:var(--public-surface-muted);border:1px solid var(--public-accent)}
 .pb-icon-wrap{padding:.4rem;flex-shrink:0;border-radius:.125rem}
 .pb-type-copper{background:var(--public-accent-soft);color:var(--public-accent-strong)}
 .pb-type-isot{background:rgba(150,40,40,.15);color:#C07070}
 .pb-type-sand{background:var(--public-surface-muted);color:var(--public-muted)}
 .pb-type-gold{background:var(--public-accent-soft);color:var(--public-accent)}
 .pb-type-dim{background:var(--public-surface-muted);color:var(--public-text-soft)}
 .pb-notif-body{flex:1;min-width:0}
 .pb-notif-top{display:flex;align-items:flex-start;justify-content:space-between;gap:.75rem}
 .pb-notif-link{font-weight:600;color:var(--public-text);transition:color .15s}
 .pb-notif-link:hover{color:var(--public-accent-strong)}
 .pb-notif-title{font-weight:600;color:var(--public-text)}
 .pb-notif-msg{font-size:.82rem;color:var(--public-muted);margin-top:.2rem;line-height:1.55}
 .pb-notif-time{font-size:.72rem;color:var(--public-text-soft);display:inline-block;margin-top:.25rem}
 .pb-notif-right{display:flex;align-items:center;gap:.5rem;flex-shrink:0}
 .pb-unread-dot{width:.5rem;height:.5rem;background:var(--public-accent);border-radius:50%;flex-shrink:0}
 .pb-del-btn{padding:.25rem;color:var(--public-text-soft);background:none;border:none;cursor:pointer;transition:color .15s}
 .pb-del-btn:hover{color:var(--public-accent-strong)}
 .pb-empty{text-align:center;padding:3rem 1rem}
 .pb-empty-icon{color:var(--public-border);display:block;margin:0 auto 1rem}
 .pb-empty-title{font-size:1.1rem;font-weight:700;color:var(--public-text);margin-bottom:.4rem}
 .pb-empty-desc{color:var(--public-muted);font-size:.88rem}
 </style>

 <div class="pb-page">
 <div class="sf-container">
 <div class="pb-grid">
 <ProfileSidebar activeKey="notifications" unreadCount={unreadCount} />

 <div>
 <div class="pb-card">
 <div class="pb-header">
 <h2 class="pb-h2">
 <Icon name="lucide:bell" class="w-4 h-4" />
 Bildirimler
 </h2>
 <div class="pb-actions">
 {unreadCount > 0 && (
 <button id="mark-all-read" class="pb-mark-all">
 <Icon name="lucide:check-check" class="w-4 h-4" />
 Tümünü Oku
 </button>
 )}
 <button id="clear-notifications" class="pb-clear-btn">
 <Icon name="lucide:trash-2" class="w-4 h-4" />
 Temizle
 </button>
 </div>
 </div>

 {notifications.length > 0 ? (
 <div class="pb-list">
 {notifications.map((notification) => {
 const typeConfig = notificationTypeConfig[notification.type] || notificationTypeConfig.system;
 const isUnread = !notification.read;
 const timeAgo = getTimeAgo(new Date(notification.created_at));

 return (
 <div
 class:list={['pb-notification-item', { 'pb-notification-item--unread': isUnread }]}
 data-notification-id={notification.id}
 >
 <div class={`pb-icon-wrap ${typeConfig.color}`}>
 <Icon name={`lucide:${typeConfig.iconName}`} class="w-4 h-4" />
 </div>
 <div class="pb-notif-body">
 <div class="pb-notif-top">
 <div>
 {notification.link ? (
 <a href={notification.link} class="pb-notif-link">{notification.title}</a>
 ) : (
 <span class="pb-notif-title">{notification.title}</span>
 )}
 <p class="pb-notif-msg">{notification.message}</p>
 <span class="pb-notif-time">{timeAgo}</span>
 </div>
 <div class="pb-notif-right">
 {isUnread && <span class="pb-unread-dot"></span>}
 <button
 class="pb-del-btn delete-notification"
 data-notification-id={notification.id}
 title="Bildirimi Sil"
 >
 <Icon name="lucide:trash-2" class="w-4 h-4" />
 </button>
 </div>
 </div>
 </div>
 </div>
 );
 })}
 </div>
 ) : (
 <div class="pb-empty">
 <Icon name="lucide:bell" class="pb-empty-icon" style="width:4rem;height:4rem" />
 <h3 class="pb-empty-title">Bildirim yok</h3>
 <p class="pb-empty-desc">Yeni bildirimleriniz burada görünecek.</p>
 </div>
 )}
 </div>
 </div>
 </div>
 </div>
 </div>

 <script>
 document.addEventListener('click', async (e: Event) => {
 const target = e.target as HTMLElement;
 const item = target.closest('.pb-notification-item') as HTMLElement | null;
 if (item && !target.closest('.pb-del-btn')) {
 const id = item.dataset.notificationId;
 if (id) {
 await markAsRead(id);
 const link = item.querySelector('a');
 if (link) {
 window.location.href = link.href;
 }
 }
 }
 });

 document.addEventListener('click', async (e: Event) => {
 const target = e.target as HTMLElement;
 const btn = target.closest('.pb-del-btn') as HTMLElement | null;
 if (!btn) return;

 e.stopPropagation();
 const id = btn.dataset.notificationId;
 await deleteNotification(id!);
 btn.closest('.pb-notification-item')?.remove();
 });

 document.addEventListener('click', async (e: Event) => {
 const target = e.target as HTMLElement;
 const btn = target.closest('#mark-all-read');
 if (!btn) return;

 try {
 await fetch('/api/notifications/mark-all-read', { method: 'POST' });
 window.location.reload();
 } catch (error) {
 console.error('Tümünü oku hatası:', error);
 }
 });

 document.addEventListener('click', async (e: Event) => {
 const target = e.target as HTMLElement;
 const btn = target.closest('#clear-notifications');
 if (!btn) return;

 if (!window.showConfirm) return;
 if (!await window.showConfirm('Tüm bildirimleriniz silinecek. Emin misiniz?')) return;

 try {
 await fetch('/api/notifications/clear', { method: 'DELETE' });
 window.location.reload();
 } catch (error) {
 console.error('Temizleme hatası:', error);
 }
 });

 async function markAsRead(id: string) {
 try {
 await fetch(`/api/notifications/${id}/read`, { method: 'POST' });
 } catch (error) {
 console.error('Okundu işaretleme hatası:', error);
 }
 }

 async function deleteNotification(id: string) {
 try {
 await fetch(`/api/notifications/${id}`, { method: 'DELETE' });
 } catch (error) {
 console.error('Silme hatası:', error);
 }
 }
 </script>
</Layout>
