---
import Layout from '../../layouts/Layout.astro';
import AdSenseSlot from '../../components/ads/AdSenseSlot.astro';
import { getPublicAppUrl } from '../../lib/public-app-url';
import {
  getClassifiedBySlug,
  getClassifiedTrustBenchmark,
  incrementClassifiedView,
  listDistrictClassifieds,
  listPriceBandClassifieds,
  listRelatedClassifieds,
} from '../../lib/classifieds';

const user = Astro.locals.user;
const slug = Astro.params.slug || '';
const listing = await getClassifiedBySlug(slug, user?.id);

if (!listing) {
  return Astro.redirect('/ilanlar');
}

if (listing.status === 'active') {
  await incrementClassifiedView(listing.id);
}
const relatedListings = await listRelatedClassifieds(listing, 6).catch(() => []);
const districtListings = await listDistrictClassifieds(listing, 6).catch(() => []);
const priceBandListings = await listPriceBandClassifieds(listing, 6).catch(() => []);
const trustBenchmark = await getClassifiedTrustBenchmark(listing.category_slug).catch(() => ({
  avg_score: 0,
  listing_count: 0,
  strong_count: 0,
}));

const formatter = new Intl.NumberFormat('tr-TR', { style: 'currency', currency: 'TRY', maximumFractionDigits: 0 });
const baseUrl = getPublicAppUrl();
const canonical = `/ilanlar/${listing.slug}`;
const seo = {
  title: `${listing.title} | Şanlıurfa Ücretsiz İlan`,
  description: listing.description.slice(0, 155),
  canonical,
};
const checklistChecks = [
  { ok: Boolean(listing.images?.length), label: 'Görsel mevcut' },
  { ok: Boolean(listing.phone), label: 'Telefon alanı var' },
  { ok: Boolean(listing.address || listing.neighborhood), label: 'Konum detayı girilmiş' },
];
const checklistHitCount = checklistChecks.filter((item) => item.ok).length;
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Ana Sayfa', item: `${baseUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'İlanlar', item: `${baseUrl}/ilanlar` },
    { '@type': 'ListItem', position: 3, name: listing.category_name, item: `${baseUrl}/ilanlar/kategori/${listing.category_slug}` },
    { '@type': 'ListItem', position: 4, name: listing.title, item: `${baseUrl}${canonical}` },
  ],
};
const listingSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: listing.title,
  description: listing.description,
  category: listing.parent_category_name ? `${listing.parent_category_name} / ${listing.category_name}` : listing.category_name,
  image: listing.images?.length ? listing.images.map((image) => `${baseUrl}${image}`) : undefined,
  itemCondition: 'https://schema.org/UsedCondition',
  brand: {
    '@type': 'Brand',
    name: 'Sanliurfa.com Ücretsiz İlanlar',
  },
  seller: {
    '@type': 'Person',
    name: listing.owner_name || 'Sanliurfa.com üyesi',
  },
  offers: {
    '@type': 'Offer',
    url: `${baseUrl}${canonical}`,
    priceCurrency: listing.currency || 'TRY',
    ...(listing.price ? { price: Number(listing.price) } : {}),
    availability: listing.status === 'active' ? 'https://schema.org/InStock' : 'https://schema.org/PreOrder',
    areaServed: {
      '@type': 'City',
      name: `${listing.district}, Şanlıurfa`,
    },
  },
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Kalite checklist tamamlanma', value: `${checklistHitCount}/3` },
    ...checklistChecks.map((item) => ({
      '@type': 'PropertyValue',
      name: item.label,
      value: item.ok ? 'Tamam' : 'Eksik',
    })),
  ],
};
const faqItems = (() => {
  const root = (listing.parent_category_name || listing.category_name || '').toLocaleLowerCase('tr-TR');
  const base = [
    {
      question: 'Bu ilan sadece Şanlıurfa için mi yayınlanır?',
      answer: 'Evet. Ücretsiz ilan sistemi yalnızca Şanlıurfa ve ilçeleri için açıktır. Farklı şehir veya ülke kaydı kabul edilmez.',
    },
    {
      question: 'İlan yayınlandıktan sonra hemen görünür mü?',
      answer: 'Hayır. Üye ilanları önce moderasyon kuyruğuna düşer. Onay sonrası ilan liste ve kategori sayfalarında yayına alınır.',
    },
    {
      question: 'Güven skoru neye göre oluşur?',
      answer: 'Güven skoru; görsel varlığı, telefon bilgisi, adres detayı, üye profili sinyali ve etkileşim izleri birlikte değerlendirilerek hesaplanır.',
    },
  ];
  if (root.includes('emlak') || root.includes('konut') || root.includes('arsa') || root.includes('iş yeri')) {
    return [
      ...base,
      {
        question: 'Emlak ilanında hangi bilgiler net olmalı?',
        answer: 'Metrekare, mahalle, tapu niteliği, aidat ve teslim durumu gibi temel alanlar eksik bırakılmamalıdır.',
      },
    ];
  }
  if (root.includes('vasıta') || root.includes('otomobil') || root.includes('motosiklet') || root.includes('arazi')) {
    return [
      ...base,
      {
        question: 'Vasıta ilanında en kritik açıklama alanları nelerdir?',
        answer: 'Model yılı, kilometre, yakıt tipi, hasar/değişen bilgisi ve teslim ilçesi açıklama içinde tutarlı olmalıdır.',
      },
    ];
  }
  return [
    ...base,
    {
      question: 'İletişim bilgileri kimlere gösterilir?',
      answer: 'Telefon ve ilan sahibi iletişim alanı yalnızca giriş yapan kullanıcılara gösterilir. Bu yapı spam aramalarını azaltmak için kullanılır.',
    },
  ];
})();
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
const categoryGuide = (() => {
  const root = (listing.parent_category_name || listing.category_name || '').toLocaleLowerCase('tr-TR');
  if (root.includes('emlak') || root.includes('konut') || root.includes('arsa') || root.includes('iş yeri')) {
    return {
      title: 'Emlak ilanında hızlı kontrol listesi',
      items: [
        'Mahalle, metrekare ve tapu niteliği açıklamada net yazılmalı.',
        'Konum tarifi ile ilçe eşleşmesi aynı olmalı; yanlış ilçe güven kaybı yaratır.',
        'Fiyat ve aidat gibi temel kalemler eksik bırakılmamalı.',
      ],
    };
  }
  if (root.includes('vasıta') || root.includes('otomobil') || root.includes('motosiklet') || root.includes('arazi')) {
    return {
      title: 'Vasıta ilanında hızlı kontrol listesi',
      items: [
        'Model yılı, kilometre ve yakıt tipi başlık ile açıklamada tutarlı olmalı.',
        'Hasar, değişen ve eksper notu saklanmadan yazılmalı.',
        'İlçe bilgisi ile araç teslim noktası aynı bölgede görünmeli.',
      ],
    };
  }
  return {
    title: 'İkinci el ilanda hızlı kontrol listesi',
    items: [
      'Ürünün durumu, kullanım izi ve teslim şekli açık biçimde belirtilmeli.',
      'Net görseller ve gerçek fiyat aralığı dönüşümü artırır.',
      'Kategori ile başlık uyumu güçlü değilse ilan moderasyonda bekleyebilir.',
    ],
  };
})();
const trustSignals = [
  listing.images?.length ? `${listing.images.length} görsel yüklü` : 'Görsel az veya yok',
  listing.phone ? 'Telefon bilgisi mevcut' : 'Telefon bilgisi eksik',
  listing.address ? 'Adres detayı girilmiş' : 'Adres detayı sınırlı',
  listing.owner_name ? 'Üye profili tanımlı' : 'Üye adı sınırlı',
];
const trustScore = [
  listing.images?.length ? 25 : 0,
  listing.phone ? 25 : 0,
  listing.address ? 20 : 0,
  listing.owner_name ? 15 : 0,
  Number(listing.contact_count || 0) > 0 ? 15 : 0,
].reduce((sum, item) => sum + item, 0);
const similarListingCount = relatedListings.length + districtListings.length + priceBandListings.length;
const trustBandLabel = trustScore >= 80 ? 'Güçlü' : trustScore >= 50 ? 'Orta' : 'Geliştirilmeli';
const trustBandTone = trustScore >= 80 ? 'strong' : trustScore >= 50 ? 'medium' : 'weak';
const trustDelta = trustScore - Number(trustBenchmark.avg_score || 0);
const trustDeltaLabel =
  trustBenchmark.listing_count > 0
    ? trustDelta >= 8
      ? 'kategori ortalamasının üstünde'
      : trustDelta <= -8
        ? 'kategori ortalamasının altında'
        : 'kategori ortalamasına yakın'
    : 'kategori verisi oluşuyor';
const trustComparison =
  trustBenchmark.listing_count > 0
    ? `Bu kategori içinde yaklaşık ${trustBenchmark.avg_score}/100 ortalama görülüyor; bu ilan ${trustDeltaLabel}.`
    : trustScore >= 80
      ? 'Bu ilan Şanlıurfa ücretsiz ilanlarında beklenen temel kalite eşiğinin üstünde görünüyor.'
      : trustScore >= 50
        ? 'Bu ilan temel alanların çoğunu karşılıyor; birkaç alan iyileştirilirse daha güvenli görünür.'
        : 'Bu ilan kalite eşiğinin altında. Görsel, iletişim ve açıklama tarafı güçlendirilirse daha iyi performans verir.';
const trustSummary =
  trustScore >= 80
    ? 'İlan temel güven alanlarında güçlü görünüyor.'
    : trustScore >= 50
      ? 'İlan orta seviyede güven sinyali taşıyor; açıklama ve iletişim alanları kontrol edilmeli.'
      : 'İlanın görsel, iletişim veya adres alanlarında geliştirme ihtiyacı var.';
const qualityBadgeText =
  trustScore >= 80
    ? 'Yüksek kaliteli ilan'
    : trustScore >= 50
      ? 'Orta kaliteli ilan'
      : 'Geliştirilmesi gereken ilan';
const checklistSuggestion =
  checklistHitCount === checklistChecks.length
    ? 'Temel kalite checklist alanları tamam. Başlık ve açıklama tutarlılığı korunduğu sürece ilan güçlü görünür.'
    : !listing.images?.length
      ? 'İlk iyileştirme adımı olarak net bir kapak görseli eklemek dönüşümü yükseltir.'
      : !listing.phone
        ? 'İletişim alanını telefonla tamamlamak güven sinyalini ve yanıt oranını artırır.'
        : 'Konum detayını biraz daha netleştirerek bu ilanı daha güvenli gösterebilirsiniz.';
---

<Layout seo={seo}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} is:inline />
    <script type="application/ld+json" set:html={JSON.stringify(listingSchema)} is:inline />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} is:inline />
  </Fragment>
  <main class="listing-detail">
    <nav class="crumbs" aria-label="Sayfa yolu">
      <a href="/ilanlar">İlanlar</a>
      <span>/</span>
      <a href={`/ilanlar/kategori/${listing.category_slug}`}>{listing.category_name}</a>
    </nav>

    <section class="detail-grid">
      <div class="gallery">
        {listing.images?.length ? (
          <>
            <img class="cover" src={listing.images[0]} alt={listing.title} />
            {listing.images.length > 1 && (
              <div class="thumbs">
                {listing.images.slice(1, 5).map((image) => <img src={image} alt={`${listing.title} görseli`} loading="lazy" />)}
              </div>
            )}
          </>
        ) : (
          <div class="empty-image">Görsel eklenmemiş</div>
        )}
      </div>

      <aside class="summary">
        <p class="badge">{listing.city} / {listing.district}</p>
        <p class:list={['quality-badge', `quality-badge--${trustBandTone}`]}>{qualityBadgeText}</p>
        <h1>{listing.title}</h1>
        <strong class="price">{listing.price ? formatter.format(Number(listing.price)) : 'Fiyat belirtilmedi'}</strong>
        <div class="trust-score-box">
          <strong>{trustScore}/100 güven skoru</strong>
          <span>{similarListingCount} benzer ilan bağlantısı mevcut</span>
          <small>{trustSummary}</small>
          <div class="trust-band" data-tone={trustBandTone} aria-label={`Güven bandı ${trustBandLabel}`}>
            <div class="trust-band-track">
              <div class="trust-band-fill" style={`width:${trustScore}%`}></div>
            </div>
            <div class="trust-band-labels" aria-hidden="true">
              <span>0</span>
              <span>50</span>
              <span>80</span>
              <span>100</span>
            </div>
            <p>{trustBandLabel} seviye. {trustComparison}</p>
            {trustBenchmark.listing_count > 0 && (
              <div class="trust-benchmark">
                <strong>Kategori ortalaması: {trustBenchmark.avg_score}/100</strong>
                <span>{trustBenchmark.listing_count} aktif ilan içinde {trustBenchmark.strong_count} tanesi güçlü bandda.</span>
              </div>
            )}
          </div>
        </div>
        <dl>
          <div><dt>Kategori</dt><dd>{listing.parent_category_name ? `${listing.parent_category_name} / ` : ''}{listing.category_name}</dd></div>
          <div><dt>Durum</dt><dd>{listing.condition}</dd></div>
          {listing.neighborhood && <div><dt>Mahalle</dt><dd>{listing.neighborhood}</dd></div>}
          {listing.address && <div><dt>Adres</dt><dd>{listing.address}</dd></div>}
          <div><dt>Yayın durumu</dt><dd>{listing.status === 'active' ? 'Yayında' : 'Onay bekliyor'}</dd></div>
        </dl>
        {user ? (
          <div class="contact-box">
            <span>İletişim</span>
            {listing.phone ? <a href={`tel:${listing.phone}`} data-contact-track data-listing-id={listing.id}>{listing.phone}</a> : <strong>Telefon eklenmemiş</strong>}
            <small>İlan sahibi: {listing.owner_name || 'Sanliurfa.com üyesi'}</small>
            <small>{listing.contact_count || 0} iletişim görüntüleme</small>
          </div>
        ) : (
          <a class="login-cta" href={`/giris?redirect=/ilanlar/${listing.slug}`}>İletişim bilgilerini görmek için giriş yap</a>
        )}
      </aside>
    </section>

    <section class="description-card">
      <h2>İlan açıklaması</h2>
      <p>{listing.description}</p>
    </section>

    <AdSenseSlot placement="classified-detail" label="Sponsorlu Reklam" minHeight={180} />

    <section class="faq-card" aria-labelledby="ilan-rehberi-baslik">
      <div class="related-head">
        <div>
          <p>İlan kullanımı ve moderasyon</p>
          <h2 id="ilan-rehberi-baslik">Şanlıurfa ücretsiz ilan rehberi</h2>
        </div>
      </div>
      <div class="faq-intro">
        <p>
          Bu ilan sayfası Şanlıurfa içi yerel alım satım akışına göre hazırlanır. Kategori, ilçe ve
          iletişim görünürlüğü moderasyon ve kullanıcı güvenliği kurallarıyla birlikte çalışır.
        </p>
      </div>
      <div class="faq-list">
        {faqItems.map((item) => (
          <article class="faq-item">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="guide-card" aria-labelledby="kategori-rehberi-baslik">
      <div class="related-head">
        <div>
          <p>Kategori bazlı kalite notu</p>
          <h2 id="kategori-rehberi-baslik">{categoryGuide.title}</h2>
        </div>
      </div>
      <div class="guide-grid">
        {categoryGuide.items.map((item) => (
          <article class="guide-item">
            <strong>Kontrol</strong>
            <p>{item}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="trust-card" aria-labelledby="ilan-guven-baslik">
      <div class="related-head">
        <div>
          <p>Satıcı ve ilan güven sinyalleri</p>
          <h2 id="ilan-guven-baslik">Bu ilanda öne çıkan güven işaretleri</h2>
        </div>
      </div>
      <div class="checklist-badge">
        <strong>{checklistHitCount}/{checklistChecks.length} kalite checklist alanı tamam</strong>
        <div>
          {checklistChecks.map((item) => (
            <span class:list={['checklist-chip', item.ok ? 'checklist-chip--ok' : 'checklist-chip--warn']}>{item.label}</span>
          ))}
        </div>
        <p>{checklistSuggestion}</p>
        <small>Bu checklist sonucu schema içinde ek özellik olarak da işlenir ve ilan kalite sinyalini destekler.</small>
      </div>
      <div class="trust-grid">
        {trustSignals.map((item) => (
          <article class="trust-item">
            <strong>Sinyal</strong>
            <p>{item}</p>
          </article>
        ))}
      </div>
    </section>

    {priceBandListings.length > 0 && (
      <section class="related-card">
        <div class="related-head">
          <div>
            <p>Benzer fiyat aralığı</p>
            <h2>Bu bütçeye yakın diğer ilanlar</h2>
          </div>
          <a href={`/ilanlar?ilce=${encodeURIComponent(listing.district)}`}>İlçedeki tüm ilanlar</a>
        </div>
        <div class="related-grid">
          {priceBandListings.map((item) => (
            <article class="related-item">
              <a href={`/ilanlar/${item.slug}`} class="related-media" aria-label={`${item.title} detay`}>
                {item.images?.[0] ? <img src={item.images[0]} alt={item.title} loading="lazy" /> : <span>İlan</span>}
              </a>
              <div class="related-body">
                <span>{item.category_name}</span>
                <h3><a href={`/ilanlar/${item.slug}`}>{item.title}</a></h3>
                <strong>{item.price ? formatter.format(Number(item.price)) : 'Fiyat belirtilmedi'}</strong>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    {relatedListings.length > 0 && (
      <section class="related-card">
        <div class="related-head">
          <div>
            <p>Aynı kategori ve ilçe çevresi</p>
            <h2>Benzer ücretsiz ilanlar</h2>
          </div>
          <a href={`/ilanlar/kategori/${listing.category_slug}`}>Kategoriye dön</a>
        </div>
        <div class="related-grid">
          {relatedListings.map((item) => (
            <article class="related-item">
              <a href={`/ilanlar/${item.slug}`} class="related-media" aria-label={`${item.title} detay`}>
                {item.images?.[0] ? <img src={item.images[0]} alt={item.title} loading="lazy" /> : <span>İlan</span>}
              </a>
              <div class="related-body">
                <span>{item.district}</span>
                <h3><a href={`/ilanlar/${item.slug}`}>{item.title}</a></h3>
                <strong>{item.price ? formatter.format(Number(item.price)) : 'Fiyat belirtilmedi'}</strong>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    {districtListings.length > 0 && (
      <section class="related-card">
        <div class="related-head">
          <div>
            <p>Aynı ilçede daha fazla seçenek</p>
            <h2>{listing.district} içindeki diğer ilanlar</h2>
          </div>
          <a href={`/ilanlar?ilce=${encodeURIComponent(listing.district)}`}>İlçe listesini aç</a>
        </div>
        <div class="related-grid">
          {districtListings.map((item) => (
            <article class="related-item">
              <a href={`/ilanlar/${item.slug}`} class="related-media" aria-label={`${item.title} detay`}>
                {item.images?.[0] ? <img src={item.images[0]} alt={item.title} loading="lazy" /> : <span>İlan</span>}
              </a>
              <div class="related-body">
                <span>{item.parent_category_name || item.category_name}</span>
                <h3><a href={`/ilanlar/${item.slug}`}>{item.title}</a></h3>
                <strong>{item.price ? formatter.format(Number(item.price)) : 'Fiyat belirtilmedi'}</strong>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}
  </main>
</Layout>

<script is:inline>
  document.querySelectorAll('[data-contact-track]').forEach((link) => {
    link.addEventListener('click', () => {
      const id = link.getAttribute('data-listing-id');
      if (!id) return;
      const form = new FormData();
      form.set('action', 'contact');
      fetch(`/api/classifieds/${encodeURIComponent(id)}`, {
        method: 'PATCH',
        body: form,
        headers: { accept: 'application/json' },
        keepalive: true,
      }).catch(() => null);
    });
  });
</script>

<style>
  .listing-detail {
    background: #fffaf0;
    color: #24170f;
    min-height: 100vh;
    padding: 2rem clamp(1rem, 3vw, 2.5rem) 4rem;
  }
  .crumbs,
  .detail-grid,
  .description-card,
  .faq-card,
  .guide-card,
  .trust-card,
  .related-card {
    margin-inline: auto;
    max-width: 78rem;
  }
  .crumbs {
    align-items: center;
    display: flex;
    gap: .5rem;
    margin-bottom: 1rem;
  }
  .crumbs a {
    color: #78331d;
    font-weight: 800;
    text-decoration: none;
  }
  .detail-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(0, 1.35fr) minmax(20rem, .65fr);
  }
  .gallery,
  .summary,
  .description-card,
  .faq-card,
  .guide-card,
  .trust-card,
  .related-card {
    background: white;
    border: 1px solid #eadcc4;
    border-radius: 1.5rem;
    box-shadow: 0 20px 55px rgb(36 23 15 / 7%);
    padding: 1rem;
  }
  .cover,
  .empty-image {
    aspect-ratio: 16 / 10;
    border-radius: 1rem;
    width: 100%;
  }
  .cover {
    object-fit: cover;
  }
  .empty-image {
    align-items: center;
    background: #f1e3ce;
    color: #8a3d22;
    display: flex;
    font-weight: 900;
    justify-content: center;
  }
  .thumbs {
    display: grid;
    gap: .75rem;
    grid-template-columns: repeat(4, 1fr);
    margin-top: .75rem;
  }
  .thumbs img {
    aspect-ratio: 1;
    border-radius: .8rem;
    object-fit: cover;
    width: 100%;
  }
  .badge {
    background: #f7ecd9;
    border-radius: 999px;
    color: #78331d;
    display: inline-flex;
    font-weight: 900;
    margin: 0;
    padding: .45rem .75rem;
