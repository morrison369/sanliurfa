---
import Layout from '../../layouts/Layout.astro';
import MessagingInbox from '../../components/MessagingInbox';

// Redirect if not logged in
if (!Astro.locals.user) {
  return Astro.redirect(`/giris?redirect=${encodeURIComponent(Astro.url.pathname)}`);
}
---

<Layout title="Mesajlar - Şanlıurfa Rehberi" noindex>
  <div class="min-h-screen bg-gray-50">
    <MessagingInbox client:load />
  </div>
</Layout>

<style>
  div :global(body) {
    overflow: hidden;
  }
</style>
