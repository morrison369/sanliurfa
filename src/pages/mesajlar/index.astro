---
import Layout from '../../layouts/Layout.astro';
import MessagingInbox from '../../components/MessagingInbox';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/giris?redirect=/mesajlar');
}
---

<Layout seo={{ title: "Mesajlar - Şanlıurfa Rehberi", noIndex: true }}>
  <div class="min-h-screen bg-[#FDFAF3]">
    <MessagingInbox client:visible={{ rootMargin: '160px' }} />
  </div>
</Layout>

<style>
  div :global(body) {
    overflow: hidden;
  }
</style>
