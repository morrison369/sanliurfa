---
import Layout from '../../layouts/Layout.astro';
import { query } from '../../lib/postgres';
import { getSiteBranding } from '../../lib/site-branding';

let recipes: any[] = [];
let popularFoodPlaces: any[] = [];

const fallbackRecipes = [
  {
    id: 'urfa-kebabi',
    slug: 'urfa-kebabi',
    name: 'Urfa Kebabı',
    description: 'Acısız zırh kıyması, isot dengesi ve köz sebze eşliğiyle klasik Şanlıurfa kebabı.',
    cover_image: '/images/hero/hero-food.webp',
    is_spicy: false,
    difficulty: 'Orta',
    prep_time: 45,
    rating: '4.9',
  },
  {
    id: 'cig-kofte',
    slug: 'cig-kofte',
    name: 'Şanlıurfa Çiğ Köftesi',
    description: 'İnce bulgur, isot, domates salçası ve uzun yoğurma tekniğiyle Urfa usulü çiğ köfte.',
    cover_image: '/images/blog/sanliurfa-lezzetler-2026.webp',
    is_spicy: true,
    difficulty: 'Zor',
    prep_time: 60,
    rating: '4.8',
  },
  {
    id: 'borani',
    slug: 'borani',
    name: 'Borani',
    description: 'Yoğurt, pazı ve nohutla hazırlanan, Şanlıurfa sofralarının dengeli yöresel lezzeti.',
    cover_image: '/images/places/cigerci-aziz-usta/food-card.webp',
    is_spicy: false,
    difficulty: 'Kolay',
    prep_time: 35,
    rating: '4.7',
  },
  {
    id: 'lebeni',
    slug: 'lebeni',
    name: 'Lebeni',
    description: 'Yoğurtlu buğday çorbası; özellikle yaz aylarında serin ve doyurucu bir Urfa tarifi.',
    cover_image: '/images/hero/hero-food.webp',
    is_spicy: false,
    difficulty: 'Kolay',
    prep_time: 30,
    rating: '4.6',
  },
  {
    id: 'sillik-tatlisi',
    slug: 'sillik-tatlisi',
    name: 'Şıllık Tatlısı',
    description: "İnce krep hamuru, ceviz ve şerbetle hazırlanan Şanlıurfa'nın en bilinen tatlılarından.",
    cover_image: '/images/blog/sanliurfa-lezzetler-2026.webp',
    is_spicy: false,
    difficulty: 'Orta',
    prep_time: 40,
    rating: '4.8',
  },
  {
    id: 'patlican-kebabi',
    slug: 'patlican-kebabi',
    name: 'Patlıcan Kebabı',
    description: 'Köz kokusu, yağ dengesi ve kuzu etiyle yapılan Urfa yaz sofralarının güçlü ana yemeği.',
    cover_image: '/images/hero/hero-food.webp',
    is_spicy: false,
    difficulty: 'Orta',
    prep_time: 55,
    rating: '4.9',
  },
];

const fallbackFoodPlaces = [
  { slug: 'cigerci-aziz-usta', name: 'Ciğerci Aziz Usta', category_name: 'Ciğerciler', rating: '4.8', review_count: 128 },
  { slug: 'sembol-ocakbasi', name: 'Sembol Ocakbaşı', category_name: 'Kebapçılar', rating: '4.7', review_count: 96 },
  { slug: 'culcuoglu', name: 'Çulcuoğlu', category_name: 'Yöresel Yemekler', rating: '4.6', review_count: 84 },
  { slug: 'gumruk-han', name: 'Gümrük Han', category_name: 'Kahvaltı ve Çay', rating: '4.5', review_count: 77 },
];

try {
  const [recipesResult, placesResult] = await Promise.all([
    query(`
      SELECT id, slug, name, description, cover_image, is_spicy, difficulty, prep_time, rating
      FROM recipes
      WHERE status = 'published'
      ORDER BY is_featured DESC, rating DESC NULLS LAST
      LIMIT 24
    `),
    query(`
      SELECT p.id, p.slug, p.name, p.rating, p.review_count, c.name AS category_name
      FROM places p
      LEFT JOIN categories c ON p.category_id = c.id
      WHERE p.status = 'active'
        AND c.slug IN (
          "kebapcilar', 'cigerciler', 'lahmacuncular', 'pideciler",
          "cig-kofteciler', 'yoresel-yemekler', 'tatlicilar"
        )
      ORDER BY p.rating DESC NULLS LAST, p.review_count DESC NULLS LAST
      LIMIT 8
    `),
  ]);

  recipes = recipesResult.rows;
  popularFoodPlaces = placesResult.rows;
} catch (error) {
  console.error('Yemek tarifleri sayfası verileri yüklenemedi:', error);
}

if (recipes.length === 0) {
  recipes = fallbackRecipes;
}

if (popularFoodPlaces.length === 0) {
  popularFoodPlaces = fallbackFoodPlaces;
}

const seo = {
  title: 'Şanlıurfa Özel Yemek Tarifleri | Geleneksel Urfa Mutfağı',
  description: 'Şanlıurfa özel yemek tarifleri: kebap, ciğer, çiğ köfte, tatlılar ve yöresel tarifler.',
  keywords: ['urfa yemek tarifleri', 'şanlıurfa urfa kebabı tarifi', 'çiğ köfte tarifi', 'urfa borani', 'şanlıurfa şıllık tatlısı', 'yöresel tarifler', 'urfa mutfağı tarifi'],
  ogImage: '/images/hero/hero-food.webp',
  canonical: '/yemek-tarifleri',
};
const { baseUrl } = await getSiteBranding();

const faqItems = [
  {
    S: 'Şanlıurfa yemek tarifleri hangi lezzetleri kapsar?',
    C: 'Urfa kebabı, çiğ köfte, borani, lebeni, şıllık tatlısı ve patlıcan kebabı gibi yöresel tarifler bu rehberde öne çıkar.',
  },
  {
    S: 'Tariflerle ilgili mekan önerisi var mı?',
    C: "Evet. Tarif kartlarının altında Şanlıurfa'da bu lezzetleri deneyebileceğiniz popüler mekan önerileri gösterilir.",
  },
  {
    S: 'Tarif görselleri nasıl yönetilir?',
    C: 'Görseller slug uyumlu adlandırılır ve Pexels öncelikli, Unsplash yedekli medya akışıyla admin onayına bağlı tutulur.',
  },
];
---

<Layout seo={seo}>
  <div class="min-h-screen bg-amber-50/40">
    <section class="pt-28 pb-14 bg-gradient-to-br from-amber-700 to-orange-800 text-white">
      <div class="container mx-auto px-4">
        <p class="text-amber-200 font-medium mb-2">Sanliurfa.com Mutfak Rehberi</p>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Şanlıurfa Özel Yemek Tarifleri</h1>
        <p class="text-amber-100 max-w-3xl text-lg">
          Urfa mutfağının geleneksel lezzetlerini adım adım keşfedin. Tarifler, malzemeler ve yöresel püf noktaları tek sayfada.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/yeme-icme" class="px-5 py-2.5 rounded-full bg-white/20 border border-white/30 hover:bg-white/30 transition-colors">
            Yeme İçme Rehberi
          </a>
          <a href="/mekanlar/yoresel-yemekler" class="px-5 py-2.5 rounded-full bg-white/20 border border-white/30 hover:bg-white/30 transition-colors">
            Yöresel Yemek Mekanları
          </a>
          <a href="/mekanlar/cig-kofteciler" class="px-5 py-2.5 rounded-full bg-white/20 border border-white/30 hover:bg-white/30 transition-colors">
            Çiğ Köfteciler
          </a>
        </div>
      </div>
    </section>

    <section class="py-12">
      <div class="container mx-auto px-4">
        <div class="mb-8 rounded-2xl border border-amber-200 bg-white p-5 shadow-sm">
          <p class="text-sm font-semibold uppercase tracking-wide text-amber-700">Hızlı Cevap</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">Şanlıurfa yemek tarifleri nereden başlanır?</h2>
          <p class="mt-2 text-sm leading-6 text-gray-700">
            Şanlıurfa yemek tarifleri sayfası; Urfa kebabı, çiğ köfte, borani, lebeni ve şıllık tatlısı gibi
            yöresel lezzetleri tek rehberde toplar. Tarifleri inceleyip ilgili yeme-içme mekanlarına geçebilirsiniz.
          </p>
          <div class="mt-3 flex flex-wrap gap-3 text-sm">
            <a href="/yemek-tarifleri" class="font-semibold text-amber-800 underline underline-offset-4">Tarif rehberi</a>
            <a href="/mekanlar/yoresel-yemekler" class="font-semibold text-amber-800 underline underline-offset-4">Yöresel yemek mekanları</a>
            <a href="/gastronomi" class="font-semibold text-amber-800 underline underline-offset-4">Gastronomi</a>
          </div>
        </div>

        <div class="flex items-center justify-between mb-7">
          <h2 class="text-2xl font-bold text-gray-900">Tarifler</h2>
          <a href="/gastronomi" class="text-red-600 hover:text-red-700 font-medium">Gastronomi Sayfası →</a>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {recipes.length > 0 ? recipes.map((recipe) => (
            <a href={`/yemek-tarifleri/${recipe.slug}`} class="bg-white rounded-xl overflow-hidden shadow-sm border border-amber-100 hover:shadow-lg transition-all group">
              <div class="h-44 bg-amber-100">
                <img
                  src={recipe.cover_image || recipe.images?.[0] || '/images/foods/default.jpg'}
                  alt={recipe.name}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                  onerror="this.setAttribute('src','/images/foods/default.jpg')"
                />
              </div>
              <div class="p-4">
                <div class="flex items-center justify-between gap-2">
                  <h3 class="font-bold text-gray-900 group-hover:text-red-600">{recipe.name}</h3>
                  {recipe.is_spicy && <span class="text-xs px-2 py-1 rounded-full bg-red-100 text-red-700 font-medium">Acılı</span>}
                </div>
                <p class="text-sm text-gray-600 mt-1 line-clamp-2">{recipe.description || 'Şanlıurfa mutfağından özel tarif.'}</p>
                <div class="flex items-center gap-3 mt-3 text-xs text-gray-500">
                  <span>Zorluk: {recipe.difficulty || '-'}</span>
                  <span>Hazırlık: {recipe.prep_time ? `${recipe.prep_time} dk` : '-'}</span>
                  <span>Puan: {recipe.rating || '-'}</span>
                </div>
              </div>
            </a>
          )) : null}
        </div>
      </div>
    </section>

    <section class="pb-16">
      <div class="container mx-auto px-4">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Tarifler İçin Önerilen Mekanlar</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
          {popularFoodPlaces.length > 0 ? popularFoodPlaces.map((place) => (
            <a href={`/isletme/${place.slug}`} class="bg-white rounded-xl border p-4 hover:shadow-lg transition-all group">
              <p class="text-xs text-gray-500">{place.category_name || 'Mekan'}</p>
              <h3 class="font-bold text-gray-900 group-hover:text-red-600 mt-1">{place.name}</h3>
              <p class="text-sm text-gray-500 mt-2">Puan: {place.rating || '-'} ({place.review_count || 0} yorum)</p>
            </a>
          )) : null}
        </div>
      </div>
    </section>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.C,
      },
    })),
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Şanlıurfa Yemek Tarifleri',
    itemListElement: recipes.slice(0, 12).map((recipe, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: recipe.name,
      url: `${baseUrl}/yemek-tarifleri/${recipe.slug}`,
    })),
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Yemek Tarifleri', item: `${baseUrl}/yemek-tarifleri` },
    ],
  })} is:inline />
</Layout>