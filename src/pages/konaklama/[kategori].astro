---
import Layout from '../../layouts/Layout.astro';
import { query } from '../../lib/postgres';

const { kategori } = Astro.params;

const categoryMeta: Record<string, { name: string; icon: string }> = {
  'oteller': { name: 'Oteller', icon: '🏨' },
  'butik-oteller': { name: 'Butik Oteller', icon: '🏡' },
  'pansiyonlar': { name: 'Pansiyonlar', icon: '🛏️' },
};

const meta = categoryMeta[kategori || ''] || { name: kategori || '', icon: '🏨' };

let places: any[] = [];

try {
  const result = await query(
    `SELECT p.*, d.name as district_name FROM places p
     LEFT JOIN categories c ON p.category_id = c.id
     LEFT JOIN districts d ON p.district_id = d.id
     WHERE (c.slug = $1 OR p.category_id = 501)
     AND p.status = 'active'
     ORDER BY p.is_featured DESC, p.rating DESC`,
    [kategori]
  );
  places = result.rows;
} catch (e) {
  console.error('Error loading konaklama kategori:', e);
}

const seo = {
  title: `Şanlıurfa ${meta.name} | Konaklama Rehberi`,
  description: `Şanlıurfa'da en iyi ${meta.name.toLowerCase()}. Fiyatlar, adresler ve bilgiler.`,
};
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50">
    <div class="bg-white border-b">
      <div class="container mx-auto px-4 py-3">
        <nav class="flex items-center gap-2 text-sm text-gray-500">
          <a href="/" class="hover:text-amber-600">Ana Sayfa</a>
          <span>/</span>
          <a href="/konaklama" class="hover:text-amber-600">Konaklama</a>
          <span>/</span>
          <span class="text-gray-900 font-medium">{meta.name}</span>
        </nav>
      </div>
    </div>

    <div class="bg-gradient-to-br from-amber-700 to-yellow-800 text-white py-12">
      <div class="container mx-auto px-4">
        <div class="flex items-center gap-4">
          <span class="text-5xl">{meta.icon}</span>
          <div>
            <h1 class="text-3xl md:text-4xl font-bold">Şanlıurfa {meta.name}</h1>
            <p class="text-amber-100 mt-1">{places.length} tesis bulundu</p>
          </div>
        </div>
      </div>
    </div>

    <div class="container mx-auto px-4 py-8">
      {places.length > 0 ? (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {places.map((place) => (
            <a href={`/places/${place.slug}`} class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-all group">
              <div class="h-44 bg-gradient-to-br from-amber-100 to-yellow-100 flex items-center justify-center">
                <span class="text-5xl opacity-50">{meta.icon}</span>
              </div>
              <div class="p-5">
                <h2 class="font-bold text-lg text-gray-900 group-hover:text-amber-600">{place.name}</h2>
                {place.district_name && <p class="text-xs text-amber-600">{place.district_name}</p>}
                {place.address && <p class="text-sm text-gray-500 mt-2">📍 {place.address}</p>}
                <div class="flex items-center justify-between mt-3">
                  {place.rating && (
                    <div class="flex items-center gap-1">
                      <span class="text-yellow-500">★</span>
                      <span class="font-medium">{place.rating}</span>
                    </div>
                  )}
                  {place.price_min && (
                    <span class="text-sm text-gray-500">{place.price_min}₺'den</span>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <div class="text-6xl mb-4">{meta.icon}</div>
          <p class="text-gray-500 text-lg">Bu kategoride henüz kayıt bulunmuyor.</p>
          <a href="/konaklama" class="mt-4 inline-block text-amber-600 hover:underline">Konaklama Rehberine Dön →</a>
        </div>
      )}
    </div>
  </div>
</Layout>
