---
import Layout from '../../layouts/Layout.astro';
import { query } from '../../lib/postgres';
import { getCachedPublicRouteData } from '../../lib/public-route-cache';
import { getPublicAppUrl } from '../../lib/public-app-url';
import { logger } from '../../lib/logging';
const baseUrl = getPublicAppUrl();

const { kategori } = Astro.params;

const categoryMeta: Record<string, { name: string; icon: string }> = {
 'oteller': { name: 'Oteller', icon: '🏨' },
 'butik-oteller': { name: 'Butik Oteller', icon: '🏡' },
 'pansiyonlar': { name: 'Pansiyonlar', icon: '🛏️' },
};

const meta = categoryMeta[kategori || ''] || { name: kategori || '', icon: '🏨' };

let places: any[] = [];

try {
 places = await getCachedPublicRouteData(`page:konaklama:${kategori || 'unknown'}`, async () => {
  const result = await query(
   `SELECT p.*, d.name as district_name FROM places p
 LEFT JOIN categories c ON p.category_id = c.id
 LEFT JOIN districts d ON p.district_id = d.id
 WHERE (c.slug = $1 OR p.category_id = 501)
 AND p.status = 'active'
 ORDER BY p.is_featured DESC, p.rating DESC`,
   [kategori]
  );
  return result.rows;
 });
} catch (e) {
 logger.error('Error loading konaklama kategori:', e instanceof Error ? e : new Error(String(e)));
}

const seo = {
 title: `Şanlıurfa ${meta.name} | Konaklama Rehberi`,
 description: `Şanlıurfa'da en iyi ${meta.name.toLowerCase()}. Fiyatlar, adresler ve bilgiler.`,
 keywords: ['şanlıurfa ' + meta.name.toLowerCase(), 'urfa ' + meta.name.toLowerCase(), meta.name + ' şanlıurfa', 'şanlıurfa konaklama'],
 ogImage: '/images/hero/hero-hotel.webp',
 canonical: `/konaklama/${kategori}`,
};
const faqItems = [
 { S: `Şanlıurfa'da ${meta.name.toLowerCase()} seçenekleri nelerdir?`, C: `Şanlıurfa'da ${meta.name.toLowerCase()} için güncel liste ve değerlendirmeler rehberimizde yer almaktadır.` },
 { S: `${meta.name} için hangi ilçeler öne çıkıyor?`, C: `Eyyübiye, Haliliye ve Karaköprü ilçeleri hizmet yoğunluğu açısından öne çıkan bölgeler arasındadır.` },
 { S: `${meta.name} bilgilerini nasıl güncelleyebilirim?`, C: `Mekan sayfasına giriş yaparak güncelleme talebinde bulunabilir veya iletişim formu üzerinden bildirimde bulunabilirsiniz.` },
];
---

<Layout seo={seo}>
 <style>
 .kk-breadcrumb{background:var(--public-bg);border-bottom:1px solid var(--public-border);padding:.75rem 0}
 .kk-breadcrumb nav{display:flex;align-items:center;gap:.5rem;font-size:.8rem;color:var(--public-muted)}
 .kk-breadcrumb a{color:var(--public-muted);transition:color .15s}.kk-breadcrumb a:hover{color:var(--public-accent)}
 .kk-breadcrumb span:last-child{color:var(--public-accent);font-weight:500}
 .kk-hero{background:var(--public-bg);border-bottom:1px solid var(--public-border);padding:3rem 0}
 .kk-hero-inner{display:flex;align-items:center;gap:1rem}
 .kk-hero-icon{font-size:3rem;line-height:1}
 .kk-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.6rem,4vw,2.5rem);font-weight:600;color:var(--public-text)}
 .kk-count{font-size:.85rem;color:var(--public-muted);margin-top:.25rem}
 .kk-body{background:var(--public-bg);padding:2rem 0 4rem}
 .kk-grid{display:grid;gap:1rem;grid-template-columns:repeat(auto-fill,minmax(260px,1fr))}
 .kk-card{background:var(--public-surface);border:1px solid var(--public-border);overflow:hidden;transition:border-color .15s}
 .kk-card:hover{border-color:var(--public-accent)}
 .kk-thumb{height:10rem;background:var(--public-accent-soft);display:flex;align-items:center;justify-content:center;font-size:3rem;opacity:.75;transition:opacity .3s}
 .kk-card:hover .kk-thumb{opacity:.6}
 .kk-card-body{padding:1rem}
 .kk-card-name{font-size:.92rem;font-weight:700;color:var(--public-text);margin-bottom:.2rem;transition:color .15s}
 .kk-card:hover .kk-card-name{color:var(--public-accent)}
 .kk-district{font-size:.72rem;color:var(--public-accent);font-weight:600;margin-bottom:.3rem}
 .kk-addr{font-size:.75rem;color:var(--public-muted);margin-top:.2rem}
 .kk-card-meta{display:flex;align-items:center;justify-content:space-between;margin-top:.6rem}
 .kk-rating{display:flex;align-items:center;gap:.25rem;font-size:.78rem;color:var(--public-text);font-weight:600}
 .kk-rating-star{color:var(--public-accent)}
 .kk-price{font-size:.78rem;color:var(--public-text-soft)}
 .kk-empty{text-align:center;padding:4rem 1rem;color:var(--public-muted)}
 .kk-empty-icon{font-size:3.5rem;margin-bottom:.75rem}
 .kk-empty-link{display:inline-block;margin-top:.75rem;color:var(--public-accent);font-size:.85rem;transition:color .15s}
 .kk-empty-link:hover{color:var(--public-accent-strong)}
 </style>

 <div class="kk-breadcrumb">
 <div class="sf-container">
 <nav>
 <a href="/">Ana Sayfa</a>
 <span>/</span>
 <a href="/konaklama">Konaklama</a>
 <span>/</span>
 <span>{meta.name}</span>
 </nav>
 </div>
 </div>

 <div class="kk-hero">
 <div class="sf-container">
 <div class="kk-hero-inner">
 <span class="kk-hero-icon">{meta.icon}</span>
 <div>
 <h1 class="kk-h1">Şanlıurfa {meta.name}</h1>
 <p class="kk-count">{places.length} tesis bulundu</p>
 </div>
 </div>
 </div>
 </div>

 <div class="kk-body">
 <div class="sf-container">
 {places.length > 0 ? (
 <div class="kk-grid">
 {places.map((place) => (
 <a href={`/isletme/${place.slug}`} class="kk-card">
 <div class="kk-thumb">{meta.icon}</div>
 <div class="kk-card-body">
 <p class="kk-card-name">{place.name}</p>
 {place.district_name && <p class="kk-district">{place.district_name}</p>}
 {place.address && <p class="kk-addr">📍 {place.address}</p>}
 <div class="kk-card-meta">
 {place.rating && (
 <div class="kk-rating">
 <span class="kk-rating-star">★</span>
 {place.rating}
 </div>
 )}
 {place.price_min && <span class="kk-price">{place.price_min}₺'den</span>}
 </div>
 </div>
 </a>
 ))}
 </div>
 ) : (
 <div class="kk-empty">
 <div class="kk-empty-icon">{meta.icon}</div>
 <p>Bu kategoride henüz kayıt bulunmuyor.</p>
 <a href="/konaklama" class="kk-empty-link">Konaklama Rehberine Dön →</a>
 </div>
 )}
 </div>
 </div>

 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'CollectionPage',
 name: `Şanlıurfa ${meta.name}`,
 description: `Şanlıurfa'da en iyi ${meta.name.toLowerCase()}. Fiyatlar, adresler ve bilgiler.`,
 url: `${baseUrl}/konaklama/${kategori}`,
 about: { '@type': 'City', name: 'Şanlıurfa' },
 itemListElement: places.slice(0, 10).map((p: any, i: number) => ({
 '@type': 'ListItem',
 position: i + 1,
 item: {
 '@type': 'LodgingBusiness',
 name: p.name,
 url: `${baseUrl}/isletme/${p.slug}`,
 ...(p.address ? { address: p.address } : {}),
 ...(p.rating ? { aggregateRating: { '@type': 'AggregateRating', ratingValue: p.rating, bestRating: 5 } } : {}),
 },
 })),
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'Konaklama', item: `${baseUrl}/konaklama` },
 { '@type': 'ListItem', position: 3, name: meta.name, item: `${baseUrl}/konaklama/${kategori}` },
 ],
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqItems.map((item) => ({
 '@type': 'Question',
 name: item.S,
 acceptedAnswer: { '@type': 'Answer', text: item.C },
 })),
 })} is:inline />
</Layout>
