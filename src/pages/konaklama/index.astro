---
import Layout from '../../layouts/Layout.astro';
import { query } from '../../lib/postgres';
import { getSiteBranding } from '../../lib/site-branding';
import { logger } from '../../lib/logging';

let hotels: any[] = [];

const konaklamaCategories = [
  { slug: 'oteller', name: 'Oteller', icon: '🏨', desc: '3-5 yıldızlı oteller' },
  { slug: 'butik-oteller', name: 'Butik Oteller', icon: '🏡', desc: 'Tarihi ve butik tesisler' },
  { slug: 'pansiyonlar', name: 'Pansiyonlar', icon: '🛏️', desc: 'Uygun fiyatlı konaklamalar' },
];

try {
  const hotelsResult = await query(
    `SELECT p.*, c.name as category_name FROM places p
     LEFT JOIN categories c ON p.category_id = c.id
     WHERE (c.slug IN ('oteller','butik-oteller','pansiyonlar') OR p.category_id = 501)
     AND p.status = 'active'
     ORDER BY p.is_featured DESC, p.rating DESC LIMIT 9`
  );
  hotels = hotelsResult.rows;
} catch (e) {
  logger.error('Error loading konaklama:', e instanceof Error ? e : new Error(String(e)));
}

const seo = {
  title: 'Şanlıurfa Oteller ve Konaklama Rehberi | En İyi Oteller',
  description: 'Şanlıurfa\'da oteller, butik oteller ve pansiyonlar. Balıklıgöl\'e yakın, tarihi hanlar ve modern konaklama seçenekleri.',
  ogImage: '/images/hero/hero-hotel.webp',
  keywords: ['şanlıurfa oteller', 'urfa konaklama', 'şanlıurfa pansiyon', 'urfa butik otel', 'şanlıurfa en iyi oteller', 'urfa balıklıgöl otel', 'şanlıurfa ucuz konaklama'],
  canonical: '/konaklama',
};

const faqItems = [
  { S: 'Şanlıurfa\'da nerede kalınır?', C: 'Şanlıurfa\'da Balıklıgöl çevresindeki tarihi oteller ve butik tesisler en popüler konaklama seçeneklerini sunar. Şehir merkezinde modern oteller, ilçelerde ise uygun fiyatlı pansiyonlar bulunur.' },
  { S: 'Göbeklitepe\'ye yakın otel var mı?', C: 'Göbeklitepe şehir merkezine 18 km uzaklıktadır. Şanlıurfa merkezdeki otellerde kalarak sabahın erken saatlerinde rahatlıkla Göbeklitepe\'ye ulaşabilirsiniz.' },
  { S: 'Halfeti\'de konaklama seçenekleri neler?', C: 'Halfeti\'de butik oteller ve tatil evleri bulunmaktadır. Fırat Nehri kıyısındaki küçük oteller doğayla iç içe bir konaklama deneyimi sunar.' },
];
const { baseUrl } = await getSiteBranding();
---

<Layout seo={seo}>
  <div class="min-h-screen bg-[#FDFAF3]">
    <div class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)] text-white py-16">
      <div class="container mx-auto px-4">
        <p class="text-sm font-semibold uppercase tracking-widest text-[#9A8470] mb-2">KONAKLAMA REHBERİ</p>
        <h1 class="text-4xl md:text-5xl font-bold text-[#F5EDD6] mb-4">Konaklama Rehberi</h1>
        <p class="text-xl text-[#C4B49A] max-w-2xl">
          Şanlıurfa'da oteller, butik tesisler ve pansiyonlar. Tarihi hanlardan modern otellere
        </p>
      </div>
    </div>

    <div class="container mx-auto px-4 py-12">
      <!-- Öne Çıkan: Tarihi Hanlar -->
      <div class="bg-[rgba(200,160,100,0.06)] border border-[rgba(200,160,100,0.2)] rounded-sm p-6 mb-10">
        <h2 class="text-xl font-bold text-[#1A1008] mb-2">🏛️ Tarihi Hanlarda Konaklama</h2>
        <p class="text-[#4A3828]">Gümrük Hanı ve Hanehan gibi tarihi binalarda dönüştürülmüş butik oteller — benzersiz bir Şanlıurfa deneyimi.</p>
      </div>

      <!-- Kategoriler -->
      <h2 class="text-2xl font-bold text-[#1A1008] mb-6">Konaklama Tipleri</h2>
      <div class="grid md:grid-cols-3 gap-6 mb-12">
        {konaklamaCategories.map((cat) => (
          <a
            href={`/konaklama/${cat.slug}`}
            class="bg-white rounded-sm p-8 border border-[rgba(200,160,100,0.18)] shadow-sm hover:shadow-md hover:border-urfa-300 hover:-translate-y-1 transition-all group text-center"
          >
            <div class="text-5xl mb-4">{cat.icon}</div>
            <h3 class="text-xl font-bold text-[#1A1008] group-hover:text-urfa-700 transition-colors">{cat.name}</h3>
            <p class="text-[#9A8470] mt-2">{cat.desc}</p>
          </a>
        ))}
      </div>

      <!-- Tüm Oteller -->
      {hotels.length > 0 && (
        <div>
          <h2 class="text-2xl font-bold text-[#1A1008] mb-6">Tüm Konaklama Yerleri</h2>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {hotels.map((hotel) => (
              <a href={`/isletme/${hotel.slug}`} class="bg-white rounded-sm overflow-hidden border border-[rgba(200,160,100,0.18)] shadow-sm hover:shadow-md hover:border-urfa-300 transition-all group">
                <div class="h-44 bg-[rgba(200,160,100,0.06)] flex items-center justify-center">
                  <span class="text-5xl opacity-50">🏨</span>
                </div>
                <div class="p-5">
                  <h3 class="font-bold text-lg text-[#1A1008] group-hover:text-urfa-700">{hotel.name}</h3>
                  <span class="text-xs text-urfa-600">{hotel.category_name}</span>
                  <p class="text-sm text-[#9A8470] mt-2 line-clamp-2">{hotel.short_description || hotel.address}</p>
                  <div class="flex items-center justify-between mt-3">
                    <div class="flex items-center gap-1">
                      <span class="text-yellow-500">★</span>
                      <span class="font-semibold text-[#1A1008]">{hotel.rating || '-'}</span>
                    </div>
                    {hotel.price_min && (
                      <span class="text-sm text-[#9A8470]">{hotel.price_min}₺ / gece'den</span>
                    )}
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Şanlıurfa Oteller',
    description: 'Şanlıurfa\'da konaklama yerleri',
    itemListElement: hotels.map((h, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Hotel',
        name: h.name,
        url: `${baseUrl}/isletme/${h.slug}`,
        address: { '@type': 'PostalAddress', addressLocality: 'Şanlıurfa', addressCountry: 'TR' }
      }
    }))
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Konaklama', item: `${baseUrl}/konaklama` },
    ],
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: { '@type': 'Answer', text: item.C },
    })),
  })} is:inline />
</Layout>
