---
import Layout from '../../layouts/Layout.astro';
import { query } from '../../lib/postgres';
import { getCachedPublicRouteData } from '../../lib/public-route-cache';
import { getPublicAppUrl } from '../../lib/public-app-url';
import { logger } from '../../lib/logging';
import { resolvePlaceImage } from '../../lib/public-image-resolvers';
import Image from '../../components/Image.astro';

let hotels: any[] = [];

const konaklamaCategories = [
 { slug: 'konaklama-oteller', name: 'Oteller', icon: '🏨', desc: '3-5 yıldızlı oteller' },
 { slug: 'konaklama-butik-oteller', name: 'Butik Oteller', icon: '🏡', desc: 'Tarihi ve butik tesisler' },
 { slug: 'konaklama-pansiyonlar', name: 'Pansiyonlar', icon: '🛏️', desc: 'Uygun fiyatlı konaklamalar' },
 { slug: 'konaklama-apart-oteller', name: 'Apart Oteller', icon: '🏢', desc: 'Uzun süreli konaklama' },
 { slug: 'konaklama-bungalov-doga-konaklama', name: 'Doğa Konaklama', icon: '🌿', desc: 'Bungalov ve kamp alanları' },
];

try {
 hotels = await getCachedPublicRouteData('page:konaklama:index', async () => {
  const hotelsResult = await query(
   `SELECT p.*, c.name as category_name FROM places p
 LEFT JOIN categories c ON p.category_id = c.id
 WHERE c.slug IN ('konaklama-oteller','konaklama-butik-oteller','konaklama-pansiyonlar',
   'konaklama-3-yildizli','konaklama-4-yildizli','konaklama-5-yildizli',
   'konaklama-apart-oteller','konaklama-bungalov-doga-konaklama')
 AND p.status = 'active'
 ORDER BY p.is_featured DESC, p.rating DESC LIMIT 9`
  );
  return hotelsResult.rows;
 });
} catch (e) {
 logger.error('Error loading konaklama:', e instanceof Error ? e : new Error(String(e)));
}

const seo = {
 title: 'Şanlıurfa Oteller ve Konaklama Rehberi | En İyi Oteller',
 description: "Şanlıurfa'da oteller, butik oteller ve pansiyonlar. Balıklıgöl'e yakın, tarihi hanlar ve modern konaklama seçenekleri.",
 ogImage: '/images/hero/hero-hotel.webp',
 keywords: ['şanlıurfa oteller', 'urfa konaklama', 'şanlıurfa pansiyon', 'urfa butik otel', 'şanlıurfa en iyi oteller', 'urfa balıklıgöl otel', 'şanlıurfa ucuz konaklama'],
 canonical: '/konaklama',
};

const faqItems = [
 { S: "Şanlıurfa'da nerede kalınır?", C: "Şanlıurfa'da Balıklıgöl çevresindeki tarihi oteller ve butik tesisler en popüler konaklama seçeneklerini sunar. Şehir merkezinde modern oteller, ilçelerde ise uygun fiyatlı pansiyonlar bulunur." },
 { S: "Göbeklitepe'ye yakın otel var mı?", C: "Göbeklitepe şehir merkezine 18 km uzaklıktadır. Şanlıurfa merkezdeki otellerde kalarak sabahın erken saatlerinde rahatlıkla Göbeklitepe'ye ulaşabilirsiniz." },
 { S: "Halfeti'de konaklama seçenekleri neler?", C: "Halfeti'de butik oteller ve tatil evleri bulunmaktadır. Fırat Nehri kıyısındaki küçük oteller doğayla iç içe bir konaklama deneyimi sunar." },
];
const baseUrl = getPublicAppUrl();
---

<Layout seo={seo}>
 <style>
 .kn-hero{position:relative;overflow:hidden;border-bottom:1px solid rgba(184,115,51,0.12);padding:clamp(3rem,6vw,5rem) 0;background:radial-gradient(circle at 18% 0%,rgba(212,151,24,0.10) 0%,transparent 42%),radial-gradient(circle at 82% 100%,rgba(44,122,82,0.08) 0%,transparent 40%),linear-gradient(180deg,#fbf6ec 0%,#f4ecd8 58%,#fbf6ec 100%)}
 .kn-hero-inner{max-width:50rem;margin:0 auto}
 .kn-eyebrow{font-size:.7rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--public-muted);margin-bottom:.5rem}
 .kn-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.9rem,4vw,3rem);font-weight:600;color:var(--public-text);margin-bottom:.5rem}
 .kn-sub{font-size:.9rem;color:var(--public-muted);max-width:38rem;line-height:1.75}
 .kn-body{background:var(--public-bg);padding:2.5rem 0 5rem}
 .kn-info-box{background:var(--public-accent-soft);border:1px solid var(--public-border);padding:1.25rem 1.5rem;margin-bottom:2rem}
 .kn-info-title{font-size:1rem;font-weight:700;color:var(--public-text);margin-bottom:.4rem}
 .kn-info-text{font-size:.82rem;color:var(--public-muted);line-height:1.7}
 .kn-section-title{font-family:'Cormorant Garamond',serif;font-size:1.25rem;font-weight:600;color:var(--public-text);margin-bottom:1.1rem}
 .kn-cat-grid{display:grid;gap:1rem;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));margin-bottom:2.5rem}
 .kn-cat-card{background:var(--public-surface);border:1px solid var(--public-border);padding:1.75rem;text-align:center;transition:border-color .15s,transform .15s}
 .kn-cat-card:hover{border-color:var(--public-accent);transform:translateY(-2px)}
 .kn-cat-icon{font-size:2.5rem;margin-bottom:.75rem}
 .kn-cat-name{font-size:1rem;font-weight:700;color:var(--public-text);margin-bottom:.25rem;transition:color .15s}
 .kn-cat-card:hover .kn-cat-name{color:var(--public-accent)}
 .kn-cat-desc{font-size:.75rem;color:var(--public-muted)}
 .kn-hotel-grid{display:grid;gap:1rem;grid-template-columns:repeat(auto-fill,minmax(260px,1fr))}
 .kn-hotel-card{background:var(--public-surface);border:1px solid var(--public-border);overflow:hidden;transition:border-color .15s}
 .kn-hotel-card:hover{border-color:var(--public-accent)}
 .kn-hotel-thumb{height:10rem;background:var(--public-accent-soft);overflow:hidden;position:relative;display:flex;align-items:center;justify-content:center}
 .kn-hotel-thumb img,
 .kn-hotel-thumb picture{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:transform .3s;display:block}
 .kn-hotel-card:hover .kn-hotel-thumb img{transform:scale(1.05)}
 .kn-hotel-thumb-fallback{font-size:2.5rem;opacity:.5;position:relative;z-index:0}
 .kn-hotel-body{padding:1rem}
 .kn-hotel-name{font-size:.92rem;font-weight:700;color:var(--public-text);margin-bottom:.15rem;transition:color .15s}
 .kn-hotel-card:hover .kn-hotel-name{color:var(--public-accent)}
 .kn-hotel-cat{font-size:.7rem;color:var(--public-accent);font-weight:600;margin-bottom:.35rem}
 .kn-hotel-desc{font-size:.77rem;color:var(--public-muted);line-height:1.6;margin-bottom:.5rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
 .kn-hotel-meta{display:flex;align-items:center;justify-content:space-between;font-size:.75rem;color:var(--public-text-soft)}
 .kn-rating{color:var(--public-accent)}
 </style>

 <div class="kn-hero">
 <div class="sf-container">
 <div class="kn-hero-inner">
 <p class="kn-eyebrow">Konaklama Rehberi</p>
 <h1 class="kn-h1">Konaklama Rehberi</h1>
 <p class="kn-sub">Şanlıurfa'da oteller, butik tesisler ve pansiyonlar. Tarihi hanlardan modern otellere</p>
 </div>
 </div>
 </div>

 <div class="kn-body">
 <div class="sf-container">
 <div class="kn-info-box">
 <p class="kn-info-title">🏛️ Tarihi Hanlarda Konaklama</p>
 <p class="kn-info-text">Gümrük Hanı ve Hanehan gibi tarihi binalarda dönüştürülmüş butik oteller — benzersiz bir Şanlıurfa deneyimi.</p>
 </div>

 <h2 class="kn-section-title">Konaklama Tipleri</h2>
 <div class="kn-cat-grid">
 {konaklamaCategories.map((cat) => (
 <a href={`/konaklama/${cat.slug}`} class="kn-cat-card">
 <div class="kn-cat-icon">{cat.icon}</div>
 <p class="kn-cat-name">{cat.name}</p>
 <p class="kn-cat-desc">{cat.desc}</p>
 </a>
 ))}
 </div>

 {hotels.length > 0 && (
 <div>
 <h2 class="kn-section-title">Tüm Konaklama Yerleri</h2>
 <div class="kn-hotel-grid">
 {hotels.map((hotel) => (
 <a href={`/isletme/${hotel.slug}`} class="kn-hotel-card">
 <div class="kn-hotel-thumb">
  <span class="kn-hotel-thumb-fallback" aria-hidden="true">🏨</span>
  <Image src={resolvePlaceImage(hotel)} alt={hotel.name} loading="lazy" width={400} height={300} class="kn-hotel-thumb-img" />
 </div>
 <div class="kn-hotel-body">
 <p class="kn-hotel-name">{hotel.name}</p>
 <p class="kn-hotel-cat">{hotel.category_name}</p>
 <p class="kn-hotel-desc">{hotel.short_description || hotel.address}</p>
 <div class="kn-hotel-meta">
 <span class="kn-rating">★ {hotel.rating || '-'}</span>
 {hotel.price_min && <span>{hotel.price_min}₺ / gece'den</span>}
 </div>
 </div>
 </a>
 ))}
 </div>
 </div>
 )}
 </div>
 </div>

 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'ItemList',
 name: 'Şanlıurfa Oteller',
 description: "Şanlıurfa'da konaklama yerleri",
 itemListElement: hotels.map((h, i) => ({
 '@type': 'ListItem',
 position: i + 1,
 item: {
 '@type': 'Hotel',
 name: h.name,
 url: `${baseUrl}/isletme/${h.slug}`,
 address: { '@type': 'PostalAddress', addressLocality: 'Şanlıurfa', addressCountry: 'TR' }
 }
 }))
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'Konaklama', item: `${baseUrl}/konaklama` },
 ],
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqItems.map((item) => ({
 '@type': 'Question',
 name: item.S,
 acceptedAnswer: { '@type': 'Answer', text: item.C },
 })),
 })} is:inline />
</Layout>
