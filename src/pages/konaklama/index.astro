---
import Layout from '../../layouts/Layout.astro';
import { query } from '../../lib/postgres';

let hotels: any[] = [];

const konaklamaCategories = [
  { slug: 'oteller', name: 'Oteller', icon: '🏨', desc: '3-5 yıldızlı oteller' },
  { slug: 'butik-oteller', name: 'Butik Oteller', icon: '🏡', desc: 'Tarihi ve butik tesisler' },
  { slug: 'pansiyonlar', name: 'Pansiyonlar', icon: '🛏️', desc: 'Uygun fiyatlı konaklamalar' },
];

try {
  const hotelsResult = await query(
    `SELECT p.*, c.name as category_name FROM places p
     LEFT JOIN categories c ON p.category_id = c.id
     WHERE (c.slug IN ('oteller','butik-oteller','pansiyonlar') OR p.category_id = 501)
     AND p.status = 'active'
     ORDER BY p.is_featured DESC, p.rating DESC LIMIT 9`
  );
  hotels = hotelsResult.rows;
} catch (e) {
  console.error('Error loading konaklama:', e);
}

const seo = {
  title: 'Şanlıurfa Oteller ve Konaklama Rehberi | En İyi Oteller',
  description: 'Şanlıurfa\'da oteller, butik oteller ve pansiyonlar. Balıklıgöl\'e yakın, tarihi hanlar ve modern konaklama seçenekleri.',
};
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50">
    <div class="bg-gradient-to-br from-amber-700 to-yellow-800 text-white py-16">
      <div class="container mx-auto px-4">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Konaklama Rehberi</h1>
        <p class="text-xl text-amber-100 max-w-2xl">
          Şanlıurfa'da oteller, butik tesisler ve pansiyonlar. Tarihi hanlardan modern otellere
        </p>
      </div>
    </div>

    <div class="container mx-auto px-4 py-12">
      <!-- Öne Çıkan: Tarihi Hanlar -->
      <div class="bg-amber-50 border border-amber-200 rounded-2xl p-6 mb-10">
        <h2 class="text-xl font-bold text-amber-800 mb-2">🏛️ Tarihi Hanlarda Konaklama</h2>
        <p class="text-amber-700">Gümrük Hanı ve Hanehan gibi tarihi binalarda dönüştürülmüş butik oteller — benzersiz bir Şanlıurfa deneyimi.</p>
      </div>

      <!-- Kategoriler -->
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Konaklama Tipleri</h2>
      <div class="grid md:grid-cols-3 gap-6 mb-12">
        {konaklamaCategories.map((cat) => (
          <a
            href={`/konaklama/${cat.slug}`}
            class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-xl transition-all hover:-translate-y-1 border border-gray-100 group text-center"
          >
            <div class="text-5xl mb-4">{cat.icon}</div>
            <h3 class="text-xl font-bold text-gray-900 group-hover:text-amber-600 transition-colors">{cat.name}</h3>
            <p class="text-gray-500 mt-2">{cat.desc}</p>
          </a>
        ))}
      </div>

      <!-- Tüm Oteller -->
      {hotels.length > 0 && (
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Tüm Konaklama Yerleri</h2>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {hotels.map((hotel) => (
              <a href={`/places/${hotel.slug}`} class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-all group">
                <div class="h-44 bg-gradient-to-br from-amber-100 to-yellow-100 flex items-center justify-center">
                  <span class="text-5xl opacity-50">🏨</span>
                </div>
                <div class="p-5">
                  <h3 class="font-bold text-lg text-gray-900 group-hover:text-amber-600">{hotel.name}</h3>
                  <span class="text-xs text-amber-600">{hotel.category_name}</span>
                  <p class="text-sm text-gray-500 mt-2 line-clamp-2">{hotel.short_description || hotel.address}</p>
                  <div class="flex items-center justify-between mt-3">
                    <div class="flex items-center gap-1">
                      <span class="text-yellow-500">★</span>
                      <span class="font-semibold">{hotel.rating || '-'}</span>
                    </div>
                    {hotel.price_min && (
                      <span class="text-sm text-gray-500">{hotel.price_min}₺ / gece'den</span>
                    )}
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Şanlıurfa Oteller',
    description: 'Şanlıurfa\'da konaklama yerleri',
    itemListElement: hotels.map((h, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Hotel',
        name: h.name,
        url: `https://sanliurfa.com/places/${h.slug}`,
        address: { '@type': 'PostalAddress', addressLocality: 'Şanlıurfa', addressCountry: 'TR' }
      }
    }))
  })} />
</Layout>
