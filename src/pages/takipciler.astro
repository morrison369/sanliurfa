---
import { Icon } from 'astro-icon/components';
import Layout from '../layouts/Layout.astro';
import Image from '../components/Image.astro';
import { requireAuth } from '../lib/auth';
import { getFollowers, getSocialStats } from '../lib/social/friendship-db';

const auth = await requireAuth(Astro.request);
if (auth instanceof Response) return auth;
if (!auth.user) return Astro.redirect('/giris');
const user = auth.user;

const [followers, stats] = await Promise.all([
 getFollowers(user.id, 50),
 getSocialStats(user.id),
]);
---

<Layout seo={{ title: `Takipçiler (${stats?.follower_count || 0}) - Şanlıurfa Rehberi`, noIndex: true }}>
 <style is:inline>
 .tk-page{background:var(--bg);min-height:100vh}
 .tk-hero{position:relative;overflow:hidden;border-bottom:1px solid rgba(184,115,51,0.12);background:radial-gradient(circle at 18% 0%,rgba(212,151,24,.10) 0%,transparent 42%),radial-gradient(circle at 82% 100%,rgba(44,122,82,.08) 0%,transparent 40%),linear-gradient(180deg,#fbf6ec 0%,#f4ecd8 58%,#fbf6ec 100%);padding:2.5rem 0}
 .tk-inner{max-width:48rem;margin:0 auto}
 .tk-hero-top{display:flex;align-items:center;justify-content:space-between;gap:1rem}
 .tk-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.5rem,3.5vw,2rem);font-weight:700;color:var(--public-text);margin:.25rem 0 0}
 .tk-hero-desc{color:var(--public-muted);font-size:.88rem;margin-top:.2rem}
 .tk-link{color:var(--public-accent);font-size:.85rem;font-weight:500;transition:color .15s;white-space:nowrap}
 .tk-link:hover{color:var(--public-accent-strong)}
 .tk-body{padding:2rem 0 4rem}
 .tk-list{background:var(--bg-card);border:1px solid rgba(184,115,51,.14)}
 .tk-item{display:flex;align-items:center;justify-content:space-between;padding:1.25rem 1.5rem;border-bottom:1px solid rgba(184,115,51,.1)}
 .tk-item:last-child{border-bottom:none}
 .tk-user-link{display:flex;align-items:center;gap:1rem}
 .tk-avatar{width:3.5rem;height:3.5rem;border-radius:50%;background:linear-gradient(135deg,var(--public-accent-strong),var(--public-accent));display:flex;align-items:center;justify-content:center;color:var(--public-text);font-size:1.1rem;font-weight:700;flex-shrink:0;overflow:hidden}
 .tk-avatar-img{width:100%;height:100%;object-fit:cover;border-radius:50%}
 .tk-name{font-weight:700;color:var(--public-text);transition:color .15s;font-size:.95rem}
 .tk-user-link:hover .tk-name{color:var(--public-accent)}
 .tk-handle{font-size:.82rem;color:var(--public-text-soft);margin-top:.1rem}
 .tk-stats{font-size:.78rem;color:var(--public-muted);margin-top:.2rem}
 .tk-actions{display:flex;align-items:center;gap:.75rem;flex-shrink:0}
 .tk-mutual{font-size:.78rem;padding:.35rem .85rem;background:rgba(184,115,51,.08);color:var(--public-muted)}
 .tk-follow-btn{font-size:.8rem;padding:.35rem .85rem;background:var(--public-accent);color:var(--public-text);font-weight:600;cursor:pointer;border:none;transition:background .15s}
 .tk-follow-btn:hover{background:var(--public-accent-strong)}
 .tk-msg-btn{padding:.4rem;color:var(--public-muted);transition:color .15s}
 .tk-msg-btn:hover{color:var(--public-accent)}
 .tk-empty{text-align:center;padding:4rem 1rem}
 .tk-empty-emoji{font-size:3.5rem;display:block;margin-bottom:1rem}
 .tk-empty-title{font-size:1.1rem;font-weight:700;color:var(--public-text);margin-bottom:.5rem}
 .tk-empty-desc{color:var(--public-muted);margin-bottom:1.5rem;font-size:.88rem}
 .tk-share-btn{padding:.6rem 1.5rem;background:var(--public-accent);color:var(--public-text);font-size:.85rem;font-weight:600;cursor:pointer;border:none;transition:background .15s}
 .tk-share-btn:hover{background:var(--public-accent-strong)}
 </style>

 <div class="tk-page">
 <div class="tk-hero">
 <div class="sf-container">
 <div class="tk-inner">
 <div class="tk-hero-top">
 <div>
 <h1 class="tk-h1">Takipçiler</h1>
 <p class="tk-hero-desc">Seni takip eden {stats?.follower_count || 0} kişi</p>
 </div>
 <a href="/takip-edilenler" class="tk-link">Takip Edilenler →</a>
 </div>
 </div>
 </div>
 </div>

 <div class="tk-body">
 <div class="sf-container">
 <div class="tk-inner">
 {followers.length > 0 ? (
 <div class="tk-list">
 {followers.map(follower => (
 <div class="tk-item">
 <a href={`/kullanici/${follower.username || follower.id}`} class="tk-user-link">
 <div class="tk-avatar">
 {follower.avatar_url ? (
 <Image src={follower.avatar_url} alt={follower.full_name || 'Avatar'} width={56} height={56} class="tk-avatar-img" loading="lazy" />
 ) : (
 follower.full_name?.charAt(0).toUpperCase() || 'U'
 )}
 </div>
 <div>
 <p class="tk-name">{follower.full_name}</p>
 <p class="tk-handle">@{follower.username || 'kullanici'}</p>
 <p class="tk-stats">{follower.follower_count} takipçi · {follower.following_count} takip</p>
 </div>
 </a>

 <div class="tk-actions">
 {follower.friendship_status === 'mutual' ? (
 <span class="tk-mutual">Karşılıklı Takip</span>
 ) : follower.friendship_status === 'follows_you' ? (
 <button
 onclick={`followUser('${follower.id}')`}
 class="tk-follow-btn"
 >
 Takip Et
 </button>
 ) : null}
 <a href={`/mesajlar?user=${follower.id}`} class="tk-msg-btn" title="Mesaj gönder">
 <Icon name="lucide:message-circle" class="w-5 h-5" />
 </a>
 </div>
 </div>
 ))}
 </div>
 ) : (
 <div class="tk-empty">
 <span class="tk-empty-emoji">👥</span>
 <h3 class="tk-empty-title">Henüz takipçi yok</h3>
 <p class="tk-empty-desc">Profilinizi paylaşarak daha fazla kişiye ulaşın</p>
 <button onclick="shareProfile()" class="tk-share-btn">Profili Paylaş</button>
 </div>
 )}
 </div>
 </div>
 </div>
 </div>

 <script is:inline>
 window.followUser = async function (userId) {
 try {
 const response = await fetch('/api/social/follow', {
 method: 'POST',
 headers: { 'Content-Type': 'application/json' },
 body: JSON.stringify({ userId, action: 'follow' }),
 });

 if (response.ok) {
 window.location.reload();
 }
 } catch {
 window.toast?.error('Takip işlemi başarısız');
 }
 };

 window.shareProfile = function () {
 if (navigator.share) {
 navigator.share({
 title: 'Profilim - Şanlıurfa Rehberi',
 url: window.location.origin + '/profil',
 });
 } else {
 navigator.clipboard.writeText(window.location.origin + '/profil');
 window.toast?.success('Profil linki kopyalandı!');
 }
 };
 </script>
</Layout>
