---

import Layout from '../layouts/Layout.astro';
import { query } from '../lib/postgres';
import { getSiteBranding } from '../lib/site-branding';
const { baseUrl } = await getSiteBranding();

let kahvaltiMekanlari: any[] = [];
try {
  const result = await query(`
    SELECT p.id, p.slug, p.name, p.address, p.rating, p.review_count,
           c.name AS category_name
    FROM places p
    LEFT JOIN categories c ON p.category_id = c.id
    WHERE p.status = 'active'
      AND (
        c.slug ILIKE '%kahvalti%'
        OR c.slug ILIKE '%cafe%'
        OR p.name ILIKE '%kahvaltı%'
        OR p.name ILIKE '%kahvalti%'
        OR p.name ILIKE '%çay%'
      )
    ORDER BY p.rating DESC NULLS LAST, p.review_count DESC NULLS LAST
    LIMIT 20
  `);
  kahvaltiMekanlari = result.rows;
} catch (e) {
  console.error('Kahvaltı mekanları yüklenemedi:', e);
}

const seo = {
  title: 'Şanlıurfa Kahvaltı Mekanları | En İyi Kahvaltı Yerleri',
  description: 'Şanlıurfa\'da kahvaltı yapılacak en iyi mekanlar. Yöresel kahvaltı, çay bahçeleri ve sabah erken açık yerler.',
  keywords: ['şanlıurfa kahvaltı', 'urfa kahvaltı mekanları', 'şanlıurfa çay bahçesi', 'urfa sabah kahvaltı', 'şanlıurfa yöresel kahvaltı'],
  ogImage: '/images/hero/hero-food.webp',
  canonical: '/sanliurfa-kahvalti-mekanlari',
};

const faqItems = [
  {
    S: 'Şanlıurfa\'nın en iyi kahvaltı mekanları hangileri?',
    C: 'Şanlıurfa\'da kahvaltı için yöresel kahvaltı sofrası sunan mekanlar popülerdir. Tereyağı, bal, kaymak, çeşit peynirler ve Urfa biberiyle sunulan geleneksel kahvaltılar şehrin öne çıkan sabah deneyimleri arasındadır.',
  },
  {
    S: 'Şanlıurfa kahvaltısında neler yenir?',
    C: 'Urfa kahvaltısında genellikle çökelek peyniri, isot ile yapılmış peynirler, Urfa biberi, tereyağı, bal, zeytin ve simit bulunur. Çay bahçelerinde ise nane limon ve çay yaygın içeceklerdir.',
  },
  {
    S: 'Şanlıurfa\'da erken açılan kahvaltı yerleri var mı?',
    C: 'Evet. Özellikle tarihi çarşı çevresindeki bazı mekanlar sabah erken saatlerde açılır. Pazar günleri çarşı çevresinde de kahvaltı mekanları yoğun olur.',
  },
];
---


<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50">
    <div class="bg-gradient-to-br from-yellow-600 to-amber-700 text-white py-16">
      <div class="container mx-auto px-4 max-w-5xl">
        <p class="text-yellow-200 font-medium mb-2">Şanlıurfa Mekan Rehberi</p>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Şanlıurfa Kahvaltı Mekanları</h1>
        <p class="text-yellow-100 text-lg max-w-2xl">
          Şanlıurfa’nın zengin kahvaltı kültürünü yaşatan, tereyağı, bal, kaymak ve yöresel peynirlerle başlayan sabahlar için en iyi adresler.
        </p>
      </div>
    </div>

    <div class="container mx-auto px-4 max-w-5xl py-12">
      <div class="mb-8 bg-white rounded-xl p-5 shadow-sm border-l-4 border-yellow-500">
        <h2 class="font-bold text-gray-900 text-lg mb-1">Urfa Kahvaltı Kültürü</h2>
        <p class="text-gray-600 text-sm leading-relaxed">
          Şanlıurfa sabah sofrası; isot yağı, cevizli peynir, taze ekmek, tereyağı, bal ve sütlü çay ile doludur. Tarihi hanlar ve bahçeli mekanlarda sunulan Urfa kahvaltısı, şehrin en keyifli deneyimlerinden biridir.
        </p>
      </div>

      {kahvaltiMekanlari.length > 0 ? (
        <div class="grid md:grid-cols-2 gap-5">
          {kahvaltiMekanlari.map((place, i) => (
            <a href={`/isletme/${place.slug}`} class="bg-white rounded-xl overflow-hidden shadow-sm border hover:shadow-lg transition-all group flex">
              <div class="w-24 h-24 bg-yellow-100 shrink-0 flex items-center justify-center text-3xl font-bold text-yellow-700">
                {i < 3 ? ['🥇','🥈','🥉'][i] : '☕'}
              </div>
              <div class="p-4 flex-1">
                <h3 class="font-bold text-gray-900 group-hover:text-yellow-700 transition-colors">{place.name}</h3>
                <p class="text-xs text-gray-500 mt-0.5">{place.category_name || 'Kahvaltı'}</p>
                {place.address && <p class="text-sm text-gray-600 mt-1 line-clamp-1">{place.address}</p>}
                <div class="flex items-center gap-3 mt-2 text-sm">
                  {place.rating && <span class="text-yellow-600 font-semibold">★ {place.rating}</span>}
                  {place.review_count > 0 && <span class="text-gray-400">{place.review_count} yorum</span>}
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-16 text-gray-400">
          <p class="text-4xl mb-4">☕</p>
          <p>Kahvaltı mekanları yakında eklenecek.</p>
        </div>
      )}

      <div class="mt-10 flex flex-wrap gap-3">
        <a href="/mekanlar" class="px-5 py-2.5 rounded-full bg-yellow-600 text-white hover:bg-yellow-700 transition-colors font-medium">Tüm Mekanlar</a>
        <a href="/sanliurfada-ne-yenir" class="px-5 py-2.5 rounded-full border border-yellow-200 text-yellow-700 hover:bg-yellow-50 transition-colors">Şanlıurfa’da Ne Yenir? →</a>
      </div>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Şanlıurfa Kahvaltı Mekanları',
    description: 'Şanlıurfa\'nın en iyi kahvaltı yerleri',
    url: `${baseUrl}/sanliurfa-kahvalti-mekanlari`,
    itemListElement: kahvaltiMekanlari.slice(0, 10).map((p: any, i: number) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'CafeOrCoffeeShop',
        name: p.name,
        url: `${baseUrl}/isletme/${p.slug}`,
        address: { '@type': 'PostalAddress', addressLocality: 'Şanlıurfa', addressCountry: 'TR' },
        ...(p.rating && { aggregateRating: { '@type': 'AggregateRating', ratingValue: p.rating, reviewCount: p.review_count || 1 } }),
      },
    })),
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Yeme İçme', item: `${baseUrl}/yeme-icme` },
      { '@type': 'ListItem', position: 3, name: 'Kahvaltı Mekanları', item: `${baseUrl}/sanliurfa-kahvalti-mekanlari` },
    ],
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: { '@type': 'Answer', text: item.C },
    })),
  })} is:inline />
</Layout>
