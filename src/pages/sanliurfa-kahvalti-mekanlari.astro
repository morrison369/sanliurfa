---

import Layout from '../layouts/Layout.astro';
import RankedPlaceCard from '../components/landing/RankedPlaceCard.astro';
import { query } from '../lib/postgres';
import { getCachedPublicRouteData } from '../lib/public-route-cache';
import { getPublicAppUrl } from '../lib/public-app-url';
import { logger } from '../lib/logging';
import {
  buildItemListSchema,
  buildBreadcrumbSchema,
  buildFAQSchema,
  type LandingPlace,
} from '../lib/landing/landing-schema';
const baseUrl = getPublicAppUrl();

let kahvaltiMekanlari: LandingPlace[] = [];
try {
 kahvaltiMekanlari = await getCachedPublicRouteData('page:guide:sanliurfa-kahvalti-mekanlari', async () => {
  const result = await query(`
 SELECT p.id, p.slug, p.name, p.address, p.rating, p.review_count, p.image_url, p.images, p.short_description,
 c.name AS category_name
 FROM places p
 LEFT JOIN categories c ON p.category_id = c.id
 WHERE p.status = 'active'
 AND (
 c.slug ILIKE '%kahvalti%'
 OR c.slug ILIKE '%cafe%'
 OR p.name ILIKE '%kahvaltı%'
 OR p.name ILIKE '%kahvalti%'
 OR p.name ILIKE '%çay%'
 )
 ORDER BY p.rating DESC NULLS LAST, p.review_count DESC NULLS LAST
 LIMIT 20
 `);
  return result.rows;
 });
} catch (e) {
 logger.error('Kahvaltı mekanları yüklenemedi:', e instanceof Error ? e : new Error(String(e)));
}

const seo = {
 title: 'Şanlıurfa Kahvaltı Mekanları | En İyi Kahvaltı Yerleri',
 description: "Şanlıurfa'da kahvaltı yapılacak en iyi mekanlar. Yöresel kahvaltı, çay bahçeleri ve sabah erken açık yerler.",
 keywords: ['şanlıurfa kahvaltı', 'urfa kahvaltı mekanları', 'şanlıurfa çay bahçesi', 'urfa sabah kahvaltı', 'şanlıurfa yöresel kahvaltı'],
 ogImage: '/images/hero/hero-food.webp',
 canonical: '/sanliurfa-kahvalti-mekanlari',
};

const faqItems = [
 {
 S: "Şanlıurfa'nın en iyi kahvaltı mekanları hangileri?",
 C: "Şanlıurfa'da kahvaltı için yöresel kahvaltı sofrası sunan mekanlar popülerdir. Tereyağı, bal, kaymak, çeşit peynirler ve Urfa biberiyle sunulan geleneksel kahvaltılar öne çıkar.",
 },
 {
 S: "Şanlıurfa kahvaltısında neler yenir?",
 C: "Urfa kahvaltısında genellikle çökelek peyniri, isot ile yapılmış peynirler, Urfa biberi, tereyağı, bal, zeytin ve simit bulunur.",
 },
 {
 S: "Şanlıurfa'da erken açılan kahvaltı yerleri var mı?",
 C: "Evet. Özellikle tarihi çarşı çevresindeki bazı mekanlar sabah erken saatlerde açılır.",
 },
];
---

<Layout seo={seo}>
 <style is:inline>
 .km-hero{position:relative;overflow:hidden;border-bottom:1px solid rgba(184,115,51,0.12);padding:clamp(3rem,6vw,5rem) 0;background:radial-gradient(circle at 18% 0%,rgba(212,151,24,0.10) 0%,transparent 42%),radial-gradient(circle at 82% 100%,rgba(44,122,82,0.08) 0%,transparent 40%),linear-gradient(180deg,#fbf6ec 0%,#f4ecd8 58%,#fbf6ec 100%)}
 .km-hero-label{font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:#4A3828}
 .km-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.7rem,4vw,2.6rem);font-weight:700;color:#1F1410;margin:.75rem 0 .25rem}
 .km-hero-desc{color:#7A6B58;font-size:.9rem;max-width:40rem}
 .km-body{background:var(--bg);padding:2rem 0 4rem}
 .km-info{background:rgba(184,115,51,.05);border:1px solid rgba(184,115,51,.18);padding:1.25rem;margin-bottom:1.75rem}
 .km-info-h2{font-size:.9rem;font-weight:700;color:#1F1410;margin-bottom:.25rem}
 .km-info-p{font-size:.8rem;line-height:1.7;color:#7A6B58}
 .km-grid{display:grid;gap:1rem}
 @media(min-width:48rem){.km-grid{grid-template-columns:1fr 1fr}}
 .km-card{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);display:flex;overflow:hidden;transition:border-color .15s}
 .km-card:hover{border-color:#B87333}
 .km-card-rank{width:6rem;height:6rem;background:rgba(184,115,51,.1);display:flex;align-items:center;justify-content:center;font-size:1.5rem;font-weight:700;color:#B87333;flex-shrink:0}
 .km-card-body{padding:1rem;flex:1;min-width:0}
 .km-card-name{font-size:.9rem;font-weight:700;color:#1F1410;transition:color .15s}
 .km-card:hover .km-card-name{color:#B87333}
 .km-card-cat{font-size:.72rem;color:#7A6B58;margin-top:.15rem}
 .km-card-addr{font-size:.78rem;color:#7A6B58;margin-top:.4rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
 .km-card-meta{display:flex;align-items:center;gap:.75rem;margin-top:.5rem;font-size:.8rem}
 .km-rating{color:#B87333;font-weight:600}
 .km-reviews{color:#4A3828}
 .km-empty{text-align:center;padding:4rem 1rem;background:var(--bg-card);border:1px solid rgba(184,115,51,.14)}
 .km-empty-icon{font-size:2.5rem;margin-bottom:.75rem}
 .km-empty-txt{font-size:.9rem;color:#7A6B58}
 .km-cta{display:flex;flex-wrap:wrap;gap:.75rem;margin-top:2.5rem}
 .km-btn-primary{background:#B87333;color:#EDE0C6;font-size:.85rem;font-weight:600;padding:.65rem 1.25rem;transition:background .15s}
 .km-btn-primary:hover{background:#9D5F1A}
 .km-btn-outline{border:1px solid rgba(184,115,51,.25);color:#B87333;font-size:.85rem;font-weight:500;padding:.65rem 1.25rem;transition:border-color .15s,color .15s}
 .km-btn-outline:hover{border-color:#B87333;color:#1F1410}
 details summary{list-style:none}
 details summary::-webkit-details-marker{display:none}
 details[open] .faq-arrow{transform:rotate(180deg)}
 </style>

 <div class="km-hero">
 <div class="sf-container">
 <p class="km-hero-label">Şanlıurfa Mekan Rehberi</p>
 <h1 class="km-h1">Şanlıurfa Kahvaltı Mekanları</h1>
 <p class="km-hero-desc">Tereyağı, bal, kaymak ve yöresel peynirlerle başlayan sabahlar için en iyi adresler.</p>
 </div>
 </div>

 <div class="km-body">
 <div class="sf-container">
 <div class="km-info">
 <h2 class="km-info-h2">Urfa Kahvaltı Kültürü</h2>
 <p class="km-info-p">Şanlıurfa sabah sofrası; isot yağı, cevizli peynir, taze ekmek, tereyağı, bal ve sütlü çay ile doludur. Tarihi hanlar ve bahçeli mekanlarda sunulan Urfa kahvaltısı şehrin en keyifli deneyimlerinden biridir.</p>
 </div>

 {kahvaltiMekanlari.length > 0 ? (
 <div class="km-grid">
 {kahvaltiMekanlari.map((place, i) => (
 <RankedPlaceCard place={place} rank={i + 1} variant="restaurant" />
 ))}
 </div>
 ) : (
 <div class="km-empty">
 <div class="km-empty-icon">☕</div>
 <p class="km-empty-txt">Kahvaltı mekanları yakında eklenecek.</p>
 </div>
 )}

 <div class="km-cta">
 <a href="/mekanlar" class="km-btn-primary">Tüm Mekanlar</a>
 <a href="/sanliurfada-ne-yenir" class="km-btn-outline">Şanlıurfa'da Ne Yenir? →</a>
 </div>
 </div>
 </div>

 {faqItems.length > 0 && (
 <div style="padding:2rem 0 3rem;border-top:1px solid rgba(184,115,51,.12)">
 <div class="sf-container">
 <h2 style="font-size:1.25rem;font-weight:700;color:#1F1410;margin-bottom:1.25rem">Sık Sorulan Sorular</h2>
 <div style="display:flex;flex-direction:column;gap:.75rem">
 {faqItems.map((item) => (
 <details style="background:var(--bg-card);border:1px solid rgba(184,115,51,.14);border-radius:.375rem;overflow:hidden">
 <summary style="padding:1rem 1.25rem;font-weight:600;color:#1F1410;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:1rem">
 {item.S}
 <span style="flex-shrink:0;color:#B87333;font-size:1.25rem;transition:transform .2s" class="faq-arrow">▾</span>
 </summary>
 <div style="padding:.75rem 1.25rem 1rem;color:#4A3828;font-size:.95rem;line-height:1.7;border-top:1px solid rgba(184,115,51,.08)">
 {item.C}
 </div>
 </details>
 ))}
 </div>
 </div>
 </div>
 )}

 <script type="application/ld+json" set:html={JSON.stringify(buildItemListSchema({
 places: kahvaltiMekanlari,
 pageName: 'Şanlıurfa Kahvaltı Mekanları',
 pagePath: '/sanliurfa-kahvalti-mekanlari',
 baseUrl,
 type: 'CafeOrCoffeeShop',
 description: "Şanlıurfa'nın en iyi kahvaltı, çay ocağı ve cafe mekanları.",
 }))} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify(buildBreadcrumbSchema({
 baseUrl,
 crumbs: [
   { name: 'Ana Sayfa', href: '/' },
   { name: 'Yeme İçme', href: '/yeme-icme' },
   { name: 'Kahvaltı Mekanları', href: '/sanliurfa-kahvalti-mekanlari' },
 ],
 }))} is:inline />
 {(() => {
   const faqJson = buildFAQSchema(faqItems);
   return faqJson ? <script type="application/ld+json" set:html={JSON.stringify(faqJson)} is:inline /> : null;
 })()}
</Layout>
