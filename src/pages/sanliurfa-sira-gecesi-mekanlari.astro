---

import Layout from '../layouts/Layout.astro';
import RankedPlaceCard from '../components/landing/RankedPlaceCard.astro';
import { query } from '../lib/postgres';
import { getCachedPublicRouteData } from '../lib/public-route-cache';
import { getPublicAppUrl } from '../lib/public-app-url';
import { logger } from '../lib/logging';
import {
  buildItemListSchema,
  buildBreadcrumbSchema,
  buildFAQSchema,
  type LandingPlace,
} from '../lib/landing/landing-schema';
const baseUrl = getPublicAppUrl();

let siraMekanlari: LandingPlace[] = [];
try {
 siraMekanlari = await getCachedPublicRouteData('page:guide:sanliurfa-sira-gecesi-mekanlari', async () => {
  const result = await query(`
 SELECT p.slug, p.name, p.address, p.rating, p.review_count, p.image_url, p.images, p.short_description, c.name AS category_name
 FROM places p
 LEFT JOIN categories c ON p.category_id = c.id
 WHERE p.status = 'active'
 AND (
 p.name ILIKE '%sıra%'
 OR p.name ILIKE '%sira%'
 OR c.slug ILIKE '%eglence%'
 OR c.slug ILIKE '%muzik%'
 OR c.slug ILIKE '%kafeterya%'
 )
 ORDER BY p.rating DESC NULLS LAST, p.review_count DESC NULLS LAST
 LIMIT 20
 `);
  return result.rows;
 });
} catch (e) {
 logger.error('Sıra gecesi mekanları yüklenemedi:', e instanceof Error ? e : new Error(String(e)));
}

const seo = {
 title: 'Şanlıurfa Sıra Gecesi Mekanları | En İyi Sıra Gecesi Yerleri',
 description: "Şanlıurfa'nın geleneksel sıra gecesi kültürünü yaşatan mekanlar. Canlı müzik, yöresel yemek ve eğlence bir arada.",
 keywords: ['urfa sıra gecesi', 'şanlıurfa sıra gecesi mekanları', 'urfa geleneksel eğlence', 'şanlıurfa canlı müzik', 'urfa gece mekanları'],
 ogImage: '/images/hero/hero-food.webp',
 canonical: '/sanliurfa-sira-gecesi-mekanlari',
};

const faqItems = [
 {
 S: 'Şanlıurfa sıra gecesi nedir?',
 C: "Sıra gecesi, Şanlıurfa'ya özgü geleneksel bir eğlence kültürüdür. Misafirler sıra ile birbirinin evine ya da özel mekanlara gider; halk müziği, yöresel yemek ve sohbet bir arada sunulur.",
 },
 {
 S: "Şanlıurfa'da sıra gecesi mekanı nasıl bulunur?",
 C: "Şanlıurfa sıra gecesi mekanları rehberinde şehrin geleneksel eğlence noktalarına ulaşabilirsiniz. Rezervasyon yapılması önerilir.",
 },
 {
 S: 'Sıra gecesine yabancılar katılabilir mi?',
 C: "Evet. Şanlıurfa'yı ziyaret eden turistler de sıra gecelerine katılabilir.",
 },
];
---

<Layout seo={seo}>
 <style is:inline>
 .sg-hero{position:relative;overflow:hidden;border-bottom:1px solid rgba(184,115,51,0.12);padding:clamp(3rem,6vw,5rem) 0;background:radial-gradient(circle at 18% 0%,rgba(212,151,24,0.10) 0%,transparent 42%),radial-gradient(circle at 82% 100%,rgba(44,122,82,0.08) 0%,transparent 40%),linear-gradient(180deg,#fbf6ec 0%,#f4ecd8 58%,#fbf6ec 100%)}
 .sg-hero-label{font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:#4A3828}
 .sg-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.7rem,4vw,2.6rem);font-weight:700;color:#1F1410;margin:.75rem 0 .25rem}
 .sg-hero-desc{color:#7A6B58;font-size:.9rem;max-width:40rem}
 .sg-body{background:var(--bg);padding:2rem 0 4rem}
 .sg-info{background:rgba(184,115,51,.05);border:1px solid rgba(184,115,51,.18);padding:1.25rem;margin-bottom:1.75rem}
 .sg-info-h2{font-size:.9rem;font-weight:700;color:#1F1410;margin-bottom:.25rem}
 .sg-info-p{font-size:.8rem;line-height:1.7;color:#7A6B58}
 .sg-grid{display:grid;gap:1rem}
 @media(min-width:48rem){.sg-grid{grid-template-columns:1fr 1fr}}
 .sg-card{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);display:flex;overflow:hidden;transition:border-color .15s}
 .sg-card:hover{border-color:#B87333}
 .sg-card-icon{width:6rem;height:6rem;background:rgba(184,115,51,.1);display:flex;align-items:center;justify-content:center;font-size:1.75rem;flex-shrink:0}
 .sg-card-body{padding:1rem;flex:1;min-width:0}
 .sg-card-name{font-size:.9rem;font-weight:700;color:#1F1410;transition:color .15s}
 .sg-card:hover .sg-card-name{color:#B87333}
 .sg-card-cat{font-size:.72rem;color:#7A6B58;margin-top:.15rem}
 .sg-card-addr{font-size:.78rem;color:#7A6B58;margin-top:.4rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
 .sg-card-meta{display:flex;align-items:center;gap:.75rem;margin-top:.5rem;font-size:.8rem}
 .sg-rating{color:#B87333;font-weight:600}
 .sg-reviews{color:#4A3828}
 .sg-empty{text-align:center;padding:4rem 1rem;background:var(--bg-card);border:1px solid rgba(184,115,51,.14)}
 .sg-empty-icon{font-size:2.5rem;margin-bottom:.75rem}
 .sg-empty-txt{font-size:.9rem;color:#7A6B58}
 .sg-cta{display:flex;flex-wrap:wrap;gap:.75rem;margin-top:2.5rem}
 .sg-btn-primary{background:#B87333;color:#EDE0C6;font-size:.85rem;font-weight:600;padding:.65rem 1.25rem;transition:background .15s}
 .sg-btn-primary:hover{background:#9D5F1A}
 .sg-btn-outline{border:1px solid rgba(184,115,51,.25);color:#B87333;font-size:.85rem;font-weight:500;padding:.65rem 1.25rem;transition:border-color .15s,color .15s}
 .sg-btn-outline:hover{border-color:#B87333;color:#1F1410}
 details summary{list-style:none}
 details summary::-webkit-details-marker{display:none}
 details[open] .faq-arrow{transform:rotate(180deg)}
 </style>

 <div class="sg-hero">
 <div class="sf-container">
 <p class="sg-hero-label">Şanlıurfa Gece Hayatı</p>
 <h1 class="sg-h1">Sıra Gecesi Mekanları</h1>
 <p class="sg-hero-desc">Şanlıurfa'nın özgün gece kültürü: halk müziği, yöresel yemekler ve dost sohbeti.</p>
 </div>
 </div>

 <div class="sg-body">
 <div class="sf-container">
 <div class="sg-info">
 <h2 class="sg-info-h2">Sıra Gecesi Nedir?</h2>
 <p class="sg-info-p">Sıra gecesi, Şanlıurfa'ya özgü bir sosyalleşme geleneğidir. Dostlar bir araya gelir, yöresel yemekler yenir, türküler söylenir ve bağlama eşliğinde eğlenilir. Her hafta farklı bir mekanda sırayla düzenlenir.</p>
 </div>

 {siraMekanlari.length > 0 ? (
 <div class="sg-grid">
 {siraMekanlari.map((place, i) => (
 <RankedPlaceCard place={place} rank={i + 1} variant="restaurant" />
 ))}
 </div>
 ) : (
 <div class="sg-empty">
 <div class="sg-empty-icon">🎵</div>
 <p class="sg-empty-txt">Sıra gecesi mekanları yakında eklenecek.</p>
 </div>
 )}

 <div class="sg-cta">
 <a href="/mekanlar" class="sg-btn-primary">Tüm Mekanlar</a>
 <a href="/sanliurfa-gece-acik-mekanlar" class="sg-btn-outline">Gece Açık Mekanlar →</a>
 <a href="/bugun-sanliurfada-ne-yapilir" class="sg-btn-outline">Bugün Ne Yapılır? →</a>
 </div>
 </div>
 </div>

 {faqItems.length > 0 && (
 <div style="padding:2rem 0 3rem;border-top:1px solid rgba(184,115,51,.12)">
 <div class="sf-container">
 <h2 style="font-size:1.25rem;font-weight:700;color:#1F1410;margin-bottom:1.25rem">Sık Sorulan Sorular</h2>
 <div style="display:flex;flex-direction:column;gap:.75rem">
 {faqItems.map((item) => (
 <details style="background:var(--bg-card);border:1px solid rgba(184,115,51,.14);border-radius:.375rem;overflow:hidden">
 <summary style="padding:1rem 1.25rem;font-weight:600;color:#1F1410;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:1rem">
 {item.S}
 <span style="flex-shrink:0;color:#B87333;font-size:1.25rem;transition:transform .2s" class="faq-arrow">▾</span>
 </summary>
 <div style="padding:.75rem 1.25rem 1rem;color:#4A3828;font-size:.95rem;line-height:1.7;border-top:1px solid rgba(184,115,51,.08)">
 {item.C}
 </div>
 </details>
 ))}
 </div>
 </div>
 </div>
 )}

 <script type="application/ld+json" set:html={JSON.stringify(buildItemListSchema({
 places: siraMekanlari,
 pageName: 'Şanlıurfa Sıra Gecesi Mekanları',
 pagePath: '/sanliurfa-sira-gecesi-mekanlari',
 baseUrl,
 type: 'EntertainmentBusiness',
 description: "Şanlıurfa'da sıra gecesi yaşayabileceğiniz mekanlar — geleneksel müzik, oyun ve gastronomi.",
 }))} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify(buildBreadcrumbSchema({
 baseUrl,
 crumbs: [
   { name: 'Ana Sayfa', href: '/' },
   { name: 'Yeme İçme', href: '/yeme-icme' },
   { name: 'Sıra Gecesi Mekanları', href: '/sanliurfa-sira-gecesi-mekanlari' },
 ],
 }))} is:inline />
 {(() => {
   const faqJson = buildFAQSchema(faqItems);
   return faqJson ? <script type="application/ld+json" set:html={JSON.stringify(faqJson)} is:inline /> : null;
 })()}
</Layout>
