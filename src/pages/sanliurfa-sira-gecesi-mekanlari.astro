---

import Layout from '../layouts/Layout.astro';
import { query } from '../lib/postgres';
import { getSiteBranding } from '../lib/site-branding';
const { baseUrl } = await getSiteBranding();

let siraMekanlari: any[] = [];
try {
  const result = await query(`
    SELECT p.slug, p.name, p.address, p.rating, p.review_count, c.name AS category_name
    FROM places p
    LEFT JOIN categories c ON p.category_id = c.id
    WHERE p.status = 'active'
      AND (
        p.name ILIKE '%sıra%'
        OR p.name ILIKE '%sira%'
        OR c.slug ILIKE '%eglence%'
        OR c.slug ILIKE '%muzik%'
        OR c.slug ILIKE '%kafeterya%'
      )
    ORDER BY p.rating DESC NULLS LAST, p.review_count DESC NULLS LAST
    LIMIT 20
  `);
  siraMekanlari = result.rows;
} catch (e) {
  console.error('Sıra gecesi mekanları yüklenemedi:', e);
}

const seo = {
  title: 'Şanlıurfa Sıra Gecesi Mekanları | En İyi Sıra Gecesi Yerleri',
  description: 'Şanlıurfa\'nın geleneksel sıra gecesi kültürünü yaşatan mekanlar. Canlı müzik, yöresel yemek ve eğlence bir arada.',
  keywords: ['urfa sıra gecesi', 'şanlıurfa sıra gecesi mekanları', 'urfa geleneksel eğlence', 'şanlıurfa canlı müzik', 'urfa gece mekanları'],
  ogImage: '/images/hero/hero-food.webp',
  canonical: '/sanliurfa-sira-gecesi-mekanlari',
};

const faqItems = [
  {
    S: 'Şanlıurfa sıra gecesi nedir?',
    C: 'Sıra gecesi, Şanlıurfa\'ya özgü geleneksel bir eğlence kültürüdür. Misafirler sıra ile birbirinin evine ya da özel mekanlara gider; halk müziği, yöresel yemek ve sohbet bir arada sunulur.',
  },
  {
    S: 'Şanlıurfa\'da sıra gecesi mekanı nasıl bulunur?',
    C: 'Şanlıurfa sıra gecesi mekanları rehberinde şehrin geleneksel eğlence noktalarına ulaşabilirsiniz. Rezervasyon yapılması önerilir.',
  },
  {
    S: 'Sıra gecesine yabancılar katılabilir mi?',
    C: 'Evet. Şanlıurfa\'yı ziyaret eden turistler de sıra gecelerine katılabilir. Yerel bir davet veya rehber eşliğinde bu deneyimi yaşamak mümkündür.',
  },
];
---


<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50">
    <div class="bg-gradient-to-br from-purple-800 to-indigo-900 text-white py-16">
      <div class="container mx-auto px-4 max-w-5xl">
        <p class="text-purple-200 font-medium mb-2">Şanlıurfa Gece Hayatı</p>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Sıra Gecesi Mekanları</h1>
        <p class="text-purple-100 text-lg max-w-2xl">
          Şanlıurfa’nın özgün gece kültürü: sıra gecesi. Halk müziği, yöresel yemekler ve dost sohbeti bir arada.
        </p>
      </div>
    </div>

    <div class="container mx-auto px-4 max-w-5xl py-12">
      <div class="mb-8 bg-white rounded-xl p-5 shadow-sm border-l-4 border-purple-600">
        <h2 class="font-bold text-gray-900 text-lg mb-1">Sıra Gecesi Nedir?</h2>
        <p class="text-gray-600 text-sm leading-relaxed">
          Sıra gecesi, Şanlıurfa’ya özgü bir sosyalleşme geleneğidir. Dostlar bir araya gelir, yöresel yemekler yenir, türküler söylenir ve bağlama eşliğinde eğlenilir. Her hafta farklı bir ev veya mekanda sırayla düzenlenir; bu yüzden "sıra gecesi" adını almıştır.
        </p>
      </div>

      {siraMekanlari.length > 0 ? (
        <div class="grid md:grid-cols-2 gap-5">
          {siraMekanlari.map((place) => (
            <a href={`/isletme/${place.slug}`} class="bg-white rounded-xl overflow-hidden shadow-sm border hover:shadow-lg transition-all group flex">
              <div class="w-24 h-24 bg-purple-100 shrink-0 flex items-center justify-center text-3xl">🎵</div>
              <div class="p-4 flex-1">
                <h3 class="font-bold text-gray-900 group-hover:text-purple-600 transition-colors">{place.name}</h3>
                <p class="text-xs text-gray-500 mt-0.5">{place.category_name || 'Eğlence'}</p>
                {place.address && <p class="text-sm text-gray-600 mt-1 line-clamp-1">{place.address}</p>}
                <div class="flex items-center gap-3 mt-2 text-sm">
                  {place.rating && <span class="text-yellow-600 font-semibold">★ {place.rating}</span>}
                  {place.review_count > 0 && <span class="text-gray-400">{place.review_count} yorum</span>}
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-16 text-gray-400">
          <p class="text-4xl mb-4">🎵</p>
          <p>Sıra gecesi mekanları yakında eklenecek.</p>
        </div>
      )}

      <div class="mt-10 flex flex-wrap gap-3">
        <a href="/mekanlar" class="px-5 py-2.5 rounded-full bg-purple-700 text-white hover:bg-purple-800 transition-colors font-medium">Tüm Mekanlar</a>
        <a href="/sanliurfa-gece-acik-mekanlar" class="px-5 py-2.5 rounded-full border border-purple-200 text-purple-700 hover:bg-purple-50 transition-colors">Gece Açık Mekanlar →</a>
        <a href="/bugun-sanliurfada-ne-yapilir" class="px-5 py-2.5 rounded-full border border-gray-200 text-gray-700 hover:bg-gray-50 transition-colors">Bugün Ne Yapılır? →</a>
      </div>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Şanlıurfa Sıra Gecesi Mekanları',
    description: 'Şanlıurfa\'da sıra gecesi yaşayabileceğiniz mekanlar listesi',
    url: `${baseUrl}/sanliurfa-sira-gecesi-mekanlari`,
    itemListElement: siraMekanlari.slice(0, 10).map((p: any, i: number) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'EntertainmentBusiness',
        name: p.name,
        url: `${baseUrl}/isletme/${p.slug}`,
        address: { '@type': 'PostalAddress', addressLocality: 'Şanlıurfa', addressCountry: 'TR' },
      },
    })),
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Yeme İçme', item: `${baseUrl}/yeme-icme` },
      { '@type': 'ListItem', position: 3, name: 'Sıra Gecesi Mekanları', item: `${baseUrl}/sanliurfa-sira-gecesi-mekanlari` },
    ],
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: { '@type': 'Answer', text: item.C },
    })),
  })} is:inline />
</Layout>
