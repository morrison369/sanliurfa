---
import AdminLayout from '../../layouts/AdminLayout.astro';
---
<AdminLayout
  title="Sistem İzleme"
  subtitle="Gerçek zamanlı sistem durumu ve loglar"
>

    <div class="container mx-auto px-4 py-8">
      {/* System Stats */}
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6" id="systemStats">
        <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-4">
          <div class="text-sm text-[#9A8470]">Uptime</div>
          <div class="text-2xl font-bold text-[#1A1008]" id="uptime">-</div>
        </div>
        <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-4">
          <div class="text-sm text-[#9A8470]">Bellek Kullanımı</div>
          <div class="text-2xl font-bold text-[#1A1008]" id="memory">-</div>
        </div>
        <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-4">
          <div class="text-sm text-[#9A8470]">Veritabani</div>
          <div class="text-2xl font-bold text-[#1A1008]" id="dbSize">-</div>
        </div>
        <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-4">
          <div class="text-sm text-[#9A8470]">Node.js</div>
          <div class="text-2xl font-bold text-[#1A1008]" id="nodeVersion">-</div>
        </div>
      </div>

      {/* Error Stats */}
      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
          <h2 class="text-lg font-bold text-[#1A1008] mb-4">Son 24 Saat Loglari</h2>
          <div id="errorStats" class="space-y-3">
            <p class="text-[#9A8470]">Yükleniyor...</p>
          </div>
        </div>

        <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
          <h2 class="text-lg font-bold text-[#1A1008] mb-4">İstek İstatistikleri</h2>
          <div id="requestStats" class="space-y-3">
            <p class="text-[#9A8470]">Yükleniyor...</p>
          </div>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
          <h2 class="text-lg font-bold text-[#1A1008] mb-4">SLO Paneli (24 Saat)</h2>
          <div id="sloPanel" class="space-y-3">
            <p class="text-[#9A8470]">Yükleniyor...</p>
          </div>
        </div>
        <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
          <h2 class="text-lg font-bold text-[#1A1008] mb-4">Drift & Alarm</h2>
          <div class="mb-3 flex items-center gap-2">
            <input id="maintenanceMinutes" class="border border-[rgba(200,160,100,0.2)] rounded-sm px-2 py-1 text-xs w-28" value="60" />
            <button id="maintenanceBtn" class="rounded-sm border border-[rgba(200,160,100,0.2)] px-2 py-1 text-xs">Bakım Penceresi</button>
            <button id="maintenanceClearBtn" class="rounded-sm border border-[rgba(200,160,100,0.2)] px-2 py-1 text-xs">Bakımı Kaldır</button>
          </div>
          <div id="alarmPanel" class="space-y-3">
            <p class="text-[#9A8470]">Yükleniyor...</p>
          </div>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
          <h2 class="text-lg font-bold text-[#1A1008] mb-4">Upstream Sağlık (Transport/Weather)</h2>
          <div id="upstreamHealth" class="space-y-3">
            <p class="text-[#9A8470]">Yükleniyor...</p>
          </div>
        </div>
        <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
          <h2 class="text-lg font-bold text-[#1A1008] mb-4">Review Anti-Spam Sağlık</h2>
          <div id="reviewHealth" class="space-y-3">
            <p class="text-[#9A8470]">Yükleniyor...</p>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6 mb-6">
        <h2 class="text-lg font-bold text-[#1A1008] mb-4">Job Health (Retention / SLA / Report)</h2>
        <div id="jobHealth" class="grid md:grid-cols-4 gap-3">
          <p class="text-[#9A8470]">Yükleniyor...</p>
        </div>
        <div id="cronTrend" class="mt-4"></div>
      </div>

      {/* Recent Errors */}
      <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm overflow-hidden">
        <div class="p-6 border-b border-[rgba(200,160,100,0.14)]">
          <h2 class="text-lg font-bold text-[#1A1008]">Son Hatalar</h2>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-[rgba(200,160,100,0.04)]">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-[#9A8470]">Zaman</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-[#9A8470]">Seviye</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-[#9A8470]">Mesaj</th>
              </tr>
            </thead>
            <tbody id="recentErrors" class="divide-y divide-[rgba(200,160,100,0.1)]">
              <tr><td colspan="3" class="px-6 py-8 text-center text-[#9A8470]">Yükleniyor...</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      {/* Auto Refresh Toggle */}
      <div class="fixed bottom-6 right-6">
        <label class="flex items-center gap-2 bg-white px-4 py-2 rounded-sm border border-[rgba(200,160,100,0.2)] shadow-sm cursor-pointer">
          <input type="checkbox" id="autoRefresh" checked class="w-4 h-4 rounded-sm" />
          <span class="text-sm text-[#6B5540]">Oto Yenile (10s)</span>
        </label>
      </div>
    </div>

  <script is:inline>
    let autoRefreshInterval;
    const SLO_THRESHOLDS = {
      apiP95Ms: { greenMax: 600, yellowMax: 900 },
      errorRatio: { greenMax: 0.01, yellowMax: 0.03 },
      cacheHitRatio: { greenMin: 0.7, yellowMin: 0.5 },
      unreadDrift: { greenMax: 0, yellowMax: 3 },
      reviewFlagged24h: { greenMax: 10, yellowMax: 40 },
    };

    function severityByMax(value, greenMax, yellowMax) {
      if (value <= greenMax) return 'green';
      if (value <= yellowMax) return 'yellow';
      return 'red';
    }

    function severityByMin(value, greenMin, yellowMin) {
      if (value >= greenMin) return 'green';
      if (value >= yellowMin) return 'yellow';
      return 'red';
    }

    function cardClassBySeverity(level) {
      if (level === 'green') return 'bg-emerald-50 text-emerald-800';
      if (level === 'yellow') return 'bg-amber-50 text-amber-800';
      return 'bg-red-50 text-red-800';
    }

    async function loadMonitoring() {
      try {
        const response = await fetch('/api/admin/monitoring');
        const data = await response.json();

        if (data.success) {
          updateSystemStats(data.system, data.database);
          updateErrorStats(data.errors);
          updateRequestStats(data.requests);
          updateRecentErrors(data.recentErrors);
          updateUpstreamHealth(data.upstreamHealth);
          updateReviewHealth(data.reviews);
          updateJobHealth(data.jobs);
          updateSloPanel(data.slo);
          updateAlarmPanel(data.alarms);
          updateCronHealth(data.cronHealth);
        }
      } catch (err) {
        console.error('Monitoring load error:', err);
      }
    }

    function updateSystemStats(system, db) {
      const hours = Math.floor(system.uptime / 3600);
      const minutes = Math.floor((system.uptime % 3600) / 60);
      
      document.getElementById('uptime').textContent = `${hours}s ${minutes}d`;
      document.getElementById('memory').textContent = `${system.memory.used}/${system.memory.total} MB`;
      document.getElementById('dbSize').textContent = db.db_size;
      document.getElementById('nodeVersion').textContent = system.nodeVersion;
    }

    function updateErrorStats(errors) {
      const container = document.getElementById('errorStats');
      
      if (errors.length === 0) {
        container.innerHTML = '<p class="text-green-600">Son 24 saatte hata yok!</p>';
        return;
      }

      const colors = {
        fatal: 'bg-red-100 text-red-800',
        error: 'bg-orange-100 text-orange-800',
        warn: 'bg-yellow-100 text-yellow-800',
        info: 'bg-blue-100 text-blue-800'
      };

      container.replaceChildren(...errors.map(e => {
        const row = document.createElement('div');
        row.className = 'flex items-center justify-between p-3 bg-gray-50 rounded-lg';
        const left = document.createElement('div');
        left.className = 'flex items-center gap-2';
        const badge = document.createElement('span');
        badge.className = 'px-2 py-1 rounded-full text-xs font-medium ' + (colors[e.level] || 'bg-gray-100');
        badge.textContent = e.level;
        left.appendChild(badge);
        const count = document.createElement('span');
        count.className = 'font-bold text-gray-900';
        count.textContent = String(e.count);
        row.appendChild(left);
        row.appendChild(count);
        return row;
      }));
    }

    function updateRequestStats(requests) {
      const container = document.getElementById('requestStats');
      
      if (requests.length === 0) {
        container.innerHTML = '<p class="text-gray-400">Veri yok</p>';
        return;
      }

      container.replaceChildren(...requests.map(r => {
        const row = document.createElement('div');
        row.className = 'flex items-center justify-between p-3 bg-gray-50 rounded-lg';
        const left = document.createElement('div');
        const method = document.createElement('span');
        method.className = 'font-medium text-gray-900';
        method.textContent = r.method || 'UNKNOWN';
        const cnt = document.createElement('span');
        cnt.className = 'text-gray-500 text-sm';
        cnt.textContent = ' — ' + r.count + ' istek';
        left.appendChild(method);
        left.appendChild(cnt);
        const dur = document.createElement('span');
        dur.className = 'text-sm text-gray-600';
        dur.textContent = Math.round(r.avg_duration || 0) + 'ms ort.';
        row.appendChild(left);
        row.appendChild(dur);
        return row;
      }));
    }

    function updateRecentErrors(errors) {
      const tbody = document.getElementById('recentErrors');
      
      if (errors.length === 0) {
        tbody.innerHTML = '<tr><td colspan="3" class="px-6 py-8 text-center text-gray-400">Son 24 saatte hata yok</td></tr>';
        return;
      }

      tbody.replaceChildren(...errors.map(e => {
        const tr = document.createElement('tr');
        tr.className = 'hover:bg-gray-50';
        const td1 = document.createElement('td');
        td1.className = 'px-4 py-3 text-sm text-gray-600';
        td1.textContent = new Date(e.created_at).toLocaleTimeString('tr-TR');
        const td2 = document.createElement('td');
        td2.className = 'px-4 py-3';
        const badge = document.createElement('span');
        badge.className = 'px-2 py-1 rounded-full text-xs font-medium ' + (e.level === 'fatal' ? 'bg-red-100 text-red-700' : 'bg-orange-100 text-orange-700');
        badge.textContent = e.level;
        td2.appendChild(badge);
        const td3 = document.createElement('td');
        td3.className = 'px-4 py-3 text-sm text-gray-700 max-w-md truncate';
        td3.textContent = e.message;
        tr.appendChild(td1);
        tr.appendChild(td2);
        tr.appendChild(td3);
        return tr;
      }));
    }

    function updateUpstreamHealth(upstream) {
      const container = document.getElementById('upstreamHealth');
      const transport = upstream?.transport || {};
      const weather = upstream?.weather || {};
      function makeInfoCard(title, rows) {
        const card = document.createElement('div');
        card.className = 'p-3 bg-gray-50 rounded-lg';
        const h = document.createElement('div');
        h.className = 'text-sm font-semibold text-gray-800';
        h.textContent = title;
        card.appendChild(h);
        rows.forEach(([label, value]) => {
          const d = document.createElement('div');
          d.className = 'text-xs text-gray-600';
          d.textContent = label + ': ' + value;
          card.appendChild(d);
        });
        return card;
      }
      container.replaceChildren(
        makeInfoCard('Transport', [
          ['updatedAt', transport.updatedAt || '-'],
          ['healthyProviders', transport.healthyProviders ?? '-'],
        ]),
        makeInfoCard('Hava Durumu', [
          ['güncelleme', weather.updatedAt || '-'],
          ['kaynak', weather.source || '-'],
          ['cache', weather.fromCache ? 'evet' : 'hayır'],
        ]),
      );
    }

    function updateReviewHealth(reviews) {
      const container = document.getElementById('reviewHealth');
      const antiSpam = reviews?.antiSpam || {};
      const statusCounts = reviews?.statusCounts || {};
      function rhCard(title, rows) {
        const card = document.createElement('div');
        card.className = 'p-3 bg-gray-50 rounded-lg';
        const h = document.createElement('div');
        h.className = 'text-sm font-semibold text-gray-800';
        h.textContent = title;
        card.appendChild(h);
        rows.forEach((text) => {
          const d = document.createElement('div');
          d.className = 'text-xs text-gray-600';
          d.textContent = text;
          card.appendChild(d);
        });
        return card;
      }
      container.replaceChildren(
        rhCard('Durum Dağılımı', [
          'aktif: ' + (statusCounts.active || 0) + ' / beklemede: ' + (statusCounts.pending || 0),
        ]),
        rhCard('Anti-Spam Eşikler', [
          'aktif: ' + (antiSpam.enabled ? 'evet' : 'hayır'),
          'otomatik moderasyon: ' + (antiSpam.autoModerateThreshold ?? '-') + ' / kesin blok: ' + (antiSpam.hardBlockThreshold ?? '-'),
        ]),
      );
    }

    function updateJobHealth(jobs) {
      const container = document.getElementById('jobHealth');
      const jobList = [
        { key: 'socialRetention', label: 'Sosyal Retention' },
        { key: 'placesSlaAlert', label: 'Mekan SLA Alarmı' },
        { key: 'socialLifecycleReport', label: 'Sosyal Yaşam Döngüsü Raporu' },
        { key: 'socialArchivePartitions', label: 'Arşiv Partitionları' },
        { key: 'socialArchivePartitionsDaily', label: 'Günlük Arşiv Wrapper' },
      ];
      container.replaceChildren(...jobList.map((x) => {
        const row = jobs?.[x.key] || null;
        const updatedAt = row?.at || row?.generatedAt || row?.finishedAt || '-';
        const ok = !!row?.success;
        const stale = updatedAt !== '-' ? (Date.now() - new Date(updatedAt).getTime()) > 36 * 60 * 60 * 1000 : true;
        const cls = !ok ? 'bg-red-50 text-red-800' : stale ? 'bg-amber-50 text-amber-800' : 'bg-emerald-50 text-emerald-800';
        const card = document.createElement('div');
        card.className = 'p-3 rounded-lg ' + cls;
        const labelEl = document.createElement('div');
        labelEl.className = 'text-sm font-semibold';
        labelEl.textContent = x.label;
        const succEl = document.createElement('div');
        succEl.className = 'text-xs';
        succEl.textContent = 'başarılı: ' + (ok ? 'evet' : 'hayır');
        const staleEl = document.createElement('div');
        staleEl.className = 'text-xs';
        staleEl.textContent = 'stale: ' + (stale ? 'evet' : 'hayır');
        const updEl = document.createElement('div');
        updEl.className = 'text-xs';
        updEl.textContent = 'updatedAt: ' + updatedAt;
        card.appendChild(labelEl);
        card.appendChild(succEl);
        card.appendChild(staleEl);
        card.appendChild(updEl);
        return card;
      }));
    }

    function updateSloPanel(slo) {
      const container = document.getElementById('sloPanel');
      const p95 = Math.round(slo?.apiP95Ms || 0);
      const errorRatio = Number(slo?.errorRatio || 0);
      const cacheHitRatio = slo?.cacheHitRatio === null || slo?.cacheHitRatio === undefined ? null : Number(slo.cacheHitRatio);
      const p95Severity = severityByMax(p95, SLO_THRESHOLDS.apiP95Ms.greenMax, SLO_THRESHOLDS.apiP95Ms.yellowMax);
      const errorSeverity = severityByMax(
        errorRatio,
        SLO_THRESHOLDS.errorRatio.greenMax,
        SLO_THRESHOLDS.errorRatio.yellowMax
      );
      const cacheSeverity =
        cacheHitRatio === null
          ? 'yellow'
          : severityByMin(cacheHitRatio, SLO_THRESHOLDS.cacheHitRatio.greenMin, SLO_THRESHOLDS.cacheHitRatio.yellowMin);

      function sloCard(severity, title, value, target) {
        const card = document.createElement('div');
        card.className = 'p-3 rounded-lg ' + cardClassBySeverity(severity);
        const h = document.createElement('div'); h.className = 'text-sm font-semibold'; h.textContent = title;
        const v = document.createElement('div'); v.className = 'text-xs'; v.textContent = value;
        const t = document.createElement('div'); t.className = 'text-[11px]'; t.textContent = target;
        card.appendChild(h); card.appendChild(v); card.appendChild(t);
        return card;
      }
      container.replaceChildren(
        sloCard(p95Severity, 'API p95', p95 + ' ms', 'hedef: ≤ ' + SLO_THRESHOLDS.apiP95Ms.greenMax + ' ms'),
        sloCard(errorSeverity, 'Hata Oranı', (errorRatio * 100).toFixed(2) + '%', 'hedef: ≤ ' + (SLO_THRESHOLDS.errorRatio.greenMax * 100).toFixed(2) + '%'),
        sloCard(cacheSeverity, 'Önbellek İsabet Oranı', cacheHitRatio === null ? '-' : (cacheHitRatio * 100).toFixed(2) + '%', 'hedef: ≥ ' + (SLO_THRESHOLDS.cacheHitRatio.greenMin * 100).toFixed(0) + '%'),
      );
    }

    function updateAlarmPanel(alarms) {
      const container = document.getElementById('alarmPanel');
      const unreadDrift = Number(alarms?.unreadDriftConversations || 0);
      const reviewFlagged = Number(alarms?.reviewFlaggedLast24h || 0);
      const cronFailureCount = Number(alarms?.cronFailureCount || 0);
      const cronStaleCount = Number(alarms?.cronStaleCount || 0);
      const driftSeverity = severityByMax(
        unreadDrift,
        SLO_THRESHOLDS.unreadDrift.greenMax,
        SLO_THRESHOLDS.unreadDrift.yellowMax
      );
      const reviewSeverity = severityByMax(
        reviewFlagged,
        SLO_THRESHOLDS.reviewFlagged24h.greenMax,
        SLO_THRESHOLDS.reviewFlagged24h.yellowMax
      );
      const cronFailureSeverity = severityByMax(cronFailureCount, 0, 1);
      const cronStaleSeverity = severityByMax(cronStaleCount, 0, 2);
      const ack = alarms?.acknowledged || {};
      const suppressed = alarms?.suppressed || {};
      function makeAlarmCard(severity, title, value, target, alarmKey, isSuppressed, ackAt, resolvedAt) {
        const card = document.createElement('div');
        card.className = 'p-3 rounded-lg ' + cardClassBySeverity(severity);
        const h = document.createElement('div'); h.className = 'text-sm font-semibold'; h.textContent = title;
        const v = document.createElement('div'); v.className = 'text-xs'; v.textContent = value;
        const t = document.createElement('div'); t.className = 'text-[11px]'; t.textContent = target;
        const ackBtn = document.createElement('button');
        ackBtn.className = 'mt-2 rounded border border-current px-2 py-1 text-[11px]';
        ackBtn.textContent = 'Onayla';
        ackBtn.addEventListener('click', async () => {
          await fetch('/api/admin/monitoring/ack', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ alarmKey }) });
          await loadMonitoring();
        });
        const snoozeBtn = document.createElement('button');
        snoozeBtn.className = 'mt-2 ml-1 rounded border border-current px-2 py-1 text-[11px]';
        snoozeBtn.textContent = '30 dk ertele';
        snoozeBtn.addEventListener('click', async () => {
          await fetch('/api/admin/monitoring/ack', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ alarmKey, mode: 'snooze', snoozeMinutes: 30 }) });
          await loadMonitoring();
        });
        const suppEl = document.createElement('div'); suppEl.className = 'text-[10px] mt-1'; suppEl.textContent = isSuppressed ? 'ertelendi' : '';
        const ackEl = document.createElement('div'); ackEl.className = 'text-[10px] mt-1'; ackEl.textContent = ackAt ? 'onay: ' + new Date(ackAt).toLocaleString('tr-TR') : '';
        const resEl = document.createElement('div'); resEl.className = 'text-[10px]'; resEl.textContent = resolvedAt ? 'çözüldü: ' + new Date(resolvedAt).toLocaleString('tr-TR') : '';
        card.appendChild(h); card.appendChild(v); card.appendChild(t);
        card.appendChild(ackBtn); card.appendChild(snoozeBtn);
        card.appendChild(suppEl); card.appendChild(ackEl); card.appendChild(resEl);
        return card;
      }
      container.replaceChildren(
        makeAlarmCard(driftSeverity, 'Okunmamış Mesaj Sapması', unreadDrift + ' konuşma', 'hedef: ≤ ' + SLO_THRESHOLDS.unreadDrift.greenMax, 'unreadDriftConversations', suppressed.unreadDriftConversations, ack.unreadDrift?.at, ack.unreadDrift?.resolvedAt),
        makeAlarmCard(reviewSeverity, 'İşaretlenen Yorum (24s)', reviewFlagged + ' olay', 'hedef: ≤ ' + SLO_THRESHOLDS.reviewFlagged24h.greenMax, 'reviewFlaggedLast24h', suppressed.reviewFlaggedLast24h, ack.reviewFlagged?.at, ack.reviewFlagged?.resolvedAt),
        makeAlarmCard(cronFailureSeverity, 'Cron Hataları', cronFailureCount + ' görev', 'hedef: 0', 'cronFailureCount', suppressed.cronFailureCount, ack.cronFailure?.at, ack.cronFailure?.resolvedAt),
        makeAlarmCard(cronStaleSeverity, 'Cron Gecikmesi', cronStaleCount + ' görev', 'hedef: 0-2', 'cronStaleCount', suppressed.cronStaleCount, ack.cronStale?.at, ack.cronStale?.resolvedAt),
      );
    }

    function updateCronHealth(cronHealth) {
      const trend = document.getElementById('cronTrend');
      const days = Array.isArray(cronHealth?.history) ? cronHealth.history : [];
      if (!days.length) {
        trend.innerHTML = '<p class="text-xs text-gray-400">7 günlük trend yok</p>';
        return;
      }
      const trendTitle = document.createElement('div');
      trendTitle.className = 'text-xs font-semibold text-gray-700 mb-2';
      trendTitle.textContent = 'Cron Health Trend (7 gün)';
      const barsRow = document.createElement('div');
      barsRow.className = 'flex items-end gap-2';
      days.forEach((d) => {
        const total = Math.max(1, (d.green || 0) + (d.yellow || 0) + (d.red || 0));
        const green = Math.round(((d.green || 0) / total) * 40);
        const yellow = Math.round(((d.yellow || 0) / total) * 40);
        const red = Math.round(((d.red || 0) / total) * 40);
        const col = document.createElement('div');
        col.className = 'flex flex-col items-center gap-1';
        const bar = document.createElement('div');
        bar.className = 'w-6 h-12 rounded border border-gray-200 overflow-hidden flex flex-col justify-end';
        const gEl = document.createElement('div'); gEl.className = 'bg-emerald-400'; gEl.style.height = green + 'px';
        const yEl = document.createElement('div'); yEl.className = 'bg-amber-400'; yEl.style.height = yellow + 'px';
        const rEl = document.createElement('div'); rEl.className = 'bg-red-400'; rEl.style.height = red + 'px';
        bar.appendChild(gEl); bar.appendChild(yEl); bar.appendChild(rEl);
        const dateEl = document.createElement('div');
        dateEl.className = 'text-[10px] text-gray-500';
        dateEl.textContent = String(d.date || '').slice(5);
        col.appendChild(bar); col.appendChild(dateEl);
        barsRow.appendChild(col);
      });
      trend.replaceChildren(trendTitle, barsRow);
    }

    function startAutoRefresh() {
      if (autoRefreshInterval) clearInterval(autoRefreshInterval);
      autoRefreshInterval = setInterval(loadMonitoring, 10000);
    }

    function stopAutoRefresh() {
      if (autoRefreshInterval) {
        clearInterval(autoRefreshInterval);
        autoRefreshInterval = null;
      }
    }

    document.getElementById('autoRefresh').addEventListener('change', (e) => {
      if (e.target.checked) {
        startAutoRefresh();
      } else {
        stopAutoRefresh();
      }
    });
    document.getElementById('maintenanceBtn').addEventListener('click', async () => {
      const maintenanceMinutes = Number(document.getElementById('maintenanceMinutes').value || 60);
      await fetch('/api/admin/monitoring/ack', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ mode: 'maintenance', maintenanceMinutes }),
      });
      await loadMonitoring();
    });
    document.getElementById('maintenanceClearBtn').addEventListener('click', async () => {
      await fetch('/api/admin/monitoring/ack', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ mode: 'clear', clearMaintenance: true }),
      });
      await loadMonitoring();
    });

    // Initial load
    loadMonitoring();
    startAutoRefresh();

    // Cleanup on page unload
    window.addEventListener('beforeunload', stopAutoRefresh);
  </script>
</AdminLayout>
