---
import AdminLayout from '../../../layouts/AdminLayoutV2.astro';
import AdminLoyaltyPanel from '../../../components/AdminLoyaltyPanel';
---

<AdminLayout
 title="Sadakat Yönetimi"
 subtitle="Ödüller, puanlar ve rozetleri yönet"
 seo={{ title: 'Sadakat Yönetimi - Admin', noIndex: true }}
>
 <div class="ly-page">
  <div class="ly-panel">
   <AdminLoyaltyPanel client:idle />
  </div>
 </div>
</AdminLayout>

<style>
 .ly-page { display: flex; flex-direction: column; gap: 1rem; }
 .ly-panel {
  background: var(--adm-bg-elev);
  border: 1px solid var(--adm-border);
  border-radius: 12px;
  padding: 1.25rem;
 }
</style>
