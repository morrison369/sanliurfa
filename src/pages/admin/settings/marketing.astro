---
import AdminLayout from '../../../layouts/AdminLayoutV2.astro';
import { query } from '../../../lib/postgres';

const user = Astro.locals.user;
if (!user || user.role !== 'admin') {
 return Astro.redirect(`/giris?redirect=${Astro.url.pathname}`);
}

// Mevcut site_settings değerlerini oku
async function readSetting<T extends object>(key: string): Promise<T> {
 try {
  const row = await query<{ value: any }>(`SELECT value FROM site_settings WHERE key = $1 LIMIT 1`, [key]);
  return (row.rows[0]?.value as T) || ({} as T);
 } catch {
  return {} as T;
 }
}

const verification = await readSetting<{ gsc?: string; bing?: string }>('integrations.verification');
const clarity = await readSetting<{ clarity_id?: string }>('integrations.clarity');
const yandex = await readSetting<{ metrica_id?: string }>('integrations.yandex');

const saved = Astro.url.searchParams.get('saved') === '1';
---

<AdminLayout title="Marketing & Tracking" subtitle="Analitik, doğrulama ve tracking ID yönetimi">
 <div class="sf-container py-8 max-w-3xl">
  <div class="mb-6">
   <a href="/admin/integrations" class="text-sm text-[#7A6B58] hover:text-[#7A6B58]">← Entegrasyonlar</a>
  </div>

  {saved && (
   <div class="mb-4 rounded border border-green-700/30 bg-green-900/10 px-4 py-3 text-sm text-green-700">
    ✓ Ayarlar kaydedildi. Site bir sonraki sayfa yüklemesinde yeni değerleri kullanır.
   </div>
  )}

  <form method="POST" action="/api/admin/settings/marketing" class="space-y-6">
   <section class="rounded border border-[var(--adm-border-strong)] bg-[var(--bg-card)] p-5">
    <h2 class="mb-1 text-lg font-bold text-[#1F1410]">Search Console Doğrulama</h2>
    <p class="mb-4 text-xs text-[#7A6B58]">Google Search Console + Bing Webmaster meta tag doğrulama kodları. Boş bırakılırsa render edilmez.</p>
    <div class="grid gap-4 sm:grid-cols-2">
     <label class="block">
      <span class="mb-1 block text-xs font-semibold text-[#7A6B58]">Google Search Console</span>
      <input type="text" name="gsc" value={verification.gsc || ''} placeholder="abc123..." class="w-full rounded border border-[var(--adm-border-strong)] bg-transparent px-3 py-2 text-sm" />
     </label>
     <label class="block">
      <span class="mb-1 block text-xs font-semibold text-[#7A6B58]">Bing Webmaster (msvalidate.01)</span>
      <input type="text" name="bing" value={verification.bing || ''} placeholder="xyz789..." class="w-full rounded border border-[var(--adm-border-strong)] bg-transparent px-3 py-2 text-sm" />
     </label>
    </div>
   </section>

   <section class="rounded border border-[var(--adm-border-strong)] bg-[var(--bg-card)] p-5">
    <h2 class="mb-1 text-lg font-bold text-[#1F1410]">Microsoft Clarity</h2>
    <p class="mb-4 text-xs text-[#7A6B58]">Heatmap + session recording. Boş bırakılırsa varsayılan (env veya hardcoded) kullanılır.</p>
    <label class="block">
     <span class="mb-1 block text-xs font-semibold text-[#7A6B58]">Clarity Project ID</span>
     <input type="text" name="clarity_id" value={clarity.clarity_id || ''} placeholder="wq08o4hm02" class="w-full rounded border border-[var(--adm-border-strong)] bg-transparent px-3 py-2 text-sm" />
    </label>
   </section>

   <section class="rounded border border-[var(--adm-border-strong)] bg-[var(--bg-card)] p-5">
    <h2 class="mb-1 text-lg font-bold text-[#1F1410]">Yandex Metrica</h2>
    <p class="mb-4 text-xs text-[#7A6B58]">TR + RU pazar için ek analytics. Boş bırakılırsa render edilmez.</p>
    <label class="block">
     <span class="mb-1 block text-xs font-semibold text-[#7A6B58]">Yandex Counter ID</span>
     <input type="text" name="metrica_id" value={yandex.metrica_id || ''} placeholder="12345678" class="w-full rounded border border-[var(--adm-border-strong)] bg-transparent px-3 py-2 text-sm" />
    </label>
   </section>

   <div class="flex items-center justify-between">
    <p class="text-xs text-[#7A6B58]">Değişiklikler hemen aktif olur, rebuild gerekmez.</p>
    <button type="submit" class="rounded bg-gradient-to-r from-[#C0571F] to-[#D49718] px-5 py-2 text-sm font-bold text-white">
     Kaydet
    </button>
   </div>
  </form>
 </div>
</AdminLayout>
