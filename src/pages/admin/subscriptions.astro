---
import AdminLayout from '../../layouts/AdminLayout.astro';
import SubscriptionAdminDashboard from '../../components/SubscriptionAdminDashboard';
---

<AdminLayout
  title="Abonelik Yönetimi"
  subtitle="Tüm abonelik sistemi, ödemeler ve müşteri verilerini yönetin"
  seo={{ title: 'Abonelik Yönetimi - Admin' }}
>
    <div class="container mx-auto px-4 py-8">
      <SubscriptionAdminDashboard client:visible />

      <div class="mt-8 grid grid-cols-2 md:grid-cols-4 gap-4">
        <a href="/admin" class="p-4 bg-white rounded-sm border border-[rgba(200,160,100,0.18)] hover:shadow-sm transition">
          <h3 class="font-semibold text-[#1A1008]">← Yönetim Paneli</h3>
        </a>
        <a href="/admin/users" class="p-4 bg-white rounded-sm border border-[rgba(200,160,100,0.18)] hover:shadow-sm transition">
          <h3 class="font-semibold text-[#1A1008]">Kullanıcılar</h3>
        </a>
        <a href="/admin/analytics" class="p-4 bg-white rounded-sm border border-[rgba(200,160,100,0.18)] hover:shadow-sm transition">
          <h3 class="font-semibold text-[#1A1008]">Analitik</h3>
        </a>
        <a href="/admin/audit-logs" class="p-4 bg-white rounded-sm border border-[rgba(200,160,100,0.18)] hover:shadow-sm transition">
          <h3 class="font-semibold text-[#1A1008]">Denetim Logları</h3>
        </a>
      </div>
    </div>
</AdminLayout>
