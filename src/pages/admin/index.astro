            </a>
            <a href="/admin/blog" class="flex items-center gap-3 p-3 rounded-sm bg-[rgba(200,160,100,0.04)] hover:bg-[rgba(200,160,100,0.08)] transition-colors">
              <span class="w-10 h-10 bg-[rgba(200,160,100,0.1)] rounded-sm flex items-center justify-center">📝</span>
              <div>
                <div class="font-medium text-[#1A1008]">Blog</div>
                <div class="text-sm text-[#9A8470]">İçerik yönetimi</div>
