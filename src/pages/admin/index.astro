---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout
  title="Yönetim Paneli"
  subtitle="Platform genel görünümü"
  seo={{ title: 'Yönetim Paneli - Sanliurfa.com', description: 'Yönetim paneli', noIndex: true }}
>
    <div class="container mx-auto px-4 py-8">
      {/* Stats Grid */}
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6" id="statsGrid">
        <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-5">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm text-[#9A8470]">Toplam Kullanıcı</p>
              <p class="text-2xl font-bold text-[#1A1008] mt-1" id="totalUsers">-</p>
            </div>
            <div class="w-12 h-12 bg-[rgba(200,160,100,0.1)] rounded-sm flex items-center justify-center text-2xl">
              👥
            </div>
          </div>
          <p class="text-xs text-[#6B5540] mt-2">+<span id="newUsers">-</span> bu ay</p>
        </div>

        <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-5">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm text-[#9A8470]">İşletmeler</p>
              <p class="text-2xl font-bold text-[#1A1008] mt-1" id="totalPlaces">-</p>
            </div>
            <div class="w-12 h-12 bg-[rgba(200,160,100,0.1)] rounded-sm flex items-center justify-center text-2xl">
              🏪
            </div>
          </div>
          <p class="text-xs text-[#9A8470] mt-2"><span id="pendingPlaces">-</span> onay bekliyor</p>
        </div>

        <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-5">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm text-[#9A8470]">Yorumlar</p>
              <p class="text-2xl font-bold text-[#1A1008] mt-1" id="totalReviews">-</p>
            </div>
            <div class="w-12 h-12 bg-[rgba(200,160,100,0.1)] rounded-sm flex items-center justify-center text-2xl">
              ⭐
            </div>
          </div>
          <p class="text-xs text-[#9A8470] mt-2"><span id="pendingReviews">-</span> onay bekliyor</p>
        </div>

        <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-5">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm text-[#9A8470]">Açık Ticketlar</p>
              <p class="text-2xl font-bold text-[#1A1008] mt-1" id="openTickets">-</p>
            </div>
            <div class="w-12 h-12 bg-[rgba(200,160,100,0.1)] rounded-sm flex items-center justify-center text-2xl">
              🎫
            </div>
          </div>
          <p class="text-xs text-[#6B5540] mt-2">+<span id="newTickets">-</span> son 24 saat</p>
        </div>
      </div>

      <div class="grid lg:grid-cols-3 gap-6">
        {/* Daily Chart */}
        <div class="lg:col-span-2 bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
          <h2 class="text-lg font-bold text-[#1A1008] mb-4">Son 14 Gün Aktivitesi</h2>
          <div id="chartContainer" class="h-64 flex items-end justify-between gap-2">
            <p class="text-[#9A8470] w-full text-center">Yükleniyor...</p>
          </div>
        </div>

        {/* Quick Actions */}
        <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
          <h2 class="text-lg font-bold text-[#1A1008] mb-4">Hızlı İşlemler</h2>
          <div class="space-y-3">
            <a href="/admin/users" class="flex items-center gap-3 p-3 rounded-sm bg-[rgba(200,160,100,0.04)] hover:bg-[rgba(200,160,100,0.08)] transition-colors">
              <span class="w-10 h-10 bg-[rgba(200,160,100,0.1)] rounded-sm flex items-center justify-center">👥</span>
              <div>
                <div class="font-medium text-[#1A1008]">Kullanıcılar</div>
                <div class="text-sm text-[#9A8470]">Tüm kullanıcıları yönet</div>
              </div>
            </a>
            <a href="/admin/places" class="flex items-center gap-3 p-3 rounded-sm bg-[rgba(200,160,100,0.04)] hover:bg-[rgba(200,160,100,0.08)] transition-colors">
              <span class="w-10 h-10 bg-[rgba(200,160,100,0.1)] rounded-sm flex items-center justify-center">🏪</span>
              <div>
                <div class="font-medium text-[#1A1008]">İşletmeler</div>
                <div class="text-sm text-[#9A8470]">Onay ve düzenleme</div>
