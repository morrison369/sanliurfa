---
import Layout from '../../layouts/Layout.astro';
import { query } from '../../lib/postgres';
import { getAdminAccessCoverage } from '../../lib/admin-access-coverage';
import {
  getAdminArtifactHealthSnapshot,
  summarizeArtifactHealth,
} from '../../lib/artifact-health';
import {
  buildArtifactHealth,
  classifyNightlyStatus,
  classifyReleaseGateStatus,
} from '../../lib/admin-status';
import { getReleaseGateSummary } from '../../lib/release-gate-summary';
import { getNightlyOpsSummary } from '../../lib/nightly-ops-summary';

const user = Astro.locals.user;

if (!user || !Astro.locals.isAdmin) {
  return Astro.redirect('/giris?redirect=/admin');
}

// İstatistikler
const [
  placesCount,
  usersCount,
  reviewsCount,
  messagesCount,
  pendingPlaces,
  adminAccessCoverage,
  artifactHealth,
  releaseGate,
  nightly,
] = await Promise.all([
  query("SELECT COUNT(*) FROM places"),
  query("SELECT COUNT(*) FROM users"),
  query("SELECT COUNT(*) FROM reviews"),
  query("SELECT COUNT(*) FROM contact_messages WHERE status = 'new'"),
  query("SELECT COUNT(*) FROM places WHERE status = 'pending'"),
  getAdminAccessCoverage(),
  getAdminArtifactHealthSnapshot(),
  getReleaseGateSummary(),
  getNightlyOpsSummary(),
]);

const stats = {
  places: parseInt(placesCount.rows[0]?.count || '0'),
  users: parseInt(usersCount.rows[0]?.count || '0'),
  reviews: parseInt(reviewsCount.rows[0]?.count || '0'),
  messages: parseInt(messagesCount.rows[0]?.count || '0'),
  pending: parseInt(pendingPlaces.rows[0]?.count || '0'),
};

const accessCoverageArtifact = buildArtifactHealth({
  kind: 'adminAccessCoverage',
  available: adminAccessCoverage.available,
  generatedAt: adminAccessCoverage.generatedAt,
});
const artifactHealthSummary = summarizeArtifactHealth(artifactHealth);

const releaseGateStatus = classifyReleaseGateStatus(releaseGate);
const nightlyRegressionStatus = classifyNightlyStatus(nightly.regression);

type OpsCard = {
  href: string;
  title: string;
  status: 'healthy' | 'degraded' | 'blocked';
  summary: string;
  detail: string;
  generatedAt: string | null;
};

function getStatusBadgeClass(status: 'healthy' | 'degraded' | 'blocked') {
  return status === 'healthy'
    ? 'bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-300'
    : status === 'degraded'
      ? 'bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-300'
      : 'bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-300';
}

function getRiskCardClass(status: 'healthy' | 'degraded' | 'blocked') {
  return status === 'healthy'
    ? 'bg-white dark:bg-gray-800 border border-transparent shadow-sm hover:shadow-md'
    : status === 'degraded'
      ? 'bg-amber-50 dark:bg-amber-950/20 border border-amber-200 dark:border-amber-800 shadow-sm hover:shadow-md'
      : 'bg-red-50 dark:bg-red-950/20 border border-red-200 dark:border-red-800 shadow-md hover:shadow-lg';
}

function formatGeneratedAt(value: string | null): string {
  if (!value) {
    return 'Henüz üretilmedi';
  }

  const date = new Date(value);
  if (Number.isNaN(date.getTime())) {
    return value;
  }

  return date.toLocaleString('tr-TR', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  });
}

function getStatusPriority(status: 'healthy' | 'degraded' | 'blocked'): number {
  return status === 'blocked' ? 0 : status === 'degraded' ? 1 : 2;
}

const artifactEntries = [
  { label: 'Release Gate', ...artifactHealth.releaseGate },
  { label: 'Nightly Regression', ...artifactHealth.nightlyRegression },
  { label: 'Nightly E2E', ...artifactHealth.nightlyE2E },
  { label: 'Performance Ops', ...artifactHealth.performanceOps },
  { label: 'Access Coverage', ...artifactHealth.adminAccessCoverage },
];

const firstProblematicArtifact =
  artifactEntries.find((entry) => entry.status !== 'healthy')?.label ?? 'Sorun yok';

const latestArtifactGeneratedAt =
  artifactEntries
    .map((entry) => entry.generatedAt)
    .filter((value): value is string => Boolean(value))
    .sort((left, right) => Date.parse(right) - Date.parse(left))[0] ?? null;

const riskCards: OpsCard[] = [
  {
    href: '/admin/dashboard',
    title: 'Release Gate',
    status: releaseGateStatus,
    summary: `${releaseGate.finalStatus} • Hata ${releaseGate.failedStepCount}`,
    detail: releaseGate.blockingFailedSteps[0] || releaseGate.advisoryFailedSteps[0] || 'Blocking hata yok',
    generatedAt: releaseGate.generatedAt,
  },
  {
    href: '/admin/dashboard',
    title: 'Nightly',
    status: nightlyRegressionStatus,
    summary: `Regression ${nightly.regression.outcome} • %${nightly.regression.successRatePercent ?? 'yok'}`,
    detail: nightly.regression.topFailures[0] || 'Öne çıkan failure yok',
    generatedAt: nightly.regression.generatedAt,
  },
  {
    href: '/admin/access-coverage',
    title: 'Access Coverage',
    status: accessCoverageArtifact.status,
    summary: `%${adminAccessCoverage.coveragePercent} • Drift ${adminAccessCoverage.driftCount}`,
    detail: adminAccessCoverage.driftedFiles[0] || 'Drift yok',
    generatedAt: adminAccessCoverage.generatedAt,
  },
  {
    href: '/admin/dashboard',
    title: 'Artifact Health',
    status: artifactHealthSummary.overall,
    summary: `Healthy ${artifactHealthSummary.healthyCount} • Degraded ${artifactHealthSummary.degradedCount} • Blocked ${artifactHealthSummary.blockedCount}`,
    detail: `İlk risk: ${firstProblematicArtifact}`,
    generatedAt: latestArtifactGeneratedAt,
  },
].sort((left, right) => getStatusPriority(left.status) - getStatusPriority(right.status));

const seo = { title: 'Admin Panel - Şanlıurfa.com' };
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-100 dark:bg-gray-900 py-8">
    <div class="container-custom">
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-8">Admin Panel</h1>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm">
          <div class="text-3xl font-bold text-urfa-600">{stats.places}</div>
          <div class="text-gray-600 dark:text-gray-400">Mekan</div>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm">
          <div class="text-3xl font-bold text-blue-600">{stats.users}</div>
          <div class="text-gray-600 dark:text-gray-400">Kullanıcı</div>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm">
          <div class="text-3xl font-bold text-green-600">{stats.reviews}</div>
          <div class="text-gray-600 dark:text-gray-400">Yorum</div>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm">
          <div class="text-3xl font-bold text-red-600">{stats.messages}</div>
          <div class="text-gray-600 dark:text-gray-400">Yeni Mesaj</div>
        </div>
      </div>
      
      <div class="mb-8">
        <div class="mb-4">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Operasyon Riski</h2>
          <p class="text-sm text-gray-600 dark:text-gray-400">Bloke veya bozulmuş sinyaller üstte gösterilir.</p>
        </div>
        <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-6">
          {riskCards.map((card) => (
            <a href={card.href} class:list={['rounded-xl p-6 transition-shadow', getRiskCardClass(card.status)]}>
              <div class="flex items-center justify-between gap-3">
                <h3 class="font-semibold text-gray-900 dark:text-white">{card.title}</h3>
                <span class:list={['rounded-full px-3 py-1 text-xs font-semibold', getStatusBadgeClass(card.status)]}>
                  {card.status}
                </span>
              </div>
              <p class="text-gray-600 dark:text-gray-400 text-sm mt-1">{card.summary}</p>
              <p class="text-gray-500 dark:text-gray-400 text-xs mt-1 truncate">{card.detail}</p>
              <p class="text-gray-500 dark:text-gray-400 text-xs mt-2">
                Son üretim: {formatGeneratedAt(card.generatedAt)}
              </p>
            </a>
          ))}
        </div>
      </div>

      <div>
        <div class="mb-4">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Yönetim Araçları</h2>
          <p class="text-sm text-gray-600 dark:text-gray-400">Operasyon dışı içerik ve yönetim yüzeyleri.</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          <a href="/admin/runtime-monitor" class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
            <h3 class="font-semibold text-gray-900 dark:text-white">Runtime Monitör</h3>
            <p class="text-gray-600 dark:text-gray-400 text-sm mt-1">Health, performance ve artifact sinyalleri</p>
          </a>
          <a href="/admin/integrations" class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
            <h3 class="font-semibold text-gray-900 dark:text-white">Entegrasyon Ayarları</h3>
            <p class="text-gray-600 dark:text-gray-400 text-sm mt-1">RESEND ve Analytics anahtarları</p>
          </a>
          <a href="/admin/users" class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
            <h3 class="font-semibold text-gray-900 dark:text-white">Kullanıcılar</h3>
            <p class="text-gray-600 dark:text-gray-400 text-sm mt-1">Kullanıcı yönetimi</p>
          </a>
          <a href="/admin/audit" class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
            <h3 class="font-semibold text-gray-900 dark:text-white">Admin Audit</h3>
            <p class="text-gray-600 dark:text-gray-400 text-sm mt-1">Kalıcı admin ops audit kayıtları</p>
          </a>
          <a href="/admin/places" class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
            <h3 class="font-semibold text-gray-900 dark:text-white">Mekanlar</h3>
            <p class="text-gray-600 dark:text-gray-400 text-sm mt-1">{stats.pending} onay bekleyen</p>
          </a>
          <a href="/admin/messages" class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
            <h3 class="font-semibold text-gray-900 dark:text-white">Mesajlar</h3>
            <p class="text-gray-600 dark:text-gray-400 text-sm mt-1">{stats.messages} yeni mesaj</p>
          </a>
          <a href="/admin/reviews" class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
            <h3 class="font-semibold text-gray-900 dark:text-white">Yorumlar</h3>
            <p class="text-gray-600 dark:text-gray-400 text-sm mt-1">Yorum moderasyonu</p>
          </a>
          <a href="/admin/blog" class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
            <h3 class="font-semibold text-gray-900 dark:text-white">Blog</h3>
            <p class="text-gray-600 dark:text-gray-400 text-sm mt-1">Blog yazıları</p>
          </a>
          <a href="/admin/events" class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
            <h3 class="font-semibold text-gray-900 dark:text-white">Etkinlikler</h3>
            <p class="text-gray-600 dark:text-gray-400 text-sm mt-1">Etkinlik yönetimi</p>
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>
