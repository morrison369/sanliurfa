---
import AdminLayout from '../../layouts/AdminLayoutV2.astro';
import { Icon } from 'astro-icon/components';
import { query } from '../../lib/postgres';

const stats = {
 users: 0, places: 0, reviews: 0, events: 0,
 blog: 0, recipes: 0,
 newUsers7d: 0, newPlaces7d: 0, newReviews7d: 0,
 newUsers30d: 0, newPlaces30d: 0, newReviews30d: 0,
 pendingClaims: 0, pendingReviews: 0, pendingPlaces: 0,
};

try {
 const r = await query(`
  SELECT
   (SELECT COUNT(*)::int FROM users) AS users,
   (SELECT COUNT(*)::int FROM places WHERE status = 'active') AS places,
   (SELECT COUNT(*)::int FROM reviews) AS reviews,
   (SELECT COUNT(*)::int FROM events WHERE status = 'published') AS events,
   (SELECT COUNT(*)::int FROM blog_posts WHERE status = 'published') AS blog,
   (SELECT COUNT(*)::int FROM recipes WHERE status = 'published') AS recipes,
   (SELECT COUNT(*)::int FROM users WHERE created_at > NOW() - INTERVAL '7 days') AS new_users_7d,
   (SELECT COUNT(*)::int FROM places WHERE created_at > NOW() - INTERVAL '7 days') AS new_places_7d,
   (SELECT COUNT(*)::int FROM reviews WHERE created_at > NOW() - INTERVAL '7 days') AS new_reviews_7d,
   (SELECT COUNT(*)::int FROM users WHERE created_at > NOW() - INTERVAL '30 days') AS new_users_30d,
   (SELECT COUNT(*)::int FROM places WHERE created_at > NOW() - INTERVAL '30 days') AS new_places_30d,
   (SELECT COUNT(*)::int FROM reviews WHERE created_at > NOW() - INTERVAL '30 days') AS new_reviews_30d,
   (SELECT COUNT(*)::int FROM places WHERE status = 'pending') AS pending_places,
   (SELECT COUNT(*)::int FROM reviews WHERE COALESCE(is_approved, true) = false AND COALESCE(is_hidden, false) = false) AS pending_reviews,
   (SELECT COUNT(*)::int FROM place_claims WHERE status = 'pending') AS pending_claims
 `);
 const row: any = r.rows[0] || {};
 stats.users = row.users || 0;
 stats.places = row.places || 0;
 stats.reviews = row.reviews || 0;
 stats.events = row.events || 0;
 stats.blog = row.blog || 0;
 stats.recipes = row.recipes || 0;
 stats.newUsers7d = row.new_users_7d || 0;
 stats.newPlaces7d = row.new_places_7d || 0;
 stats.newReviews7d = row.new_reviews_7d || 0;
 stats.newUsers30d = row.new_users_30d || 0;
 stats.newPlaces30d = row.new_places_30d || 0;
 stats.newReviews30d = row.new_reviews_30d || 0;
 stats.pendingPlaces = row.pending_places || 0;
 stats.pendingReviews = row.pending_reviews || 0;
 stats.pendingClaims = row.pending_claims || 0;
} catch { /* sessiz */ }

function pct(now: number, before: number): { value: string; positive: boolean | null } {
 if (before === 0 && now === 0) return { value: '0%', positive: null };
 if (before === 0) return { value: 'yeni', positive: true };
 const delta = ((now - before) / before) * 100;
 if (Math.abs(delta) < 1) return { value: '~0%', positive: null };
 const sign = delta > 0 ? '+' : '';
 return { value: `${sign}${delta.toFixed(0)}%`, positive: delta >= 0 };
}

const usersDelta = pct(stats.newUsers7d, Math.max(0, stats.newUsers30d - stats.newUsers7d));
const placesDelta = pct(stats.newPlaces7d, Math.max(0, stats.newPlaces30d - stats.newPlaces7d));
const reviewsDelta = pct(stats.newReviews7d, Math.max(0, stats.newReviews30d - stats.newReviews7d));

const heroCards = [
 { label: 'Toplam Kullanıcı', value: stats.users, icon: 'lucide:users', color: 'indigo', delta: usersDelta, detail: `${stats.newUsers7d} yeni · ${stats.newUsers30d} aylık`, href: '/admin/manage' },
 { label: 'Aktif Mekanlar', value: stats.places, icon: 'lucide:map-pin', color: 'emerald', delta: placesDelta, detail: `${stats.newPlaces7d} yeni · ${stats.pendingPlaces} onay bekliyor`, href: '/admin/places' },
 { label: 'Yorumlar', value: stats.reviews, icon: 'lucide:message-square', color: 'amber', delta: reviewsDelta, detail: `${stats.newReviews7d} yeni · ${stats.pendingReviews} moderasyon`, href: '/admin/reviews' },
 { label: 'Etkinlikler', value: stats.events, icon: 'lucide:calendar', color: 'rose', delta: null, detail: `Yayın · ${stats.blog} blog · ${stats.recipes} tarif`, href: '/admin/events' },
];

const quickActions = [
 { label: 'Yeni Mekan', icon: 'lucide:store', href: '/admin/places/add', color: 'emerald' },
 { label: 'Yeni Blog', icon: 'lucide:pen-tool', href: '/admin/blog/new', color: 'sky' },
 { label: 'Yeni Etkinlik', icon: 'lucide:calendar-plus', href: '/admin/events/add', color: 'rose' },
 { label: 'İçerik Üretici', icon: 'lucide:sparkles', href: '/admin/content-generator', color: 'violet' },
 { label: 'Moderasyon', icon: 'lucide:shield-check', href: '/admin/moderation', color: 'amber', badge: stats.pendingClaims + stats.pendingReviews + stats.pendingPlaces },
 { label: 'Marketing', icon: 'lucide:line-chart', href: '/admin/settings/marketing', color: 'indigo' },
 { label: 'Site Audit', icon: 'lucide:clipboard-check', href: '/admin/site-audit', color: 'teal' },
 { label: 'Entegrasyonlar', icon: 'lucide:plug', href: '/admin/integrations', color: 'slate' },
];

const navHighlights = [
 { title: 'İçerik Üretimi', icon: 'lucide:edit-3', desc: 'Blog yazısı, tarif, etkinlik ekleme', href: '/admin/blog/new' },
 { title: 'Kullanıcı Yönetimi', icon: 'lucide:user-cog', desc: 'Üye listesi, roller, banlamalar', href: '/admin/manage' },
 { title: 'Analitik & SEO', icon: 'lucide:bar-chart-3', desc: 'GA4, GSC, performans raporları', href: '/admin/analytics' },
 { title: 'Tema & İçerik', icon: 'lucide:palette', desc: 'Homepage, footer, branding', href: '/admin/site-content' },
];
---

<AdminLayout title="Dashboard" subtitle="Platform genel görünümü ve hızlı eylemler">
 <div class="dash">
  <section class="dash-stats">
   {heroCards.map((card, idx) => (
    <a href={card.href} class={`dash-stat dash-stat--${card.color}`} data-spark-key={['users', 'places', 'reviews', 'events'][idx]} data-anim-idx={idx}>
     <div class="dash-stat-bg" aria-hidden="true"></div>
     <div class="dash-stat-row">
      <span class="dash-stat-icon"><Icon name={card.icon} class="w-5 h-5" /></span>
      {card.delta && card.delta.positive !== null && (
       <span class={`dash-stat-delta ${card.delta.positive === false ? 'dash-stat-delta--down' : ''}`}>
        <Icon name={card.delta.positive === false ? 'lucide:trending-down' : 'lucide:trending-up'} class="w-3 h-3" />
        {card.delta.value}
       </span>
      )}
     </div>
     <p class="dash-stat-value" data-counter={card.value}>0</p>
     <p class="dash-stat-label">{card.label}</p>
     <p class="dash-stat-detail">{card.detail}</p>
     <svg class="dash-spark" viewBox="0 0 200 40" preserveAspectRatio="none" aria-hidden="true">
      <defs>
       <linearGradient id={`sparkGrad-${idx}`} x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" class="dash-spark-stop1" />
        <stop offset="100%" class="dash-spark-stop2" />
       </linearGradient>
      </defs>
      <path class="dash-spark-fill" fill={`url(#sparkGrad-${idx})`} d="" />
      <polyline class="dash-spark-line" points="" />
     </svg>
    </a>
   ))}
  </section>

  <section class="dash-section" style="--anim-delay: 0.08s">
   <header class="dash-section-head">
    <div>
     <h2 class="dash-section-title">Hızlı Eylemler</h2>
     <p class="dash-section-sub">Sık kullanılan içerik & yönetim işlemleri</p>
    </div>
   </header>
   <div class="dash-quick">
    {quickActions.map((a, idx) => (
     <a href={a.href} class={`dash-action dash-action--${a.color}`} style={`animation-delay: ${0.12 + idx * 0.03}s`}>
      <span class="dash-action-icon"><Icon name={a.icon} class="w-4 h-4" /></span>
      <span class="dash-action-label">{a.label}</span>
      {typeof a.badge === 'number' && a.badge > 0 && (
       <span class="dash-action-badge">{a.badge}</span>
      )}
      <span class="dash-action-arrow" aria-hidden="true"><Icon name="lucide:arrow-right" class="w-3.5 h-3.5" /></span>
     </a>
    ))}
   </div>
  </section>

  <div class="dash-grid-2">
   <section class="dash-section dash-section--col" style="--anim-delay: 0.14s">
    <header class="dash-section-head">
     <div>
      <h2 class="dash-section-title">Son Aktiviteler</h2>
      <p class="dash-section-sub">Platformda son 7 gün</p>
     </div>
     <button type="button" class="dash-icon-btn" id="dash-activity-refresh" aria-label="Yenile" title="Yenile">
      <Icon name="lucide:refresh-cw" class="w-3.5 h-3.5" />
     </button>
    </header>
    <ul class="dash-activity" id="dash-activity">
     <li class="dash-activity-skeleton"><span class="dash-skel-circle"></span><div style="flex:1"><span class="dash-skel-bar dash-skel-bar--sm"></span><span class="dash-skel-bar"></span></div></li>
     <li class="dash-activity-skeleton"><span class="dash-skel-circle"></span><div style="flex:1"><span class="dash-skel-bar dash-skel-bar--sm"></span><span class="dash-skel-bar"></span></div></li>
     <li class="dash-activity-skeleton"><span class="dash-skel-circle"></span><div style="flex:1"><span class="dash-skel-bar dash-skel-bar--sm"></span><span class="dash-skel-bar"></span></div></li>
     <li class="dash-activity-skeleton"><span class="dash-skel-circle"></span><div style="flex:1"><span class="dash-skel-bar dash-skel-bar--sm"></span><span class="dash-skel-bar"></span></div></li>
    </ul>
   </section>

   <section class="dash-section dash-section--col" style="--anim-delay: 0.18s">
    <header class="dash-section-head">
     <div>
      <h2 class="dash-section-title">Sistem Durumu</h2>
      <p class="dash-section-sub">Production canlı</p>
     </div>
     <a href="/admin/monitoring" class="dash-link-sm">Detay →</a>
    </header>
    <ul class="dash-health" id="dash-health">
     <li><span class="dash-health-icon"><Icon name="lucide:globe" class="w-3.5 h-3.5" /></span><span class="dash-health-label">API</span><span class="dash-health-state">kontrol...</span><span class="dash-health-dot"></span></li>
     <li><span class="dash-health-icon"><Icon name="lucide:database" class="w-3.5 h-3.5" /></span><span class="dash-health-label">Veritabanı</span><span class="dash-health-state">—</span><span class="dash-health-dot"></span></li>
     <li><span class="dash-health-icon"><Icon name="lucide:zap" class="w-3.5 h-3.5" /></span><span class="dash-health-label">Redis</span><span class="dash-health-state">—</span><span class="dash-health-dot"></span></li>
     <li><span class="dash-health-icon"><Icon name="lucide:hard-drive" class="w-3.5 h-3.5" /></span><span class="dash-health-label">Disk</span><span class="dash-health-state">—</span><span class="dash-health-dot"></span></li>
    </ul>
   </section>
  </div>

  <section class="dash-section" style="--anim-delay: 0.22s">
   <header class="dash-section-head">
    <div>
     <h2 class="dash-section-title">Yönetim Alanları</h2>
     <p class="dash-section-sub">Sık ihtiyaç duyacağın bölümlere hızlı erişim</p>
    </div>
   </header>
   <div class="dash-highlights">
    {navHighlights.map((h, idx) => (
     <a href={h.href} class="dash-highlight" style={`animation-delay: ${0.28 + idx * 0.04}s`}>
      <span class="dash-highlight-icon"><Icon name={h.icon} class="w-5 h-5" /></span>
      <h3 class="dash-highlight-title">{h.title}</h3>
      <p class="dash-highlight-desc">{h.desc}</p>
      <span class="dash-highlight-cta">Aç <Icon name="lucide:arrow-right" class="w-3.5 h-3.5" /></span>
     </a>
    ))}
   </div>
  </section>
 </div>
</AdminLayout>

<script is:inline>
 function animateValue(el, target, duration) {
  duration = duration || 900;
  const startTime = performance.now();
  function tick(now) {
   const elapsed = now - startTime;
   const progress = Math.min(elapsed / duration, 1);
   const eased = 1 - Math.pow(1 - progress, 3);
   const value = Math.floor(target * eased);
   el.textContent = value.toLocaleString('tr-TR');
   if (progress < 1) requestAnimationFrame(tick);
   else el.textContent = target.toLocaleString('tr-TR');
  }
  requestAnimationFrame(tick);
 }
 document.querySelectorAll('[data-counter]').forEach((el) => {
  const target = Number(el.getAttribute('data-counter')) || 0;
  if (target > 0) animateValue(el, target);
  else el.textContent = '0';
 });

 async function loadSparklines() {
  try {
   const res = await fetch('/api/admin/dashboard/sparkline');
   if (!res.ok) return;
   const j = await res.json();
   const series = (j && j.data && j.data.series) || {};
   document.querySelectorAll('[data-spark-key]').forEach((card) => {
    const key = card.getAttribute('data-spark-key');
    if (!key || !series[key]) return;
    const data = series[key];
    const max = Math.max(...data, 1);
    const W = 200, H = 40;
    const stepX = W / (data.length - 1 || 1);
    const points = data.map((v, i) => `${(i * stepX).toFixed(1)},${(H - (v / max) * (H - 4) + 2).toFixed(1)}`).join(' ');
    const fillPath = `M0,${H} L${points.split(' ').join(' L')} L${W},${H} Z`;
    card.querySelector('.dash-spark-line')?.setAttribute('points', points);
    card.querySelector('.dash-spark-fill')?.setAttribute('d', fillPath);
   });
  } catch {}
 }

 const iconMap = { user: '👤', place: '🏪', review: '💬', blog: '📝', event: '📅' };
 const labelMap = { user: 'Yeni kullanıcı', place: 'Yeni mekan', review: 'Yorum', blog: 'Blog yazısı', event: 'Etkinlik' };
 const linkMap = {
  user: () => '/admin/manage',
  place: (i) => `/isletme/${i.slug}`,
  review: () => '/admin/reviews',
  blog: (i) => `/blog/${i.slug}`,
  event: (i) => `/etkinlikler/${i.slug}`,
 };
 function timeAgo(d) {
  const m = Math.floor((Date.now() - new Date(d).getTime()) / 60000);
  if (m < 1) return 'az önce';
  if (m < 60) return m + 'dk';
  const h = Math.floor(m / 60);
  return h < 24 ? h + 'sa' : Math.floor(h / 24) + 'g';
 }
 async function loadActivity() {
  const list = document.getElementById('dash-activity');
  if (!list) return;
  try {
   const res = await fetch('/api/admin/dashboard/activity');
   if (!res.ok) throw new Error('failed');
   const j = await res.json();
   const items = (j && j.data && j.data.items) || [];
   while (list.firstChild) list.removeChild(list.firstChild);
   if (items.length === 0) {
    const p = document.createElement('li');
    p.className = 'dash-activity-empty';
    p.textContent = 'Son 7 günde aktivite yok.';
    list.appendChild(p);
    return;
   }
   items.forEach((item, idx) => {
    const li = document.createElement('li');
    li.className = 'dash-activity-item';
    li.style.animationDelay = (idx * 0.03) + 's';
    const icon = document.createElement('span');
    icon.className = 'dash-activity-icon';
    icon.textContent = iconMap[item.type] || '•';
    const body = document.createElement('div');
    body.className = 'dash-activity-body';
    const lbl = document.createElement('p'); lbl.className = 'dash-activity-label'; lbl.textContent = labelMap[item.type] || item.type;
    const ttl = document.createElement('p'); ttl.className = 'dash-activity-title'; ttl.textContent = item.title || '(başlıksız)';
    body.appendChild(lbl); body.appendChild(ttl);
    const time = document.createElement('span');
    time.className = 'dash-activity-time';
    time.textContent = timeAgo(item.created_at);
    const href = linkMap[item.type] && linkMap[item.type](item);
    if (href) {
     const a = document.createElement('a');
     a.href = href;
     a.appendChild(icon); a.appendChild(body); a.appendChild(time);
     li.appendChild(a);
    } else {
     li.appendChild(icon); li.appendChild(body); li.appendChild(time);
    }
    list.appendChild(li);
   });
  } catch {
   while (list.firstChild) list.removeChild(list.firstChild);
   const err = document.createElement('li');
   err.className = 'dash-activity-empty';
   err.textContent = '✗ Yüklenemedi';
   list.appendChild(err);
  }
 }
 document.getElementById('dash-activity-refresh')?.addEventListener('click', loadActivity);

 async function loadHealth() {
  try {
   const res = await fetch('/api/health');
   if (!res.ok) throw new Error('health fail');
   const j = await res.json();
   const data = (j && j.data) || j;
   const services = (data && data.services) || {};
   const items = document.querySelectorAll('#dash-health li');
   const setItem = (idx, state, level) => {
    const li = items[idx]; if (!li) return;
    const dot = li.querySelector('.dash-health-dot');
    const stateEl = li.querySelector('.dash-health-state');
    if (stateEl) stateEl.textContent = state;
    if (dot) {
     dot.classList.remove('dash-health-dot--warn', 'dash-health-dot--fail');
     if (level === 'warn') dot.classList.add('dash-health-dot--warn');
     if (level === 'fail') dot.classList.add('dash-health-dot--fail');
    }
   };
   setItem(0, data.status === 'healthy' ? 'Çalışıyor' : 'Sorun', data.status === 'healthy' ? 'ok' : 'fail');
   if (services.database) setItem(1, services.database.status === 'connected' ? (services.database.latencyMs + 'ms') : 'Yok', services.database.status === 'connected' ? 'ok' : 'fail');
   if (services.redis) setItem(2, services.redis.status === 'connected' ? 'Bağlı' : 'Yok', services.redis.status === 'connected' ? 'ok' : 'fail');
   if (services.disk) setItem(3, '%' + services.disk.usedPercent + ' · ' + services.disk.freeGb + 'GB', services.disk.usedPercent > 85 ? 'warn' : 'ok');
  } catch {
   document.querySelectorAll('#dash-health li').forEach((i) => {
    const dot = i.querySelector('.dash-health-dot');
    const state = i.querySelector('.dash-health-state');
    dot && dot.classList.add('dash-health-dot--fail');
    if (state) state.textContent = 'Erişilemiyor';
   });
  }
 }
 loadSparklines();
 loadActivity();
 loadHealth();
</script>

<style>
 .dash { display: flex; flex-direction: column; gap: 1.5rem; }

 .dash-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1rem; }
 .dash-stat {
  position: relative; background: var(--adm-bg-elev);
  border: 1px solid var(--adm-border); border-radius: 14px;
  padding: 1.3rem 1.4rem; text-decoration: none; color: var(--adm-text);
  overflow: hidden; display: flex; flex-direction: column;
  transition: transform 0.18s, box-shadow 0.18s, border-color 0.18s;
  opacity: 0; animation: dashStatIn 0.45s ease-out forwards;
 }
 .dash-stat[data-anim-idx="0"] { animation-delay: 0.02s; }
 .dash-stat[data-anim-idx="1"] { animation-delay: 0.08s; }
 .dash-stat[data-anim-idx="2"] { animation-delay: 0.14s; }
 .dash-stat[data-anim-idx="3"] { animation-delay: 0.20s; }
 @keyframes dashStatIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
 .dash-stat:hover {
  transform: translateY(-3px);
  box-shadow: 0 14px 36px -8px rgba(31,20,16,0.16), 0 4px 8px rgba(31,20,16,0.05);
  border-color: var(--stat-accent);
 }
 .dash-stat-bg {
  position: absolute; inset: 0; pointer-events: none;
  background: radial-gradient(circle at 100% 0%, var(--stat-accent) 0%, transparent 55%);
  opacity: 0.06;
 }
 .dash-stat-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.85rem; }
 .dash-stat-icon {
  width: 44px; height: 44px; border-radius: 12px;
  display: inline-flex; align-items: center; justify-content: center;
  background: var(--stat-accent-soft); color: var(--stat-accent);
 }
 .dash-stat-delta {
  display: inline-flex; align-items: center; gap: 0.25rem;
  font-size: 0.74rem; font-weight: 700;
  padding: 0.22rem 0.55rem; border-radius: 999px;
  background: rgba(16,185,129,0.12); color: rgb(5,150,105);
 }
 .dash-stat-delta--down { background: rgba(225,29,72,0.12); color: rgb(190,18,60); }
 .dash-stat-value {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2.5rem; font-weight: 700;
  margin: 0; line-height: 1; color: var(--adm-text);
  letter-spacing: -0.02em;
 }
 .dash-stat-label { margin: 0.5rem 0 0; font-size: 0.88rem; font-weight: 600; color: var(--adm-text-muted); }
 .dash-stat-detail { margin: 0.35rem 0 0; font-size: 0.74rem; color: var(--adm-text-soft); }
 .dash-spark { position: absolute; bottom: 0; left: 0; right: 0; width: 100%; height: 44px; pointer-events: none; }
 .dash-spark-line { fill: none; stroke-width: 1.8; stroke-linejoin: round; stroke-linecap: round; stroke: var(--stat-accent); }
 .dash-spark-stop1 { stop-color: var(--stat-accent); stop-opacity: 0.22; }
 .dash-spark-stop2 { stop-color: var(--stat-accent); stop-opacity: 0; }
 .dash-stat--indigo { --stat-accent: rgb(99,102,241); --stat-accent-soft: rgba(99,102,241,0.12); }
 .dash-stat--emerald { --stat-accent: rgb(16,185,129); --stat-accent-soft: rgba(16,185,129,0.12); }
 .dash-stat--amber { --stat-accent: rgb(217,119,6); --stat-accent-soft: rgba(217,119,6,0.12); }
 .dash-stat--rose { --stat-accent: rgb(225,29,72); --stat-accent-soft: rgba(225,29,72,0.10); }

 .dash-section {
  background: var(--adm-bg-elev); border: 1px solid var(--adm-border);
  border-radius: 14px; padding: 1.4rem;
  opacity: 0; animation: dashFadeIn 0.5s ease-out forwards;
  animation-delay: var(--anim-delay, 0s);
 }
 .dash-section--col { display: flex; flex-direction: column; }
 @keyframes dashFadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
 .dash-section-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 0.75rem; margin-bottom: 1rem; }
 .dash-section-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.35rem; font-weight: 700; color: var(--adm-text); margin: 0; line-height: 1.1;
 }
 .dash-section-sub { font-size: 0.82rem; color: var(--adm-text-muted); margin: 0.22rem 0 0; }
 .dash-icon-btn {
  background: var(--adm-bg-hover); border: 1px solid var(--adm-border);
  color: var(--adm-text-muted); width: 32px; height: 32px;
  border-radius: 8px; cursor: pointer;
  display: inline-flex; align-items: center; justify-content: center;
  transition: all 0.2s;
 }
