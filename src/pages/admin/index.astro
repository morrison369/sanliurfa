          <h2 class="text-lg font-bold text-[#1A1008] mb-4">Son Kayıt Olanlar</h2>
          <div id="recentUsers" class="space-y-3">
            <p class="text-[#9A8470] text-center py-4">Yükleniyor...</p>
          </div>
        </div>

        {/* Recent Places */}
        <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
          <h2 class="text-lg font-bold text-[#1A1008] mb-4">Son Eklenen İşletmeler</h2>
          <div id="recentPlaces" class="space-y-3">
            <p class="text-[#9A8470] text-center py-4">Yükleniyor...</p>
          </div>
        </div>
      </div>

      {/* Top Places */}
      <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6 mt-6">
        <h2 class="text-lg font-bold text-[#1A1008] mb-4">En Çok Görüntülenen İşletmeler (Son 30 Gün)</h2>
        <div id="topPlaces" class="grid md:grid-cols-5 gap-4">
          <p class="text-[#9A8470] col-span-5 text-center py-4">Yükleniyor...</p>
        </div>
      </div>
    </div>

  <script>
    async function loadDashboard() {
      try {
        const response = await fetch('/api/admin/dashboard');
        const data = await response.json();

        if (data.success) {
          updateStats(data.stats);
          renderChart(data.dailyStats);
          renderRecent(data.recent);
          renderTopPlaces(data.topPlaces);
        }
      } catch (err) {
        console.error('Dashboard load error:', err);
      }
    }

    function updateStats(stats: any) {
      document.getElementById('totalUsers')!.textContent = stats.users.total;
      document.getElementById('newUsers')!.textContent = stats.users.new_this_month;
      document.getElementById('totalPlaces')!.textContent = stats.places.total;
      document.getElementById('pendingPlaces')!.textContent = stats.places.pending;
      document.getElementById('totalReviews')!.textContent = stats.reviews.total;
      document.getElementById('pendingReviews')!.textContent = stats.reviews.pending;
      document.getElementById('openTickets')!.textContent = stats.tickets.open;
      document.getElementById('newTickets')!.textContent = stats.tickets.new_today;
    }

    function renderChart(dailyStats: any[]) {
      if (!dailyStats || dailyStats.length === 0) return;
      const container = document.getElementById('chartContainer')!;
      container.innerHTML = '';

      const max = Math.max(...dailyStats.map((d: any) => parseInt(d.views) || 0), 1);

      dailyStats.forEach((day: any) => {
        const height = ((parseInt(day.views) || 0) / max) * 100;
        const date = new Date(day.date);
        const label = date.toLocaleDateString('tr-TR', { day: 'numeric', month: 'short' });
        const views = parseInt(day.views) || 0;

        const wrapper = document.createElement('div');
        wrapper.className = 'flex-1 flex flex-col items-center group relative';

        const bar = document.createElement('div');
        bar.className = 'w-full bg-urfa-600 rounded-t hover:bg-urfa-700 transition-colors';
        bar.style.height = `${Math.max(height, 4)}%`;

        const lbl = document.createElement('span');
        lbl.className = 'text-xs text-[#9A8470] mt-1 rotate-45 origin-left';
        lbl.textContent = label;

        const tooltip = document.createElement('div');
        tooltip.className = 'absolute bottom-full mb-2 hidden group-hover:block bg-[#0D0A08] text-white text-xs rounded-sm px-2 py-1 whitespace-nowrap z-10';
        tooltip.textContent = `${views} görüntülenme`;

        wrapper.appendChild(bar);
        wrapper.appendChild(lbl);
        wrapper.appendChild(tooltip);
        container.appendChild(wrapper);
      });
    }

    function renderRecent(recent: any) {
      const usersContainer = document.getElementById('recentUsers')!;
      usersContainer.innerHTML = '';

      if (!recent.users.length) {
        usersContainer.textContent = 'Kullanıcı yok';
        return;
      }

      recent.users.forEach((user: any) => {
        const row = document.createElement('div');
        row.className = 'flex items-center gap-3 p-3 bg-[rgba(200,160,100,0.04)] rounded-sm';

        const avatar = document.createElement('div');
        avatar.className = 'w-10 h-10 bg-[rgba(200,160,100,0.12)] rounded-full flex items-center justify-center font-medium text-[#6B5540]';
        avatar.textContent = user.name ? user.name.charAt(0).toUpperCase() : '?';

        const info = document.createElement('div');
        info.className = 'flex-1 min-w-0';
        const name = document.createElement('div');
        name.className = 'font-medium text-[#1A1008] truncate';
        name.textContent = user.name || 'İsimsiz';
        const email = document.createElement('div');
        email.className = 'text-sm text-[#9A8470]';
        email.textContent = user.email;
        info.appendChild(name);
        info.appendChild(email);

        const badge = document.createElement('span');
        badge.className = 'text-xs px-2 py-1 rounded-sm bg-[rgba(200,160,100,0.06)] text-[#9A8470]';
        badge.textContent = user.role;

        row.appendChild(avatar);
        row.appendChild(info);
        row.appendChild(badge);
        usersContainer.appendChild(row);
      });

      const placesContainer = document.getElementById('recentPlaces')!;
      placesContainer.innerHTML = '';

      if (!recent.places.length) {
        placesContainer.textContent = 'İşletme yok';
        return;
      }

      recent.places.forEach((place: any) => {
        const row = document.createElement('div');
        row.className = 'flex items-center gap-3 p-3 bg-[rgba(200,160,100,0.04)] rounded-sm';

        const icon = document.createElement('div');
        icon.className = 'w-10 h-10 bg-[rgba(200,160,100,0.1)] rounded-sm flex items-center justify-center text-xl';
        icon.textContent = '🏪';

        const info = document.createElement('div');
        info.className = 'flex-1 min-w-0';
        const pname = document.createElement('div');
        pname.className = 'font-medium text-[#1A1008] truncate';
        pname.textContent = place.name;
        const owner = document.createElement('div');
        owner.className = 'text-sm text-[#9A8470]';
        owner.textContent = place.owner_name || 'Sahipsiz';
        info.appendChild(pname);
        info.appendChild(owner);

        const badge = document.createElement('span');
        badge.className = 'text-xs px-2 py-1 rounded-sm bg-[rgba(200,160,100,0.06)] text-[#9A8470]';
        badge.textContent = place.status;

        row.appendChild(icon);
        row.appendChild(info);
        row.appendChild(badge);
        placesContainer.appendChild(row);
      });
    }

    function renderTopPlaces(places: any[]) {
      const container = document.getElementById('topPlaces')!;
      container.innerHTML = '';

      if (!places.length) {
        const empty = document.createElement('p');
        empty.className = 'text-[#9A8470] col-span-5 text-center';
        empty.textContent = 'Veri yok';
        container.appendChild(empty);
        return;
      }

      const medals = ['🥇', '🥈', '🥉'];

      places.forEach((place: any, i: number) => {
        const card = document.createElement('div');
        card.className = 'bg-[rgba(200,160,100,0.04)] rounded-sm border border-[rgba(200,160,100,0.14)] p-4 text-center';

        const medal = document.createElement('div');
        medal.className = 'text-2xl mb-2';
        medal.textContent = medals[i] ?? `${i + 1}.`;

        let imgEl: HTMLElement;
        if (place.image_url) {
          const img = document.createElement('img');
          img.src = place.image_url;
          img.alt = '';
          img.className = 'w-16 h-16 rounded-sm object-cover mx-auto mb-2';
          imgEl = img;
        } else {
          const placeholder = document.createElement('div');
          placeholder.className = 'w-16 h-16 bg-[rgba(200,160,100,0.1)] rounded-sm mx-auto mb-2 flex items-center justify-center text-2xl';
          placeholder.textContent = '🏪';
          imgEl = placeholder;
        }

        const pname = document.createElement('div');
        pname.className = 'font-medium text-[#1A1008] text-sm truncate';
        pname.textContent = place.name;

        const views = document.createElement('div');
        views.className = 'text-urfa-600 font-bold';
        views.textContent = `${place.total_views} gör.`;

        card.appendChild(medal);
        card.appendChild(imgEl);
        card.appendChild(pname);
        card.appendChild(views);
        container.appendChild(card);
      });
    }

    loadDashboard();
  </script>
</AdminLayout>
