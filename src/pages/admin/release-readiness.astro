---
import fs from 'node:fs';
import path from 'node:path';
import { Icon } from 'astro-icon/components';
import AdminLayout from '../../layouts/AdminLayoutV2.astro';
import AdmStatGrid from '../../components/admin/AdmStatGrid.astro';
import { loadHomepagePlatformData } from '../../lib/home-data';
import {
 HOMEPAGE_SECTIONS_FALLBACK,
 resolveHomepageSections,
 summarizeHomepageSections,
} from '../../lib/home-settings';
import { getSiteSetting, getSiteSettingValidationStatuses } from '../../lib/site-content';
import { query } from '../../lib/postgres';
import { isFreshnessStale } from '../../lib/city-service-freshness';

type ReadinessDashboard = {
 generatedAt: string | null;
 ready: boolean;
 decision?: 'READY' | 'BLOCKED' | 'ADVISORY';
 gateSummary?: Record<string, string | boolean | number>;
 qualityRefresh?: {
  status?: string;
  generatedAt?: string | null;
  lintOk?: boolean;
  typecheckOk?: boolean;
  openapiOk?: boolean;
 };
 releaseNextActions?: {
  status?: string;
  actionCount?: number;
  blockingActionCount?: number;
  waitingActionCount?: number;
  actions?: Array<{
   priority?: string;
   area?: string;
   title?: string;
   status?: string;
   command?: string;
   detail?: string;
  }>;
 } | null;
 freshness?: {
  status?: string;
  generatedAt?: string | null;
  staleOrMissingCount?: number | null;
 };
 releaseHandoffSummary?: {
  generatedAt?: string | null;
  releaseStatus?: string;
  localMediaStorage?: string;
  pagespeedApiLessLighthouse?: string;
  artifactCount?: number;
  advisoryCount?: number;
 } | null;
 uploadArchive?: {
  status?: string;
  generatedAt?: string | null;
  total?: number;
  archiveCandidate?: number;
  deletableReview?: number;
 };
 unitSkips?: {
  status?: string;
  generatedAt?: string | null;
  observedSkippedFiles?: number;
  observedSkippedTests?: number;
  declarationCount?: number;
  undocumentedCount?: number;
 };
 e2eSkips?: {
  status?: string;
  generatedAt?: string | null;
  declarationCount?: number;
  undocumentedCount?: number;
 };
 e2eCriticalCoverage?: {
  status?: string;
  generatedAt?: string | null;
  flowCount?: number;
  coveredCount?: number;
  missingCount?: number;
 };
  api?: {
  releaseGate?: {
   status?: string;
   passedChecks?: number;
   totalChecks?: number;
   failedChecks?: number;
  } | null;
  contractGroups?: {
   status?: string;
   groupCount?: number;
   coverageGapCount?: number;
  } | null;
  debugEnvelope?: {
   status?: string;
   passed?: number;
   total?: number;
   failed?: number;
  } | null;
 };
 buildArtifacts?: {
  status?: string;
  distClientTotalMb?: number;
  distClientWithinSoftBudget?: boolean;
  astroWithinBudget?: boolean;
 } | null;
 scriptCanonicalSurface?: {
  status?: string;
  totalScripts?: number;
  familyCount?: number;
  canonicalCount?: number;
  missingCanonicalCount?: number;
 } | null;
 migrationDuplicateDrift?: {
  status?: string;
  duplicateNumberGroups?: number;
  duplicateSlugGroups?: number;
  numberDrift?: boolean;
  slugDrift?: boolean;
 } | null;
 dbRetirement?: {
  status?: string;
  p0DropCandidateCount?: number;
  p0QuarantineCandidateCount?: number;
  p0RuntimeHoldCount?: number;
  p1ReviewCandidateCount?: number;
  p2UnusedIndexCandidateCount?: number;
  automaticDropAllowed?: boolean;
 } | null;
 dbP0QuarantinePlan?: {
  status?: string;
  quarantineCandidateCount?: number;
  runtimeHoldCount?: number;
  earliestActionAt?: string | null;
  automaticDropAllowed?: boolean;
 } | null;
 dbObservationCadence?: {
  status?: string;
  snapshotCount?: number;
  observationDays?: number;
  missingDays?: number;
  stableEnoughForAction?: boolean;
  earliestActionAt?: string | null;
 } | null;
 dbObservationCalendar?: {
  status?: string;
  completeCount?: number;
  observationDays?: number;
  missingOrPendingCount?: number;
  nextSnapshotDueAt?: string | null;
  earliestActionAt?: string | null;
  actionWindowOpen?: boolean;
  automaticDropAllowed?: boolean;
 } | null;
 dbManualDecisionReadiness?: {
  status?: string;
  readyForManualPrCount?: number;
  waitingForEvidenceCount?: number;
  runtimeHoldCount?: number;
  actionWindowOpen?: boolean;
 } | null;
 dbRegistryClassification?: {
  status?: string;
  tableCount?: number;
  unclassifiedCount?: number;
  unusedIndexCount?: number;
  automaticDbDropAllowed?: boolean;
 } | null;
 dbRuntimeHoldPlan?: {
  status?: string;
  table?: string;
  runtimeReferenceCount?: number;
  incompatibleContractCount?: number;
  automaticDropAllowed?: boolean;
 } | null;
 localUploadBucketQuota?: {
  status?: string;
  bucketCount?: number;
  blockerCount?: number;
  reviewCount?: number;
  advisoryCount?: number;
 } | null;
 localMediaStorageGate?: {
  status?: string;
  localStorageOnly?: boolean;
  externalObjectStorageConfigured?: boolean;
  liveChecks?: number;
  liveOk?: number;
  failedPatterns?: number;
 } | null;
 mediaReadiness?: {
  status?: string;
  checks?: number;
  passed?: number;
  failed?: number;
  uploadFiles?: number;
  publicImages?: number;
  localStorageOnly?: boolean;
  externalObjectStorageAllowed?: boolean;
  automaticDeleteAllowed?: boolean;
 } | null;
 redisRuntimeHealth?: {
  status?: string;
  host?: string;
  port?: number;
  pingOk?: boolean;
  latencyMs?: number | null;
  runtimeMode?: string;
  releaseBlocker?: boolean;
  fallbackAllowed?: boolean;
 } | null;
 warmupSafety?: {
  status?: string;
  reviewCount?: number;
 } | null;
 cronReadiness?: {
  status?: string;
  requiredJobCount?: number;
  presentJobCount?: number;
  missingJobCount?: number;
 } | null;
 llmsSitemapAutoUpdate?: {
  status?: string;
  checks?: number;
  ok?: number;
  failed?: number;
 } | null;
 gmapsScraperReadiness?: {
  status?: string;
  binaryFound?: boolean;
  cliOk?: boolean;
  localStorageOnly?: boolean;
 } | null;
 gmapsDiscoveryDrafts?: {
  status?: string;
  mode?: string;
  candidateCount?: number;
  existingDraftCount?: number | null;
  pendingDraftCount?: number | null;
  insertedOrUpdatedCount?: number;
  autoPublish?: boolean;
 } | null;
 contentAgentDrafts?: {
  status?: string;
  total?: number;
  pending?: number;
  stalePendingCount?: number;
  autoPublish?: boolean;
 } | null;
 publishAllContentDrafts?: {
  status?: string;
  remainingDraftLike?: number;
  moderationPending?: number;
  cityContentUpdated?: number;
  moderationQueuesAutoApproved?: boolean;
 } | null;
 blogDraftRichResults?: {
  status?: string;
  drafts?: number;
  ok?: number;
  review?: number;
 } | null;
 pagespeedApiLessLighthouse?: {
  status?: string;
  checks?: number;
  ok?: number;
  review?: number;
  failed?: number;
  apiUsed?: boolean;
  performance?: number | null;
  accessibility?: number | null;
  bestPractices?: number | null;
  seo?: number | null;
  reviewClassification?: string | null;
  externalExpectedReview?: boolean;
 } | null;
 adminStrictRoleGate?: {
  status?: string;
  checked?: number;
  ok?: number;
  review?: number;
 } | null;
 searchZeroResult?: {
  status?: string;
  unresolvedCount?: number;
  unresolvedOccurrences?: number;
 } | null;
 advisoryReasons?: Array<{ code?: string; detail?: string }>;
 e2eFailures?: Array<{ spec?: string; title?: string; outcome?: string }>;
 checks: Array<{ rel: string; ok: boolean }>;
};

const dashboardPath = path.join(process.cwd(), 'docs', 'release-readiness-dashboard.json');
let dashboard: ReadinessDashboard = { generatedAt: null, ready: false, checks: [] };
const homepageConfigKeys = [
 'homepage.primaryActions',
 'homepage.quickCategories',
 'homepage.featuredGuides',
 'homepage.faq',
 'homepage.heroQuickLinks',
 'homepage.liveStatusCards',
 'homepage.serviceQuickLinks',
 'homepage.communityPanel',
 'homepage.trendingFallbackQueries',
 'homepage.sections',
 'homepage.mvpQuickStart',
];
const homepageConfigStatuses = await getSiteSettingValidationStatuses(homepageConfigKeys);
const invalidHomepageConfigs = homepageConfigStatuses.filter((item) => !item.valid);
let freshnessRows: Array<{ key: string; value: string; stale: boolean }> = [];
const homepageSectionsSetting = await getSiteSetting('homepage.sections', HOMEPAGE_SECTIONS_FALLBACK);
const homepagePlatformData = await loadHomepagePlatformData();
const homepageSectionState = resolveHomepageSections({
 homepageSectionsSetting,
 platformHomepageSections: homepagePlatformData.platformHomepageSections as Array<{
  section_key?: string;
  is_active?: boolean;
 }>,
});
const homepageSectionSummary = summarizeHomepageSections({
 sectionOrderMap: homepageSectionState.sectionOrderMap,
 sectionVisibilitySetting: homepageSectionState.sectionVisibilitySetting,
});

if (fs.existsSync(dashboardPath)) {
 try { dashboard = JSON.parse(fs.readFileSync(dashboardPath, 'utf8')); }
 catch { dashboard = { generatedAt: null, ready: false, checks: [] }; }
}

try {
 const result = await query(
  `SELECT setting_key, setting_value
   FROM site_settings
   WHERE setting_key IN ('transport.lastUpdated','weather.lastUpdated','pharmacy.lastUpdated','jobs.contentQuality.lastRun')`,
 );
 freshnessRows = (result.rows || []).map((row) => {
  const settingValue =
   row?.setting_value && typeof row.setting_value === 'object' ? row.setting_value : {};
  const value = String(settingValue.at || settingValue.updatedAt || settingValue.lastUpdated || '');
  return {
   key: String(row.setting_key || ''),
   value,
   stale: isFreshnessStale(String(row.setting_key || ''), {
    [String(row.setting_key || '')]: value,
   }),
  };
 });
} catch { freshnessRows = []; }

const checksOk = dashboard.checks.filter(c => c.ok).length;
const checksTotal = dashboard.checks.length;
const configsValid = homepageConfigStatuses.filter(c => c.valid).length;
const configsTotal = homepageConfigStatuses.length;
const freshOk = freshnessRows.filter(r => !r.stale).length;
const sectionsActive = homepageSectionSummary.filter(s => s.enabled).length;
---

<AdminLayout
 title="Release Readiness"
 subtitle={`Frontend release gate • ${dashboard.decision || (dashboard.ready ? 'READY' : 'BLOCKED')}`}
 seo={{ title: 'Release Readiness - Admin', noIndex: true }}
>
 <div class="rr-page">
  <div class:list={['rr-banner', dashboard.decision === 'READY' && 'rr-banner--ok', dashboard.decision === 'ADVISORY' && 'rr-banner--warn', (!dashboard.ready || dashboard.decision === 'BLOCKED') && 'rr-banner--err']}>
   <div class="rr-banner-icon">
    <Icon name={dashboard.decision === 'READY' ? 'lucide:check-circle' : dashboard.decision === 'ADVISORY' ? 'lucide:info' : 'lucide:alert-triangle'} class="w-5 h-5" />
   </div>
   <div class="rr-banner-text">
    <div class="rr-banner-title">
     {dashboard.decision === 'READY' ? 'Production deploy serbest' : dashboard.decision === 'ADVISORY' ? 'Production deploy advisory ile serbest' : 'Release bloklanmış'}
    </div>
    <div class="rr-banner-sub">
     Son rapor: {dashboard.generatedAt ? new Date(dashboard.generatedAt).toLocaleString('tr-TR') : 'henüz üretilmemiş'}
    </div>
   </div>
  </div>

  <AdmStatGrid stats={[
   { label: 'Checklist', value: checksTotal > 0 ? `${checksOk}/${checksTotal}` : '—', icon: 'lucide:list-checks', color: checksOk === checksTotal ? 'emerald' : 'rose' },
   { label: 'Homepage Config', value: `${configsValid}/${configsTotal}`, icon: 'lucide:settings', color: configsValid === configsTotal ? 'emerald' : 'amber' },
   { label: 'Servis Tazeliği', value: freshnessRows.length > 0 ? `${freshOk}/${freshnessRows.length}` : '—', icon: 'lucide:radio', color: freshOk === freshnessRows.length ? 'emerald' : 'amber' },
   { label: 'Aktif Section', value: `${sectionsActive}/${homepageSectionSummary.length}`, icon: 'lucide:layout', color: 'indigo' },
   { label: 'Quality Refresh', value: dashboard.qualityRefresh?.status || '—', icon: 'lucide:refresh-cw', color: dashboard.qualityRefresh?.status === 'passed' ? 'emerald' : 'amber' },
   { label: 'Next Actions', value: dashboard.releaseNextActions ? `${dashboard.releaseNextActions.blockingActionCount ?? 0}/${dashboard.releaseNextActions.waitingActionCount ?? 0}` : '—', icon: 'lucide:list-todo', color: (dashboard.releaseNextActions?.blockingActionCount ?? 0) === 0 ? 'emerald' : 'amber' },
   { label: 'Freshness', value: dashboard.freshness?.status || '—', icon: 'lucide:clock-3', color: dashboard.freshness?.status === 'passed' ? 'emerald' : 'rose' },
   { label: 'Handoff', value: dashboard.releaseHandoffSummary?.releaseStatus || '—', icon: 'lucide:clipboard-check', color: dashboard.releaseHandoffSummary ? 'emerald' : 'rose' },
   { label: 'Upload Archive', value: String(dashboard.uploadArchive?.total ?? '—'), icon: 'lucide:archive', color: (dashboard.uploadArchive?.deletableReview ?? 0) > 0 ? 'rose' : (dashboard.uploadArchive?.total ?? 0) > 0 ? 'amber' : 'emerald' },
   { label: 'Unit Skips', value: String(dashboard.unitSkips?.observedSkippedTests ?? '—'), icon: 'lucide:skip-forward', color: (dashboard.unitSkips?.undocumentedCount ?? 0) > 0 ? 'rose' : 'emerald' },
   { label: 'E2E Critical', value: `${dashboard.e2eCriticalCoverage?.coveredCount ?? '—'}/${dashboard.e2eCriticalCoverage?.flowCount ?? '—'}`, icon: 'lucide:route', color: dashboard.e2eCriticalCoverage?.status === 'ok' ? 'emerald' : 'amber' },
   { label: 'API Gate', value: dashboard.api?.releaseGate?.status || '—', icon: 'lucide:shield-check', color: dashboard.api?.releaseGate?.status === 'passed' ? 'emerald' : 'rose' },
   { label: 'API Debug', value: `${dashboard.api?.debugEnvelope?.passed ?? '—'}/${dashboard.api?.debugEnvelope?.total ?? '—'}`, icon: 'lucide:bug', color: dashboard.api?.debugEnvelope?.status === 'ok' ? 'emerald' : 'rose' },
   { label: 'DB P0', value: String(dashboard.dbRetirement?.p0QuarantineCandidateCount ?? dashboard.dbRetirement?.p0DropCandidateCount ?? '—'), icon: 'lucide:database-zap', color: (dashboard.dbRetirement?.p0QuarantineCandidateCount ?? dashboard.dbRetirement?.p0DropCandidateCount ?? 0) > 0 ? 'amber' : 'emerald' },
   { label: 'DB Gözlem', value: `${dashboard.dbObservationCadence?.snapshotCount ?? '—'}/${dashboard.dbObservationCadence?.observationDays ?? '—'}`, icon: 'lucide:calendar-clock', color: dashboard.dbObservationCadence?.status === 'stale' ? 'rose' : 'amber' },
   { label: 'DB Takvim', value: `${dashboard.dbObservationCalendar?.completeCount ?? '—'}/${dashboard.dbObservationCalendar?.observationDays ?? '—'}`, icon: 'lucide:calendar-days', color: dashboard.dbObservationCalendar?.status === 'complete' ? 'emerald' : 'amber' },
   { label: 'DB Registry', value: String(dashboard.dbRegistryClassification?.unclassifiedCount ?? '—'), icon: 'lucide:database-backup', color: (dashboard.dbRegistryClassification?.unclassifiedCount ?? 0) > 0 ? 'amber' : 'emerald' },
   { label: 'DB Runtime Hold', value: String(dashboard.dbRuntimeHoldPlan?.runtimeReferenceCount ?? '—'), icon: 'lucide:git-pull-request-draft', color: dashboard.dbRuntimeHoldPlan?.status === 'clear' ? 'emerald' : 'amber' },
   { label: 'DB Manuel Karar', value: dashboard.dbManualDecisionReadiness?.status || '—', icon: 'lucide:file-check-2', color: dashboard.dbManualDecisionReadiness?.status === 'manual_review_ready' ? 'amber' : 'emerald' },
   { label: 'Upload Bucket', value: dashboard.localUploadBucketQuota?.status || '—', icon: 'lucide:folder-kanban', color: dashboard.localUploadBucketQuota?.status === 'ok' ? 'emerald' : dashboard.localUploadBucketQuota?.status === 'blocked' ? 'rose' : 'amber' },
   { label: 'Local Medya', value: dashboard.localMediaStorageGate?.status || '—', icon: 'lucide:hard-drive', color: dashboard.localMediaStorageGate?.status === 'ok' && dashboard.localMediaStorageGate?.localStorageOnly ? 'emerald' : 'rose' },
   { label: 'Media Readiness', value: `${dashboard.mediaReadiness?.passed ?? '—'}/${dashboard.mediaReadiness?.checks ?? '—'}`, icon: 'lucide:image-up', color: dashboard.mediaReadiness?.status === 'ok' && dashboard.mediaReadiness?.localStorageOnly ? 'emerald' : 'rose' },
   { label: 'Admin Role', value: `${dashboard.adminStrictRoleGate?.ok ?? '—'}/${dashboard.adminStrictRoleGate?.checked ?? '—'}`, icon: 'lucide:user-lock', color: dashboard.adminStrictRoleGate?.status === 'ok' ? 'emerald' : 'rose' },
   { label: 'Redis', value: dashboard.redisRuntimeHealth?.status || '—', icon: 'lucide:database', color: dashboard.redisRuntimeHealth?.status === 'ok' ? 'emerald' : dashboard.redisRuntimeHealth?.releaseBlocker ? 'rose' : 'amber' },
   { label: 'Warmup', value: dashboard.warmupSafety?.status || '—', icon: 'lucide:flame-kindling', color: dashboard.warmupSafety?.status === 'ok' ? 'emerald' : 'rose' },
   { label: 'Cron', value: `${dashboard.cronReadiness?.presentJobCount ?? '—'}/${dashboard.cronReadiness?.requiredJobCount ?? '—'}`, icon: 'lucide:calendar-cog', color: dashboard.cronReadiness?.status === 'ok' ? 'emerald' : 'rose' },
   { label: 'LLMS/Sitemap', value: `${dashboard.llmsSitemapAutoUpdate?.ok ?? '—'}/${dashboard.llmsSitemapAutoUpdate?.checks ?? '—'}`, icon: 'lucide:bot', color: dashboard.llmsSitemapAutoUpdate?.status === 'ok' ? 'emerald' : 'rose' },
   { label: 'GMaps CLI', value: dashboard.gmapsScraperReadiness?.status || '—', icon: 'lucide:map-pinned', color: dashboard.gmapsScraperReadiness?.status === 'ok' ? 'emerald' : 'amber' },
   { label: 'Keşif Draft', value: String(dashboard.gmapsDiscoveryDrafts?.pendingDraftCount ?? '—'), icon: 'lucide:map-plus', color: dashboard.gmapsDiscoveryDrafts?.status === 'ok' && dashboard.gmapsDiscoveryDrafts?.autoPublish === false ? 'emerald' : 'amber' },
   { label: 'İçerik Draft', value: String(dashboard.contentAgentDrafts?.pending ?? '—'), icon: 'lucide:file-pen-line', color: dashboard.contentAgentDrafts?.status === 'ok' && dashboard.contentAgentDrafts?.pending === 0 && dashboard.contentAgentDrafts?.autoPublish === false ? 'emerald' : 'amber' },
   { label: 'Toplu Yayın', value: String(dashboard.publishAllContentDrafts?.remainingDraftLike ?? '—'), icon: 'lucide:send-horizontal', color: dashboard.publishAllContentDrafts?.status === 'ok' && dashboard.publishAllContentDrafts?.remainingDraftLike === 0 ? 'emerald' : 'amber' },
   { label: 'Rich Results', value: `${dashboard.blogDraftRichResults?.ok ?? '—'}/${dashboard.blogDraftRichResults?.drafts ?? '—'}`, icon: 'lucide:sparkles', color: dashboard.blogDraftRichResults?.status === 'ok' ? 'emerald' : 'amber' },
   { label: 'Lighthouse CI', value: dashboard.pagespeedApiLessLighthouse?.externalExpectedReview ? 'expected' : dashboard.pagespeedApiLessLighthouse?.performance != null ? String(dashboard.pagespeedApiLessLighthouse.performance) : dashboard.pagespeedApiLessLighthouse?.status || '—', icon: 'lucide:activity', color: dashboard.pagespeedApiLessLighthouse?.status === 'ok' || dashboard.pagespeedApiLessLighthouse?.externalExpectedReview ? 'emerald' : dashboard.pagespeedApiLessLighthouse?.status === 'review' ? 'amber' : 'rose' },
   { label: 'Scripts', value: String(dashboard.scriptCanonicalSurface?.totalScripts ?? '—'), icon: 'lucide:terminal-square', color: (dashboard.scriptCanonicalSurface?.missingCanonicalCount ?? 0) === 0 ? 'emerald' : 'rose' },
   { label: 'Migration Drift', value: dashboard.migrationDuplicateDrift?.status || '—', icon: 'lucide:git-compare-arrows', color: dashboard.migrationDuplicateDrift?.status === 'ok' ? 'emerald' : 'rose' },
  ]} />

  {dashboard.advisoryReasons && dashboard.advisoryReasons.length > 0 && (
   <section class="rr-section">
    <header class="rr-section-head">
     <h2 class="rr-section-title">
      <Icon name="lucide:info" class="w-4 h-4" /> Advisory Sebepleri
     </h2>
     <span class="rr-section-meta">{dashboard.advisoryReasons.length} neden</span>
    </header>
    <div class="rr-list">
     {dashboard.advisoryReasons.map((item) => (
      <div class="rr-row rr-row--warn">
       <div class="rr-row-info">
        <code class="rr-row-key">{item.code || 'advisory'}</code>
        <span class="rr-row-resolution">{item.detail || 'Detay yok'}</span>
       </div>
       <span class="rr-row-status rr-row-status--warn">ADVISORY</span>
      </div>
     ))}
    </div>
  </section>
 )}

  <section class="rr-section">
   <header class="rr-section-head">
    <h2 class="rr-section-title">
     <Icon name="lucide:layout-dashboard" class="w-4 h-4" /> İçerik ve Keşif Operasyonları
    </h2>
    <span class="rr-section-meta">admin onaylı, local storage, autopublish kapalı</span>
   </header>
   <div class="rr-list">
    <div class:list={['rr-row', dashboard.gmapsScraperReadiness?.status === 'ok' && 'rr-row--ok', dashboard.gmapsScraperReadiness?.status !== 'ok' && 'rr-row--warn']}>
     <div class="rr-row-info">
      <code class="rr-row-key">google maps scraper readiness</code>
      <span class="rr-row-resolution">
       binary={dashboard.gmapsScraperReadiness?.binaryFound ? 'found' : 'missing'} · cli={dashboard.gmapsScraperReadiness?.cliOk ? 'ok' : 'review'} · local-storage={dashboard.gmapsScraperReadiness?.localStorageOnly ? 'yes' : 'no'}
      </span>
     </div>
     <span class:list={['rr-row-status', dashboard.gmapsScraperReadiness?.status === 'ok' ? 'rr-row-status--ok' : 'rr-row-status--warn']}>
      {dashboard.gmapsScraperReadiness?.status || 'not-run'}
     </span>
    </div>
    <div class:list={['rr-row', dashboard.gmapsDiscoveryDrafts?.status === 'ok' && dashboard.gmapsDiscoveryDrafts?.autoPublish === false && 'rr-row--ok', dashboard.gmapsDiscoveryDrafts?.autoPublish !== false && 'rr-row--warn']}>
     <div class="rr-row-info">
      <code class="rr-row-key">google maps discovery drafts</code>
      <span class="rr-row-resolution">
       {dashboard.gmapsDiscoveryDrafts?.candidateCount ?? 0} aday · pending={dashboard.gmapsDiscoveryDrafts?.pendingDraftCount ?? 0} · mode={dashboard.gmapsDiscoveryDrafts?.mode || 'unknown'} · upsert={dashboard.gmapsDiscoveryDrafts?.insertedOrUpdatedCount ?? 0} · autopublish={dashboard.gmapsDiscoveryDrafts?.autoPublish ? 'yes' : 'no'}
      </span>
     </div>
     <span class:list={['rr-row-status', dashboard.gmapsDiscoveryDrafts?.status === 'ok' && dashboard.gmapsDiscoveryDrafts?.autoPublish === false ? 'rr-row-status--ok' : 'rr-row-status--warn']}>
      {dashboard.gmapsDiscoveryDrafts?.status || 'not-run'}
     </span>
    </div>
    <div class:list={['rr-row', dashboard.contentAgentDrafts?.status === 'ok' && dashboard.contentAgentDrafts?.autoPublish === false && 'rr-row--ok', dashboard.contentAgentDrafts?.autoPublish !== false && 'rr-row--warn']}>
     <div class="rr-row-info">
      <code class="rr-row-key">content agent drafts</code>
      <span class="rr-row-resolution">
       total={dashboard.contentAgentDrafts?.total ?? 0} · pending={dashboard.contentAgentDrafts?.pending ?? 0} · stale={dashboard.contentAgentDrafts?.stalePendingCount ?? 0} · admin approval required · autopublish={dashboard.contentAgentDrafts?.autoPublish ? 'yes' : 'no'}
      </span>
     </div>
     <span class:list={['rr-row-status', dashboard.contentAgentDrafts?.status === 'ok' && dashboard.contentAgentDrafts?.autoPublish === false ? 'rr-row-status--ok' : 'rr-row-status--warn']}>
      {dashboard.contentAgentDrafts?.status || 'not-run'}
     </span>
    </div>
    <div class:list={['rr-row', dashboard.publishAllContentDrafts?.status === 'ok' && dashboard.publishAllContentDrafts?.remainingDraftLike === 0 && 'rr-row--ok', dashboard.publishAllContentDrafts?.status !== 'ok' && 'rr-row--warn']}>
     <div class="rr-row-info">
      <code class="rr-row-key">publish all content drafts</code>
      <span class="rr-row-resolution">
       remaining-draft-like={dashboard.publishAllContentDrafts?.remainingDraftLike ?? 0} · city-content-updated={dashboard.publishAllContentDrafts?.cityContentUpdated ?? 0} · moderation-pending={dashboard.publishAllContentDrafts?.moderationPending ?? 0} · moderation-auto-approved={dashboard.publishAllContentDrafts?.moderationQueuesAutoApproved ? 'yes' : 'no'}
      </span>
     </div>
     <span class:list={['rr-row-status', dashboard.publishAllContentDrafts?.status === 'ok' ? 'rr-row-status--ok' : 'rr-row-status--warn']}>
      {dashboard.publishAllContentDrafts?.status || 'not-run'}
     </span>
    </div>
   </div>
  </section>

  <section class="rr-section">
   <header class="rr-section-head">
    <h2 class="rr-section-title">
     <Icon name="lucide:search-check" class="w-4 h-4" /> SEO, AEO, GEO ve AIO Gate Özeti
    </h2>
