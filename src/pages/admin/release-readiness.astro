     <span class:list={['rr-row-status', dashboard.dbObservationCalendar?.status === 'complete' ? 'rr-row-status--ok' : 'rr-row-status--warn']}>
      {dashboard.dbObservationCalendar?.status || 'not-run'}
     </span>
    </div>
    <div class:list={['rr-row', dashboard.dbManualDecisionReadiness?.status === 'waiting' && 'rr-row--warn', dashboard.dbManualDecisionReadiness?.status === 'manual_review_ready' && 'rr-row--warn']}>
     <div class="rr-row-info">
      <code class="rr-row-key">db manual decision readiness</code>
      <span class="rr-row-resolution">{dashboard.dbManualDecisionReadiness?.readyForManualPrCount ?? 0} ready · {dashboard.dbManualDecisionReadiness?.waitingForEvidenceCount ?? 0} waiting · {dashboard.dbManualDecisionReadiness?.runtimeHoldCount ?? 0} runtime hold · auto drop yok</span>
     </div>
     <span class="rr-row-status rr-row-status--warn">
     {dashboard.dbManualDecisionReadiness?.status || 'not-run'}
    </span>
   </div>
    <div class:list={['rr-row', dashboard.dbRuntimeHoldPlan?.status === 'clear' && 'rr-row--ok', dashboard.dbRuntimeHoldPlan?.status !== 'clear' && 'rr-row--warn']}>
     <div class="rr-row-info">
      <code class="rr-row-key">db runtime hold plan</code>
      <span class="rr-row-resolution">
       table={dashboard.dbRuntimeHoldPlan?.table || 'unknown'} · refs={dashboard.dbRuntimeHoldPlan?.runtimeReferenceCount ?? 0} · incompatible-contracts={dashboard.dbRuntimeHoldPlan?.incompatibleContractCount ?? 0} · auto-drop={dashboard.dbRuntimeHoldPlan?.automaticDropAllowed ? 'yes' : 'no'}
      </span>
     </div>
     <span class:list={['rr-row-status', dashboard.dbRuntimeHoldPlan?.status === 'clear' ? 'rr-row-status--ok' : 'rr-row-status--warn']}>
      {dashboard.dbRuntimeHoldPlan?.status || 'not-run'}
     </span>
    </div>
   <div class:list={['rr-row', (dashboard.dbRegistryClassification?.unclassifiedCount ?? 0) === 0 && 'rr-row--ok', (dashboard.dbRegistryClassification?.unclassifiedCount ?? 0) > 0 && 'rr-row--warn']}>
     <div class="rr-row-info">
      <code class="rr-row-key">db registry classification</code>
      <span class="rr-row-resolution">{dashboard.dbRegistryClassification?.tableCount ?? 0} tablo · {dashboard.dbRegistryClassification?.unclassifiedCount ?? 0} unclassified · {dashboard.dbRegistryClassification?.unusedIndexCount ?? 0} unused index · auto drop {dashboard.dbRegistryClassification?.automaticDbDropAllowed ? 'açık' : 'kapalı'}</span>
     </div>
     <span class:list={['rr-row-status', (dashboard.dbRegistryClassification?.unclassifiedCount ?? 0) === 0 ? 'rr-row-status--ok' : 'rr-row-status--warn']}>
      {dashboard.dbRegistryClassification?.status || 'not-run'}
     </span>
    </div>
    <div class:list={['rr-row', (dashboard.searchZeroResult?.unresolvedCount ?? 0) === 0 && 'rr-row--ok', (dashboard.searchZeroResult?.unresolvedCount ?? 0) > 0 && 'rr-row--err']}>
     <div class="rr-row-info">
      <code class="rr-row-key">zero-result search</code>
      <span class="rr-row-resolution">{dashboard.searchZeroResult?.unresolvedCount ?? 0} unresolved · {dashboard.searchZeroResult?.unresolvedOccurrences ?? 0} occurrence</span>
     </div>
     <span class:list={['rr-row-status', (dashboard.searchZeroResult?.unresolvedCount ?? 0) === 0 ? 'rr-row-status--ok' : 'rr-row-status--err']}>
      {dashboard.searchZeroResult?.status || 'not-run'}
     </span>
    </div>
   </div>
  </section>

  {dashboard.gateSummary && (
   <section class="rr-section">
    <header class="rr-section-head">
     <h2 class="rr-section-title">
      <Icon name="lucide:gauge" class="w-4 h-4" /> Tek Bakış Gate Özeti
     </h2>
     <span class="rr-section-meta">{dashboard.decision || 'UNKNOWN'}</span>
    </header>
    <div class="rr-list">
     {Object.entries(dashboard.gateSummary).map(([key, value]) => {
      const ok = value === true || value === 'ready' || value === 'passed' || value === 'ok';
      const warn = value === 'not-run' || value === 'ready_with_advisories' || value === 'review';
      return (
       <div class:list={['rr-row', ok && 'rr-row--ok', warn && 'rr-row--warn', !ok && !warn && 'rr-row--err']}>
        <code class="rr-row-key">{key}</code>
        <span class:list={['rr-row-status', ok ? 'rr-row-status--ok' : warn ? 'rr-row-status--warn' : 'rr-row-status--err']}>
         {String(value)}
        </span>
       </div>
      );
     })}
    </div>
   </section>
  )}

  {dashboard.e2eFailures && dashboard.e2eFailures.length > 0 && (
   <section class="rr-section">
    <header class="rr-section-head">
     <h2 class="rr-section-title">
      <Icon name="lucide:bug" class="w-4 h-4" /> E2E Failure Detayları
     </h2>
     <span class="rr-section-meta">{dashboard.e2eFailures.length} failure</span>
    </header>
    <div class="rr-list">
     {dashboard.e2eFailures.map((item) => (
      <div class="rr-row rr-row--err">
       <div class="rr-row-info">
        <code class="rr-row-key">{item.spec || 'unknown spec'}</code>
        <span class="rr-row-resolution">{item.title || 'unknown test'}</span>
       </div>
       <span class="rr-row-status rr-row-status--err">{item.outcome || 'failed'}</span>
      </div>
     ))}
    </div>
   </section>
  )}

  <section class="rr-section">
   <header class="rr-section-head">
    <h2 class="rr-section-title">
     <Icon name="lucide:list-checks" class="w-4 h-4" /> Checklist Kontrolleri
    </h2>
    <span class="rr-section-meta">{checksOk}/{checksTotal} başarılı</span>
   </header>
   <div class="rr-list">
    {(dashboard.checks || []).map((item) => (
     <div class:list={['rr-row', item.ok && 'rr-row--ok', !item.ok && 'rr-row--err']}>
      <code class="rr-row-key">{item.rel}</code>
      <span class:list={['rr-row-status', item.ok ? 'rr-row-status--ok' : 'rr-row-status--err']}>
       {item.ok ? '✓ OK' : '✕ EKSİK'}
      </span>
     </div>
    ))}
    {checksTotal === 0 && <p class="rr-empty">Henüz rapor üretilmemiş. CLI: <code>npm run release:dashboard</code></p>}
   </div>
  </section>

  <section class="rr-section">
   <header class="rr-section-head">
    <h2 class="rr-section-title">
     <Icon name="lucide:settings-2" class="w-4 h-4" /> Homepage Config Sağlığı
    </h2>
    <span class="rr-section-meta">{configsValid}/{configsTotal} valid</span>
   </header>
   <div class="rr-list">
    {homepageConfigStatuses.map((item) => (
     <div class:list={['rr-row', item.valid && 'rr-row--ok', !item.valid && 'rr-row--err']}>
      <div class="rr-row-info">
       <code class="rr-row-key">{item.key}</code>
       <span class="rr-row-resolution">
        {item.resolution === 'cms-valid' ? 'kaynak: cms'
         : item.resolution === 'cms-invalid-fallback' ? 'kaynak: cms (fallback aktif)'
         : 'kaynak: fallback'}
       </span>
      </div>
      <span class:list={['rr-row-status', item.valid ? 'rr-row-status--ok' : 'rr-row-status--err']}>
       {item.valid ? '✓ VALID' : item.hasRow ? '✕ INVALID' : '○ EKSİK'}
      </span>
     </div>
    ))}
   </div>
   {invalidHomepageConfigs.length > 0 && (
    <div class="rr-warn">
     <Icon name="lucide:alert-triangle" class="w-3.5 h-3.5" />
     Invalid <code>homepage.*</code> payload tespit edildi. Fallback çalışıyor; prod deploy bloklanmalı.
    </div>
   )}
  </section>

  <section class="rr-section">
   <header class="rr-section-head">
    <h2 class="rr-section-title">
     <Icon name="lucide:radio" class="w-4 h-4" /> Canlı Servis Tazeliği
    </h2>
   </header>
   <div class="rr-list">
    {freshnessRows.map((item) => (
     <div class:list={['rr-row', !item.stale && 'rr-row--ok', item.stale && 'rr-row--warn']}>
      <code class="rr-row-key">{item.key}</code>
      <span class:list={['rr-row-status', item.stale ? 'rr-row-status--warn' : 'rr-row-status--ok']}>
       {item.stale ? '⚠ STALE' : '✓ OK'}
      </span>
     </div>
    ))}
    {freshnessRows.length === 0 && <p class="rr-empty">Tazelik verisi bulunamadı.</p>}
   </div>
  </section>

  <section class="rr-section">
   <header class="rr-section-head">
    <h2 class="rr-section-title">
     <Icon name="lucide:layout" class="w-4 h-4" /> Homepage Section Sırası ve Görünürlüğü
    </h2>
   </header>
   <div class="rr-list">
    {homepageSectionSummary.map((item) => (
     <div class:list={['rr-row', item.enabled && 'rr-row--ok', !item.enabled && 'rr-row--warn']}>
      <div class="rr-row-info">
       <span class="rr-order">{item.order}</span>
       <code class="rr-row-key">{item.id}</code>
      </div>
      <span class:list={['rr-row-status', item.enabled ? 'rr-row-status--ok' : 'rr-row-status--warn']}>
       {item.enabled ? '✓ AKTİF' : '○ KAPALI'}
      </span>
     </div>
    ))}
   </div>
  </section>
 </div>

 <style>
  .rr-page { display: flex; flex-direction: column; gap: 1.25rem; }

  .rr-banner {
   display: flex; gap: 1rem; align-items: center;
   padding: 1rem 1.25rem;
   border-radius: 12px;
   border: 1px solid var(--adm-border);
  }
  .rr-banner--ok {
   background: rgba(16,185,129,0.06);
   border-color: rgba(16,185,129,0.25);
  }
  .rr-banner--err {
   background: rgba(225,29,72,0.06);
   border-color: rgba(225,29,72,0.25);
  }
  .rr-banner--warn {
   background: rgba(217,119,6,0.06);
   border-color: rgba(217,119,6,0.25);
  }
  .rr-banner-icon {
   width: 44px; height: 44px;
   border-radius: 11px;
   display: inline-flex; align-items: center; justify-content: center;
   flex-shrink: 0;
  }
  .rr-banner--ok .rr-banner-icon { background: rgba(16,185,129,0.15); color: rgb(5,150,105); }
  .rr-banner--err .rr-banner-icon { background: rgba(225,29,72,0.15); color: rgb(190,18,60); }
  .rr-banner--warn .rr-banner-icon { background: rgba(217,119,6,0.15); color: rgb(180,83,9); }
  .rr-banner-title {
   font-family: 'Cormorant Garamond', serif;
   font-size: 1.3rem; font-weight: 700;
   color: var(--adm-text);
  }
  .rr-banner-sub {
   font-size: 0.82rem;
   color: var(--adm-text-soft);
   margin-top: 0.2rem;
  }

  .rr-section {
   background: var(--adm-bg-elev);
   border: 1px solid var(--adm-border);
   border-radius: 12px;
   overflow: hidden;
  }
  .rr-section-head {
   display: flex; align-items: center; justify-content: space-between;
   padding: 0.95rem 1.15rem;
   border-bottom: 1px solid var(--adm-border);
   background: var(--adm-bg-hover);
  }
  .rr-section-title {
   display: inline-flex; align-items: center; gap: 0.5rem;
   margin: 0;
   font-size: 0.95rem; font-weight: 600;
   color: var(--adm-text);
  }
  .rr-section-meta {
   font-size: 0.78rem;
   color: var(--adm-text-soft);
   font-weight: 500;
  }

  .rr-list { padding: 0.65rem; display: flex; flex-direction: column; gap: 0.35rem; }

  .rr-row {
   display: flex; align-items: center; justify-content: space-between;
   gap: 0.85rem;
   padding: 0.55rem 0.85rem;
   background: var(--adm-bg);
   border: 1px solid var(--adm-border);
   border-radius: 8px;
   transition: border-color 0.15s;
  }
  .rr-row--ok { border-left: 3px solid rgb(5,150,105); }
  .rr-row--err { border-left: 3px solid rgb(190,18,60); }
  .rr-row--warn { border-left: 3px solid rgb(180,83,9); }
  .rr-row-info { display: flex; flex-direction: column; gap: 0.2rem; min-width: 0; }
  .rr-row-key {
   font-family: 'Menlo', 'Monaco', monospace;
   font-size: 0.76rem;
   color: var(--adm-text);
  }
  .rr-row-resolution {
   font-size: 0.68rem;
   color: var(--adm-text-soft);
   text-transform: uppercase;
   letter-spacing: 0.06em;
  }
  .rr-row-status {
   font-size: 0.74rem; font-weight: 700;
   white-space: nowrap;
   padding: 0.2rem 0.55rem;
   border-radius: 999px;
  }
  .rr-row-status--ok { background: rgba(16,185,129,0.12); color: rgb(5,150,105); }
  .rr-row-status--err { background: rgba(225,29,72,0.12); color: rgb(190,18,60); }
  .rr-row-status--warn { background: rgba(217,119,6,0.12); color: rgb(180,83,9); }

  .rr-order {
   display: inline-flex; align-items: center; justify-content: center;
   min-width: 22px; height: 22px;
   padding: 0 0.4rem;
   background: var(--adm-accent);
   color: #fff;
   border-radius: 999px;
   font-size: 0.7rem; font-weight: 700;
   margin-right: 0.5rem;
  }

  .rr-empty {
   text-align: center;
   padding: 1.5rem;
   color: var(--adm-text-soft);
   font-size: 0.86rem;
   margin: 0;
  }
  .rr-empty code {
   background: var(--adm-bg);
   padding: 0.15rem 0.4rem;
   border-radius: 4px;
   font-family: 'Menlo', 'Monaco', monospace;
   color: var(--adm-accent);
  }

  .rr-warn {
   margin: 0 1rem 1rem;
   padding: 0.55rem 0.85rem;
   background: rgba(225,29,72,0.06);
   border: 1px solid rgba(225,29,72,0.18);
   border-radius: 8px;
   color: rgb(190,18,60);
   font-size: 0.82rem;
   display: flex; align-items: center; gap: 0.4rem;
  }
  .rr-warn code {
   background: rgba(225,29,72,0.1);
   padding: 0.1rem 0.3rem;
   border-radius: 4px;
   font-family: 'Menlo', 'Monaco', monospace;
  }
 </style>
</AdminLayout>
