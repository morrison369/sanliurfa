---
import { Icon } from 'astro-icon/components';
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { query } from '../../../../lib/postgres';
import { logger } from '../../../../lib/logging';

const { id } = Astro.params;

let place: any = null;
let categories: any[] = [];

try {
  const [placeResult, catResult] = await Promise.all([
    query(
      `SELECT p.*, c.name as category_name, d.name as district_name
       FROM places p
       LEFT JOIN categories c ON c.id = p.category_id
       LEFT JOIN districts d ON d.id = p.district_id
       WHERE p.id = $1`,
      [id]
    ),
    query(
      `SELECT id, name, slug FROM categories WHERE parent_id IS NOT NULL AND is_active = true ORDER BY sort_order`,
      []
    ),
  ]);
  place = placeResult.rows[0] || null;
  categories = catResult.rows;
} catch (e) {
  logger.error('Edit place load error', e instanceof Error ? e : new Error(String(e)));
}

if (!place) {
  return Astro.redirect('/admin/places?error=not_found');
}

const amenitiesList = [
  'Otopark', 'Wifi', 'Klima', 'Bahçe', 'Teras', 'Engelli Erişimi',
  'Paket Servis', 'Rezervasyon', 'Canlı Müzik', 'Çocuk Oyun Alanı',
  'Evcil Hayvan Dostu', 'Sigara İçilebilir Alan'
];

const days = [
  { id: 'monday', label: 'Pazartesi' },
  { id: 'tuesday', label: 'Salı' },
  { id: 'wednesday', label: 'Çarşamba' },
  { id: 'thursday', label: 'Perşembe' },
  { id: 'friday', label: 'Cuma' },
  { id: 'saturday', label: 'Cumartesi' },
  { id: 'sunday', label: 'Pazar' },
];
---

<AdminLayout
  title="Mekan Düzenle"
  subtitle={`${place.name} — ID: ${id}`}
  seo={{ title: `Mekan Düzenle: ${place.name} - Yönetim Paneli`, noIndex: true }}
>
    <div class="container mx-auto px-4 py-8 max-w-6xl">
      <div class="mb-6">
        <a href="/admin" class="text-sm text-[#9A8470] hover:text-[#6B5540]">← Admin Paneli</a>
      </div>

      <form action={`/api/places/${id}/update`} method="POST" class="grid lg:grid-cols-3 gap-8" enctype="multipart/form-data">
        <div class="lg:col-span-2 space-y-5">
          <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
            <h2 class="text-lg font-semibold text-[#1A1008] mb-4">Temel Bilgiler</h2>
            <div class="space-y-4">
              <div>
                <label for="name" class="block text-sm font-medium text-[#6B5540] mb-1">Mekan Adı *</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
                  value={place.name}
                />
              </div>

              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label for="category_id" class="block text-sm font-medium text-[#6B5540] mb-1">Kategori *</label>
                  <select id="category_id" name="category_id" required class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400">
                    <option value="">Kategori seçin</option>
                    {categories.map(cat => (
                      <option value={cat.id} selected={cat.id === place.category_id}>{cat.name}</option>
                    ))}
                  </select>
                </div>
                <div>
                  <label for="price_range" class="block text-sm font-medium text-[#6B5540] mb-1">Fiyat Aralığı</label>
                  <select id="price_range" name="price_range" class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400">
                    <option value="1" selected={place.price_range === 1}>₺ - Ucuz</option>
                    <option value="2" selected={place.price_range === 2}>₺₺ - Orta</option>
                    <option value="3" selected={place.price_range === 3}>₺₺₺ - Pahalı</option>
                    <option value="4" selected={place.price_range === 4}>₺₺₺₺ - Lüks</option>
                  </select>
                </div>
              </div>

              <div>
                <label for="description" class="block text-sm font-medium text-[#6B5540] mb-1">Açıklama *</label>
                <textarea
                  id="description"
                  name="description"
                  rows="4"
                  required
                  class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400 resize-none"
                >{place.description}</textarea>
              </div>

              <div>
                <label for="short_description" class="block text-sm font-medium text-[#6B5540] mb-1">Kısa Açıklama</label>
                <input
                  type="text"
                  id="short_description"
                  name="short_description"
                  maxlength="150"
                  class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
                  value={place.short_description}
                />
              </div>
            </div>
          </div>

          <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
            <h2 class="text-lg font-semibold text-[#1A1008] mb-4">İletişim Bilgileri</h2>
            <div class="space-y-4">
              <div>
                <label for="address" class="block text-sm font-medium text-[#6B5540] mb-1">Adres *</label>
                <div class="relative">
                  <Icon name="lucide:map-pin" class="absolute left-3 top-3 w-5 h-5 text-[#9A8470]" />
                  <input
                    type="text"
                    id="address"
                    name="address"
                    required
                    class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] pl-10 px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
                    value={place.address}
                  />
                </div>
              </div>

              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label for="phone" class="block text-sm font-medium text-[#6B5540] mb-1">Telefon</label>
                  <div class="relative">
                    <Icon name="lucide:phone" class="absolute left-3 top-3 w-5 h-5 text-[#9A8470]" />
                    <input
                      type="tel"
                      id="phone"
                      name="phone"
                      class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] pl-10 px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
                      value={place.phone}
                    />
                  </div>
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium text-[#6B5540] mb-1">E-posta</label>
                  <div class="relative">
                    <Icon name="lucide:mail" class="absolute left-3 top-3 w-5 h-5 text-[#9A8470]" />
                    <input
                      type="email"
                      id="email"
                      name="email"
                      class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] pl-10 px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
                      value={place.email}
                    />
                  </div>
                </div>
              </div>

              <div>
                <label for="website" class="block text-sm font-medium text-[#6B5540] mb-1">Web Sitesi</label>
                <div class="relative">
                  <Icon name="lucide:globe" class="absolute left-3 top-3 w-5 h-5 text-[#9A8470]" />
                  <input
                    type="url"
                    id="website"
                    name="website"
                    class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] pl-10 px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
                    value={place.website}
                  />
                </div>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
            <h2 class="text-lg font-semibold text-[#1A1008] mb-4">Çalışma Saatleri</h2>
            <div class="space-y-3">
              {days.map(day => (
                <div class="flex items-center gap-4">
                  <span class="w-24 text-sm text-[#6B5540]">{day.label}</span>
                  <input
                    type="text"
                    name={`opening_hours_${day.id}`}
                    class="flex-1 rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
                    value={place.opening_hours?.[day.id] || ''}
                    placeholder="08:00 - 22:00 veya Kapalı"
                  />
                </div>
              ))}
            </div>
          </div>
        </div>

        <aside class="space-y-5">
          <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
            <h3 class="font-semibold text-[#1A1008] mb-4">Yayınla</h3>
            <div class="space-y-3">
              <label class="flex items-center gap-2">
                <input type="checkbox" name="is_featured" checked={place.is_featured} class="rounded border-[rgba(200,160,100,0.3)] text-urfa-600" />
                <span class="text-sm text-[#6B5540]">Öne çıkan mekan</span>
              </label>
              <label class="flex items-center gap-2">
                <input type="checkbox" name="is_verified" checked={place.is_verified} class="rounded border-[rgba(200,160,100,0.3)] text-urfa-600" />
                <span class="text-sm text-[#6B5540]">Doğrulanmış mekan</span>
              </label>
            </div>
            <div class="mt-4 pt-4 border-t border-[rgba(200,160,100,0.14)]">
              <label for="status" class="block text-sm font-medium text-[#6B5540] mb-1">Durum</label>
              <select id="status" name="status" class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400">
                <option value="active" selected={place.status === 'active'}>Aktif</option>
                <option value="pending" selected={place.status === 'pending'}>Beklemede</option>
                <option value="inactive" selected={place.status === 'inactive'}>Pasif</option>
              </select>
            </div>
            <div class="flex gap-2 mt-4">
              <button type="submit" class="rounded-sm bg-urfa-600 flex-1 flex items-center justify-center gap-2 px-4 py-2 text-sm font-semibold text-white hover:bg-urfa-700">
                <Icon name="lucide:save" class="w-4 h-4" />
                Kaydet
              </button>
            </div>
          </div>

          <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
            <h3 class="font-semibold text-[#1A1008] mb-4">Olanaklar</h3>
            <div class="space-y-2 max-h-64 overflow-y-auto">
              {amenitiesList.map(amenity => (
                <label class="flex items-center gap-2">
                  <input
                    type="checkbox"
                    name="amenities"
                    value={amenity}
                    checked={place.amenities?.includes(amenity)}
                    class="rounded border-[rgba(200,160,100,0.3)] text-urfa-600"
                  />
                  <span class="text-sm text-[#6B5540]">{amenity}</span>
                </label>
              ))}
            </div>
          </div>

          <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
            <h3 class="font-semibold text-[#1A1008] mb-4">Etiketler</h3>
            <input
              type="text"
              name="tags"
              class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
              value={place.tags?.join(', ')}
              placeholder="Etiketleri virgülle ayırın"
            />
          </div>
        </aside>
      </form>
    </div>
</AdminLayout>
