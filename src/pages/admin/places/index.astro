---
import Layout from '../../../layouts/Layout.astro';
import { query } from '../../../lib/postgres';

const user = Astro.locals.user;

if (!user || !Astro.locals.isAdmin) {
  return Astro.redirect('/giris?redirect=/admin/places');
}

const search = Astro.url.searchParams.get('q')?.trim() || '';
const status = Astro.url.searchParams.get('status') || 'all';
const allowedStatuses = new Set(['all', 'active', 'pending', 'inactive']);
const selectedStatus = allowedStatuses.has(status) ? status : 'all';

const values: unknown[] = [];
const filters: string[] = [];

if (selectedStatus !== 'all') {
  values.push(selectedStatus);
  filters.push(`status = $${values.length}`);
}

if (search) {
  values.push(`%${search}%`);
  filters.push(`(name ILIKE $${values.length} OR address ILIKE $${values.length} OR category ILIKE $${values.length})`);
}

const where = filters.length ? `WHERE ${filters.join(' AND ')}` : '';
const result = await query(
  `SELECT id, name, slug, category, status, is_featured, is_verified, rating, review_count, updated_at
   FROM places
   ${where}
   ORDER BY updated_at DESC NULLS LAST, created_at DESC
   LIMIT 100`,
  values
);

const places = result.rows;
const seo = { title: 'Mekan Yönetimi - Admin', noindex: true };
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-100 dark:bg-gray-900 py-8">
    <div class="container-custom">
      <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between mb-8">
        <div>
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Mekan Yönetimi</h1>
          <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Mekanları veritabanından yönetin; örnek veri gösterilmez.</p>
        </div>
        <div class="flex gap-3">
          <a href="/admin" class="btn-secondary">Admin Panel</a>
          <a href="/admin/places/add" class="btn-primary">Yeni Mekan Ekle</a>
        </div>
      </div>

      <form method="GET" action="/admin/places" class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4 mb-6 grid gap-4 md:grid-cols-[1fr_180px_auto]">
        <input
          type="search"
          name="q"
          value={search}
          placeholder="Mekan adı, adres veya kategori ara"
          class="input dark:bg-gray-700 dark:border-gray-600 dark:text-white"
        />
        <select name="status" class="input dark:bg-gray-700 dark:border-gray-600 dark:text-white">
          <option value="all" selected={selectedStatus === 'all'}>Tüm durumlar</option>
          <option value="active" selected={selectedStatus === 'active'}>Aktif</option>
          <option value="pending" selected={selectedStatus === 'pending'}>Beklemede</option>
          <option value="inactive" selected={selectedStatus === 'inactive'}>Pasif</option>
        </select>
        <button type="submit" class="btn-primary">Filtrele</button>
      </form>

      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm overflow-hidden">
        {places.length > 0 ? (
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead class="bg-gray-50 dark:bg-gray-700">
                <tr>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Mekan</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Kategori</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Durum</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Puan</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Güncelleme</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">İşlemler</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                {places.map((place) => (
                  <tr>
                    <td class="px-6 py-4">
                      <div class="font-medium text-gray-900 dark:text-white">{place.name}</div>
                      <div class="text-sm text-gray-500 dark:text-gray-400">/{place.slug}</div>
                      <div class="flex gap-2 mt-2">
                        {place.is_featured && <span class="text-xs px-2 py-1 rounded-full bg-amber-100 text-amber-800">Öne çıkan</span>}
                        {place.is_verified && <span class="text-xs px-2 py-1 rounded-full bg-green-100 text-green-800">Doğrulanmış</span>}
                      </div>
                    </td>
                    <td class="px-6 py-4 text-sm text-gray-700 dark:text-gray-300">{place.category}</td>
                    <td class="px-6 py-4">
                      <span class={`text-xs px-2 py-1 rounded-full ${
                        place.status === 'active'
                          ? 'bg-green-100 text-green-800'
                          : place.status === 'pending'
                            ? 'bg-yellow-100 text-yellow-800'
                            : 'bg-gray-100 text-gray-800'
                      }`}>
                        {place.status === 'active' ? 'Aktif' : place.status === 'pending' ? 'Beklemede' : 'Pasif'}
                      </span>
                    </td>
                    <td class="px-6 py-4 text-sm text-gray-700 dark:text-gray-300">
                      {Number(place.rating || 0).toFixed(1)} / {place.review_count || 0} yorum
                    </td>
                    <td class="px-6 py-4 text-sm text-gray-500 dark:text-gray-400">
                      {place.updated_at ? new Date(place.updated_at).toLocaleDateString('tr-TR') : '-'}
                    </td>
                    <td class="px-6 py-4">
                      <div class="flex gap-3 text-sm">
                        <a href={`/admin/places/edit/${place.id}`} class="text-urfa-600 hover:text-urfa-700">Düzenle</a>
                        <a href={`/places/${place.slug}`} class="text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">Görüntüle</a>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        ) : (
          <div class="text-center py-12">
            <p class="text-gray-600 dark:text-gray-400">Filtreye uygun mekan bulunamadı.</p>
          </div>
        )}
      </div>
    </div>
  </div>
</Layout>
