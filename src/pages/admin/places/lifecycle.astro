---
import Layout from '../../../layouts/Layout.astro';

const seo = {
  title: 'Mekan Yaşam Döngüsü - Admin',
  description: 'Mekan durum geçişleri ve SLA ihlal görünümü',
  noIndex: true,
};
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50 pt-20 pb-12">
    <div class="container mx-auto px-4 space-y-6">
      <div class="bg-white rounded-xl shadow-sm p-6">
        <h1 class="text-2xl font-bold text-gray-900">Mekan Yaşam Döngüsü</h1>
        <p class="text-gray-500 mt-1">Durum geçişlerini ve SLA ihlallerini izleyin.</p>
      </div>

      <div class="grid md:grid-cols-4 gap-4" id="slaCards">
        <div class="bg-white rounded-xl shadow-sm p-5">
          <p class="text-sm text-gray-500">SLA Saat</p>
          <p class="text-2xl font-bold text-gray-900 mt-1" id="slaHours">-</p>
        </div>
        <div class="bg-white rounded-xl shadow-sm p-5">
          <p class="text-sm text-gray-500">Beklemede</p>
          <p class="text-2xl font-bold text-gray-900 mt-1" id="pendingCount">-</p>
        </div>
        <div class="bg-white rounded-xl shadow-sm p-5">
          <p class="text-sm text-gray-500">Bilgi Gerekli</p>
          <p class="text-2xl font-bold text-gray-900 mt-1" id="needsInfoCount">-</p>
        </div>
        <div class="bg-white rounded-xl shadow-sm p-5">
          <p class="text-sm text-gray-500">SLA İhlali</p>
          <p class="text-2xl font-bold text-red-700 mt-1" id="breachedCount">-</p>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-lg font-bold text-gray-900">Son Geçişler</h2>
          <div class="flex items-center gap-2">
            <a
              id="exportLink"
              href="/api/admin/places/lifecycle/export"
              class="rounded-lg border px-3 py-1.5 text-sm hover:bg-gray-50"
            >
              CSV Dışa Aktar
            </a>
            <button id="signedLinkBtn" class="rounded-lg border px-3 py-1.5 text-sm hover:bg-gray-50" type="button">
              5dk İmzalı Link
            </button>
            <button id="refreshBtn" class="rounded-lg border px-3 py-1.5 text-sm">Yenile</button>
          </div>
        </div>
        <input id="signedLinkOut" class="border rounded-lg px-3 py-2 mb-3 w-full text-xs" readonly placeholder="İmzalı export linki burada" />
        <div class="overflow-x-auto">
          <table class="min-w-full text-sm">
            <thead>
              <tr class="border-b text-left text-gray-600">
                <th class="px-2 py-2">Zaman</th>
                <th class="px-2 py-2">Mekan</th>
                <th class="px-2 py-2">Önceki Durum</th>
                <th class="px-2 py-2">Yeni Durum</th>
                <th class="px-2 py-2">İşlem Yapan</th>
                <th class="px-2 py-2">Gerekçe</th>
              </tr>
            </thead>
            <tbody id="timelineRows">
              <tr><td class="px-2 py-3 text-gray-400" colspan="6">Yükleniyor...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    async function loadSla() {
      const res = await fetch('/api/admin/places/lifecycle/sla');
      const json = await res.json();
      if (!res.ok || !json?.success) return;
      document.getElementById('slaHours').textContent = String(json.slaHours || '-');
      document.getElementById('pendingCount').textContent = String(json.summary?.pending_count ?? '-');
      document.getElementById('needsInfoCount').textContent = String(json.summary?.needs_info_count ?? '-');
      document.getElementById('breachedCount').textContent = String(json.summary?.pending_breached_count ?? '-');
    }

    async function loadTimeline() {
      const rows = document.getElementById('timelineRows');
      const res = await fetch('/api/admin/places/lifecycle?limit=100&offset=0');
      const json = await res.json();
      if (!res.ok || !json?.success) {
        rows.innerHTML = '<tr><td class="px-2 py-3 text-red-600" colspan="6">Yüklenemedi</td></tr>';
        return;
      }
      const items = Array.isArray(json.items) ? json.items : [];
      if (!items.length) {
        rows.innerHTML = '<tr><td class="px-2 py-3 text-gray-400" colspan="6">Kayıt yok</td></tr>';
        return;
      }
      rows.innerHTML = items.map((x) => `
        <tr class="border-b border-gray-100">
          <td class="px-2 py-2 whitespace-nowrap">${x.created_at ? new Date(x.created_at).toLocaleString('tr-TR') : '-'}</td>
          <td class="px-2 py-2">${x.place_name || x.place_id}</td>
          <td class="px-2 py-2"><span class="font-mono">${x.from_status || '-'}</span></td>
          <td class="px-2 py-2"><span class="font-mono">${x.to_status || '-'}</span></td>
          <td class="px-2 py-2"><span class="font-mono">${x.actor_email || x.actor_user_id || '-'}</span></td>
          <td class="px-2 py-2">${x.reason || '-'}</td>
        </tr>
      `).join('');
      const firstStatus = items[0]?.to_status || '';
      document.getElementById('exportLink').setAttribute(
        'href',
        `/api/admin/places/lifecycle/export?${new URLSearchParams({
          ...(firstStatus ? { toStatus: firstStatus } : {}),
          limit: '1000',
        }).toString()}`,
      );
    }

    document.getElementById('refreshBtn').addEventListener('click', () => {
      void loadSla();
      void loadTimeline();
    });
    document.getElementById('signedLinkBtn').addEventListener('click', async () => {
      const res = await fetch('/api/admin/exports/token', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          resourceKey: 'admin.places.lifecycle.export',
          payload: {},
          ttlSeconds: 300,
          maxDownloads: 1,
        }),
      });
      const json = await res.json();
      const out = document.getElementById('signedLinkOut');
      if (!res.ok || !json?.success) {
        out.value = 'Token üretilemedi';
        return;
      }
      out.value = `${location.origin}/api/admin/places/lifecycle/export?token=${encodeURIComponent(json.token)}`;
    });

    void loadSla();
    void loadTimeline();
  </script>
</Layout>
