---
import { Icon } from 'astro-icon/components';
import AdminLayout from '../../../layouts/AdminLayoutV2.astro';
import { query } from '../../../lib/postgres';
import { logger } from '../../../lib/logging';

let categories: any[] = [];
let districts: any[] = [];

try {
 const [catResult, distResult] = await Promise.all([
 query(`SELECT id, name, slug FROM categories WHERE parent_id IS NOT NULL AND is_active = true ORDER BY sort_order`, []),
 query(`SELECT id, name FROM districts ORDER BY is_central DESC, sort_order`, []),
 ]);
 categories = catResult.rows;
 districts = distResult.rows;
} catch (e) {
 logger.error('Add place load error', e instanceof Error ? e : new Error(String(e)));
}

const amenitiesList = [
 'Otopark', 'Wifi', 'Klima', 'Bahçe', 'Teras', 'Engelli Erişimi',
 'Paket Servis', 'Rezervasyon', 'Canlı Müzik', 'Çocuk Oyun Alanı',
 'Evcil Hayvan Dostu', 'Sigara İçilebilir Alan'
];

const days = [
 { id: 'monday', label: 'Pazartesi' },
 { id: 'tuesday', label: 'Salı' },
 { id: 'wednesday', label: 'Çarşamba' },
 { id: 'thursday', label: 'Perşembe' },
 { id: 'friday', label: 'Cuma' },
 { id: 'saturday', label: 'Cumartesi' },
 { id: 'sunday', label: 'Pazar' },
];
---

<AdminLayout
 title="Yeni Mekan Ekle"
 subtitle="Mekan bilgilerini doldurun, taslak veya aktif olarak kaydedin"
 seo={{ title: 'Mekan Ekle - Yönetim Paneli', noIndex: true }}
>
 <a slot="page-actions" href="/admin/places" class="plf-back">
  <Icon name="lucide:arrow-left" class="w-4 h-4" /> Mekanlar
 </a>

 <div class="plf-wrap">
 <nav class="plf-tabs" aria-label="Mekan form sekmeleri">
  {['Genel Bilgiler', 'İletişim', 'Çalışma Saatleri', 'Lokasyon', 'Medya / SEO', 'Durum / Bot Önerileri'].map((tab, index) => (
   <button type="button" class:list={['plf-tab', index === 0 && 'plf-tab--active']} data-place-form-tab={tab}>{tab}</button>
  ))}
 </nav>
 <form action="/api/admin/places/create" method="POST" class="grid lg:grid-cols-3 gap-6" enctype="multipart/form-data">
 <div class="lg:col-span-2 space-y-5">
 <div class="bg-[var(--bg-card)] border border-[var(--adm-border)] rounded-sm p-6">
 <h2 class="text-base font-semibold text-[#7A6B58] mb-4">Temel Bilgiler</h2>
 <div class="space-y-4">
 <div>
 <label for="name" class="block text-sm font-medium text-[#7A6B58] mb-1">Mekan Adı *</label>
 <input
 type="text"
 id="name"
 name="name"
 required
 class="w-full rounded-sm border border-[var(--adm-border-strong)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
 placeholder="Örn: Ciğerci Aziz Usta"
 />
 </div>

 <script is:inline>
  const placeTabButtons = Array.from(document.querySelectorAll('[data-place-form-tab]'));
  const placeCards = Array.from(document.querySelectorAll('.plf-wrap form > div > div, .plf-wrap form > aside > div'));
  const tabMatchers = {
   'Genel Bilgiler': ['Temel Bilgiler'],
   'İletişim': ['İletişim Bilgileri'],
   'Çalışma Saatleri': ['Çalışma Saatleri'],
   'Lokasyon': ['Konum'],
   'Medya / SEO': ['Fotoğraflar', 'SEO', 'Olanaklar', 'Etiketler'],
   'Durum / Bot Önerileri': ['Yayınla', 'Bot', 'Durum'],
  };
  function cardTitle(card) {
   return (card.querySelector('h2,h3')?.textContent || '').trim();
  }
  function showPlaceTab(tab) {
   placeTabButtons.forEach((btn) => btn.classList.toggle('plf-tab--active', btn.dataset.placeFormTab === tab));
   const needles = tabMatchers[tab] || [];
   placeCards.forEach((card) => {
    const title = cardTitle(card);
    const show = needles.some((needle) => title.includes(needle));
    card.hidden = !show;
   });
  }
  placeTabButtons.forEach((btn) => btn.addEventListener('click', () => showPlaceTab(btn.dataset.placeFormTab)));
  showPlaceTab('Genel Bilgiler');
 </script>

 <div class="grid sm:grid-cols-2 gap-4">
 <div>
 <label for="category_id" class="block text-sm font-medium text-[#7A6B58] mb-1">Kategori *</label>
 <select id="category_id" name="category_id" required class="w-full rounded-sm border border-[var(--adm-border-strong)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400">
 <option value="">Kategori seçin</option>
 {categories.map(cat => (
 <option value={cat.id}>{cat.name}</option>
 ))}
 </select>
 </div>
 <div>
 <label for="price_range" class="block text-sm font-medium text-[#7A6B58] mb-1">Fiyat Aralığı</label>
 <select id="price_range" name="price_range" class="w-full rounded-sm border border-[var(--adm-border-strong)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400">
 <option value="1">₺ - Ucuz</option>
 <option value="2">₺₺ - Orta</option>
 <option value="3">₺₺₺ - Pahalı</option>
 <option value="4">₺₺₺₺ - Lüks</option>
 </select>
 </div>
 </div>

 <div>
 <label for="description" class="block text-sm font-medium text-[#7A6B58] mb-1">Açıklama *</label>
 <textarea
 id="description"
 name="description"
 rows="4"
 required
 class="w-full rounded-sm border border-[var(--adm-border-strong)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400 resize-none"
 placeholder="Mekan hakkında detaylı açıklama..."
 ></textarea>
 </div>

 <div>
 <label for="short_description" class="block text-sm font-medium text-[#7A6B58] mb-1">Kısa Açıklama</label>
 <input
 type="text"
 id="short_description"
 name="short_description"
 maxlength="150"
 class="w-full rounded-sm border border-[var(--adm-border-strong)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
 placeholder="Mekanın kısa özeti (150 karakter)"
 />
 </div>
 </div>
 </div>

 <div class="bg-[var(--bg-card)] border border-[var(--adm-border)] rounded-sm p-6">
 <h2 class="text-base font-semibold text-[#7A6B58] mb-4">İletişim Bilgileri</h2>
 <div class="space-y-4">
 <div>
 <label for="address" class="block text-sm font-medium text-[#7A6B58] mb-1">Adres *</label>
 <div class="relative">
 <Icon name="lucide:map-pin" class="absolute left-3 top-3 w-5 h-5 text-[#7A6B58]" />
 <input
 type="text"
 id="address"
 name="address"
 required
 class="w-full rounded-sm border border-[var(--adm-border-strong)] pl-10 px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
 placeholder="Tam adres"
 />
 </div>
 </div>

 <div class="grid sm:grid-cols-2 gap-4">
 <div>
 <label for="phone" class="block text-sm font-medium text-[#7A6B58] mb-1">Telefon</label>
 <div class="relative">
 <Icon name="lucide:phone" class="absolute left-3 top-3 w-5 h-5 text-[#7A6B58]" />
 <input
 type="tel"
 id="phone"
 name="phone"
 class="w-full rounded-sm border border-[var(--adm-border-strong)] pl-10 px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
 placeholder="+90 414 123 45 67"
 />
 </div>
 </div>
 <div>
 <label for="email" class="block text-sm font-medium text-[#7A6B58] mb-1">E-posta</label>
 <div class="relative">
 <Icon name="lucide:mail" class="absolute left-3 top-3 w-5 h-5 text-[#7A6B58]" />
 <input
 type="email"
 id="email"
 name="email"
 class="w-full rounded-sm border border-[var(--adm-border-strong)] pl-10 px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
 placeholder="info@ornek.com"
 />
 </div>
 </div>
 </div>

 <div>
 <label for="website" class="block text-sm font-medium text-[#7A6B58] mb-1">Web Sitesi</label>
 <div class="relative">
 <Icon name="lucide:globe" class="absolute left-3 top-3 w-5 h-5 text-[#7A6B58]" />
 <input
 type="url"
 id="website"
 name="website"
 class="w-full rounded-sm border border-[var(--adm-border-strong)] pl-10 px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
 placeholder="https://www.ornek.com"
 />
 </div>
 </div>
 </div>
 </div>

 <div class="bg-[var(--bg-card)] border border-[var(--adm-border)] rounded-sm p-6">
 <h2 class="text-base font-semibold text-[#7A6B58] mb-4">Çalışma Saatleri</h2>
 <div class="space-y-3">
 {days.map(day => (
 <div class="flex items-center gap-4">
 <span class="w-24 text-sm text-[#7A6B58]">{day.label}</span>
 <input
 type="text"
 name={`opening_hours_${day.id}`}
 class="w-full rounded-sm border border-[var(--adm-border-strong)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
 placeholder="08:00 - 22:00 veya Kapalı"
 />
 </div>
 ))}
 </div>
 </div>

 <div class="bg-[var(--bg-card)] border border-[var(--adm-border)] rounded-sm p-6">
 <h2 class="text-base font-semibold text-[#7A6B58] mb-4">Konum</h2>
 <div class="grid sm:grid-cols-2 gap-4">
 <div>
 <label for="latitude" class="block text-sm font-medium text-[#7A6B58] mb-1">Enlem</label>
 <input
 type="number"
 id="latitude"
 name="latitude"
 step="any"
 class="w-full rounded-sm border border-[var(--adm-border-strong)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
 placeholder="37.1592"
 />
 </div>
 <div>
 <label for="longitude" class="block text-sm font-medium text-[#7A6B58] mb-1">Boylam</label>
 <input
 type="number"
 id="longitude"
 name="longitude"
 step="any"
 class="w-full rounded-sm border border-[var(--adm-border-strong)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
 placeholder="38.7965"
 />
 </div>
 </div>

 <div class="mt-4">
  <div class="flex items-center justify-between mb-2">
    <p class="text-sm text-[#7A6B58]">📍 Haritadan seçin (Şanlıurfa merkez):</p>
    <div class="flex gap-2">
      <button type="button" id="map-center-urfa" class="text-xs px-2.5 py-1 rounded-sm bg-[var(--adm-bg-hover)] text-[#7A6B58] hover:bg-[rgba(184,115,51,0.16)]">Şanlıurfa Merkez</button>
      <button type="button" id="map-use-current" class="text-xs px-2.5 py-1 rounded-sm bg-[var(--adm-bg-hover)] text-[#7A6B58] hover:bg-[rgba(184,115,51,0.16)]">Mevcut Konumum</button>
    </div>
  </div>
  <div id="place-location-map" style="height:320px;width:100%;border:1px solid var(--adm-border-strong);border-radius:4px;background:#f5edda"></div>
  <p class="text-xs text-[#9B8A75] mt-2">Haritada istediğiniz yere tıklayın — koordinatlar otomatik dolacak. Alternatif: Google Maps'ten elle yapıştır.</p>
 </div>
 </div>

 <link rel="stylesheet" href="/vendor/leaflet/leaflet.css" />
 <script src="/vendor/leaflet/leaflet.js" is:inline></script>
 <script is:inline define:vars={{ urfaCenter: [37.1592, 38.7965] }}>
  document.addEventListener('DOMContentLoaded', () => {
    const L = (window).L;
    if (!L) { console.warn('Leaflet not loaded'); return; }
    const latInput = document.getElementById('latitude');
    const lonInput = document.getElementById('longitude');
    const mapEl = document.getElementById('place-location-map');
    if (!latInput || !lonInput || !mapEl) return;

    // Mevcut koordinat varsa kullan, yoksa Urfa merkez.
    const initLat = parseFloat(latInput.value) || urfaCenter[0];
    const initLon = parseFloat(lonInput.value) || urfaCenter[1];
    const hasCoords = !!(parseFloat(latInput.value) && parseFloat(lonInput.value));

    const map = L.map(mapEl).setView([initLat, initLon], hasCoords ? 15 : 12);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 19,
      attribution: '© OpenStreetMap'
    }).addTo(map);

    let marker = null;
    function setMarker(lat, lon) {
      if (marker) marker.setLatLng([lat, lon]);
      else marker = L.marker([lat, lon], { draggable: true }).addTo(map)
        .on('dragend', (e) => {
          const p = e.target.getLatLng();
          latInput.value = p.lat.toFixed(7);
          lonInput.value = p.lng.toFixed(7);
        });
      latInput.value = lat.toFixed(7);
      lonInput.value = lon.toFixed(7);
    }

    if (hasCoords) setMarker(initLat, initLon);

    map.on('click', (e) => setMarker(e.latlng.lat, e.latlng.lng));

    // Manuel input değişirse marker'ı senkronla
    function syncFromInputs() {
      const la = parseFloat(latInput.value), lo = parseFloat(lonInput.value);
      if (Number.isFinite(la) && Number.isFinite(lo)) {
        setMarker(la, lo);
        map.setView([la, lo], Math.max(map.getZoom(), 14));
      }
    }
    latInput.addEventListener('change', syncFromInputs);
    lonInput.addEventListener('change', syncFromInputs);

    document.getElementById('map-center-urfa')?.addEventListener('click', () => {
      setMarker(urfaCenter[0], urfaCenter[1]);
      map.setView(urfaCenter, 13);
    });
    document.getElementById('map-use-current')?.addEventListener('click', () => {
      if (!navigator.geolocation) { alert('Tarayıcı konum desteği yok'); return; }
      navigator.geolocation.getCurrentPosition(
        (pos) => { setMarker(pos.coords.latitude, pos.coords.longitude); map.setView([pos.coords.latitude, pos.coords.longitude], 16); },
        () => alert('Konum alınamadı'),
        { timeout: 8000 }
      );
    });
  });
 </script>
 </div>

 <aside class="space-y-5">
 <div class="bg-[var(--bg-card)] border border-[var(--adm-border)] rounded-sm p-6">
 <h3 class="font-semibold text-[#7A6B58] mb-4">Yayınla</h3>
 <div class="space-y-3">
 <label class="flex items-center gap-2">
 <input type="checkbox" name="is_featured" class="rounded" />
 <span class="text-sm text-[#7A6B58]">Öne çıkan mekan</span>
 </label>
 <label class="flex items-center gap-2">
 <input type="checkbox" name="is_verified" class="rounded" />
 <span class="text-sm text-[#7A6B58]">Doğrulanmış mekan</span>
 </label>
 </div>
 <div class="mt-4 pt-4 border-t border-[var(--adm-border)] space-y-3">
 <div>
 <label for="district_id" class="block text-sm font-medium text-[#7A6B58] mb-1">İlçe</label>
 <select id="district_id" name="district_id" class="w-full rounded-sm border border-[var(--adm-border-strong)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400 mt-1">
 <option value="">İlçe seçin</option>
 {districts.map(d => (
 <option value={d.id}>{d.name}</option>
 ))}
 </select>
 </div>
 <div>
 <label for="status" class="block text-sm font-medium text-[#7A6B58] mb-1">Durum</label>
 <select id="status" name="status" class="w-full rounded-sm border border-[var(--adm-border-strong)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400 mt-1">
 <option value="active">Aktif</option>
 <option value="pending">Beklemede</option>
 <option value="inactive">Pasif</option>
 </select>
 </div>
 </div>
 <div class="flex gap-2 mt-4">
 <button type="submit" class="rounded-sm bg-urfa-600 flex-1 px-4 py-2 text-sm font-semibold text-white hover:bg-urfa-700">Kaydet</button>
 <a href="/admin/places" class="rounded-sm border border-[var(--adm-border-strong)] px-4 py-2 text-sm text-[#7A6B58] hover:bg-[var(--adm-bg-hover)] text-center">İptal</a>
 </div>
 </div>

 <div class="bg-[var(--bg-card)] border border-[var(--adm-border)] rounded-sm p-6">
 <h3 class="font-semibold text-[#7A6B58] mb-4">Görseller</h3>
 <div class="space-y-4">
 <div>
 <label for="cover_image" class="block text-sm font-medium text-[#7A6B58] mb-1">Kapak Fotoğrafı</label>
 <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-[var(--adm-border-strong)] border-dashed rounded-sm hover:border-urfa-400 transition-colors">
 <div class="space-y-1 text-center">
 <Icon name="lucide:upload" class="mx-auto h-12 w-12 text-[#7A6B58]" />
 <div class="flex text-sm text-[#7A6B58]">
 <label for="cover_image" class="relative cursor-pointer rounded-sm font-medium text-urfa-600 hover:text-urfa-500">
 <span>Dosya seç</span>
 <input id="cover_image" name="cover_image" type="file" accept="image/*" class="sr-only" />
 </label>
 </div>
 <p class="text-xs text-[#7A6B58]">PNG, JPG up to 5MB</p>
 </div>
 </div>
 </div>

 <div>
 <label for="gallery" class="block text-sm font-medium text-[#7A6B58] mb-1">Galeri Fotoğrafları</label>
 <input
 type="file"
 id="gallery"
 name="gallery"
 accept="image/*"
 multiple
 class="w-full rounded-sm border border-[var(--adm-border-strong)] px-3 py-2 text-sm focus:outline-none"
 />
 <p class="text-xs text-[#7A6B58] mt-1">Birden fazla seçebilirsiniz</p>
 </div>
 </div>
 </div>

 <div class="bg-[var(--bg-card)] border border-[var(--adm-border)] rounded-sm p-6">
 <h3 class="font-semibold text-[#7A6B58] mb-4">Olanaklar</h3>
 <div class="space-y-2 max-h-64 overflow-y-auto">
 {amenitiesList.map(amenity => (
 <label class="flex items-center gap-2">
 <input type="checkbox" name="amenities" value={amenity} class="rounded" />
 <span class="text-sm text-[#7A6B58]">{amenity}</span>
 </label>
 ))}
 </div>
 </div>

 <div class="bg-[var(--bg-card)] border border-[var(--adm-border)] rounded-sm p-6">
 <h3 class="font-semibold text-[#7A6B58] mb-4">Etiketler</h3>
 <input
 type="text"
 name="tags"
 class="w-full rounded-sm border border-[var(--adm-border-strong)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
 placeholder="Etiketleri virgülle ayırın"
 />
 <p class="text-xs text-[#7A6B58] mt-1">Örn: ciğer kebabı, tarihi, aile</p>
 </div>
 </aside>
 </form>
 </div>

 <style>
  .plf-wrap { display: flex; flex-direction: column; gap: 1.25rem; }
 .plf-back {
   display: inline-flex; align-items: center; gap: 0.4rem;
   padding: 0.5rem 1rem;
   background: var(--adm-bg-elev);
   border: 1px solid var(--adm-border);
   color: var(--adm-text-muted);
   font-weight: 600; font-size: 0.84rem;
   border-radius: 8px;
   text-decoration: none;
   transition: all 0.15s;
 }
 .plf-tabs {
  position: sticky;
  top: 60px;
  z-index: 5;
  display: flex;
  gap: .35rem;
  overflow-x: auto;
  margin-bottom: 1rem;
  padding: .35rem;
  border: 1px solid var(--adm-border);
  border-radius: 14px;
  background: color-mix(in srgb, var(--adm-bg-elev) 92%, transparent);
  backdrop-filter: blur(12px);
 }
 .plf-tab {
  white-space: nowrap;
  border: 0;
  border-radius: 10px;
  background: transparent;
  color: var(--adm-text-muted);
  padding: .55rem .8rem;
  font-size: .82rem;
  font-weight: 800;
  cursor: pointer;
 }
 .plf-tab:hover { background: var(--adm-bg-hover); color: var(--adm-text); }
 .plf-tab--active { background: var(--adm-text); color: var(--adm-bg); }
  .plf-back:hover { border-color: var(--adm-accent); color: var(--adm-accent); }
 </style>
</AdminLayout>
