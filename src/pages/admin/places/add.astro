---
import { Icon } from 'astro-icon/components';
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { query } from '../../../lib/postgres';
import { logger } from '../../../lib/logging';

let categories: any[] = [];
let districts: any[] = [];

try {
  const [catResult, distResult] = await Promise.all([
    query(`SELECT id, name, slug FROM categories WHERE parent_id IS NOT NULL AND is_active = true ORDER BY sort_order`, []),
    query(`SELECT id, name FROM districts ORDER BY is_central DESC, sort_order`, []),
  ]);
  categories = catResult.rows;
  districts = distResult.rows;
} catch (e) {
  logger.error('Add place load error', e instanceof Error ? e : new Error(String(e)));
}

const amenitiesList = [
  'Otopark', 'Wifi', 'Klima', 'Bahçe', 'Teras', 'Engelli Erişimi',
  'Paket Servis', 'Rezervasyon', 'Canlı Müzik', 'Çocuk Oyun Alanı',
  'Evcil Hayvan Dostu', 'Sigara İçilebilir Alan'
];

const days = [
  { id: 'monday', label: 'Pazartesi' },
  { id: 'tuesday', label: 'Salı' },
  { id: 'wednesday', label: 'Çarşamba' },
  { id: 'thursday', label: 'Perşembe' },
  { id: 'friday', label: 'Cuma' },
  { id: 'saturday', label: 'Cumartesi' },
  { id: 'sunday', label: 'Pazar' },
];
---

<AdminLayout
  title="Yeni Mekan Ekle"
  subtitle="Mekan bilgilerini doldurun"
  seo={{ title: 'Mekan Ekle - Yönetim Paneli', noIndex: true }}
>
    <div class="container mx-auto px-4 py-8 max-w-6xl space-y-5">
      <div class="mb-2">
        <a href="/admin/places" class="text-sm text-[#9A8470] hover:text-[#6B5540]">← Mekanlar</a>
      </div>

      <form action="/api/admin/places/create" method="POST" class="grid lg:grid-cols-3 gap-6" enctype="multipart/form-data">
        <div class="lg:col-span-2 space-y-5">
          <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
            <h2 class="text-base font-semibold text-[#6B5540] mb-4">Temel Bilgiler</h2>
            <div class="space-y-4">
              <div>
                <label for="name" class="block text-sm font-medium text-[#6B5540] mb-1">Mekan Adı *</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
                  placeholder="Örn: Ciğerci Aziz Usta"
                />
              </div>

              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label for="category_id" class="block text-sm font-medium text-[#6B5540] mb-1">Kategori *</label>
                  <select id="category_id" name="category_id" required class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400">
                    <option value="">Kategori seçin</option>
                    {categories.map(cat => (
                      <option value={cat.id}>{cat.name}</option>
                    ))}
                  </select>
                </div>
                <div>
                  <label for="price_range" class="block text-sm font-medium text-[#6B5540] mb-1">Fiyat Aralığı</label>
                  <select id="price_range" name="price_range" class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400">
                    <option value="1">₺ - Ucuz</option>
                    <option value="2">₺₺ - Orta</option>
                    <option value="3">₺₺₺ - Pahalı</option>
                    <option value="4">₺₺₺₺ - Lüks</option>
                  </select>
                </div>
              </div>

              <div>
                <label for="description" class="block text-sm font-medium text-[#6B5540] mb-1">Açıklama *</label>
                <textarea
                  id="description"
                  name="description"
                  rows="4"
                  required
                  class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400 resize-none"
                  placeholder="Mekan hakkında detaylı açıklama..."
                ></textarea>
              </div>

              <div>
                <label for="short_description" class="block text-sm font-medium text-[#6B5540] mb-1">Kısa Açıklama</label>
                <input
                  type="text"
                  id="short_description"
                  name="short_description"
                  maxlength="150"
                  class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
                  placeholder="Mekanın kısa özeti (150 karakter)"
                />
              </div>
            </div>
          </div>

          <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
            <h2 class="text-base font-semibold text-[#6B5540] mb-4">İletişim Bilgileri</h2>
            <div class="space-y-4">
              <div>
                <label for="address" class="block text-sm font-medium text-[#6B5540] mb-1">Adres *</label>
                <div class="relative">
                  <Icon name="lucide:map-pin" class="absolute left-3 top-3 w-5 h-5 text-[#9A8470]" />
                  <input
                    type="text"
                    id="address"
                    name="address"
                    required
                    class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] pl-10 px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
                    placeholder="Tam adres"
                  />
                </div>
              </div>

              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label for="phone" class="block text-sm font-medium text-[#6B5540] mb-1">Telefon</label>
                  <div class="relative">
                    <Icon name="lucide:phone" class="absolute left-3 top-3 w-5 h-5 text-[#9A8470]" />
                    <input
                      type="tel"
                      id="phone"
                      name="phone"
                      class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] pl-10 px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
                      placeholder="+90 414 123 45 67"
                    />
                  </div>
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium text-[#6B5540] mb-1">E-posta</label>
                  <div class="relative">
                    <Icon name="lucide:mail" class="absolute left-3 top-3 w-5 h-5 text-[#9A8470]" />
                    <input
                      type="email"
                      id="email"
                      name="email"
                      class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] pl-10 px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
                      placeholder="info@ornek.com"
                    />
                  </div>
                </div>
              </div>

              <div>
                <label for="website" class="block text-sm font-medium text-[#6B5540] mb-1">Web Sitesi</label>
                <div class="relative">
                  <Icon name="lucide:globe" class="absolute left-3 top-3 w-5 h-5 text-[#9A8470]" />
                  <input
                    type="url"
                    id="website"
                    name="website"
                    class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] pl-10 px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
                    placeholder="https://www.ornek.com"
                  />
                </div>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
            <h2 class="text-base font-semibold text-[#6B5540] mb-4">Çalışma Saatleri</h2>
            <div class="space-y-3">
              {days.map(day => (
                <div class="flex items-center gap-4">
                  <span class="w-24 text-sm text-[#6B5540]">{day.label}</span>
                  <input
                    type="text"
                    name={`opening_hours_${day.id}`}
                    class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
                    placeholder="08:00 - 22:00 veya Kapalı"
                  />
                </div>
              ))}
            </div>
          </div>

          <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
            <h2 class="text-base font-semibold text-[#6B5540] mb-4">Konum</h2>
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="latitude" class="block text-sm font-medium text-[#6B5540] mb-1">Enlem</label>
                <input
                  type="number"
                  id="latitude"
                  name="latitude"
                  step="any"
                  class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
                  placeholder="37.1592"
                />
              </div>
              <div>
                <label for="longitude" class="block text-sm font-medium text-[#6B5540] mb-1">Boylam</label>
                <input
                  type="number"
                  id="longitude"
                  name="longitude"
                  step="any"
                  class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
                  placeholder="38.7965"
                />
              </div>
            </div>
            <p class="text-sm text-[#9A8470] mt-2">Koordinatları Google Maps'ten alabilirsiniz.</p>
          </div>
        </div>

        <aside class="space-y-5">
          <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
            <h3 class="font-semibold text-[#6B5540] mb-4">Yayınla</h3>
            <div class="space-y-3">
              <label class="flex items-center gap-2">
                <input type="checkbox" name="is_featured" class="rounded" />
                <span class="text-sm text-[#6B5540]">Öne çıkan mekan</span>
              </label>
              <label class="flex items-center gap-2">
                <input type="checkbox" name="is_verified" class="rounded" />
                <span class="text-sm text-[#6B5540]">Doğrulanmış mekan</span>
              </label>
            </div>
            <div class="mt-4 pt-4 border-t border-[rgba(200,160,100,0.14)] space-y-3">
              <div>
                <label for="district_id" class="block text-sm font-medium text-[#6B5540] mb-1">İlçe</label>
                <select id="district_id" name="district_id" class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400 mt-1">
                  <option value="">İlçe seçin</option>
                  {districts.map(d => (
                    <option value={d.id}>{d.name}</option>
                  ))}
                </select>
              </div>
              <div>
                <label for="status" class="block text-sm font-medium text-[#6B5540] mb-1">Durum</label>
                <select id="status" name="status" class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400 mt-1">
                  <option value="active">Aktif</option>
                  <option value="pending">Beklemede</option>
                  <option value="inactive">Pasif</option>
                </select>
              </div>
            </div>
            <div class="flex gap-2 mt-4">
              <button type="submit" class="rounded-sm bg-urfa-600 flex-1 px-4 py-2 text-sm font-semibold text-white hover:bg-urfa-700">Kaydet</button>
              <a href="/admin/places" class="rounded-sm border border-[rgba(200,160,100,0.2)] px-4 py-2 text-sm text-[#6B5540] hover:bg-[rgba(200,160,100,0.04)] text-center">İptal</a>
            </div>
          </div>

          <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
            <h3 class="font-semibold text-[#6B5540] mb-4">Görseller</h3>
            <div class="space-y-4">
              <div>
                <label for="cover_image" class="block text-sm font-medium text-[#6B5540] mb-1">Kapak Fotoğrafı</label>
                <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-[rgba(200,160,100,0.2)] border-dashed rounded-sm hover:border-urfa-400 transition-colors">
                  <div class="space-y-1 text-center">
                    <Icon name="lucide:upload" class="mx-auto h-12 w-12 text-[#9A8470]" />
                    <div class="flex text-sm text-[#6B5540]">
                      <label for="cover_image" class="relative cursor-pointer rounded-sm font-medium text-urfa-600 hover:text-urfa-500">
                        <span>Dosya seç</span>
                        <input id="cover_image" name="cover_image" type="file" accept="image/*" class="sr-only" />
                      </label>
                    </div>
                    <p class="text-xs text-[#9A8470]">PNG, JPG up to 5MB</p>
                  </div>
                </div>
              </div>

              <div>
                <label for="gallery" class="block text-sm font-medium text-[#6B5540] mb-1">Galeri Fotoğrafları</label>
                <input
                  type="file"
                  id="gallery"
                  name="gallery"
                  accept="image/*"
                  multiple
                  class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm focus:outline-none"
                />
                <p class="text-xs text-[#9A8470] mt-1">Birden fazla seçebilirsiniz</p>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
            <h3 class="font-semibold text-[#6B5540] mb-4">Olanaklar</h3>
            <div class="space-y-2 max-h-64 overflow-y-auto">
              {amenitiesList.map(amenity => (
                <label class="flex items-center gap-2">
                  <input type="checkbox" name="amenities" value={amenity} class="rounded" />
                  <span class="text-sm text-[#6B5540]">{amenity}</span>
                </label>
              ))}
            </div>
          </div>

          <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
            <h3 class="font-semibold text-[#6B5540] mb-4">Etiketler</h3>
            <input
              type="text"
              name="tags"
              class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
              placeholder="Etiketleri virgülle ayırın"
            />
            <p class="text-xs text-[#9A8470] mt-1">Örn: ciğer kebabı, tarihi, aile</p>
          </div>
        </aside>
      </form>
    </div>
</AdminLayout>
