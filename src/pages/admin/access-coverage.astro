---
import Layout from '../../layouts/Layout.astro';

const user = Astro.locals.user;

if (!user || !Astro.locals.isAdmin) {
  return Astro.redirect('/giris?redirect=/admin/access-coverage');
}

const seo = {
  title: 'Admin Erişim Kapsaması - Şanlıurfa.com',
  description: 'Admin API wrapper kapsama raporunu ve drift dosyalarını inceleyin.',
};
---

<Layout seo={seo}>
  <section class="min-h-screen bg-gray-100 dark:bg-gray-950 py-8">
    <div class="container-custom space-y-6">
      <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-urfa-600">Admin erişim kapsaması</p>
          <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Wrapper kapsama raporu</h1>
          <p class="mt-2 max-w-3xl text-sm text-gray-600 dark:text-gray-400">
            `api/admin` ağacındaki route dosyalarının ortak admin access wrapper standardına uyumunu okuyun.
          </p>
        </div>
        <button
          id="refresh-admin-access-coverage"
          class="inline-flex items-center justify-center rounded-xl bg-urfa-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-urfa-700"
          type="button"
        >
          Yenile
        </button>
      </div>

      <div
        id="admin-access-coverage-summary"
        class="rounded-2xl border border-gray-200 bg-white p-4 text-sm text-gray-600 shadow-sm dark:border-gray-800 dark:bg-gray-900 dark:text-gray-300"
      >
        Kapsama verileri yükleniyor.
      </div>

      <div
        id="admin-access-coverage-alert"
        class="hidden rounded-2xl border p-4 text-sm font-semibold"
      ></div>

      <div class="grid gap-4 md:grid-cols-3">
        <div class="rounded-2xl border border-gray-200 bg-white p-4 text-sm text-gray-600 shadow-sm dark:border-gray-800 dark:bg-gray-900 dark:text-gray-300">
          <div class="text-xs uppercase tracking-[0.18em] text-gray-500">Son yenileme</div>
          <div id="admin-access-coverage-last-refresh" class="mt-2 text-lg font-semibold text-gray-900 dark:text-white">-</div>
        </div>
        <div class="rounded-2xl border border-gray-200 bg-white p-4 text-sm text-gray-600 shadow-sm dark:border-gray-800 dark:bg-gray-900 dark:text-gray-300">
          <div class="text-xs uppercase tracking-[0.18em] text-gray-500">Otomatik yenileme</div>
          <div class="mt-2 text-lg font-semibold text-gray-900 dark:text-white">60 saniye</div>
        </div>
        <div class="rounded-2xl border border-gray-200 bg-white p-4 text-sm text-gray-600 shadow-sm dark:border-gray-800 dark:bg-gray-900 dark:text-gray-300">
          <div class="text-xs uppercase tracking-[0.18em] text-gray-500">Olay farkı</div>
          <div id="admin-access-coverage-delta" class="mt-2 text-sm font-semibold text-gray-900 dark:text-white">Henüz veri yok.</div>
        </div>
      </div>

      <div class="rounded-2xl border border-gray-200 bg-white p-4 text-sm text-gray-600 shadow-sm dark:border-gray-800 dark:bg-gray-900 dark:text-gray-300">
        <div class="text-xs uppercase tracking-[0.18em] text-gray-500">Kısa geçmiş</div>
        <div id="admin-access-coverage-trend" class="mt-2 text-sm font-semibold text-gray-900 dark:text-white">Henüz veri yok.</div>
      </div>

      <div class="grid gap-4 md:grid-cols-4">
        <div class="rounded-2xl border border-gray-200 bg-white p-5 shadow-sm dark:border-gray-800 dark:bg-gray-900">
          <div class="text-xs text-gray-500">Durum</div>
          <div id="admin-access-coverage-status" class="mt-2 text-2xl font-bold text-gray-900 dark:text-white">-</div>
          <div class="mt-2 text-xs text-gray-500">Artifact freshness sonucu</div>
        </div>
        <div class="rounded-2xl border border-gray-200 bg-white p-5 shadow-sm dark:border-gray-800 dark:bg-gray-900">
          <div class="text-xs text-gray-500">Kapsama</div>
          <div id="admin-access-coverage-percent" class="mt-2 text-2xl font-bold text-gray-900 dark:text-white">-</div>
          <div id="admin-access-coverage-routes" class="mt-2 text-xs text-gray-500">-</div>
        </div>
        <div class="rounded-2xl border border-gray-200 bg-white p-5 shadow-sm dark:border-gray-800 dark:bg-gray-900">
          <div class="text-xs text-gray-500">Drift Count</div>
          <div id="admin-access-coverage-drift-count" class="mt-2 text-2xl font-bold text-gray-900 dark:text-white">-</div>
          <div class="mt-2 text-xs text-gray-500">Wrapper dışı route dosyası</div>
        </div>
        <div class="rounded-2xl border border-gray-200 bg-white p-5 shadow-sm dark:border-gray-800 dark:bg-gray-900">
          <div class="text-xs text-gray-500">Son Üretim</div>
          <div id="admin-access-coverage-generated-at" class="mt-2 text-sm font-semibold text-gray-900 dark:text-white">-</div>
          <div id="admin-access-coverage-formats" class="mt-2 text-xs text-gray-500">-</div>
        </div>
      </div>

      <div class="grid gap-4 md:grid-cols-2">
        <div class="rounded-2xl border border-gray-200 bg-white p-5 shadow-sm dark:border-gray-800 dark:bg-gray-900">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Artefact meta bilgisi</h2>
          <dl class="mt-4 space-y-3 text-sm">
            <div class="flex items-center justify-between gap-4">
              <dt class="text-gray-500">Artefact adı</dt>
              <dd id="admin-access-coverage-artifact" class="font-medium text-gray-900 dark:text-white">-</dd>
            </div>
            <div class="flex items-center justify-between gap-4">
              <dt class="text-gray-500">Artefact durumu</dt>
              <dd id="admin-access-coverage-artifact-status" class="font-medium text-gray-900 dark:text-white">-</dd>
            </div>
          </dl>
          <div class="mt-4 flex flex-wrap gap-3">
            <a
              id="admin-access-coverage-download-json"
              href="#"
              class="inline-flex items-center justify-center rounded-xl border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 transition hover:border-urfa-600 hover:text-urfa-700 dark:border-gray-700 dark:text-gray-200"
            >
              JSON İndir
            </a>
            <a
              id="admin-access-coverage-download-md"
              href="#"
              class="inline-flex items-center justify-center rounded-xl border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 transition hover:border-urfa-600 hover:text-urfa-700 dark:border-gray-700 dark:text-gray-200"
            >
              Markdown İndir
            </a>
          </div>
        </div>

        <div class="rounded-2xl border border-gray-200 bg-white p-5 shadow-sm dark:border-gray-800 dark:bg-gray-900">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Drift dosyaları</h2>
          <ul id="admin-access-drift-files" class="mt-4 space-y-2 text-sm text-gray-700 dark:text-gray-200">
            <li>Yükleniyor...</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <script type="module">
    import { initAdminAccessCoveragePage } from '../../scripts/admin-access-coverage-page.ts';

    initAdminAccessCoveragePage();
  </script>
</Layout>
