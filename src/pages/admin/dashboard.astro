---
import AdminLayout from '../../layouts/AdminLayout.astro';
import AdminDashboardOverview from '../../components/AdminDashboardOverview';
import ModerationQueueManager from '../../components/ModerationQueueManager';
import UserManagementTable from '../../components/UserManagementTable';
import DashboardStats from '../../components/admin/DashboardStats.astro';
import IntegrationsHealthSummary from '../../components/admin/IntegrationsHealthSummary.astro';
---

<AdminLayout
  title="Yönetim Paneli"
  subtitle="Platform yönetimi, moderasyon ve kullanıcı yönetimi"
  seo={{ title: 'Yönetim Paneli - Admin', noIndex: true }}
>
    <div class="max-w-7xl mx-auto px-4 py-8">
      {/* Server Island: İstatistikler — server:defer ile ilk HTML beklenmeden yüklenir */}
      <div class="mb-6">
        <DashboardStats server:defer>
          <div slot="fallback" class="grid grid-cols-2 md:grid-cols-3 gap-4 animate-pulse">
            {[1,2,3].map(() => (
              <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-5 h-24" />
            ))}
          </div>
        </DashboardStats>
      </div>

      {/* Server Island: Entegrasyonlar sağlık özeti */}
      <div class="mb-6">
        <IntegrationsHealthSummary server:defer>
          <div slot="fallback" class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6 animate-pulse">
            <div class="h-5 bg-[rgba(200,160,100,0.1)] rounded-sm w-40 mb-4"></div>
            <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
              <div class="h-20 bg-[rgba(200,160,100,0.06)] rounded-sm"></div>
              <div class="h-20 bg-[rgba(200,160,100,0.06)] rounded-sm"></div>
              <div class="h-20 bg-[rgba(200,160,100,0.06)] rounded-sm"></div>
              <div class="h-20 bg-[rgba(200,160,100,0.06)] rounded-sm"></div>
              <div class="h-20 bg-[rgba(200,160,100,0.06)] rounded-sm"></div>
            </div>
          </div>
        </IntegrationsHealthSummary>
      </div>

      {/* Tabs */}
      <div class="mb-6">
        <div class="border-b border-[rgba(200,160,100,0.2)] flex gap-8">
          <button
            onclick="switchTab('overview')"
            class="py-3 px-1 border-b-2 border-urfa-600 text-urfa-600 font-medium text-sm"
            id="tab-overview"
          >
            Genel Bakış
          </button>
          <button
            onclick="switchTab('moderation')"
            class="py-3 px-1 border-b-2 border-transparent text-[#6B5540] font-medium text-sm hover:text-[#1A1008]"
            id="tab-moderation"
          >
            Moderasyon
          </button>
          <button
            onclick="switchTab('users')"
            class="py-3 px-1 border-b-2 border-transparent text-[#6B5540] font-medium text-sm hover:text-[#1A1008]"
            id="tab-users"
          >
            Kullanıcı Yönetimi
          </button>
        </div>
      </div>

      {/* Content Sections */}
      <div id="overview-section">
        <AdminDashboardOverview client:visible />
      </div>

      <div id="moderation-section" class="hidden">
        <div class="bg-white border border-[rgba(200,160,100,0.18)] rounded-sm p-6 shadow-sm">
          <h2 class="text-xl font-semibold text-[#1A1008] mb-4">Moderasyon Kuyruğu</h2>
          <ModerationQueueManager client:visible />
        </div>
      </div>

      <div id="users-section" class="hidden">
        <div class="bg-white border border-[rgba(200,160,100,0.18)] rounded-sm p-6 shadow-sm">
          <h2 class="text-xl font-semibold text-[#1A1008] mb-4">Kullanıcı Yönetimi</h2>
          <UserManagementTable client:visible />
        </div>
      </div>
    </div>

  <script is:inline>
    function switchTab(tabName) {
      document.getElementById('overview-section')?.classList.add('hidden');
      document.getElementById('moderation-section')?.classList.add('hidden');
      document.getElementById('users-section')?.classList.add('hidden');

      document.getElementById('tab-overview')?.classList.remove('border-urfa-600', 'text-urfa-600');
      document.getElementById('tab-moderation')?.classList.remove('border-urfa-600', 'text-urfa-600');
      document.getElementById('tab-users')?.classList.remove('border-urfa-600', 'text-urfa-600');

      document.getElementById('tab-overview')?.classList.add('border-transparent', 'text-[#6B5540]');
      document.getElementById('tab-moderation')?.classList.add('border-transparent', 'text-[#6B5540]');
      document.getElementById('tab-users')?.classList.add('border-transparent', 'text-[#6B5540]');

      const sectionId = `${tabName}-section`;
      const tabId = `tab-${tabName}`;

      document.getElementById(sectionId)?.classList.remove('hidden');
      document.getElementById(tabId)?.classList.remove('border-transparent', 'text-[#6B5540]');
      document.getElementById(tabId)?.classList.add('border-urfa-600', 'text-urfa-600');
    }
  </script>
</AdminLayout>
