---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { query } from '../../lib/postgres';
import { logger } from '../../lib/logging';

let deletionRequests: any[] = [];

try {
  const result = await query(`
    SELECT ddr.id, ddr.user_id, ddr.reason, ddr.scheduled_for,
           ddr.status, ddr.created_at,
           u.email, u.full_name, u.role, u.created_at as user_created_at
    FROM data_deletion_requests ddr
    JOIN users u ON ddr.user_id = u.id
    WHERE ddr.status = 'pending'
    ORDER BY ddr.scheduled_for ASC
    LIMIT 100
  `);
  deletionRequests = result.rows;
} catch (e) {
  logger.error('User deletions admin query failed', e instanceof Error ? e : new Error(String(e)));
}

const today = new Date();
const deletionRequestRows = deletionRequests.map((req) => {
  const scheduledDate = new Date(req.scheduled_for);
  const daysLeft = Math.ceil((scheduledDate.getTime() - today.getTime()) / (1000 * 60 * 60 * 24));
  return {
    ...req,
    scheduledDate,
    daysLeft,
    isUrgent: daysLeft <= 3,
  };
});
const escapeHtml = (value: unknown) =>
  String(value ?? '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
const deletionRowsHtml = deletionRequestRows
  .map((req) => {
    const badgeClass =
      req.daysLeft <= 0
        ? 'bg-[rgba(200,160,100,0.2)] text-[#6B5540]'
        : req.isUrgent
          ? 'bg-[rgba(200,160,100,0.12)] text-[#6B5540]'
          : 'bg-[rgba(200,160,100,0.06)] text-[#9A8470]';
    const badgeText = req.daysLeft <= 0 ? 'Bugün silinecek' : `${req.daysLeft} gün`;
    return `
      <tr class="border-b border-[rgba(200,160,100,0.08)] last:border-0 hover:bg-[rgba(200,160,100,0.04)]">
        <td class="py-3 px-4">
          <div class="font-medium text-[#1A1008]">${escapeHtml(req.full_name || '—')}</div>
          <div class="text-xs text-[#9A8470]">${escapeHtml(req.email)}</div>
          <div class="text-xs text-[#9A8470]">Rol: ${escapeHtml(req.role)}</div>
        </td>
        <td class="py-3 px-4 text-[#6B5540] text-xs">${new Date(req.created_at).toLocaleDateString('tr-TR')}</td>
        <td class="py-3 px-4 text-[#6B5540] text-xs">${req.scheduledDate.toLocaleDateString('tr-TR')}</td>
        <td class="py-3 px-4 text-[#9A8470] text-xs max-w-xs">${escapeHtml(req.reason ? req.reason.substring(0, 100) : '—')}</td>
        <td class="py-3 px-4">
          <span class="text-xs px-2 py-0.5 rounded-sm font-medium ${badgeClass}">${escapeHtml(badgeText)}</span>
        </td>
      </tr>
    `;
  })
  .join('');

---

<AdminLayout
  title="Hesap Silme Talepleri"
  subtitle={`${deletionRequests.length} aktif talep`}
  seo={{ title: 'Hesap Silme Talepleri - Admin', noIndex: true }}
>
    <div class="container mx-auto px-4 py-8 max-w-5xl space-y-5">
      <div class="mb-2">
        <a href="/admin" class="text-sm text-[#9A8470] hover:text-[#6B5540]">← Admin Paneli</a>
      </div>

      {deletionRequests.length > 0 && (
        <div class="bg-[rgba(200,160,100,0.06)] border border-[rgba(200,160,100,0.2)] rounded-sm p-4 text-sm text-[#6B5540]">
          Silme tarihi geçmiş veya yaklaşan talepler dikkat ister. Hesaplar belirtilen tarihte otomatik silinir.
        </div>
      )}

      <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm overflow-hidden">
        {deletionRequests.length === 0 ? (
          <div class="p-12 text-center text-[#9A8470] text-sm">Aktif hesap silme talebi yok.</div>
        ) : (
          <table class="w-full text-sm">
            <thead class="border-b border-[rgba(200,160,100,0.14)] bg-[rgba(200,160,100,0.04)]">
              <tr>
                <th class="py-3 px-4 text-left font-medium text-[#6B5540]">Kullanıcı</th>
                <th class="py-3 px-4 text-left font-medium text-[#6B5540]">Talep Tarihi</th>
                <th class="py-3 px-4 text-left font-medium text-[#6B5540]">Silinecek Tarih</th>
                <th class="py-3 px-4 text-left font-medium text-[#6B5540]">Sebep</th>
                <th class="py-3 px-4 text-left font-medium text-[#6B5540]">Kalan Gün</th>
              </tr>
            </thead>
            <tbody set:html={deletionRowsHtml} />
          </table>
        )}
      </div>
    </div>
</AdminLayout>
