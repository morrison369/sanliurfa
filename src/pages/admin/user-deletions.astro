---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { query } from '../../lib/postgres';
import { logger } from '../../lib/logging';

let deletionRequests: any[] = [];

try {
 const result = await query(`
 SELECT ddr.id, ddr.user_id, ddr.reason, ddr.scheduled_for,
 ddr.status, ddr.created_at,
 u.email, u.full_name, u.role, u.created_at as user_created_at
 FROM data_deletion_requests ddr
 JOIN users u ON ddr.user_id = u.id
 WHERE ddr.status = 'pending'
 ORDER BY ddr.scheduled_for ASC
 LIMIT 100
 `);
 deletionRequests = result.rows;
} catch (e) {
 logger.error('User deletions admin query failed', e instanceof Error ? e : new Error(String(e)));
}

const today = new Date();
const deletionRequestRows = deletionRequests.map((req) => {
 const scheduledDate = new Date(req.scheduled_for);
 const daysLeft = Math.ceil((scheduledDate.getTime() - today.getTime()) / (1000 * 60 * 60 * 24));
 return {
 ...req,
 scheduledDate,
 daysLeft,
 isUrgent: daysLeft <= 3,
 };
});
const escapeHtml = (value: unknown) =>
 String(value ?? '')
 .replace(/&/g, '&amp;')
 .replace(/</g, '&lt;')
 .replace(/>/g, '&gt;')
 .replace(/"/g, '&quot;')
 .replace(/'/g, '&#39;');
const deletionRowsHtml = deletionRequestRows
 .map((req) => {
 const badgeClass =
 req.daysLeft <= 0
 ? 'bg-[rgba(184,115,51,0.2)] text-[#7A6B58]'
 : req.isUrgent
 ? 'bg-[rgba(184,115,51,0.12)] text-[#7A6B58]'
 : 'bg-[rgba(184,115,51,0.06)] text-[#7A6B58]';
 const badgeText = req.daysLeft <= 0 ? 'Bugün silinecek' : `${req.daysLeft} gün`;
 return `
 <tr class="border-b border-[rgba(184,115,51,0.08)] last:border-0 hover:bg-[rgba(184,115,51,0.04)]">
 <td class="py-3 px-4">
 <div class="font-medium text-[#1F1410]">${escapeHtml(req.full_name || '—')}</div>
 <div class="text-xs text-[#7A6B58]">${escapeHtml(req.email)}</div>
 <div class="text-xs text-[#7A6B58]">Rol: ${escapeHtml(req.role)}</div>
 </td>
 <td class="py-3 px-4 text-[#7A6B58] text-xs">${new Date(req.created_at).toLocaleDateString('tr-TR')}</td>
 <td class="py-3 px-4 text-[#7A6B58] text-xs">${req.scheduledDate.toLocaleDateString('tr-TR')}</td>
 <td class="py-3 px-4 text-[#7A6B58] text-xs max-w-xs">${escapeHtml(req.reason ? req.reason.substring(0, 100) : '—')}</td>
 <td class="py-3 px-4">
 <span class="text-xs px-2 py-0.5 rounded-sm font-medium ${badgeClass}">${escapeHtml(badgeText)}</span>
 </td>
 </tr>
 `;
 })
 .join('');

---

<AdminLayout
 title="Hesap Silme Talepleri"
 subtitle={`${deletionRequests.length} aktif talep`}
 seo={{ title: 'Hesap Silme Talepleri - Admin', noIndex: true }}
>
 <div class="sf-container py-8 max-w-5xl space-y-5">
 <div class="mb-2">
 <a href="/admin" class="text-sm text-[#7A6B58] hover:text-[#7A6B58]">← Admin Paneli</a>
 </div>

 {deletionRequests.length > 0 && (
 <div class="bg-[rgba(184,115,51,0.06)] border border-[rgba(184,115,51,0.2)] rounded-sm p-4 text-sm text-[#7A6B58]">
 Silme tarihi geçmiş veya yaklaşan talepler dikkat ister. Hesaplar belirtilen tarihte otomatik silinir.
 </div>
 )}

 <div class="bg-[var(--bg-card)] border border-[rgba(184,115,51,0.14)] rounded-sm overflow-hidden">
 {deletionRequests.length === 0 ? (
 <div class="p-12 text-center text-[#7A6B58] text-sm">Aktif hesap silme talebi yok.</div>
 ) : (
 <table class="w-full text-sm">
 <thead class="border-b border-[rgba(184,115,51,0.14)] bg-[rgba(184,115,51,0.04)]">
 <tr>
 <th class="py-3 px-4 text-left font-medium text-[#7A6B58]">Kullanıcı</th>
 <th class="py-3 px-4 text-left font-medium text-[#7A6B58]">Talep Tarihi</th>
 <th class="py-3 px-4 text-left font-medium text-[#7A6B58]">Silinecek Tarih</th>
 <th class="py-3 px-4 text-left font-medium text-[#7A6B58]">Sebep</th>
 <th class="py-3 px-4 text-left font-medium text-[#7A6B58]">Kalan Gün</th>
 </tr>
 </thead>
 <tbody set:html={deletionRowsHtml} />
 </table>
 )}
 </div>
 </div>
</AdminLayout>
