---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { requireRole } from '../../lib/auth';

const auth = await requireRole(Astro.request, 'admin');
if (auth instanceof Response) return auth;
---

<AdminLayout title="Şehir İçerik Ajanları">
  <section class="space-y-6">
    <div class="rounded-2xl border border-amber-200 bg-amber-50 p-5">
      <p class="text-sm font-semibold uppercase tracking-wide text-amber-700">Yayın politikası</p>
      <h1 class="mt-1 text-2xl font-bold text-slate-950">Şanlıurfa içerikleri admin onayıyla yayınlanır</h1>
      <p class="mt-2 max-w-4xl text-sm leading-6 text-slate-700">
        Bu ekran ürün/mağaza karşılaştırma için değil; Şanlıurfa nöbetçi eczane, ulaşım, uçak saatleri,
        etkinlik, mekan, yemek tarifi, görsel ve SEO/AEO/GEO/AIO içerik taslakları içindir.
        Ajanlar otomatik yayın yapmaz, tüm çıktılar taslak kuyruğuna düşer.
      </p>
    </div>

    <div id="agent-policy" class="grid gap-3 md:grid-cols-4"></div>

    <div class="grid gap-6 xl:grid-cols-[1.1fr_0.9fr]">
      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between gap-3">
          <div>
            <h2 class="text-lg font-bold text-slate-950">Ajanlar</h2>
            <p class="text-sm text-slate-500">Kaynakları kontrol eder ve yayınlanmadan önce taslak üretir.</p>
          </div>
          <button id="refresh-btn" class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700">
            Yenile
          </button>
        </div>
        <div id="agents-list" class="mt-5 grid gap-4"></div>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-lg font-bold text-slate-950">Resmi / izinli kaynaklar</h2>
        <p class="text-sm text-slate-500">Öncelik resmi kaynak, sonra lisanslı görsel sağlayıcılarıdır.</p>
        <div id="sources-list" class="mt-5 space-y-3"></div>
      </div>
    </div>

    <div class="grid gap-6 xl:grid-cols-[1fr_1fr]">
      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-lg font-bold text-slate-950">Taslak kuyruğu</h2>
        <p class="text-sm text-slate-500">Onaylanan taslaklar yayın sistemine kaynak olur; reddedilenler canlıya çıkmaz.</p>
        <div id="drafts-list" class="mt-5 space-y-3"></div>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-lg font-bold text-slate-950">Ajan iş geçmişi</h2>
        <p class="text-sm text-slate-500">Her çalışma loglanır; hata alırsa public site etkilenmez.</p>
        <div id="jobs-list" class="mt-5 space-y-3"></div>
      </div>
    </div>
  </section>

  <script is:inline>
    const state = { agents: [], sources: [], jobs: [], drafts: [], policy: {} };

    function escapeHtml(value) {
      return String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    function statusClass(status) {
      if (status === 'completed' || status === 'approved') return 'bg-emerald-100 text-emerald-700';
      if (status === 'failed' || status === 'rejected') return 'bg-red-100 text-red-700';
      if (status === 'running') return 'bg-blue-100 text-blue-700';
      return 'bg-amber-100 text-amber-700';
    }

    async function apiPost(payload) {
      const res = await fetch('/api/admin/city-content-agents', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (!res.ok || data.success === false) {
        throw new Error(data.detail || data.error || 'İşlem başarısız');
      }
      return data;
    }

    async function runAgent(agentKey, sourceKey = null) {
      const buttonSelector = sourceKey
        ? `[data-source-run="${sourceKey}"]`
        : `[data-agent-run="${agentKey}"]`;
      const button = document.querySelector(buttonSelector);
      if (button) {
        button.disabled = true;
        button.textContent = 'Çalışıyor...';
      }
      try {
        await apiPost({ action: 'run-agent', agentKey, sourceKey });
        await loadData();
      } catch (error) {
        alert(error.message || 'Ajan çalıştırılamadı');
      } finally {
        if (button) {
          button.disabled = false;
          button.textContent = sourceKey ? 'Bu kaynaktan üret' : 'Taslak üret';
        }
      }
    }

    async function updateDraft(action, draftId) {
      try {
        await apiPost({ action, draftId });
        await loadData();
      } catch (error) {
        alert(error.message || 'Taslak güncellenemedi');
      }
    }

    function renderPolicy() {
      const policy = state.policy || {};
      const items = [
        ['Otomatik yayın', policy.autoPublish ? 'Açık' : 'Kapalı'],
        ['Dil', 'Sadece Türkçe'],
        ['Odak kelime', policy.focusKeyword || 'Şanlıurfa'],
        ['Görsel önceliği', (policy.imagePriority || []).join(' → ') || 'Pexels → Unsplash'],
      ];
      document.getElementById('agent-policy').innerHTML = items.map(([label, value]) => `
        <div class="rounded-xl border border-slate-200 bg-white p-4">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">${escapeHtml(label)}</p>
          <p class="mt-1 font-bold text-slate-950">${escapeHtml(value)}</p>
        </div>
      `).join('');
    }

    function renderAgents() {
      document.getElementById('agents-list').innerHTML = state.agents.map((agent) => `
        <article class="rounded-xl border border-slate-200 p-4">
          <div class="flex items-start justify-between gap-3">
            <div>
              <h3 class="font-bold text-slate-950">${escapeHtml(agent.title)}</h3>
              <p class="mt-1 text-sm leading-6 text-slate-600">${escapeHtml(agent.purpose)}</p>
              <p class="mt-2 text-xs text-slate-500">Çıktı: ${escapeHtml(agent.outputType)} · Otomatik yayın: kapalı</p>
            </div>
            <button data-agent-run="${escapeHtml(agent.key)}" onclick="runAgent('${escapeHtml(agent.key)}')" class="shrink-0 rounded-lg bg-amber-600 px-4 py-2 text-sm font-semibold text-white hover:bg-amber-700">
              Taslak üret
            </button>
          </div>
        </article>
      `).join('');
    }

    function renderSources() {
      if (!state.sources.length) {
        document.getElementById('sources-list').innerHTML = '<p class="text-sm text-slate-500">Kaynak yok.</p>';
        return;
      }
      document.getElementById('sources-list').innerHTML = state.sources.map((source) => `
        <article class="rounded-xl border border-slate-200 p-4">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="font-semibold text-slate-950">${escapeHtml(source.title)}</p>
              <p class="mt-1 text-xs text-slate-500">${escapeHtml(source.agent_key)} · ${escapeHtml(source.trust_level)}</p>
              <a class="mt-2 block break-all text-sm text-blue-700 hover:underline" href="${escapeHtml(source.url)}" target="_blank" rel="noreferrer">${escapeHtml(source.url)}</a>
            </div>
            <div class="flex shrink-0 flex-col items-end gap-2">
              <span class="rounded-full ${source.is_active ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-500'} px-2 py-1 text-xs font-semibold">
                ${source.is_active ? 'Aktif' : 'Kapalı'}
              </span>
              <button data-source-run="${escapeHtml(source.source_key)}" onclick="runAgent('${escapeHtml(source.agent_key)}', '${escapeHtml(source.source_key)}')" class="rounded-lg bg-slate-900 px-3 py-2 text-xs font-semibold text-white hover:bg-slate-700">
                Bu kaynaktan üret
              </button>
            </div>
          </div>
        </article>
      `).join('');
    }

    function renderDrafts() {
      if (!state.drafts.length) {
        document.getElementById('drafts-list').innerHTML = '<p class="text-sm text-slate-500">Taslak yok.</p>';
        return;
      }
      document.getElementById('drafts-list').innerHTML = state.drafts.map((draft) => `
        <article class="rounded-xl border border-slate-200 p-4">
          <div class="flex items-start justify-between gap-3">
            <div>
              <h3 class="font-bold text-slate-950">${escapeHtml(draft.title)}</h3>
              <p class="mt-1 text-xs text-slate-500">${escapeHtml(draft.draft_type)} · /${escapeHtml(draft.slug)}</p>
              <p class="mt-2 text-sm leading-6 text-slate-600">${escapeHtml(draft.payload?.summary || draft.payload?.sourceDigest || '').slice(0, 260)}</p>
            </div>
            <span class="rounded-full px-2 py-1 text-xs font-semibold ${statusClass(draft.status)}">${escapeHtml(draft.status)}</span>
          </div>
          <div class="mt-3 flex flex-wrap gap-2">
            <button onclick="updateDraft('approve-draft', '${escapeHtml(draft.id)}')" class="rounded-lg bg-emerald-600 px-3 py-2 text-xs font-semibold text-white hover:bg-emerald-700">Onayla</button>
            <button onclick="updateDraft('reject-draft', '${escapeHtml(draft.id)}')" class="rounded-lg bg-slate-200 px-3 py-2 text-xs font-semibold text-slate-700 hover:bg-slate-300">Reddet</button>
          </div>
        </article>
      `).join('');
    }

    function renderJobs() {
      if (!state.jobs.length) {
        document.getElementById('jobs-list').innerHTML = '<p class="text-sm text-slate-500">Henüz ajan işi yok.</p>';
        return;
      }
      document.getElementById('jobs-list').innerHTML = state.jobs.map((job) => `
        <article class="rounded-xl border border-slate-200 p-4">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="font-semibold text-slate-950">${escapeHtml(job.agent_key)}</p>
              <p class="mt-1 text-xs text-slate-500">${new Date(job.created_at).toLocaleString('tr-TR')}</p>
              <p class="mt-2 text-sm text-slate-600">${escapeHtml(job.summary || job.error_message || 'İş kaydı oluşturuldu.')}</p>
            </div>
            <span class="rounded-full px-2 py-1 text-xs font-semibold ${statusClass(job.status)}">${escapeHtml(job.status)}</span>
          </div>
        </article>
      `).join('');
    }

    async function loadData() {
      const res = await fetch('/api/admin/city-content-agents');
      const data = await res.json();
      if (!res.ok || data.success === false) throw new Error(data.detail || 'Veri alınamadı');
      Object.assign(state, data);
      renderPolicy();
      renderAgents();
      renderSources();
      renderDrafts();
      renderJobs();
    }

    window.runAgent = runAgent;
    window.updateDraft = updateDraft;
    document.getElementById('refresh-btn').addEventListener('click', loadData);
    loadData().catch((error) => {
      document.getElementById('agents-list').innerHTML = `<p class="text-sm text-red-600">${escapeHtml(error.message)}</p>`;
    });
  </script>
</AdminLayout>
