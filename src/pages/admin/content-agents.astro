---
import { Icon } from 'astro-icon/components';
import AdminLayout from '../../layouts/AdminLayoutV2.astro';
---

<AdminLayout
 title="Şehir İçerik Ajanları"
 subtitle="Otomatik kaynak takip + admin onaylı taslak yayın"
 seo={{ title: 'Şehir İçerik Ajanları - Admin', noIndex: true }}
>
 <div class="ca-page">
  <div class="ca-policy">
   <div class="ca-policy-icon">
    <Icon name="lucide:shield-check" class="w-5 h-5" />
   </div>
   <div class="ca-policy-body">
    <p class="ca-policy-eyebrow">Yayın Politikası</p>
    <h2 class="ca-policy-title">Şanlıurfa içerikleri admin onayıyla yayınlanır</h2>
    <p class="ca-policy-desc">
     Nöbetçi eczane, ulaşım, uçak saatleri, etkinlik, mekan, yemek tarifi, görsel ve SEO taslakları için.
     <strong>Ajanlar otomatik yayın yapmaz</strong> — tüm çıktılar taslak kuyruğuna düşer ve onay bekler.
    </p>
   </div>
  </div>

  <div id="agent-policy" class="ca-policy-grid"></div>

  <div class="ca-two-col">
   <section class="ca-card">
    <header class="ca-card-head">
     <div>
      <h2 class="ca-card-title">
       <Icon name="lucide:bot" class="w-4 h-4" /> Ajanlar
      </h2>
      <p class="ca-card-sub">Kaynakları izler ve taslak üretir</p>
     </div>
     <button id="refresh-btn" type="button" class="ca-btn">
      <Icon name="lucide:refresh-cw" class="w-3.5 h-3.5" /> Yenile
     </button>
    </header>
    <div id="agents-list" class="ca-list"></div>
   </section>

   <section class="ca-card">
    <header class="ca-card-head">
     <div>
      <h2 class="ca-card-title">
       <Icon name="lucide:link" class="w-4 h-4" /> Resmi Kaynaklar
      </h2>
      <p class="ca-card-sub">Öncelik: resmi kaynak → lisanslı görsel sağlayıcı</p>
     </div>
    </header>
    <div id="sources-list" class="ca-list"></div>
   </section>
  </div>

  <div class="ca-two-col">
   <section class="ca-card">
    <header class="ca-card-head">
     <div>
      <h2 class="ca-card-title">
       <Icon name="lucide:inbox" class="w-4 h-4" /> Taslak Kuyruğu
      </h2>
      <p class="ca-card-sub" id="drafts-summary">Onaylanan taslaklar yayına geçer; reddedilenler canlıya çıkmaz</p>
     </div>
    </header>
    <div class="ca-filter-row">
     <label>
      Durum
      <select id="draft-status-filter">
       <option value="">Tümü</option>
       <option value="pending" selected>Pending</option>
       <option value="approved">Approved</option>
       <option value="rejected">Rejected</option>
      </select>
     </label>
     <label>
      Tip
      <select id="draft-type-filter">
       <option value="">Tümü</option>
       <option value="place-discovery-draft">Google Maps keşif</option>
       <option value="place-enrichment-draft">Mekan zenginleştirme</option>
       <option value="seo-override-draft">SEO/GEO</option>
       <option value="media-task">Görsel görevleri</option>
      </select>
     </label>
     <label>
      Limit
      <select id="draft-limit-filter">
       <option value="50">50</option>
       <option value="100" selected>100</option>
       <option value="250">250</option>
       <option value="500">500</option>
      </select>
     </label>
    </div>
    <div id="drafts-list" class="ca-list"></div>
   </section>

   <section class="ca-card">
    <header class="ca-card-head">
     <div>
      <h2 class="ca-card-title">
       <Icon name="lucide:list-checks" class="w-4 h-4" /> İş Geçmişi
      </h2>
      <p class="ca-card-sub">Her çalışma loglanır — hata alırsa public site etkilenmez</p>
     </div>
    </header>
    <div id="jobs-list" class="ca-list"></div>
   </section>
  </div>
 </div>

 <script is:inline>
 const state = { agents: [], sources: [], jobs: [], drafts: [], policy: {}, draftSummary: {} };

 function statusBadgeClass(status) {
 if (status === 'completed' || status === 'approved') return 'bg-[rgba(184,115,51,0.15)] text-[#7A6B58]';
 if (status === 'failed' || status === 'rejected') return 'bg-[var(--adm-bg-hover)] text-[#7A6B58]';
 if (status === 'running') return 'bg-[var(--adm-border-strong)] text-[#7A6B58]';
 return 'bg-[var(--adm-bg-active)] text-[#7A6B58]';
 }

 async function apiPost(payload) {
 const res = await fetch('/api/admin/city-content-agents', {
 method: 'POST',
 headers: { 'Content-Type': 'application/json' },
 body: JSON.stringify(payload),
 });
 const data = await res.json();
 if (!res.ok || data.success === false) {
 throw new Error(data.detail || data.error || 'İşlem başarısız');
 }
 return data;
 }

 async function runAgent(agentKey, sourceKey = null) {
 const buttonSelector = sourceKey
 ? `[data-source-run="${sourceKey}"]`
 : `[data-agent-run="${agentKey}"]`;
 const button = document.querySelector(buttonSelector);
 if (button) {
 button.disabled = true;
 button.textContent = 'Çalışıyor...';
 }
 try {
 await apiPost({ action: 'run-agent', agentKey, sourceKey });
 await loadData();
 } catch {
 window.toast?.error('Ajan çalıştırılamadı');
 } finally {
 if (button) {
 button.disabled = false;
 button.textContent = sourceKey ? 'Bu kaynaktan üret' : 'Taslak üret';
 }
 }
 }

 async function updateDraft(action, draftId) {
 try {
 await apiPost({ action, draftId });
 await loadData();
 } catch {
 window.toast?.error('Taslak güncellenemedi');
 }
 }

 function makePolicyCard(label, value) {
 const div = document.createElement('div');
 div.className = 'rounded-sm border border-[var(--adm-border)] bg-[var(--bg-card)] p-4';
 const p1 = document.createElement('p');
 p1.className = 'text-xs font-semibold uppercase tracking-widest text-[#7A6B58]';
 p1.textContent = label;
 const p2 = document.createElement('p');
 p2.className = 'mt-1 font-bold text-[#1F1410]';
 p2.textContent = value;
 div.appendChild(p1);
 div.appendChild(p2);
 return div;
 }

 function renderPolicy() {
 const policy = state.policy || {};
 const items = [
 ['Otomatik yayın', policy.autoPublish ? 'Açık' : 'Kapalı'],
 ['Dil', 'Sadece Türkçe'],
 ['Odak kelime', policy.focusKeyword || 'Şanlıurfa'],
 ['Görsel önceliği', (policy.imagePriority || []).join(' → ') || 'Pexels → Unsplash'],
 ];
 const container = document.getElementById('agent-policy');
 container.replaceChildren(...items.map(([label, value]) => makePolicyCard(label, value)));
 }

 function makeAgentCard(agent) {
 const article = document.createElement('article');
 article.className = 'rounded-sm border border-[var(--adm-border)] p-4';
 const row = document.createElement('div');
 row.className = 'flex items-start justify-between gap-3';
 const info = document.createElement('div');
 const title = document.createElement('h3');
 title.className = 'font-bold text-[#1F1410]';
 title.textContent = agent.title;
 const purpose = document.createElement('p');
 purpose.className = 'mt-1 text-sm leading-6 text-[#7A6B58]';
 purpose.textContent = agent.purpose;
 const meta = document.createElement('p');
 meta.className = 'mt-2 text-xs text-[#7A6B58]';
 meta.textContent = 'Çıktı: ' + agent.outputType + ' · Otomatik yayın: kapalı';
 info.appendChild(title);
 info.appendChild(purpose);
 info.appendChild(meta);
 const btn = document.createElement('button');
 btn.dataset.agentRun = agent.key;
 btn.className = 'shrink-0 rounded-sm bg-urfa-600 px-4 py-2 text-sm font-semibold text-white hover:bg-urfa-700';
 btn.textContent = 'Taslak üret';
 btn.addEventListener('click', () => runAgent(agent.key));
 row.appendChild(info);
 row.appendChild(btn);
 article.appendChild(row);
 return article;
 }

 function renderAgents() {
 const container = document.getElementById('agents-list');
 if (!state.agents.length) {
 const p = document.createElement('p');
 p.className = 'text-sm text-[#7A6B58]';
 p.textContent = 'Ajan yok.';
 container.replaceChildren(p);
 return;
 }
 container.replaceChildren(...state.agents.map(makeAgentCard));
 }

 function makeSourceCard(source) {
 const article = document.createElement('article');
 article.className = 'rounded-sm border border-[var(--adm-border)] p-4';
 const row = document.createElement('div');
 row.className = 'flex items-start justify-between gap-3';
 const info = document.createElement('div');
 const title = document.createElement('p');
 title.className = 'font-semibold text-[#1F1410]';
 title.textContent = source.title;
 const meta = document.createElement('p');
 meta.className = 'mt-1 text-xs text-[#7A6B58]';
 meta.textContent = source.agent_key + ' · ' + source.trust_level;
 const link = document.createElement('a');
 link.className = 'mt-2 block break-all text-sm text-urfa-600 hover:underline';
 link.href = source.url;
 link.target = '_blank';
 link.rel = 'noreferrer noopener';
 link.textContent = source.url;
 info.appendChild(title);
 info.appendChild(meta);
 info.appendChild(link);
 const actions = document.createElement('div');
 actions.className = 'flex shrink-0 flex-col items-end gap-2';
 const badge = document.createElement('span');
 badge.className = 'rounded-full px-2 py-0.5 text-xs font-medium ' +
 (source.is_active ? 'bg-[rgba(184,115,51,0.15)] text-[#7A6B58]' : 'bg-[var(--adm-bg-hover)] text-[#7A6B58]');
 badge.textContent = source.is_active ? 'Aktif' : 'Kapalı';
 const btn = document.createElement('button');
 btn.dataset.sourceRun = source.source_key;
 btn.className = 'rounded-sm bg-[#0D0A08] px-3 py-2 text-xs font-semibold text-white hover:opacity-90';
 btn.textContent = 'Bu kaynaktan üret';
 btn.addEventListener('click', () => runAgent(source.agent_key, source.source_key));
 actions.appendChild(badge);
 actions.appendChild(btn);
 row.appendChild(info);
 row.appendChild(actions);
 article.appendChild(row);
 return article;
 }

 function renderSources() {
 const container = document.getElementById('sources-list');
 if (!state.sources.length) {
 const p = document.createElement('p');
 p.className = 'text-sm text-[#7A6B58]';
 p.textContent = 'Kaynak yok.';
 container.replaceChildren(p);
 return;
 }
 container.replaceChildren(...state.sources.map(makeSourceCard));
 }

 function makeDraftCard(draft) {
 const article = document.createElement('article');
 article.className = 'rounded-sm border border-[var(--adm-border)] p-4';
 const row = document.createElement('div');
 row.className = 'flex items-start justify-between gap-3';
 const info = document.createElement('div');
 const title = document.createElement('h3');
 title.className = 'font-bold text-[#1F1410]';
 title.textContent = draft.title;
 const meta = document.createElement('p');
 meta.className = 'mt-1 text-xs text-[#7A6B58]';
 meta.textContent = draft.draft_type + ' · /' + draft.slug;
 const summary = document.createElement('p');
 summary.className = 'mt-2 text-sm leading-6 text-[#7A6B58]';
 summary.textContent = String(draft.payload?.summary || draft.payload?.sourceDigest || draft.payload?.query || '').slice(0, 260);
 info.appendChild(title);
 info.appendChild(meta);
 info.appendChild(summary);
 const badge = document.createElement('span');
 badge.className = 'rounded-full px-2 py-0.5 text-xs font-medium flex-shrink-0 ' + statusBadgeClass(draft.status);
 badge.textContent = draft.status;
 row.appendChild(info);
 row.appendChild(badge);
 article.appendChild(row);
 const btns = document.createElement('div');
 btns.className = 'mt-3 flex flex-wrap gap-2';
 const approveBtn = document.createElement('button');
 approveBtn.className = 'rounded-sm bg-[#6B5540] px-3 py-2 text-xs font-semibold text-white hover:bg-[#4A3A28]';
 approveBtn.textContent = 'Onayla';
 approveBtn.addEventListener('click', () => updateDraft('approve-draft', draft.id));
 const rejectBtn = document.createElement('button');
 rejectBtn.className = 'rounded-sm bg-[var(--adm-bg-hover)] px-3 py-2 text-xs font-semibold text-[#7A6B58] hover:bg-[var(--adm-bg-active)]';
 rejectBtn.textContent = 'Reddet';
 rejectBtn.addEventListener('click', () => updateDraft('reject-draft', draft.id));
 btns.appendChild(approveBtn);
 btns.appendChild(rejectBtn);
 article.appendChild(btns);
 return article;
 }

function renderDrafts() {
 const container = document.getElementById('drafts-list');
 const summary = state.draftSummary || {};
 const summaryEl = document.getElementById('drafts-summary');
 if (summaryEl) {
 const pending = summary.byStatus?.pending || 0;
 const discovery = summary.byType?.['place-discovery-draft'] || 0;
 summaryEl.textContent = `${summary.total || 0} toplam · ${pending} pending · ${discovery} Google Maps keşif adayı`;
 }
 if (!state.drafts.length) {
 const p = document.createElement('p');
 p.className = 'text-sm text-[#7A6B58]';
 p.textContent = 'Taslak yok.';
 container.replaceChildren(p);
 return;
 }
 container.replaceChildren(...state.drafts.map(makeDraftCard));
 }

 function makeJobCard(job) {
 const article = document.createElement('article');
 article.className = 'rounded-sm border border-[var(--adm-border)] p-4';
 const row = document.createElement('div');
 row.className = 'flex items-start justify-between gap-3';
 const info = document.createElement('div');
 const title = document.createElement('p');
 title.className = 'font-semibold text-[#1F1410]';
 title.textContent = job.agent_key;
 const ts = document.createElement('p');
 ts.className = 'mt-1 text-xs text-[#7A6B58]';
 ts.textContent = new Date(job.created_at).toLocaleString('tr-TR');
 const summary = document.createElement('p');
 summary.className = 'mt-2 text-sm text-[#7A6B58]';
 summary.textContent = job.summary || job.error_message || 'İş kaydı oluşturuldu.';
 info.appendChild(title);
 info.appendChild(ts);
 info.appendChild(summary);
 const badge = document.createElement('span');
 badge.className = 'rounded-full px-2 py-0.5 text-xs font-medium flex-shrink-0 ' + statusBadgeClass(job.status);
 badge.textContent = job.status;
 row.appendChild(info);
 row.appendChild(badge);
 article.appendChild(row);
 return article;
 }

 function renderJobs() {
 const container = document.getElementById('jobs-list');
 if (!state.jobs.length) {
 const p = document.createElement('p');
 p.className = 'text-sm text-[#7A6B58]';
 p.textContent = 'Henüz ajan işi yok.';
 container.replaceChildren(p);
 return;
 }
 container.replaceChildren(...state.jobs.map(makeJobCard));
 }

 function draftQueryString() {
 const params = new URLSearchParams();
 const status = document.getElementById('draft-status-filter')?.value || '';
 const draftType = document.getElementById('draft-type-filter')?.value || '';
 const limit = document.getElementById('draft-limit-filter')?.value || '100';
 if (status) params.set('status', status);
 if (draftType) params.set('draftType', draftType);
 params.set('limit', limit);
 const query = params.toString();
 return query ? `?${query}` : '';
 }

 async function loadData() {
 const res = await fetch('/api/admin/city-content-agents' + draftQueryString());
 const data = await res.json();
 if (!res.ok || data.success === false) throw new Error(data.detail || 'Veri alınamadı');
 Object.assign(state, data);
 renderPolicy();
 renderAgents();
 renderSources();
 renderDrafts();
 renderJobs();
 }

 window.runAgent = runAgent;
 window.updateDraft = updateDraft;
 document.getElementById('refresh-btn').addEventListener('click', loadData);
 document.getElementById('draft-status-filter')?.addEventListener('change', loadData);
 document.getElementById('draft-type-filter')?.addEventListener('change', loadData);
 document.getElementById('draft-limit-filter')?.addEventListener('change', loadData);
 loadData().catch((error) => {
 const p = document.createElement('p');
 p.className = 'text-sm text-[#7A6B58]';
 p.textContent = error instanceof Error ? error.message : 'Yüklenemedi';
 const el = document.getElementById('agents-list');
 if (el) el.replaceChildren(p);
 });
 </script>

 <style>
  .ca-page { display: flex; flex-direction: column; gap: 1.25rem; }

  .ca-policy {
   display: flex; gap: 1rem; align-items: flex-start;
   padding: 1.15rem 1.25rem;
   background: linear-gradient(135deg, var(--adm-bg-hover), rgba(217,119,6,0.05));
   border: 1px solid var(--adm-border-strong);
   border-radius: 12px;
  }
  .ca-policy-icon {
   width: 44px; height: 44px;
   border-radius: 11px;
   background: linear-gradient(135deg, var(--adm-accent), var(--adm-warning));
   color: #fff;
   display: inline-flex; align-items: center; justify-content: center;
   flex-shrink: 0;
   box-shadow: 0 4px 12px -2px rgba(192,87,31,0.3);
  }
  .ca-policy-eyebrow {
   margin: 0 0 0.2rem;
   font-size: 0.68rem; font-weight: 700;
   text-transform: uppercase;
   letter-spacing: 0.1em;
   color: var(--adm-accent);
  }
  .ca-policy-title {
   font-family: 'Cormorant Garamond', serif;
   font-size: 1.3rem; font-weight: 700;
   color: var(--adm-text);
   margin: 0 0 0.4rem;
  }
  .ca-policy-desc {
   font-size: 0.86rem;
   color: var(--adm-text-muted);
   margin: 0;
   line-height: 1.55;
  }
  .ca-policy-desc strong { color: var(--adm-text); font-weight: 700; }

  .ca-policy-grid {
   display: grid;
   grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
   gap: 0.65rem;
  }

  .ca-two-col {
   display: grid;
   grid-template-columns: 1fr;
   gap: 1.25rem;
  }
  @media (min-width: 1024px) {
   .ca-two-col { grid-template-columns: 1.1fr 0.9fr; }
   .ca-two-col + .ca-two-col { grid-template-columns: 1fr 1fr; }
  }

  .ca-card {
   background: var(--adm-bg-elev);
   border: 1px solid var(--adm-border);
   border-radius: 12px;
   overflow: hidden;
  }
  .ca-card-head {
   display: flex; align-items: center; justify-content: space-between;
   gap: 0.75rem;
   padding: 0.95rem 1.15rem;
   border-bottom: 1px solid var(--adm-border);
   background: var(--adm-bg-hover);
  }
  .ca-card-title {
   display: inline-flex; align-items: center; gap: 0.5rem;
   margin: 0;
   font-size: 0.95rem; font-weight: 600;
   color: var(--adm-text);
  }
  .ca-card-sub {
   font-size: 0.78rem;
   color: var(--adm-text-soft);
   margin: 0.2rem 0 0;
  }

  .ca-btn {
   display: inline-flex; align-items: center; gap: 0.3rem;
   padding: 0.4rem 0.85rem;
   background: var(--adm-accent);
   color: #fff;
   border: none;
   border-radius: 6px;
   font-size: 0.78rem; font-weight: 600;
   cursor: pointer;
   flex-shrink: 0;
  }
  .ca-btn:hover { filter: brightness(0.93); }

  .ca-list {
   padding: 1rem 1.15rem;
   display: flex; flex-direction: column;
   gap: 0.65rem;
   min-height: 80px;
  }
  .ca-filter-row {
   display: grid;
   grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
   gap: 0.65rem;
   padding: 0.85rem 1.15rem 0;
  }
  .ca-filter-row label {
   display: flex;
   flex-direction: column;
   gap: 0.25rem;
   font-size: 0.72rem;
   font-weight: 700;
   color: var(--adm-text-soft);
   text-transform: uppercase;
   letter-spacing: 0.06em;
  }
  .ca-filter-row select {
   border: 1px solid var(--adm-border);
   border-radius: 8px;
   background: var(--adm-bg-elev);
   color: var(--adm-text);
   padding: 0.55rem 0.65rem;
   font-size: 0.86rem;
   text-transform: none;
   letter-spacing: 0;
  }
 </style>
</AdminLayout>
