---
import Layout from '../../layouts/Layout.astro';
import UserManagementTable from '../../components/UserManagementTable.astro';

const user = Astro.locals.user;

if (!user || !Astro.locals.isAdmin) {
  return Astro.redirect('/giris?redirect=/admin/users');
}

const seo = { title: 'Kullanıcı Yönetimi - Admin' };
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-100 dark:bg-gray-900 py-8">
    <div class="container-custom">
      <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Kullanıcılar</h1>
        <a href="/admin" class="text-urfa-600 hover:text-urfa-700">← Admin Panel</a>
      </div>
      
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm overflow-hidden">
        <div class="p-6">
          <UserManagementTable />
        </div>
      </div>
    </div>
  </div>
</Layout>
