---
import AdminLayout from '../../layouts/AdminLayoutV2.astro';
import PharmacyManager from '../../components/admin/PharmacyManager';
---

<AdminLayout
 title="Nöbetçi Eczane Yönetimi"
 subtitle="Günlük nöbetçi eczane ataması ve eczane veri yönetimi"
 seo={{ title: 'Nöbetçi Eczane Yönetimi - Admin', noIndex: true }}
>
 <div class="ph-page">
  <div class="ph-panel">
   <PharmacyManager client:idle />
  </div>
 </div>
</AdminLayout>

<style>
 .ph-page { display: flex; flex-direction: column; gap: 1rem; }
 .ph-panel {
  background: var(--adm-bg-elev);
  border: 1px solid var(--adm-border);
  border-radius: 12px;
  padding: 1.25rem;
 }
</style>
