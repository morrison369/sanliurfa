---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getCategories, getTags } from '../../../lib/blog/db';

const [categories, tags] = await Promise.all([
 getCategories(),
 getTags(),
]);
---

<AdminLayout
 title="Yeni Yazı"
 subtitle="Yeni bir blog yazısı oluşturun"
 seo={{ title: 'Yeni Yazı - Yönetim Paneli', noIndex: true }}
>
 <div class="sf-container py-8 max-w-4xl">
 <div class="mb-6 flex items-center justify-between">
 <a href="/admin/blog/posts" class="text-sm text-[#7A6B58] hover:text-[#7A6B58]">← Listeye Dön</a>
 </div>

 <form id="post-form" class="space-y-5">
 <div class="bg-[var(--bg-card)] border border-[rgba(184,115,51,0.14)] rounded-sm p-6 space-y-4">
 <div>
 <label class="block text-sm font-medium text-[#7A6B58] mb-1">Başlık</label>
 <input
 type="text"
 name="title"
 required
 class="w-full rounded-sm border border-[rgba(184,115,51,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
 placeholder="Yazı başlığı..."
 />
 </div>

 <div>
 <label class="block text-sm font-medium text-[#7A6B58] mb-1">URL (Slug)</label>
 <input
 type="text"
 name="slug"
 required
 class="w-full rounded-sm border border-[rgba(184,115,51,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
 placeholder="ornek-yazi-url"
 />
 <p class="text-xs text-[#7A6B58] mt-1">SEO dostu URL. Örn: sanliurfa-rehberi</p>
 </div>

 <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
 <div>
 <label class="block text-sm font-medium text-[#7A6B58] mb-1">Kategori</label>
 <select name="category_id" class="w-full rounded-sm border border-[rgba(184,115,51,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400">
 <option value="">Kategori Seçin</option>
 {categories.map(cat => (
 <option value={cat.id}>{cat.name}</option>
 ))}
 </select>
 </div>

 <div>
 <label class="block text-sm font-medium text-[#7A6B58] mb-1">Durum</label>
 <select name="status" class="w-full rounded-sm border border-[rgba(184,115,51,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400">
 <option value="draft">Taslak</option>
 <option value="published">Yayınla</option>
 <option value="scheduled">Planla</option>
 </select>
 </div>
 </div>

 <div>
 <label class="block text-sm font-medium text-[#7A6B58] mb-1">Özet</label>
 <textarea
 name="excerpt"
 rows="2"
 class="w-full rounded-sm border border-[rgba(184,115,51,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
 placeholder="Yazının kısa özeti..."
 ></textarea>
 </div>

 <div>
 <label class="block text-sm font-medium text-[#7A6B58] mb-1">İçerik</label>
 <div class="border border-[rgba(184,115,51,0.2)] rounded-sm">
 <div class="flex flex-wrap gap-1 p-2 border-b border-[rgba(184,115,51,0.14)] bg-[rgba(184,115,51,0.04)]">
 <button type="button" onclick="formatText('bold')" class="p-2 hover:bg-[rgba(184,115,51,0.08)] rounded-sm text-sm" title="Kalın"><strong>B</strong></button>
 <button type="button" onclick="formatText('italic')" class="p-2 hover:bg-[rgba(184,115,51,0.08)] rounded-sm text-sm" title="İtalik"><em>I</em></button>
 <button type="button" onclick="formatText('h2')" class="p-2 hover:bg-[rgba(184,115,51,0.08)] rounded-sm text-sm" title="Başlık 2">H2</button>
 <button type="button" onclick="formatText('h3')" class="p-2 hover:bg-[rgba(184,115,51,0.08)] rounded-sm text-sm" title="Başlık 3">H3</button>
 <button type="button" onclick="insertLink()" class="p-2 hover:bg-[rgba(184,115,51,0.08)] rounded-sm text-sm" title="Link">🔗</button>
 <button type="button" onclick="insertImage()" class="p-2 hover:bg-[rgba(184,115,51,0.08)] rounded-sm text-sm" title="Görsel">🖼️</button>
 <button type="button" onclick="formatText('ul')" class="p-2 hover:bg-[rgba(184,115,51,0.08)] rounded-sm text-sm" title="Liste">• Liste</button>
 <button type="button" onclick="formatText('ol')" class="p-2 hover:bg-[rgba(184,115,51,0.08)] rounded-sm text-sm" title="Numaralı Liste">1. Liste</button>
 </div>

 <textarea
 id="content"
 name="content"
 rows="20"
 required
 class="w-full px-3 py-2 focus:outline-none border-0"
 placeholder="Yazı içeriğini buraya yazın... Markdown formatı desteklenir."
 ></textarea>
 </div>
 </div>

 <div>
 <label class="block text-sm font-medium text-[#7A6B58] mb-1">Öne Çıkan Görsel</label>
 <div class="flex flex-wrap items-start gap-3">
  <div class="flex-1 min-w-[240px] space-y-2">
   <input
    type="url"
    name="featured_image"
    id="featured_image_url"
    class="w-full rounded-sm border border-[rgba(184,115,51,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
    placeholder="https://... veya yükleyin"
   />
   <p class="text-xs text-[#9B8A75]">URL elle yazabilir veya alttaki butonla dosya yükleyebilirsiniz (JPEG/PNG/WebP, maks 5MB).</p>
  </div>
  <div class="space-y-2">
   <label class="inline-flex items-center cursor-pointer rounded-sm bg-urfa-600 px-4 py-2 text-sm font-semibold text-white hover:bg-urfa-700 transition">
    <input type="file" id="featured_image_file" accept="image/jpeg,image/png,image/webp" class="hidden" />
    📷 Dosya Yükle
   </label>
   <p id="featured_image_status" class="text-xs text-[#7A6B58] hidden"></p>
  </div>
  <img id="featured_image_preview" src="" alt="Önizleme" class="hidden h-20 w-32 rounded-sm border border-[rgba(184,115,51,0.2)] object-cover" />
 </div>
 </div>

 <script is:inline>
  (function() {
   const fileInput = document.getElementById('featured_image_file');
   const urlInput = document.getElementById('featured_image_url');
   const preview = document.getElementById('featured_image_preview');
   const status = document.getElementById('featured_image_status');
   if (!fileInput || !urlInput || !preview || !status) return;

   urlInput.addEventListener('input', () => {
    if (urlInput.value) { preview.src = urlInput.value; preview.classList.remove('hidden'); }
    else { preview.classList.add('hidden'); }
   });

   fileInput.addEventListener('change', async (e) => {
    const file = e.target.files && e.target.files[0];
    if (!file) return;
    if (file.size > 5 * 1024 * 1024) {
     status.textContent = '✗ Maksimum 5MB';
     status.className = 'text-xs text-red-600';
     status.classList.remove('hidden');
     fileInput.value = '';
     return;
    }
    status.textContent = '⏳ Yükleniyor...';
    status.className = 'text-xs text-[#7A6B58]';
    status.classList.remove('hidden');
    const fd = new FormData();
    fd.append('file', file);
    try {
     const res = await fetch('/api/admin/blog/upload', { method: 'POST', body: fd });
     const data = await res.json();
     if (!res.ok || !data?.data?.url) throw new Error(data?.detail || data?.error || 'Yükleme başarısız');
     urlInput.value = data.data.url;
     preview.src = data.data.url;
     preview.classList.remove('hidden');
     status.textContent = '✓ Yüklendi';
     status.className = 'text-xs text-green-700';
    } catch (err) {
     status.textContent = '✗ ' + (err instanceof Error ? err.message : 'Hata');
     status.className = 'text-xs text-red-600';
    }
   });
  })();
 </script>

 <div>
 <label class="block text-sm font-medium text-[#7A6B58] mb-1">Etiketler</label>
 <div class="flex flex-wrap gap-2">
 {tags.map(tag => (
 <label class="inline-flex items-center px-3 py-1 bg-[rgba(184,115,51,0.08)] rounded-sm cursor-pointer hover:bg-[rgba(184,115,51,0.15)]">
 <input type="checkbox" name="tag_ids" value={tag.id} class="mr-2" />
 <span class="text-sm text-[#7A6B58]">{tag.name}</span>
 </label>
 ))}
 </div>
 </div>
 </div>

 <div class="bg-[var(--bg-card)] border border-[rgba(184,115,51,0.14)] rounded-sm p-6 space-y-4">
 <h3 class="font-medium text-[#1F1410]">SEO Ayarları</h3>

 <div>
 <label class="block text-sm font-medium text-[#7A6B58] mb-1">Meta Başlık</label>
 <input
 type="text"
 name="meta_title"
 class="w-full rounded-sm border border-[rgba(184,115,51,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
 placeholder="SEO başlığı (boş bırakılırsa yazı başlığı kullanılır)"
 />
 </div>

 <div>
 <label class="block text-sm font-medium text-[#7A6B58] mb-1">Meta Açıklama</label>
 <textarea
 name="meta_description"
 rows="2"
 class="w-full rounded-sm border border-[rgba(184,115,51,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"
 placeholder="SEO açıklaması..."
 ></textarea>
 </div>
 </div>

 <div class="flex gap-4">
 <label class="inline-flex items-center">
 <input type="checkbox" name="is_featured" class="mr-2" />
 <span class="text-sm text-[#7A6B58]">Öne Çıkan Yazı</span>
 </label>
 <label class="inline-flex items-center">
 <input type="checkbox" name="is_pinned" class="mr-2" />
 <span class="text-sm text-[#7A6B58]">Sabitle</span>
 </label>
 </div>

 <div class="flex gap-4">
 <button type="submit" class="rounded-sm bg-urfa-600 px-6 py-2 text-sm font-semibold text-white hover:bg-urfa-700">
 Kaydet
 </button>
 <a href="/admin/blog/posts" class="rounded-sm border border-[rgba(184,115,51,0.2)] px-6 py-2 text-sm text-[#7A6B58] hover:bg-[rgba(184,115,51,0.04)]">
 İptal
 </a>
 </div>
 </form>
 </div>

 <script>
 document.querySelector('input[name="title"]')?.addEventListener('input', (e) => {
 const title = (e.target as HTMLInputElement).value;
 const slugInput = document.querySelector('input[name="slug"]') as HTMLInputElement;
 if (slugInput && !slugInput.dataset.edited) {
 slugInput.value = title
 .toLowerCase()
 .replace(/ğ/g, 'g').replace(/ü/g, 'u').replace(/ş/g, 's')
 .replace(/ı/g, 'i').replace(/ö/g, 'o').replace(/ç/g, 'c')
 .replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
 }
 });

 document.querySelector('input[name="slug"]')?.addEventListener('input', (e) => {
 (e.target as HTMLInputElement).dataset.edited = 'true';
 });

 function formatText(command: string) {
 const textarea = document.getElementById('content') as HTMLTextAreaElement;
 const start = textarea.selectionStart;
 const end = textarea.selectionEnd;
 const text = textarea.value;
 const selected = text.substring(start, end);

 let formatted = '';
 switch(command) {
 case 'bold': formatted = `**${selected}**`; break;
 case 'italic': formatted = `*${selected}*`; break;
 case 'h2': formatted = `\n## ${selected}\n`; break;
 case 'h3': formatted = `\n### ${selected}\n`; break;
 case 'ul': formatted = selected.split('\n').map(l => `- ${l}`).join('\n'); break;
 case 'ol': formatted = selected.split('\n').map((l, i) => `${i + 1}. ${l}`).join('\n'); break;
 }

 textarea.value = text.substring(0, start) + formatted + text.substring(end);
 textarea.focus();
 textarea.setSelectionRange(start + formatted.length, start + formatted.length);
 }

 async function insertLink() {
 if (!window.promptInput) return;
 const url = await window.promptInput('Link URL:');
 if (url) {
 const textarea = document.getElementById('content') as HTMLTextAreaElement;
 const start = textarea.selectionStart;
 textarea.value = textarea.value.substring(0, start) + `[](${url})` + textarea.value.substring(start);
 }
 }

 async function insertImage() {
 if (!window.promptInput) return;
 const url = await window.promptInput('Görsel URL:');
 if (url) {
 const textarea = document.getElementById('content') as HTMLTextAreaElement;
 const start = textarea.selectionStart;
 textarea.value = textarea.value.substring(0, start) + `\n![Görsel](${url})\n` + textarea.value.substring(start);
 }
 }

 document.getElementById('post-form')?.addEventListener('submit', async (e) => {
 e.preventDefault();

 const formData = new FormData(e.target as HTMLFormElement);
 const data = {
 title: formData.get('title'),
 slug: formData.get('slug'),
 excerpt: formData.get('excerpt'),
 content: formData.get('content'),
 category_id: formData.get('category_id') || null,
 status: formData.get('status'),
 featured_image: formData.get('featured_image'),
 meta_title: formData.get('meta_title'),
 meta_description: formData.get('meta_description'),
 is_featured: formData.has('is_featured'),
 is_pinned: formData.has('is_pinned'),
 tag_ids: Array.from(formData.getAll('tag_ids')),
 };

 try {
 const response = await fetch('/api/admin/blog', {
 method: 'POST',
 headers: { 'Content-Type': 'application/json' },
 body: JSON.stringify(data),
 });

 const result = await response.json();

 if (result.success) {
 window.location.href = '/admin/blog/posts';
 } else {
 window.toast?.error('Hata: ' + (result.error || 'Kaydedilemedi'));
 }
 } catch (error) {
 window.toast?.error('Bir hata oluştu');
 }
 });
 (window as any).formatText = formatText;
 (window as any).insertLink = insertLink;
 (window as any).insertImage = insertImage;
 </script>
</AdminLayout>
