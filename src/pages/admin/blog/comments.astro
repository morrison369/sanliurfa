---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { queryMany, queryOne } from '../../../lib/postgres';
import { logger } from '../../../lib/logging';

type CommentStatus = 'pending' | 'approved' | 'rejected';

interface CommentStatsRow {
 pending: string | number;
 approved: string | number;
 rejected: string | number;
}

interface BlogCommentModerationRow {
 id: string | number;
 author_name: string | null;
 author_email: string | null;
 content: string;
 created_at: string | Date;
 status: CommentStatus;
 post_title: string;
 slug: string;
}

const isCommentStatus = (value: string | null): value is CommentStatus =>
 value === 'pending' || value === 'approved' || value === 'rejected';

const requestedStatus = Astro.url.searchParams.get('status');
const status: CommentStatus = isCommentStatus(requestedStatus) ? requestedStatus : 'pending';
const limit = 20;
const offset = 0;

let comments: BlogCommentModerationRow[] = [];
let stats = { pending: 0, approved: 0, rejected: 0 };
let error = '';

try {
 const [statsResult, result] = await Promise.all([
 queryOne<CommentStatsRow>(`
 SELECT
 COUNT(*) FILTER (WHERE status = 'pending') as pending,
 COUNT(*) FILTER (WHERE status = 'approved') as approved,
 COUNT(*) FILTER (WHERE status = 'rejected') as rejected
 FROM blog_comments
 `),
 queryMany<BlogCommentModerationRow>(`
 SELECT bc.*, bp.title as post_title, bp.slug
 FROM blog_comments bc
 JOIN blog_posts bp ON bc.post_id = bp.id
 WHERE bc.status = $1
 ORDER BY bc.created_at DESC
 LIMIT $2 OFFSET $3
 `, [status, limit, offset]),
 ]);

 if (statsResult) {
 stats = {
 pending: Number(statsResult.pending || 0),
 approved: Number(statsResult.approved || 0),
 rejected: Number(statsResult.rejected || 0)
 };
 }
 comments = result;
} catch (err) {
 error = 'Yorumlar yüklenirken hata oluştu';
 logger.error('Comments moderation error', err instanceof Error ? err : new Error(String(err)));
}

---

<AdminLayout
 title="Yorum Moderasyonu"
 subtitle="Blog yazılarının yorumlarını onayla, reddet veya sil"
 seo={{ title: 'Yorum Moderasyonu - Yönetim Paneli', noIndex: true }}
>
 <div class="sf-container py-8 max-w-6xl space-y-5">
 <div class="mb-2">
 <a href="/admin/blog" class="text-sm text-[#7A6B58] hover:text-[#7A6B58]">← Blog Yönetimi</a>
 </div>

 {error && (
 <div class="rounded-sm border border-[rgba(184,115,51,0.2)] bg-[rgba(184,115,51,0.06)] px-4 py-3 text-sm text-[#7A6B58]">
 {error}
 </div>
 )}

 <div class="grid grid-cols-3 gap-4">
 <a
 href="/admin/blog/comments?status=pending"
 class={`p-4 rounded-sm border-2 transition-all ${
 status === 'pending'
 ? 'border-[rgba(184,115,51,0.5)] bg-[rgba(184,115,51,0.08)]'
 : 'border-[rgba(184,115,51,0.14)] hover:border-[rgba(184,115,51,0.35)]'
 }`}
 >
 <p class="text-sm text-[#7A6B58]">Onay Beklemede</p>
 <p class="text-3xl font-bold text-[#7A6B58]">{stats.pending}</p>
 </a>

 <a
 href="/admin/blog/comments?status=approved"
 class={`p-4 rounded-sm border-2 transition-all ${
 status === 'approved'
 ? 'border-[rgba(184,115,51,0.5)] bg-[rgba(184,115,51,0.08)]'
 : 'border-[rgba(184,115,51,0.14)] hover:border-[rgba(184,115,51,0.35)]'
 }`}
 >
 <p class="text-sm text-[#7A6B58]">Onaylı</p>
 <p class="text-3xl font-bold text-[#7A6B58]">{stats.approved}</p>
 </a>

 <a
 href="/admin/blog/comments?status=rejected"
 class={`p-4 rounded-sm border-2 transition-all ${
 status === 'rejected'
 ? 'border-[rgba(184,115,51,0.5)] bg-[rgba(184,115,51,0.08)]'
 : 'border-[rgba(184,115,51,0.14)] hover:border-[rgba(184,115,51,0.35)]'
 }`}
 >
 <p class="text-sm text-[#7A6B58]">Reddedildi</p>
 <p class="text-3xl font-bold text-[#7A6B58]">{stats.rejected}</p>
 </a>
 </div>

 <div class="bg-[var(--bg-card)] border border-[rgba(184,115,51,0.14)] rounded-sm overflow-hidden">
 {comments.length > 0 ? (
 <div class="divide-y divide-[rgba(184,115,51,0.08)]">
 {comments.map((comment) => (
 <div class="p-6 hover:bg-[rgba(184,115,51,0.04)] transition-colors">
 <div class="flex items-start justify-between mb-3">
 <div>
 <h4 class="font-semibold text-[#1F1410]">
 {comment.author_name}
 </h4>
 <p class="text-sm text-[#7A6B58]">
 {comment.author_email && `${comment.author_email} • `}
 {new Date(comment.created_at).toLocaleDateString('tr-TR')}
 </p>
 </div>
 <div class="flex items-center gap-2">
 {status === 'pending' && (
 <>
 <button
 onclick={`approveComment(${comment.id})`}
 class="px-3 py-1 bg-[rgba(184,115,51,0.15)] text-[#7A6B58] rounded-sm text-sm hover:bg-[rgba(184,115,51,0.25)]"
 >
 ✓ Onayla
 </button>
 <button
 onclick={`rejectComment(${comment.id})`}
 class="px-3 py-1 bg-[rgba(184,115,51,0.08)] text-[#7A6B58] rounded-sm text-sm hover:bg-[rgba(184,115,51,0.15)]"
 >
 ✗ Reddet
 </button>
 </>
 )}
 <button
 onclick={`deleteComment(${comment.id})`}
 class="px-3 py-1 bg-[rgba(184,115,51,0.06)] text-[#7A6B58] rounded-sm text-sm hover:bg-[rgba(184,115,51,0.12)]"
 >
 Sil
 </button>
 </div>
 </div>

 <p class="text-[#7A6B58] mb-3 line-clamp-3 text-sm">
 {comment.content}
 </p>

 <p class="text-sm text-[#7A6B58]">
 Yazı: <a href={`/blog/${comment.slug}`} target="_blank" rel="noopener" class="text-urfa-600 hover:text-[#7A6B58]">
 {comment.post_title}
 </a>
 </p>

 <div class="mt-3 pt-3 border-t border-[rgba(184,115,51,0.14)]">
 <span class={`inline-block px-2 py-0.5 rounded-sm text-xs font-medium ${
 comment.status === 'approved'
 ? 'bg-[rgba(184,115,51,0.15)] text-[#7A6B58]'
 : comment.status === 'pending'
 ? 'bg-[rgba(184,115,51,0.1)] text-[#7A6B58]'
 : 'bg-[rgba(184,115,51,0.06)] text-[#7A6B58]'
 }`}>
 {comment.status === 'approved' ? '✓ Onaylı' : comment.status === 'pending' ? '⏳ Bekleme' : '✗ Reddedildi'}
 </span>
 </div>
 </div>
 ))}
 </div>
 ) : (
 <div class="p-12 text-center text-sm text-[#7A6B58]">
 {status === 'pending' ? 'Onay bekleyen yorum yok' : `${status} durumunda yorum yok`}
 </div>
 )}
 </div>
 </div>
</AdminLayout>

<script is:inline>
 async function approveComment(id) {
 const response = await fetch(`/api/blog/comments/${id}/approve`, {
 method: 'PATCH',
 headers: { 'Content-Type': 'application/json' }
 });

 if (response.ok) {
 window.toast?.success('Yorum onaylandı');
 window.location.reload();
 } else {
 window.toast?.error('Yorum onaylanırken hata oluştu');
 }
 }

 async function rejectComment(id) {
 const response = await fetch(`/api/blog/comments/${id}/reject`, {
 method: 'PATCH',
 headers: { 'Content-Type': 'application/json' }
 });

 if (response.ok) {
 window.toast?.success('Yorum reddedildi');
 window.location.reload();
 } else {
 window.toast?.error('Yorum reddedilirken hata oluştu');
 }
 }

 async function deleteComment(id) {
 if (!await window.showConfirm('Bu yorumu silmek istediğinize emin misiniz?')) return;

 const response = await fetch(`/api/blog/comments/${id}`, {
 method: 'DELETE'
 });

 if (response.ok) {
 window.toast?.success('Yorum silindi');
 window.location.reload();
 } else {
 window.toast?.error('Yorum silinirken hata oluştu');
 }
 }
 window.approveComment = approveComment;
 window.rejectComment = rejectComment;
 window.deleteComment = deleteComment;
</script>
