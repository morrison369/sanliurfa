---
import Layout from '../../../layouts/Layout.astro';

const seo = {
  title: 'Blog Yonetimi - Admin Panel',
  description: 'Blog yazilarini yonetin',
  noindex: true,
};
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50 pt-20 pb-12">
    <div class="container mx-auto px-4">
      {/* Header */}
      <div class="bg-white rounded-xl shadow-sm p-6 mb-6">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
          <div>
            <h1 class="text-2xl font-bold text-gray-900">Blog Yonetimi</h1>
            <p class="text-gray-500 mt-1">Blog yazilarini olusturun, duzenleyin ve yayinlayin</p>
          </div>
          <a 
            href="/admin/blog/new" 
            class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors inline-flex items-center gap-2"
          >
            <span>+</span> Yeni Yazi
          </a>
        </div>
      </div>

      {/* Filters */}
      <div class="bg-white rounded-xl shadow-sm p-4 mb-6">
        <div class="flex flex-wrap gap-4">
          <input
            type="text"
            id="searchInput"
            placeholder="Yazi ara..."
            class="px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 flex-1 min-w-[200px]"
          />
          <select id="statusFilter" class="px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500">
            <option value="">Tum Durumlar</option>
            <option value="published">Yayinda</option>
            <option value="draft">Taslak</option>
            <option value="scheduled">Zamanlanmis</option>
          </select>
          <button id="searchBtn" class="px-4 py-2 bg-gray-800 text-white rounded-lg hover:bg-gray-900">
            Ara
          </button>
        </div>
      </div>

      {/* Posts Table */}
      <div class="bg-white rounded-xl shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-gray-50 border-b border-gray-200">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Yazi</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Yazar</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Durum</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Istatistikler</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Tarih</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Islemler</th>
              </tr>
            </thead>
            <tbody id="postsTableBody" class="divide-y divide-gray-100">
              <tr>
                <td colspan="6" class="px-6 py-12 text-center text-gray-500">
                  Yukleniyor...
                </td>
              </tr>
            </tbody>
          </table>
        </div>
        
        {/* Pagination */}
        <div class="px-6 py-4 border-t border-gray-200 flex items-center justify-between">
          <div class="text-sm text-gray-500">
            <span id="showingFrom">0</span> - <span id="showingTo">0</span> / <span id="totalCount">0</span>
          </div>
          <div class="flex gap-2" id="pagination"></div>
        </div>
      </div>
    </div>
  </div>

  <script>
    let currentPage = 1;

    const statusLabels = {
      published: { text: 'Yayinda', class: 'bg-green-100 text-green-700' },
      draft: { text: 'Taslak', class: 'bg-gray-100 text-gray-700' },
      scheduled: { text: 'Zamanlanmis', class: 'bg-blue-100 text-blue-700' },
    };

    async function loadPosts() {
      const tbody = document.getElementById('postsTableBody');
      tbody.innerHTML = '<tr><td colspan="6" class="px-6 py-12 text-center text-gray-500">Yukleniyor...</td></tr>';

      const params = new URLSearchParams({ page: currentPage.toString() });
      
      const search = document.getElementById('searchInput').value;
      const status = document.getElementById('statusFilter').value;

      if (search) params.append('search', search);
      if (status) params.append('status', status);

      try {
        const response = await fetch(`/api/blog/admin?${params}`);
        const data = await response.json();

        if (data.success) {
          renderPosts(data.posts);
          updatePagination(data.pagination);
        }
      } catch (err) {
        tbody.innerHTML = '<tr><td colspan="6" class="px-6 py-12 text-center text-red-500">Hata olustu</td></tr>';
      }
    }

    function renderPosts(posts) {
      const tbody = document.getElementById('postsTableBody');
      
      if (posts.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" class="px-6 py-12 text-center text-gray-500">Yazi bulunamadi</td></tr>';
        return;
      }

      tbody.innerHTML = posts.map(post => `
        <tr class="hover:bg-gray-50">
          <td class="px-6 py-4">
            <div class="flex items-center gap-3">
              ${post.cover_image ? `
                <img src="${post.cover_image}" alt="" class="w-12 h-12 rounded-lg object-cover" />
              ` : `
                <div class="w-12 h-12 bg-gray-200 rounded-lg flex items-center justify-center text-gray-400">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
              `}
              <div>
                <div class="font-medium text-gray-900 line-clamp-1">${post.title}</div>
                <div class="text-sm text-gray-500">/${post.slug}</div>
              </div>
            </div>
          </td>
          <td class="px-6 py-4 text-sm text-gray-600">
            ${post.author_name || 'Bilinmiyor'}
          </td>
          <td class="px-6 py-4">
            <span class="px-2 py-1 rounded-full text-xs font-medium ${statusLabels[post.status]?.class || 'bg-gray-100'}">
              ${statusLabels[post.status]?.text || post.status}
            </span>
            ${post.featured ? `<span class="ml-2 px-2 py-0.5 bg-amber-100 text-amber-700 text-xs rounded">One Cikan</span>` : ''}
          </td>
          <td class="px-6 py-4 text-sm text-gray-600">
            <div>${post.like_count || 0} begeni</div>
            <div>${post.comment_count || 0} yorum</div>
          </td>
          <td class="px-6 py-4 text-sm text-gray-500">
            ${post.published_at 
              ? new Date(post.published_at).toLocaleDateString('tr-TR')
              : new Date(post.created_at).toLocaleDateString('tr-TR')
            }
          </td>
          <td class="px-6 py-4">
            <div class="flex gap-2">
              <a href="/admin/blog/edit/${post.id}" class="text-blue-600 hover:text-blue-800 text-sm">Duzenle</a>
              <a href="/blog/${post.slug}" target="_blank" class="text-gray-600 hover:text-gray-800 text-sm">Goruntule</a>
              <button onclick="deletePost('${post.id}')" class="text-red-600 hover:text-red-800 text-sm">Sil</button>
            </div>
          </td>
        </tr>
      `).join('');
    }

    function updatePagination(pagination) {
      document.getElementById('showingFrom').textContent = ((pagination.page - 1) * pagination.limit) + 1;
      document.getElementById('showingTo').textContent = Math.min(pagination.page * pagination.limit, pagination.total);
      document.getElementById('totalCount').textContent = pagination.total;

      const pages = [];
      for (let i = 1; i <= pagination.totalPages; i++) {
        if (i === 1 || i === pagination.totalPages || (i >= pagination.page - 2 && i <= pagination.page + 2)) {
          pages.push(`
            <button onclick="goToPage(${i})" 
              class="px-3 py-1 rounded ${i === pagination.page ? 'bg-red-600 text-white' : 'bg-gray-100 hover:bg-gray-200'}">
              ${i}
            </button>
          `);
        } else if (i === pagination.page - 3 || i === pagination.page + 3) {
          pages.push('<span class="px-2">...</span>');
        }
      }
      document.getElementById('pagination').innerHTML = pages.join('');
    }

    function goToPage(page) {
      currentPage = page;
      loadPosts();
    }

    async function deletePost(id) {
      if (!confirm('Bu yaziyi silmek istediginize emin misiniz?')) return;

      try {
        const response = await fetch(`/api/blog/${id}/admin`, {
          method: 'DELETE'
        });

        if (response.ok) {
          loadPosts();
        } else {
          alert('Silme islemi basarisiz');
        }
      } catch (err) {
        alert('Bir hata olustu');
      }
    }

    document.getElementById('searchBtn').addEventListener('click', () => {
      currentPage = 1;
      loadPosts();
    });

    loadPosts();
  </script>
</Layout>
