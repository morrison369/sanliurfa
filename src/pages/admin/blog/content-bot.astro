---
// Content Bot - Automatic Content Generation
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { requireRole } from '../../../lib/auth';

const auth = await requireRole(Astro.request, 'admin');
if (auth instanceof Response) return auth;
---

<AdminLayout title="İçerik Botu">
  <div class="space-y-6">
    <!-- Header -->
    <div>
      <h1 class="text-2xl font-bold text-gray-900">🤖 İçerik Botu</h1>
      <p class="text-gray-600 mt-1">AI destekli otomatik blog yazısı oluşturucu</p>
    </div>

    <!-- Features -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div class="bg-gradient-to-br from-purple-500 to-purple-600 p-6 rounded-xl text-white">
        <h3 class="font-semibold text-lg mb-2">Mekan İçerikleri</h3>
        <p class="text-purple-100 text-sm">Veritabanındaki mekanlar için otomatik blog yazıları oluştur</p>
      </div>
      
      <div class="bg-gradient-to-br from-blue-500 to-blue-600 p-6 rounded-xl text-white">
        <h3 class="font-semibold text-lg mb-2">Kategori Rehberleri</h3>
        <p class="text-blue-100 text-sm">Restoran, otel, tarihi yerler için kapsamlı rehberler</p>
      </div>
      
      <div class="bg-gradient-to-br from-green-500 to-green-600 p-6 rounded-xl text-white">
        <h3 class="font-semibold text-lg mb-2">SEO Optimizasyonu</h3>
        <p class="text-green-100 text-sm">Otomatik meta başlıklar ve açıklamalar</p>
      </div>
    </div>

    <!-- Generate by Category -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Kategori Rehberi Oluştur</h2>
      <p class="text-gray-600 mb-4">Belirli bir kategori için kapsamlı rehber yazısı oluşturun</p>
      
      <div class="flex flex-wrap gap-3">
        <button onclick="generateCategoryGuide('restoran')" class="px-4 py-2 bg-red-100 text-red-700 rounded-lg hover:bg-red-200 font-medium">
          🍽️ Restoran Rehberi
        </button>
        <button onclick="generateCategoryGuide('otel')" class="px-4 py-2 bg-blue-100 text-blue-700 rounded-lg hover:bg-blue-200 font-medium">
          🏨 Otel Rehberi
        </button>
        <button onclick="generateCategoryGuide('tarihi-yerler')" class="px-4 py-2 bg-amber-100 text-amber-700 rounded-lg hover:bg-amber-200 font-medium">
          🏛️ Tarihi Yerler Rehberi
        </button>
        <button onclick="generateCategoryGuide('cafe')" class="px-4 py-2 bg-orange-100 text-orange-700 rounded-lg hover:bg-orange-200 font-medium">
          ☕ Kafe Rehberi
        </button>
      </div>
      
      <div id="category-result" class="mt-4 hidden">
        <div class="bg-green-50 border border-green-200 rounded-lg p-4">
          <p class="text-green-800 font-medium">✅ İçerik başarıyla oluşturuldu!</p>
          <a id="category-link" href="/admin/blog" class="text-blue-600 hover:underline mt-2 inline-block">Yazıyı görüntüle →</a>
        </div>
      </div>
    </div>

    <!-- Generate for Places -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Mekanlar İçin İçerik Oluştur</h2>
      <p class="text-gray-600 mb-4">İçerik oluşturulmamış mekanlar için otomatik yazılar</p>
      
      <button onclick="loadPlacesWithoutContent()" class="px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700">
        Mekanları Listele
      </button>
      
      <div id="places-container" class="mt-4 hidden">
        <div class="border rounded-lg overflow-hidden">
          <table class="w-full">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-3 text-left text-sm font-medium text-gray-600">
                  <input type="checkbox" id="select-all" onchange="toggleSelectAll()" />
                </th>
                <th class="px-4 py-3 text-left text-sm font-medium text-gray-600">Mekan</th>
                <th class="px-4 py-3 text-left text-sm font-medium text-gray-600">Kategori</th>
              </tr>
            </thead>
            <tbody id="places-list" class="divide-y divide-gray-200">
              <!-- Populated by JS -->
            </tbody>
          </table>
        </div>
        
        <button onclick="generateForSelected()" class="mt-4 px-6 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 disabled:opacity-50" id="generate-btn" disabled>
          Seçili Mekanlar İçin İçerik Oluştur
        </button>
      </div>
    </div>

    <!-- Oluşturma geçmişi -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Oluşturma Geçmişi</h2>
      <div id="history-list" class="space-y-3">
        <p class="text-gray-500 text-center py-4">Yükleniyor...</p>
      </div>
    </div>
  </div>

  <script is:inline>
    let placesWithoutContent = [];
    let selectedPlaces = new Set();

    // Kategori rehberi oluştur
    async function generateCategoryGuide(category) {
      const resultDiv = document.getElementById('category-result');
      resultDiv.classList.add('hidden');
      
      try {
        const response = await fetch('/api/admin/content-bot/generate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: 'category-guide', category })
        });
        
        const data = await response.json();
        
        if (data.success) {
          resultDiv.classList.remove('hidden');
          document.getElementById('category-link').href = `/admin/blog/edit/${data.post.id}`;
          loadHistory();
        } else {
          alert('Hata: ' + data.error);
        }
      } catch (error) {
        alert('Bir hata oluştu');
      }
    }

    // İçeriği olmayan mekanları yükle
    async function loadPlacesWithoutContent() {
      try {
        const response = await fetch('/api/admin/content-bot/generate');
        const data = await response.json();
        
        placesWithoutContent = data.placesWithoutContent || [];
        
        const container = document.getElementById('places-container');
        const list = document.getElementById('places-list');
        
        if (placesWithoutContent.length === 0) {
          list.innerHTML = '<tr><td colspan="3" class="px-4 py-8 text-center text-gray-500">Tüm mekanlar için içerik oluşturulmuş!</td></tr>';
        } else {
          list.innerHTML = placesWithoutContent.map(p => `
            <tr>
              <td class="px-4 py-3">
                <input type="checkbox" value="${p.id}" onchange="togglePlace('${p.id}')" />
              </td>
              <td class="px-4 py-3 font-medium">${p.name}</td>
              <td class="px-4 py-3 text-gray-600">${p.category}</td>
            </tr>
          `).join('');
        }
        
        container.classList.remove('hidden');
      } catch (error) {
        alert('Mekanlar yüklenirken hata oluştu');
      }
    }

    // Mekan seçimini değiştir
    function togglePlace(id) {
      if (selectedPlaces.has(id)) {
        selectedPlaces.delete(id);
      } else {
        selectedPlaces.add(id);
      }
      updateGenerateButton();
    }

    // Tümünü seç/kaldır
    function toggleSelectAll() {
      const checkboxes = document.querySelectorAll('#places-list input[type="checkbox"]');
      const selectAll = document.getElementById('select-all').checked;
      
      checkboxes.forEach(cb => {
        cb.checked = selectAll;
        if (selectAll) {
          selectedPlaces.add(cb.value);
        } else {
          selectedPlaces.delete(cb.value);
        }
      });
      
      updateGenerateButton();
    }

    // Oluşturma butonunu güncelle
    function updateGenerateButton() {
      const btn = document.getElementById('generate-btn');
      btn.disabled = selectedPlaces.size === 0;
      btn.textContent = `Seçili ${selectedPlaces.size} Mekan İçin İçerik Oluştur`;
    }

    // Seçili mekanlar için içerik oluştur
    async function generateForSelected() {
      if (selectedPlaces.size === 0) return;
      
      const btn = document.getElementById('generate-btn');
      btn.disabled = true;
      btn.textContent = 'Oluşturuluyor...';
      
      try {
        const response = await fetch('/api/admin/content-bot/generate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            type: 'places',
            placeIds: Array.from(selectedPlaces)
          })
        });
        
        const data = await response.json();
        
        if (data.success) {
          alert(`${data.generated.filter(g => g.status === 'created').length} yazı oluşturuldu!`);
          selectedPlaces.clear();
          loadPlacesWithoutContent();
          loadHistory();
        } else {
          alert('Hata: ' + data.error);
        }
      } catch (error) {
        alert('Bir hata oluştu');
      } finally {
        updateGenerateButton();
      }
    }

    // Oluşturma geçmişini yükle
    async function loadHistory() {
      try {
        const response = await fetch('/api/admin/content-bot/generate');
        const data = await response.json();
        
        const list = document.getElementById('history-list');
        
        if (data.jobs?.length === 0) {
          list.innerHTML = '<p class="text-gray-500 text-center py-4">Henüz oluşturma işlemi yok</p>';
        } else {
          list.innerHTML = data.jobs.map(job => `
            <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
              <div class="flex items-center gap-3">
                <span class="text-2xl">${job.job_type === 'category-guide' ? '📚' : '📝'}</span>
                <div>
                  <p class="font-medium text-gray-900">${job.job_type === 'category-guide' ? 'Kategori Rehberi' : 'Mekan İçeriği'}</p>
                  <p class="text-sm text-gray-500">${new Date(job.created_at).toLocaleString('tr-TR')}</p>
                </div>
              </div>
              <span class="px-3 py-1 text-xs font-medium rounded-full ${
                job.status === 'completed' ? 'bg-green-100 text-green-800' :
                job.status === 'failed' ? 'bg-red-100 text-red-800' :
                'bg-yellow-100 text-yellow-800'
              }">${
                job.status === 'completed' ? 'Tamamlandı' :
                job.status === 'failed' ? 'Başarısız' :
                job.status === 'running' ? 'Çalışıyor' :
                job.status === 'queued' ? 'Sırada' :
                'Beklemede'
              }</span>
            </div>
          `).join('');
        }
      } catch (error) {
        console.error('Oluşturma geçmişi yüklenemedi:', error);
      }
    }

    // Sayfa açılışında geçmişi yükle
    window.generateCategoryGuide = generateCategoryGuide;
    window.loadPlacesWithoutContent = loadPlacesWithoutContent;
    window.togglePlace = togglePlace;
    window.toggleSelectAll = toggleSelectAll;
    window.generateForSelected = generateForSelected;
    loadHistory();
  </script>
</AdminLayout>
