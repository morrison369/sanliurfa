---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getBlogCategories } from '../../../lib/blog/blog';

const categories = await getBlogCategories();
---

<AdminLayout
 title="Yeni Blog Yazısı"
 subtitle="Yeni bir blog yazısı oluşturun"
 seo={{ title: 'Yeni Blog Yazısı - Yönetim Paneli', noIndex: true }}
>
 <div class="sf-container py-8 max-w-4xl space-y-5">
 <div class="mb-2">
 <a href="/admin/blog" class="text-sm text-[#7A6B58] hover:text-[#7A6B58]">← Blog Yönetimi</a>
 </div>

 <form id="blogForm" class="space-y-5">
 <div class="bg-[var(--bg-card)] border border-[rgba(184,115,51,0.14)] rounded-sm p-6 space-y-4">
 <div>
 <label for="title" class="block text-sm font-medium text-[#7A6B58] mb-1">Başlık</label>
 <input type="text" id="title" name="title" required class="w-full rounded-sm border border-[rgba(184,115,51,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400" />
 </div>

 <div>
 <label for="content" class="block text-sm font-medium text-[#7A6B58] mb-1">İçerik</label>
 <textarea id="content" name="content" rows="10" required class="w-full rounded-sm border border-[rgba(184,115,51,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"></textarea>
 </div>

 <div>
 <label for="excerpt" class="block text-sm font-medium text-[#7A6B58] mb-1">Özet</label>
 <textarea id="excerpt" name="excerpt" rows="3" class="w-full rounded-sm border border-[rgba(184,115,51,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400"></textarea>
 </div>

 <div class="grid md:grid-cols-2 gap-4">
 <div>
 <label for="categoryId" class="block text-sm font-medium text-[#7A6B58] mb-1">Kategori</label>
 <select id="categoryId" name="categoryId" class="w-full rounded-sm border border-[rgba(184,115,51,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400">
 <option value="">Seçiniz</option>
 {categories.map(cat => (
 <option value={cat.id}>{cat.name}</option>
 ))}
 </select>
 </div>

 <div>
 <label for="status" class="block text-sm font-medium text-[#7A6B58] mb-1">Durum</label>
 <select id="status" name="status" class="w-full rounded-sm border border-[rgba(184,115,51,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400">
 <option value="draft">Taslak</option>
 <option value="published">Yayınla</option>
 </select>
 </div>
 </div>
 </div>

 <div class="flex justify-end gap-4">
 <button type="button" onclick="history.back()" class="rounded-sm border border-[rgba(184,115,51,0.2)] px-4 py-2 text-sm text-[#7A6B58] hover:bg-[rgba(184,115,51,0.04)]">İptal</button>
 <button type="submit" class="rounded-sm bg-urfa-600 px-4 py-2 text-sm font-semibold text-white hover:bg-urfa-700">Kaydet</button>
 </div>
 </form>
 </div>

 <script is:inline>
 const form = document.getElementById('blogForm');
 if (form) {
 form.addEventListener('submit', async (e) => {
 e.preventDefault();

 const formData = new FormData(form);
 const data = {
 title: formData.get('title'),
 content: formData.get('content'),
 excerpt: formData.get('excerpt'),
 categoryId: formData.get('categoryId') ? parseInt(String(formData.get('categoryId'))) : null,
 status: formData.get('status') || 'draft'
 };

 try {
 const response = await fetch('/api/blog/posts', {
 method: 'POST',
 headers: { 'Content-Type': 'application/json' },
 body: JSON.stringify(data)
 });

 const result = await response.json();

 if (result.success) {
 window.location.href = '/admin/blog';
 } else {
 window.toast?.error(result.error || 'Bir hata oluştu');
 }
 } catch (error) {
 window.toast?.error('Bağlantı hatası');
 }
 });
 }
 </script>
</AdminLayout>
