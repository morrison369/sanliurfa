---
import { actions } from 'astro:actions';
import { Icon } from 'astro-icon/components';
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { query } from '../../../lib/postgres';
import { logger } from '../../../lib/logging';

interface AdminEventRow {
 id: string;
 title: string;
 slug: string;
 category: string;
 start_date: string | Date;
 end_date?: string | Date | null;
 location: string;
 status: string;
 is_featured?: boolean | null;
}

interface EventStats {
 total: string | number;
 upcoming: string | number;
 draft: string | number;
}

let events: AdminEventRow[] = [];
let stats: EventStats = { total: 0, upcoming: 0, draft: 0 };

const deleteResult = Astro.getActionResult(actions.deleteAdminEvent);

try {
 const [eventsResult, statsResult] = await Promise.all([
 query(
 `SELECT * FROM events ORDER BY start_date ASC`
 ),
 query(
 `SELECT
 COUNT(*) as total,
 COUNT(*) FILTER (WHERE start_date > CURRENT_DATE AND status = 'published') as upcoming,
 COUNT(*) FILTER (WHERE status = 'draft') as draft
 FROM events`
 ),
 ]);
 events = eventsResult.rows;
 stats = statsResult.rows[0] || stats;
} catch (e) {
 logger.error('Error loading admin events', e instanceof Error ? e : new Error(String(e)));
}
---

<AdminLayout
 title="Etkinlik Yönetimi"
 subtitle="Etkinlikleri listeleyin ve yönetin"
 seo={{ title: 'Etkinlik Yönetimi - Yönetim Paneli', noIndex: true }}
>
 <a slot="hero-action" href="/admin/events/add" class="rounded-sm bg-urfa-600 px-4 py-2 text-sm font-semibold text-white hover:bg-urfa-700 flex items-center gap-2">
 <Icon name="lucide:plus" class="w-4 h-4" />
 Yeni Etkinlik
 </a>

 <div class="sf-container py-8 max-w-6xl space-y-5">
 <div class="mb-2">
 <a href="/admin" class="text-sm text-[#7A6B58] hover:text-[#7A6B58]">← Admin Paneli</a>
 </div>

 {deleteResult?.data?.success && (
 <div class="rounded-sm border border-[rgba(184,115,51,0.2)] bg-[rgba(184,115,51,0.06)] px-4 py-3 text-sm text-[#7A6B58]">
 {deleteResult.data.message || 'Etkinlik silindi.'}
 </div>
 )}

 {deleteResult?.error && (
 <div class="rounded-sm border border-[rgba(184,115,51,0.2)] bg-[rgba(184,115,51,0.06)] px-4 py-3 text-sm text-[#7A6B58]">
 {deleteResult.error.message || 'Etkinlik silinemedi.'}
 </div>
 )}

 <div class="grid grid-cols-2 lg:grid-cols-3 gap-4">
 <div class="bg-[var(--bg-card)] border border-[rgba(184,115,51,0.14)] rounded-sm p-4">
 <p class="text-sm text-[#7A6B58]">Toplam Etkinlik</p>
 <p class="text-2xl font-bold text-[#1F1410]">{stats.total}</p>
 </div>
 <div class="bg-[var(--bg-card)] border border-[rgba(184,115,51,0.14)] rounded-sm p-4">
 <p class="text-sm text-[#7A6B58]">Yaklaşan</p>
 <p class="text-2xl font-bold text-[#7A6B58]">{stats.upcoming}</p>
 </div>
 <div class="bg-[var(--bg-card)] border border-[rgba(184,115,51,0.14)] rounded-sm p-4">
 <p class="text-sm text-[#7A6B58]">Taslak</p>
 <p class="text-2xl font-bold text-[#7A6B58]">{stats.draft}</p>
 </div>
 </div>

 <div class="bg-[var(--bg-card)] border border-[rgba(184,115,51,0.14)] rounded-sm overflow-hidden">
 <div class="overflow-x-auto">
 <table class="w-full text-sm">
 <thead class="border-b border-[rgba(184,115,51,0.14)] bg-[rgba(184,115,51,0.04)]">
 <tr>
 <th class="text-left py-3 px-4 font-medium text-[#7A6B58]">Etkinlik</th>
 <th class="text-left py-3 px-4 font-medium text-[#7A6B58]">Tarih</th>
 <th class="text-left py-3 px-4 font-medium text-[#7A6B58]">Konum</th>
 <th class="text-left py-3 px-4 font-medium text-[#7A6B58]">Durum</th>
 <th class="text-right py-3 px-4 font-medium text-[#7A6B58]">İşlemler</th>
 </tr>
 </thead>
 <tbody>
 {events.map(event => (
 <tr class="border-b border-[rgba(184,115,51,0.08)] last:border-0 hover:bg-[rgba(184,115,51,0.04)]">
 <td class="py-4 px-4">
 <div class="flex items-start gap-3">
 <div class="w-10 h-10 bg-[rgba(184,115,51,0.1)] rounded-sm flex items-center justify-center flex-shrink-0">
 <Icon name="lucide:calendar" class="w-5 h-5 text-urfa-600" />
 </div>
 <div>
 <p class="font-medium text-[#1F1410] text-sm">{event.title}</p>
 <p class="text-xs text-[#7A6B58]">{event.category}</p>
 {event.is_featured && (
 <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-[rgba(184,115,51,0.1)] text-[#7A6B58] text-xs rounded-sm mt-1">
 ⭐ Öne Çıkan
 </span>
 )}
 </div>
 </div>
 </td>
 <td class="py-4 px-4">
 <div class="text-sm text-[#7A6B58]">
 <div>{new Date(event.start_date).toLocaleDateString('tr-TR')}</div>
 {event.end_date && (
 <div class="text-xs text-[#7A6B58]">
 - {new Date(event.end_date).toLocaleDateString('tr-TR')}
 </div>
 )}
 </div>
 </td>
 <td class="py-4 px-4">
 <div class="flex items-center gap-1 text-sm text-[#7A6B58]">
 <Icon name="lucide:map-pin" class="w-4 h-4" />
 <span class="truncate max-w-[150px]">{event.location}</span>
 </div>
 </td>
 <td class="py-4 px-4">
 <span class={`inline-flex px-2 py-0.5 rounded-sm text-xs font-medium ${
 event.status === 'published'
 ? 'bg-[rgba(184,115,51,0.15)] text-[#7A6B58]'
 : event.status === 'draft'
 ? 'bg-[rgba(184,115,51,0.08)] text-[#7A6B58]'
 : 'bg-[rgba(184,115,51,0.04)] text-[#7A6B58]'
 }`}>
 {event.status === 'published' ? 'Yayında' : event.status === 'draft' ? 'Taslak' : 'İptal'}
 </span>
 </td>
 <td class="py-4 px-4">
 <div class="flex items-center justify-end gap-1">
 <a href={`/etkinlikler/${event.slug}`} target="_blank" rel="noopener" class="p-2 text-[#7A6B58] hover:text-urfa-600 transition-colors" title="Görüntüle">
 <Icon name="lucide:eye" class="w-4 h-4" />
 </a>
 <a href={`/admin/events/edit/${event.id}`} class="p-2 text-[#7A6B58] hover:text-urfa-600 transition-colors" title="Düzenle">
 <Icon name="lucide:pencil" class="w-4 h-4" />
 </a>
 <form method="POST" action={actions.deleteAdminEvent} class="inline" data-confirm="Bu etkinliği silmek istediğinize emin misiniz?">
 <input type="hidden" name="id" value={event.id} />
 <button type="submit" class="p-2 text-[#7A6B58] hover:text-[#7A6B58] transition-colors" title="Sil">
 <Icon name="lucide:trash-2" class="w-4 h-4" />
 </button>
 </form>
 </div>
 </td>
 </tr>
 ))}

 {(!events || events.length === 0) && (
 <tr>
 <td colspan="5" class="py-8 text-center text-[#7A6B58]">
 Henüz etkinlik bulunmuyor.
 <a href="/admin/events/add" class="text-urfa-600 hover:underline ml-1">İlk etkinliği ekle</a>
 </td>
 </tr>
 )}
 </tbody>
 </table>
 </div>
 </div>
 </div>
</AdminLayout>
