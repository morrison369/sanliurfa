---
import { actions } from 'astro:actions';
import { Icon } from 'astro-icon/components';
import AdminLayout from '../../../layouts/AdminLayoutV2.astro';
import AdmStatGrid from '../../../components/admin/AdmStatGrid.astro';
import AdmEmptyState from '../../../components/admin/AdmEmptyState.astro';
import { query } from '../../../lib/postgres';
import { logger } from '../../../lib/logging';

interface AdminEventRow {
 id: string;
 title: string;
 slug: string;
 category: string;
 start_date: string | Date;
 end_date?: string | Date | null;
 location: string;
 status: string;
 is_featured?: boolean | null;
}

interface EventStats {
 total: number;
 upcoming: number;
 draft: number;
 published: number;
}

let events: AdminEventRow[] = [];
let stats: EventStats = { total: 0, upcoming: 0, draft: 0, published: 0 };

const deleteResult = Astro.getActionResult(actions.deleteAdminEvent);

try {
 const [eventsResult, statsResult] = await Promise.all([
  query<AdminEventRow>(`SELECT * FROM events ORDER BY start_date ASC`),
  query<EventStats>(
   `SELECT
     COUNT(*)::int as total,
     COUNT(*) FILTER (WHERE start_date > CURRENT_DATE AND status = 'published')::int as upcoming,
     COUNT(*) FILTER (WHERE status = 'draft')::int as draft,
     COUNT(*) FILTER (WHERE status = 'published')::int as published
    FROM events`
  ),
 ]);
 events = eventsResult.rows;
 stats = statsResult.rows[0] || stats;
} catch (e) {
 logger.error('Error loading admin events', e instanceof Error ? e : new Error(String(e)));
}

const statusLabels: Record<string, { text: string; cls: string }> = {
 published: { text: 'Yayında', cls: 'ev-badge--ok' },
 draft:     { text: 'Taslak',  cls: 'ev-badge--muted' },
 cancelled: { text: 'İptal',   cls: 'ev-badge--err' },
};
---

<AdminLayout
 title="Etkinlik Yönetimi"
 subtitle={`${stats.total.toLocaleString('tr-TR')} etkinlik • ${stats.upcoming} yaklaşan`}
 seo={{ title: 'Etkinlik Yönetimi - Yönetim Paneli', noIndex: true }}
>
 <a slot="page-actions" href="/admin/events/add" class="ev-cta">
  <Icon name="lucide:plus" class="w-4 h-4" /> Yeni Etkinlik
 </a>

 <div class="ev-page">
  <AdmStatGrid stats={[
   { label: 'Toplam Etkinlik', value: stats.total, icon: 'lucide:calendar', color: 'indigo' },
   { label: 'Yayında', value: stats.published, icon: 'lucide:check-circle', color: 'emerald' },
   { label: 'Yaklaşan', value: stats.upcoming, icon: 'lucide:calendar-clock', color: 'amber' },
   { label: 'Taslak', value: stats.draft, icon: 'lucide:pencil-line', color: 'slate' },
  ]} />

  {deleteResult?.data?.success && (
   <div class="ev-toast ev-toast--ok">
    <Icon name="lucide:check-circle" class="w-4 h-4" />
    {deleteResult.data.message || 'Etkinlik silindi.'}
   </div>
  )}
  {deleteResult?.error && (
   <div class="ev-toast ev-toast--err">
    <Icon name="lucide:alert-circle" class="w-4 h-4" />
    {deleteResult.error.message || 'Etkinlik silinemedi.'}
   </div>
  )}

  <div class="ev-table-wrap">
   {!events || events.length === 0 ? (
    <AdmEmptyState
     icon="lucide:calendar-x"
     title="Henüz etkinlik yok"
     description="Şanlıurfa'da gerçekleşecek etkinlikleri buraya ekleyebilirsiniz."
     actionLabel="İlk Etkinliği Ekle"
     actionHref="/admin/events/add"
     size="md"
    />
   ) : (
    <table class="ev-table">
     <thead>
      <tr>
       <th class="ev-th">Etkinlik</th>
       <th class="ev-th">Tarih</th>
       <th class="ev-th">Konum</th>
       <th class="ev-th">Durum</th>
       <th class="ev-th ev-th-actions">İşlemler</th>
      </tr>
     </thead>
     <tbody>
      {events.map(event => {
       const meta = statusLabels[event.status] || { text: event.status, cls: 'ev-badge--muted' };
       const startDate = new Date(event.start_date);
       const isPast = startDate.getTime() < Date.now();
       return (
        <tr>
         <td class="ev-td">
          <div class="ev-event-cell">
           <div class="ev-event-icon" aria-hidden="true">
            <Icon name="lucide:calendar" class="w-5 h-5" />
           </div>
           <div class="ev-event-info">
            <div class="ev-event-title">{event.title}</div>
            <div class="ev-event-meta">
             <span>{event.category}</span>
             {event.is_featured && (
              <span class="ev-featured">
               <Icon name="lucide:star" class="w-3 h-3" /> Öne Çıkan
              </span>
             )}
            </div>
           </div>
          </div>
         </td>
         <td class="ev-td">
          <div class:list={['ev-date', isPast && 'ev-date--past']}>
           <Icon name="lucide:calendar" class="w-3 h-3" />
           {startDate.toLocaleDateString('tr-TR', { day: '2-digit', month: 'short', year: 'numeric' })}
          </div>
          {event.end_date && (
           <div class="ev-date-end">
            → {new Date(event.end_date).toLocaleDateString('tr-TR', { day: '2-digit', month: 'short' })}
           </div>
          )}
         </td>
         <td class="ev-td">
          <div class="ev-location">
           <Icon name="lucide:map-pin" class="w-3.5 h-3.5" />
           <span>{event.location || '—'}</span>
          </div>
         </td>
         <td class="ev-td">
          <span class:list={['ev-badge', meta.cls]}>{meta.text}</span>
         </td>
         <td class="ev-td ev-td-actions">
          <a href={`/etkinlikler/${event.slug}`} target="_blank" rel="noopener" class="ev-icon-btn" title="Görüntüle" aria-label="Görüntüle">
           <Icon name="lucide:eye" class="w-4 h-4" />
          </a>
          <a href={`/admin/events/edit/${event.id}`} class="ev-icon-btn" title="Düzenle" aria-label="Düzenle">
           <Icon name="lucide:pencil" class="w-4 h-4" />
          </a>
          <form method="POST" action={actions.deleteAdminEvent} class="ev-form-inline" data-confirm="Bu etkinliği silmek istediğinize emin misiniz?">
           <input type="hidden" name="id" value={event.id} />
           <button type="submit" class="ev-icon-btn ev-icon-btn--danger" title="Sil" aria-label="Sil">
            <Icon name="lucide:trash-2" class="w-4 h-4" />
           </button>
          </form>
         </td>
        </tr>
       );
      })}
     </tbody>
    </table>
   )}
  </div>
 </div>

 <style>
  .ev-page { display: flex; flex-direction: column; gap: 1.25rem; }

  .ev-cta {
   display: inline-flex; align-items: center; gap: 0.4rem;
   padding: 0.55rem 1.1rem;
   background: linear-gradient(135deg, var(--adm-accent), var(--adm-warning));
   color: #fff; font-weight: 600; font-size: 0.85rem;
   border-radius: 8px; text-decoration: none;
   transition: transform 0.15s;
  }
  .ev-cta:hover { transform: translateY(-1px); box-shadow: var(--adm-shadow); }

  .ev-toast {
   display: flex; align-items: center; gap: 0.55rem;
   padding: 0.7rem 1rem;
   border-radius: 10px;
   font-size: 0.86rem; font-weight: 500;
  }
  .ev-toast--ok { background: rgba(16,185,129,0.08); color: rgb(5,150,105); border: 1px solid rgba(16,185,129,0.18); }
  .ev-toast--err { background: rgba(225,29,72,0.08); color: rgb(190,18,60); border: 1px solid rgba(225,29,72,0.18); }

  .ev-table-wrap {
   overflow-x: auto;
   background: var(--adm-bg-elev);
   border: 1px solid var(--adm-border);
   border-radius: 12px;
  }
  .ev-table { width: 100%; border-collapse: collapse; }
  .ev-th {
   text-align: left;
   font-size: 0.7rem;
   font-weight: 700;
   letter-spacing: 0.06em;
   text-transform: uppercase;
   color: var(--adm-text-soft);
   padding: 0.85rem 1rem;
   background: var(--adm-bg-hover);
   border-bottom: 1px solid var(--adm-border);
  }
  .ev-th-actions { text-align: right; width: 160px; }
  .ev-table tbody tr {
   border-bottom: 1px solid var(--adm-border);
  }
  .ev-table tbody tr:last-child { border-bottom: none; }
  .ev-table tbody tr:hover { background: var(--adm-bg-hover); }
  .ev-td { padding: 0.85rem 1rem; font-size: 0.86rem; color: var(--adm-text); vertical-align: middle; }
  .ev-td-actions { text-align: right; white-space: nowrap; }

  .ev-event-cell { display: flex; align-items: center; gap: 0.75rem; }
  .ev-event-icon {
   width: 40px; height: 40px;
   background: var(--adm-bg-active);
   color: var(--adm-accent);
   border-radius: 10px;
   display: inline-flex; align-items: center; justify-content: center;
   flex-shrink: 0;
  }
  .ev-event-title {
   font-weight: 600;
   color: var(--adm-text);
   line-height: 1.3;
   margin-bottom: 0.2rem;
  }
  .ev-event-meta {
   display: flex; align-items: center; gap: 0.4rem;
   font-size: 0.72rem;
   color: var(--adm-text-soft);
  }
  .ev-featured {
   display: inline-flex; align-items: center; gap: 0.2rem;
   padding: 0.15rem 0.45rem;
   background: rgba(217,119,6,0.12);
   color: rgb(180,83,9);
   border-radius: 999px;
   font-size: 0.68rem;
   font-weight: 700;
  }

  .ev-date {
   display: inline-flex; align-items: center; gap: 0.3rem;
   font-weight: 600;
   color: var(--adm-text);
  }
  .ev-date--past { color: var(--adm-text-soft); }
  .ev-date-end {
   font-size: 0.76rem;
   color: var(--adm-text-soft);
   margin-top: 0.15rem;
   padding-left: 1rem;
  }

  .ev-location {
   display: inline-flex; align-items: center; gap: 0.3rem;
   color: var(--adm-text-muted);
   max-width: 200px;
  }
  .ev-location span {
   overflow: hidden;
   text-overflow: ellipsis;
   white-space: nowrap;
  }

  .ev-badge {
   display: inline-flex; align-items: center;
   padding: 0.22rem 0.6rem;
   font-size: 0.72rem; font-weight: 600;
   border-radius: 999px;
  }
  .ev-badge--ok    { background: rgba(16,185,129,0.12); color: rgb(5,150,105); }
  .ev-badge--muted { background: rgba(100,116,139,0.12); color: rgb(71,85,105); }
  .ev-badge--err   { background: rgba(225,29,72,0.12); color: rgb(190,18,60); }

  .ev-icon-btn {
   display: inline-flex; align-items: center; justify-content: center;
   width: 32px; height: 32px;
   color: var(--adm-text-soft);
   background: transparent;
   border: 1px solid var(--adm-border);
   border-radius: 6px;
   text-decoration: none;
   margin-left: 0.25rem;
   cursor: pointer;
   transition: all 0.15s;
  }
  .ev-icon-btn:hover { border-color: var(--adm-accent); color: var(--adm-accent); }
  .ev-icon-btn--danger:hover { border-color: rgb(190,18,60); color: rgb(190,18,60); background: rgba(225,29,72,0.06); }

  .ev-form-inline { display: inline; }
 </style>
</AdminLayout>
