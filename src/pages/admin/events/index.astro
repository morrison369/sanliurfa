---
import { actions } from 'astro:actions';
import Layout from '../../../layouts/Layout.astro';
import { query } from '../../../lib/postgres';

interface AdminEventRow {
  id: string;
  title: string;
  slug: string;
  category: string;
  start_date: string | Date;
  end_date?: string | Date | null;
  location: string;
  status: string;
  is_featured?: boolean | null;
}

interface EventStats {
  total: string | number;
  upcoming: string | number;
  draft: string | number;
}

const icons = {
  calendar: `<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>`,
  plus: `<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>`,
  edit: `<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.375 2.625a1 1 0 0 1 3 3l-9.013 9.014a2 2 0 0 1-.853.505l-2.873.84a.5.5 0 0 1-.62-.62l.84-2.873a2 2 0 0 1 .506-.852z"/></svg>`,
  trash2: `<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>`,
  eye: `<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.72 10.72 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.72 10.72 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/></svg>`,
  mapPin: `<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`,
};

const user = Astro.locals.user;
if (!user || !Astro.locals.isAdmin) {
  return Astro.redirect('/giris?redirect=/admin/events');
}

let events: AdminEventRow[] = [];
let stats: EventStats = {
  total: 0,
  upcoming: 0,
  draft: 0,
};
const seo = {
  title: 'Etkinlik Yönetimi - Yönetim Paneli',
  description: 'Admin etkinlik yönetimi ekranı',
  noIndex: true,
};
const deleteResult = Astro.getActionResult(actions.deleteAdminEvent);

try {

  const eventsResult = await query(
    `SELECT e.*, u.full_name as creator_name 
     FROM events e 
     LEFT JOIN users u ON e.created_by = u.id 
     ORDER BY e.start_date ASC`
  );
  events = eventsResult.rows;

  const statsResult = await query(
    `SELECT 
      COUNT(*) as total,
      COUNT(*) FILTER (WHERE start_date > CURRENT_DATE AND status = 'published') as upcoming,
      COUNT(*) FILTER (WHERE status = 'draft') as draft
     FROM events`
  );
  stats = statsResult.rows[0] || stats;

} catch (e) {
  console.error('Error loading data:', e);
}
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <div class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
      <div class="container-custom py-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <a href="/admin" class="text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white">← Geri</a>
            <h1 class="text-2xl font-display font-bold text-gray-900 dark:text-white">Etkinlik Yönetimi</h1>
          </div>
          <a href="/admin/events/add" class="btn-primary flex items-center gap-2">
            <span set:html={icons.plus}></span>
            Yeni Etkinlik
          </a>
        </div>
      </div>
    </div>
    
    <div class="container-custom py-8">
      {deleteResult?.data?.success && (
        <div class="mb-4 rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700 dark:border-green-800 dark:bg-green-900/20 dark:text-green-300">
          {deleteResult.data.message || 'Etkinlik silindi.'}
        </div>
      )}

      {deleteResult?.error && (
        <div class="mb-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700 dark:border-red-800 dark:bg-red-900/20 dark:text-red-300">
          {deleteResult.error.message || 'Etkinlik silinemedi.'}
        </div>
      )}

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="bg-white dark:bg-gray-800 rounded-xl p-4 border border-gray-200 dark:border-gray-700">
          <p class="text-sm text-gray-600 dark:text-gray-400">Toplam Etkinlik</p>
          <p class="text-2xl font-bold text-gray-900 dark:text-white">{stats.total}</p>
        </div>
        <div class="bg-green-50 dark:bg-green-900/20 rounded-xl p-4 border border-green-200 dark:border-green-800">
          <p class="text-sm text-green-700 dark:text-green-400">Yaklaşan</p>
          <p class="text-2xl font-bold text-green-800 dark:text-green-300">{stats.upcoming}</p>
        </div>
        <div class="bg-yellow-50 dark:bg-yellow-900/20 rounded-xl p-4 border border-yellow-200 dark:border-yellow-800">
          <p class="text-sm text-yellow-700 dark:text-yellow-400">Taslak</p>
          <p class="text-2xl font-bold text-yellow-800 dark:text-yellow-300">{stats.draft}</p>
        </div>
      </div>
      
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-700/50">
                <th class="text-left py-3 px-4 text-sm font-medium text-gray-600 dark:text-gray-400">Etkinlik</th>
                <th class="text-left py-3 px-4 text-sm font-medium text-gray-600 dark:text-gray-400">Tarih</th>
                <th class="text-left py-3 px-4 text-sm font-medium text-gray-600 dark:text-gray-400">Konum</th>
                <th class="text-left py-3 px-4 text-sm font-medium text-gray-600 dark:text-gray-400">Durum</th>
                <th class="text-right py-3 px-4 text-sm font-medium text-gray-600 dark:text-gray-400">İşlemler</th>
              </tr>
            </thead>
            <tbody>
              {events.map(event => (
                <tr class="border-b border-gray-200 dark:border-gray-700 last:border-0 hover:bg-gray-50 dark:hover:bg-gray-700/50">
                  <td class="py-4 px-4">
                    <div class="flex items-start gap-3">
                      <div class="w-10 h-10 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center flex-shrink-0">
                        <span set:html={icons.calendar} class="w-5 h-5 text-purple-600 dark:text-purple-400"></span>
                      </div>
                      <div>
                        <p class="font-medium text-gray-900 dark:text-white text-sm">{event.title}</p>
                        <p class="text-xs text-gray-500 dark:text-gray-400">{event.category}</p>
                        {event.is_featured && (
                          <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-urfa-100 dark:bg-urfa-900/30 text-urfa-700 dark:text-urfa-300 text-xs rounded mt-1">
                            ⭐ Öne Çıkan
                          </span>
                        )}
                      </div>
                    </div>
                  </td>
                  <td class="py-4 px-4">
                    <div class="text-sm text-gray-700 dark:text-gray-300">
                      <div>{new Date(event.start_date).toLocaleDateString('tr-TR')}</div>
                      {event.end_date && (
                        <div class="text-xs text-gray-500 dark:text-gray-400">
                          - {new Date(event.end_date).toLocaleDateString('tr-TR')}
                        </div>
                      )}
                    </div>
                  </td>
                  <td class="py-4 px-4">
                    <div class="flex items-center gap-1 text-sm text-gray-600 dark:text-gray-400">
                      <span set:html={icons.mapPin} class="w-4 h-4"></span>
                      <span class="truncate max-w-[150px]">{event.location}</span>
                    </div>
                  </td>
                  <td class="py-4 px-4">
                    <span class={`inline-flex px-2 py-1 rounded-full text-xs font-medium ${
                      event.status === 'published' 
                        ? 'bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-300' 
                        : event.status === 'draft'
                        ? 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-800 dark:text-yellow-300'
                        : 'bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-300'
                    }`}>
                      {event.status === 'published' ? 'Yayında' : event.status === 'draft' ? 'Taslak' : 'İptal'}
                    </span>
                  </td>
                  <td class="py-4 px-4">
                    <div class="flex items-center justify-end gap-1">
                      <a href={`/etkinlikler/${event.slug}`} target="_blank" class="p-2 text-gray-400 hover:text-urfa-600 transition-colors" title="Görüntüle">
                        <span set:html={icons.eye}></span>
                      </a>
                      <a href={`/admin/events/edit/${event.id}`} class="p-2 text-gray-400 hover:text-blue-600 transition-colors" title="Düzenle">
                        <span set:html={icons.edit}></span>
                      </a>
                      <form method="POST" action={actions.deleteAdminEvent} class="inline" onsubmit="return confirm('Bu etkinliği silmek istediğinize emin misiniz?');">
                        <input type="hidden" name="id" value={event.id} />
                        <button type="submit" class="p-2 text-gray-400 hover:text-red-600 transition-colors" title="Sil">
                          <span set:html={icons.trash2}></span>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              ))}
              
              {(!events || events.length === 0) && (
                <tr>
                  <td colspan="5" class="py-8 text-center text-gray-500 dark:text-gray-400">
                    Henüz etkinlik bulunmuyor.
                    <a href="/admin/events/add" class="text-urfa-600 hover:underline ml-1">İlk etkinliği ekle</a>
                  </td>
                </tr>
              )}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</Layout>


