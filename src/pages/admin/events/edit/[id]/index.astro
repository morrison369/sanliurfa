---
import { actions, isInputError } from 'astro:actions';
import { Icon } from 'astro-icon/components';
import AdminLayout from '../../../../../layouts/AdminLayout.astro';
import { queryOne } from '../../../../../lib/postgres';
import { logger } from '../../../../../lib/logging';

let event: any = null;
const routeId = Astro.params.id;

if (!routeId) {
  return Astro.redirect('/admin/events');
}

const eventResult = Astro.getActionResult(actions.updateAdminEvent);
const eventInputErrors = isInputError(eventResult?.error) ? eventResult.error.fields : {};
const eventActionError =
  !isInputError(eventResult?.error) && eventResult?.error?.message
    ? eventResult.error.message
    : null;

const categories = [
  { id: 'kultur-sanat', label: 'Kültür & Sanat' },
  { id: 'gastronomi', label: 'Gastronomi' },
  { id: 'tarih', label: 'Tarih' },
  { id: 'muzik', label: 'Müzik' },
  { id: 'spor', label: 'Spor' },
  { id: 'egitim', label: 'Eğitim' },
  { id: 'diger', label: 'Diğer' },
];

const formatDateTimeLocal = (dateString: string) => {
  const d = new Date(dateString);
  if (Number.isNaN(d.getTime())) return '';
  return d.toISOString().slice(0, 16);
};

try {
  event = await queryOne('SELECT * FROM events WHERE id = $1', [routeId]);
  if (!event) {
    return Astro.redirect('/admin/events');
  }
} catch (e) {
  logger.error('Error loading admin event', e instanceof Error ? e : new Error(String(e)));
}

---

<AdminLayout
  title="Etkinlik Düzenle"
  subtitle={event ? event.title : 'Etkinlik bilgilerini güncelleyin'}
  seo={{ title: event ? `${event.title} - Düzenle` : 'Düzenle - Yönetim Paneli', noIndex: true }}
>
    <div class="container mx-auto px-4 py-8 max-w-6xl space-y-5">
      <div class="mb-2">
        <a href="/admin/events" class="text-sm text-[#9A8470] hover:text-[#6B5540]">← Etkinlikler</a>
      </div>

      {eventResult?.data?.success && (
        <div class="rounded-sm border border-[rgba(200,160,100,0.2)] bg-[rgba(200,160,100,0.06)] px-4 py-3 text-sm text-[#6B5540]">
          {eventResult.data.message || 'Etkinlik güncellendi.'}
          <a href="/admin/events" class="ml-2 font-medium underline">Etkinlik listesine dön</a>
        </div>
      )}

      {eventActionError && (
        <div class="rounded-sm border border-[rgba(200,160,100,0.2)] bg-[rgba(200,160,100,0.06)] px-4 py-3 text-sm text-[#9A8470]">
          {eventActionError}
        </div>
      )}

      <form action={actions.updateAdminEvent} method="POST" class="grid lg:grid-cols-3 gap-6">
        <input type="hidden" name="id" value={routeId} />
        <div class="lg:col-span-2 space-y-5">
          <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
            <h2 class="text-base font-semibold text-[#6B5540] mb-4">Temel Bilgiler</h2>
            <div class="space-y-4">
              <div>
                <label for="title" class="block text-sm font-medium text-[#6B5540] mb-1">Etkinlik Adı *</label>
                <input type="text" id="title" name="title" required class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400" value={event.title} />
                {eventInputErrors.title && <p class="mt-1 text-xs text-[#9A8470]">{eventInputErrors.title[0]}</p>}
              </div>
              <div>
                <label for="description" class="block text-sm font-medium text-[#6B5540] mb-1">Açıklama *</label>
                <textarea id="description" name="description" rows="5" required class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400 resize-none">{event.description}</textarea>
                {eventInputErrors.description && <p class="mt-1 text-xs text-[#9A8470]">{eventInputErrors.description[0]}</p>}
              </div>
              <div>
                <label for="category" class="block text-sm font-medium text-[#6B5540] mb-1">Kategori *</label>
                <select id="category" name="category" required class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400">
                  {categories.map(cat => (
                    <option value={cat.id} selected={cat.id === event.category}>{cat.label}</option>
                  ))}
                </select>
                {eventInputErrors.category && <p class="mt-1 text-xs text-[#9A8470]">{eventInputErrors.category[0]}</p>}
              </div>
            </div>
          </div>

          <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
            <h2 class="text-base font-semibold text-[#6B5540] mb-4">Tarih ve Konum</h2>
            <div class="space-y-4">
              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label for="start_date" class="block text-sm font-medium text-[#6B5540] mb-1">Başlangıç Tarihi *</label>
                  <input type="datetime-local" id="start_date" name="start_date" required class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400" value={formatDateTimeLocal(event.start_date)} />
                  {eventInputErrors.start_date && <p class="mt-1 text-xs text-[#9A8470]">{eventInputErrors.start_date[0]}</p>}
                </div>
                <div>
                  <label for="end_date" class="block text-sm font-medium text-[#6B5540] mb-1">Bitiş Tarihi</label>
                  <input type="datetime-local" id="end_date" name="end_date" class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400" value={event.end_date ? formatDateTimeLocal(event.end_date) : ''} />
                </div>
              </div>
              <div>
                <label for="location" class="block text-sm font-medium text-[#6B5540] mb-1">Konum *</label>
                <div class="relative">
                  <Icon name="lucide:map-pin" class="absolute left-3 top-3 w-5 h-5 text-[#9A8470]" />
                  <input type="text" id="location" name="location" required class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] pl-10 px-3 py-2 text-sm focus:outline-none focus:border-urfa-400" value={event.location} />
                  {eventInputErrors.location && <p class="mt-1 text-xs text-[#9A8470]">{eventInputErrors.location[0]}</p>}
                </div>
              </div>
            </div>
          </div>
        </div>

        <aside class="space-y-5">
          <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
            <h3 class="font-semibold text-[#6B5540] mb-4">Yayınla</h3>
            <label class="flex items-center gap-2 mb-3">
              <input type="checkbox" name="is_featured" checked={event.is_featured} class="rounded" />
              <span class="text-sm text-[#6B5540]">Öne çıkan etkinlik</span>
            </label>
            <label for="status" class="block text-sm font-medium text-[#6B5540] mb-1">Durum</label>
            <select id="status" name="status" class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400 mt-1">
              <option value="draft" selected={event.status === 'draft'}>Taslak</option>
              <option value="published" selected={event.status === 'published'}>Yayında</option>
              <option value="cancelled" selected={event.status === 'cancelled'}>İptal Edildi</option>
            </select>
            <button type="submit" class="rounded-sm bg-urfa-600 w-full mt-4 px-4 py-2 text-sm font-semibold text-white hover:bg-urfa-700 flex items-center justify-center gap-2">
              <Icon name="lucide:save" class="w-4 h-4" />
              Kaydet
            </button>
          </div>

          <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-6">
            <h3 class="font-semibold text-[#6B5540] mb-4">Görsel</h3>
            <input type="url" name="image" class="w-full rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm focus:outline-none focus:border-urfa-400" value={event.image_url || ''} placeholder="https://example.com/image.jpg" />
            <p class="text-xs text-[#9A8470] mt-2">Etkinlik görsel URL'si</p>
            {event.image_url && <img src={event.image_url} alt="" class="mt-3 w-full h-32 object-cover rounded-sm" />}
          </div>
        </aside>
      </form>
    </div>
</AdminLayout>
