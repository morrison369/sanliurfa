---
import { actions, isInputError } from 'astro:actions';
import { Icon } from 'astro-icon/components';
import AdminLayout from '../../../layouts/AdminLayoutV2.astro';

const categories = [
 { id: 'kultur-sanat', label: 'Kültür & Sanat' },
 { id: 'gastronomi', label: 'Gastronomi' },
 { id: 'tarih', label: 'Tarih' },
 { id: 'muzik', label: 'Müzik' },
 { id: 'spor', label: 'Spor' },
 { id: 'egitim', label: 'Eğitim' },
 { id: 'diger', label: 'Diğer' },
];

const eventResult = Astro.getActionResult(actions.createAdminEvent);
const eventInputErrors = isInputError(eventResult?.error) ? eventResult.error.fields : {};
const eventActionError =
 !isInputError(eventResult?.error) && eventResult?.error?.message
  ? eventResult.error.message
  : null;
const errorMessage = Astro.url.searchParams.get('error');
const errorMessages: Record<string, string> = {
 'missing_fields': 'Başlık, açıklama, konum, tarih ve kategori zorunludur.',
 'server_error': 'Bir hata oluştu. Lütfen tekrar deneyin.',
};

const startPresets = [
 { key: 'today',    label: 'Bugün 18:00' },
 { key: 'tomorrow', label: 'Yarın 18:00' },
 { key: 'weekend',  label: 'Cumartesi' },
 { key: '+7d',      label: '+7 gün' },
 { key: '+30d',     label: '+30 gün' },
];
const endPresets = [
 { key: '+1h',     label: '+1 saat' },
 { key: '+3h',     label: '+3 saat' },
 { key: 'sameday', label: 'Aynı gün 23:00' },
 { key: '+1d',     label: 'Ertesi gün' },
];
---

<AdminLayout
 title="Yeni Etkinlik"
 subtitle="Etkinlik bilgilerini doldurun, taslak veya yayında olarak kaydedin"
 seo={{ title: 'Yeni Etkinlik - Yönetim Paneli', noIndex: true }}
>
 <a slot="page-actions" href="/admin/events" class="evf-back">
  <Icon name="lucide:arrow-left" class="w-4 h-4" /> Etkinlikler
 </a>

 <div class="evf-page">
  {errorMessage && (
   <div class="evf-toast evf-toast--err">
    <Icon name="lucide:alert-circle" class="w-4 h-4" />
    {errorMessages[errorMessage] || 'Bir hata oluştu.'}
   </div>
  )}

  {eventResult?.data?.success && (
   <div class="evf-toast evf-toast--ok">
    <Icon name="lucide:check-circle" class="w-4 h-4" />
    <span>
     {eventResult.data.message || 'Etkinlik oluşturuldu.'}
     <a href="/admin/events" class="evf-toast-link">→ Etkinlik listesine dön</a>
    </span>
   </div>
  )}

  {eventActionError && (
   <div class="evf-toast evf-toast--err">
    <Icon name="lucide:alert-circle" class="w-4 h-4" />
    {eventActionError}
   </div>
  )}

  <form action={actions.createAdminEvent} method="POST" class="evf-grid">
   <div class="evf-main">
    <section class="evf-card">
     <header class="evf-card-head">
      <h2 class="evf-card-title">
       <Icon name="lucide:info" class="w-4 h-4" /> Temel Bilgiler
      </h2>
     </header>
     <div class="evf-card-body evf-fields">
      <div class="evf-field">
       <label for="title" class="evf-label">Etkinlik Adı <span class="evf-req">*</span></label>
       <input type="text" id="title" name="title" required class="evf-input" placeholder="Örn: Urfa Gastronomi Festivali" />
       {eventInputErrors.title && <p class="evf-err">{eventInputErrors.title[0]}</p>}
      </div>

      <div class="evf-field">
       <label for="description" class="evf-label">Açıklama <span class="evf-req">*</span></label>
       <textarea id="description" name="description" rows="5" required class="evf-input evf-textarea" placeholder="Etkinlik hakkında detaylı bilgi…"></textarea>
       {eventInputErrors.description && <p class="evf-err">{eventInputErrors.description[0]}</p>}
      </div>

      <div class="evf-field">
       <label for="category" class="evf-label">Kategori <span class="evf-req">*</span></label>
       <select id="category" name="category" required class="evf-input">
        <option value="">— Kategori Seç —</option>
        {categories.map(cat => (
         <option value={cat.id}>{cat.label}</option>
        ))}
       </select>
       {eventInputErrors.category && <p class="evf-err">{eventInputErrors.category[0]}</p>}
      </div>
     </div>
    </section>

    <section class="evf-card">
     <header class="evf-card-head">
      <h2 class="evf-card-title">
       <Icon name="lucide:calendar-clock" class="w-4 h-4" /> Tarih ve Konum
      </h2>
     </header>
     <div class="evf-card-body evf-fields">
      <div class="evf-row">
       <div class="evf-field">
        <label for="start_date" class="evf-label">Başlangıç Tarihi <span class="evf-req">*</span></label>
        <input type="datetime-local" id="start_date" name="start_date" required class="evf-input" />
        <div class="evf-presets">
         {startPresets.map(p => (
          <button type="button" data-date-preset={p.key} data-target="start_date" class="evf-preset">{p.label}</button>
         ))}
        </div>
        <p id="start_date_preview" class="evf-preview"></p>
        {eventInputErrors.start_date && <p class="evf-err">{eventInputErrors.start_date[0]}</p>}
       </div>
       <div class="evf-field">
        <label for="end_date" class="evf-label">Bitiş Tarihi</label>
        <input type="datetime-local" id="end_date" name="end_date" class="evf-input" />
        <div class="evf-presets">
         {endPresets.map(p => (
          <button type="button" data-end-preset={p.key} class="evf-preset">{p.label}</button>
         ))}
        </div>
        <p id="end_date_preview" class="evf-preview"></p>
       </div>
      </div>

      <div class="evf-field">
       <label for="location" class="evf-label">Konum <span class="evf-req">*</span></label>
       <div class="evf-input-icon">
        <Icon name="lucide:map-pin" class="evf-input-icon-svg" />
        <input type="text" id="location" name="location" required class="evf-input evf-input--padded" placeholder="Örn: Balıklıgöl, Şanlıurfa" />
       </div>
       {eventInputErrors.location && <p class="evf-err">{eventInputErrors.location[0]}</p>}
      </div>
     </div>
    </section>
   </div>

   <aside class="evf-aside">
    <section class="evf-card evf-publish">
     <header class="evf-card-head">
      <h3 class="evf-card-title">
       <Icon name="lucide:send" class="w-4 h-4" /> Yayınla
      </h3>
     </header>
     <div class="evf-card-body evf-fields">
      <label class="evf-checkbox">
       <input type="checkbox" name="is_featured" />
       <span>
        <strong>Öne çıkan etkinlik</strong>
        <em>Ana sayfada ve etkinlik listesinde vurgulanır</em>
       </span>
      </label>

      <div class="evf-field">
       <label for="status" class="evf-label">Durum</label>
       <select id="status" name="status" class="evf-input">
        <option value="draft">Taslak</option>
        <option value="published">Yayında</option>
        <option value="cancelled">İptal Edildi</option>
       </select>
      </div>

      <button type="submit" class="evf-submit">
       <Icon name="lucide:save" class="w-4 h-4" /> Kaydet
      </button>
     </div>
    </section>

    <section class="evf-card">
     <header class="evf-card-head">
      <h3 class="evf-card-title">
       <Icon name="lucide:image" class="w-4 h-4" /> Görsel
      </h3>
     </header>
     <div class="evf-card-body evf-fields">
      <input type="url" name="image" class="evf-input" placeholder="https://example.com/image.jpg" />
      <p class="evf-hint">Etkinlik için görsel URL (opsiyonel)</p>
     </div>
    </section>
   </aside>
  </form>
 </div>

 <script is:inline>
  (function () {
   function pad(n) { return String(n).padStart(2, '0'); }
   function toLocalInput(d) {
    return d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate()) +
     'T' + pad(d.getHours()) + ':' + pad(d.getMinutes());
   }
   function fmtTr(d) {
    return d.toLocaleDateString('tr-TR', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }) +
     ' · ' + d.toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit' });
   }
   function setDate(targetId, d) {
    const el = document.getElementById(targetId);
    if (!el) return;
    el.value = toLocalInput(d);
    el.dispatchEvent(new Event('change'));
   }
   function updatePreview(id) {
    const el = document.getElementById(id);
    const out = document.getElementById(id + '_preview');
    if (!el || !out) return;
    if (!el.value) { out.textContent = ''; return; }
    const d = new Date(el.value);
    out.textContent = Number.isFinite(d.getTime()) ? fmtTr(d) : '';
   }

   document.querySelectorAll('[data-date-preset]').forEach((btn) => {
    btn.addEventListener('click', () => {
     const preset = btn.getAttribute('data-date-preset');
     const target = btn.getAttribute('data-target') || 'start_date';
     const now = new Date();
     now.setSeconds(0); now.setMilliseconds(0);
     if (preset === 'today') { now.setHours(18, 0); setDate(target, now); }
     else if (preset === 'tomorrow') { now.setDate(now.getDate() + 1); now.setHours(18, 0); setDate(target, now); }
     else if (preset === 'weekend') {
      const dow = now.getDay();
      const diff = (6 - dow + 7) % 7 || 7;
      now.setDate(now.getDate() + diff); now.setHours(20, 0); setDate(target, now);
     }
     else if (preset === '+7d') { now.setDate(now.getDate() + 7); now.setHours(19, 0); setDate(target, now); }
     else if (preset === '+30d') { now.setDate(now.getDate() + 30); now.setHours(19, 0); setDate(target, now); }
    });
   });

   document.querySelectorAll('[data-end-preset]').forEach((btn) => {
    btn.addEventListener('click', () => {
     const preset = btn.getAttribute('data-end-preset');
     const start = document.getElementById('start_date').value;
     if (!start) { window.toast?.warning?.('Önce başlangıç tarihi seçin') ?? alert('Önce başlangıç tarihi seçin'); return; }
     const d = new Date(start);
     if (preset === '+1h') d.setHours(d.getHours() + 1);
     else if (preset === '+3h') d.setHours(d.getHours() + 3);
     else if (preset === 'sameday') d.setHours(23, 0);
     else if (preset === '+1d') { d.setDate(d.getDate() + 1); }
     setDate('end_date', d);
    });
   });

   ['start_date', 'end_date'].forEach((id) => {
    const el = document.getElementById(id);
    if (el) {
     el.addEventListener('change', () => updatePreview(id));
     el.addEventListener('input', () => updatePreview(id));
     updatePreview(id);
    }
   });
  })();
 </script>

 <style>
  .evf-page { display: flex; flex-direction: column; gap: 1.25rem; }

  .evf-back {
   display: inline-flex; align-items: center; gap: 0.4rem;
   padding: 0.5rem 1rem;
   background: var(--adm-bg-elev);
   border: 1px solid var(--adm-border);
   color: var(--adm-text-muted);
   font-weight: 600; font-size: 0.84rem;
   border-radius: 8px; text-decoration: none;
   transition: all 0.15s;
  }
  .evf-back:hover { border-color: var(--adm-accent); color: var(--adm-accent); }

  .evf-toast {
   display: flex; align-items: center; gap: 0.55rem;
   padding: 0.7rem 1rem;
   border-radius: 10px;
   font-size: 0.86rem;
  }
  .evf-toast--ok { background: rgba(16,185,129,0.08); color: rgb(5,150,105); border: 1px solid rgba(16,185,129,0.18); }
  .evf-toast--err { background: rgba(225,29,72,0.08); color: rgb(190,18,60); border: 1px solid rgba(225,29,72,0.18); }
  .evf-toast-link {
   margin-left: 0.4rem;
   font-weight: 600;
   text-decoration: underline;
   color: inherit;
  }

  .evf-grid {
   display: grid;
   grid-template-columns: 1fr;
   gap: 1.25rem;
  }
  @media (min-width: 1024px) {
   .evf-grid { grid-template-columns: 1.6fr 1fr; }
  }
  .evf-main, .evf-aside { display: flex; flex-direction: column; gap: 1.25rem; }

  .evf-card {
   background: var(--adm-bg-elev);
   border: 1px solid var(--adm-border);
   border-radius: 12px;
   overflow: hidden;
  }
  .evf-card-head {
   padding: 0.95rem 1.15rem;
   border-bottom: 1px solid var(--adm-border);
   background: var(--adm-bg-hover);
  }
  .evf-card-title {
   display: inline-flex; align-items: center; gap: 0.5rem;
   margin: 0;
   font-size: 0.95rem; font-weight: 600;
   color: var(--adm-text);
  }
  .evf-card-body { padding: 1.15rem; }
  .evf-fields { display: flex; flex-direction: column; gap: 0.95rem; }
  .evf-row {
   display: grid;
   grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
   gap: 0.85rem;
  }

  .evf-field { display: flex; flex-direction: column; gap: 0.3rem; }
  .evf-label {
   font-size: 0.8rem; font-weight: 600;
   color: var(--adm-text);
  }
  .evf-req { color: rgb(190,18,60); font-weight: 700; }
  .evf-input {
   padding: 0.55rem 0.75rem;
   background: var(--adm-bg);
   border: 1px solid var(--adm-border);
   border-radius: 8px;
   font-size: 0.88rem;
   color: var(--adm-text);
   font-family: inherit;
   width: 100%;
  }
  .evf-input:focus { outline: none; border-color: var(--adm-accent); box-shadow: 0 0 0 3px var(--adm-bg-active); }
  .evf-textarea { resize: vertical; min-height: 110px; }

  .evf-input-icon { position: relative; }
  .evf-input-icon-svg {
   position: absolute;
   left: 0.7rem; top: 50%;
   transform: translateY(-50%);
   width: 1rem; height: 1rem;
   color: var(--adm-text-soft);
   pointer-events: none;
  }
  .evf-input--padded { padding-left: 2.1rem; }

  .evf-err {
   font-size: 0.74rem;
   color: rgb(190,18,60);
   margin: 0;
  }
  .evf-hint { font-size: 0.72rem; color: var(--adm-text-soft); margin: 0; }

  .evf-presets {
   display: flex; flex-wrap: wrap; gap: 0.3rem;
  }
  .evf-preset {
   font-size: 0.72rem; font-weight: 600;
   padding: 0.25rem 0.65rem;
   background: var(--adm-bg);
   border: 1px solid var(--adm-border);
   border-radius: 999px;
   color: var(--adm-text-muted);
   cursor: pointer;
   transition: all 0.15s;
  }
  .evf-preset:hover { border-color: var(--adm-accent); color: var(--adm-accent); }

  .evf-preview {
   font-size: 0.74rem;
   color: var(--adm-text-soft);
   margin: 0;
   font-style: italic;
  }

  .evf-checkbox {
   display: flex; gap: 0.6rem; align-items: flex-start;
   padding: 0.7rem 0.85rem;
   background: var(--adm-bg);
   border: 1px solid var(--adm-border);
   border-radius: 8px;
   cursor: pointer;
  }
  .evf-checkbox input {
   width: 16px; height: 16px;
   accent-color: var(--adm-accent);
   margin-top: 0.15rem;
  }
  .evf-checkbox strong {
   display: block;
   font-weight: 600;
   font-size: 0.86rem;
   color: var(--adm-text);
   margin-bottom: 0.15rem;
  }
  .evf-checkbox em {
   display: block;
   font-style: normal;
   font-size: 0.74rem;
   color: var(--adm-text-soft);
   line-height: 1.4;
  }

  .evf-submit {
   width: 100%;
   display: inline-flex; align-items: center; justify-content: center; gap: 0.4rem;
   padding: 0.65rem 1.1rem;
   background: linear-gradient(135deg, var(--adm-accent), var(--adm-warning));
   color: #fff;
   border: none;
   border-radius: 8px;
   font-weight: 600; font-size: 0.88rem;
   cursor: pointer;
   transition: transform 0.15s;
   margin-top: 0.25rem;
  }
  .evf-submit:hover { transform: translateY(-1px); }
 </style>
</AdminLayout>
