---
import { actions } from 'astro:actions';
import { Icon } from 'astro-icon/components';
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { query } from '../../../lib/postgres';
import { logger } from '../../../lib/logging';

interface HistoricalSiteRow {
  id: string;
  slug: string;
  name: string;
  period?: string | null;
  location?: string | null;
  status?: string | null;
  is_unesco?: boolean | null;
  is_featured?: boolean | null;
}

interface HistoricalSiteStats {
  total: string | number;
  unesco: string | number;
  featured: string | number;
  active: string | number;
}

let sites: HistoricalSiteRow[] = [];
let stats: HistoricalSiteStats = { total: 0, unesco: 0, featured: 0, active: 0 };

const deleteResult = Astro.getActionResult(actions.deleteAdminHistoricalSite);

try {
  const [sitesResult, statsResult] = await Promise.all([
    query('SELECT * FROM historical_sites ORDER BY name ASC'),
    query(
      `SELECT
        COUNT(*) as total,
        COUNT(*) FILTER (WHERE is_unesco = true) as unesco,
        COUNT(*) FILTER (WHERE is_featured = true) as featured,
        COUNT(*) FILTER (WHERE status = 'active') as active
       FROM historical_sites`
    ),
  ]);
  sites = sitesResult.rows;
  stats = statsResult.rows[0] || stats;
} catch (e) {
  logger.error('Error loading admin historical sites', e instanceof Error ? e : new Error(String(e)));
}
---

<AdminLayout
  title="Tarihi Yerler"
  subtitle="Tarihi yerleri listeleyin ve yönetin"
  seo={{ title: 'Tarihi Yerler Yönetimi - Yönetim Paneli', noIndex: true }}
>
  <a slot="hero-action" href="/admin/historical-sites/add" class="rounded-sm bg-urfa-600 px-4 py-2 text-sm font-semibold text-white hover:bg-urfa-700 flex items-center gap-2">
    <Icon name="lucide:plus" class="w-4 h-4" />
    Yeni Yer Ekle
  </a>

    <div class="container mx-auto px-4 py-8 max-w-6xl space-y-5">
      <div class="mb-2">
        <a href="/admin" class="text-sm text-[#9A8470] hover:text-[#6B5540]">← Admin Paneli</a>
      </div>

      {deleteResult?.data?.success && (
        <div class="rounded-sm border border-[rgba(200,160,100,0.2)] bg-[rgba(200,160,100,0.06)] px-4 py-3 text-sm text-[#6B5540]">
          {deleteResult.data.message || 'Tarihi yer silindi.'}
        </div>
      )}

      {deleteResult?.error && (
        <div class="rounded-sm border border-[rgba(200,160,100,0.2)] bg-[rgba(200,160,100,0.06)] px-4 py-3 text-sm text-[#9A8470]">
          {deleteResult.error.message || 'Tarihi yer silinemedi.'}
        </div>
      )}

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-4">
          <p class="text-sm text-[#9A8470]">Toplam Yer</p>
          <p class="text-2xl font-bold text-[#1A1008]">{stats.total}</p>
        </div>
        <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-4">
          <p class="text-sm text-[#9A8470]">UNESCO</p>
          <p class="text-2xl font-bold text-[#6B5540]">{stats.unesco}</p>
        </div>
        <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-4">
          <p class="text-sm text-[#9A8470]">Öne Çıkan</p>
          <p class="text-2xl font-bold text-[#6B5540]">{stats.featured}</p>
        </div>
        <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm p-4">
          <p class="text-sm text-[#9A8470]">Aktif</p>
          <p class="text-2xl font-bold text-[#6B5540]">{stats.active}</p>
        </div>
      </div>

      <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="border-b border-[rgba(200,160,100,0.14)] bg-[rgba(200,160,100,0.04)]">
              <tr>
                <th class="text-left py-3 px-4 font-medium text-[#6B5540]">Yer</th>
                <th class="text-left py-3 px-4 font-medium text-[#6B5540]">Dönem</th>
                <th class="text-left py-3 px-4 font-medium text-[#6B5540]">Konum</th>
                <th class="text-left py-3 px-4 font-medium text-[#6B5540]">Durum</th>
                <th class="text-right py-3 px-4 font-medium text-[#6B5540]">İşlemler</th>
              </tr>
            </thead>
            <tbody>
              {sites.map(site => (
                <tr class="border-b border-[rgba(200,160,100,0.08)] last:border-0 hover:bg-[rgba(200,160,100,0.04)]">
                  <td class="py-4 px-4">
                    <div class="flex items-start gap-3">
                      <div class="w-10 h-10 bg-[rgba(200,160,100,0.1)] rounded-sm flex items-center justify-center flex-shrink-0">
                        <Icon name="lucide:landmark" class="w-5 h-5 text-urfa-600" />
                      </div>
                      <div>
                        <p class="font-medium text-[#1A1008] text-sm">{site.name}</p>
                        {site.is_unesco && (
                          <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-[rgba(200,160,100,0.15)] text-[#6B5540] text-xs rounded-sm mt-1">
                            <Icon name="lucide:star" class="w-3 h-3" /> UNESCO
                          </span>
                        )}
                        {site.is_featured && !site.is_unesco && (
                          <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-[rgba(200,160,100,0.1)] text-[#6B5540] text-xs rounded-sm mt-1">
                            ⭐ Öne Çıkan
                          </span>
                        )}
                      </div>
                    </div>
                  </td>
                  <td class="py-4 px-4">
                    <span class="text-sm text-[#9A8470]">{site.period || '-'}</span>
                  </td>
                  <td class="py-4 px-4">
                    <div class="flex items-center gap-1 text-sm text-[#9A8470]">
                      <Icon name="lucide:map-pin" class="w-4 h-4" />
                      <span class="truncate max-w-[150px]">{site.location}</span>
                    </div>
                  </td>
                  <td class="py-4 px-4">
                    <span class={`inline-flex px-2 py-0.5 rounded-sm text-xs font-medium ${
                      site.status === 'active'
                        ? 'bg-[rgba(200,160,100,0.15)] text-[#6B5540]'
                        : site.status === 'draft'
                        ? 'bg-[rgba(200,160,100,0.08)] text-[#9A8470]'
                        : 'bg-[rgba(200,160,100,0.04)] text-[#9A8470]'
                    }`}>
                      {site.status === 'active' ? 'Aktif' : site.status === 'draft' ? 'Taslak' : 'Pasif'}
                    </span>
                  </td>
                  <td class="py-4 px-4">
                    <div class="flex items-center justify-end gap-1">
                      <a href={`/tarihi-yerler/${site.slug}`} target="_blank" rel="noopener" class="p-2 text-[#9A8470] hover:text-urfa-600 transition-colors" title="Görüntüle">
                        <Icon name="lucide:eye" class="w-4 h-4" />
                      </a>
                      <a href={`/admin/historical-sites/edit/${site.id}`} class="p-2 text-[#9A8470] hover:text-urfa-600 transition-colors" title="Düzenle">
                        <Icon name="lucide:pencil" class="w-4 h-4" />
                      </a>
                      <form method="POST" action={actions.deleteAdminHistoricalSite} class="inline" data-confirm="Bu tarihi yeri silmek istediğinize emin misiniz?">
                        <input type="hidden" name="id" value={site.id} />
                        <button type="submit" class="p-2 text-[#9A8470] hover:text-[#6B5540] transition-colors" title="Sil">
                          <Icon name="lucide:trash-2" class="w-4 h-4" />
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              ))}

              {(!sites || sites.length === 0) && (
                <tr>
                  <td colspan="5" class="py-8 text-center text-[#9A8470]">
                    Henüz tarihi yer bulunmuyor.
                    <a href="/admin/historical-sites/add" class="text-urfa-600 hover:underline ml-1">İlk yeri ekle</a>
                  </td>
                </tr>
              )}
            </tbody>
          </table>
        </div>
      </div>
    </div>
</AdminLayout>
