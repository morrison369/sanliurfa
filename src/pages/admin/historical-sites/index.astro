---
import Layout from '../../../layouts/Layout.astro';
import { query } from '../../../lib/postgres';

const icons = {
  landmark: `<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="2" y2="13"/><path d="M22 20H2"/><path d="m19 9-3.5 1 3.5 7"/><path d="m5 9 3.5 1-3.5 7"/><path d="M8 20V9l4-7 4 7v11"/></svg>`,
  plus: `<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>`,
  edit: `<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.375 2.625a1 1 0 0 1 3 3l-9.013 9.014a2 2 0 0 1-.853.505l-2.873.84a.5.5 0 0 1-.62-.62l.84-2.873a2 2 0 0 1 .506-.852z"/></svg>`,
  trash2: `<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>`,
  eye: `<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.72 10.72 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.72 10.72 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/></svg>`,
  mapPin: `<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`,
  star: `<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13.676 2.43 16.293 7.84 22.249 8.72 17.913 12.873 18.97 18.717 13.676 15.962 8.382 18.717 9.439 12.873 5.103 8.72 11.059 7.84 13.676 2.43"/></svg>`,
};

const user = Astro.locals.user;
if (!user || !Astro.locals.isAdmin) {
  return Astro.redirect('/giris?redirect=/admin/historical-sites');
}

let sites: any[] = [];
let stats: any[] = [];
const seo = {
    title: 'Tarihi Yerler Yönetimi - Admin Panel',
    noindex: true
  };

try {

  const sitesResult = await query('SELECT * FROM historical_sites ORDER BY name ASC');
  sites = sitesResult.rows;

  const statsResult = await query(
    `SELECT 
      COUNT(*) as total,
      COUNT(*) FILTER (WHERE is_unesco = true) as unesco,
      COUNT(*) FILTER (WHERE is_featured = true) as featured,
      COUNT(*) FILTER (WHERE status = 'active') as active
     FROM historical_sites`
  );
  stats = statsResult.rows[0];

} catch (e) {
  console.error('Error loading data:', e);
}
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <div class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
      <div class="container-custom py-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <a href="/admin" class="text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white">← Geri</a>
            <h1 class="text-2xl font-display font-bold text-gray-900 dark:text-white">Tarihi Yerler</h1>
          </div>
          <a href="/admin/historical-sites/add" class="btn-primary flex items-center gap-2">
            <span set:html={icons.plus}></span>
            Yeni Yer Ekle
          </a>
        </div>
      </div>
    </div>
    
    <div class="container-custom py-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="bg-white dark:bg-gray-800 rounded-xl p-4 border border-gray-200 dark:border-gray-700">
          <p class="text-sm text-gray-600 dark:text-gray-400">Toplam Yer</p>
          <p class="text-2xl font-bold text-gray-900 dark:text-white">{stats.total}</p>
        </div>
        <div class="bg-blue-50 dark:bg-blue-900/20 rounded-xl p-4 border border-blue-200 dark:border-blue-800">
          <p class="text-sm text-blue-700 dark:text-blue-400">UNESCO</p>
          <p class="text-2xl font-bold text-blue-800 dark:text-blue-300">{stats.unesco}</p>
        </div>
        <div class="bg-urfa-50 dark:bg-urfa-900/20 rounded-xl p-4 border border-urfa-200 dark:border-urfa-800">
          <p class="text-sm text-urfa-700 dark:text-urfa-400">Öne Çıkan</p>
          <p class="text-2xl font-bold text-urfa-800 dark:text-urfa-300">{stats.featured}</p>
        </div>
        <div class="bg-green-50 dark:bg-green-900/20 rounded-xl p-4 border border-green-200 dark:border-green-800">
          <p class="text-sm text-green-700 dark:text-green-400">Aktif</p>
          <p class="text-2xl font-bold text-green-800 dark:text-green-300">{stats.active}</p>
        </div>
      </div>
      
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-700/50">
                <th class="text-left py-3 px-4 text-sm font-medium text-gray-600 dark:text-gray-400">Yer</th>
                <th class="text-left py-3 px-4 text-sm font-medium text-gray-600 dark:text-gray-400">Dönem</th>
                <th class="text-left py-3 px-4 text-sm font-medium text-gray-600 dark:text-gray-400">Konum</th>
                <th class="text-left py-3 px-4 text-sm font-medium text-gray-600 dark:text-gray-400">Durum</th>
                <th class="text-right py-3 px-4 text-sm font-medium text-gray-600 dark:text-gray-400">İşlemler</th>
              </tr>
            </thead>
            <tbody>
              {sites?.map(site => (
                <tr class="border-b border-gray-200 dark:border-gray-700 last:border-0 hover:bg-gray-50 dark:hover:bg-gray-700/50">
                  <td class="py-4 px-4">
                    <div class="flex items-start gap-3">
                      <div class="w-10 h-10 bg-amber-100 dark:bg-amber-900/30 rounded-lg flex items-center justify-center flex-shrink-0">
                        <span set:html={icons.landmark} class="w-5 h-5 text-amber-600 dark:text-amber-400"></span>
                      </div>
                      <div>
                        <p class="font-medium text-gray-900 dark:text-white text-sm">{site.name}</p>
                        {site.is_unesco && (
                          <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 text-xs rounded mt-1">
                            <span set:html={icons.star}></span> UNESCO
                          </span>
                        )}
                        {site.is_featured && !site.is_unesco && (
                          <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-urfa-100 dark:bg-urfa-900/30 text-urfa-700 dark:text-urfa-300 text-xs rounded mt-1">
                            ⭐ Öne Çıkan
                          </span>
                        )}
                      </div>
                    </div>
                  </td>
                  <td class="py-4 px-4">
                    <span class="text-sm text-gray-600 dark:text-gray-400">{site.period || '-'}</span>
                  </td>
                  <td class="py-4 px-4">
                    <div class="flex items-center gap-1 text-sm text-gray-600 dark:text-gray-400">
                      <span set:html={icons.mapPin} class="w-4 h-4"></span>
                      <span class="truncate max-w-[150px]">{site.location}</span>
                    </div>
                  </td>
                  <td class="py-4 px-4">
                    <span class={`inline-flex px-2 py-1 rounded-full text-xs font-medium ${
                      site.status === 'active' 
                        ? 'bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-300' 
                        : site.status === 'draft'
                        ? 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-800 dark:text-yellow-300'
                        : 'bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-300'
                    }`}>
                      {site.status === 'active' ? 'Aktif' : site.status === 'draft' ? 'Taslak' : 'Pasif'}
                    </span>
                  </td>
                  <td class="py-4 px-4">
                    <div class="flex items-center justify-end gap-1">
                      <a href={`/tarihi-yerler/${site.slug}`} target="_blank" class="p-2 text-gray-400 hover:text-urfa-600 transition-colors" title="Görüntüle">
                        <span set:html={icons.eye}></span>
                      </a>
                      <a href={`/admin/historical-sites/edit/${site.id}`} class="p-2 text-gray-400 hover:text-blue-600 transition-colors" title="Düzenle">
                        <span set:html={icons.edit}></span>
                      </a>
                      <form method="POST" action={`/api/historical-sites/${site.id}/delete`} class="inline" onsubmit="return confirm('Bu tarihi yeri silmek istediğinize emin misiniz?');">
                        <button type="submit" class="p-2 text-gray-400 hover:text-red-600 transition-colors" title="Sil">
                          <span set:html={icons.trash2}></span>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              ))}
              
              {(!sites || sites.length === 0) && (
                <tr>
                  <td colspan="5" class="py-8 text-center text-gray-500 dark:text-gray-400">
                    Henüz tarihi yer bulunmuyor.
                    <a href="/admin/historical-sites/add" class="text-urfa-600 hover:underline ml-1">İlk yeri ekle</a>
                  </td>
                </tr>
              )}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</Layout>
