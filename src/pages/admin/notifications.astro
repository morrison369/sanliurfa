---
/**
 * Admin - Push Notifications Yönetimi
 * Bildirimleri gönder, taslaklar, geçmiş
 */

import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout
 title="Bildirim Yönetimi"
 subtitle="Push bildirimleri gönder, taslakları yönet ve geçmişi görüntüle"
 seo={{ title: 'Bildirim Yönetimi - Admin' }}
>
 <div class="sf-container py-8 max-w-6xl">
 <div class="mb-6">
 <a href="/admin" class="text-sm text-[#7A6B58] hover:text-[#7A6B58]">← Admin Paneli</a>
 </div>

 <!-- Tabs -->
 <div class="mb-6 flex border-b border-[rgba(184,115,51,0.14)]">
 <button id="tab-send" class="px-4 py-3 font-medium text-sm text-urfa-600 border-b-2 border-urfa-600 cursor-pointer">
 Gönder
 </button>
 <button id="tab-drafts" class="px-4 py-3 font-medium text-sm text-[#7A6B58] cursor-pointer hover:text-[#7A6B58] border-b-2 border-transparent">
 Taslaklar
 </button>
 <button id="tab-history" class="px-4 py-3 font-medium text-sm text-[#7A6B58] cursor-pointer hover:text-[#7A6B58] border-b-2 border-transparent">
 Geçmiş
 </button>
 <button id="tab-stats" class="px-4 py-3 font-medium text-sm text-[#7A6B58] cursor-pointer hover:text-[#7A6B58] border-b-2 border-transparent">
 İstatistikler
 </button>
 </div>

 <!-- Send Tab -->
 <div id="content-send" class="grid grid-cols-3 gap-6">
 <!-- Form -->
 <div class="col-span-2">
 <div class="bg-[var(--bg-card)] border border-[rgba(184,115,51,0.14)] rounded-sm p-6">
 <form id="notification-form" class="space-y-4">
 <div>
 <label class="block text-sm font-medium text-[#7A6B58] mb-1">Bildirim Başlığı</label>
 <input
 type="text"
 name="title"
 placeholder="örn: Yeni Blog Yazısı"
 required
 maxlength="100"
 class="w-full px-3 py-2 border border-[rgba(184,115,51,0.2)] rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-urfa-500"
 />
 </div>
 <div>
 <label class="block text-sm font-medium text-[#7A6B58] mb-1">Açıklama</label>
 <textarea
 name="body"
 placeholder="Bildirim içeriğini yazın..."
 rows="4"
 maxlength="500"
 required
 class="w-full px-3 py-2 border border-[rgba(184,115,51,0.2)] rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-urfa-500"
 ></textarea>
 </div>
 <div>
 <label class="block text-sm font-medium text-[#7A6B58] mb-1">Tıklanınca Gidecek URL</label>
 <input
 type="url"
 name="url"
 placeholder="/blog"
 class="w-full px-3 py-2 border border-[rgba(184,115,51,0.2)] rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-urfa-500"
 />
 </div>
 <div>
 <label class="block text-sm font-medium text-[#7A6B58] mb-1">Hedef Kitle</label>
 <select name="target" class="w-full px-3 py-2 border border-[rgba(184,115,51,0.2)] rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-urfa-500">
 <option value="all">Tüm Aboneler</option>
 <option value="blog">Blog Aboneleri</option>
 <option value="new">Yeni Kullanıcılar</option>
 <option value="active">Aktif Kullanıcılar</option>
 </select>
 </div>
 <div class="grid grid-cols-2 gap-4">
 <div>
 <label class="block text-sm font-medium text-[#7A6B58] mb-1">Gönderme Zamanı</label>
 <input
 type="datetime-local"
 name="scheduled_for"
 class="w-full px-3 py-2 border border-[rgba(184,115,51,0.2)] rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-urfa-500"
 />
 </div>
 <div>
 <label class="block text-sm font-medium text-[#7A6B58] mb-1">Öncelik</label>
 <select name="priority" class="w-full px-3 py-2 border border-[rgba(184,115,51,0.2)] rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-urfa-500">
 <option value="normal">Normal</option>
 <option value="high">Yüksek</option>
 <option value="urgent">Acil</option>
 </select>
 </div>
 </div>
 <div class="flex gap-3 pt-2">
 <button
 type="button"
 onclick="saveDraft()"
 class="flex-1 px-4 py-2 bg-[rgba(184,115,51,0.06)] text-[#7A6B58] rounded-sm text-sm font-medium hover:bg-[rgba(184,115,51,0.12)] transition"
 >
 Taslak Olarak Kaydet
 </button>
 <button
 type="submit"
 class="flex-1 px-4 py-2 rounded-sm bg-urfa-600 text-white text-sm font-medium hover:bg-urfa-700 transition"
 >
 Gönder
 </button>
 </div>
 </form>
 </div>
 </div>

 <!-- Preview -->
 <div>
 <div class="bg-[var(--bg-card)] border border-[rgba(184,115,51,0.14)] rounded-sm p-6">
 <h3 class="font-semibold text-[#7A6B58] mb-4 text-sm">Önizleme</h3>
 <div class="bg-[#0D0A08] rounded-sm p-4 border border-[rgba(184,115,51,0.14)]">
 <p id="preview-title" class="font-bold text-base mb-1 text-[#F5EDD6]">Bildirim Başlığı</p>
 <p id="preview-body" class="text-sm text-[#7A6B58] line-clamp-3">
 Bildirim açıklaması burada gösterilir
 </p>
 <p class="text-xs text-[#7A6B58] mt-3">sanliurfa.com</p>
 </div>
 <div class="mt-4 space-y-1.5 text-sm text-[#7A6B58]">
 <p><span class="font-medium text-[#1F1410]">Hedef:</span> <span id="preview-target">Tüm Aboneler</span></p>
 <p><span class="font-medium text-[#1F1410]">Zamanla:</span> <span id="preview-time">Hemen</span></p>
 <p><span class="font-medium text-[#1F1410]">Durum:</span> <span class="text-[#7A6B58]">Hazırlanıyor</span></p>
 </div>
 </div>
 </div>
 </div>

 <!-- Drafts Tab -->
 <div id="content-drafts" class="hidden">
 <div class="bg-[var(--bg-card)] border border-[rgba(184,115,51,0.14)] rounded-sm p-6">
 <h3 class="font-semibold text-[#7A6B58] mb-4 text-sm">Kaydedilmiş Taslaklar</h3>
 <div id="drafts-list" class="space-y-3">
 <p class="text-[#7A6B58] text-sm">Taslak yok</p>
 </div>
 </div>
 </div>

 <!-- History Tab -->
 <div id="content-history" class="hidden">
 <div class="bg-[var(--bg-card)] border border-[rgba(184,115,51,0.14)] rounded-sm p-6">
 <h3 class="font-semibold text-[#7A6B58] mb-4 text-sm">Gönderilen Bildirimler</h3>
 <div id="history-list" class="space-y-3">
 <p class="text-[#7A6B58] text-sm">Geçmiş yükleniyor...</p>
 </div>
 </div>
 </div>

 <!-- Stats Tab -->
 <div id="content-stats" class="hidden">
 <div class="grid grid-cols-4 gap-4 mb-6">
 <div class="bg-[var(--bg-card)] border border-[rgba(184,115,51,0.14)] rounded-sm p-6">
 <p class="text-[#7A6B58] text-sm">Toplam Gönderilen</p>
 <p id="stat-total" class="text-2xl font-bold text-[#1F1410]">0</p>
 </div>
 <div class="bg-[var(--bg-card)] border border-[rgba(184,115,51,0.14)] rounded-sm p-6">
 <p class="text-[#7A6B58] text-sm">Tıklanan</p>
 <p id="stat-clicked" class="text-2xl font-bold text-urfa-600">0</p>
 </div>
 <div class="bg-[var(--bg-card)] border border-[rgba(184,115,51,0.14)] rounded-sm p-6">
 <p class="text-[#7A6B58] text-sm">Abone Sayısı</p>
 <p id="stat-subscribers" class="text-2xl font-bold text-[#7A6B58]">0</p>
 </div>
 <div class="bg-[var(--bg-card)] border border-[rgba(184,115,51,0.14)] rounded-sm p-6">
 <p class="text-[#7A6B58] text-sm">Tıklama Oranı</p>
 <p id="stat-rate" class="text-2xl font-bold text-[#1F1410]">0%</p>
 </div>
 </div>
 <div class="bg-[var(--bg-card)] border border-[rgba(184,115,51,0.14)] rounded-sm p-6">
 <h3 class="font-semibold text-[#7A6B58] mb-4 text-sm">Son Bildirimler</h3>
 <div id="stats-detail" class="space-y-3">
 <p class="text-[#7A6B58] text-sm">İstatistik yükleniyor...</p>
 </div>
 </div>
 </div>
 </div>
</AdminLayout>

<script is:inline>
 // Tab yönetimi
 const tabs = {
 send: 'content-send',
 drafts: 'content-drafts',
 history: 'content-history',
 stats: 'content-stats'
 };

 Object.keys(tabs).forEach(tabName => {
 document.getElementById(`tab-${tabName}`).addEventListener('click', () => {
 Object.values(tabs).forEach(contentId => {
 document.getElementById(contentId).classList.add('hidden');
 });
 document.getElementById(tabs[tabName]).classList.remove('hidden');

 Object.keys(tabs).forEach(name => {
 const btn = document.getElementById(`tab-${name}`);
 if (name === tabName) {
 btn.classList.add('border-urfa-600', 'text-urfa-600');
 btn.classList.remove('border-transparent', 'text-[#7A6B58]');
 } else {
 btn.classList.remove('border-urfa-600', 'text-urfa-600');
 btn.classList.add('border-transparent', 'text-[#7A6B58]');
 }
 });

 if (tabName === 'stats') loadStats();
 if (tabName === 'history') loadHistory();
 if (tabName === 'drafts') loadDrafts();
 });
 });

 document.getElementById('notification-form').addEventListener('input', (e) => {
 const form = e.target.form;
 document.getElementById('preview-title').textContent = form.title.value || 'Bildirim Başlığı';
 document.getElementById('preview-body').textContent = form.body.value || 'Bildirim açıklaması burada gösterilir';
 document.getElementById('preview-target').textContent = form.target.value;
 document.getElementById('preview-time').textContent = form.scheduled_for.value ? 'Zamanlanmış' : 'Hemen';
 });

 async function saveDraft() {
 const form = document.getElementById('notification-form');
 const data = new FormData(form);
 try {
 const response = await fetch('/api/notifications/draft', {
 method: 'POST',
 headers: { 'Content-Type': 'application/json' },
 body: JSON.stringify(Object.fromEntries(data))
 });
 if (response.ok) {
 window.toast?.success('Taslak kaydedildi');
 form.reset();
 } else {
 window.toast?.error('Hata oluştu');
 }
 } catch {
 window.toast?.error('Bir hata oluştu');
 }
 }

 document.getElementById('notification-form').addEventListener('submit', async (e) => {
 e.preventDefault();
 const form = e.target;
 const data = new FormData(form);
 try {
 const response = await fetch('/api/notifications/send', {
 method: 'POST',
 headers: { 'Content-Type': 'application/json' },
 body: JSON.stringify(Object.fromEntries(data))
 });
 if (response.ok) {
 window.toast?.success('Bildirim gönderildi');
 form.reset();
 } else {
 const error = await response.json();
 window.toast?.error(error.error || 'Bildirim gönderilemedi');
 }
 } catch {
 window.toast?.error('Bir hata oluştu');
 }
 });

 function renderNotification(n) {
 const wrapper = document.createElement('div');
 wrapper.className = 'border border-[rgba(184,115,51,0.14)] rounded-sm p-4';

 const title = document.createElement('p');
 title.className = 'font-medium text-[#1F1410]';
 title.textContent = n.title;

 const body = document.createElement('p');
 body.className = 'text-sm text-[#7A6B58] mt-1';
 body.textContent = n.body;

 const meta = document.createElement('p');
 meta.className = 'text-xs text-[#7A6B58] mt-2';
 meta.textContent = `${new Date(n.sent_at).toLocaleString('tr-TR')} · ${n.recipient_count} kişi · ${n.click_count} tıkla`;

 wrapper.appendChild(title);
 wrapper.appendChild(body);
 wrapper.appendChild(meta);
 return wrapper;
 }

 function renderDraft(d, onDelete) {
 const wrapper = document.createElement('div');
 wrapper.className = 'border border-[rgba(184,115,51,0.14)] rounded-sm p-4';

 const row = document.createElement('div');
 row.className = 'flex justify-between items-start';

 const content = document.createElement('div');

 const title = document.createElement('p');
 title.className = 'font-medium text-[#1F1410]';
 title.textContent = d.title;

 const body = document.createElement('p');
 body.className = 'text-sm text-[#7A6B58] mt-1';
 body.textContent = d.body;

 content.appendChild(title);
 content.appendChild(body);

 const delBtn = document.createElement('button');
 delBtn.className = 'text-xs text-[#7A6B58] hover:text-[#1F1410] hover:underline ml-4 flex-shrink-0';
 delBtn.textContent = 'Sil';
 delBtn.addEventListener('click', onDelete);

 row.appendChild(content);
 row.appendChild(delBtn);
 wrapper.appendChild(row);
 return wrapper;
 }

 async function loadStats() {
 try {
 const response = await fetch('/api/notifications/stats');
 if (response.ok) {
 const data = await response.json();
 document.getElementById('stat-total').textContent = data.total || '0';
 document.getElementById('stat-clicked').textContent = data.clicked || '0';
 document.getElementById('stat-subscribers').textContent = data.subscribers || '0';
 document.getElementById('stat-rate').textContent = (data.rate || 0).toFixed(1) + '%';
 }
 } catch {
 // ignore
 }
 }

 async function loadHistory() {
 const list = document.getElementById('history-list');
 list.textContent = '';
 try {
 const response = await fetch('/api/notifications/history');
 const data = await response.json();
 if (data.notifications?.length) {
 data.notifications.forEach(n => list.appendChild(renderNotification(n)));
 } else {
 const empty = document.createElement('p');
 empty.className = 'text-[#7A6B58] text-sm';
 empty.textContent = 'Gönderilen bildirim yok';
 list.appendChild(empty);
 }
 } catch {
 // ignore
 }
 }

 async function loadDrafts() {
 const list = document.getElementById('drafts-list');
 list.textContent = '';
 try {
 const response = await fetch('/api/notifications/drafts');
 const data = await response.json();
 if (data.drafts?.length) {
 data.drafts.forEach(d => {
 list.appendChild(renderDraft(d, async () => {
 if (await window.showConfirm('Taslağı silmek istediğinize emin misiniz?')) {
 try {
 await fetch(`/api/notifications/drafts/${d.id}`, { method: 'DELETE' });
 loadDrafts();
 } catch {
 window.toast?.error('Hata oluştu');
 }
 }
 }));
 });
 } else {
 const empty = document.createElement('p');
 empty.className = 'text-[#7A6B58] text-sm';
 empty.textContent = 'Taslak yok';
 list.appendChild(empty);
 }
 } catch {
 // ignore
 }
 }

 window.saveDraft = saveDraft;
</script>
