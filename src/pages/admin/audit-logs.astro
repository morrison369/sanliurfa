---
import AdminLayout from '../../layouts/AdminLayoutV2.astro';
import AuditLogViewer from '../../components/admin/AuditLogViewer';
---

<AdminLayout
 title="Denetim Kayıtları"
 subtitle="Sistem aktivitesi ve değişiklikleri izle — kim, ne, ne zaman"
 seo={{ title: 'Denetim Kayıtları - Admin', noIndex: true }}
>
 <div class="al-page">
  <div class="al-panel">
   <AuditLogViewer client:idle />
  </div>
 </div>
</AdminLayout>

<style>
 .al-page { display: flex; flex-direction: column; gap: 1rem; }
 .al-panel {
  background: var(--adm-bg-elev);
  border: 1px solid var(--adm-border);
  border-radius: 12px;
  padding: 1.25rem;
 }
</style>
