---
import Layout from "../../layouts/Layout.astro";
import { query } from "../../lib/postgres";

const user = Astro.locals.user;
if (!user || !Astro.locals.isAdmin) {
  return Astro.redirect("/giris?redirect=/admin/sosyal");
}

let swipeStats = {
  profiles: 0,
  totalSwipes: 0,
  likeSwipes: 0,
  passSwipes: 0,
  totalMatches: 0,
  activeMatches: 0,
};

let recentSwipes: Array<{ swiper_id: string; target_id: string; direction: string; created_at: string }> = [];
let recentMatches: Array<{ id: number; user_a: string; user_b: string; created_at: string; is_active: boolean }> = [];
let moderationLogs: Array<{
  match_id: number;
  actor_user_id: string | null;
  action: string;
  reason: string | null;
  created_at: string;
}> = [];
let hasSwipeTables = true;

try {
  const [profilesRes, swipesRes, matchesRes, recentSwipesRes, recentMatchesRes, moderationLogsRes] = await Promise.all([
    query("SELECT COUNT(*) FROM social_swipe_profiles"),
    query(
      "SELECT COUNT(*) as total, COUNT(*) FILTER (WHERE direction = 'like') as likes, COUNT(*) FILTER (WHERE direction = 'pass') as passes FROM social_swipes"
    ),
    query(
      "SELECT COUNT(*) as total, COUNT(*) FILTER (WHERE is_active = TRUE) as active FROM social_matches"
    ),
    query(
      "SELECT swiper_id, target_id, direction, created_at FROM social_swipes ORDER BY created_at DESC LIMIT 20"
    ),
    query(
      "SELECT id, user_a, user_b, created_at, is_active FROM social_matches ORDER BY created_at DESC LIMIT 20"
    ),
    query(
      "SELECT match_id, actor_user_id, action, reason, created_at FROM social_match_moderation_logs ORDER BY created_at DESC LIMIT 30"
    ),
  ]);

  swipeStats = {
    profiles: parseInt(profilesRes.rows[0]?.count || "0", 10),
    totalSwipes: parseInt(swipesRes.rows[0]?.total || "0", 10),
    likeSwipes: parseInt(swipesRes.rows[0]?.likes || "0", 10),
    passSwipes: parseInt(swipesRes.rows[0]?.passes || "0", 10),
    totalMatches: parseInt(matchesRes.rows[0]?.total || "0", 10),
    activeMatches: parseInt(matchesRes.rows[0]?.active || "0", 10),
  };

  recentSwipes = recentSwipesRes.rows;
  recentMatches = recentMatchesRes.rows;
  moderationLogs = moderationLogsRes.rows;
} catch {
  hasSwipeTables = false;
}

const seo = {
  title: "Admin Sosyal Eşleşme - sanliurfa.com",
  noindex: true,
};
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-100 dark:bg-gray-900 py-8">
    <div class="container-custom space-y-6">
      <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Sosyal Eşleşme Yönetimi</h1>
        <a href="/admin" class="text-sm text-urfa-600 hover:text-urfa-700">Admin panele dön</a>
      </div>

      {
        !hasSwipeTables ? (
          <div class="rounded-xl border border-amber-200 bg-amber-50 p-4 text-amber-900">
            Sosyal eşleşme tabloları bulunamadı. Önce migration çalıştırın: <code>npm run migrate</code>
          </div>
        ) : (
          <>
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
              <div class="bg-white dark:bg-gray-800 rounded-xl p-4 shadow-sm"><div class="text-xs text-gray-500">Profil</div><div class="text-2xl font-bold text-urfa-600">{swipeStats.profiles}</div></div>
              <div class="bg-white dark:bg-gray-800 rounded-xl p-4 shadow-sm"><div class="text-xs text-gray-500">Swipe</div><div class="text-2xl font-bold text-blue-600">{swipeStats.totalSwipes}</div></div>
              <div class="bg-white dark:bg-gray-800 rounded-xl p-4 shadow-sm"><div class="text-xs text-gray-500">Like</div><div class="text-2xl font-bold text-green-600">{swipeStats.likeSwipes}</div></div>
              <div class="bg-white dark:bg-gray-800 rounded-xl p-4 shadow-sm"><div class="text-xs text-gray-500">Pass</div><div class="text-2xl font-bold text-gray-700 dark:text-gray-200">{swipeStats.passSwipes}</div></div>
              <div class="bg-white dark:bg-gray-800 rounded-xl p-4 shadow-sm"><div class="text-xs text-gray-500">Eşleşme</div><div class="text-2xl font-bold text-purple-600">{swipeStats.totalMatches}</div></div>
              <div class="bg-white dark:bg-gray-800 rounded-xl p-4 shadow-sm"><div class="text-xs text-gray-500">Aktif</div><div class="text-2xl font-bold text-emerald-600">{swipeStats.activeMatches}</div></div>
            </div>

            <div class="grid lg:grid-cols-2 gap-6">
              <section class="bg-white dark:bg-gray-800 rounded-xl p-5 shadow-sm">
                <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Son Swipe Kayıtları</h2>
                <div class="space-y-2 max-h-[480px] overflow-auto">
                  {recentSwipes.length === 0 ? (
                    <p class="text-sm text-gray-500">Kayıt bulunmuyor.</p>
                  ) : (
                    recentSwipes.map((row) => (
                      <div class="rounded-lg border border-gray-200 dark:border-gray-700 p-3 text-sm">
                        <div class="font-medium text-gray-900 dark:text-white">{row.direction === "like" ? "Like" : "Pass"}</div>
                        <div class="text-gray-600 dark:text-gray-300 break-all">swiper: {row.swiper_id}</div>
                        <div class="text-gray-600 dark:text-gray-300 break-all">target: {row.target_id}</div>
                        <div class="text-gray-500 mt-1">{new Date(row.created_at).toLocaleString("tr-TR")}</div>
                      </div>
                    ))
                  )}
                </div>
              </section>

              <section class="bg-white dark:bg-gray-800 rounded-xl p-5 shadow-sm">
                <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Son Eşleşmeler</h2>
                <div class="space-y-2 max-h-[480px] overflow-auto">
                  {recentMatches.length === 0 ? (
                    <p class="text-sm text-gray-500">Kayıt bulunmuyor.</p>
                  ) : (
                    recentMatches.map((row) => (
                      <div class="rounded-lg border border-gray-200 dark:border-gray-700 p-3 text-sm">
                        <div class="font-medium text-gray-900 dark:text-white">{row.is_active ? "Aktif" : "Pasif"} eşleşme</div>
                        <div class="text-gray-600 dark:text-gray-300 break-all">A: {row.user_a}</div>
                        <div class="text-gray-600 dark:text-gray-300 break-all">B: {row.user_b}</div>
                        <div class="text-gray-500 mt-1">{new Date(row.created_at).toLocaleString("tr-TR")}</div>
                        {row.is_active && (
                          <button
                            type="button"
                            data-deactivate-match={row.id}
                            class="mt-2 rounded-full border border-gray-300 px-3 py-1 text-xs font-semibold text-gray-700 dark:text-gray-200"
                          >
                            Eşleşmeyi pasifleştir
                          </button>
                        )}
                      </div>
                    ))
                  )}
                </div>
              </section>
            </div>

            <section class="bg-white dark:bg-gray-800 rounded-xl p-5 shadow-sm">
              <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Moderasyon Kayıtları</h2>
              <div class="space-y-2 max-h-[400px] overflow-auto">
                {moderationLogs.length === 0 ? (
                  <p class="text-sm text-gray-500">Kayıt bulunmuyor.</p>
                ) : (
                  moderationLogs.map((row) => (
                    <div class="rounded-lg border border-gray-200 dark:border-gray-700 p-3 text-sm">
                      <div class="font-medium text-gray-900 dark:text-white">{row.action}</div>
                      <div class="text-gray-600 dark:text-gray-300">match: {row.match_id}</div>
                      <div class="text-gray-600 dark:text-gray-300 break-all">actor: {row.actor_user_id || "system"}</div>
                      <div class="text-gray-600 dark:text-gray-300">reason: {row.reason || "-"}</div>
                      <div class="text-gray-500 mt-1">{new Date(row.created_at).toLocaleString("tr-TR")}</div>
                    </div>
                  ))
                )}
              </div>
            </section>
          </>
        )
      }
    </div>
  </div>
  <script is:inline>
    {
      const buttons = document.querySelectorAll('[data-deactivate-match]');
      buttons.forEach((button) => {
        button.addEventListener('click', async () => {
          const id = button.getAttribute('data-deactivate-match');
          if (!id) return;
          button.setAttribute('disabled', 'true');
          try {
            const reason = window.prompt('Pasifleştirme gerekçesini yazın (en az 10 karakter):', 'Moderasyon gereği pasifleştirildi');
            if (!reason || reason.trim().length < 10) {
              throw new Error('invalid-reason');
            }
            const response = await fetch(`/api/admin/social/matches/${id}/deactivate`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ reason })
            });
            if (!response.ok) {
              throw new Error('İşlem başarısız');
            }
            window.location.reload();
          } catch {
            button.removeAttribute('disabled');
            alert('Eşleşme pasifleştirilemedi. Gerekçe en az 10 karakter olmalı.');
          }
        });
      });
    }
  </script>
</Layout>
