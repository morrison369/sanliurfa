  seo={{ title: 'Mekan Doğrulama Yönetimi - Yönetim Paneli', noIndex: true }}
>
    <div class="container mx-auto px-4 py-8 max-w-6xl">
      <div class="mb-6">
        <a href="/admin" class="text-sm text-[#9A8470] hover:text-[#6B5540]">← Admin Paneli</a>
      </div>

      <AdminVerificationQueue client:visible />
    </div>
</AdminLayout>
