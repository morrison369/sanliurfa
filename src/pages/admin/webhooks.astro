---
import AdminLayout from '../../layouts/AdminLayoutV2.astro';
import WebhookManager from '../../components/WebhookManager';
import WebhookAnalyticsDashboard from '../../components/WebhookAnalyticsDashboard';

const user = Astro.locals.user;
if (!user || !Astro.locals.isAdmin) {
  return Astro.redirect(`/giris?redirect=${Astro.url.pathname}`);
}
---

<AdminLayout
  title="Webhook Yönetimi"
  subtitle="Webhook entegrasyonları oluşturun, test edin ve performansını izleyin"
  breadcrumbs={[{ label: 'Sistem', href: '/admin' }, { label: 'Webhook Yönetimi' }]}
  seo={{ title: 'Webhook Yönetimi - Admin', noIndex: true }}
>
  <div class="wh-page">
    <div class="wh-section">
      <WebhookAnalyticsDashboard token="" client:idle />
    </div>
    <div class="wh-section">
      <WebhookManager token="" client:load />
    </div>
  </div>
</AdminLayout>

<style>
  .wh-page { display: flex; flex-direction: column; gap: 1rem; }
  .wh-section {
    background: var(--adm-bg-elev);
    border: 1px solid var(--adm-border);
    border-radius: 14px;
    padding: 1.25rem;
  }
</style>
