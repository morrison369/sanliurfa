---
import Layout from '../../layouts/Layout.astro';
import AnalyticsPanel from '../../components/AnalyticsPanel';
import AdminAnalyticsDashboard from '../../components/AdminAnalyticsDashboard';
import AdminPerformanceDashboard from '../../components/AdminPerformanceDashboard';

// Check admin access
const user = Astro.locals.user;
if (!user || user.role !== 'admin') {
  return Astro.redirect(`/giris?redirect=${encodeURIComponent(Astro.url.pathname)}`);
}

const seo = {
  title: 'Analitik - Yönetim Paneli',
  description: 'Sistem analitikleri ve istatistikleri',
  noindex: true
};
---

<Layout seo={seo}>
  <div class="bg-gray-50 dark:bg-gray-900 min-h-screen pt-20">
    <div class="container-custom py-8">
      <div class="mb-12">
        <h1 class="text-4xl font-bold mb-2">Analitikler</h1>
        <p class="text-gray-600 dark:text-gray-400">Platform çapında istatistikler ve içgörüler</p>
      </div>

      <div class="space-y-12">
        <section>
          <h2 class="text-2xl font-bold mb-6">Performans İzleme</h2>
          <AdminPerformanceDashboard client:load />
        </section>
        <hr class="dark:border-gray-700" />
        <section>
          <h2 class="text-2xl font-bold mb-6">Platform Analitikleri</h2>
          <AdminAnalyticsDashboard client:load />
        </section>
        <hr class="dark:border-gray-700" />
        <section>
          <h2 class="text-2xl font-bold mb-6">Sistem Metrikleri</h2>
          <AnalyticsPanel client:load />
        </section>
      </div>
    </div>
  </div>
</Layout>
