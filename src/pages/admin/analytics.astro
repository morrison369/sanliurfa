---
import AdminLayout from '../../layouts/AdminLayout.astro';
import AnalyticsPanel from '../../components/AnalyticsPanel';
import AdminAnalyticsDashboard from '../../components/AdminAnalyticsDashboard';
import AdminPerformanceDashboard from '../../components/AdminPerformanceDashboard';
import WebVitalsCard from '../../components/admin/WebVitalsCard';
---

<AdminLayout
  title="Analitikler"
  subtitle="Platform çapında istatistikler ve içgörüler"
  seo={{ title: 'Analitik - Admin', description: 'Sistem analitikleri ve istatistikleri' }}
>
    <div class="container mx-auto px-4 py-8">
      <div class="space-y-12">
        <section>
          <h2 class="text-2xl font-bold mb-6 text-[#1A1008]">Web Vitals (Real User Monitoring)</h2>
          <WebVitalsCard client:visible />
        </section>
        <hr class="border-[rgba(200,160,100,0.2)]" />
        <section>
          <h2 class="text-2xl font-bold mb-6 text-[#1A1008]">Performans İzleme</h2>
          <AdminPerformanceDashboard client:visible />
        </section>
        <hr class="border-[rgba(200,160,100,0.2)]" />
        <section>
          <h2 class="text-2xl font-bold mb-6 text-[#1A1008]">Platform Analitiği</h2>
          <AdminAnalyticsDashboard client:visible />
        </section>
        <hr class="border-[rgba(200,160,100,0.2)]" />
        <section>
          <h2 class="text-2xl font-bold mb-6 text-[#1A1008]">Sistem Metrikleri</h2>
          <AnalyticsPanel client:visible />
        </section>
      </div>
</AdminLayout>
