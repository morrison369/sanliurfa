---
import Layout from '../../layouts/Layout.astro';
import AnalyticsPanel from '../../components/AnalyticsPanel.astro';
import AdminAnalyticsDashboard from '../../components/AdminAnalyticsDashboard.astro';
import AdminPerformanceDashboard from '../../components/AdminPerformanceDashboard.astro';

// Check admin access
const user = Astro.locals.user;
if (!user || user.role !== 'admin') {
  return Astro.redirect('/giris');
}

const seo = {
  title: 'Analitik - Admin',
  description: 'Sistem analitikleri ve istatistikleri',
  noindex: true
};
---

<Layout seo={seo}>
  <div class="bg-gray-50 dark:bg-gray-900 min-h-screen pt-20">
    <div class="container-custom py-8">
      <div class="mb-12">
        <h1 class="text-4xl font-bold mb-2">Analitikler</h1>
        <p class="text-gray-600 dark:text-gray-400">Platform çapında istatistikler ve içgörüler</p>
      </div>

      <div class="space-y-12">
        <section>
          <h2 class="text-2xl font-bold mb-6">Performans izleme</h2>
          <AdminPerformanceDashboard />
        </section>
        <hr class="dark:border-gray-700" />
        <section>
          <h2 class="text-2xl font-bold mb-6">Platform analitiği</h2>
          <AdminAnalyticsDashboard />
        </section>
        <hr class="dark:border-gray-700" />
        <section>
          <h2 class="text-2xl font-bold mb-6">Sistem metrikleri</h2>
          <AnalyticsPanel />
        </section>
      </div>
    </div>
  </div>
</Layout>
