---
/**
 * Admin - E-posta kampanyalari
 * E-posta pazarlama kampanyalarini ve akislari yonet
 */

import Layout from '../../layouts/Layout.astro';
import { getAllCampaigns } from '../../lib/email-campaigns';
import { getSequence, getSequenceSteps } from '../../lib/email-automation';

// Check auth
if (!Astro.locals.user?.isAdmin) {
  return Astro.redirect('/giris');
}

// Fetch campaigns and sequences
const campaigns = await getAllCampaigns(100);
---

<Layout title="Kampanyalar - Yönetim Paneli">
  <div class="container mx-auto px-4 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold mb-2">E-posta kampanyaları</h1>
      <p class="text-gray-600">Pazarlama kampanyalarını ve otomasyon akışlarını yönetin.</p>
    </div>

    <!-- Tabs -->
    <div class="tabs mb-8" role="tablist">
      <button
        class="tab-button active px-6 py-3 font-medium border-b-2 border-blue-500 text-blue-600"
        role="tab"
        data-tab="campaigns"
      >
        Kampanya listesi
      </button>
      <button
        class="tab-button px-6 py-3 font-medium border-b-2 border-transparent text-gray-600 hover:text-gray-800"
        role="tab"
        data-tab="create"
      >
        Yeni kampanya
      </button>
      <button
        class="tab-button px-6 py-3 font-medium border-b-2 border-transparent text-gray-600 hover:text-gray-800"
        role="tab"
        data-tab="analytics"
      >
        Kampanya analitiği
      </button>
      <button
        class="tab-button px-6 py-3 font-medium border-b-2 border-transparent text-gray-600 hover:text-gray-800"
        role="tab"
        data-tab="sequences"
      >
        Otomasyon akışları
      </button>
    </div>

    <!-- Campaigns Tab -->
    <div id="campaigns-tab" class="tab-content">
      <div class="grid gap-4">
        {campaigns.length > 0 ? (
          campaigns.map((campaign) => (
            <div class="bg-white p-6 rounded-lg shadow border border-gray-200">
              <div class="flex justify-between items-start mb-4">
                <div>
                  <h3 class="text-lg font-bold">{campaign.name}</h3>
                  <p class="text-sm text-gray-600">{campaign.subject}</p>
                </div>
                <div class="flex gap-2">
                  <span class={`px-3 py-1 rounded-full text-xs font-semibold ${
                    campaign.status === 'completed' ? 'bg-green-100 text-green-800' :
                    campaign.status === 'sending' ? 'bg-blue-100 text-blue-800' :
                    campaign.status === 'scheduled' ? 'bg-yellow-100 text-yellow-800' :
                    'bg-gray-100 text-gray-800'
                  }`}>
                    {campaign.status === 'draft' ? 'Taslak' :
                     campaign.status === 'sending' ? 'Gönderiliyor' :
                     campaign.status === 'scheduled' ? 'Planlandı' :
                     campaign.status === 'completed' ? 'Tamamlandı' :
                     campaign.status}
                  </span>
                </div>
              </div>

              <div class="grid grid-cols-2 gap-4 mb-4 text-sm">
                <div>
                  <span class="text-gray-600">Gönderim:</span>
                  <span class="font-semibold ml-2">{campaign.sendCount}</span>
                </div>
                <div>
                  <span class="text-gray-600">Açılma:</span>
                  <span class="font-semibold ml-2">{campaign.openCount} ({campaign.sendCount > 0 ? Math.round((campaign.openCount / campaign.sendCount) * 100) : 0}%)</span>
                </div>
                <div>
                  <span class="text-gray-600">Tıklama:</span>
                  <span class="font-semibold ml-2">{campaign.clickCount} ({campaign.sendCount > 0 ? Math.round((campaign.clickCount / campaign.sendCount) * 100) : 0}%)</span>
                </div>
                <div>
                  <span class="text-gray-600">Abonelikten çıkış:</span>
                  <span class="font-semibold ml-2">{campaign.unsubscribeCount}</span>
                </div>
              </div>

              <div class="flex gap-2">
                <button
                  class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 text-sm"
                  onclick="sendCampaign({campaign.id})"
                >
                  Hemen gönder
                </button>
                <button
                  class="px-4 py-2 bg-gray-200 text-gray-800 rounded hover:bg-gray-300 text-sm"
                  onclick="testCampaign({campaign.id})"
                >
                  Test gönder
                </button>
                <button
                  class="px-4 py-2 bg-gray-100 text-gray-800 rounded hover:bg-gray-200 text-sm"
                  onclick="editCampaign({campaign.id})"
                >
                  Düzenle
                </button>
              </div>
            </div>
          ))
        ) : (
          <div class="bg-gray-50 p-8 rounded-lg text-center">
            <p class="text-gray-600">Henüz kampanya bulunmuyor</p>
            <button onclick="switchTab('create')" class="mt-4 px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">
              İlk kampanyanızı oluşturun
            </button>
          </div>
        )}
      </div>
    </div>

    <!-- Create Campaign Tab -->
    <div id="create-tab" class="tab-content hidden">
      <form id="campaign-form" class="bg-white p-6 rounded-lg shadow max-w-2xl">
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium mb-1">Kampanya adı</label>
            <input
              type="text"
              name="name"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded"
              placeholder="ör: Hoş geldin kampanyası"
            />
          </div>

          <div>
            <label class="block text-sm font-medium mb-1">Konu</label>
            <input
              type="text"
              name="subject"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded"
                placeholder="E-posta konusu"
            />
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
            <label class="block text-sm font-medium mb-1">Gönderici adı</label>
              <input
                type="text"
                name="fromName"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded"
                placeholder="ör: Şanlıurfa.com"
              />
            </div>
            <div>
            <label class="block text-sm font-medium mb-1">Gönderici e-posta</label>
              <input
                type="email"
                name="fromEmail"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded"
                placeholder="noreply@sanliurfa.com"
              />
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium mb-1">Hedef kitle</label>
            <select name="segment" required class="w-full px-4 py-2 border border-gray-300 rounded">
              <option value="">Hedef kitle seçin...</option>
              <option value="all_users">Tüm Kullanıcılar</option>
              <option value="subscribers">Abone Olanlar</option>
              <option value="premium">Premium Üyeler</option>
              <option value="inactive">30+ Gün Pasif</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium mb-1">HTML içerik</label>
            <textarea
              name="htmlContent"
              required
              rows="10"
              class="w-full px-4 py-2 border border-gray-300 rounded font-mono text-sm"
                      placeholder="HTML e-posta içeriği"
            ></textarea>
          </div>

          <div>
            <label class="block text-sm font-medium mb-1">Zamanlama</label>
            <select name="timing" class="w-full px-4 py-2 border border-gray-300 rounded">
              <option value="now">Hemen gönder</option>
              <option value="schedule">Zamanla...</option>
            </select>
          </div>

          <div class="flex gap-2">
            <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">
              Kampanya oluştur
            </button>
            <button type="reset" class="px-6 py-2 bg-gray-200 text-gray-800 rounded hover:bg-gray-300">
              Formu temizle
            </button>
          </div>
        </div>
      </form>
    </div>

    <!-- Analytics Tab -->
    <div id="analytics-tab" class="tab-content hidden">
      <div class="grid grid-cols-2 gap-4">
        <div class="bg-white p-6 rounded-lg shadow">
          <h3 class="text-gray-600 text-sm font-medium mb-2">Ortalama açılma oranı</h3>
          <p class="text-3xl font-bold">
            {campaigns.length > 0 ? (
              campaigns.reduce((sum, c) => sum + (c.sendCount > 0 ? (c.openCount / c.sendCount) * 100 : 0), 0) / campaigns.length
            ).toFixed(1) : 0}%
          </p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow">
          <h3 class="text-gray-600 text-sm font-medium mb-2">Ortalama tıklama oranı</h3>
          <p class="text-3xl font-bold">
            {campaigns.length > 0 ? (
              campaigns.reduce((sum, c) => sum + (c.sendCount > 0 ? (c.clickCount / c.sendCount) * 100 : 0), 0) / campaigns.length
            ).toFixed(1) : 0}%
          </p>
        </div>
      </div>
    </div>

    <!-- Sequences Tab -->
    <div id="sequences-tab" class="tab-content hidden">
      <div class="bg-white p-6 rounded-lg shadow">
        <h3 class="font-bold mb-4">Otomasyon akışları</h3>
        <p class="text-gray-600">Otomasyon akışları, belirli olaylara yanıt olarak tetiklenen e-posta serileridir.</p>
        <ul class="mt-4 space-y-2 text-sm">
          <li class="flex items-center gap-2">
            <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
            <span><strong>Hoş geldin serisi:</strong> Yeni üye kaydolduğunda başlayıp 7 gün süren selamlama akışı</span>
          </li>
          <li class="flex items-center gap-2">
            <span class="w-2 h-2 bg-green-500 rounded-full"></span>
            <span><strong>Premium karşılama:</strong> Premium abonelik başladığında devreye giren karşılama akışı</span>
          </li>
          <li class="flex items-center gap-2">
            <span class="w-2 h-2 bg-orange-500 rounded-full"></span>
            <span><strong>Geri kazanım:</strong> 30+ gün pasif kullanıcılara yeniden katılım daveti</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Tab switching
  function switchTab(tabName: string) {
    // Hide all tabs
    document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
    document.querySelectorAll('.tab-button').forEach(el => el.classList.remove('active', 'border-blue-500', 'text-blue-600'));

    // Show selected tab
    const tabEl = document.getElementById(`${tabName}-tab`);
    if (tabEl) {
      tabEl.classList.remove('hidden');
    }

    // Update button state
    const btn = document.querySelector(`[data-tab="${tabName}"]`);
    if (btn) {
      btn.classList.add('active', 'border-blue-500', 'text-blue-600');
      btn.classList.remove('border-transparent', 'text-gray-600');
    }
  }

  // Tab button click handlers
  document.querySelectorAll('.tab-button').forEach(btn => {
    btn.addEventListener('click', () => {
      const tabName = (btn as HTMLElement).getAttribute('data-tab');
      if (tabName) switchTab(tabName);
    });
  });

  // Campaign actions
  function sendCampaign(campaignId: number) {
    if (confirm('Kampanya gönderilsin mi?')) {
      // Send to API
      fetch(`/api/marketing/campaigns/${campaignId}/send`, { method: 'POST' })
        .then(r => r.json())
        .then(data => {
          if (data.success) {
            alert('Kampanya gönderimi başlatıldı.');
            location.reload();
          } else {
            alert('Kampanya gönderilemedi: ' + data.error);
          }
        })
        .catch(error => {
          console.error('Kampanya gönderimi başlatılamadı:', error);
          alert('Kampanya gönderilemedi. Lütfen tekrar deneyin.');
        });
    }
  }

  function testCampaign(campaignId: number) {
    fetch(`/api/marketing/campaigns/${campaignId}/send`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ testMode: true })
    })
      .then(r => r.json())
        .then(data => {
        if (data.success) {
          alert('Test e-postası yönetici hesabına gönderildi.');
        } else {
          alert('Test gönderimi başarısız: ' + data.error);
        }
      })
      .catch(error => {
        console.error('Test gönderimi başlatılamadı:', error);
        alert('Test gönderimi başarısız. Lütfen tekrar deneyin.');
      });
  }

  function editCampaign(campaignId: number) {
    alert('Kampanya düzenleme özelliği yakında eklenecek.');
  }

  // Form submission
  document.getElementById('campaign-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const data = new FormData(form);

    const payload = {
      name: data.get('name'),
      subject: data.get('subject'),
      fromName: data.get('fromName'),
      fromEmail: data.get('fromEmail'),
      segment: data.get('segment'),
      htmlContent: data.get('htmlContent'),
      textContent: '',
      status: 'draft'
    };

    try {
      const response = await fetch('/api/marketing/campaigns', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      const result = await response.json();
      if (result.success) {
        alert('Kampanya oluşturuldu.');
        form.reset();
        location.reload();
      } else {
        alert('Kampanya oluşturulamadı: ' + result.error);
      }
    } catch (error) {
      console.error('Kampanya oluşturulamadı:', error);
      alert('Kampanya oluşturulamadı. Lütfen tekrar deneyin.');
    }
  });
</script>

<style>
  .tab-button {
    cursor: pointer;
    transition: all 0.2s;
  }

  .tab-button:hover {
    color: #1f2937;
  }

  .tab-content {
    animation: fadeIn 0.2s;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>
