---
/**
 * Admin - Email Campaigns
 * Manage email marketing campaigns and sequences
 */

import AdminLayout from '../../layouts/AdminLayout.astro';
import { getAllCampaigns } from '../../lib/email/email-campaigns';
import { logger } from '../../lib/logging';

let campaigns: Awaited<ReturnType<typeof getAllCampaigns>> = [];
try {
 campaigns = await getAllCampaigns(100);
} catch (e) {
 logger.error('Admin campaigns query failed', e instanceof Error ? e : new Error(String(e)));
}
---

<AdminLayout
 title="Email Kampanyaları"
 subtitle="Pazarlama kampanyalarını ve otomasyon akışlarını yönet"
 seo={{ title: 'Kampanyalar - Admin' }}
>
 <div class="sf-container py-8 max-w-5xl">
 <div class="mb-6">
 <a href="/admin" class="text-sm text-[#7A6B58] hover:text-[#7A6B58]">← Admin Paneli</a>
 </div>

 <!-- Tabs -->
 <div class="mb-8 flex border-b border-[rgba(184,115,51,0.14)]" role="tablist">
 <button class="tab-button active px-6 py-3 font-medium text-sm border-b-2 border-urfa-600 text-urfa-600"
 role="tab"
 data-tab="campaigns"
 >
 Kampanyalar
 </button>
 <button class="tab-button px-6 py-3 font-medium text-sm border-b-2 border-transparent text-[#7A6B58] hover:text-[#7A6B58]"
 role="tab"
 data-tab="create"
 >
 Yeni Kampanya
 </button>
 <button class="tab-button px-6 py-3 font-medium text-sm border-b-2 border-transparent text-[#7A6B58] hover:text-[#7A6B58]"
 role="tab"
 data-tab="analytics"
 >
 Analitik
 </button>
 <button class="tab-button px-6 py-3 font-medium text-sm border-b-2 border-transparent text-[#7A6B58] hover:text-[#7A6B58]"
 role="tab"
 data-tab="sequences"
 >
 Otomasyon
 </button>
 </div>

 <!-- Campaigns Tab -->
 <div id="campaigns-tab" class="tab-content">
 <div class="grid gap-4">
 {campaigns.length > 0 ? (
 campaigns.map((campaign) => (
 <div class="bg-[var(--bg-card)] p-6 rounded-sm border border-[rgba(184,115,51,0.14)] shadow-sm">
 <div class="flex justify-between items-start mb-4">
 <div>
 <h3 class="text-lg font-bold text-[#1F1410]">{campaign.name}</h3>
 <p class="text-sm text-[#7A6B58]">{campaign.subject}</p>
 </div>
 <div class="flex gap-2">
 <span class={`px-2 py-0.5 rounded-sm text-xs font-medium ${
 campaign.status === 'completed' ? 'bg-[rgba(184,115,51,0.15)] text-[#7A6B58]' :
 campaign.status === 'active' ? 'bg-[rgba(184,115,51,0.2)] text-[#7A6B58]' :
 campaign.status === 'scheduled' ? 'bg-[rgba(184,115,51,0.1)] text-[#7A6B58]' :
 'bg-[rgba(184,115,51,0.06)] text-[#7A6B58]'
 }`}>
 {campaign.status === 'draft' ? 'Taslak' :
 campaign.status === 'active' ? 'Gönderiliyor' :
 campaign.status === 'scheduled' ? 'Planlandı' :
 campaign.status === 'completed' ? 'Tamamlandı' :
 campaign.status}
 </span>
 </div>
 </div>

 <div class="grid grid-cols-2 gap-4 mb-4 text-sm">
 <div>
 <span class="text-[#7A6B58]">Gönderilen:</span>
 <span class="font-semibold text-[#1F1410] ml-2">{campaign.sendCount}</span>
 </div>
 <div>
 <span class="text-[#7A6B58]">Açılan:</span>
 <span class="font-semibold text-[#1F1410] ml-2">{campaign.openCount} ({campaign.sendCount > 0 ? Math.round((campaign.openCount / campaign.sendCount) * 100) : 0}%)</span>
 </div>
 <div>
 <span class="text-[#7A6B58]">Tıklanan:</span>
 <span class="font-semibold text-[#1F1410] ml-2">{campaign.clickCount} ({campaign.sendCount > 0 ? Math.round((campaign.clickCount / campaign.sendCount) * 100) : 0}%)</span>
 </div>
 <div>
 <span class="text-[#7A6B58]">Abonelikten Çıkan:</span>
 <span class="font-semibold text-[#1F1410] ml-2">{campaign.unsubscribeCount}</span>
 </div>
 </div>

 <div class="flex gap-2">
 <button class="px-4 py-2 rounded-sm bg-urfa-600 text-white hover:bg-urfa-700 text-sm" onclick={`sendCampaign(${JSON.stringify(campaign.id)})`}>
 Hemen Gönder
 </button>
 <button class="px-4 py-2 bg-[rgba(184,115,51,0.06)] text-[#7A6B58] rounded-sm hover:bg-[rgba(184,115,51,0.12)] text-sm" onclick={`testCampaign(${JSON.stringify(campaign.id)})`}>
 Test Gönder
 </button>
 <button class="px-4 py-2 bg-[rgba(184,115,51,0.04)] text-[#7A6B58] rounded-sm hover:bg-[rgba(184,115,51,0.08)] text-sm" onclick={`editCampaign(${JSON.stringify(campaign.id)})`}>
 Düzenle
 </button>
 </div>
 </div>
 ))
 ) : (
 <div class="bg-[rgba(184,115,51,0.04)] p-8 rounded-sm text-center border border-[rgba(184,115,51,0.14)]">
 <p class="text-[#7A6B58]">Henüz kampanya yok</p>
 <button onclick="switchTab('create')" class="mt-4 px-4 py-2 rounded-sm bg-urfa-600 text-white hover:bg-urfa-700 text-sm">
 İlk Kampanyanızı Oluşturun
 </button>
 </div>
 )}
 </div>
 </div>

 <!-- Create Campaign Tab -->
 <div id="create-tab" class="tab-content hidden">
 <form id="campaign-form" class="bg-[var(--bg-card)] p-6 rounded-sm border border-[rgba(184,115,51,0.14)] shadow-sm max-w-2xl">
 <input type="hidden" name="campaignId" value="" />
 <div class="space-y-4">
 <div id="edit-mode-banner" class="hidden rounded-sm border border-[rgba(184,115,51,0.2)] bg-[rgba(184,115,51,0.06)] px-4 py-3 text-sm text-[#7A6B58]">
 Kampanya düzenleniyor. Kaydettiğinizde mevcut taslak güncellenecek.
 </div>
 <div>
 <label class="block text-sm font-medium text-[#7A6B58] mb-1">Kampanya Adı</label>
 <input
 type="text"
 name="name"
 required
 class="w-full px-3 py-2 border border-[rgba(184,115,51,0.2)] rounded-sm text-sm"
 placeholder="ör: Hoş geldin kampanyası"
 />
 </div>

 <div>
 <label class="block text-sm font-medium text-[#7A6B58] mb-1">Konu</label>
 <input
 type="text"
 name="subject"
 required
 class="w-full px-3 py-2 border border-[rgba(184,115,51,0.2)] rounded-sm text-sm"
 placeholder="Email konusu"
 />
 </div>

 <div class="grid grid-cols-2 gap-4">
 <div>
 <label class="block text-sm font-medium text-[#7A6B58] mb-1">Gönderici Adı</label>
 <input
 type="text"
 name="fromName"
 required
 class="w-full px-3 py-2 border border-[rgba(184,115,51,0.2)] rounded-sm text-sm"
 placeholder="ör: Sanliurfa.com"
 />
 </div>
 <div>
 <label class="block text-sm font-medium text-[#7A6B58] mb-1">Gönderici Email</label>
 <input
 type="email"
 name="fromEmail"
 required
 class="w-full px-3 py-2 border border-[rgba(184,115,51,0.2)] rounded-sm text-sm"
 placeholder="noreply@sanliurfa.com"
 />
 </div>
 </div>

 <div>
 <label class="block text-sm font-medium text-[#7A6B58] mb-1">Segment</label>
 <select name="segment" required class="w-full px-3 py-2 border border-[rgba(184,115,51,0.2)] rounded-sm text-sm">
 <option value="">Seç...</option>
 <option value="all_users">Tüm Kullanıcılar</option>
 <option value="subscribers">Abone Olanlar</option>
 <option value="premium">Premium Üyeler</option>
 <option value="inactive">30+ Gün Inaktif</option>
 </select>
 </div>

 <div>
 <label class="block text-sm font-medium text-[#7A6B58] mb-1">HTML İçerik</label>
 <textarea
 name="htmlContent"
 required
 rows="10"
 class="w-full px-3 py-2 border border-[rgba(184,115,51,0.2)] rounded-sm font-mono text-sm"
 placeholder="HTML email içeriği"
 ></textarea>
 </div>

 <div>
 <label class="block text-sm font-medium text-[#7A6B58] mb-1">Zamanlama</label>
 <select name="timing" class="w-full px-3 py-2 border border-[rgba(184,115,51,0.2)] rounded-sm text-sm">
 <option value="now">Hemen Gönder</option>
 <option value="schedule">Zamanla...</option>
 </select>
 </div>

 <div class="flex gap-2">
 <button type="submit" class="px-6 py-2 rounded-sm bg-urfa-600 text-white hover:bg-urfa-700 text-sm">
 <span id="campaign-submit-label">Kampanya Oluştur</span>
 </button>
 <button type="reset" class="px-6 py-2 bg-[rgba(184,115,51,0.06)] text-[#7A6B58] rounded-sm hover:bg-[rgba(184,115,51,0.12)] text-sm">
 Temizle
 </button>
 </div>
 </div>
 </form>
 </div>

 <!-- Analytics Tab -->
 <div id="analytics-tab" class="tab-content hidden">
 <div class="grid grid-cols-2 gap-4">
 <div class="bg-[var(--bg-card)] p-6 rounded-sm border border-[rgba(184,115,51,0.14)] shadow-sm">
 <h3 class="text-[#7A6B58] text-sm font-medium mb-2">Ortalama Açılma Oranı</h3>
 <p class="text-3xl font-bold text-[#1F1410]">
 {campaigns.length > 0 ? (
 campaigns.reduce((sum, c) => sum + (c.sendCount > 0 ? (c.openCount / c.sendCount) * 100 : 0), 0) / campaigns.length
 ).toFixed(1) : 0}%
 </p>
 </div>
 <div class="bg-[var(--bg-card)] p-6 rounded-sm border border-[rgba(184,115,51,0.14)] shadow-sm">
 <h3 class="text-[#7A6B58] text-sm font-medium mb-2">Ortalama Tıklama Oranı</h3>
 <p class="text-3xl font-bold text-[#1F1410]">
 {campaigns.length > 0 ? (
 campaigns.reduce((sum, c) => sum + (c.sendCount > 0 ? (c.clickCount / c.sendCount) * 100 : 0), 0) / campaigns.length
 ).toFixed(1) : 0}%
 </p>
 </div>
 </div>
 </div>

 <!-- Sequences Tab -->
 <div id="sequences-tab" class="tab-content hidden">
 <div class="bg-[var(--bg-card)] p-6 rounded-sm border border-[rgba(184,115,51,0.14)] shadow-sm">
 <h3 class="font-bold text-[#1F1410] mb-4">Otomasyon Akışları</h3>
 <p class="text-[#7A6B58] text-sm">Otomasyon akışları kullanıcıların belirli olaylara yanıt olarak tetiklenen email serileridir.</p>
 <ul class="mt-4 space-y-2 text-sm">
 <li class="flex items-center gap-2">
 <span class="w-2 h-2 bg-urfa-600 rounded-full flex-shrink-0"></span>
 <span class="text-[#7A6B58]"><strong class="text-[#1F1410]">Hoş Geldin Serisi:</strong> Yeni üye kaydolduğunda başlayıp 7 gün süren selamlaşma</span>
 </li>
 <li class="flex items-center gap-2">
 <span class="w-2 h-2 bg-urfa-600 rounded-full flex-shrink-0"></span>
 <span class="text-[#7A6B58]"><strong class="text-[#1F1410]">Premium Onboarding:</strong> Premium abonelik başladığında başlayan selamlaşma</span>
 </li>
 <li class="flex items-center gap-2">
 <span class="w-2 h-2 bg-urfa-600 rounded-full flex-shrink-0"></span>
 <span class="text-[#7A6B58]"><strong class="text-[#1F1410]">Geri Kazanım:</strong> 30+ gün inaktif kullanıcılara yeniden katılım daveti</span>
 </li>
 </ul>
 </div>
 </div>
 </div>
</AdminLayout>

<script is:inline define:vars={{ campaignsJson: JSON.stringify(campaigns) }}>
 const campaigns = JSON.parse(campaignsJson);

 function switchTab(tabName) {
 document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
 document.querySelectorAll('.tab-button').forEach(el => {
 el.classList.remove('active', 'border-urfa-600', 'text-urfa-600');
 el.classList.add('border-transparent', 'text-[#7A6B58]');
 });

 const tabEl = document.getElementById(`${tabName}-tab`);
 if (tabEl) tabEl.classList.remove('hidden');

 const btn = document.querySelector(`[data-tab="${tabName}"]`);
 if (btn) {
 btn.classList.add('active', 'border-urfa-600', 'text-urfa-600');
 btn.classList.remove('border-transparent', 'text-[#7A6B58]');
 }
 }

 document.querySelectorAll('.tab-button').forEach(btn => {
 btn.addEventListener('click', () => {
 const tabName = btn.getAttribute('data-tab');
 if (tabName) switchTab(tabName);
 });
 });

 async function sendCampaign(campaignId) {
 if (await window.showConfirm('Kampanyayı gönder?')) {
 fetch(`/api/marketing/campaigns/${campaignId}/send`, { method: 'POST' })
 .then(r => r.json())
 .then(data => {
 if (data.success) {
 window.toast?.success('Kampanya gönderilmeye başladı!');
 location.reload();
 } else {
 window.toast?.error('Hata: ' + (data.error || 'Gönderilemedi'));
 }
 });
 }
 }

 function testCampaign(campaignId) {
 fetch(`/api/marketing/campaigns/${campaignId}/send`, {
 method: 'POST',
 headers: { 'Content-Type': 'application/json' },
 body: JSON.stringify({ testMode: true })
 })
 .then(r => r.json())
 .then(data => {
 if (data.success) {
 window.toast?.success('Test emaili admin hesabına gönderildi!');
 } else {
 window.toast?.error('Hata: ' + (data.error || 'Gönderilemedi'));
 }
 });
 }

 function editCampaign(campaignId) {
 const campaign = campaigns.find((item) => String(item.id) === String(campaignId));
 const form = document.getElementById('campaign-form');
 if (!campaign || !(form instanceof HTMLFormElement)) return;
 const field = (name) => form.elements.namedItem(name);

 field('campaignId').value = campaign.id || '';
 field('name').value = campaign.name || '';
 field('subject').value = campaign.subject || '';
 field('fromName').value = campaign.fromName || '';
 field('fromEmail').value = campaign.fromEmail || '';
 field('segment').value = campaign.segment || 'all_users';
 field('htmlContent').value = campaign.htmlContent || '';
 field('timing').value = campaign.scheduledAt ? 'schedule' : 'now';

 document.getElementById('edit-mode-banner')?.classList.remove('hidden');
 const label = document.getElementById('campaign-submit-label');
 if (label) label.textContent = 'Kampanyayı Güncelle';
 switchTab('create');
 form.scrollIntoView({ behavior: 'smooth', block: 'start' });
 }
 window.sendCampaign = sendCampaign;
 window.testCampaign = testCampaign;
 window.editCampaign = editCampaign;

 document.getElementById('campaign-form')?.addEventListener('submit', async (e) => {
 e.preventDefault();
 const form = e.target;
 if (!(form instanceof HTMLFormElement)) return;
 const data = new FormData(form);

 const payload = {
 id: String(data.get('campaignId') || ''),
 name: String(data.get('name') || ''),
 subject: String(data.get('subject') || ''),
 fromName: String(data.get('fromName') || ''),
 fromEmail: String(data.get('fromEmail') || ''),
 segment: String(data.get('segment') || ''),
 htmlContent: String(data.get('htmlContent') || ''),
 textContent: '',
 status: 'draft',
 timing: String(data.get('timing') || 'now')
 };
 const isEdit = Boolean(payload.id);

 const response = await fetch(isEdit ? `/api/marketing/campaigns?id=${encodeURIComponent(payload.id)}` : '/api/marketing/campaigns', {
 method: isEdit ? 'PUT' : 'POST',
 headers: { 'Content-Type': 'application/json' },
 body: JSON.stringify(payload)
 });

 const result = await response.json();
 if (result.success) {
 window.toast?.success(isEdit ? 'Kampanya güncellendi!' : 'Kampanya oluşturuldu!');
 form.reset();
 location.reload();
 } else {
 window.toast?.error('Hata: ' + (result.error || 'Kaydedilemedi'));
 }
 });
</script>
