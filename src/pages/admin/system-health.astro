---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout
  title="Sistem Sağlığı"
  subtitle="Release, entegrasyon ve operasyon kanıtları"
  seo={{ title: 'Sistem Sağlığı - Admin', noIndex: true }}
>
  <div class="container mx-auto max-w-6xl px-4 py-8 space-y-5">
    <div class="mb-2">
      <a href="/admin" class="text-sm text-[#9A8470] hover:text-[#6B5540]">Admin Paneli</a>
    </div>

    <div id="health-grid" class="grid gap-4 md:grid-cols-3"></div>

    <div class="rounded-sm border border-[rgba(200,160,100,0.18)] bg-white p-5 shadow-sm">
      <h2 class="font-bold text-[#1A1008]">Rapor Bağlantıları</h2>
      <p class="mt-1 text-sm text-[#9A8470]">Operasyon kanıt dosyalarına hızlı erişim.</p>
      <div class="mt-4 grid gap-2 sm:grid-cols-2 lg:grid-cols-4">
        <a class="rounded-sm bg-[rgba(200,160,100,0.06)] px-3 py-2 text-sm font-semibold text-[#6B5540] hover:bg-[rgba(200,160,100,0.12)]" href="/docs/RELEASE_EVIDENCE.md">Yayın Kanıtı</a>
        <a class="rounded-sm bg-[rgba(200,160,100,0.06)] px-3 py-2 text-sm font-semibold text-[#6B5540] hover:bg-[rgba(200,160,100,0.12)]" href="/docs/PROD_EVIDENCE.md">Üretim Kanıtı</a>
        <a class="rounded-sm bg-[rgba(200,160,100,0.06)] px-3 py-2 text-sm font-semibold text-[#6B5540] hover:bg-[rgba(200,160,100,0.12)]" href="/docs/SECURITY_HEADERS_SNAPSHOT.md">Güvenlik Başlıkları</a>
        <a class="rounded-sm bg-[rgba(200,160,100,0.06)] px-3 py-2 text-sm font-semibold text-[#6B5540] hover:bg-[rgba(200,160,100,0.12)]" href="/docs/openapi-contract-gap-report.md">OpenAPI Borcu</a>
        <a class="rounded-sm bg-[rgba(200,160,100,0.06)] px-3 py-2 text-sm font-semibold text-[#6B5540] hover:bg-[rgba(200,160,100,0.12)]" href="/docs/BACKUP_RESTORE_EVIDENCE.md">Yedek Kanıtı</a>
        <a class="rounded-sm bg-[rgba(200,160,100,0.06)] px-3 py-2 text-sm font-semibold text-[#6B5540] hover:bg-[rgba(200,160,100,0.12)]" href="/docs/RUNTIME_PROD_DOCTOR.md">Runtime Kontrolü</a>
        <a class="rounded-sm bg-[rgba(200,160,100,0.06)] px-3 py-2 text-sm font-semibold text-[#6B5540] hover:bg-[rgba(200,160,100,0.12)]" href="/docs/MIGRATION_BASELINE_DECISION.md">Migration Kararı</a>
        <a class="rounded-sm bg-[rgba(200,160,100,0.06)] px-3 py-2 text-sm font-semibold text-[#6B5540] hover:bg-[rgba(200,160,100,0.12)]" href="/docs/OPERATIONS_INDEX.md">Operasyon İndeksi</a>
      </div>
    </div>

    <div class="rounded-sm border border-[rgba(200,160,100,0.18)] bg-white p-5 shadow-sm">
      <h2 class="font-bold text-[#1A1008]">Detaylı Durum Tablosu</h2>
      <p class="mt-1 text-sm text-[#9A8470]">Yayın, güvenlik, OpenAPI, görsel ve operasyon sinyalleri tek tabloda gösterilir.</p>
      <div class="mt-4 overflow-auto">
        <table class="w-full min-w-[720px] text-left text-sm">
          <thead class="text-xs uppercase tracking-widest text-[#9A8470]">
            <tr>
              <th class="border-b border-[rgba(200,160,100,0.18)] py-2">Alan</th>
              <th class="border-b border-[rgba(200,160,100,0.18)] py-2">Durum</th>
              <th class="border-b border-[rgba(200,160,100,0.18)] py-2">Detay</th>
            </tr>
          </thead>
          <tbody id="health-detail-rows" class="text-[#6B5540]"></tbody>
        </table>
      </div>
    </div>

    <div class="rounded-sm border border-[rgba(200,160,100,0.18)] bg-white p-5 shadow-sm">
      <div class="flex items-center justify-between gap-3">
        <div>
          <h2 class="font-bold text-[#1A1008]">Release Kanıtları</h2>
          <p class="text-sm text-[#9A8470]">Secret değerleri gösterilmez; sadece durum bilgisi yer alır.</p>
        </div>
        <button id="refresh-btn" class="rounded-sm bg-urfa-600 px-4 py-2 text-sm font-semibold text-white hover:bg-urfa-700">
          Yenile
        </button>
      </div>
      <pre id="release-json" class="mt-4 overflow-auto rounded-sm bg-[#0D0A08] p-4 text-xs text-[#F5EDD6]">Yükleniyor...</pre>
    </div>
  </div>

  <script is:inline>
    function badge(status) {
      if (status === 'ready' || status === 'ok' || status === 'working' || status === 'healthy') return 'bg-[rgba(200,160,100,0.14)] text-[#6B5540]';
      if (status === 'blocked' || status === 'failed' || status === 'failing') return 'bg-red-50 text-red-700';
      return 'bg-[rgba(200,160,100,0.06)] text-[#9A8470]';
    }

    function card(label, status, value) {
      const div = document.createElement('div');
      div.className = 'rounded-sm border border-[rgba(200,160,100,0.18)] bg-white p-5 shadow-sm';
      div.innerHTML = `
        <p class="text-xs font-semibold uppercase tracking-widest text-[#9A8470]">${label}</p>
        <p class="mt-3 inline-flex rounded-sm px-2 py-1 text-sm font-semibold ${badge(status)}">${status || 'unknown'}</p>
        <p class="mt-3 text-sm text-[#6B5540]">${value || ''}</p>
      `;
      return div;
    }

    async function loadHealth() {
      const [releaseRes, providerRes] = await Promise.all([
        fetch('/api/admin/system/release-status'),
        fetch('/api/admin/site/media/provider-health'),
      ]);
      const release = await releaseRes.json();
      const provider = await providerRes.json();
      const grid = document.getElementById('health-grid');
      grid.innerHTML = '';
      grid.append(
        card('Yayın', release.releaseStatus?.status, `blocked=${release.releaseStatus?.blocked ?? '-'}, advisory=${release.releaseStatus?.advisory ?? '-'}`),
        card('Yayın Kanıtı', release.releaseEvidence?.status, `ok=${release.releaseEvidence?.totals?.ok ?? '-'}, blocked=${release.releaseEvidence?.totals?.blocked ?? '-'}`),
        card('Üretim Kanıtı', release.prodEvidence?.status, `ok=${release.prodEvidence?.totals?.ok ?? '-'}, blocked=${release.prodEvidence?.totals?.blocked ?? '-'}`),
        card('Yedek Kanıtı', release.backupRestoreEvidence?.status, release.backupRestoreEvidence?.smokeCommand || ''),
        card('Runtime Kontrolü', release.runtimeProdDoctor?.status, `advisory=${release.runtimeProdDoctor?.totals?.advisory ?? '-'}`),
        card('Ortam Kontrolü', release.envDoctor?.status, 'Yerel yapılandırma raporu'),
        card('Son Operasyon', release.opsLastRun?.status, release.opsLastRun?.finishedAt || ''),
        card('Site Kontrolü', release.siteDoctor?.status, 'DB-first artefact kontrolü'),
        card('Kritik Sayfalar', release.criticalPages?.status, 'Kritik sayfa kalite kontrolü'),
        card('Görsel Sağlayıcılar', provider.success ? 'ok' : 'failing', `Pexels=${provider.providers?.pexels || '-'}, Unsplash=${provider.providers?.unsplash || '-'}`),
      );
      const rows = [
        ['Yayın', release.releaseStatus?.status, `OpenAPI=${release.releaseStatus?.openapiRoutes || '-'}, blocked=${release.releaseStatus?.blocked ?? '-'}`],
        ['Yayın Kanıtı', release.releaseEvidence?.status, `ok=${release.releaseEvidence?.totals?.ok ?? '-'}, blocked=${release.releaseEvidence?.totals?.blocked ?? '-'}`],
        ['Üretim Kanıtı', release.prodEvidence?.status, `ok=${release.prodEvidence?.totals?.ok ?? '-'}, blocked=${release.prodEvidence?.totals?.blocked ?? '-'}`],
        ['Yedek Kanıtı', release.backupRestoreEvidence?.status, release.backupRestoreEvidence?.smokeCommand || '-'],
        ['Runtime Kontrolü', release.runtimeProdDoctor?.status, `advisory=${release.runtimeProdDoctor?.totals?.advisory ?? '-'}`],
        ['OpenAPI Tier', release.releaseStatus?.openapiTiers, JSON.stringify(release.releaseStatus?.openapiTierTotals || {})],
        ['Güvenlik', release.releaseStatus?.authLogStandard, `env=${release.releaseStatus?.envDoctor || '-'}`],
        ['Görseller', provider.success ? 'ok' : 'failing', `Pexels=${provider.providers?.pexels || '-'}, Unsplash=${provider.providers?.unsplash || '-'}`],
        ['Operasyon', release.opsLastRun?.status, release.opsLastRun?.finishedAt || '-'],
      ];
      document.getElementById('health-detail-rows').innerHTML = rows.map(([label, status, detail]) => `
        <tr>
          <td class="border-b border-[rgba(200,160,100,0.10)] py-2 font-semibold text-[#1A1008]">${label}</td>
          <td class="border-b border-[rgba(200,160,100,0.10)] py-2">${status || 'unknown'}</td>
          <td class="border-b border-[rgba(200,160,100,0.10)] py-2">${detail || '-'}</td>
        </tr>
      `).join('');
      document.getElementById('release-json').textContent = JSON.stringify({ release, provider }, null, 2);
    }

    document.getElementById('refresh-btn')?.addEventListener('click', loadHealth);
    loadHealth().catch(() => {
      document.getElementById('release-json').textContent = 'Sistem sağlığı yüklenemedi.';
    });
  </script>
</AdminLayout>
