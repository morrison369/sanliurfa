---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { query } from '../../lib/postgres';
import { logger } from '../../lib/logging';

let users: any[] = [];

try {
  const result = await query(`
    SELECT u.id, u.email, u.full_name, u.role, u.subscription_tier,
           uq.feature_key, uq.used_count, uq.limit_override, uq.reset_at
    FROM users u
    LEFT JOIN user_quotas uq ON u.id = uq.user_id
    WHERE u.role != 'admin'
    ORDER BY u.created_at DESC
    LIMIT 200
  `);

  const userMap = new Map<string, any>();
  for (const row of result.rows) {
    if (!userMap.has(row.id)) {
      userMap.set(row.id, {
        id: row.id,
        email: row.email,
        full_name: row.full_name,
        role: row.role,
        subscription_tier: row.subscription_tier,
        quotas: [],
      });
    }
    if (row.feature_key) {
      userMap.get(row.id).quotas.push({
        feature_key: row.feature_key,
        used_count: row.used_count,
        limit_override: row.limit_override,
        reset_at: row.reset_at,
      });
    }
  }
  users = Array.from(userMap.values());
} catch (e) {
  logger.error('Quotas admin query failed', e instanceof Error ? e : new Error(String(e)));
}

---

<AdminLayout
  title="Kota Yönetimi"
  subtitle={`${users.length} kullanıcı`}
  seo={{ title: 'Kota Yönetimi - Admin', noIndex: true }}
>
    <div class="container mx-auto px-4 py-8 max-w-6xl">
      <div class="mb-6">
        <a href="/admin" class="text-sm text-[#9A8470] hover:text-[#6B5540]">← Admin Paneli</a>
      </div>

      <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] shadow-sm overflow-hidden">
        {users.length === 0 ? (
          <div class="p-12 text-center text-[#9A8470] text-sm">Kullanıcı kota verisi bulunamadı.</div>
        ) : (
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="border-b border-[rgba(200,160,100,0.14)] bg-[rgba(200,160,100,0.04)]">
                <tr>
                  <th class="py-3 px-4 text-left font-medium text-[#6B5540]">Kullanıcı</th>
                  <th class="py-3 px-4 text-left font-medium text-[#6B5540]">Tier</th>
                  <th class="py-3 px-4 text-left font-medium text-[#6B5540]">Kota Kullanımı</th>
                  <th class="py-3 px-4 text-left font-medium text-[#6B5540]">İşlem</th>
                </tr>
              </thead>
              <tbody>
                {users.map(u => (
                  <tr class="border-b border-[rgba(200,160,100,0.08)] last:border-0 hover:bg-[rgba(200,160,100,0.04)]">
                    <td class="py-3 px-4">
                      <div class="font-medium text-[#1A1008]">{u.full_name || '—'}</div>
                      <div class="text-xs text-[#9A8470]">{u.email}</div>
                    </td>
                    <td class="py-3 px-4">
                      <span class={`text-xs px-2 py-0.5 rounded-sm font-medium ${u.subscription_tier === 'pro_plus' ? 'bg-[rgba(200,160,100,0.2)] text-[#6B5540]' : u.subscription_tier === 'pro' ? 'bg-[rgba(200,160,100,0.15)] text-[#6B5540]' : 'bg-[rgba(200,160,100,0.06)] text-[#9A8470]'}`}>
                        {u.subscription_tier || 'free'}
                      </span>
                    </td>
                    <td class="py-3 px-4">
                      {u.quotas.length === 0 ? (
                        <span class="text-[#9A8470] text-xs">Kota kaydı yok</span>
                      ) : (
                        <div class="space-y-0.5">
                          {u.quotas.map((q: any) => (
                            <div class="text-xs text-[#6B5540]">
                              <span class="font-mono bg-[rgba(200,160,100,0.06)] px-1 rounded-sm">{q.feature_key}</span>
                              {': '}{q.used_count}
                              {q.limit_override ? ` / ${q.limit_override}` : ''}
                            </div>
                          ))}
                        </div>
                      )}
                    </td>
                    <td class="py-3 px-4">
                      <button
                        class="reset-btn px-2 py-1 bg-[rgba(200,160,100,0.06)] text-[#6B5540] rounded-sm text-xs hover:bg-[rgba(200,160,100,0.1)]"
                        data-user-id={u.id}
                        data-email={u.email}
                      >
                        Tümünü Sıfırla
                      </button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>
    </div>
</AdminLayout>

<script is:inline>
  document.querySelectorAll('.reset-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      if (!await window.showConfirm(`${btn.dataset.email} kullanıcısının tüm kotaları sıfırlansın mı?`)) return;
      btn.disabled = true;
      btn.textContent = 'Sıfırlanıyor...';

      const res = await fetch(`/api/admin/quotas/${btn.dataset.userId}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'reset_all' }),
      });

      if (res.ok) {
        btn.textContent = 'Sıfırlandı';
        btn.className = 'px-2 py-1 bg-[rgba(200,160,100,0.15)] text-[#6B5540] rounded-sm text-xs';
      } else {
        btn.textContent = 'Hata';
        btn.className = 'px-2 py-1 bg-[rgba(200,160,100,0.06)] text-[#9A8470] rounded-sm text-xs';
        btn.disabled = false;
      }
    });
  });
</script>
