---
import Layout from '../../layouts/Layout.astro';

const seo = {
  title: 'Sosyal Abuse Politikaları - Admin',
  description: 'Tenant bazlı sosyal rate limit politikalarını yönet.',
  noIndex: true,
};
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50 pt-20 pb-12">
    <div class="container mx-auto px-4 space-y-6">
      <div class="bg-white rounded-xl shadow-sm p-6">
        <h1 class="text-2xl font-bold text-gray-900">Tenant Sosyal Politikaları</h1>
        <p class="text-gray-500 mt-1">Swipe/follow/mesaj abuse limitlerini tenant bazında yönetin.</p>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">Politika Ekle / Güncelle</h2>
        <form id="policyForm" class="grid md:grid-cols-3 gap-3">
          <input class="border rounded-lg px-3 py-2" name="tenantId" placeholder="tenantId (örn: default)" required />
          <input class="border rounded-lg px-3 py-2" name="swipeLimit" placeholder="swipe limit" value="120" />
          <input class="border rounded-lg px-3 py-2" name="swipeWindowSeconds" placeholder="swipe pencere sn" value="60" />
          <input class="border rounded-lg px-3 py-2" name="followLimit" placeholder="follow limit" value="60" />
          <input class="border rounded-lg px-3 py-2" name="followWindowSeconds" placeholder="follow pencere sn" value="60" />
          <input class="border rounded-lg px-3 py-2" name="messageWriteLimit" placeholder="mesaj limit" value="80" />
          <input class="border rounded-lg px-3 py-2" name="messageWriteWindowSeconds" placeholder="mesaj pencere sn" value="60" />
          <input class="border rounded-lg px-3 py-2 md:col-span-2" name="note" placeholder="not" />
          <label class="flex items-center gap-2 border rounded-lg px-3 py-2">
            <input type="checkbox" name="isActive" checked />
            <span>Aktif</span>
          </label>
          <button class="rounded-lg bg-indigo-600 text-white px-4 py-2 font-semibold hover:bg-indigo-700" type="submit">
            Kaydet
          </button>
        </form>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">Policy Simulator</h2>
        <form id="simulateForm" class="grid md:grid-cols-4 gap-3">
          <input class="border rounded-lg px-3 py-2" name="tenantId" placeholder="tenantId" value="default" required />
          <select class="border rounded-lg px-3 py-2" name="action">
            <option value="swipe">swipe</option>
            <option value="follow">follow</option>
            <option value="message_write">message_write</option>
          </select>
          <input class="border rounded-lg px-3 py-2" name="plannedCount" placeholder="planned count" value="50" />
          <input class="border rounded-lg px-3 py-2" name="rps" placeholder="rps" value="0" />
          <input class="border rounded-lg px-3 py-2" name="burst" placeholder="burst" value="0" />
          <input class="border rounded-lg px-3 py-2" name="durationSeconds" placeholder="duration seconds" value="60" />
          <button class="rounded-lg bg-slate-800 text-white px-4 py-2 font-semibold hover:bg-black" type="submit">
            Simüle Et
          </button>
        </form>
        <pre id="simulateResult" class="mt-3 rounded-lg bg-gray-900 text-gray-100 p-3 text-xs overflow-auto">Henüz çalıştırılmadı.</pre>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-lg font-bold text-gray-900">Mevcut Politikalar</h2>
          <button id="refreshBtn" class="rounded-lg border px-3 py-1.5 text-sm">Yenile</button>
        </div>
        <div class="overflow-x-auto">
          <table class="min-w-full text-sm">
            <thead>
              <tr class="border-b text-left text-gray-600">
                <th class="px-2 py-2">Tenant</th>
                <th class="px-2 py-2">Swipe</th>
                <th class="px-2 py-2">Follow</th>
                <th class="px-2 py-2">Mesaj</th>
                <th class="px-2 py-2">Aktif</th>
                <th class="px-2 py-2">Güncellendi</th>
                <th class="px-2 py-2">Not</th>
              </tr>
            </thead>
            <tbody id="policyRows">
              <tr><td class="px-2 py-3 text-gray-400" colspan="7">Yükleniyor...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    async function loadPolicies() {
      const rows = document.getElementById('policyRows');
      const res = await fetch('/api/admin/social/policies');
      const json = await res.json();
      if (!res.ok || !json?.success) {
        rows.innerHTML = `<tr><td class="px-2 py-3 text-red-600" colspan="7">${json?.error || 'Yüklenemedi'}</td></tr>`;
        return;
      }
      const items = Array.isArray(json.items) ? json.items : [];
      if (items.length === 0) {
        rows.innerHTML = '<tr><td class="px-2 py-3 text-gray-400" colspan="7">Kayıt yok</td></tr>';
        return;
      }
      rows.innerHTML = items.map((item) => `
        <tr class="border-b border-gray-100">
          <td class="px-2 py-2 font-mono">${item.tenant_id}</td>
          <td class="px-2 py-2">${item.swipe_limit}/${item.swipe_window_seconds}s</td>
          <td class="px-2 py-2">${item.follow_limit}/${item.follow_window_seconds}s</td>
          <td class="px-2 py-2">${item.message_write_limit}/${item.message_write_window_seconds}s</td>
          <td class="px-2 py-2">${item.is_active ? 'Evet' : 'Hayır'}</td>
          <td class="px-2 py-2">${item.updated_at ? new Date(item.updated_at).toLocaleString('tr-TR') : '-'}</td>
          <td class="px-2 py-2">${item.note || '-'}</td>
        </tr>
      `).join('');
    }

    document.getElementById('policyForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const payload = {
        tenantId: form.tenantId.value,
        swipeLimit: Number(form.swipeLimit.value || 120),
        swipeWindowSeconds: Number(form.swipeWindowSeconds.value || 60),
        followLimit: Number(form.followLimit.value || 60),
        followWindowSeconds: Number(form.followWindowSeconds.value || 60),
        messageWriteLimit: Number(form.messageWriteLimit.value || 80),
        messageWriteWindowSeconds: Number(form.messageWriteWindowSeconds.value || 60),
        isActive: !!form.isActive.checked,
        note: form.note.value || null,
      };
      const res = await fetch('/api/admin/social/policies', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const json = await res.json();
      alert(res.ok && json?.success ? 'Kaydedildi' : (json?.error || 'Kaydedilemedi'));
      if (res.ok && json?.success) await loadPolicies();
    });

    document.getElementById('refreshBtn').addEventListener('click', () => void loadPolicies());

    document.getElementById('simulateForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const payload = {
        tenantId: form.tenantId.value,
        action: form.action.value,
        plannedCount: Number(form.plannedCount.value || 0),
        rps: Number(form.rps.value || 0),
        burst: Number(form.burst.value || 0),
        durationSeconds: Number(form.durationSeconds.value || 60),
      };
      const out = document.getElementById('simulateResult');
      const res = await fetch('/api/admin/social/policies/simulate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const json = await res.json();
      out.textContent = JSON.stringify(json, null, 2);
    });

    void loadPolicies();
  </script>
</Layout>
