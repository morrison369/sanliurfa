---
import AdminLayout from '../../layouts/AdminLayoutV2.astro';
import SiteContentManager from '../../components/admin/SiteContentManager';
import SiteOperationsOverview from '../../components/admin/SiteOperationsOverview';
import SitePlatformBlueprint from '../../components/admin/SitePlatformBlueprint';
---

<AdminLayout
 title="Site İçerik Yönetimi"
 subtitle="Ana sayfa hero ve site içerik blokları — DB-kaynaklı management"
 seo={{ title: 'Site İçerik Yönetimi - Admin', noIndex: true }}
>
 <div class="sc-page">
  <div class="sc-panel">
   <SiteOperationsOverview client:visible />
  </div>
  <div class="sc-panel">
   <SitePlatformBlueprint client:visible />
  </div>
  <div class="sc-panel">
   <SiteContentManager client:idle />
  </div>
</div>
</AdminLayout>

<style>
 .sc-page { display: flex; flex-direction: column; gap: 1.25rem; }
 .sc-panel {
  background: var(--adm-bg-elev);
  border: 1px solid var(--adm-border);
  border-radius: 12px;
  padding: 1.25rem;
 }
</style>
