---
// Admin Import/Export Page
import AdminLayout from '../../layouts/AdminLayout.astro';
import { requireRole } from '../../lib/auth';
import { query } from '../../lib/postgres';

const auth = await requireRole(Astro.request, 'admin');
if (auth instanceof Response) return auth;

const catResult = await query(`SELECT id, slug, name FROM categories WHERE is_active = true ORDER BY sort_order, name`);
const categories = catResult.rows;
---

<AdminLayout title="İçe/Dışa Aktar">
  <div class="space-y-8">
    {/* Import Section */}
    <div class="bg-white rounded-xl shadow-sm p-6">
      <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
        <span>📥</span> CSV ile İçe Aktar
      </h2>
      
      <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
        <h3 class="font-medium text-blue-900 mb-2">Beklenen CSV Formatı:</h3>
        <code class="block bg-white p-3 rounded text-sm text-blue-800">
          isim,adres,telefon,aciklama,enlem,boylam<br/>
          "Mekan Adı","Adres Bilgisi","0543 123 4567","Açıklama",37.1234,38.5678
        </code>
      </div>
      
      <form id="import-form" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Kategori</label>
          <select name="categoryId" required class="w-full px-4 py-2 border rounded-lg">
            <option value="">Kategori Seçin</option>
            {categories.map(cat => (
              <option value={cat.id}>{cat.name}</option>
            ))}
          </select>
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">CSV Dosyası</label>
          <input
            type="file"
            name="file"
            accept=".csv"
            required
            class="w-full px-4 py-2 border rounded-lg"
          />
        </div>
        
        <button
          type="submit"
          class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700"
        >
          İçe Aktar
        </button>
      </form>
      
      <div id="import-result" class="mt-4 hidden"></div>
    </div>

    {/* Export Section */}
    <div class="bg-white rounded-xl shadow-sm p-6">
      <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
        <span>📤</span> Dışa Aktar
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <a
          href="/api/admin/export?type=places&format=csv"
          class="p-6 border rounded-xl hover:border-blue-500 transition-colors text-center"
        >
          <div class="text-4xl mb-2">📍</div>
          <h3 class="font-medium">Mekanlar</h3>
          <p class="text-sm text-gray-500">CSV olarak indir</p>
        </a>
        
        <a
          href="/api/admin/export?type=reviews&format=csv"
          class="p-6 border rounded-xl hover:border-blue-500 transition-colors text-center"
        >
          <div class="text-4xl mb-2">⭐</div>
          <h3 class="font-medium">Değerlendirmeler</h3>
          <p class="text-sm text-gray-500">CSV olarak indir</p>
        </a>
        
        <a
          href="/api/admin/export?type=users&format=csv"
          class="p-6 border rounded-xl hover:border-blue-500 transition-colors text-center"
        >
          <div class="text-4xl mb-2">👥</div>
          <h3 class="font-medium">Kullanıcılar</h3>
          <p class="text-sm text-gray-500">CSV olarak indir</p>
        </a>
      </div>
    </div>

    {/* Backup Section */}
    <div class="bg-white rounded-xl shadow-sm p-6">
      <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
        <span>💾</span> Yedekleme
      </h2>
      
      <div class="flex gap-4">
        <button
          onclick="createBackup()"
          class="px-6 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700"
        >
          Yedek Oluştur
        </button>
        
        <button
          onclick="restoreBackup()"
          class="px-6 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200"
        >
          Yedekten Geri Yükle
        </button>
      </div>
    </div>
  </div>

  <script>
    document.getElementById('import-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(e.target);
      const resultDiv = document.getElementById('import-result');
      
      resultDiv.innerHTML = '<p class="text-blue-600">İşleniyor...</p>';
      resultDiv.classList.remove('hidden');
      
      try {
        const response = await fetch('/api/admin/import', {
          method: 'POST',
          body: formData,
        });
        
        const result = await response.json();
        
        if (result.error) {
          resultDiv.innerHTML = `<p class="text-red-600">Hata: ${result.error}</p>`;
        } else {
          resultDiv.innerHTML = `
            <div class="bg-green-50 border border-green-200 rounded-lg p-4">
              <p class="text-green-800 font-medium">İşlem Tamamlandı!</p>
              <p class="text-green-700 mt-1">
                Toplam: ${result.total} | 
                Başarılı: ${result.success} | 
                Başarısız: ${result.failed}
              </p>
              ${result.errors.length > 0 ? `
                <details class="mt-3">
                  <summary class="cursor-pointer text-sm">Hataları Gör (${result.errors.length})</summary>
                  <ul class="mt-2 text-sm text-red-600 list-disc pl-4">
                    ${result.errors.slice(0, 10).map(err => `<li>${err}</li>`).join('')}
                    ${result.errors.length > 10 ? `<li>... ve ${result.errors.length - 10} hata daha</li>` : ''}
                  </ul>
                </details>
              ` : ''}
            </div>
          `;
        }
      } catch (error) {
        resultDiv.innerHTML = '<p class="text-red-600">Bir hata oluştu</p>';
      }
    });
    
    async function createBackup() {
      alert('Yedekleme özelliği yakında geliyor!');
    }
    
    async function restoreBackup() {
      alert('Geri yükleme özelliği yakında geliyor!');
    }
  </script>
</AdminLayout>
