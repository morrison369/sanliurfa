---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout
  title="Site Denetim Zaman Çizelgesi"
  subtitle="İçerik, medya ve sosyal abuse kayıtlarını izleyin ve dışa aktarın."
  seo={{ title: 'Site Denetim Zaman Çizelgesi - Admin', noIndex: true }}
>
    <div class="container mx-auto px-4 py-8 max-w-6xl space-y-5">
      <div class="mb-2">
        <a href="/admin" class="text-sm text-[#9A8470] hover:text-[#6B5540]">← Admin Paneli</a>
      </div>

      <div class="rounded-sm border border-[rgba(200,160,100,0.18)] bg-white p-5 shadow-sm">
        <h2 class="font-semibold text-[#6B5540] mb-3">Anomaly Özeti (24s)</h2>
        <div id="anomalyCard" class="rounded-sm border border-[rgba(200,160,100,0.2)] bg-[rgba(200,160,100,0.06)] p-3 text-sm text-[#6B5540]">
          Yükleniyor...
        </div>
      </div>

      <div class="rounded-sm border border-[rgba(200,160,100,0.18)] bg-white p-5 shadow-sm">
        <div class="grid gap-3 md:grid-cols-5">
          <input id="filterKey" class="rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm" placeholder="key filtresi" />
          <input id="filterAction" class="rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm" placeholder="action filtresi" />
          <input id="filterLimit" type="number" value="50" class="rounded-sm border border-[rgba(200,160,100,0.2)] px-3 py-2 text-sm" />
          <button id="btnLoad" class="rounded-sm bg-urfa-600 px-4 py-2 text-sm font-semibold text-white hover:bg-urfa-700">Timeline Getir</button>
          <a id="btnExport" class="rounded-sm bg-[#6B5540] px-4 py-2 text-center text-sm font-semibold text-white hover:bg-[#4A3A28]" href="/api/admin/site/audit/export?limit=50">CSV Dışa Aktar</a>
        </div>

        <div class="mt-4 flex items-center gap-3">
          <button id="prevPage" class="rounded-sm border border-[rgba(200,160,100,0.14)] px-3 py-1 text-sm text-[#6B5540] hover:bg-[rgba(200,160,100,0.04)]">Önceki</button>
          <button id="nextPage" class="rounded-sm border border-[rgba(200,160,100,0.14)] px-3 py-1 text-sm text-[#6B5540] hover:bg-[rgba(200,160,100,0.04)]">Sonraki</button>
          <span id="pageInfo" class="text-sm text-[#9A8470]"></span>
        </div>

        <div class="mt-4 overflow-x-auto">
          <table class="min-w-full text-sm">
            <thead class="border-b border-[rgba(200,160,100,0.14)] bg-[rgba(200,160,100,0.04)]">
              <tr>
                <th class="px-3 py-3 text-left font-medium text-[#6B5540]">Tarih</th>
                <th class="px-3 py-3 text-left font-medium text-[#6B5540]">Key</th>
                <th class="px-3 py-3 text-left font-medium text-[#6B5540]">Action</th>
                <th class="px-3 py-3 text-left font-medium text-[#6B5540]">Email</th>
                <th class="px-3 py-3 text-left font-medium text-[#6B5540]">IP</th>
                <th class="px-3 py-3 text-left font-medium text-[#6B5540]">Metadata</th>
              </tr>
            </thead>
            <tbody id="auditBody">
              <tr><td colspan="6" class="px-3 py-6 text-center text-[#9A8470]">Yükleniyor...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

  <script>
    let offset = 0;
    let total = 0;

    const byId = (id: string) => {
      const node = document.getElementById(id);
      if (!node) throw new Error(`Element bulunamadı: ${id}`);
      return node;
    };
    const filterKey = byId('filterKey') as HTMLInputElement;
    const filterAction = byId('filterAction') as HTMLInputElement;
    const filterLimit = byId('filterLimit') as HTMLInputElement;
    const body = byId('auditBody') as HTMLTableSectionElement;
    const pageInfo = byId('pageInfo');
    const anomalyCard = byId('anomalyCard');
    const btnExport = byId('btnExport');
    const btnLoad = byId('btnLoad');
    const prevPage = byId('prevPage');
    const nextPage = byId('nextPage');

    const readValue = (node: Element | null) => {
      if (
        node instanceof HTMLInputElement ||
        node instanceof HTMLTextAreaElement ||
        node instanceof HTMLSelectElement
      ) {
        return node.value;
      }
      return '';
    };
    const setHref = (node: Element | null, href: string) => {
      if (node instanceof HTMLAnchorElement) {
        node.href = href;
      }
    };

    function buildParams() {
      const limit = Math.max(1, Number(readValue(filterLimit) || 50));
      const qp = new URLSearchParams({ limit: String(limit), offset: String(offset) });
      const keyValue = readValue(filterKey).trim();
      if (keyValue) qp.set('key', keyValue);
      const actionValue = readValue(filterAction).trim();
      if (actionValue) qp.set('action', actionValue);
      return qp;
    }

    function setBodyMsg(tbody: HTMLElement, colSpan: number, text: string, cls: string) {
      const tr = document.createElement('tr');
      const td = document.createElement('td');
      td.colSpan = colSpan;
      td.className = cls;
      td.textContent = text;
      tr.appendChild(td);
      tbody.replaceChildren(tr);
    }

    function buildAuditRow(r: any): HTMLTableRowElement {
      const tr = document.createElement('tr');
      tr.className = 'border-b border-[rgba(200,160,100,0.08)] hover:bg-[rgba(200,160,100,0.04)]';
      const cells: [string, string][] = [
        ['px-3 py-2 text-xs text-[#9A8470]', new Date(r.created_at).toLocaleString('tr-TR')],
        ['px-3 py-2 text-xs font-mono text-[#6B5540]', r.setting_key || '-'],
        ['px-3 py-2 text-xs text-urfa-600', r.action || '-'],
        ['px-3 py-2 text-xs text-[#6B5540]', r.actor_email || '-'],
        ['px-3 py-2 text-xs text-[#9A8470]', r.ip_address || '-'],
        ['px-3 py-2 text-xs font-mono text-[#9A8470]', JSON.stringify(r.metadata || {}).slice(0, 140)],
      ];
      cells.forEach(([cls, text]) => {
        const td = document.createElement('td');
        td.className = cls;
        td.textContent = text;
        tr.appendChild(td);
      });
      return tr;
    }

    async function load() {
      const qp = buildParams();
      const res = await fetch(`/api/admin/site/audit?${qp.toString()}`);
      const data = await res.json();
      if (!res.ok || !data.success) {
        setBodyMsg(body, 6, data.error || 'Hata', 'px-3 py-6 text-center text-[#9A8470]');
        return;
      }

      total = Number(data.total || 0);
      const rows = Array.isArray(data.items) ? data.items : [];
      if (rows.length === 0) {
        setBodyMsg(body, 6, 'Kayıt bulunamadı', 'px-3 py-6 text-center text-[#9A8470]');
      } else {
        body.replaceChildren(...rows.map(buildAuditRow));
      }

      const limit = Math.max(1, Number(readValue(filterLimit) || 50));
      pageInfo.textContent = `${offset + 1}-${Math.min(offset + limit, total)} / ${total}`;
      setHref(btnExport, `/api/admin/site/audit/export?${qp.toString().replace(/offset=\d+&?/, '')}`);
    }

    async function loadAnomaly() {
      const res = await fetch('/api/admin/site/audit/anomaly');
      const json = await res.json();
      if (!res.ok || !json?.success) {
        anomalyCard.textContent = json?.error || 'Anomaly yüklenemedi';
        return;
      }
      const d = json.data || {};
      const makeRow = (label: string, value: string | number) => {
        const div = document.createElement('div');
        const strong = document.createElement('strong');
        strong.textContent = String(value);
        div.textContent = label + ': ';
        div.appendChild(strong);
        return div;
      };
      anomalyCard.replaceChildren(
        makeRow('Toplam Event', d.totalEvents || 0),
        makeRow('Social Abuse Oranı', '%' + (d.socialAbuseRate || 0)),
        makeRow('Şüpheli IP Sayısı', d.suspiciousIpCount || 0),
      );
    }

    btnLoad.addEventListener('click', () => {
      offset = 0;
      load();
    });
    prevPage.addEventListener('click', () => {
      const limit = Math.max(1, Number(readValue(filterLimit) || 50));
      offset = Math.max(0, offset - limit);
      load();
    });
    nextPage.addEventListener('click', () => {
      const limit = Math.max(1, Number(readValue(filterLimit) || 50));
      if (offset + limit < total) {
        offset += limit;
        load();
      }
    });

    load();
    loadAnomaly();
  </script>
</AdminLayout>
