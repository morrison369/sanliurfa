---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { query } from '../../lib/postgres';
import { logger } from '../../lib/logging';

let scheduledReports: any[] = [];
let recentExecutions: any[] = [];

try {
 const [repResult, execResult] = await Promise.all([
 query(`SELECT * FROM scheduled_reports ORDER BY created_at DESC LIMIT 50`),
 query(`SELECT * FROM report_executions ORDER BY created_at DESC LIMIT 20`),
 ]);
 scheduledReports = repResult.rows;
 recentExecutions = execResult.rows;
} catch (e) {
 logger.error('Reports admin query failed', e instanceof Error ? e : new Error(String(e)));
}

const typeLabels: Record<string, string> = {
 users: 'Kullanıcılar',
 places: 'Mekanlar',
 reviews: 'Yorumlar',
 revenue: 'Gelir',
 engagement: 'Etkileşim',
};

---

<AdminLayout
 title="Rapor Yönetimi"
 subtitle={`${scheduledReports.length} zamanlanmış rapor`}
 seo={{ title: 'Rapor Yönetimi - Admin', noIndex: true }}
>
 <a slot="hero-action" href="/admin/analytics" class="px-4 py-2 rounded-sm bg-urfa-600 text-white hover:bg-urfa-700 text-sm transition-colors">
 Analitik Dashboard →
 </a>

 <div class="sf-container py-8 max-w-5xl">
 <div class="mb-4">
 <a href="/admin" class="text-sm text-[#7A6B58] hover:text-[#7A6B58]">← Admin Paneli</a>
 </div>

 <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
 {['users', 'places', 'reviews', 'revenue'].map(type => (
 <a
 href={`/api/admin/reports/generate?type=${type}&period=monthly&format=json`}
 target="_blank"
 rel="noopener"
 class="bg-[var(--bg-card)] border border-[rgba(184,115,51,0.14)] rounded-sm p-4 text-center hover:border-[rgba(184,115,51,0.4)] hover:shadow-sm transition-all"
 >
 <div class="text-2xl mb-2">
 {type === 'users' ? '👥' : type === 'places' ? '📍' : type === 'reviews' ? '⭐' : '💰'}
 </div>
 <div class="text-sm font-medium text-[#7A6B58]">{typeLabels[type]}</div>
 <div class="text-xs text-[#7A6B58] mt-1">Aylık rapor</div>
 </a>
 ))}
 </div>

 <div class="bg-[var(--bg-card)] border border-[rgba(184,115,51,0.14)] rounded-sm overflow-hidden mb-6">
 <div class="p-4 border-b border-[rgba(184,115,51,0.14)] bg-[rgba(184,115,51,0.04)]">
 <h2 class="font-semibold text-[#7A6B58] text-sm">Zamanlanmış Raporlar</h2>
 </div>
 {scheduledReports.length === 0 ? (
 <div class="p-8 text-center text-[#7A6B58] text-sm">Henüz zamanlanmış rapor yok.</div>
 ) : (
 <table class="w-full text-sm">
 <thead class="border-b border-[rgba(184,115,51,0.14)] bg-[rgba(184,115,51,0.04)]">
 <tr>
 <th class="py-3 px-4 text-left font-medium text-[#7A6B58]">Tür</th>
 <th class="py-3 px-4 text-left font-medium text-[#7A6B58]">Periyot</th>
 <th class="py-3 px-4 text-left font-medium text-[#7A6B58]">E-posta</th>
 <th class="py-3 px-4 text-left font-medium text-[#7A6B58]">Sıklık</th>
 <th class="py-3 px-4 text-left font-medium text-[#7A6B58]">Oluşturulma</th>
 </tr>
 </thead>
 <tbody>
 {scheduledReports.map(rep => (
 <tr class="border-b border-[rgba(184,115,51,0.08)] last:border-0 hover:bg-[rgba(184,115,51,0.04)]">
 <td class="py-3 px-4 font-medium text-[#1F1410]">{typeLabels[rep.type] || rep.type}</td>
 <td class="py-3 px-4 text-[#7A6B58]">{rep.period}</td>
 <td class="py-3 px-4 text-[#7A6B58] truncate max-w-xs">{rep.email}</td>
 <td class="py-3 px-4 text-[#7A6B58]">{rep.frequency}</td>
 <td class="py-3 px-4 text-[#7A6B58] text-xs">
 {new Date(rep.created_at).toLocaleDateString('tr-TR')}
 </td>
 </tr>
 ))}
 </tbody>
 </table>
 )}
 </div>

 {recentExecutions.length > 0 && (
 <div class="bg-[var(--bg-card)] border border-[rgba(184,115,51,0.14)] rounded-sm overflow-hidden">
 <div class="p-4 border-b border-[rgba(184,115,51,0.14)] bg-[rgba(184,115,51,0.04)]">
 <h2 class="font-semibold text-[#7A6B58] text-sm">Son Rapor Çalışmaları</h2>
 </div>
 <table class="w-full text-sm">
 <thead class="border-b border-[rgba(184,115,51,0.14)] bg-[rgba(184,115,51,0.04)]">
 <tr>
 <th class="py-3 px-4 text-left font-medium text-[#7A6B58]">Rapor</th>
 <th class="py-3 px-4 text-left font-medium text-[#7A6B58]">Durum</th>
 <th class="py-3 px-4 text-left font-medium text-[#7A6B58]">Tarih</th>
 </tr>
 </thead>
 <tbody>
 {recentExecutions.map(exec => (
 <tr class="border-b border-[rgba(184,115,51,0.08)] last:border-0 hover:bg-[rgba(184,115,51,0.04)]">
 <td class="py-3 px-4 text-[#1F1410]">{exec.report_id || exec.type || '—'}</td>
 <td class="py-3 px-4">
 <span class={`text-xs px-2 py-0.5 rounded-sm font-medium ${exec.status === 'completed' ? 'bg-[rgba(184,115,51,0.15)] text-[#7A6B58]' : exec.status === 'failed' ? 'bg-[rgba(184,115,51,0.06)] text-[#7A6B58]' : 'bg-[rgba(184,115,51,0.1)] text-[#7A6B58]'}`}>
 {exec.status || 'bilinmiyor'}
 </span>
 </td>
 <td class="py-3 px-4 text-[#7A6B58] text-xs">{new Date(exec.created_at).toLocaleDateString('tr-TR')}</td>
 </tr>
 ))}
 </tbody>
 </table>
 </div>
 )}
 </div>
</AdminLayout>
