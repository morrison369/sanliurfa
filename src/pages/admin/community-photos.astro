---
import AdminLayout from '../../layouts/AdminLayout.astro';
import Image from '../../components/Image.astro';
import { Icon } from 'astro-icon/components';
import { queryMany, queryOne } from '../../lib/postgres';
import { safeIntParam } from '../../lib/api';

const user = Astro.locals.user;
if (!user || user.role !== 'admin') return Astro.redirect(`/giris?redirect=${Astro.url.pathname}`);

const status = Astro.url.searchParams.get('status') || 'pending';
const page = safeIntParam(Astro.url.searchParams.get('page'), 1, 1, 1000);
const limit = 20;
const offset = (page - 1) * limit;

const VALID_STATUSES = new Set(['pending', 'approved', 'rejected', 'all']);
const safeStatus = VALID_STATUSES.has(status) ? status : 'pending';

const whereClause = safeStatus === 'all' ? '' : `WHERE cp.status = '${safeStatus}'`;

let photos: any[] = [];
let total = 0;

try {
  const [photosResult, countRow] = await Promise.all([
    queryMany(
      `SELECT cp.*, u.full_name, u.username, u.email,
              ab.full_name AS approved_by_name
       FROM community_photos cp
       JOIN users u ON u.id = cp.user_id
       LEFT JOIN users ab ON ab.id = cp.approved_by
       ${whereClause}
       ORDER BY cp.created_at ${safeStatus === 'approved' ? 'DESC' : 'ASC'}
       LIMIT $1 OFFSET $2`,
      [limit, offset]
    ),
    queryOne<{ count: number }>(
      `SELECT COUNT(*)::int AS count FROM community_photos cp ${whereClause}`,
      []
    ),
  ]);
  photos = photosResult;
  total = countRow?.count || 0;
} catch {}

const tabs = [
  { key: 'pending', label: 'Bekleyen', icon: 'lucide:clock' },
  { key: 'approved', label: 'Onaylı', icon: 'lucide:check-circle' },
  { key: 'rejected', label: 'Reddedilmiş', icon: 'lucide:x-circle' },
  { key: 'all', label: 'Tümü', icon: 'lucide:image' },
];
---

<AdminLayout
  title="Topluluk Fotoğrafları"
  subtitle="Üye fotoğraflarını onaylayın veya reddedin"
  seo={{ title: 'Topluluk Fotoğrafları - Admin', noIndex: true }}
>
  <style is:inline>
  .cp-tabs{display:flex;gap:.5rem;margin-bottom:1.5rem;flex-wrap:wrap}
  .cp-tab{display:inline-flex;align-items:center;gap:.35rem;padding:.45rem 1rem;border-radius:.375rem;font-size:.82rem;font-weight:600;text-decoration:none;border:1px solid transparent;transition:all .15s}
  .cp-tab-active{background:#78331d;color:white;border-color:#78331d}
  .cp-tab:not(.cp-tab-active){background:rgba(255,255,255,.04);color:#B87333;border-color:rgba(184,115,51,.2)}
  .cp-tab:not(.cp-tab-active):hover{background:rgba(184,115,51,.08)}
  .cp-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.25rem}
  .cp-card{border-radius:.75rem;overflow:hidden;border:1px solid rgba(184,115,51,.14);background:var(--bg-card);box-shadow:0 2px 8px rgba(0,0,0,.12)}
  .cp-img-wrap{position:relative;aspect-ratio:4/3;overflow:hidden;background:#1a1208}
  .cp-img{width:100%;height:100%;object-fit:cover}
  .cp-body{padding:.75rem}
  .cp-user{font-size:.8rem;font-weight:600;color:#1F1410;margin-bottom:.25rem}
  .cp-email{font-size:.72rem;color:#7A6B58;margin-bottom:.35rem}
  .cp-caption{font-size:.8rem;color:#B87333;line-height:1.5;margin-bottom:.5rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
  .cp-location{font-size:.72rem;color:#7A6B58;margin-bottom:.5rem}
  .cp-date{font-size:.7rem;color:#7A6B58;margin-bottom:.75rem}
  .cp-actions{display:flex;gap:.5rem;flex-wrap:wrap}
  .cp-btn-approve{padding:.35rem .75rem;background:#166534;color:white;font-size:.78rem;font-weight:600;border:none;border-radius:.3rem;cursor:pointer;transition:background .15s}
  .cp-btn-approve:hover{background:#15803d}
  .cp-btn-reject{padding:.35rem .75rem;background:#991b1b;color:white;font-size:.78rem;font-weight:600;border:none;border-radius:.3rem;cursor:pointer;transition:background .15s}
  .cp-btn-reject:hover{background:#7f1d1d}
  .cp-btn-delete{padding:.35rem .75rem;background:rgba(184,115,51,.1);color:#B87333;font-size:.78rem;font-weight:600;border:1px solid rgba(184,115,51,.2);border-radius:.3rem;cursor:pointer;transition:background .15s}
  .cp-btn-delete:hover{background:rgba(184,115,51,.18)}
  .cp-status{display:inline-flex;align-items:center;gap:.25rem;font-size:.72rem;font-weight:600;padding:.2rem .45rem;border-radius:.25rem;margin-bottom:.5rem}
  .cp-status-pending{background:#fef9c3;color:#854d0e}
  .cp-status-approved{background:#dcfce7;color:#166534}
  .cp-status-rejected{background:#fee2e2;color:#991b1b}
  .cp-pagination{display:flex;gap:.5rem;margin-top:2rem;justify-content:center}
  .cp-page-btn{padding:.4rem .85rem;border-radius:.3rem;font-size:.82rem;border:1px solid rgba(184,115,51,.2);background:rgba(255,255,255,.04);color:#B87333;text-decoration:none;transition:background .15s}
  .cp-page-btn:hover,.cp-page-btn.active{background:rgba(184,115,51,.14)}
  .cp-empty{text-align:center;padding:3rem 1rem;color:#7A6B58}
  .cp-empty-title{font-size:1.2rem;color:#1F1410;margin-bottom:.5rem}
  .cp-reject-modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:1000;align-items:center;justify-content:center}
  .cp-reject-modal.open{display:flex}
  .cp-reject-box{background:var(--bg-card);border:1px solid rgba(184,115,51,.2);border-radius:.75rem;padding:1.5rem;max-width:480px;width:90%}
  .cp-reject-box h3{font-size:1rem;font-weight:700;color:#1F1410;margin-bottom:.75rem}
  .cp-reject-textarea{width:100%;padding:.5rem;border:1px solid rgba(184,115,51,.25);border-radius:.375rem;background:transparent;color:#1F1410;font-size:.85rem;resize:vertical;margin-bottom:.75rem}
  .cp-reject-btns{display:flex;gap:.5rem;justify-content:flex-end}
  </style>

  <div class="mb-4">
    <a href="/admin" class="text-sm text-[#7A6B58] hover:text-[#7A6B58]">← Admin Paneli</a>
  </div>

  <!-- Tabs -->
  <div class="cp-tabs">
    {tabs.map((tab) => (
      <a
        href={`/admin/community-photos?status=${tab.key}`}
        class={`cp-tab ${safeStatus === tab.key ? 'cp-tab-active' : ''}`}
      >
        <Icon name={tab.icon} style="width:.85rem;height:.85rem" />
        {tab.label}
        {safeStatus === tab.key && total > 0 && ` (${total})`}
      </a>
    ))}
  </div>

  <p id="action-feedback" style="display:none;margin-bottom:1rem;font-size:.85rem;padding:.5rem 1rem;border-radius:.375rem"></p>

  <!-- Photo grid -->
  {photos.length === 0 ? (
    <div class="cp-empty">
      <Icon name="lucide:image" style="width:3rem;height:3rem;margin:0 auto .75rem" />
      <p class="cp-empty-title">Bu durumda fotoğraf yok</p>
      <p>"{tabs.find(t => t.key === safeStatus)?.label}" kategorisinde görüntülenecek fotoğraf bulunmuyor.</p>
    </div>
  ) : (
    <div class="cp-grid" id="cp-grid">
      {photos.map((photo) => (
        <div class="cp-card" id={`card-${photo.id}`}>
          <div class="cp-img-wrap">
            <Image
              src={photo.file_path}
              alt={photo.caption || `${photo.full_name} fotoğrafı`}
              class="cp-img"
              width={560}
              height={420}
              loading="lazy"
            />
          </div>
          <div class="cp-body">
            <span class={`cp-status cp-status-${photo.status}`}>
              {photo.status === 'pending' ? 'Bekliyor' : photo.status === 'approved' ? 'Onaylandı' : 'Reddedildi'}
            </span>
            <p class="cp-user">{photo.full_name || photo.username}</p>
            <p class="cp-email">{photo.email}</p>
            {photo.caption && <p class="cp-caption">{photo.caption}</p>}
            {photo.location && <p class="cp-location"><Icon name="lucide:map-pin" style="width:.7rem;height:.7rem;vertical-align:middle" /> {photo.location}</p>}
            <p class="cp-date">{new Date(photo.created_at).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' })}</p>
            {photo.status === 'rejected' && photo.rejection_reason && (
              <p style="font-size:.72rem;color:#991b1b;margin-bottom:.5rem">Ret: {photo.rejection_reason}</p>
            )}
            <div class="cp-actions">
              {photo.status !== 'approved' && (
                <button class="cp-btn-approve" onclick={`adminAction('${photo.id}','approve')`}>
                  <Icon name="lucide:check" style="width:.75rem;height:.75rem;vertical-align:middle" /> Onayla
                </button>
              )}
              {photo.status !== 'rejected' && (
                <button class="cp-btn-reject" onclick={`openRejectModal('${photo.id}')`}>
                  <Icon name="lucide:x" style="width:.75rem;height:.75rem;vertical-align:middle" /> Reddet
                </button>
              )}
              <button class="cp-btn-delete" onclick={`adminAction('${photo.id}','delete')`}>
                <Icon name="lucide:trash-2" style="width:.75rem;height:.75rem;vertical-align:middle" /> Sil
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>
  )}

  <!-- Pagination -->
  {total > limit && (
    <div class="cp-pagination">
      {page > 1 && (
        <a href={`/admin/community-photos?status=${safeStatus}&page=${page - 1}`} class="cp-page-btn">← Önceki</a>
      )}
      <span class="cp-page-btn" style="pointer-events:none;opacity:.7">{page} / {Math.ceil(total / limit)}</span>
      {page * limit < total && (
        <a href={`/admin/community-photos?status=${safeStatus}&page=${page + 1}`} class="cp-page-btn">Sonraki →</a>
      )}
    </div>
  )}

  <!-- Reject Modal -->
  <div class="cp-reject-modal" id="reject-modal">
    <div class="cp-reject-box">
      <h3>Reddetme Sebebi</h3>
      <textarea class="cp-reject-textarea" id="reject-reason" rows={3} placeholder="İsteğe bağlı — üyeye gösterilecek"></textarea>
      <div class="cp-reject-btns">
        <button class="cp-btn-delete" onclick="closeRejectModal()">İptal</button>
        <button class="cp-btn-reject" onclick="submitReject()">Reddet</button>
      </div>
    </div>
  </div>

  <script is:inline>
  let rejectPhotoId = null;

  function openRejectModal(photoId) {
    rejectPhotoId = photoId;
    document.getElementById('reject-reason').value = '';
    document.getElementById('reject-modal').classList.add('open');
  }

  function closeRejectModal() {
    rejectPhotoId = null;
    document.getElementById('reject-modal').classList.remove('open');
  }

  async function submitReject() {
    const reason = document.getElementById('reject-reason').value.trim();
    closeRejectModal();
    await adminAction(rejectPhotoId, 'reject', reason);
  }

  function showFeedback(msg, ok) {
    const el = document.getElementById('action-feedback');
    if (!el) return;
    el.textContent = msg;
    el.style.display = 'block';
    el.style.background = ok ? 'rgba(20,83,45,.25)' : 'rgba(153,27,27,.25)';
    el.style.color = ok ? '#86efac' : '#fca5a5';
    el.style.border = `1px solid ${ok ? 'rgba(134,239,172,.3)' : 'rgba(252,165,165,.3)'}`;
    setTimeout(() => { el.style.display = 'none'; }, 4000);
  }

  async function adminAction(photoId, action, reason) {
    if (action === 'delete' && !confirm('Bu fotoğrafı kalıcı olarak silmek istediğinizden emin misiniz?')) return;
    try {
      const res = await fetch(`/api/admin/community/photos?id=${photoId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action, reason }),
      });
      const data = await res.json();
      if (!res.ok) { showFeedback(data?.error || 'İşlem başarısız', false); return; }
      showFeedback(data?.data?.message || 'İşlem tamamlandı', true);
      const card = document.getElementById(`card-${photoId}`);
      if (card) { card.style.transition = 'opacity .3s'; card.style.opacity = '0'; setTimeout(() => card.remove(), 300); }
    } catch { showFeedback('Bağlantı hatası', false); }
  }

  // Close modal on backdrop click
  document.getElementById('reject-modal')?.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) closeRejectModal();
  });
  </script>
</AdminLayout>
