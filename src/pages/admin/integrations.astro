---
import AdminLayout from '../../layouts/AdminLayout.astro';
import IntegrationsSettings from '../../components/admin/IntegrationsSettings';
---

<AdminLayout
  title="Entegrasyon Ayarları"
  subtitle="Resend, SMTP, Analytics, Stripe, resim sağlayıcıları ve sosyal giriş yönetimi"
>
    <div class="container mx-auto px-4 py-8 max-w-4xl">
      <div class="mb-6">
        <a href="/admin" class="text-sm text-[#9A8470] hover:text-[#6B5540]">← Admin Paneli</a>
      </div>

      <div class="bg-[rgba(200,160,100,0.06)] border border-[rgba(200,160,100,0.2)] rounded-sm p-4 mb-6 text-sm text-[#6B5540]">
        6 servis tek panelden: Resend (e-posta) → SMTP (yedek), Google Analytics, Stripe ödeme, resim sağlayıcıları (Unsplash/Pexels) ve sosyal giriş (Google/Facebook/Twitter). Değişiklikler rebuild gerektirmeden aktif olur.
      </div>

      <IntegrationsSettings client:idle />
    </div>
</AdminLayout>
