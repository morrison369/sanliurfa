---
import Layout from '../../layouts/Layout.astro';
import IntegrationsSettings from '../../components/admin/IntegrationsSettings';

if (!Astro.locals.isAdmin && Astro.locals.user?.role !== 'admin') {
  return Astro.redirect('/giris?redirect=/admin/integrations');
}

const seo = {
  title: 'Entegrasyon Ayarları - Admin',
  description: 'E-posta ve Analytics API ayarları',
  noIndex: true,
};
---

<Layout seo={seo}>
  <div class="bg-gray-50 min-h-screen pt-24 pb-10">
    <div class="container mx-auto px-4 max-w-2xl">
      <div class="mb-6">
        <a href="/admin" class="text-sm text-gray-500 hover:text-gray-700">← Admin Paneli</a>
        <h1 class="text-3xl font-bold text-gray-900 mt-2">Entegrasyon Ayarları</h1>
        <p class="mt-1 text-gray-500">E-posta (Resend) ve Google Analytics API bilgilerini girin. Değişiklikler rebuild gerektirmeden hemen aktif olur.</p>
      </div>
      <IntegrationsSettings client:idle />
    </div>
  </div>
</Layout>
