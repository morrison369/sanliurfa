---
import AdminLayout from '../../layouts/AdminLayoutV2.astro';
---

<AdminLayout
 title="Sosyal Risk Paneli"
 subtitle="Tenant bazlı trend, skor ve anomali sinyalleri."
 seo={{ title: 'Sosyal Risk Paneli - Admin', noIndex: true }}
>
 <div class="sf-container py-8 max-w-6xl space-y-5">
 <div class="mb-2">
 <a href="/admin" class="text-sm text-[#7A6B58] hover:text-[#7A6B58]">← Admin Paneli</a>
 </div>

 <div class="bg-[var(--bg-card)] border border-[var(--adm-border)] rounded-sm p-5">
 <div class="flex items-center gap-3">
 <input id="hoursInput" class="border border-[var(--adm-border-strong)] rounded-sm px-3 py-2 text-sm w-28" value="24" />
 <button id="refreshBtn" class="rounded-sm bg-urfa-600 text-white px-4 py-2 text-sm font-semibold hover:bg-urfa-700">Yenile</button>
 <button id="testWebhookBtn" class="rounded-sm bg-[#6B5540] text-white px-4 py-2 text-sm font-semibold hover:bg-[#4A3A28]">Webhook Testi</button>
 </div>
 </div>

 <div class="bg-[var(--bg-card)] border border-[var(--adm-border)] rounded-sm p-5">
 <h2 class="font-semibold text-[#7A6B58] mb-3">Eşik ve Webhook</h2>
 <div id="metaPanel" class="mt-3 text-sm text-[#7A6B58]"><span class="adm-shimmer-text">Veriler yükleniyor…</span></div>
 </div>

 <div id="cards" class="grid md:grid-cols-3 gap-4">
 <p class="text-[#7A6B58] text-sm"><span class="adm-shimmer-text">Veriler yükleniyor…</span></p>
 </div>

 <div class="bg-[var(--bg-card)] border border-[var(--adm-border)] rounded-sm p-5">
 <h2 class="font-semibold text-[#7A6B58] mb-3">Webhook Teslimat Kaydı</h2>
 <div id="webhookLog" class="mt-3 space-y-2 text-sm text-[#7A6B58]"><span class="adm-shimmer-text">Veriler yükleniyor…</span></div>
 </div>

 <div class="bg-[var(--bg-card)] border border-[var(--adm-border)] rounded-sm p-5">
 <h2 class="font-semibold text-[#7A6B58] mb-3">Webhook Yeniden Deneme ve Hata Analizi</h2>
 <div id="webhookMetrics" class="mt-3 text-sm text-[#7A6B58]"><span class="adm-shimmer-text">Veriler yükleniyor…</span></div>
 </div>
 </div>

 <script is:inline>
 const cards = document.getElementById('cards');
 const hoursInput = document.getElementById('hoursInput');
 const metaPanel = document.getElementById('metaPanel');
 const webhookLog = document.getElementById('webhookLog');
 const webhookMetrics = document.getElementById('webhookMetrics');

 function level(score) {
 if (score >= 70) return ['Yüksek', 'bg-[var(--adm-border-strong)] text-[#7A6B58]'];
 if (score >= 40) return ['Orta', 'bg-[var(--adm-bg-active)] text-[#7A6B58]'];
 return ['Düşük', 'bg-[var(--adm-bg-hover)] text-[#7A6B58]'];
 }

 async function loadRisk() {
 const hours = Number(hoursInput.value || 24);
 const res = await fetch(`/api/admin/social/risk?hours=${encodeURIComponent(hours)}`);
 const json = await res.json();
 if (!res.ok || !json?.success) {
 const p = document.createElement('p');
 p.className = 'text-[#7A6B58] text-sm';
 p.textContent = 'Risk verisi alınamadı';
 cards.replaceChildren(p);
 return;
 }
 const tenants = Array.isArray(json.tenants) ? json.tenants : [];
 if (!tenants.length) {
 const p = document.createElement('p');
 p.className = 'text-[#7A6B58] text-sm';
 p.textContent = 'Veri yok';
 cards.replaceChildren(p);
 metaPanel.textContent = 'Meta veri yok';
 return;
 }
 const thresholds = json.thresholds || {};
 const webhook = json.webhook || {};
 const autoActions = json.autoActions || {};
 const alertedTenantIds = Array.isArray(json.alertedTenantIds) ? json.alertedTenantIds : [];

 function makeMetaCard(title, rows) {
 const card = document.createElement('div');
 card.className = 'p-3 rounded-sm bg-[var(--adm-bg-hover)] border border-[var(--adm-bg-active)]';
 const h = document.createElement('div');
 h.className = 'font-semibold text-[#1F1410] text-sm mb-1';
 h.textContent = title;
 card.appendChild(h);
 rows.forEach(([cls, text]) => {
 const d = document.createElement('div');
 d.className = cls || 'text-xs text-[#7A6B58]';
 d.textContent = text;
 card.appendChild(d);
 });
 return card;
 }

 const grid = document.createElement('div');
 grid.className = 'grid md:grid-cols-4 gap-3';
 grid.appendChild(makeMetaCard('Eşik', [
 ['text-xs text-[#7A6B58]', 'scoreAlert: ' + (thresholds.scoreAlert ?? '-')],
 ['text-xs text-[#7A6B58]', 'zScoreAlert: ' + (thresholds.zScoreAlert ?? '-')],
 ['text-xs text-[#7A6B58]', 'minLastHour/minTotal: ' + (thresholds.minLastHour ?? '-') + ' / ' + (thresholds.minTotal ?? '-')],
 ]));
 grid.appendChild(makeMetaCard('Webhook', [
 ['text-xs text-[#7A6B58]', 'aktif: ' + (webhook.enabled ? 'evet' : 'hayır')],
 ['text-xs text-[#7A6B58]', 'olay: ' + (webhook.eventName || '-')],
 ['text-xs text-[#7A6B58]', 'bekleme: ' + (webhook.cooldownMinutes ?? '-') + ' dk'],
 ]));
 grid.appendChild(makeMetaCard('Son Alarm', [
 ['text-xs text-[#7A6B58]', 'Alarm alan tenant: ' + alertedTenantIds.length],
 ['text-xs text-[#7A6B58]', alertedTenantIds.slice(0, 8).join(', ') || '-'],
 ]));
 const appliedIds = (autoActions.appliedTenantIds || []);
 grid.appendChild(makeMetaCard('Otomatik Aksiyon', [
 ['text-xs text-[#7A6B58]', 'aktif: ' + (autoActions.enabled ? 'evet' : 'hayır')],
 ['text-xs text-[#7A6B58]', 'uygulanan: ' + appliedIds.length],
 ['text-xs text-[#7A6B58]', 'geri dönüş: ' + (autoActions.rollbackCount || 0)],
 ['text-xs text-[#7A6B58]', appliedIds.slice(0, 6).join(', ') || '-'],
 ]));
 metaPanel.replaceChildren(grid);

 cards.replaceChildren(...tenants.map((t) => {
 const [label, cls] = level(Number(t.score || 0));
 const card = document.createElement('div');
 card.className = 'bg-[var(--bg-card)] border border-[var(--adm-border)] rounded-sm p-5 space-y-2';

 const header = document.createElement('div');
 header.className = 'flex items-center justify-between';

 const tenantEl = document.createElement('div');
 tenantEl.className = 'font-mono text-xs text-[#7A6B58]';
 tenantEl.textContent = t.tenantId;

 const badge = document.createElement('span');
 badge.className = 'px-2 py-0.5 rounded-sm text-xs font-medium ' + cls;
 badge.textContent = label;
 header.appendChild(tenantEl);
 header.appendChild(badge);

 const scoreEl = document.createElement('div');
 scoreEl.className = 'text-3xl font-bold text-[#1F1410]';
 scoreEl.textContent = String(t.score);

 const statsEl = document.createElement('div');
 statsEl.className = 'text-xs text-[#7A6B58]';
 statsEl.textContent = 'total=' + t.total + ' | lastHour=' + t.lastHour + ' | z=' + t.zScore;

 if (t.anomaly) {
 const anomalySpan = document.createElement('span');
 anomalySpan.className = 'ml-2 text-urfa-600 font-semibold';
 anomalySpan.textContent = 'ANOMALİ';
 statsEl.appendChild(anomalySpan);
 }

 const ul = document.createElement('ul');
 ul.className = 'text-xs text-[#7A6B58] list-disc pl-4';
 const reasons = (t.reasons || []).slice(0, 4);
 if (reasons.length === 0) {
 const li = document.createElement('li');
 li.textContent = 'reason yok';
 ul.appendChild(li);
 } else {
 reasons.forEach((r) => {
 const li = document.createElement('li');
 li.textContent = r.reason + ': ' + r.count;
 ul.appendChild(li);
 });
 }
 card.appendChild(header);
 card.appendChild(scoreEl);
 card.appendChild(statsEl);
 card.appendChild(ul);
 return card;
 }));

 await loadWebhookLog();
 await loadWebhookMetrics();
 }

 async function loadWebhookLog() {
 const res = await fetch('/api/admin/social/risk/webhook-log?limit=20');
 const json = await res.json();
 if (!res.ok || !json?.success) {
 webhookLog.textContent = 'Webhook log alınamadı';
 return;
 }
 const items = Array.isArray(json.items) ? json.items : [];
 if (!items.length) {
 webhookLog.textContent = 'Kayıt yok';
 return;
 }
 webhookLog.replaceChildren(...items.map((x) => {
 const wrap = document.createElement('div');
 wrap.className = 'rounded-sm border border-[var(--adm-border)] p-2';

 const ts = document.createElement('div');
 ts.className = 'text-xs text-[#7A6B58]';
 ts.textContent = new Date(x.delivered_at).toLocaleString('tr-TR');

 const stat = document.createElement('div');
 stat.className = 'text-xs text-[#7A6B58]';
 stat.textContent = 'status=' + (x.response_status || '-') + ' retry=' + (x.retry_count || 0);

 const err = document.createElement('div');
 err.className = 'text-xs text-[#7A6B58]';
 err.textContent = x.error || '';

 wrap.appendChild(ts);
 wrap.appendChild(stat);
 wrap.appendChild(err);
 return wrap;
 }));
 }

 async function loadWebhookMetrics() {
 const res = await fetch('/api/admin/social/risk/webhook-metrics');
 const json = await res.json();
 if (!res.ok || !json?.success) {
 webhookMetrics.textContent = 'Webhook metrikleri alınamadı';
 return;
 }
 const retry = Array.isArray(json.retryBuckets) ? json.retryBuckets : [];
 const fail = Array.isArray(json.failureClasses) ? json.failureClasses : [];
 const summary = json.summary || {};
 const latency = json.latency || {};

 function wmCard(cls, label, value) {
 const d = document.createElement('div');
 d.className = 'p-3 rounded-sm ' + cls;
 const h = document.createElement('div');
 h.className = 'font-semibold text-sm';
 h.textContent = label;
 const v = document.createElement('div');
 v.className = 'text-lg font-bold mt-1';
 v.textContent = String(value);
 d.appendChild(h);
 d.appendChild(v);
 return d;
 }

 function wmList(title, items, fn) {
 const d = document.createElement('div');
 d.className = 'p-3 rounded-sm border border-[var(--adm-border)]';
 const h = document.createElement('div');
 h.className = 'font-semibold text-[#1F1410] text-sm mb-2';
 h.textContent = title;
 const ul = document.createElement('ul');
 ul.className = 'text-xs space-y-1 text-[#7A6B58]';
 if (!items.length) {
 const li = document.createElement('li');
 li.textContent = 'veri yok';
 ul.appendChild(li);
 } else {
 items.forEach((item) => {
 const li = document.createElement('li');
 li.textContent = fn(item);
 ul.appendChild(li);
 });
 }
 d.appendChild(h);
 d.appendChild(ul);
 return d;
 }

 const g1 = document.createElement('div');
 g1.className = 'grid md:grid-cols-3 gap-3 mb-3';
 g1.appendChild(wmCard('bg-[var(--adm-bg-hover)] text-[#7A6B58]', 'Toplam', summary.total || 0));
 g1.appendChild(wmCard('bg-[var(--adm-bg-active)] text-[#7A6B58]', 'Başarılı', summary.success_count || 0));
 g1.appendChild(wmCard('bg-[var(--adm-bg-hover)] text-[#7A6B58]', 'Başarısız', summary.failure_count || 0));

 const g2 = document.createElement('div');
 g2.className = 'grid md:grid-cols-2 gap-3 mb-3';
 g2.appendChild(wmCard('bg-[var(--adm-bg-hover)] text-[#7A6B58]', 'Gecikme p50', Math.round(Number(latency.p50_ms || 0)) + ' ms'));
 g2.appendChild(wmCard('bg-[var(--adm-bg-hover)] text-[#7A6B58]', 'Gecikme p95', Math.round(Number(latency.p95_ms || 0)) + ' ms'));

 const g3 = document.createElement('div');
 g3.className = 'grid md:grid-cols-2 gap-3';
 g3.appendChild(wmList('Yeniden Deneme Dağılımı', retry, (r) => 'retry=' + r.retry_count + ': ' + r.count));
 g3.appendChild(wmList('Hata Sınıfları', fail, (f) => f.failure_class + ': ' + f.count));

 webhookMetrics.replaceChildren(g1, g2, g3);
 }

 document.getElementById('refreshBtn').addEventListener('click', () => void loadRisk());
 document.getElementById('testWebhookBtn').addEventListener('click', async () => {
 const res = await fetch('/api/admin/social/risk/webhook-test', {
 method: 'POST',
 headers: { 'Content-Type': 'application/json' },
 body: JSON.stringify({ tenantId: 'manual-test', score: 91, zScore: 3.1 }),
 });
 const json = await res.json();
 if (!res.ok || !json?.success) {
 window.toast?.error('Webhook test başarısız');
 return;
 }
 await loadWebhookLog();
 });

 void loadRisk();
 </script>
</AdminLayout>
