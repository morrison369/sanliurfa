---
import Layout from '../../layouts/Layout.astro';

const seo = {
  title: 'Sosyal Risk Paneli - Yönetim',
  description: 'Tenant bazlı sosyal kötüye kullanım trend ve anomali takibi.',
  noIndex: true,
};
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50 pt-20 pb-12">
    <div class="container mx-auto px-4 space-y-6">
      <div class="bg-white rounded-xl shadow-sm p-6">
        <h1 class="text-2xl font-bold text-gray-900">Sosyal Risk Paneli</h1>
        <p class="text-gray-500 mt-1">Tenant bazlı trend, skor ve anomali sinyalleri.</p>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6">
        <div class="flex items-center gap-3">
          <input id="hoursInput" class="border rounded-lg px-3 py-2 w-32" value="24" />
          <button id="refreshBtn" class="rounded-lg bg-slate-900 text-white px-4 py-2 font-semibold">Yenile</button>
        <button id="testWebhookBtn" class="rounded-lg bg-rose-700 text-white px-4 py-2 font-semibold">Webhook Testi</button>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6">
        <h2 class="text-lg font-bold text-gray-900">Eşik ve Webhook</h2>
        <div id="metaPanel" class="mt-3 text-sm text-gray-600">Yükleniyor...</div>
      </div>

      <div id="cards" class="grid md:grid-cols-3 gap-4">
        <p class="text-gray-400">Yükleniyor...</p>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6">
        <h2 class="text-lg font-bold text-gray-900">Webhook Teslimat Kaydı</h2>
        <div id="webhookLog" class="mt-3 space-y-2 text-sm text-gray-600">Yükleniyor...</div>
      </div>

      <div class="bg-white rounded-xl shadow-sm p-6">
        <h2 class="text-lg font-bold text-gray-900">Webhook Yeniden Deneme ve Hata Analizi</h2>
        <div id="webhookMetrics" class="mt-3 text-sm text-gray-600">Yükleniyor...</div>
      </div>
    </div>
  </div>

  <script is:inline>
    const cards = document.getElementById('cards');
    const hoursInput = document.getElementById('hoursInput');
    const metaPanel = document.getElementById('metaPanel');
    const webhookLog = document.getElementById('webhookLog');
    const webhookMetrics = document.getElementById('webhookMetrics');

    function level(score) {
      if (score >= 70) return ['Yüksek', 'bg-red-100 text-red-700'];
      if (score >= 40) return ['Orta', 'bg-amber-100 text-amber-700'];
      return ['Düşük', 'bg-emerald-100 text-emerald-700'];
    }

    async function loadRisk() {
      const hours = Number(hoursInput.value || 24);
      const res = await fetch(`/api/admin/social/risk?hours=${encodeURIComponent(hours)}`);
      const json = await res.json();
      if (!res.ok || !json?.success) {
        cards.innerHTML = '<p class="text-red-600">Risk verisi alınamadı</p>';
        return;
      }
      const tenants = Array.isArray(json.tenants) ? json.tenants : [];
      if (!tenants.length) {
        cards.innerHTML = '<p class="text-gray-400">Veri yok</p>';
        metaPanel.innerHTML = '<p class="text-gray-400">Meta veri yok</p>';
        return;
      }
      const thresholds = json.thresholds || {};
      const webhook = json.webhook || {};
      const autoActions = json.autoActions || {};
      const alertedTenantIds = Array.isArray(json.alertedTenantIds) ? json.alertedTenantIds : [];
      metaPanel.innerHTML = `
        <div class="grid md:grid-cols-4 gap-3">
          <div class="p-3 rounded bg-gray-50">
            <div class="font-semibold text-gray-800">Eşik</div>
            <div>scoreAlert: ${thresholds.scoreAlert ?? '-'}</div>
            <div>zScoreAlert: ${thresholds.zScoreAlert ?? '-'}</div>
            <div>minLastHour/minTotal: ${thresholds.minLastHour ?? '-'} / ${thresholds.minTotal ?? '-'}</div>
          </div>
          <div class="p-3 rounded bg-gray-50">
            <div class="font-semibold text-gray-800">Webhook</div>
            <div>aktif: ${webhook.enabled ? 'evet' : 'hayır'}</div>
            <div>olay: ${webhook.eventName || '-'}</div>
            <div>bekleme: ${webhook.cooldownMinutes ?? '-'} dk</div>
          </div>
          <div class="p-3 rounded bg-gray-50">
            <div class="font-semibold text-gray-800">Son Alarm</div>
            <div>Alarm alan tenant: ${alertedTenantIds.length}</div>
            <div class="text-xs">${alertedTenantIds.slice(0, 8).join(', ') || '-'}</div>
          </div>
          <div class="p-3 rounded bg-gray-50">
            <div class="font-semibold text-gray-800">Otomatik Aksiyon</div>
            <div>aktif: ${autoActions.enabled ? 'evet' : 'hayır'}</div>
            <div>uygulanan: ${(autoActions.appliedTenantIds || []).length}</div>
            <div>geri dönüş: ${autoActions.rollbackCount || 0}</div>
            <div class="text-xs">${(autoActions.appliedTenantIds || []).slice(0, 6).join(', ') || '-'}</div>
          </div>
        </div>
      `;
      cards.innerHTML = tenants.map((t) => {
        const [label, cls] = level(Number(t.score || 0));
        const reasonRows = (t.reasons || []).slice(0, 4).map((r) => `<li>${r.reason}: ${r.count}</li>`).join('');
        return `
          <div class="bg-white rounded-xl shadow-sm p-5 space-y-2">
            <div class="flex items-center justify-between">
              <div class="font-mono text-sm text-gray-700">${t.tenantId}</div>
              <span class="px-2 py-1 rounded text-xs font-semibold ${cls}">${label}</span>
            </div>
            <div class="text-3xl font-bold text-gray-900">${t.score}</div>
            <div class="text-xs text-gray-500">
              total=${t.total} | lastHour=${t.lastHour} | z=${t.zScore}
              ${t.anomaly ? '<span class="ml-2 text-red-600 font-semibold">ANOMALİ</span>' : ''}
            </div>
            <ul class="text-xs text-gray-600 list-disc pl-4">
              ${reasonRows || '<li>reason yok</li>'}
            </ul>
          </div>
        `;
      }).join('');
      await loadWebhookLog();
      await loadWebhookMetrics();
    }

    async function loadWebhookLog() {
      const res = await fetch('/api/admin/social/risk/webhook-log?limit=20');
      const json = await res.json();
      if (!res.ok || !json?.success) {
        webhookLog.innerHTML = '<p class="text-red-600">Webhook log alınamadı</p>';
        return;
      }
      const items = Array.isArray(json.items) ? json.items : [];
      if (!items.length) {
        webhookLog.innerHTML = '<p class="text-gray-400">Kayıt yok</p>';
        return;
      }
      webhookLog.innerHTML = items.map((x) => `
        <div class="rounded border border-gray-200 p-2">
          <div class="text-xs text-gray-500">${new Date(x.delivered_at).toLocaleString('tr-TR')}</div>
          <div class="text-xs">status=${x.response_status || '-'} retry=${x.retry_count || 0}</div>
          <div class="text-xs text-rose-700">${x.error || ''}</div>
        </div>
      `).join('');
    }

    async function loadWebhookMetrics() {
      const res = await fetch('/api/admin/social/risk/webhook-metrics');
      const json = await res.json();
      if (!res.ok || !json?.success) {
        webhookMetrics.innerHTML = '<p class="text-red-600">Webhook metrikleri alınamadı</p>';
        return;
      }
      const retry = Array.isArray(json.retryBuckets) ? json.retryBuckets : [];
      const fail = Array.isArray(json.failureClasses) ? json.failureClasses : [];
      const summary = json.summary || {};
      const latency = json.latency || {};
      webhookMetrics.innerHTML = `
        <div class="grid md:grid-cols-3 gap-3 mb-3">
          <div class="p-3 rounded bg-gray-50"><div class="font-semibold">Toplam</div><div>${summary.total || 0}</div></div>
          <div class="p-3 rounded bg-emerald-50 text-emerald-800"><div class="font-semibold">Başarılı</div><div>${summary.success_count || 0}</div></div>
          <div class="p-3 rounded bg-rose-50 text-rose-800"><div class="font-semibold">Başarısız</div><div>${summary.failure_count || 0}</div></div>
        </div>
        <div class="grid md:grid-cols-2 gap-3 mb-3">
          <div class="p-3 rounded bg-gray-50"><div class="font-semibold">Gecikme p50</div><div>${Math.round(Number(latency.p50_ms || 0))} ms</div></div>
          <div class="p-3 rounded bg-gray-50"><div class="font-semibold">Gecikme p95</div><div>${Math.round(Number(latency.p95_ms || 0))} ms</div></div>
        </div>
        <div class="grid md:grid-cols-2 gap-3">
          <div class="p-3 rounded border border-gray-200">
            <div class="font-semibold text-gray-800 mb-2">Yeniden Deneme Dağılımı</div>
            <ul class="text-xs space-y-1">${retry.map((r) => `<li>retry=${r.retry_count}: ${r.count}</li>`).join('') || '<li>veri yok</li>'}</ul>
          </div>
          <div class="p-3 rounded border border-gray-200">
            <div class="font-semibold text-gray-800 mb-2">Hata Sınıfları</div>
            <ul class="text-xs space-y-1">${fail.map((f) => `<li>${f.failure_class}: ${f.count}</li>`).join('') || '<li>veri yok</li>'}</ul>
          </div>
        </div>
      `;
    }

    document.getElementById('refreshBtn').addEventListener('click', () => void loadRisk());
    document.getElementById('testWebhookBtn').addEventListener('click', async () => {
      const res = await fetch('/api/admin/social/risk/webhook-test', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ tenantId: 'manual-test', score: 91, zScore: 3.1 }),
      });
      const json = await res.json();
      if (!res.ok || !json?.success) {
        alert('Webhook test başarısız');
        return;
      }
      await loadWebhookLog();
    });
    void loadRisk();
  </script>
</Layout>
