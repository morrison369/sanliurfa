---
import { Icon } from 'astro-icon/components';
import AdminLayout from '../../layouts/AdminLayoutV2.astro';
import AdmStatGrid from '../../components/admin/AdmStatGrid.astro';
import AdmEmptyState from '../../components/admin/AdmEmptyState.astro';
import { query } from '../../lib/postgres';
import { logger } from '../../lib/logging';

interface Reservation {
 id: string;
 customer_name: string;
 customer_phone: string;
 customer_email: string;
 reservation_date: string;
 reservation_time: string;
 party_size: number;
 status: string;
 special_requests?: string;
 occasion?: string;
 created_at: string;
 place_name: string;
 place_slug: string;
}

let reservations: Reservation[] = [];
let stats = { total: 0, pending: 0, confirmed: 0, completed: 0, cancelled: 0 };

const statusFilter = Astro.url.searchParams.get('status') || '';
const dateFilter = Astro.url.searchParams.get('date') || '';

try {
 let sql = `
  SELECT r.id, r.customer_name, r.customer_phone, r.customer_email,
   r.reservation_date, r.reservation_time, r.party_size,
   r.status, r.special_requests, r.occasion, r.created_at,
   p.name as place_name, p.slug as place_slug
  FROM reservations r
  JOIN places p ON r.place_id = p.id
  WHERE 1=1
 `;
 const params: unknown[] = [];
 let i = 1;
 if (statusFilter) { sql += ` AND r.status = $${i++}`; params.push(statusFilter); }
 if (dateFilter)   { sql += ` AND r.reservation_date = $${i++}`; params.push(dateFilter); }
 sql += ` ORDER BY r.created_at DESC LIMIT 100`;

 const result = await query<Reservation>(sql, params);
 reservations = result.rows;
} catch (e) {
 logger.error('Reservations admin query failed', e instanceof Error ? e : new Error(String(e)));
}

try {
 const r = await query<{ status: string; cnt: number }>(
  `SELECT status, COUNT(*)::int AS cnt FROM reservations GROUP BY status`
 );
 for (const row of r.rows) {
  const k = row.status as keyof typeof stats;
  if (k in stats) stats[k] = row.cnt;
  stats.total += row.cnt;
 }
} catch (e) {
 logger.error('Reservations stats failed', e instanceof Error ? e : new Error(String(e)));
}

const statusLabels: Record<string, { text: string; cls: string }> = {
 pending:   { text: 'Bekliyor',    cls: 'rs-badge--warn' },
 confirmed: { text: 'Onaylandı',   cls: 'rs-badge--ok' },
 cancelled: { text: 'İptal',       cls: 'rs-badge--err' },
 completed: { text: 'Tamamlandı',  cls: 'rs-badge--info' },
 no_show:   { text: 'Gelmedi',     cls: 'rs-badge--muted' },
};
---

<AdminLayout
 title="Rezervasyon Yönetimi"
 subtitle={`${stats.total.toLocaleString('tr-TR')} rezervasyon • ${stats.pending} onay bekliyor`}
 seo={{ title: 'Rezervasyon Yönetimi - Admin', noIndex: true }}
>
 <div class="rs-page">
  <AdmStatGrid stats={[
   { label: 'Toplam', value: stats.total, icon: 'lucide:calendar', color: 'indigo' },
   { label: 'Onay Bekleyen', value: stats.pending, icon: 'lucide:clock', color: 'amber' },
   { label: 'Onaylı', value: stats.confirmed, icon: 'lucide:check-circle', color: 'emerald' },
   { label: 'Tamamlandı', value: stats.completed, icon: 'lucide:check-square', color: 'sky' },
   { label: 'İptal', value: stats.cancelled, icon: 'lucide:x-circle', color: 'rose' },
  ]} />

  <form method="get" class="rs-toolbar">
   <div class="rs-toolbar-field">
    <label class="rs-toolbar-label">Durum</label>
    <select name="status" class="rs-select">
     <option value="">Tüm Durumlar</option>
     {Object.entries(statusLabels).map(([val, meta]) => (
      <option value={val} selected={statusFilter === val}>{meta.text}</option>
     ))}
    </select>
   </div>
   <div class="rs-toolbar-field">
    <label class="rs-toolbar-label">Tarih</label>
    <input type="date" name="date" value={dateFilter} class="rs-select" />
   </div>
   <div class="rs-toolbar-actions">
    <button type="submit" class="rs-btn">
     <Icon name="lucide:filter" class="w-4 h-4" /> Filtrele
    </button>
    {(statusFilter || dateFilter) && (
     <a href="/admin/reservations" class="rs-btn rs-btn--ghost">
      <Icon name="lucide:x" class="w-4 h-4" /> Temizle
     </a>
    )}
   </div>
  </form>

  <div class="rs-table-wrap">
   {reservations.length === 0 ? (
    <AdmEmptyState
     icon="lucide:calendar-x"
     title="Rezervasyon bulunamadı"
     description={statusFilter || dateFilter ? 'Filtre kriterlerinize uygun rezervasyon yok. Filtreyi temizleyip tekrar deneyin.' : 'Henüz bir rezervasyon yok. Müşteriler işletme sayfalarından rezervasyon yapabilir.'}
     size="md"
    />
   ) : (
    <table class="rs-table">
     <thead>
      <tr>
       <th class="rs-th">Müşteri</th>
       <th class="rs-th">Mekan</th>
       <th class="rs-th">Tarih / Saat</th>
       <th class="rs-th rs-th-num">Kişi</th>
       <th class="rs-th">Durum</th>
       <th class="rs-th rs-th-actions">İşlem</th>
      </tr>
     </thead>
     <tbody>
      {reservations.map(r => {
       const meta = statusLabels[r.status] || { text: r.status, cls: 'rs-badge--muted' };
       return (
        <tr>
         <td class="rs-td">
          <div class="rs-customer">
           <div class="rs-customer-name">{r.customer_name}</div>
           <div class="rs-customer-phone">
            <Icon name="lucide:phone" class="w-3 h-3" />
            {r.customer_phone}
           </div>
          </div>
         </td>
         <td class="rs-td">
          <a href={`/isletme/${r.place_slug}`} target="_blank" rel="noopener" class="rs-place-link">
           <Icon name="lucide:store" class="w-3 h-3" />
           {r.place_name}
          </a>
         </td>
         <td class="rs-td">
          <div class="rs-date">{new Date(r.reservation_date).toLocaleDateString('tr-TR', { day: '2-digit', month: 'short', year: 'numeric' })}</div>
          <div class="rs-time">
           <Icon name="lucide:clock" class="w-3 h-3" />
           {r.reservation_time}
          </div>
         </td>
         <td class="rs-td rs-td-num">
          <span class="rs-party">
           <Icon name="lucide:users" class="w-3 h-3" /> {r.party_size}
          </span>
         </td>
         <td class="rs-td">
          <span class:list={['rs-badge', meta.cls]}>{meta.text}</span>
         </td>
         <td class="rs-td rs-td-actions" data-reservation-id={r.id}>
          {r.status === 'pending' && (
           <button class="rs-row-btn rs-row-btn--ok confirm-btn" data-id={r.id}>
            <Icon name="lucide:check" class="w-3.5 h-3.5" /> Onayla
           </button>
          )}
          {(r.status === 'pending' || r.status === 'confirmed') && (
           <button class="rs-row-btn rs-row-btn--danger cancel-btn" data-id={r.id}>
            <Icon name="lucide:x" class="w-3.5 h-3.5" /> İptal
           </button>
          )}
          {r.status === 'confirmed' && (
           <button class="rs-row-btn complete-btn" data-id={r.id}>
            <Icon name="lucide:check-square" class="w-3.5 h-3.5" /> Tamamlandı
           </button>
          )}
         </td>
        </tr>
       );
      })}
     </tbody>
    </table>
   )}
  </div>
 </div>

 <script is:inline>
  async function updateStatus(id, status) {
   const res = await fetch('/api/reservations/' + id, {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ status }),
   });
   if (res.ok) location.reload();
   else window.toast?.error('İşlem başarısız oldu.');
  }
  document.querySelectorAll('.confirm-btn').forEach(btn => {
   btn.addEventListener('click', () => updateStatus(btn.dataset.id, 'confirmed'));
  });
  document.querySelectorAll('.cancel-btn').forEach(btn => {
   btn.addEventListener('click', () => updateStatus(btn.dataset.id, 'cancelled'));
  });
  document.querySelectorAll('.complete-btn').forEach(btn => {
   btn.addEventListener('click', () => updateStatus(btn.dataset.id, 'completed'));
  });
 </script>

 <style>
  .rs-page { display: flex; flex-direction: column; gap: 1.25rem; }

  .rs-toolbar {
   background: var(--adm-bg-elev);
   border: 1px solid var(--adm-border);
   border-radius: 12px;
   padding: 0.85rem 1rem;
   display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: flex-end;
  }
  .rs-toolbar-field {
   display: flex; flex-direction: column; gap: 0.25rem;
   min-width: 180px;
  }
  .rs-toolbar-label {
   font-size: 0.72rem; font-weight: 600;
   color: var(--adm-text-soft);
   text-transform: uppercase;
   letter-spacing: 0.04em;
  }
  .rs-select {
   padding: 0.5rem 0.75rem;
   background: var(--adm-bg);
   border: 1px solid var(--adm-border);
   border-radius: 8px;
   font-size: 0.86rem;
   color: var(--adm-text);
   cursor: pointer;
  }
  .rs-select:focus { outline: none; border-color: var(--adm-accent); }
  .rs-toolbar-actions { display: flex; gap: 0.5rem; }
  .rs-btn {
   display: inline-flex; align-items: center; gap: 0.35rem;
   padding: 0.55rem 1rem;
   background: var(--adm-accent);
   color: #fff;
   border: 1px solid var(--adm-accent);
   border-radius: 8px;
   font-weight: 600; font-size: 0.82rem;
   cursor: pointer;
   text-decoration: none;
  }
  .rs-btn:hover { filter: brightness(0.92); }
  .rs-btn--ghost {
   background: transparent;
   color: var(--adm-text-muted);
   border-color: var(--adm-border);
  }
  .rs-btn--ghost:hover { border-color: var(--adm-accent); color: var(--adm-accent); }

  .rs-table-wrap {
   overflow-x: auto;
   background: var(--adm-bg-elev);
   border: 1px solid var(--adm-border);
   border-radius: 12px;
  }
  .rs-table { width: 100%; border-collapse: collapse; }
  .rs-th {
   text-align: left;
   font-size: 0.7rem;
   font-weight: 700;
   letter-spacing: 0.06em;
   text-transform: uppercase;
   color: var(--adm-text-soft);
   padding: 0.85rem 1rem;
   background: var(--adm-bg-hover);
   border-bottom: 1px solid var(--adm-border);
  }
  .rs-th-num { text-align: right; }
  .rs-th-actions { text-align: right; width: 280px; }
  .rs-table tbody tr {
   border-bottom: 1px solid var(--adm-border);
   transition: background 0.12s;
  }
  .rs-table tbody tr:last-child { border-bottom: none; }
  .rs-table tbody tr:hover { background: var(--adm-bg-hover); }
  .rs-td { padding: 0.85rem 1rem; font-size: 0.86rem; color: var(--adm-text); vertical-align: middle; }
  .rs-td-num { text-align: right; }
  .rs-td-actions { text-align: right; white-space: nowrap; }

  .rs-customer-name {
   font-weight: 600;
   color: var(--adm-text);
   line-height: 1.3;
  }
  .rs-customer-phone {
   display: inline-flex; align-items: center; gap: 0.25rem;
   font-size: 0.76rem;
   color: var(--adm-text-soft);
   margin-top: 0.2rem;
  }

  .rs-place-link {
   display: inline-flex; align-items: center; gap: 0.3rem;
   color: var(--adm-accent);
   text-decoration: none;
   font-weight: 500;
   font-size: 0.86rem;
  }
  .rs-place-link:hover { text-decoration: underline; }

  .rs-date {
   font-weight: 500;
   color: var(--adm-text);
  }
  .rs-time {
   display: inline-flex; align-items: center; gap: 0.25rem;
   font-size: 0.76rem;
   color: var(--adm-text-soft);
   margin-top: 0.2rem;
  }

  .rs-party {
   display: inline-flex; align-items: center; gap: 0.25rem;
   padding: 0.25rem 0.55rem;
   background: var(--adm-bg);
   border-radius: 6px;
   font-size: 0.82rem; font-weight: 600;
   color: var(--adm-text);
  }

  .rs-badge {
   display: inline-flex; align-items: center;
   padding: 0.22rem 0.6rem;
   font-size: 0.72rem; font-weight: 600;
   border-radius: 999px;
  }
  .rs-badge--ok    { background: rgba(16,185,129,0.12); color: rgb(5,150,105); }
  .rs-badge--warn  { background: rgba(217,119,6,0.12); color: rgb(180,83,9); }
  .rs-badge--err   { background: rgba(225,29,72,0.12); color: rgb(190,18,60); }
  .rs-badge--info  { background: rgba(2,132,199,0.12); color: rgb(2,132,199); }
  .rs-badge--muted { background: rgba(100,116,139,0.12); color: rgb(71,85,105); }

  .rs-row-btn {
   display: inline-flex; align-items: center; gap: 0.3rem;
   padding: 0.38rem 0.7rem;
   font-size: 0.78rem;
   font-weight: 500;
   color: var(--adm-text-muted);
   background: transparent;
   border: 1px solid var(--adm-border);
   border-radius: 6px;
   text-decoration: none;
   cursor: pointer;
   margin-left: 0.35rem;
   transition: all 0.15s;
  }
  .rs-row-btn:hover { border-color: var(--adm-text-muted); color: var(--adm-text); background: var(--adm-bg); }
  .rs-row-btn--ok { color: rgb(5,150,105); border-color: rgba(16,185,129,0.3); }
  .rs-row-btn--ok:hover { background: rgba(16,185,129,0.08); border-color: rgb(5,150,105); }
  .rs-row-btn--danger { color: rgb(190,18,60); border-color: rgba(225,29,72,0.3); }
  .rs-row-btn--danger:hover { background: rgba(225,29,72,0.08); border-color: rgb(190,18,60); }
 </style>
</AdminLayout>
