---
import Layout from '../../layouts/Layout.astro';

const user = Astro.locals.user;

if (!user || !Astro.locals.isAdmin) {
  return Astro.redirect('/giris?redirect=/admin/audit');
}

const seo = {
  title: 'Admin Denetimi - Şanlıurfa.com',
  description: 'Admin işlem denetim kayıtlarını uç nokta, yöntem ve sonuç bazında inceleyin.',
};
---

<Layout seo={seo}>
  <section class="min-h-screen bg-gray-100 dark:bg-gray-950 py-8">
    <div class="container-custom space-y-6">
      <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-urfa-600">Admin Denetimi</p>
          <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Admin işlem denetim kayıtları</h1>
          <p class="mt-2 max-w-3xl text-sm text-gray-600 dark:text-gray-400">
            Kalıcı admin işlem denetim verisini uç nokta, yöntem, kip ve durum kodu bazında filtreleyin.
          </p>
        </div>
        <button
          id="refresh-admin-audit"
          class="inline-flex items-center justify-center rounded-xl bg-urfa-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-urfa-700"
          type="button"
        >
          Yenile
        </button>
      </div>

      <div class="grid gap-4 md:grid-cols-8">
        <input id="audit-endpoint" class="rounded-xl border border-gray-300 px-3 py-2 text-sm" placeholder="uç nokta filtresi" />
        <input id="audit-actor" class="rounded-xl border border-gray-300 px-3 py-2 text-sm" placeholder="aktör anahtarı filtresi" />
        <input id="audit-request-id" class="rounded-xl border border-gray-300 px-3 py-2 text-sm" placeholder="istek kimliği filtresi" />
        <select id="audit-mode" class="rounded-xl border border-gray-300 px-3 py-2 text-sm">
          <option value="">Tüm kipler</option>
          <option value="read">okuma</option>
          <option value="write">yazma</option>
        </select>
        <select id="audit-outcome" class="rounded-xl border border-gray-300 px-3 py-2 text-sm">
          <option value="">Tüm sonuçlar</option>
          <option value="allowed">izin verildi</option>
          <option value="denied">reddedildi</option>
          <option value="error">hata</option>
        </select>
        <input id="audit-status" class="rounded-xl border border-gray-300 px-3 py-2 text-sm" placeholder="durum kodu" />
        <input id="audit-start-date" class="rounded-xl border border-gray-300 px-3 py-2 text-sm" type="datetime-local" />
        <input id="audit-end-date" class="rounded-xl border border-gray-300 px-3 py-2 text-sm" type="datetime-local" />
      </div>

      <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
        <p class="text-xs text-gray-500 dark:text-gray-400">
          Tarih alanları sunucu taraflı filtre uygular. Diğer alanlar yüklü kayıtlar üzerinde yerel filtrelenir.
        </p>
        <button
          id="export-admin-audit-csv"
          class="inline-flex items-center justify-center rounded-xl border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 transition hover:border-urfa-600 hover:text-urfa-700 dark:border-gray-700 dark:text-gray-200"
          type="button"
        >
          CSV İndir
        </button>
      </div>

      <div id="audit-summary" class="rounded-2xl border border-gray-200 bg-white p-4 text-sm text-gray-600 shadow-sm dark:border-gray-800 dark:bg-gray-900 dark:text-gray-300">
        Denetim verileri yükleniyor.
      </div>

      <div class="overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm dark:border-gray-800 dark:bg-gray-900">
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200 text-sm dark:divide-gray-800">
            <thead class="bg-gray-50 dark:bg-gray-900/40">
              <tr>
                <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">Zaman</th>
                <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">Uç nokta</th>
                <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">Yöntem</th>
                <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">Kip</th>
                <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">Sonuç</th>
                <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">Durum</th>
                <th class="px-4 py-3 text-left font-semibold text-gray-700 dark:text-gray-300">Aktör</th>
              </tr>
            </thead>
            <tbody id="audit-rows" class="divide-y divide-gray-100 dark:divide-gray-800">
              <tr><td colspan="7" class="px-4 py-6 text-center text-gray-500">Yükleniyor...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <script type="module">
    import { initAdminAuditPage } from '../../scripts/admin-audit-page.ts';

    initAdminAuditPage();
  </script>
</Layout>
