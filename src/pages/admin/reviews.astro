---
import { actions } from 'astro:actions';
import AdminLayout from '../../layouts/AdminLayout.astro';
import { query } from '../../lib/postgres';
import { logger } from '../../lib/logging';

let pendingReviews: any[] = [];
const moderationResult = Astro.getActionResult(actions.moderateReview);

try {
  const result = await query(
    `SELECT r.*, p.name as place_name, p.slug as place_slug, u.full_name as user_name
     FROM reviews r
     JOIN places p ON r.place_id = p.id
     JOIN users u ON r.user_id = u.id
     WHERE r.is_moderated = false
     ORDER BY r.created_at DESC`
  );
  pendingReviews = result.rows;
} catch (e) {
  logger.error('Error loading admin reviews', e instanceof Error ? e : new Error(String(e)));
}
---

<AdminLayout
  title="Yorum Moderasyonu"
  subtitle="Onay bekleyen yorumları inceleyin ve yönetin"
  seo={{ title: 'Yorum Moderasyonu - Admin', description: 'Admin yorum moderasyon ekranı', noIndex: true }}
>
    <div class="container mx-auto px-4 py-8">
      <div class="flex items-center justify-between mb-6">
        <a href="/admin" class="text-urfa-600 hover:text-urfa-700 text-sm">← Yönetim Paneli</a>
      </div>

      {moderationResult?.data?.success && (
        <div class="mb-4 rounded-sm border border-[rgba(200,160,100,0.2)] bg-[rgba(200,160,100,0.06)] px-4 py-3 text-sm text-[#6B5540]">
          Yorum moderasyon işlemi tamamlandı.
        </div>
      )}

      {moderationResult?.error && (
        <div class="mb-4 rounded-sm border border-[rgba(200,160,100,0.2)] bg-[rgba(200,160,100,0.06)] px-4 py-3 text-sm text-[#9A8470]">
          {moderationResult.error.message || 'Yorum moderasyon işlemi tamamlanamadı.'}
        </div>
      )}

      {pendingReviews.length > 0 ? (
        <div class="space-y-4">
          {pendingReviews.map((review) => (
            <div class="bg-white rounded-sm border border-[rgba(200,160,100,0.18)] p-6 shadow-sm">
              <div class="flex items-start justify-between">
                <div>
                  <div class="flex items-center gap-2">
                    <span class="font-semibold text-[#1A1008]">{review.user_name}</span>
                    <span class="text-[#9A8470]">→</span>
                    <a href={`/isletme/${review.place_slug}`} class="text-urfa-600 hover:underline">
                      {review.place_name}
                    </a>
                  </div>
                  <div class="flex items-center gap-1 text-urfa-600 my-2">
                    {[...Array(5)].map((_, i) => (
                      <svg class={`w-4 h-4 ${i < review.rating ? 'fill-current' : 'text-[rgba(200,160,100,0.2)]'}`} viewBox="0 0 20 20">
                        <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                      </svg>
                    ))}
                  </div>
                  {review.title && <h4 class="font-medium text-[#1A1008]">{review.title}</h4>}
                  <p class="text-[#6B5540] mt-1">{review.content}</p>
                  <span class="text-sm text-[#9A8470]">{new Date(review.created_at).toLocaleDateString('tr-TR')}</span>
                </div>
                <div class="flex gap-2">
                  <form method="POST" action={actions.moderateReview}>
                    <input type="hidden" name="id" value={review.id} />
                    <input type="hidden" name="decision" value="approve" />
                    <button type="submit" class="px-4 py-2 rounded-sm bg-[#6B5540] text-white hover:bg-[#4A3A28]">
                      Onayla
                    </button>
                  </form>
                  <form method="POST" action={actions.moderateReview}>
                    <input type="hidden" name="id" value={review.id} />
                    <input type="hidden" name="decision" value="reject" />
                    <button type="submit" class="px-4 py-2 rounded-sm bg-[#9A8470] text-white hover:bg-[#6B5540]">
                      Reddet
                    </button>
                  </form>
                </div>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-12 bg-white rounded-sm border border-[rgba(200,160,100,0.18)]">
          <p class="text-[#6B5540]">Onay bekleyen yorum bulunmuyor.</p>
        </div>
      )}
    </div>
</AdminLayout>
