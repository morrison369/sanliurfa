---
import { Icon } from 'astro-icon/components';
import { actions } from 'astro:actions';
import AdminLayout from '../../layouts/AdminLayoutV2.astro';
import AdmEmptyState from '../../components/admin/AdmEmptyState.astro';
import AdmStatGrid from '../../components/admin/AdmStatGrid.astro';
import { query } from '../../lib/postgres';
import { logger } from '../../lib/logging';

interface ReviewRow {
 id: string;
 place_id: string;
 user_id: string;
 rating: number;
 title?: string;
 content?: string;
 created_at: string;
 place_name: string;
 place_slug: string;
 user_name: string;
}

let pendingReviews: ReviewRow[] = [];
let stats = { pending: 0, approved: 0, rejected: 0, total: 0, avgRating: 0 };
const moderationResult = Astro.getActionResult(actions.moderateReview);

try {
 const result = await query<ReviewRow>(
  `SELECT r.id, r.place_id, r.user_id, r.rating, r.title, r.content, r.created_at,
          p.name as place_name, p.slug as place_slug,
          COALESCE(u.full_name, 'Anonim') as user_name
   FROM reviews r
   JOIN places p ON r.place_id = p.id
   LEFT JOIN users u ON r.user_id = u.id
   WHERE r.is_moderated = false
   ORDER BY r.created_at DESC
   LIMIT 100`
 );
 pendingReviews = result.rows;
} catch (e) {
 logger.error('Error loading admin reviews', e instanceof Error ? e : new Error(String(e)));
}

try {
 const r = await query<{ k: string; cnt: number; avg_r: number | null }>(
  `SELECT
     CASE
       WHEN is_moderated = false THEN 'pending'
       WHEN status = 'active' THEN 'approved'
       WHEN status = 'rejected' THEN 'rejected'
       ELSE 'other'
     END as k,
     COUNT(*)::int as cnt,
     AVG(rating)::float as avg_r
   FROM reviews
   GROUP BY k`
 );
 let ratingSum = 0; let ratingCount = 0;
 for (const row of r.rows) {
  if (row.k === 'pending') stats.pending = row.cnt;
  else if (row.k === 'approved') stats.approved = row.cnt;
  else if (row.k === 'rejected') stats.rejected = row.cnt;
  stats.total += row.cnt;
  if (row.avg_r !== null) { ratingSum += row.avg_r * row.cnt; ratingCount += row.cnt; }
 }
 stats.avgRating = ratingCount > 0 ? +(ratingSum / ratingCount).toFixed(2) : 0;
} catch (e) {
 logger.error('admin reviews stats failed', e instanceof Error ? e : new Error(String(e)));
}

function initials(name: string): string {
 return name.split(' ').filter(Boolean).slice(0, 2).map(s => s[0]?.toUpperCase() || '').join('') || '?';
}
---

<AdminLayout
 title="Yorum Moderasyonu"
 subtitle={`${stats.pending} onay bekliyor • ${stats.total.toLocaleString('tr-TR')} toplam`}
 seo={{ title: 'Yorum Moderasyonu - Admin', noIndex: true }}
>
 <div class="rv-page">
  <AdmStatGrid stats={[
   { label: 'Onay Bekleyen', value: stats.pending, icon: 'lucide:clock', color: 'amber' },
   { label: 'Onaylı', value: stats.approved, icon: 'lucide:check-circle', color: 'emerald' },
   { label: 'Reddedilen', value: stats.rejected, icon: 'lucide:x-circle', color: 'rose' },
   { label: 'Ortalama Puan', value: stats.avgRating || '—', icon: 'lucide:star', color: 'amber', detail: `${stats.total} yorum üzerinden` },
  ]} />

  {moderationResult?.data?.success && (
   <div class="rv-toast rv-toast--ok">
    <Icon name="lucide:check-circle" class="w-4 h-4" />
    Yorum moderasyon işlemi tamamlandı.
   </div>
  )}

  {moderationResult?.error && (
   <div class="rv-toast rv-toast--err">
    <Icon name="lucide:alert-circle" class="w-4 h-4" />
    {moderationResult.error.message || 'Yorum moderasyon işlemi tamamlanamadı.'}
   </div>
  )}

  {pendingReviews.length > 0 ? (
   <div class="rv-list">
    {pendingReviews.map((review) => (
     <article class="rv-card">
      <div class="rv-card-head">
       <div class="rv-author">
        <div class="rv-avatar" aria-hidden="true">{initials(review.user_name)}</div>
        <div class="rv-author-info">
         <div class="rv-author-name">{review.user_name}</div>
         <div class="rv-author-meta">
          <a href={`/isletme/${review.place_slug}`} target="_blank" rel="noopener" class="rv-place-link">
           <Icon name="lucide:store" class="w-3 h-3" />
           {review.place_name}
          </a>
          <span class="rv-dot">·</span>
          <span class="rv-time">{new Date(review.created_at).toLocaleDateString('tr-TR', { day: '2-digit', month: 'short', year: 'numeric' })}</span>
         </div>
        </div>
       </div>
       <div class="rv-rating" role="img" aria-label={`${review.rating} / 5 yıldız`}>
        {[1, 2, 3, 4, 5].map(i => (
         <span aria-hidden="true">
          <Icon name="lucide:star" class:list={['rv-star', i <= review.rating && 'rv-star--filled']} />
         </span>
        ))}
       </div>
      </div>

      {review.title && <h4 class="rv-title">{review.title}</h4>}
      {review.content && <p class="rv-content">{review.content}</p>}

      <div class="rv-card-foot">
       <form method="POST" action={actions.moderateReview} class="rv-form">
        <input type="hidden" name="id" value={review.id} />
        <input type="hidden" name="decision" value="reject" />
        <button type="submit" class="rv-btn rv-btn--danger">
         <Icon name="lucide:x" class="w-3.5 h-3.5" /> Reddet
        </button>
       </form>
       <form method="POST" action={actions.moderateReview} class="rv-form">
        <input type="hidden" name="id" value={review.id} />
        <input type="hidden" name="decision" value="approve" />
        <button type="submit" class="rv-btn rv-btn--primary">
         <Icon name="lucide:check" class="w-3.5 h-3.5" /> Onayla
        </button>
       </form>
      </div>
     </article>
    ))}
   </div>
  ) : (
   <AdmEmptyState
    icon="lucide:check-square"
    title="Tüm yorumlar moderate edildi"
    description="Şu anda moderasyon için bekleyen yorum yok. Yeni yorumlar geldiğinde burada listelenecek."
    actionLabel="Tüm Yorumları Gör"
    actionHref="/admin/places"
    size="md"
   />
  )}
 </div>
</AdminLayout>

<style>
 .rv-page { display: flex; flex-direction: column; gap: 1.25rem; }

 .rv-toast {
  display: flex; align-items: center; gap: 0.55rem;
  padding: 0.75rem 1rem;
  border-radius: 10px;
  font-size: 0.88rem; font-weight: 500;
  animation: rvToastIn 0.25s ease-out;
 }
 @keyframes rvToastIn {
  from { opacity: 0; transform: translateY(-4px); }
  to { opacity: 1; transform: translateY(0); }
 }
 .rv-toast--ok { background: rgba(16,185,129,0.08); color: rgb(5,150,105); border: 1px solid rgba(16,185,129,0.18); }
 .rv-toast--err { background: rgba(225,29,72,0.08); color: rgb(190,18,60); border: 1px solid rgba(225,29,72,0.18); }

 .rv-list {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0.85rem;
 }
 @media (min-width: 1024px) {
  .rv-list { grid-template-columns: repeat(2, 1fr); }
 }

 .rv-card {
  background: var(--adm-bg-elev);
  border: 1px solid var(--adm-border);
  border-radius: 12px;
  padding: 1.1rem 1.2rem;
  transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
  display: flex; flex-direction: column; gap: 0.75rem;
 }
 .rv-card:hover {
  border-color: rgba(184,115,51,0.3);
  box-shadow: 0 4px 14px -4px rgba(31,20,16,0.08);
 }

 .rv-card-head {
  display: flex; align-items: flex-start; justify-content: space-between;
  gap: 0.75rem;
 }
 .rv-author { display: flex; gap: 0.7rem; align-items: center; min-width: 0; }
 .rv-avatar {
  width: 38px; height: 38px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--adm-accent), var(--adm-warning));
  color: #fff;
  display: inline-flex; align-items: center; justify-content: center;
  font-weight: 700; font-size: 0.82rem;
  flex-shrink: 0;
 }
 .rv-author-info { min-width: 0; }
 .rv-author-name {
  font-weight: 600;
  color: var(--adm-text);
  font-size: 0.92rem;
  margin-bottom: 0.15rem;
 }
 .rv-author-meta {
  display: flex; flex-wrap: wrap; align-items: center; gap: 0.35rem;
  font-size: 0.76rem;
  color: var(--adm-text-soft);
 }
 .rv-place-link {
  display: inline-flex; align-items: center; gap: 0.25rem;
  color: var(--adm-accent);
  text-decoration: none;
  font-weight: 500;
 }
 .rv-place-link:hover { text-decoration: underline; }
 .rv-dot { color: var(--adm-text-soft); }

 .rv-rating { display: inline-flex; gap: 0.1rem; flex-shrink: 0; }
 .rv-star {
  width: 1rem; height: 1rem;
  color: var(--adm-border-strong);
  fill: transparent;
 }
 .rv-star--filled {
  color: rgb(217,119,6);
  fill: rgb(217,119,6);
 }

 .rv-title {
  font-size: 1rem; font-weight: 600;
  color: var(--adm-text);
  margin: 0;
  line-height: 1.3;
 }
 .rv-content {
  font-size: 0.88rem;
  color: var(--adm-text-muted);
  line-height: 1.55;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
  overflow: hidden;
 }

 .rv-card-foot {
  display: flex; gap: 0.5rem; justify-content: flex-end;
  padding-top: 0.5rem;
  border-top: 1px dashed var(--adm-border);
 }
 .rv-form { display: inline-flex; }
 .rv-btn {
  display: inline-flex; align-items: center; gap: 0.35rem;
  padding: 0.45rem 0.9rem;
  font-size: 0.82rem; font-weight: 600;
  border-radius: 8px;
  border: 1px solid var(--adm-border);
  cursor: pointer;
  background: var(--adm-bg);
  color: var(--adm-text-muted);
  transition: all 0.15s;
 }
 .rv-btn--primary {
  background: linear-gradient(135deg, rgba(16,185,129,1), rgba(5,150,105,1));
  color: #fff;
  border-color: rgba(16,185,129,1);
 }
 .rv-btn--primary:hover { filter: brightness(0.95); transform: translateY(-1px); }
 .rv-btn--danger {
  border-color: rgba(225,29,72,0.3);
  color: rgb(190,18,60);
 }
 .rv-btn--danger:hover { background: rgba(225,29,72,0.08); border-color: rgba(225,29,72,0.5); }
</style>
