---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout
 title="Gelir Yönetimi"
 subtitle="Abonelik geliri, MRR ve kayıp oranı analitikleri"
>
 <div class="sf-container py-8">
 <div class="mb-6">
 <a href="/admin" class="text-sm text-[#7A6B58] hover:text-[#7A6B58]">← Admin Paneli</a>
 </div>

 <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
 <div class="bg-[var(--bg-card)] border border-[rgba(184,115,51,0.14)] rounded-sm p-6">
 <div class="flex items-center justify-between mb-4">
 <h3 class="text-sm font-medium text-[#7A6B58]">Aylık Gelir (MRR)</h3>
 </div>
 <div class="text-3xl font-bold text-[#1F1410]" id="totalMRR">$0.00</div>
 <p class="text-sm text-[#7A6B58] mt-2">Aktif aboneliklerden</p>
 </div>

 <div class="bg-[var(--bg-card)] border border-[rgba(184,115,51,0.14)] rounded-sm p-6">
 <div class="flex items-center justify-between mb-4">
 <h3 class="text-sm font-medium text-[#7A6B58]">Aktif Abonelikler</h3>
 </div>
 <div class="text-3xl font-bold text-[#1F1410]" id="activeSubscriptions">0</div>
 <p class="text-sm text-[#7A6B58] mt-2">Tüm katmanlar</p>
 </div>

 <div class="bg-[var(--bg-card)] border border-[rgba(184,115,51,0.14)] rounded-sm p-6">
 <div class="flex items-center justify-between mb-4">
 <h3 class="text-sm font-medium text-[#7A6B58]">Kayıp Oranı (30g)</h3>
 </div>
 <div class="text-3xl font-bold text-urfa-600" id="churnRate">0%</div>
 <p class="text-sm text-[#7A6B58] mt-2">Kaybedilen abonelikler</p>
 </div>

 <div class="bg-[var(--bg-card)] border border-[rgba(184,115,51,0.14)] rounded-sm p-6">
 <div class="flex items-center justify-between mb-4">
 <h3 class="text-sm font-medium text-[#7A6B58]">Toplam Gelir</h3>
 </div>
 <div class="text-3xl font-bold text-[#1F1410]" id="totalRevenue">$0.00</div>
 <p class="text-sm text-[#7A6B58] mt-2">Tüm zamanlar</p>
 </div>
 </div>

 <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
 {['free', 'premium', 'pro'].map((tier) => (
 <div class="bg-[var(--bg-card)] border border-[rgba(184,115,51,0.14)] rounded-sm p-6">
 <h3 class="text-lg font-semibold text-[#1F1410] mb-4 capitalize">
 {tier === 'free' && 'Ücretsiz'}
 {tier === 'premium' && '⭐ Premium'}
 {tier === 'pro' && 'Pro'}
 </h3>

 {tier === 'free' && (
 <div class="text-sm text-[#7A6B58]">
 <p class="mb-4">Ücretli olmayan hesaplar. Ücretsiz özellikler sunarlar.</p>
 <div class="text-2xl font-bold text-[#1F1410] mb-2">
 <span id="freeTierCount">0</span> kullanıcı
 </div>
 </div>
 )}

 {tier === 'premium' && (
 <div class="text-sm text-[#7A6B58]">
 <p class="mb-4">$2.99/ay fiyatlandırma.</p>
 <div class="mb-4">
 <div class="text-2xl font-bold text-[#1F1410]">
 <span id="premiumTierCount">0</span> aktif abone
 </div>
 <div class="text-lg text-urfa-600 mt-2">
 <span id="premiumTierRevenue">$0.00</span>/ay
 </div>
 </div>
 </div>
 )}

 {tier === 'pro' && (
 <div class="text-sm text-[#7A6B58]">
 <p class="mb-4">$5.99/ay fiyatlandırma.</p>
 <div class="mb-4">
 <div class="text-2xl font-bold text-[#1F1410]">
 <span id="proTierCount">0</span> aktif abone
 </div>
 <div class="text-lg text-urfa-600 mt-2">
 <span id="proTierRevenue">$0.00</span>/ay
 </div>
 </div>
 </div>
 )}
 </div>
 ))}
 </div>

 <div class="bg-[rgba(184,115,51,0.06)] border border-[rgba(184,115,51,0.2)] rounded-sm p-6">
 <h3 class="font-semibold text-[#1F1410] mb-2">Grafik Yükleniyor</h3>
 <p class="text-sm text-[#7A6B58]">
 Günlük gelir grafiği burada gösterilecek (Chart.js ile). Son 30 günün gelir trendini takip et.
 </p>
 </div>
 </div>

 <script>
 async function loadRevenueData() {
 try {
 const response = await fetch('/api/admin/revenue');
 if (!response.ok) throw new Error('Gelir verisi alınamadı.');

 const result = await response.json();
 const { summary, byTier } = result.data;

 document.getElementById('totalMRR')!.textContent = `$${summary.totalMRR.toFixed(2)}`;
 document.getElementById('activeSubscriptions')!.textContent = summary.totalActiveSubscriptions.toString();
 document.getElementById('churnRate')!.textContent = `${summary.churnRatePercent}%`;
 document.getElementById('totalRevenue')!.textContent = `$${summary.totalRevenueAllTime.toFixed(2)}`;

 if (byTier.premium) {
 document.getElementById('premiumTierCount')!.textContent = byTier.premium.count.toString();
 document.getElementById('premiumTierRevenue')!.textContent = `$${byTier.premium.monthlyRevenue.toFixed(2)}`;
 }

 if (byTier.pro) {
 document.getElementById('proTierCount')!.textContent = byTier.pro.count.toString();
 document.getElementById('proTierRevenue')!.textContent = `$${byTier.pro.monthlyRevenue.toFixed(2)}`;
 }
 } catch (error) {
 console.error('Gelir verisi yüklenemedi:', error);
 }
 }

 loadRevenueData();
 setInterval(loadRevenueData, 5 * 60 * 1000);
 </script>
</AdminLayout>
