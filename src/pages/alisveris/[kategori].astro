---
import Layout from '../../layouts/Layout.astro';
import { query } from '../../lib/postgres';
import { getCachedPublicRouteData } from '../../lib/public-route-cache';
import { getPublicAppUrl } from '../../lib/public-app-url';
import { logger } from '../../lib/logging';
const baseUrl = getPublicAppUrl();

const { kategori } = Astro.params;

const categoryMeta: Record<string, { name: string; icon: string }> = {
 'avmler': { name: 'Alışveriş Merkezleri', icon: '🏬' },
 'hediyelik-esya': { name: 'Hediyelik Eşya', icon: '🎁' },
 'yoresel-urunler': { name: 'Yöresel Ürünler', icon: '🫙' },
 'kuyumcular': { name: 'Kuyumcular', icon: '💍' },
 'giyim-magazalari': { name: 'Giyim Mağazaları', icon: '👗' },
};

const meta = categoryMeta[kategori || ''] || { name: kategori || '', icon: '🛍️' };

let places: any[] = [];

try {
 places = await getCachedPublicRouteData(`page:alisveris:${kategori || 'unknown'}`, async () => {
  const result = await query(
   `SELECT p.*, d.name as district_name FROM places p
 LEFT JOIN categories c ON p.category_id = c.id
 LEFT JOIN districts d ON p.district_id = d.id
 WHERE c.slug = $1 AND p.status = 'active'
 ORDER BY p.is_featured DESC, p.rating DESC`,
   [kategori]
  );
  return result.rows;
 });
} catch (e) {
 logger.error('Error loading alisveris kategori:', e instanceof Error ? e : new Error(String(e)));
}

const seo = {
 title: `Şanlıurfa ${meta.name} | Alışveriş Rehberi`,
 description: `Şanlıurfa'da en iyi ${meta.name.toLowerCase()}. Adres, telefon ve konum bilgileri.`,
 keywords: ['şanlıurfa ' + meta.name.toLowerCase(), 'urfa ' + meta.name.toLowerCase(), meta.name + ' şanlıurfa', 'şanlıurfa alışveriş'],
 ogImage: '/images/places/balikligol.jpg',
 canonical: `/alisveris/${kategori}`,
};
const faqItems = [
 { S: `Şanlıurfa'da ${meta.name.toLowerCase()} seçenekleri nelerdir?`, C: `Şanlıurfa'da ${meta.name.toLowerCase()} için güncel liste ve değerlendirmeler rehberimizde yer almaktadır.` },
 { S: `${meta.name} için hangi ilçeler öne çıkıyor?`, C: `Eyyübiye, Haliliye ve Karaköprü ilçeleri hizmet yoğunluğu açısından öne çıkan bölgeler arasındadır.` },
 { S: `${meta.name} bilgilerini nasıl güncelleyebilirim?`, C: `Mekan sayfasına giriş yaparak güncelleme talebinde bulunabilir veya iletişim formu üzerinden bildirimde bulunabilirsiniz.` },
];
---

<Layout seo={seo}>
 <style is:inline>
 .ak-breadcrumb{background:var(--bg);border-bottom:1px solid rgba(184,115,51,.14);padding:.75rem 0}
 .ak-breadcrumb nav{display:flex;align-items:center;gap:.5rem;font-size:.8rem;color:var(--public-muted)}
 .ak-breadcrumb a{color:var(--public-muted);transition:color .15s}.ak-breadcrumb a:hover{color:var(--public-accent)}
 .ak-breadcrumb span:last-child{color:var(--public-accent);font-weight:500}
 .ak-hero{position:relative;overflow:hidden;border-bottom:1px solid rgba(184,115,51,0.12);padding:clamp(3rem,6vw,5rem) 0;background:radial-gradient(circle at 18% 0%,rgba(212,151,24,0.10) 0%,transparent 42%),radial-gradient(circle at 82% 100%,rgba(44,122,82,0.08) 0%,transparent 40%),linear-gradient(180deg,#fbf6ec 0%,#f4ecd8 58%,#fbf6ec 100%)}
 .ak-hero-inner{display:flex;align-items:center;gap:1rem}
 .ak-hero-icon{font-size:3rem;line-height:1}
 .ak-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.6rem,4vw,2.5rem);font-weight:600;color:var(--public-text)}
 .ak-count{font-size:.85rem;color:var(--public-muted);margin-top:.25rem}
 .ak-body{background:var(--bg);padding:2rem 0 4rem}
 .ak-grid{display:grid;gap:1rem;grid-template-columns:repeat(auto-fill,minmax(260px,1fr))}
 .ak-card{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);padding:1.25rem;transition:border-color .15s}
 .ak-card:hover{border-color:var(--public-accent)}
 .ak-card-name{font-size:.92rem;font-weight:700;color:var(--public-text);margin-bottom:.2rem;transition:color .15s}
 .ak-card:hover .ak-card-name{color:var(--public-accent)}
 .ak-district{font-size:.72rem;color:var(--public-accent);font-weight:600;margin-bottom:.3rem}
 .ak-addr{font-size:.75rem;color:var(--public-muted);margin-top:.2rem}
 .ak-phone{font-size:.75rem;color:var(--public-muted)}
 .ak-short{font-size:.75rem;color:var(--public-text-soft);margin-top:.35rem;line-height:1.55;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
 .ak-empty{text-align:center;padding:4rem 1rem;color:var(--public-muted)}
 .ak-empty-icon{font-size:3.5rem;margin-bottom:.75rem}
 .ak-empty-link{display:inline-block;margin-top:.75rem;color:var(--public-accent);font-size:.85rem;transition:color .15s}
 .ak-empty-link:hover{color:var(--public-accent-strong)}
 </style>

 <div class="ak-breadcrumb">
 <div class="sf-container">
 <nav>
 <a href="/">Ana Sayfa</a>
 <span>/</span>
 <a href="/alisveris">Alışveriş</a>
 <span>/</span>
 <span>{meta.name}</span>
 </nav>
 </div>
 </div>

 <div class="ak-hero">
 <div class="sf-container">
 <div class="ak-hero-inner">
 <span class="ak-hero-icon">{meta.icon}</span>
 <div>
 <h1 class="ak-h1">Şanlıurfa {meta.name}</h1>
 <p class="ak-count">{places.length} mekan bulundu</p>
 </div>
 </div>
 </div>
 </div>

 <div class="ak-body">
 <div class="sf-container">
 {places.length > 0 ? (
 <div class="ak-grid">
 {places.map((place) => (
 <a href={`/isletme/${place.slug}`} class="ak-card">
 <p class="ak-card-name">{place.name}</p>
 {place.district_name && <p class="ak-district">{place.district_name}</p>}
 {place.address && <p class="ak-addr">📍 {place.address}</p>}
 {place.phone && <p class="ak-phone">📞 {place.phone}</p>}
 {place.short_description && <p class="ak-short">{place.short_description}</p>}
 </a>
 ))}
 </div>
 ) : (
 <div class="ak-empty">
 <div class="ak-empty-icon">{meta.icon}</div>
 <p>Bu kategoride henüz kayıt bulunmuyor.</p>
 <a href="/alisveris" class="ak-empty-link">Alışveriş Rehberine Dön →</a>
 </div>
 )}
 </div>
 </div>

 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'CollectionPage',
 name: `Şanlıurfa ${meta.name}`,
 description: `Şanlıurfa'da en iyi ${meta.name.toLowerCase()}. Adres, telefon ve konum bilgileri.`,
 url: `${baseUrl}/alisveris/${kategori}`,
 about: { '@type': 'City', name: 'Şanlıurfa' },
 itemListElement: places.slice(0, 10).map((p: any, i: number) => ({
 '@type': 'ListItem',
 position: i + 1,
 item: {
 '@type': 'Store',
 name: p.name,
 url: `${baseUrl}/isletme/${p.slug}`,
 ...(p.address ? { address: p.address } : {}),
 ...(p.phone ? { telephone: p.phone } : {}),
 },
 })),
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'Alışveriş', item: `${baseUrl}/alisveris` },
 { '@type': 'ListItem', position: 3, name: meta.name, item: `${baseUrl}/alisveris/${kategori}` },
 ],
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqItems.map((item) => ({
 '@type': 'Question',
 name: item.S,
 acceptedAnswer: { '@type': 'Answer', text: item.C },
 })),
 })} is:inline />
</Layout>
