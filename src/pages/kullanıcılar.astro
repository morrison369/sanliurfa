---
/**
 * User Discovery & Search Page
 * Browse and search for users
 */

import Layout from '../layouts/Layout.astro';
import UserSearchResults from '../components/UserSearchResults.astro';
---

<Layout title="Kullanıcıları keşfet - Şanlıurfa.com">
  <div class="container-custom py-8">
    <div className="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Kullanıcıları keşfet</h1>
      <p class="text-gray-600 dark:text-gray-400 mt-2">Topluluğumuzu keşfedin ve diğer kullanıcılarla bağlantı kurmaya başlayın.</p>
    </div>

    <UserSearchResults currentUserId={Astro.locals.user?.id} />
  </div>
</Layout>
