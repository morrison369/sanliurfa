---
// Search Results Page
import Layout from '../layouts/Layout.astro';
import { searchPlaces } from '../lib/places/db';
import { searchPosts } from '../lib/blog';

const url = new URL(Astro.request.url);
const query = url.searchParams.get('q') || '';

let places = [];
let posts = [];
let historicalSites = [];
let districts = [];

import { query as dbQuery } from '../lib/postgres';

if (query.length >= 2) {
  const [placesResult, postsResult, sitesResult, distResult] = await Promise.all([
    searchPlaces(query),
    searchPosts(query),
    dbQuery(
      `SELECT id, name, slug, short_description, 'historical_site' as type
       FROM historical_sites
       WHERE status = 'active' AND (name ILIKE $1 OR short_description ILIKE $1 OR description ILIKE $1)
       LIMIT 6`,
      [`%${query}%`]
    ).catch(() => ({ rows: [] })),
    dbQuery(
      `SELECT id, name, slug, description, 'district' as type
       FROM districts
       WHERE name ILIKE $1 OR description ILIKE $1
       LIMIT 6`,
      [`%${query}%`]
    ).catch(() => ({ rows: [] })),
  ]);
  places = placesResult.places;
  posts = postsResult;
  historicalSites = sitesResult.rows;
  districts = distResult.rows;
}

const totalResults = places.length + posts.length + historicalSites.length + districts.length;

const seo = {
  title: query ? `"${query}" Arama Sonuçları - Şanlıurfa Rehberi` : 'Ara - Şanlıurfa Rehberi',
  description: query ? `"${query}" için ${totalResults} sonuç bulundu.` : 'Şanlıurfa mekanları ve blog yazılarında arayın.',
};
---

<Layout seo={seo}>
  <!-- Search Header -->
  <section class="bg-gray-50 py-12 border-b">
    <div class="container-custom">
      <h1 class="text-3xl font-bold mb-6">Ara</h1>
      
      <form action="/ara" method="get" class="max-w-2xl">
        <div class="relative">
          <input
            type="text"
            name="q"
            value={query}
            placeholder="Mekan, kategori veya blog yazısı ara..."
            class="w-full px-6 py-4 pr-32 text-lg border border-gray-300 rounded-xl focus:ring-2 focus:ring-amber-500 focus:border-transparent"
            autofocus
          />
          <button
            type="submit"
            class="absolute right-2 top-2 bottom-2 px-6 bg-amber-600 text-white font-medium rounded-lg hover:bg-amber-700 transition-colors"
          >
            Ara
          </button>
        </div>
      </form>
      
      {query && (
        <p class="text-gray-600 mt-4">
          <strong>"{query}"</strong> için <strong>{totalResults}</strong> sonuç bulundu
        </p>
      )}
    </div>
  </section>

  <!-- Results -->
  <section class="py-12">
    <div class="container-custom">
      {query.length < 2 ? (
        <div class="text-center py-16">
          <div class="text-6xl mb-4">🔍</div>
          <p class="text-gray-600">Arama yapmak için en az 2 karakter girin</p>
        </div>
      ) : totalResults === 0 ? (
        <div class="text-center py-16">
          <div class="text-6xl mb-4">😕</div>
          <h2 class="text-xl font-bold mb-2">Sonuç Bulunamadı</h2>
          <p class="text-gray-600">"{query}" için herhangi bir sonuç bulunamadı.</p>
          <div class="mt-6">
            <p class="text-gray-500 mb-4">Şunları deneyebilirsiniz:</p>
            <div class="flex flex-wrap gap-2 justify-center">
              {['Göbeklitepe', 'Balıklıgöl', 'Kebapçı', 'Ciğerci', 'Harran', 'Otel', 'Eczane', 'Kahvaltı'].map(suggestion => (
                <a
                  href={`/ara?q=${encodeURIComponent(suggestion)}`}
                  class="px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors"
                >
                  {suggestion}
                </a>
              ))}
            </div>
          </div>
        </div>
      ) : (
        <div class="space-y-12">
          {/* Places Results */}
          {places.length > 0 && (
            <div>
              <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
                <span>📍</span> Mekanlar ({places.length})
              </h2>
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {places.map(place => (
                  <a href={`/places/${place.slug}`} class="group">
                    <article class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow">
                      <div class="h-48 bg-gray-200">
                        {place.thumbnail ? (
                          <img src={place.thumbnail} alt={place.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform" />
                        ) : (
                          <div class="w-full h-full flex items-center justify-center text-gray-300 text-4xl">📍</div>
                        )}
                      </div>
                      <div class="p-5">
                        <span class="text-xs text-gray-500 uppercase">{place.category_name}</span>
                        <h3 class="font-bold text-lg mt-1 group-hover:text-amber-600 transition-colors">{place.name}</h3>
                        <div class="flex items-center gap-2 mt-2">
                          <div class="flex text-yellow-400 text-sm">
                            {'★'.repeat(Math.floor(place.rating || 0))}
                            <span class="text-gray-300">{'★'.repeat(5 - Math.floor(place.rating || 0))}</span>
                          </div>
                          <span class="text-sm text-gray-500">({place.review_count})</span>
                        </div>
                        <p class="text-gray-600 text-sm mt-2 line-clamp-2">{place.short_description}</p>
                      </div>
                    </article>
                  </a>
                ))}
              </div>
            </div>
          )}
          
          {/* Historical Sites */}
          {historicalSites.length > 0 && (
            <div>
              <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
                <span>🏛️</span> Gezilecek Yerler ({historicalSites.length})
              </h2>
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {historicalSites.map((site: any) => (
                  <a href={`/gezilecek-yerler/${site.slug}`} class="group">
                    <article class="bg-white rounded-xl p-5 shadow-sm hover:shadow-lg transition-shadow">
                      <div class="flex items-start gap-3">
                        <span class="text-3xl">🏛️</span>
                        <div>
                          <h3 class="font-bold text-lg group-hover:text-amber-600 transition-colors">{site.name}</h3>
                          <p class="text-gray-600 text-sm mt-1 line-clamp-2">{site.short_description}</p>
                        </div>
                      </div>
                    </article>
                  </a>
                ))}
              </div>
            </div>
          )}

          {/* Districts */}
          {districts.length > 0 && (
            <div>
              <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
                <span>🏙️</span> İlçeler ({districts.length})
              </h2>
              <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                {districts.map((d: any) => (
                  <a href={`/ilceler/${d.slug}`} class="bg-white rounded-xl p-4 shadow-sm hover:shadow-lg transition-all group flex items-center gap-3">
                    <span class="text-2xl">🏙️</span>
                    <div>
                      <h3 class="font-bold text-gray-900 group-hover:text-amber-600">{d.name}</h3>
                      {d.description && <p class="text-xs text-gray-500 line-clamp-1">{d.description}</p>}
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}

          {/* Blog Results */}
          {posts.length > 0 && (
            <div>
              <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
                <span>📝</span> Blog Yazıları ({posts.length})
              </h2>
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {posts.map(post => (
                  <a href={`/blog/${post.slug}`} class="group">
                    <article class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow">
                      <div class="h-48 bg-gradient-to-br from-gray-100 to-gray-200">
                        {post.featured_image ? (
                          <img src={post.featured_image} alt={post.title} class="w-full h-full object-cover" />
                        ) : (
                          <div class="w-full h-full flex items-center justify-center text-gray-300 text-4xl">📝</div>
                        )}
                      </div>
                      <div class="p-5">
                        <span class="text-xs text-amber-600 font-medium uppercase">{post.category_name}</span>
                        <h3 class="font-bold text-lg mt-1 group-hover:text-amber-600 transition-colors line-clamp-2">{post.title}</h3>
                        <p class="text-gray-600 text-sm mt-2 line-clamp-2">{post.excerpt}</p>
                        <div class="flex items-center gap-4 mt-4 text-sm text-gray-500">
                          <span>{post.reading_time} dk okuma</span>
                        </div>
                      </div>
                    </article>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      )}
    </div>
  </section>
</Layout>
