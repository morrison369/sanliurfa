---

import Layout from '../layouts/Layout.astro';
import { query } from '../lib/postgres';
import { getSiteBranding } from '../lib/site-branding';
const { baseUrl } = await getSiteBranding();

let kebapcilar: any[] = [];
try {
  const result = await query(`
    SELECT p.id, p.slug, p.name, p.address, p.rating, p.review_count, p.images,
           c.name AS category_name
    FROM places p
    LEFT JOIN categories c ON p.category_id = c.id
    WHERE p.status = 'active'
      AND (
        c.slug ILIKE '%kebap%'
        OR p.name ILIKE '%kebap%'
        OR p.name ILIKE '%ocakbaş%'
        OR c.slug = 'restoran'
      )
    ORDER BY p.rating DESC NULLS LAST, p.review_count DESC NULLS LAST
    LIMIT 20
  `);
  kebapcilar = result.rows;
} catch (e) {
  console.error('Kebapçılar yüklenemedi:', e);
}

const seo = {
  title: 'Şanlıurfa En İyi Kebapçılar | Urfa Kebabı Nerede Yenir?',
  description: 'Şanlıurfa\'nın en iyi kebapçıları. Urfa kebabı, patlıcan kebabı ve kaburga kebabı için en çok tercih edilen mekanlar.',
  keywords: ['şanlıurfa kebapçılar', 'urfa kebabı nerede yenir', 'en iyi urfa kebap', 'şanlıurfa ocakbaşı', 'urfa kaburga kebabı', 'şanlıurfa patlıcan kebabı'],
  ogImage: '/images/hero/hero-food.webp',
  canonical: '/en-iyi-kebapcilar',
};

const faqItems = [
  {
    S: 'Şanlıurfa\'da en iyi kebap nerede yenir?',
    C: 'Şanlıurfa\'nın tarihi çarşı çevresi ve şehir merkezindeki köklü restoranlar Urfa kebabı için en çok tercih edilen adreslerdir.',
  },
  {
    S: 'Urfa kebabı ile Adana kebabı arasındaki fark nedir?',
    C: 'Urfa kebabı daha az baharatlı ve tombul hazırlanır. Adana kebabı acı biber ile yapılırken Urfa kebabı genellikle sade veya hafif baharatlıdır.',
  },
  {
    S: 'Şanlıurfa\'da kaburga ve patlıcan kebabı bulunur mu?',
    C: 'Evet. Şanlıurfa\'nın önde gelen kebapçılarında kaburga kebabı, patlıcan kebabı ve et döner gibi çeşitli et yemekleri menüde yer almaktadır.',
  },
];
---


<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50">
    <div class="bg-gradient-to-br from-red-700 to-orange-800 text-white py-16">
      <div class="container mx-auto px-4 max-w-5xl">
        <p class="text-red-200 font-medium mb-2">Şanlıurfa Gastronomi Rehberi</p>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Şanlıurfa’nın En İyi Kebapçıları</h1>
        <p class="text-red-100 text-lg max-w-2xl">
          Urfa kebabı, patlıcan kebabı ve kaburga kebabının ustası mekanlar. Şanlıurfa’da kebap yemek isteyenler için en güncel rehber.
        </p>
      </div>
    </div>

    <div class="container mx-auto px-4 max-w-5xl py-12">
      <div class="mb-8 bg-white rounded-xl p-5 shadow-sm border-l-4 border-red-600">
        <h2 class="font-bold text-gray-900 text-lg mb-1">Urfa Kebabı Hakkında</h2>
        <p class="text-gray-600 text-sm leading-relaxed">
          Urfa kebabı, yağlı kuzu kıyması ile isot biberin mükemmel birleşimidir. Geleneksel olarak mangal ateşinde pişirilir ve közlenmiş domates, biber ile servis edilir. Acısız versiyonu Urfa Kebabı, acılı versiyonu ise Adana Kebabı olarak bilinir.
        </p>
      </div>

      {kebapcilar.length > 0 ? (
        <div class="grid md:grid-cols-2 gap-5">
          {kebapcilar.map((place, i) => (
            <a href={`/isletme/${place.slug}`} class="bg-white rounded-xl overflow-hidden shadow-sm border hover:shadow-lg transition-all group flex">
              <div class="w-24 h-24 bg-red-100 shrink-0 flex items-center justify-center text-3xl font-bold text-red-600">
                {i < 3 ? ['🥇','🥈','🥉'][i] : `${i+1}`}
              </div>
              <div class="p-4 flex-1">
                <h3 class="font-bold text-gray-900 group-hover:text-red-600 transition-colors">{place.name}</h3>
                <p class="text-xs text-gray-500 mt-0.5">{place.category_name || 'Kebapçı'}</p>
                {place.address && <p class="text-sm text-gray-600 mt-1 line-clamp-1">{place.address}</p>}
                <div class="flex items-center gap-3 mt-2 text-sm">
                  {place.rating && <span class="text-yellow-600 font-semibold">★ {place.rating}</span>}
                  {place.review_count > 0 && <span class="text-gray-400">{place.review_count} yorum</span>}
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-16 text-gray-400">
          <p class="text-4xl mb-4">🍖</p>
          <p>Mekan bilgileri yakında eklenecek.</p>
        </div>
      )}

      <div class="mt-10 flex flex-wrap gap-3">
        <a href="/gastronomi" class="px-5 py-2.5 rounded-full bg-red-600 text-white hover:bg-red-700 transition-colors font-medium">Gastronomi Rehberi</a>
        <a href="/yemek-tarifleri/urfa-kebabi" class="px-5 py-2.5 rounded-full border border-red-200 text-red-700 hover:bg-red-50 transition-colors">Urfa Kebabı Tarifi</a>
        <a href="/en-iyi-cigerciler" class="px-5 py-2.5 rounded-full border border-gray-200 text-gray-700 hover:bg-gray-50 transition-colors">En İyi Cigerciler →</a>
      </div>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Şanlıurfa En İyi Kebapçılar',
    description: 'Şanlıurfa\'nın en iyi kebap restoranları listesi',
    url: `${baseUrl}/en-iyi-kebapcilar`,
    itemListElement: kebapcilar.slice(0, 10).map((p: any, i: number) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Restaurant',
        name: p.name,
        url: `${baseUrl}/isletme/${p.slug}`,
        address: { '@type': 'PostalAddress', addressLocality: 'Şanlıurfa', addressCountry: 'TR' },
        ...(p.rating && { aggregateRating: { '@type': 'AggregateRating', ratingValue: p.rating, reviewCount: p.review_count || 1 } }),
      },
    })),
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Yeme İçme', item: `${baseUrl}/yeme-icme` },
      { '@type': 'ListItem', position: 3, name: 'En İyi Kebapçılar', item: `${baseUrl}/en-iyi-kebapcilar` },
    ],
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: { '@type': 'Answer', text: item.C },
    })),
  })} is:inline />
</Layout>
