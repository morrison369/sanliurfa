---
import Layout from "../../layouts/Layout.astro";
import TrendingPlaces from "../../components/TrendingPlaces";
import { getSiteBranding } from "../../lib/site-branding";
const { baseUrl } = await getSiteBranding();

const seo = {
  title: 'Trend Mekanlar - Şanlıurfa',
  description: "Şanlıurfa'da bu hafta en çok ziyaret edilen ve beğenilen trend mekanları keşfedin.",
  keywords: ['trend mekanlar', 'şanlıurfa popüler yerler', 'bu hafta popüler', 'şanlıurfa gidilecek yerler'],
  ogImage: '/images/hero/hero-home.webp',
  canonical: '/trend',
};

const faqItems = [
  { S: "Trend mekanlar nasıl belirleniyor?", C: "Trend mekanlar son 7 günde en çok ziyaret edilen, yorum alan ve beğenilen mekanlar baz alınarak belirlenir." },
  { S: "Trend listesi ne sıklıkla güncelleniyor?", C: "Trend listesi her gün otomatik olarak güncellenir." },
  { S: "Mekanım trend listesine nasıl girebilir?", C: "Müşterilerinizi yorum yazmaya teşvik edin ve işletme sayfanızın güncel tutulmasını sağlayın." },
];
---

<Layout seo={seo}>
  <div class="min-h-screen bg-[#FDFAF3]">
    <div class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)] text-white py-12">
      <div class="max-w-6xl mx-auto px-4">
        <p class="text-sm font-semibold uppercase tracking-widest text-[#9A8470] mb-2">Şanlıurfa Mekan Rehberi</p>
        <h1 class="text-4xl font-bold text-[#F5EDD6] mb-2">Trend Mekanlar</h1>
        <p class="text-[#C4B49A]">Bu hafta en çok ziyaret edilen ve beğenilen mekanlar</p>
      </div>
    </div>

    <div class="max-w-6xl mx-auto px-4 py-8">
      <TrendingPlaces client:visible={{ rootMargin: '180px' }} />
    </div>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: { '@type': 'Answer', text: item.C },
    })),
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Trend Mekanlar', item: `${baseUrl}/trend` },
    ],
  })} is:inline />
</Layout>
