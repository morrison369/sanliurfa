---
import Layout from "../../layouts/Layout.astro";
import TrendingPlaces from "../../components/TrendingPlaces";
import PublicPageIntro from "../../components/public/PublicPageIntro.astro";
import { getPublicAppUrl } from '../../lib/public-app-url';
const baseUrl = getPublicAppUrl();

const seo = {
 title: 'Trend Mekanlar - Şanlıurfa',
 description: "Şanlıurfa'da bu hafta en çok ziyaret edilen ve beğenilen trend mekanları keşfedin.",
 keywords: ['trend mekanlar', 'şanlıurfa popüler yerler', 'bu hafta popüler', 'şanlıurfa gidilecek yerler'],
 ogImage: '/images/places/balikligol.jpg',
 canonical: '/trend',
};

const faqItems = [
 { S: "Trend mekanlar nasıl belirleniyor?", C: "Trend mekanlar son 7 günde en çok ziyaret edilen, yorum alan ve beğenilen mekanlar baz alınarak belirlenir." },
 { S: "Trend listesi ne sıklıkla güncelleniyor?", C: "Trend listesi her gün otomatik olarak güncellenir." },
 { S: "Mekanım trend listesine nasıl girebilir?", C: "Müşterilerinizi yorum yazmaya teşvik edin ve işletme sayfanızın güncel tutulmasını sağlayın." },
];
---

<Layout seo={seo}>
 <PublicPageIntro
 eyebrow="Şanlıurfa Mekan Rehberi"
 title="Trend Mekanlar"
 description="Bu hafta en çok ziyaret edilen, yorumlanan ve kaydedilen Şanlıurfa mekanlarını tek listede keşfet."
 quickAnswerTitle="Hızlı cevap"
 quickAnswerText="Trend listesi son ziyaret, yorum ve beğeni sinyallerine göre güncel tutulur."
 actions={[
 { href: '/mekanlar', label: 'Tüm Mekanlar' },
 { href: '/gezilecek-yerler', label: 'Gezilecek Yerler' },
 { href: '/oneriler', label: 'Öneriler' },
 ]}
 />

 <div class="tr-body">
 <div class="sf-container">
 <TrendingPlaces client:visible={{ rootMargin: '180px' }} />
 </div>
 </div>

 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqItems.map((item) => ({
 '@type': 'Question',
 name: item.S,
 acceptedAnswer: { '@type': 'Answer', text: item.C },
 })),
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'Trend Mekanlar', item: `${baseUrl}/trend` },
 ],
 })} is:inline />
</Layout>

<style>
 .tr-body {
 background: var(--public-bg);
 padding: 2rem 0 4rem;
 }
</style>
