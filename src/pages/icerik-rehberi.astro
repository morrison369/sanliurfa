---
import { Icon } from 'astro-icon/components';
import Layout from '../layouts/Layout.astro';
import { getPublicAppUrl } from '../lib/public-app-url';
const baseUrl = getPublicAppUrl();

const seo = {
 title: 'İçerik Rehberi - Sanliurfa.com',
 description: 'Şanlıurfa gezi rehberi için içerik ve resim ekleme rehberi',
 keywords: ['şanlıurfa içerik rehberi', 'sanliurfa.com rehber', 'urfa içerik'],
 ogImage: '/images/places/balikligol.jpg',
 canonical: '/icerik-rehberi',
};

const steps = [
 {
 title: "1. Wikipedia'dan İçerik Çekme",
 description: 'Hazır script ile otomatik içerik çekme',
 code: 'npx tsx scripts/content-scraper/wikipedia-scraper.ts',
 note: 'Balıklıgöl, Göbeklitepe, Harran gibi yerlerin içeriği otomatik çekilir'
 },
 {
 title: '2. Slug Kuralıyla Resim İndirme',
 description: 'Unsplash + Pexels kaynaklarından otomatik indir ve içeriklere eşleştir',
 code: `# .env içine anahtarları ekle
UNSPLASH_ACCESS_KEY=xxx
PEXELS_API_KEY=xxx

# Tüm içerik kategorileri için:
# - indir
# - slug'a göre map et
# - external URL kontrolü
# - doğrula
npm run images:pipeline`,
 note: 'Resimler /images/{kategori}/{slug}.jpg formatında üretilir'
 },
 {
 title: '3. Manuel İçerik Ekleme',
 description: 'src/content/places/ klasörüne .md dosyası oluştur',
 code: `---
title: "Mekan Adı"
description: "Kısa açıklama"
slug: "mekan-adi"
lat: 37.1591
lon: 38.7969
category: "tarihi"
image: "/images/places/mekan-adi.jpg"
thumb: "/images/places/mekan-adi-thumb.jpg"
---

# Başlık

İçerik buraya...`,
 note: 'Frontmatter (--- arası) zorunlu alanları içermeli'
 },
 {
 title: '4. Ücretsiz Resim Kaynakları',
 description: 'API kullanmadan manuel indirme',
 links: [
 { name: 'Unsplash', url: 'https://unsplash.com/s/photos/sanliurfa' },
 { name: 'Pexels', url: 'https://pexels.com/search/sanliurfa' },
 { name: 'Pixabay', url: 'https://pixabay.com/images/search/urfa' },
 { name: 'Wikimedia Commons', url: 'https://commons.wikimedia.org/wiki/Sanliurfa' }
 ]
 }
];

const imageKeywords = [
 'Sanliurfa cityscape', 'Balikligol Urfa', 'Gobekli Tepe', 'Harran houses',
 'Southeast Turkey landscape', 'Mesopotamia', 'Anatolian history', 'Turkish cuisine',
 'Historical mosque', 'Ancient ruins'
];

const faqItems = [
 { S: 'Sanliurfa.com için nasıl içerik ekleyebilirim?', C: 'Admin panelinden blog yazısı, mekan veya etkinlik ekleyebilirsiniz. Dış kaynak içerikleri için scraper scriptleri mevcuttur.' },
 { S: 'Resimler hangi formatta ve boyutta olmalı?', C: 'WebP formatı tercih edilir; en az 1200×630 piksel boyut SEO ve sosyal medya paylaşımı için önerilir.' },
 { S: 'İçerik ekleme sürecinde takıldım, destek alabilirim?', C: 'İletişim sayfası üzerinden teknik destek talebinde bulunabilirsiniz.' },
];
---

<Layout seo={seo}>
 <style is:inline>
 .ir-hero{position:relative;overflow:hidden;border-bottom:1px solid rgba(184,115,51,0.12);padding:clamp(3rem,6vw,5rem) 0;background:radial-gradient(circle at 18% 0%,rgba(212,151,24,0.10) 0%,transparent 42%),radial-gradient(circle at 82% 100%,rgba(44,122,82,0.08) 0%,transparent 40%),linear-gradient(180deg,#fbf6ec 0%,#f4ecd8 58%,#fbf6ec 100%)}
 .ir-hero-label{font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:var(--public-text-soft)}
 .ir-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.5rem,3.5vw,2.2rem);font-weight:700;color:var(--public-text);margin:.75rem 0 .25rem}
 .ir-hero-desc{color:var(--public-muted);font-size:.9rem}
 .ir-body{background:var(--bg);padding:2rem 0 4rem}
 .ir-inner{max-width:56rem;margin:0 auto}
 .ir-steps{display:flex;flex-direction:column;gap:1.25rem}
 .ir-step{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);padding:1.5rem}
 .ir-step-title{font-family:'Cormorant Garamond',serif;font-size:1.15rem;font-weight:700;color:var(--public-text);margin-bottom:.5rem}
 .ir-step-desc{font-size:.85rem;color:var(--public-muted);margin-bottom:1rem}
 .ir-code{background:#0a0a0a;border:1px solid rgba(0,255,0,.12);color:#4ade80;padding:1rem;font-size:.78rem;font-family:monospace;line-height:1.65;overflow-x:auto;margin-bottom:1rem}
 .ir-links{margin-bottom:1rem}
 .ir-link{display:flex;align-items:center;gap:.5rem;font-size:.85rem;color:var(--public-accent);padding:.25rem 0;transition:color .15s}
 .ir-link:hover{color:var(--public-accent-strong)}
 .ir-note{font-size:.8rem;color:var(--public-accent);background:rgba(184,115,51,.07);border-left:2px solid var(--public-accent);padding:.65rem .85rem}
 .ir-keywords{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);padding:1.5rem;margin-top:1.25rem}
 .ir-keywords-title{font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-weight:700;color:var(--public-text);margin-bottom:.5rem}
 .ir-keywords-desc{font-size:.82rem;color:var(--public-muted);margin-bottom:.85rem}
 .ir-keyword-chips{display:flex;flex-wrap:wrap;gap:.5rem}
 .ir-chip{display:inline-block;padding:.3rem .75rem;background:rgba(184,115,51,.08);border:1px solid rgba(184,115,51,.18);font-size:.78rem;color:var(--public-accent);transition:background .15s,color .15s}
 .ir-chip:hover{background:rgba(184,115,51,.15);color:var(--public-text)}
 .ir-cta{text-align:center;margin-top:2rem}
 .ir-btn{display:inline-flex;align-items:center;gap:.5rem;background:var(--public-accent);color:var(--public-text);font-size:.85rem;font-weight:600;padding:.65rem 1.5rem;transition:background .15s}
 .ir-btn:hover{background:var(--public-accent-strong)}
 </style>

 <div class="ir-hero">
 <div class="sf-container">
 <p class="ir-hero-label">Geliştirici Rehberi</p>
 <h1 class="ir-h1">İçerik ve Resim Ekleme Rehberi</h1>
 <p class="ir-hero-desc">Şanlıurfa gezi rehberi için içerik ve resim bulma kaynakları.</p>
 </div>
 </div>

 <div class="ir-body">
 <div class="sf-container">
 <div class="ir-inner">
 <div class="ir-steps">
 {steps.map((step) => (
 <div class="ir-step">
 <h2 class="ir-step-title">{step.title}</h2>
 <p class="ir-step-desc">{step.description}</p>
 {step.code && <pre class="ir-code"><code>{step.code}</code></pre>}
 {step.links && (
 <div class="ir-links">
 {step.links.map((link) => (
 <a href={link.url} target="_blank" rel="noopener" class="ir-link">
 <span>{link.name}</span>
 <Icon name="lucide:external-link" class="w-4 h-4" />
 </a>
 ))}
 </div>
 )}
 {step.note && <p class="ir-note">💡 {step.note}</p>}
 </div>
 ))}
 </div>

 <div class="ir-keywords">
 <h2 class="ir-keywords-title">Arama Anahtar Kelimeleri</h2>
 <p class="ir-keywords-desc">Ücretsiz resim sitelerinde kullanabileceğiniz İngilizce anahtar kelimeler:</p>
 <div class="ir-keyword-chips">
 {imageKeywords.map((kw) => (
 <a href={`https://unsplash.com/s/photos/${encodeURIComponent(kw)}`} target="_blank" rel="noopener" class="ir-chip">{kw}</a>
 ))}
 </div>
 </div>

 <div class="ir-cta">
 <a href="/mekanlar" class="ir-btn">
 <span>Mekanları Görüntüle</span>
 <Icon name="lucide:arrow-right" class="w-4 h-4" />
 </a>
 </div>
 </div>
 </div>
 </div>

 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'İçerik Rehberi', item: `${baseUrl}/icerik-rehberi` },
 ],
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqItems.map((item) => ({
 '@type': 'Question',
 name: item.S,
 acceptedAnswer: { '@type': 'Answer', text: item.C },
 })),
 })} is:inline />
</Layout>
