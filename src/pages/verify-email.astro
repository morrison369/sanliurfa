---
/**
 * Email verification page
 * URL: /verify-email?token=xxx
 * Shows status of email verification
 */

import Layout from '../layouts/Layout.astro';

const token = Astro.url.searchParams.get('token');
---

<Layout seo={{ title: 'E-posta Doğrulama - Sanliurfa.com', description: 'Sanliurfa.com e-posta adresinizi doğrulayın.', noIndex: true }}>
 <style is:inline>
 .ve-page{background:var(--bg);min-height:100vh;display:flex;align-items:center;justify-content:center;padding:1rem}
 .ve-card{background:var(--bg-card);border:1px solid rgba(184,115,51,.18);padding:2rem;max-width:28rem;width:100%;text-align:center}
 .ve-spinner{width:3rem;height:3rem;border:3px solid rgba(184,115,51,.2);border-top-color:#B87333;border-radius:50%;animation:ve-spin .8s linear infinite;margin:0 auto}
 @keyframes ve-spin{to{transform:rotate(360deg)}}
 .ve-spin-text{margin-top:1rem;font-size:.88rem;color:#7A6B58}
 .ve-icon{font-size:3.5rem;margin-bottom:1rem}
 .ve-title{font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:700;color:#1F1410;margin-bottom:.75rem}
 .ve-desc{font-size:.88rem;color:#7A6B58;margin-bottom:1.5rem;line-height:1.65}
 .ve-btn{display:inline-block;background:#B87333;color:#EDE0C6;padding:.6rem 1.5rem;font-size:.85rem;font-weight:600;transition:background .15s}
 .ve-btn:hover{background:#9D5F1A}
 .ve-btn-success{background:#B87333}
 .ve-btn-error{background:#B87333}
 </style>

 <div class="ve-page">
 <div class="ve-card">
 {token ? (
 <>
 <div id="verification-status">
 <div class="ve-spinner"></div>
 <p class="ve-spin-text">E-posta doğrulanıyor...</p>
 </div>
 <div id="verification-result" class="hidden"></div>
 </>
 ) : (
 <div>
 <div class="ve-icon">!</div>
 <h1 class="ve-title">Geçersiz Bağlantı</h1>
 <p class="ve-desc">Doğrulama bağlantısı bulunamadı. Lütfen e-postanızdaki bağlantıyı kontrol edin.</p>
 <a href="/" class="ve-btn">Ana Sayfaya Dön</a>
 </div>
 )}
 </div>
 </div>

 <script define:vars={{ token }} is:inline>
 function buildSuccessResult(resultEl) {
 resultEl.replaceChildren();

 const emoji = document.createElement('div');
 emoji.className = 've-icon';
 emoji.textContent = '✓';
 resultEl.appendChild(emoji);

 const title = document.createElement('h1');
 title.className = 've-title';
 title.style.color = '#B87333';
 title.textContent = 'Doğrulama Başarılı!';
 resultEl.appendChild(title);

 const desc = document.createElement('p');
 desc.className = 've-desc';
 desc.textContent = 'E-posta adresiniz başarıyla doğrulanmıştır.';
 resultEl.appendChild(desc);

 const link = document.createElement('a');
 link.href = '/ayarlar';
 link.className = 've-btn ve-btn-success';
 link.textContent = 'Ayarlarına Git';
 resultEl.appendChild(link);
 }

 function buildErrorResult(resultEl, heading, message) {
 resultEl.replaceChildren();

 const emoji = document.createElement('div');
 emoji.className = 've-icon';
 emoji.textContent = '!';
 resultEl.appendChild(emoji);

 const title = document.createElement('h1');
 title.className = 've-title';
 title.style.color = '#1F1410';
 title.textContent = heading;
 resultEl.appendChild(title);

 const desc = document.createElement('p');
 desc.className = 've-desc';
 desc.textContent = message;
 resultEl.appendChild(desc);

 const link = document.createElement('a');
 link.href = '/';
 link.className = 've-btn ve-btn-error';
 link.textContent = 'Ana Sayfaya Dön';
 resultEl.appendChild(link);
 }

 if (token) {
 fetch('/api/users/verify-email?token=' + encodeURIComponent(token))
 .then(function(res) { return res.json(); })
 .then(function(data) {
 var statusEl = document.getElementById('verification-status');
 var resultEl = document.getElementById('verification-result');

 if (statusEl && resultEl) {
 statusEl.remove();
 if (data.success) {
 buildSuccessResult(resultEl);
 } else {
 buildErrorResult(
 resultEl,
 'Doğrulama Başarısız',
 data.error || 'E-posta doğrulanamadı. Bağlantı geçerli değil veya süresi dolmuş olabilir.'
 );
 }
 resultEl.classList.remove('hidden');
 }
 })
 .catch(function() {
 var statusEl = document.getElementById('verification-status');
 var resultEl = document.getElementById('verification-result');

 if (statusEl && resultEl) {
 statusEl.remove();
 buildErrorResult(resultEl, 'Bir Hata Oluştu', 'Lütfen daha sonra tekrar deneyin.');
 resultEl.classList.remove('hidden');
 }
 });
 }
 </script>
</Layout>
