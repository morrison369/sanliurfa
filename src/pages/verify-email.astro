---
/**
 * Email verification page
 * URL: /verify-email?token=xxx
 * Shows status of email verification
 */

import Layout from '../layouts/Layout.astro';

// Get token from URL
const token = Astro.url.searchParams.get('token');

// Verification status will be handled by client-side component
---

<Layout seo={{ title: 'E-posta Doğrulama - Sanliurfa.com', description: 'Sanliurfa.com e-posta adresinizi doğrulayın.', noIndex: true }}>
  <div class="min-h-screen bg-[#FDFAF3] flex items-center justify-center p-4">
    <div class="bg-white rounded-sm shadow-sm border border-[rgba(200,160,100,0.18)] p-8 max-w-md w-full">
      {token ? (
        <>
          <div class="text-center">
            <div id="verification-status" class="mb-6">
              <div class="animate-spin mx-auto w-12 h-12 border-4 border-[rgba(200,160,100,0.2)] border-t-urfa-600 rounded-full"></div>
              <p class="mt-4 text-[#6B5540]">E-posta doğrulanıyor...</p>
            </div>
            <div id="verification-result" class="hidden"></div>
          </div>
        </>
      ) : (
        <div class="text-center">
          <div class="text-6xl mb-4">!</div>
          <h1 class="text-2xl font-bold text-[#1A1008] mb-4">Geçersiz Bağlantı</h1>
          <p class="text-[#6B5540] mb-6">Doğrulama bağlantısı bulunamadı. Lütfen e-postanızdaki bağlantıyı kontrol edin.</p>
          <a
            href="/"
            class="inline-block bg-urfa-600 text-white px-6 py-2 rounded-sm hover:bg-urfa-700 transition-colors"
          >
            Ana Sayfaya Dön
          </a>
        </div>
      )}
    </div>
  </div>

  <script define:vars={{ token }} is:inline>
    function buildSuccessResult(resultEl) {
      resultEl.replaceChildren();

      const emoji = document.createElement('div');
      emoji.className = 'text-6xl mb-4';
      emoji.textContent = '✓';
      resultEl.appendChild(emoji);

      const title = document.createElement('h1');
      title.className = 'text-2xl font-bold text-urfa-600 mb-4';
      title.textContent = 'Doğrulama Başarılı!';
      resultEl.appendChild(title);

      const desc = document.createElement('p');
      desc.className = 'text-[#6B5540] mb-6';
      desc.textContent = 'E-posta adresiniz başarıyla doğrulanmıştır.';
      resultEl.appendChild(desc);

      const link = document.createElement('a');
      link.href = '/ayarlar';
      link.className = 'inline-block bg-urfa-600 text-white px-6 py-2 rounded-sm hover:bg-urfa-700 transition-colors';
      link.textContent = 'Ayarlarına Git';
      resultEl.appendChild(link);
    }

    function buildErrorResult(resultEl, heading, message) {
      resultEl.replaceChildren();

      const emoji = document.createElement('div');
      emoji.className = 'text-6xl mb-4';
      emoji.textContent = '!';
      resultEl.appendChild(emoji);

      const title = document.createElement('h1');
      title.className = 'text-2xl font-bold text-red-600 mb-4';
      title.textContent = heading;
      resultEl.appendChild(title);

      const desc = document.createElement('p');
      desc.className = 'text-[#6B5540] mb-6';
      desc.textContent = message;
      resultEl.appendChild(desc);

      const link = document.createElement('a');
      link.href = '/';
      link.className = 'inline-block bg-urfa-600 text-white px-6 py-2 rounded-sm hover:bg-urfa-700 transition-colors';
      link.textContent = 'Ana Sayfaya Dön';
      resultEl.appendChild(link);
    }

    if (token) {
      fetch('/api/users/verify-email?token=' + encodeURIComponent(token))
        .then(function(res) { return res.json(); })
        .then(function(data) {
          var statusEl = document.getElementById('verification-status');
          var resultEl = document.getElementById('verification-result');

          if (statusEl && resultEl) {
            statusEl.remove();
            if (data.success) {
              buildSuccessResult(resultEl);
            } else {
              buildErrorResult(
                resultEl,
                'Doğrulama Başarısız',
                data.error || 'E-posta doğrulanamadı. Bağlantı geçerli değil veya süresi dolmuş olabilir.'
              );
            }
            resultEl.classList.remove('hidden');
          }
        })
        .catch(function() {
          var statusEl = document.getElementById('verification-status');
          var resultEl = document.getElementById('verification-result');

          if (statusEl && resultEl) {
            statusEl.remove();
            buildErrorResult(resultEl, 'Bir Hata Oluştu', 'Lütfen daha sonra tekrar deneyin.');
            resultEl.classList.remove('hidden');
          }
        });
    }
  </script>
</Layout>
