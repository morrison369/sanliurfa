---
import Layout from '../layouts/Layout.astro';
import { actions, isInputError } from 'astro:actions';

const seo = {
  title: 'Kayıt Ol - Sanliurfa.com',
  description: 'Sanliurfa.com\'a ücretsiz kayıt olun. Mekan değerlendirin, koleksiyon oluşturun ve Şanlıurfa\'nın en kapsamlı şehir rehberine katılın.',
  noIndex: true,
};

// Check if already logged in
const user = Astro.locals.user;
if (user) {
  return Astro.redirect('/');
}

const registerResult = Astro.getActionResult(actions.register);
const registerInputErrors = isInputError(registerResult?.error) ? registerResult.error.fields : {};
const registerSubmitError =
  !isInputError(registerResult?.error) && registerResult?.error?.message
    ? registerResult.error.message
    : null;

if (registerResult?.data?.success) {
  return Astro.redirect('/');
}
---
<Layout seo={seo} hideFooter>
  <div class="min-h-screen flex items-center justify-center bg-[#0D0A08] p-4">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <a href="/" style="display:inline-flex;align-items:baseline;gap:0.0625rem;text-decoration:none;">
          <span style="font-family:'Cormorant Garamond',Georgia,serif;font-size:2rem;font-weight:300;font-style:italic;color:#F5EDD6;letter-spacing:-0.02em;">Sanliurfa</span>
          <span style="font-family:'Jost',sans-serif;font-size:1rem;font-weight:700;color:#CE8E38;letter-spacing:0.06em;">.com</span>
        </a>
        <p class="text-[#9A8470] mt-2 text-sm tracking-wide">Yeni hesap oluşturun</p>
      </div>

      <div class="bg-[#FDFAF3] border border-[rgba(200,160,100,0.22)] rounded-sm shadow-2xl shadow-black/40 p-8">
        {registerSubmitError && (
          <div class="mb-4 rounded-sm border border-isot-200 bg-isot-50 p-3 text-sm text-isot-700">
            {registerSubmitError}
          </div>
        )}

        <form action={actions.register} method="POST" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-[#4A3828] mb-1">Ad Soyad</label>
            <input
              type="text"
              name="name"
              required
              transition:persist
              aria-invalid={registerInputErrors.name ? 'true' : 'false'}
              class="w-full px-4 py-3 border border-[rgba(200,160,100,0.3)] rounded-sm bg-white focus:ring-2 focus:ring-urfa-400 focus:border-transparent"
              placeholder="Adınız Soyadınız"
            />
            {registerInputErrors.name && (
              <p class="mt-2 text-sm text-isot-600">{registerInputErrors.name.join(', ')}</p>
            )}
          </div>

          <div>
            <label class="block text-sm font-medium text-[#4A3828] mb-1">E-posta</label>
            <input
              type="email"
              name="email"
              required
              transition:persist
              aria-invalid={registerInputErrors.email ? 'true' : 'false'}
              class="w-full px-4 py-3 border border-[rgba(200,160,100,0.3)] rounded-sm bg-white focus:ring-2 focus:ring-urfa-400 focus:border-transparent"
              placeholder="ornek@email.com"
            />
            {registerInputErrors.email && (
              <p class="mt-2 text-sm text-isot-600">{registerInputErrors.email.join(', ')}</p>
            )}
          </div>

          <div>
            <label class="block text-sm font-medium text-[#4A3828] mb-1">Şifre</label>
            <input
              type="password"
              name="password"
              autocomplete="new-password"
              required
              minlength="6"
              aria-invalid={registerInputErrors.password ? 'true' : 'false'}
              class="w-full px-4 py-3 border border-[rgba(200,160,100,0.3)] rounded-sm bg-white focus:ring-2 focus:ring-urfa-400 focus:border-transparent"
              placeholder="En az 6 karakter"
            />
            {registerInputErrors.password && (
              <p class="mt-2 text-sm text-isot-600">{registerInputErrors.password.join(', ')}</p>
            )}
          </div>

          <div>
            <label class="block text-sm font-medium text-[#4A3828] mb-1">Şifre Tekrar</label>
            <input
              type="password"
              name="passwordConfirm"
              autocomplete="new-password"
              required
              aria-invalid={registerInputErrors.passwordConfirm ? 'true' : 'false'}
              class="w-full px-4 py-3 border border-[rgba(200,160,100,0.3)] rounded-sm bg-white focus:ring-2 focus:ring-urfa-400 focus:border-transparent"
              placeholder="Şifrenizi tekrar girin"
            />
            {registerInputErrors.passwordConfirm && (
              <p class="mt-2 text-sm text-isot-600">{registerInputErrors.passwordConfirm.join(', ')}</p>
            )}
          </div>

          <div class="flex items-start">
            <input
              type="checkbox"
              name="terms"
              required
              aria-invalid={registerInputErrors.terms ? 'true' : 'false'}
              class="w-4 h-4 mt-1 text-urfa-600 rounded border-[rgba(200,160,100,0.3)]"
            />
            <label class="ml-2 text-sm text-[#6B5540]">
              <a href="/kullanim-kosullari" class="text-urfa-600 hover:underline">Kullanım koşullarını</a> ve
              <a href="/gizlilik-politikasi" class="text-urfa-600 hover:underline">gizlilik politikasını</a> kabul ediyorum
            </label>
          </div>
          {registerInputErrors.terms && (
            <p class="mt-2 text-sm text-isot-600">{registerInputErrors.terms.join(', ')}</p>
          )}

          <button
            type="submit"
            class="w-full py-3 bg-urfa-600 text-white rounded-sm font-medium tracking-wide hover:bg-urfa-700 transition-colors"
          >
            Kayıt Ol
          </button>
        </form>

        <div class="mt-6 text-center">
          <p class="text-[#9A8470] text-sm">
            Zaten hesabınız var mı?
            <a href="/giris" class="text-urfa-600 font-medium hover:underline">Giriş Yap</a>
          </p>
        </div>
      </div>

      <p class="text-center text-sm text-[#6B5540] mt-8">
        <a href="/" class="hover:text-[#C4B49A]">← Ana Sayfaya Dön</a>
      </p>
    </div>
  </div>
</Layout>



