---
import Layout from '../layouts/Layout.astro';
import { actions, isInputError } from 'astro:actions';

const seo = {
  title: 'Kayıt Ol - Sanliurfa.com',
  description: 'Yeni hesap oluşturun',
  noIndex: true,
};

// Check if already logged in
const user = Astro.locals.user;
if (user) {
  return Astro.redirect('/');
}

const registerResult = Astro.getActionResult(actions.register);
const registerInputErrors = isInputError(registerResult?.error) ? registerResult.error.fields : {};
const registerSubmitError =
  !isInputError(registerResult?.error) && registerResult?.error?.message
    ? registerResult.error.message
    : null;

if (registerResult?.data?.success) {
  return Astro.redirect('/');
}
---
<Layout seo={seo} hideFooter>
  <div class="min-h-screen flex items-center justify-center bg-gray-50 p-4">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <a href="/" class="text-3xl font-bold text-gray-900">
          Şanlıurfa<span class="text-red-600">.com</span>
        </a>
        <p class="text-gray-500 mt-2">Yeni hesap oluşturun</p>
      </div>

      <div class="bg-white rounded-2xl shadow-lg p-8">
        {registerSubmitError && (
          <div class="mb-4 rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700">
            {registerSubmitError}
          </div>
        )}

        <form action={actions.register} method="POST" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Ad Soyad</label>
            <input 
              type="text" 
              name="name" 
              required
              transition:persist
              aria-invalid={registerInputErrors.name ? 'true' : 'false'}
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent"
              placeholder="Adınız Soyadınız"
            />
            {registerInputErrors.name && (
              <p class="mt-2 text-sm text-red-600">{registerInputErrors.name.join(', ')}</p>
            )}
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">E-posta</label>
            <input 
              type="email" 
              name="email" 
              required
              transition:persist
              aria-invalid={registerInputErrors.email ? 'true' : 'false'}
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent"
              placeholder="ornek@email.com"
            />
            {registerInputErrors.email && (
              <p class="mt-2 text-sm text-red-600">{registerInputErrors.email.join(', ')}</p>
            )}
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Şifre</label>
            <input 
              type="password" 
              name="password" 
              required 
              minlength="6"
              aria-invalid={registerInputErrors.password ? 'true' : 'false'}
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent"
              placeholder="En az 6 karakter"
            />
            {registerInputErrors.password && (
              <p class="mt-2 text-sm text-red-600">{registerInputErrors.password.join(', ')}</p>
            )}
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Şifre Tekrar</label>
            <input 
              type="password" 
              name="passwordConfirm" 
              required 
              aria-invalid={registerInputErrors.passwordConfirm ? 'true' : 'false'}
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-transparent"
              placeholder="Şifrenizi tekrar girin"
            />
            {registerInputErrors.passwordConfirm && (
              <p class="mt-2 text-sm text-red-600">{registerInputErrors.passwordConfirm.join(', ')}</p>
            )}
          </div>

          <div class="flex items-start">
            <input 
              type="checkbox" 
              name="terms" 
              required
              aria-invalid={registerInputErrors.terms ? 'true' : 'false'}
              class="w-4 h-4 mt-1 text-red-600 rounded border-gray-300"
            />
            <label class="ml-2 text-sm text-gray-600">
              <a href="/kullanim-kosullari" class="text-red-600 hover:underline">Kullanım koşullarını</a> ve
              <a href="/gizlilik-politikasi" class="text-red-600 hover:underline">gizlilik politikasını</a> kabul ediyorum
            </label>
          </div>
          {registerInputErrors.terms && (
            <p class="mt-2 text-sm text-red-600">{registerInputErrors.terms.join(', ')}</p>
          )}

          <button 
            type="submit" 
            class="w-full py-3 bg-red-600 text-white rounded-lg font-medium hover:bg-red-700 transition-colors"
          >
            Kayıt Ol
          </button>
        </form>

        <div class="mt-6 text-center">
          <p class="text-gray-500">
            Zaten hesabınız var mı? 
            <a href="/giris" class="text-red-600 font-medium hover:underline">Giriş Yap</a>
          </p>
        </div>
      </div>

      <p class="text-center text-sm text-gray-500 mt-8">
        <a href="/" class="hover:text-gray-700">← Ana Sayfaya Dön</a>
      </p>
    </div>
  </div>
</Layout>



