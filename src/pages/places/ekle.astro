---
import Layout from '../../layouts/Layout.astro';

// SVG ikonlar
const icons = {
  mapPin: `<svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
  upload: `<svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>`,
  clock: `<svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  phone: `<svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
  globe: `<svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
  mail: `<svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
  info: `<svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>`,
  check: `<svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`,
};

const seo = {
  title: 'Mekan Ekle - Şanlıurfa.com',
  description: 'Şanlıurfa.com\'a mekan ekleyin. Restoran, kafe, otel veya tarihi yer ekleyerek binlerce kullanıcıya ulaşın.',
};

const categories = [
  { id: 'restaurant', label: 'Restoran' },
  { id: 'cafe', label: 'Kafe' },
  { id: 'hotel', label: 'Otel' },
  { id: 'museum', label: 'Müze' },
  { id: 'park', label: 'Park' },
  { id: 'shopping', label: 'Alışveriş' },
  { id: 'entertainment', label: 'Eğlence' },
  { id: 'other', label: 'Diğer' },
];

const success = Astro.url.searchParams.get('success');
const error = Astro.url.searchParams.get('error');
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <!-- Page Header -->
    <div class="page-header">
      <div class="page-header-content">
        <h1 class="page-header-title">Mekan Ekle</h1>
        <p class="page-header-description">
          Şanlıurfa'nın zenginliklerini keşfetmemize yardımcı olun. Mekanınızı ekleyerek binlerce kullanıcıya ulaşın.
        </p>
      </div>
    </div>
    
    <div class="container-custom py-12">
      {success ? (
        <div class="max-w-2xl mx-auto text-center">
          <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-12">
            <div class="w-20 h-20 bg-green-100 dark:bg-green-900/20 rounded-full flex items-center justify-center mx-auto mb-6">
              <span set:html={icons.check}></span>
            </div>
            <h2 class="text-2xl font-display font-bold text-gray-900 dark:text-white mb-4">
              Başvurunuz Alındı!
            </h2>
            <p class="text-gray-600 dark:text-gray-400 mb-8">
              Mekanınız incelendikten sonra onaylanacaktır. Bilgilendirme e-postası alacaksınız.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a href="/" class="btn-primary">Ana Sayfaya Dön</a>
              <a href="/places" class="btn-secondary">Mekanları Keşfet</a>
            </div>
          </div>
        </div>
      ) : (
        <div class="grid lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
          <!-- Form -->
          <div class="lg:col-span-2">
            {error && (
              <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl p-4 mb-6">
                <p class="text-red-600 dark:text-red-400 text-sm">
                  {error === 'missing_fields' && 'Lütfen tüm zorunlu alanları doldurun.'}
                  {error === 'invalid_email' && 'Geçerli bir e-posta adresi girin.'}
                  {error === 'server_error' && 'Bir hata oluştu. Lütfen tekrar deneyin.'}
                </p>
              </div>
            )}
            
            <form action="/api/places/submit" method="POST" class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-8" enctype="multipart/form-data">
              <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-6">Mekan Bilgileri</h2>
              
              <div class="space-y-6">
                <!-- Basic Info -->
                <div class="grid sm:grid-cols-2 gap-4">
                  <div class="sm:col-span-2">
                    <label for="name" class="label dark:text-gray-300">Mekan Adı *</label>
                    <input 
                      type="text" 
                      id="name" 
                      name="name" 
                      required
                      class="input dark:bg-gray-700 dark:border-gray-600 dark:text-white"
                      placeholder="Mekan adı"
                    />
                  </div>
                  
                  <div>
                    <label for="category" class="label dark:text-gray-300">Kategori *</label>
                    <select id="category" name="category" required class="input dark:bg-gray-700 dark:border-gray-600 dark:text-white">
                      <option value="">Kategori seçin</option>
                      {categories.map(cat => (
                        <option value={cat.id}>{cat.label}</option>
                      ))}
                    </select>
                  </div>
                  
                  <div>
                    <label for="phone" class="label dark:text-gray-300">Telefon *</label>
                    <div class="relative">
                      <span set:html={icons.phone}></span>
                      <input 
                        type="tel" 
                        id="phone" 
                        name="phone"
                        required
                        class="input pl-10 dark:bg-gray-700 dark:border-gray-600 dark:text-white"
                        placeholder="+90 414 123 45 67"
                      />
                    </div>
                  </div>
                </div>
                
                <!-- Address -->
                <div>
                  <label for="address" class="label dark:text-gray-300">Adres *</label>
                  <div class="relative">
                    <span set:html={icons.mapPin}></span>
                    <input 
                      type="text" 
                      id="address" 
                      name="address" 
                      required
                      class="input pl-10 dark:bg-gray-700 dark:border-gray-600 dark:text-white"
                      placeholder="Tam adres"
                    />
                  </div>
                </div>
                
                <!-- Description -->
                <div>
                  <label for="description" class="label dark:text-gray-300">Açıklama *</label>
                  <textarea 
                    id="description" 
                    name="description" 
                    rows="4" 
                    required
                    class="input dark:bg-gray-700 dark:border-gray-600 dark:text-white resize-none"
                    placeholder="Mekanınız hakkında kısa bir açıklama..."
                  ></textarea>
                </div>
                
                <!-- Opening Hours -->
                <div>
                  <label for="opening_hours" class="label dark:text-gray-300">Çalışma Saatleri</label>
                  <div class="relative">
                    <span set:html={icons.clock}></span>
                    <input 
                      type="text" 
                      id="opening_hours" 
                      name="opening_hours"
                      class="input pl-10 dark:bg-gray-700 dark:border-gray-600 dark:text-white"
                      placeholder="Örn: Pzt-Paz: 08:00 - 22:00"
                    />
                  </div>
                </div>
                
                <!-- Website -->
                <div>
                  <label for="website" class="label dark:text-gray-300">Web Sitesi (varsa)</label>
                  <div class="relative">
                    <span set:html={icons.globe}></span>
                    <input 
                      type="url" 
                      id="website" 
                      name="website"
                      class="input pl-10 dark:bg-gray-700 dark:border-gray-600 dark:text-white"
                      placeholder="https://www.ornek.com"
                    />
                  </div>
                </div>
                
                <!-- Image -->
                <div>
                  <label for="image" class="label dark:text-gray-300">Fotoğraf</label>
                  <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 dark:border-gray-600 border-dashed rounded-lg hover:border-urfa-500 transition-colors">
                    <div class="space-y-1 text-center">
                      <span set:html={icons.upload}></span>
                      <div class="flex text-sm text-gray-600 dark:text-gray-400">
                        <label for="image" class="relative cursor-pointer rounded-md font-medium text-urfa-600 hover:text-urfa-500">
                          <span>Dosya seç</span>
                          <input id="image" name="image" type="file" accept="image/*" class="sr-only" />
                        </label>
                        <p class="pl-1">veya sürükleyin</p>
                      </div>
                      <p class="text-xs text-gray-500 dark:text-gray-400">PNG, JPG up to 5MB</p>
                    </div>
                  </div>
                </div>
                
                <!-- Submitter Info -->
                <div class="border-t border-gray-200 dark:border-gray-700 pt-6">
                  <h3 class="font-medium text-gray-900 dark:text-white mb-4">İletişim Bilgileriniz</h3>
                  <div class="grid sm:grid-cols-2 gap-4">
                    <div>
                      <label for="submitter_name" class="label dark:text-gray-300">Adınız *</label>
                      <input 
                        type="text" 
                        id="submitter_name" 
                        name="submitter_name"
                        required
                        class="input dark:bg-gray-700 dark:border-gray-600 dark:text-white"
                        placeholder="Adınız Soyadınız"
                      />
                    </div>
                    <div>
                      <label for="submitter_email" class="label dark:text-gray-300">E-posta *</label>
                      <div class="relative">
                        <Mail className="absolute left-3 top-3 w-5 h-5 text-gray-400" />
                        <input 
                          type="email" 
                          id="submitter_email" 
                          name="submitter_email"
                          required
                          class="input pl-10 dark:bg-gray-700 dark:border-gray-600 dark:text-white"
                          placeholder="ornek@email.com"
                        />
                      </div>
                    </div>
                  </div>
                </div>
                
                <!-- Submit -->
                <div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-6 border-t border-gray-200 dark:border-gray-700">
                  <p class="text-sm text-gray-600 dark:text-gray-400 flex items-center gap-2">
                    <Info className="w-4 h-4" />
                    * ile işaretli alanlar zorunludur
                  </p>
                  <div class="flex gap-3">
                    <a href="/places" class="btn-secondary">İptal</a>
                    <button type="submit" class="btn-primary">
                      Başvuruyu Gönder
                    </button>
                  </div>
                </div>
              </div>
            </form>
          </div>
          
          <!-- Sidebar Info -->
          <aside class="space-y-6">
            <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
              <h3 class="font-semibold text-gray-900 dark:text-white mb-4">Neden Eklemeli?</h3>
              <ul class="space-y-3 text-sm">
                <li class="flex items-start gap-2">
                  <Check className="w-5 h-5 text-green-500 flex-shrink-0" />
                  <span class="text-gray-600 dark:text-gray-400">Binlerce potansiyel müşteriye ulaşın</span>
                </li>
                <li class="flex items-start gap-2">
                  <Check className="w-5 h-5 text-green-500 flex-shrink-0" />
                  <span class="text-gray-600 dark:text-gray-400">Ücretsiz tanıtım imkanı</span>
                </li>
                <li class="flex items-start gap-2">
                  <Check className="w-5 h-5 text-green-500 flex-shrink-0" />
                  <span class="text-gray-600 dark:text-gray-400">Müşteri değerlendirmeleri alın</span>
                </li>
                <li class="flex items-start gap-2">
                  <Check className="w-5 h-5 text-green-500 flex-shrink-0" />
                  <span class="text-gray-600 dark:text-gray-400">Rehber uygulamalarında görünün</span>
                </li>
              </ul>
            </div>
            
            <div class="bg-urfa-600 rounded-2xl p-6 text-white">
              <h3 class="font-semibold mb-2">Yardım mı lazım?</h3>
              <p class="text-sm text-urfa-100 mb-4">
                Mekan ekleme sürecinde sorun yaşıyorsanız bize ulaşın.
              </p>
              <a href="/iletisim" class="inline-block px-4 py-2 bg-white text-urfa-600 rounded-lg font-medium text-sm hover:bg-urfa-50 transition-colors">
                İletişime Geç
              </a>
            </div>
          </aside>
        </div>
      )}
    </div>
  </div>
</Layout>
