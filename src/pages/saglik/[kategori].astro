---
import Layout from '../../layouts/Layout.astro';
import { query } from '../../lib/postgres';
import { getCachedPublicRouteData } from '../../lib/public-route-cache';
import { getPublicAppUrl } from '../../lib/public-app-url';
import { logger } from '../../lib/logging';
const baseUrl = getPublicAppUrl();

const { kategori } = Astro.params;

const categoryMeta: Record<string, { name: string; icon: string }> = {
 'devlet-hastaneleri': { name: 'Devlet Hastaneleri', icon: '🏥' },
 'ozel-hastaneler': { name: 'Özel Hastaneler', icon: '🏨' },
 'dis-klinikleri': { name: 'Diş Klinikleri', icon: '🦷' },
 'eczaneler': { name: 'Eczaneler', icon: '💊' },
 'veterinerler': { name: 'Veterinerler', icon: '🐾' },
};

const meta = categoryMeta[kategori || ''] || { name: kategori || '', icon: '🏥' };

let places: any[] = [];

try {
 places = await getCachedPublicRouteData(`page:saglik:${kategori || 'unknown'}`, async () => {
  const result = await query(
   `SELECT p.*, d.name as district_name FROM places p
 LEFT JOIN categories c ON p.category_id = c.id
 LEFT JOIN districts d ON p.district_id = d.id
 WHERE c.slug = $1 AND p.status = 'active'
 ORDER BY p.is_featured DESC, p.rating DESC`,
   [kategori]
  );
  return result.rows;
 });
} catch (e) {
 logger.error('Error loading saglik kategori:', e instanceof Error ? e : new Error(String(e)));
}

const seo = {
 title: `Şanlıurfa ${meta.name} | Sağlık Rehberi`,
 description: `Şanlıurfa'da ${meta.name.toLowerCase()}. Adres, telefon ve konum bilgileri.`,
 keywords: ['şanlıurfa ' + meta.name.toLowerCase(), 'urfa ' + meta.name.toLowerCase(), meta.name + ' şanlıurfa', 'şanlıurfa sağlık'],
 ogImage: '/images/places/balikligol.jpg',
 canonical: `/saglik/${kategori}`,
};
const faqItems = [
 { S: `Şanlıurfa'da ${meta.name.toLowerCase()} seçenekleri nelerdir?`, C: `Şanlıurfa'da ${meta.name.toLowerCase()} için güncel liste ve değerlendirmeler rehberimizde yer almaktadır.` },
 { S: `${meta.name} için hangi ilçeler öne çıkıyor?`, C: `Eyyübiye, Haliliye ve Karaköprü ilçeleri hizmet yoğunluğu açısından öne çıkan bölgeler arasındadır.` },
 { S: `${meta.name} bilgilerini nasıl güncelleyebilirim?`, C: `Mekan sayfasına giriş yaparak güncelleme talebinde bulunabilir veya iletişim formu üzerinden bildirimde bulunabilirsiniz.` },
];
---

<Layout seo={seo}>
 <style>
 .sk-breadcrumb{background:var(--public-bg);border-bottom:1px solid var(--public-border);padding:.75rem 0}
 .sk-breadcrumb nav{display:flex;align-items:center;gap:.5rem;font-size:.8rem;color:var(--public-muted)}
 .sk-breadcrumb a{color:var(--public-muted);transition:color .15s}.sk-breadcrumb a:hover{color:var(--public-accent)}
 .sk-breadcrumb span:last-child{color:var(--public-accent);font-weight:500}
 .sk-hero{background:var(--public-bg);border-bottom:1px solid var(--public-border);padding:3rem 0}
 .sk-hero-inner{display:flex;align-items:center;gap:1rem}
 .sk-hero-icon{font-size:3rem;line-height:1}
 .sk-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.6rem,4vw,2.5rem);font-weight:600;color:var(--public-text)}
 .sk-count{font-size:.85rem;color:var(--public-muted);margin-top:.25rem}
 .sk-body{background:var(--public-bg);padding:2rem 0 4rem}
 .sk-grid{display:grid;gap:1rem;grid-template-columns:repeat(auto-fill,minmax(280px,1fr))}
 .sk-card{background:var(--public-surface);border:1px solid var(--public-border);padding:1.25rem;display:flex;align-items:flex-start;gap:.85rem;transition:border-color .15s}
 .sk-card:hover{border-color:var(--public-accent)}
 .sk-card-icon{font-size:2rem;flex-shrink:0;line-height:1}
 .sk-card-content{flex:1;min-width:0}
 .sk-card-name{font-size:.92rem;font-weight:700;color:var(--public-text);margin-bottom:.2rem;transition:color .15s}
 .sk-card:hover .sk-card-name{color:var(--public-accent)}
 .sk-district{font-size:.72rem;color:var(--public-text-soft)}
 .sk-addr{font-size:.75rem;color:var(--public-muted);margin-top:.2rem}
 .sk-phone{font-size:.75rem;color:var(--public-muted)}
 .sk-rating{display:flex;align-items:center;gap:.25rem;font-size:.78rem;color:var(--public-text);font-weight:600;margin-top:.35rem}
 .sk-rating-star{color:var(--public-accent)}
 .sk-empty{text-align:center;padding:4rem 1rem;color:var(--public-muted)}
 .sk-empty-icon{font-size:3.5rem;margin-bottom:.75rem}
 .sk-empty-link{display:inline-block;margin-top:.75rem;color:var(--public-accent);font-size:.85rem;transition:color .15s}
 .sk-empty-link:hover{color:var(--public-accent-strong)}
 </style>

 <div class="sk-breadcrumb">
 <div class="sf-container">
 <nav>
 <a href="/">Ana Sayfa</a>
 <span>/</span>
 <a href="/saglik">Sağlık</a>
 <span>/</span>
 <span>{meta.name}</span>
 </nav>
 </div>
 </div>

 <div class="sk-hero">
 <div class="sf-container">
 <div class="sk-hero-inner">
 <span class="sk-hero-icon">{meta.icon}</span>
 <div>
 <h1 class="sk-h1">Şanlıurfa {meta.name}</h1>
 <p class="sk-count">{places.length} kuruluş bulundu</p>
 </div>
 </div>
 </div>
 </div>

 <div class="sk-body">
 <div class="sf-container">
 {places.length > 0 ? (
 <div class="sk-grid">
 {places.map((place) => (
 <a href={`/isletme/${place.slug}`} class="sk-card">
 <span class="sk-card-icon">{meta.icon}</span>
 <div class="sk-card-content">
 <p class="sk-card-name">{place.name}</p>
 {place.district_name && <p class="sk-district">{place.district_name}</p>}
 {place.address && <p class="sk-addr">📍 {place.address}</p>}
 {place.phone && <p class="sk-phone">📞 {place.phone}</p>}
 {place.rating && (
 <div class="sk-rating">
 <span class="sk-rating-star">★</span>
 {place.rating}
 </div>
 )}
 </div>
 </a>
 ))}
 </div>
 ) : (
 <div class="sk-empty">
 <div class="sk-empty-icon">{meta.icon}</div>
 <p>Bu kategoride henüz kayıt bulunmuyor.</p>
 <a href="/saglik" class="sk-empty-link">Sağlık Rehberine Dön →</a>
 </div>
 )}
 </div>
 </div>

 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'CollectionPage',
 name: `Şanlıurfa ${meta.name}`,
 description: `Şanlıurfa'da ${meta.name.toLowerCase()}. Adres, telefon ve konum bilgileri.`,
 url: `${baseUrl}/saglik/${kategori}`,
 about: { '@type': 'City', name: 'Şanlıurfa' },
 itemListElement: places.slice(0, 10).map((p: any, i: number) => ({
 '@type': 'ListItem',
 position: i + 1,
 item: {
 '@type': 'MedicalOrganization',
 name: p.name,
 url: `${baseUrl}/isletme/${p.slug}`,
 ...(p.address ? { address: p.address } : {}),
 ...(p.phone ? { telephone: p.phone } : {}),
 },
 })),
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'Sağlık', item: `${baseUrl}/saglik` },
 { '@type': 'ListItem', position: 3, name: meta.name, item: `${baseUrl}/saglik/${kategori}` },
 ],
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqItems.map((item) => ({
 '@type': 'Question',
 name: item.S,
 acceptedAnswer: { '@type': 'Answer', text: item.C },
 })),
 })} is:inline />
</Layout>
