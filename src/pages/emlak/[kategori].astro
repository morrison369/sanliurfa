---

import Layout from '../../layouts/Layout.astro';
import { query } from '../../lib/postgres';
import { getSiteBranding } from '../../lib/site-branding';
import { logger } from '../../lib/logging';
const { baseUrl } = await getSiteBranding();

const { kategori } = Astro.params;

const categoryMeta: Record<string, { name: string; icon: string; desc: string }> = {
  'satilik-daire': { name: 'Satılık Daireler', icon: '🏠', desc: 'Şanlıurfa\'da satılık konutlar' },
  'kiralik-daire': { name: 'Kiralık Daireler', icon: '🔑', desc: 'Şanlıurfa\'da kiralık konutlar' },
  'emlak-ofisleri': { name: 'Emlak Ofisleri', icon: '🏢', desc: 'Güvenilir emlakçı ve danışmanlar' },
};

const meta = categoryMeta[kategori || ''] || { name: kategori || '', icon: '🏠', desc: '' };

let places: any[] = [];

try {
  const result = await query(
    `SELECT p.*, d.name as district_name FROM places p
     LEFT JOIN categories c ON p.category_id = c.id
     LEFT JOIN districts d ON p.district_id = d.id
     WHERE c.slug = $1 AND p.status = 'active'
     ORDER BY p.is_featured DESC, p.created_at DESC`,
    [kategori]
  );
  places = result.rows;
} catch (e) {
  logger.error('Error loading emlak kategori:', e instanceof Error ? e : new Error(String(e)));
}

const seo = {
  title: `Şanlıurfa ${meta.name} | Emlak Rehberi`,
  description: `${meta.desc}. Detaylı bilgi, adres ve iletişim.`,
  keywords: ['şanlıurfa ' + meta.name.toLowerCase(), 'urfa ' + meta.name.toLowerCase(), meta.name + ' şanlıurfa', 'şanlıurfa emlak'],
  ogImage: '/images/hero/hero-home.webp',
  canonical: `/emlak/${kategori}`,
};
const faqItems = [
  { S: `Şanlıurfa'da ${meta.name.toLowerCase()} seçenekleri nelerdir?`, C: `Şanlıurfa'da ${meta.name.toLowerCase()} için güncel liste ve değerlendirmeler rehberimizde yer almaktadır.` },
  { S: `${meta.name} için hangi ilçeler öne çıkıyor?`, C: `Eyyübiye, Haliliye ve Karaköprü ilçeleri hizmet yoğunluğu açısından öne çıkan bölgeler arasındadır.` },
  { S: `${meta.name} bilgilerini nasıl güncelleyebilirim?`, C: `Mekan sayfasına giriş yaparak güncelleme talebinde bulunabilir veya iletişim formu üzerinden bildirimde bulunabilirsiniz.` },
];
---

<Layout seo={seo}>
  <div class="min-h-screen bg-[#FDFAF3]">
    <div class="bg-[#FDFAF3] border-b border-[rgba(200,160,100,0.14)]">
      <div class="container mx-auto px-4 py-3">
        <nav class="flex items-center gap-2 text-sm text-[#9A8470]">
          <a href="/" class="hover:text-urfa-600">Ana Sayfa</a>
          <span>/</span>
          <a href="/emlak" class="hover:text-urfa-600">Emlak</a>
          <span>/</span>
          <span class="text-[#1A1008] font-medium">{meta.name}</span>
        </nav>
      </div>
    </div>

    <div class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)] text-white py-12">
      <div class="container mx-auto px-4">
        <div class="flex items-center gap-4">
          <span class="text-5xl">{meta.icon}</span>
          <div>
            <h1 class="text-3xl md:text-4xl font-bold text-[#F5EDD6]">Şanlıurfa {meta.name}</h1>
            <p class="text-[#9A8470] mt-1">{meta.desc}</p>
          </div>
        </div>
      </div>
    </div>

    <div class="container mx-auto px-4 py-8">
      {places.length > 0 ? (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {places.map((place) => (
            <a href={`/isletme/${place.slug}`} class="bg-white rounded-sm p-5 border border-[rgba(200,160,100,0.18)] shadow-sm hover:shadow-md hover:border-urfa-300 transition-all group">
              <div class="flex items-start justify-between gap-2">
                <h2 class="font-bold text-lg text-[#1A1008] group-hover:text-urfa-700">{place.name}</h2>
                {place.price_range && <span class="text-urfa-700 font-medium">{place.price_range}</span>}
              </div>
              {place.district_name && <p class="text-xs text-[#9A8470] mt-1">📍 {place.district_name}</p>}
              {place.short_description && <p class="text-sm text-[#6B5540] mt-2 line-clamp-2">{place.short_description}</p>}
              {place.phone && <p class="text-sm text-[#9A8470] mt-2">📞 {place.phone}</p>}
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <div class="text-6xl mb-4">{meta.icon}</div>
          <p class="text-[#9A8470] text-lg">Bu kategoride henüz ilan bulunmuyor.</p>
          <a href="/emlak" class="mt-4 inline-block text-urfa-600 hover:underline">Emlak Rehberine Dön →</a>
        </div>
      )}
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: `Şanlıurfa ${meta.name}`,
    description: `${meta.desc}. Detaylı bilgi, adres ve iletişim.`,
    url: `${baseUrl}/emlak/${kategori}`,
    about: { '@type': 'City', name: 'Şanlıurfa' },
    itemListElement: places.slice(0, 10).map((p: any, i: number) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'RealEstateAgent',
        name: p.name,
        url: `${baseUrl}/isletme/${p.slug}`,
        ...(p.address ? { address: p.address } : {}),
        ...(p.phone ? { telephone: p.phone } : {}),
      },
    })),
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Emlak', item: `${baseUrl}/emlak` },
      { '@type': 'ListItem', position: 3, name: meta.name, item: `${baseUrl}/emlak/${kategori}` },
    ],
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: { '@type': 'Answer', text: item.C },
    })),
  })} is:inline />
</Layout>
