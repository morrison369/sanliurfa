---
import Layout from '../../layouts/Layout.astro';
import { query } from '../../lib/postgres';

const { kategori } = Astro.params;

const categoryMeta: Record<string, { name: string; icon: string; desc: string }> = {
  'satilik-daire': { name: 'Satılık Daireler', icon: '🏠', desc: 'Şanlıurfa\'da satılık konutlar' },
  'kiralik-daire': { name: 'Kiralık Daireler', icon: '🔑', desc: 'Şanlıurfa\'da kiralık konutlar' },
  'emlak-ofisleri': { name: 'Emlak Ofisleri', icon: '🏢', desc: 'Güvenilir emlakçı ve danışmanlar' },
};

const meta = categoryMeta[kategori || ''] || { name: kategori || '', icon: '🏠', desc: '' };

let places: any[] = [];

try {
  const result = await query(
    `SELECT p.*, d.name as district_name FROM places p
     LEFT JOIN categories c ON p.category_id = c.id
     LEFT JOIN districts d ON p.district_id = d.id
     WHERE c.slug = $1 AND p.status = 'active'
     ORDER BY p.is_featured DESC, p.created_at DESC`,
    [kategori]
  );
  places = result.rows;
} catch (e) {
  console.error('Error loading emlak kategori:', e);
}

const seo = {
  title: `Şanlıurfa ${meta.name} | Emlak Rehberi`,
  description: `${meta.desc}. Detaylı bilgi, adres ve iletişim.`,
};
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50">
    <div class="bg-white border-b">
      <div class="container mx-auto px-4 py-3">
        <nav class="flex items-center gap-2 text-sm text-gray-500">
          <a href="/" class="hover:text-emerald-600">Ana Sayfa</a>
          <span>/</span>
          <a href="/emlak" class="hover:text-emerald-600">Emlak</a>
          <span>/</span>
          <span class="text-gray-900 font-medium">{meta.name}</span>
        </nav>
      </div>
    </div>

    <div class="bg-gradient-to-br from-emerald-700 to-green-800 text-white py-12">
      <div class="container mx-auto px-4">
        <div class="flex items-center gap-4">
          <span class="text-5xl">{meta.icon}</span>
          <div>
            <h1 class="text-3xl md:text-4xl font-bold">Şanlıurfa {meta.name}</h1>
            <p class="text-emerald-100 mt-1">{meta.desc}</p>
          </div>
        </div>
      </div>
    </div>

    <div class="container mx-auto px-4 py-8">
      {places.length > 0 ? (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {places.map((place) => (
            <a href={`/places/${place.slug}`} class="bg-white rounded-xl p-5 shadow-sm hover:shadow-lg transition-all group">
              <div class="flex items-start justify-between gap-2">
                <h2 class="font-bold text-lg text-gray-900 group-hover:text-emerald-600">{place.name}</h2>
                {place.price_range && <span class="text-emerald-700 font-medium">{place.price_range}</span>}
              </div>
              {place.district_name && <p class="text-xs text-gray-500 mt-1">📍 {place.district_name}</p>}
              {place.short_description && <p class="text-sm text-gray-600 mt-2 line-clamp-2">{place.short_description}</p>}
              {place.phone && <p class="text-sm text-gray-500 mt-2">📞 {place.phone}</p>}
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <div class="text-6xl mb-4">{meta.icon}</div>
          <p class="text-gray-500 text-lg">Bu kategoride henüz ilan bulunmuyor.</p>
          <a href="/emlak" class="mt-4 inline-block text-emerald-600 hover:underline">Emlak Rehberine Dön →</a>
        </div>
      )}
    </div>
  </div>
</Layout>
