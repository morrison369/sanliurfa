---
import Layout from '../../layouts/Layout.astro';
import AnalyticsDashboard from '../../components/vendor/AnalyticsDashboard';
import { query } from '../../lib/postgres';

if (!Astro.locals.user) {
  return Astro.redirect('/giris?redirect=/vendor/analytics');
}

const userId = Astro.locals.user.id;

const placeResult = await query(
  `SELECT id, slug, name FROM places WHERE owner_id = $1 AND status != 'deleted' ORDER BY created_at DESC LIMIT 1`,
  [userId]
);
const firstPlace = placeResult.rows[0];

if (!firstPlace) {
  return Astro.redirect('/vendor/dashboard');
}

const vendor = {
  id: userId,
  name: Astro.locals.user.fullName || 'İşletme Sahibi',
  placeId: firstPlace.id,
};

const seo = {
  title: 'Analitikler - İşletme Paneli',
  description: 'İşletmenizin performans istatistiklerini görüntüleyin',
  noindex: true,
};
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50 pt-20 pb-12">
    <div class="container mx-auto px-4">
      {/* Header */}
      <div class="bg-white rounded-xl shadow-sm p-6 mb-6">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
          <div>
            <h1 class="text-2xl font-bold text-gray-900">Analitikler</h1>
            <p class="text-gray-500 mt-1">İşletmenizin performansını detaylı inceleyin</p>
          </div>
          <a
            href="/vendor/dashboard"
            class="px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors"
          >
            ← Panele Dön
          </a>
        </div>
      </div>

      {/* Analytics Dashboard */}
      <AnalyticsDashboard placeId={vendor.placeId} client:load />
    </div>
  </div>
</Layout>
