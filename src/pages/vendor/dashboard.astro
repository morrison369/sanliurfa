---
import Layout from '../../layouts/Layout.astro';
import PlaceManager from '../../components/vendor/PlaceManager';
import ReviewManager from '../../components/vendor/ReviewManager';
import ReservationManager from '../../components/vendor/ReservationManager';
import PromotionManager from '../../components/vendor/PromotionManager';
import PhotoUpload from '../../components/PhotoUpload';

import { query } from '../../lib/postgres';

const seo = {
  title: 'İşletme Paneli - Şanlıurfa.com',
  description: 'İşletme bilgilerinizi yönetin, yorumları yanıtlayın ve performansınızı takip edin.',
  noindex: true,
};

if (!Astro.locals.user) {
  return Astro.redirect('/giris?redirect=/vendor/dashboard');
}

const userId = Astro.locals.user.id;

const [placesResult, subResult] = await Promise.all([
  query(
    `SELECT id, slug, name FROM places WHERE owner_id = $1 AND status != 'deleted' ORDER BY created_at DESC`,
    [userId]
  ),
  query(
    `SELECT st.name as plan FROM subscriptions s
     JOIN subscription_tiers st ON st.id = s.tier_id
     WHERE s.user_id = $1 AND s.status = 'active'
     ORDER BY s.created_at DESC LIMIT 1`,
    [userId]
  ),
]);

const vendor = {
  id: userId,
  name: Astro.locals.user.fullName || 'İşletme Sahibi',
  email: Astro.locals.user.email,
  plan: subResult.rows[0]?.plan || 'free',
  places: placesResult.rows.map((p: any) => p.id),
  firstPlace: placesResult.rows[0] || null,
};
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50 pt-20 pb-12">
    <div class="container mx-auto px-4">
      {/* Header */}
      <div class="bg-white rounded-xl shadow-sm p-6 mb-6">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
          <div>
            <h1 class="text-2xl font-bold text-gray-900">İşletme Paneli</h1>
            <p class="text-gray-500 mt-1">Hoş geldiniz, {vendor.name}</p>
          </div>
          <div class="flex items-center gap-3">
            <span class="px-3 py-1 bg-amber-100 text-amber-700 rounded-full text-sm font-medium">
              {vendor.plan !== 'free' ? `${vendor.plan} Plan` : 'Ücretsiz Plan'}
            </span>
            {vendor.firstPlace && (
              <a
                href={`/places/${vendor.firstPlace.slug}`}
                target="_blank"
                class="px-4 py-2 bg-amber-600 text-white rounded-lg hover:bg-amber-700 transition-colors text-sm"
              >
                Sayfayı Görüntüle →
              </a>
            )}
          </div>
        </div>
      </div>

      {/* Quick Stats */}
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        <div class="bg-white rounded-xl shadow-sm p-4">
          <div class="text-2xl font-bold text-gray-900">2,847</div>
          <div class="text-sm text-gray-500">Bu Ay Görüntülenme</div>
          <div class="text-xs text-green-600 mt-1">↑ %15 artış</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm p-4">
          <div class="text-2xl font-bold text-gray-900">89</div>
          <div class="text-sm text-gray-500">Telefon Tıklaması</div>
          <div class="text-xs text-green-600 mt-1">↑ %8 artış</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm p-4">
          <div class="text-2xl font-bold text-gray-900">4.8</div>
          <div class="text-sm text-gray-500">Ortalama Puan</div>
          <div class="text-xs text-gray-500 mt-1">1,247 yorum</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm p-4">
          <div class="text-2xl font-bold text-gray-900">156</div>
          <div class="text-sm text-gray-500">Yol Tarifi</div>
          <div class="text-xs text-green-600 mt-1">↑ %22 artış</div>
        </div>
      </div>

      {/* Main Content */}
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {/* Left Column - Place Management */}
        <div class="lg:col-span-2 space-y-6">
          {vendor.firstPlace ? (
            <>
              <PlaceManager placeId={vendor.firstPlace.id} client:load />
              <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                <h2 class="text-xl font-semibold text-gray-900 mb-4">Fotoğraflar</h2>
                <PhotoUpload placeId={vendor.firstPlace.id} photos={[]} client:load />
              </div>
              <ReservationManager placeId={vendor.firstPlace.id} client:load />
              <PromotionManager placeId={vendor.firstPlace.id} client:load />
              <ReviewManager placeId={vendor.firstPlace.id} client:load />
            </>
          ) : (
            <div class="bg-white rounded-xl shadow-sm p-12 text-center text-gray-500">
              <div class="text-4xl mb-4">🏪</div>
              <p class="text-lg font-medium mb-2">Henüz işletmeniz yok</p>
              <p class="text-sm mb-4">İşletmenizi ekleyerek paneli kullanmaya başlayın.</p>
              <a href="/isletme-kayit" class="inline-block px-6 py-2 bg-amber-600 text-white rounded-lg hover:bg-amber-700">
                İşletme Ekle
              </a>
            </div>
          )}
        </div>

        {/* Right Column - Sidebar */}
        <div class="space-y-6">
          {/* Plan Info */}
          <div class="bg-white rounded-xl shadow-sm p-6">
            <h3 class="font-bold text-gray-900 mb-4">Mevcut Planınız</h3>
            <div class="space-y-3">
              <div class="flex items-center justify-between">
                <span class="text-gray-600">Plan</span>
                <span class="font-medium text-amber-600">Premium</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-gray-600">Aylık Ücret</span>
                <span class="font-medium">₺500</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-gray-600">Yenileme Tarihi</span>
                <span class="font-medium">15 Mayıs 2026</span>
              </div>
            </div>
            <hr class="my-4" />
            <h4 class="font-medium text-gray-900 mb-2">Premium Avantajları</h4>
            <ul class="space-y-2 text-sm text-gray-600">
              <li class="flex items-center gap-2">
                <span class="text-green-500">✓</span>
                Öne çıkan listeleme
              </li>
              <li class="flex items-center gap-2">
                <span class="text-green-500">✓</span>
                Sosyal medya tanıtımı
              </li>
              <li class="flex items-center gap-2">
                <span class="text-green-500">✓</span>
                Detaylı analitik raporları
              </li>
              <li class="flex items-center gap-2">
                <span class="text-green-500">✓</span>
                Öncelikli destek
              </li>
            </ul>
          </div>

          {/* Quick Actions */}
          <div class="bg-white rounded-xl shadow-sm p-6">
            <h3 class="font-bold text-gray-900 mb-4">Hızlı İşlemler</h3>
            <div class="space-y-2">
              <button class="w-full text-left px-4 py-3 rounded-lg hover:bg-gray-50 transition-colors flex items-center gap-3">
                <span class="w-8 h-8 bg-blue-100 text-blue-600 rounded-lg flex items-center justify-center">
                  📸
                </span>
                <span>Fotoğraf Ekle</span>
              </button>
              <button class="w-full text-left px-4 py-3 rounded-lg hover:bg-gray-50 transition-colors flex items-center gap-3">
                <span class="w-8 h-8 bg-green-100 text-green-600 rounded-lg flex items-center justify-center">
                  🏷️
                </span>
                <span>Kampanya Oluştur</span>
              </button>
              <button class="w-full text-left px-4 py-3 rounded-lg hover:bg-gray-50 transition-colors flex items-center gap-3">
                <span class="w-8 h-8 bg-purple-100 text-purple-600 rounded-lg flex items-center justify-center">
                  📊
                </span>
                <span>Detaylı Rapor İndir</span>
              </button>
            </div>
          </div>

          {/* Support */}
          <div class="bg-gradient-to-br from-amber-500 to-orange-600 rounded-xl shadow-sm p-6 text-white">
            <h3 class="font-bold mb-2">Yardıma mı ihtiyacınız var?</h3>
            <p class="text-amber-100 text-sm mb-4">Premium üyelere 7/24 öncelikli destek</p>
            <a
              href="mailto:support@sanliurfa.com"
              class="inline-block px-4 py-2 bg-white text-amber-600 rounded-lg font-medium hover:bg-amber-50 transition-colors"
            >
              Destek Al
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
