---

import Layout from "../../layouts/Layout.astro";
import TrendingPlaces from "../../components/TrendingPlaces";
import UserRecommendations from "../../components/UserRecommendations";
import { getPublicAppUrl } from '../../lib/public-app-url';
const baseUrl = getPublicAppUrl();

const { locals } = Astro;
const isAuthenticated = Boolean(locals.user);

const seo = {
 title: 'Keşfet | Şanlıurfa Mekanlar ve Topluluk Önerileri',
 description: "Şanlıurfa'nın trend mekanlarını ve topluluk önerilerini keşfedin. Popüler restoranlar, tarihi yerler ve yerel favoriteler.",
 keywords: ['şanlıurfa keşfet', 'urfa popüler mekanlar', 'şanlıurfa trend', 'urfa topluluk önerileri', 'şanlıurfa yeni mekanlar'],
 ogImage: '/images/places/balikligol.jpg',
 canonical: '/kesfet',
};

const faqItems = [
 { S: "Şanlıurfa'da en popüler mekanlar hangileri?", C: 'Balıklıgöl çevresi, Göbeklitepe, Harran ve Halfeti bölgesi en çok ziyaret edilen rotalar arasındadır.' },
 { S: 'Keşfet sayfasında hangi içerikler yer alır?', C: 'Kullanıcı puanlamasına göre öne çıkan mekanlar, güncel yorumlar ve topluluk önerileri listelenir.' },
 { S: "Şanlıurfa'da yeni açılan mekanları nasıl takip edebilirim?", C: 'Keşfet sayfası düzenli olarak güncellenir; yeni eklenen mekanlar ve öneriler burada öne çıkar.' },
];
---

<Layout seo={seo}>
 <style is:inline>
 .kf-hero{position:relative;overflow:hidden;border-bottom:1px solid rgba(184,115,51,0.12);padding:clamp(3rem,6vw,5rem) 0;background:radial-gradient(circle at 18% 0%,rgba(212,151,24,0.10) 0%,transparent 42%),radial-gradient(circle at 82% 100%,rgba(44,122,82,0.08) 0%,transparent 40%),linear-gradient(180deg,#fbf6ec 0%,#f4ecd8 58%,#fbf6ec 100%)}
 .kf-hero-label{font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:#4A3828}
 .kf-h1{font-family:'Cormorant Garamond',serif;font-size:clamp(1.7rem,4vw,2.6rem);font-weight:700;color:#1F1410;margin:.75rem 0 .25rem}
 .kf-hero-desc{color:#7A6B58;font-size:.9rem}
 .kf-body{background:var(--bg);padding:2rem 0 4rem}
 .kf-layout{display:grid;gap:2rem}
 @media(min-width:64rem){.kf-layout{grid-template-columns:1fr 20rem}}
 .kf-sidebar-card{background:var(--bg-card);border:1px solid rgba(184,115,51,.14);padding:1.5rem}
 .kf-sidebar-title{font-size:.9rem;font-weight:700;color:#1F1410;margin-bottom:.5rem}
 .kf-sidebar-desc{font-size:.8rem;color:#7A6B58;line-height:1.6;margin-bottom:1rem}
 .kf-btn-primary{display:inline-block;background:#B87333;color:#EDE0C6;font-size:.82rem;font-weight:600;padding:.55rem 1rem;transition:background .15s}
 .kf-btn-primary:hover{background:#9D5F1A}
 .kf-btn-outline{display:inline-block;border:1px solid rgba(184,115,51,.25);color:#B87333;font-size:.82rem;font-weight:500;padding:.55rem 1rem;transition:border-color .15s,color .15s}
 .kf-btn-outline:hover{border-color:#B87333;color:#1F1410}
 .kf-quick-links{background:rgba(184,115,51,.05);border:1px solid rgba(184,115,51,.18);padding:1.25rem;margin-top:1rem}
 .kf-quick-title{font-size:.82rem;font-weight:700;color:#1F1410;margin-bottom:.75rem}
 .kf-quick-link{display:block;font-size:.8rem;color:#B87333;padding:.2rem 0;transition:color .15s}
 .kf-quick-link:hover{color:#B87333}
 </style>

 <div class="kf-hero">
 <div class="sf-container">
 <p class="kf-hero-label">Şanlıurfa Platformu</p>
 <h1 class="kf-h1">Keşfet</h1>
 <p class="kf-hero-desc">Yeni mekanlar ve kullanıcılar bul.</p>
 </div>
 </div>

 <div class="kf-body">
 <div class="sf-container">
 <div class="kf-layout">
 <div>
 <TrendingPlaces client:visible={{ rootMargin: '160px' }} />
 </div>

 <aside>
 <div class="kf-sidebar-card">
 {isAuthenticated ? (
 <UserRecommendations client:visible={{ rootMargin: '140px' }} />
 ) : (
 <>
 <h2 class="kf-sidebar-title">Topluluk önerileri</h2>
 <p class="kf-sidebar-desc">
 Üye olduğunuzda Şanlıurfa'daki kullanıcıları takip edebilir, mesajlaşabilir ve eşleşme özelliğini kullanabilirsiniz.
 </p>
 <div style="display:flex;flex-wrap:wrap;gap:.5rem">
 <a href="/kayit" class="kf-btn-primary">Ücretsiz Katıl</a>
 <a href="/topluluk" class="kf-btn-outline">Topluluğu İncele</a>
 </div>
 </>
 )}
 </div>

 <div class="kf-quick-links">
 <h3 class="kf-quick-title">Hızlı Bağlantılar</h3>
 <a href="/siralamalar" class="kf-quick-link">— Sıralamalar</a>
 <a href="/arama" class="kf-quick-link">— Gelişmiş Arama</a>
 <a href={isAuthenticated ? '/bildirimler' : '/giris?redirect=/bildirimler'} class="kf-quick-link">— Bildirimler</a>
 <a href={isAuthenticated ? '/mesajlar' : '/giris?redirect=/mesajlar'} class="kf-quick-link">— Mesajlar</a>
 </div>
 </aside>
 </div>
 </div>
 </div>

 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'CollectionPage',
 name: "Şanlıurfa'yı Keşfet",
 url: `${baseUrl}/kesfet`,
 description: "Şanlıurfa'nın popüler mekanlarını, trend içeriklerini ve kişisel önerileri keşfedin.",
 about: { '@type': 'City', name: 'Şanlıurfa', url: `${baseUrl}` },
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'Keşfet', item: `${baseUrl}/kesfet` },
 ],
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqItems.map((item) => ({
 '@type': 'Question',
 name: item.S,
 acceptedAnswer: { '@type': 'Answer', text: item.C },
 })),
 })} is:inline />
</Layout>
