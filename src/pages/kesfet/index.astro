---
import Layout from "../../layouts/Layout.astro";
import TrendingPlaces from "../../components/TrendingPlaces";
import UserRecommendations from "../../components/UserRecommendations";
---

<Layout
  seo={{
    title: "Şanlıurfa Keşfet - Mekânlar, Lezzetler ve Şehir Rotaları",
    description:
      "Şanlıurfa'da trend mekânları, tarihi durakları, gastronomi önerilerini ve şehir servislerini keşfedin.",
    canonicalUrl: "https://sanliurfa.com/kesfet",
  }}
>
  <section
    class="bg-gradient-to-br from-urfa-950 via-urfa-900 to-isot-900 text-white"
  >
    <div class="container-custom py-14">
      <p class="text-sm uppercase tracking-wide text-urfa-200">
        Şanlıurfa keşif merkezi
      </p>
      <h1 class="text-4xl md:text-5xl font-display font-bold mt-3">
        Şanlıurfa'da bugün ne keşfedilir?
      </h1>
      <p class="max-w-3xl text-urfa-100 mt-4 text-lg">
        Tarihi yerler, yöresel lezzetler, popüler mekânlar ve günlük şehir
        servisleri tek ekranda.
      </p>
      <div class="flex flex-wrap gap-3 mt-8">
        <a href="/places" class="btn-accent">Mekânları keşfet</a>
        <a
          href="/sehir-servisleri"
          class="btn bg-white/10 text-white hover:bg-white/20"
          >Şehir servisleri</a
        >
      </div>
    </div>
  </section>

  <div class="container-custom py-10">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2">
        <div class="mb-12">
          <TrendingPlaces client:load />
        </div>
      </div>

      <div class="space-y-6">
        <div
          class="bg-white dark:bg-gray-800 p-6 rounded-lg border border-gray-200 dark:border-gray-700"
        >
          <UserRecommendations client:load />
        </div>

        <div
          class="bg-blue-50 dark:bg-blue-900/20 p-6 rounded-lg border border-blue-200 dark:border-blue-800"
        >
          <h3 class="font-bold text-gray-900 dark:text-white mb-4">
            Hızlı Bağlantılar
          </h3>
          <div class="space-y-2">
            <a
              href="/places"
              class="block text-sm text-blue-600 hover:text-blue-700"
            >
              - Mekânlar
            </a>
            <a
              href="/arama/gelismis"
              class="block text-sm text-blue-600 hover:text-blue-700"
            >
              - Gelişmiş Arama
            </a>
            <a
              href="/gastronomi"
              class="block text-sm text-blue-600 hover:text-blue-700"
            >
              - Gastronomi
            </a>
            <a
              href="/tarihi-yerler"
              class="block text-sm text-blue-600 hover:text-blue-700"
            >
              - Tarihi yerler
            </a>
            <a
              href="/etkinlikler"
              class="block text-sm text-blue-600 hover:text-blue-700"
            >
              - Etkinlikler
            </a>
            <a
              href="/sehir-servisleri"
              class="block text-sm text-blue-600 hover:text-blue-700"
            >
              - Şehir Servisleri
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
