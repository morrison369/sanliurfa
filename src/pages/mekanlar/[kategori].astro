---
import Layout from '../../layouts/Layout.astro';
import { query, queryOne } from '../../lib/postgres';

const { kategori } = Astro.params;
let category: any = null;
let places: any[] = [];
let totalCount = 0;

const page = parseInt(Astro.url.searchParams.get('sayfa') || '1');
const limit = 12;
const offset = (page - 1) * limit;

try {
  category = await queryOne(
    "SELECT * FROM categories WHERE slug = $1 AND is_active = true",
    [kategori]
  );

  if (!category) {
    return Astro.redirect('/mekanlar');
  }

  // Hem bu kategorinin hem de alt kategorilerinin mekanlarını getir
  const countResult = await query(
    `SELECT COUNT(*) FROM places p
     JOIN categories c ON p.category_id = c.id
     WHERE (c.slug = $1 OR c.parent_id = (SELECT id FROM categories WHERE slug = $1))
     AND p.status = 'active'`,
    [kategori]
  );
  totalCount = parseInt(countResult.rows[0]?.count || '0');

  const placesResult = await query(
    `SELECT p.*, c.name as category_name, c.slug as category_slug,
            d.name as district_name
     FROM places p
     JOIN categories c ON p.category_id = c.id
     LEFT JOIN districts d ON p.district_id = d.id
     WHERE (c.slug = $1 OR c.parent_id = (SELECT id FROM categories WHERE slug = $1))
     AND p.status = 'active'
     ORDER BY p.is_featured DESC, p.rating DESC
     LIMIT $2 OFFSET $3`,
    [kategori, limit, offset]
  );
  places = placesResult.rows;
} catch (e) {
  console.error('Error loading category:', e);
}

const totalPages = Math.ceil(totalCount / limit);

const seo = {
  title: category?.meta_title || `${category?.name || kategori} - Şanlıurfa`,
  description: category?.meta_description || category?.description || `Şanlıurfa ${category?.name || ''} mekanları`,
};

const breadcrumbs = [
  { label: 'Ana Sayfa', href: '/' },
  { label: 'Mekanlar', href: '/mekanlar' },
  { label: category?.name || kategori, href: `/mekanlar/${kategori}` },
];
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50">
    <!-- Breadcrumb -->
    <div class="bg-white border-b">
      <div class="container mx-auto px-4 py-3">
        <nav class="flex items-center gap-2 text-sm text-gray-500">
          {breadcrumbs.map((crumb, i) => (
            <>
              {i > 0 && <span>/</span>}
              {i === breadcrumbs.length - 1 ? (
                <span class="text-gray-900 font-medium">{crumb.label}</span>
              ) : (
                <a href={crumb.href} class="hover:text-red-600">{crumb.label}</a>
              )}
            </>
          ))}
        </nav>
      </div>
    </div>

    <!-- Hero -->
    <div class="bg-gradient-to-br from-red-700 to-red-900 text-white py-12">
      <div class="container mx-auto px-4">
        <h1 class="text-3xl md:text-4xl font-bold mb-2">Şanlıurfa {category?.name || kategori}</h1>
        <p class="text-red-100">{totalCount} mekan bulundu</p>
      </div>
    </div>

    <div class="container mx-auto px-4 py-8">
      {places.length > 0 ? (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {places.map((place) => (
            <a href={`/places/${place.slug}`} class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-all group">
              <div class="h-44 bg-gradient-to-br from-red-50 to-orange-50 flex items-center justify-center">
                {place.thumbnail_url ? (
                  <img src={place.thumbnail_url} alt={place.name} class="w-full h-full object-cover" loading="lazy" />
                ) : (
                  <span class="text-5xl opacity-40">🍽️</span>
                )}
              </div>
              <div class="p-5">
                <div class="flex items-start justify-between gap-2">
                  <h2 class="font-bold text-lg text-gray-900 group-hover:text-red-600 transition-colors">{place.name}</h2>
                  {place.is_featured && <span class="px-2 py-0.5 bg-yellow-100 text-yellow-700 text-xs rounded-full font-medium">Öne Çıkan</span>}
                </div>
                <p class="text-sm text-gray-500 mt-2 line-clamp-2">{place.short_description || place.address}</p>
                <div class="flex items-center justify-between mt-4">
                  <div class="flex items-center gap-1">
                    <span class="text-yellow-500">★</span>
                    <span class="font-semibold">{place.rating || '-'}</span>
                    <span class="text-gray-400 text-sm">({place.review_count || 0})</span>
                  </div>
                  {place.price_range && <span class="text-gray-500 text-sm">{place.price_range}</span>}
                </div>
                {place.district_name && (
                  <p class="text-xs text-gray-400 mt-2">📍 {place.district_name}</p>
                )}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <div class="text-6xl mb-4">🔍</div>
          <p class="text-gray-500 text-lg">Bu kategoride henüz mekan bulunmuyor.</p>
          <a href="/mekanlar" class="mt-4 inline-block text-red-600 hover:underline">Tüm Mekanlara Göz At →</a>
        </div>
      )}

      {/* Pagination */}
      {totalPages > 1 && (
        <div class="flex justify-center gap-2 mt-10">
          {page > 1 && <a href={`/mekanlar/${kategori}?sayfa=${page - 1}`} class="px-4 py-2 bg-white border rounded-lg hover:bg-gray-50">← Önceki</a>}
          {Array.from({ length: totalPages }, (_, i) => i + 1).map((p) => (
            <a
              href={`/mekanlar/${kategori}?sayfa=${p}`}
              class={`px-4 py-2 rounded-lg ${p === page ? 'bg-red-600 text-white' : 'bg-white border hover:bg-gray-50'}`}
            >
              {p}
            </a>
          ))}
          {page < totalPages && <a href={`/mekanlar/${kategori}?sayfa=${page + 1}`} class="px-4 py-2 bg-white border rounded-lg hover:bg-gray-50">Sonraki →</a>}
        </div>
      )}
    </div>
  </div>
</Layout>
