---

import Layout from '../../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import PublicCollectionHero from '../../components/public/PublicCollectionHero.astro';
import PublicCollectionBody from '../../components/public/PublicCollectionBody.astro';
import PublicSidebarCard from '../../components/public/PublicSidebarCard.astro';
import PublicFaqList from '../../components/public/PublicFaqList.astro';
import PlaceCard from '../../components/PlaceCard.astro';
import { query, queryOne } from '../../lib/postgres';
import { getCachedPublicRouteData } from '../../lib/public-route-cache';
import { getMediaAsset, getSeoOverride } from '../../lib/site-platform';
import { getPublicAppUrl } from '../../lib/public-app-url';
import { logger } from '../../lib/logging';
import { safeIntParam } from '../../lib/api';
import { resolvePlaceImage } from '../../lib/public-image-resolvers';
const baseUrl = getPublicAppUrl();

const { kategori } = Astro.params;
const page = safeIntParam(Astro.url.searchParams.get('sayfa'), 1, 1, 1_000_000);
const limit = 12;
const offset = (page - 1) * limit;

let category: any = null;
let places: any[] = [];
let districtBreakdown: any[] = [];
let relatedCategories: any[] = [];
let relatedBlogPosts: any[] = [];
let totalCount = 0;
let heroImage = '/images/places/balikligol.jpg';
let seoOverridePayload: Record<string, any> | null = null;
let seoOverrideCanonical = '';

try {
 const data = await getCachedPublicRouteData(`page:mekanlar:category:${kategori || 'unknown'}:${page}`, async () => {
  const categoryRow = await queryOne(
   `SELECT id, name, slug, description, parent_id
   FROM categories
   WHERE slug = $1 AND is_active = true
   LIMIT 1`,
   [kategori],
  );

  if (!categoryRow) {
   return {
    category: null,
    places: [],
    districtBreakdown: [],
    relatedCategories: [],
    totalCount: 0,
   };
  }

  const matchSql = `(p.category_id = $1 OR p.category_id IN (SELECT id FROM categories WHERE parent_id = $1))`;

  const relatedSql = categoryRow.parent_id != null
   ? `SELECT c.name, c.slug,
        (SELECT COUNT(*) FROM places pp WHERE pp.category_id = c.id AND pp.status='active') AS p_count
      FROM categories c
      WHERE c.parent_id = $2::int AND c.id <> $1::int AND c.is_active = true
      ORDER BY c.sort_order NULLS LAST, c.name ASC LIMIT 8`
   : `SELECT c.name, c.slug,
        (SELECT COUNT(*) FROM places pp WHERE pp.category_id = c.id AND pp.status='active') AS p_count
      FROM categories c
      WHERE c.parent_id = $1::int AND c.is_active = true
      ORDER BY c.sort_order NULLS LAST, c.name ASC LIMIT 8`;
  const relatedParams = categoryRow.parent_id != null
   ? [categoryRow.id, categoryRow.parent_id]
   : [categoryRow.id];

  const blogKeywords = [categoryRow.slug, categoryRow.name?.split(' ')[0]?.toLowerCase()].filter(Boolean);
  const blogTagCondition = blogKeywords.map((_: string, i: number) => `tags && ARRAY[$${i + 1}]::text[]`).join(' OR ');

  const [countResult, placesResult, districtResult, relatedResult, blogResult] = await Promise.all([
   query(
    `SELECT COUNT(*)::int AS count FROM places p
    WHERE p.status = 'active' AND ${matchSql}`,
    [categoryRow.id],
   ),
   query(
    `SELECT
     p.*,
     d.name AS district_name,
     d.slug AS district_slug,
     c.name AS subcategory_name,
     c.slug AS subcategory_slug
    FROM places p
    LEFT JOIN districts d ON d.id = p.district_id
    LEFT JOIN categories c ON c.id = p.category_id
    WHERE p.status = 'active' AND ${matchSql}
    ORDER BY COALESCE(p.is_featured, false) DESC, COALESCE(p.rating, 0) DESC, COALESCE(p.review_count, 0) DESC, p.created_at DESC
    LIMIT $2 OFFSET $3`,
    [categoryRow.id, limit, offset],
   ),
   query(
    `SELECT d.name, d.slug, COUNT(*)::int AS place_count
    FROM places p
    JOIN districts d ON d.id = p.district_id
    WHERE p.status = 'active' AND ${matchSql}
    GROUP BY d.id, d.name, d.slug
    ORDER BY COUNT(*) DESC, d.name ASC
    LIMIT 6`,
    [categoryRow.id],
   ),
   query(relatedSql, relatedParams),
   blogKeywords.length > 0
    ? query(
       `SELECT title, slug FROM blog_posts
       WHERE status = 'published' AND published_at <= CURRENT_DATE + INTERVAL '60 days' AND (${blogTagCondition} OR category_slug = $${blogKeywords.length + 1})
       ORDER BY published_at ASC LIMIT 4`,
       [...blogKeywords, categoryRow.slug],
      ).catch(() => ({ rows: [] }))
    : Promise.resolve({ rows: [] }),
  ]);

  return {
   category: categoryRow,
   places: placesResult.rows,
   districtBreakdown: districtResult.rows,
   relatedCategories: relatedResult.rows,
   relatedBlogPosts: blogResult.rows,
   totalCount: Number(countResult.rows[0]?.count || 0),
  };
 });

 category = data.category;
 if (!category) {
  return Astro.redirect('/mekanlar');
 }
 places = data.places;
 districtBreakdown = data.districtBreakdown;
 relatedCategories = data.relatedCategories;
 relatedBlogPosts = data.relatedBlogPosts ?? [];
 totalCount = data.totalCount;
} catch (error) {
 logger.error('Error loading mekan category page:', error instanceof Error ? error : new Error(String(error)));
}

try {
 const [heroAsset, seoOverride] = await Promise.all([
  getMediaAsset(`category.${String(kategori || '').trim()}.hero`),
  getSeoOverride('category', String(kategori || '').trim()),
 ]);
 heroImage = String(heroAsset?.url || heroImage);
 seoOverridePayload = seoOverride?.seo_payload || null;
 seoOverrideCanonical = String(seoOverride?.canonical_path || '').trim();
} catch (error) {
 logger.error('Error loading kategori platform data:', error instanceof Error ? error : new Error(String(error)));
}

const totalPages = Math.max(1, Math.ceil(totalCount / limit));
const categoryName = String(category?.name || kategori || 'Mekanlar');
const description =
 String(category?.description || '').trim() ||
 `${categoryName} kategorisindeki aktif Şanlıurfa mekanları puan, yorum ve ilçe yoğunluğu ile keşfedilebilir.`;

const seo = {
 title: `Şanlıurfa ${categoryName} | En İyi Mekanlar, Puanlar ve Yorumlar`,
 description: `Şanlıurfa ${categoryName.toLowerCase()} rehberi. ${description}`,
 canonical: `/mekanlar/${kategori}`,
 keywords: ['şanlıurfa ' + categoryName.toLowerCase(), 'urfa ' + categoryName.toLowerCase(), categoryName, categoryName + ' şanlıurfa', 'şanlıurfa mekanlar'],
 ogImage: '/images/places/balikligol.jpg',
 noIndex: totalCount === 0,
};

if (seoOverridePayload) {
 Object.assign(seo, seoOverridePayload, {
  canonical: seoOverrideCanonical || seoOverridePayload.canonical || seo.canonical,
 });
}

const faqItems = [
 {
  q: `Şanlıurfa ${categoryName.toLowerCase()} listesi güncel mi?`,
  a: `${categoryName} sayfası aktif mekan kayıtları üzerinden günlük güncellenir; öne çıkan işletmeler puan, yorum ve görünürlük sinyallerine göre sıralanır. Yeni eklenen mekanlar onay sürecinden geçtikten sonra listede yer alır, kapalı ya da taşınan işletmeler ise pasife alınarak görünümden kaldırılır.`,
 },
 {
  q: `${categoryName} mekanları ilçeye göre filtrelenebilir mi?`,
  a: `Evet, sayfadaki ilçe yoğunluğu kartları üzerinden istediğiniz ilçe rehberine geçebilir, ${categoryName.toLowerCase()} ile birlikte ilçe bazlı filtreyi kullanabilirsiniz. Eyyübiye, Haliliye, Karaköprü, Harran, Halfeti ve diğer ilçelerdeki mekanları ayrı ayrı incelemek mümkündür.`,
 },
 {
  q: `${categoryName} sayfasında hangi veriler gösterilir?`,
  a: `Her mekan kartında; mekan adı, kısa açıklama, puan (5 üzerinden), yorum sayısı, ilçe bilgisi ve kapak fotoğrafı yer alır. Mekan detay sayfasında ek olarak adres, telefon numarası, çalışma saatleri ve kullanıcı yorumlarına da ulaşabilirsiniz.`,
 },
 {
  q: `Şanlıurfa ${categoryName.toLowerCase()} için hangi ilçeler öne çıkıyor?`,
  a: `Şanlıurfa'da ${categoryName.toLowerCase()} alanında en fazla mekan genellikle Eyyübiye, Haliliye ve Karaköprü ilçelerinde yoğunlaşmaktadır. Siverek, Halfeti ve Harran gibi daha uzak ilçelerde de bölgeye özgü mekanlar bulunmaktadır; ilçe yoğunluğu tablosundan bu dağılımı anlık görebilirsiniz.`,
 },
];
const toAbsoluteImageUrl = (src: string) => (src.startsWith('http') ? src : `${baseUrl}${src}`);
---

<Layout seo={seo}>
 <style is:inline>
  .mc-page{background:var(--bg);min-height:100vh}
  .mc-places-grid{display:grid;gap:1rem;grid-template-columns:repeat(auto-fit,minmax(250px,1fr))}

  /* Empty state */
  .mc-empty{background:#fff;border:1px dashed rgba(192,87,31,.25);padding:3.5rem 2rem;text-align:center;border-radius:8px}
  .mc-empty-title{font-family:'Cormorant Garamond',serif;font-size:1.5rem;color:#1F1410;margin:0 0 .65rem;font-weight:700}
  .mc-empty-text{font-size:.88rem;color:var(--public-muted);margin:0 0 1.5rem;line-height:1.65;max-width:480px;margin-left:auto;margin-right:auto}
  .mc-empty-btn{display:inline-flex;align-items:center;gap:.4rem;padding:.75rem 1.65rem;background:linear-gradient(135deg,#C0571F,#D49718);color:#fff;font-size:.9rem;font-weight:700;text-decoration:none;border-radius:6px;transition:transform .15s}
  .mc-empty-btn:hover{transform:translateY(-1px)}

  /* Pagination */
  .mc-pagination{display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:.4rem;margin-top:2rem}
  .mc-page-btn{display:inline-flex;align-items:center;justify-content:center;min-width:2.4rem;padding:.55rem .9rem;background:#fff;border:1px solid rgba(192,87,31,.18);color:var(--public-muted);font-size:.85rem;font-weight:600;text-decoration:none;border-radius:6px;transition:all .15s}
  .mc-page-btn:hover{border-color:#C0571F;color:#C0571F}
  .mc-page-btn-active{background:linear-gradient(135deg,#C0571F,#D49718);border-color:#C0571F;color:#fff}

  .mc-district-link{display:flex;align-items:center;justify-content:space-between;padding:.55rem .75rem;font-size:.85rem;font-weight:600;color:#1F1410;text-decoration:none;border-radius:5px;transition:all .15s;margin-bottom:.3rem}
  .mc-district-link:hover{background:rgba(44,122,82,.08);color:#1F5F40}
  .mc-district-count{display:inline-flex;align-items:center;justify-content:center;min-width:1.6rem;padding:.1rem .45rem;background:rgba(192,87,31,.10);color:#C0571F;font-size:.72rem;font-weight:700;border-radius:999px}

  .mc-blog-links{display:flex;flex-direction:column;gap:.2rem}
  .mc-blog-link{font-size:.82rem;color:#1F1410;text-decoration:none;padding:.45rem .5rem;border-radius:4px;line-height:1.35;transition:background .12s}
  .mc-blog-link:hover{background:rgba(192,87,31,.07);color:#C0571F}
  .mc-tag-wrap{display:flex;flex-wrap:wrap;gap:.4rem}
  .mc-tag{display:inline-flex;align-items:center;gap:.25rem;padding:.4rem .75rem;background:rgba(192,87,31,.06);border:1px solid rgba(192,87,31,.15);color:#1F1410;font-size:.78rem;font-weight:600;text-decoration:none;border-radius:999px;transition:all .15s}
  .mc-tag:hover{background:#C0571F;color:#fff;border-color:#C0571F}
  .mc-tag-count{font-size:.65rem;color:#7A6448;font-weight:600}
  .mc-tag:hover .mc-tag-count{color:rgba(255,255,255,.8)}
 </style>

 <div class="mc-page">
  <PublicCollectionHero
   title={`Şanlıurfa ${categoryName}`}
   description={description}
   imageSrc={heroImage}
   imageAlt={`Şanlıurfa ${categoryName}`}
   eyebrow="Şanlıurfa Kategori Rehberi"
   breadcrumbItems={[
    { href: '/', label: 'Ana Sayfa' },
    { href: '/mekanlar', label: 'Mekanlar' },
    { label: categoryName },
   ]}
   stats={[
    { label: 'Aktif Mekan', value: totalCount },
    { label: 'İlçe Sayısı', value: districtBreakdown.length },
   ]}
  />

  <PublicCollectionBody compactSidebar>
    <section>
     {places.length > 0 ? (
      <div class="mc-places-grid">
       {places.map((place) => (
        <PlaceCard
         place={{
          id: String(place.id),
          name: place.name,
          slug: place.slug,
          description:
           place.short_description || place.description || `${categoryName} kategorisinde aktif mekan.`,
          image_url: resolvePlaceImage(place),
          category: place.subcategory_slug || place.category_slug || 'general',
          rating: place.rating,
          review_count: place.review_count,
         }}
        />
       ))}
      </div>
     ) : (
      <div class="mc-empty">
       <p class="mc-empty-title">Henüz aktif mekan yok</p>
       <p class="mc-empty-text">
        Bu kategori için işletme başvuruları açık. Sanliurfa.com'da ücretsiz işletme profili oluşturarak ilk olun.
       </p>
       <a href="/isletme-kayit" class="mc-empty-btn">
        <Icon name="lucide:plus-circle" style="width:1.05rem;height:1.05rem" />
        İşletme Kaydı Başlat
       </a>
      </div>
     )}

     {totalPages > 1 && (
      <nav class="mc-pagination" aria-label="Sayfalama">
       {page > 1 && (
        <a href={`/mekanlar/${kategori}?sayfa=${page - 1}`} class="mc-page-btn">← Önceki</a>
       )}
       {Array.from({ length: Math.min(totalPages, 8) }, (_, i) => i + 1).map((item) => (
        <a
         href={`/mekanlar/${kategori}?sayfa=${item}`}
         class={`mc-page-btn ${item === page ? 'mc-page-btn-active' : ''}`}
        >
         {item}
        </a>
       ))}
       {page < totalPages && (
        <a href={`/mekanlar/${kategori}?sayfa=${page + 1}`} class="mc-page-btn">Sonraki →</a>
       )}
      </nav>
     )}
    </section>

    <Fragment slot="sidebar">
     {districtBreakdown.length > 0 && (
      <PublicSidebarCard title="İlçe Yoğunluğu">
       {districtBreakdown.map((item) => (
        <a href={`/ilceler/${item.slug}`} class="mc-district-link">
         <span>{item.name}</span>
         <span class="mc-district-count">{Number(item.place_count || 0)}</span>
        </a>
       ))}
      </PublicSidebarCard>
     )}

     {relatedCategories.length > 0 && (
      <PublicSidebarCard title={category?.parent_id ? 'Yakın Kategoriler' : 'Alt Kategoriler'}>
       <div class="mc-tag-wrap">
        {relatedCategories.map((item) => (
         <a href={`/mekanlar/${item.slug}`} class="mc-tag">
          {item.name}
          {item.p_count > 0 && <span class="mc-tag-count">({item.p_count})</span>}
         </a>
        ))}
       </div>
      </PublicSidebarCard>
     )}

     {relatedBlogPosts.length > 0 && (
      <PublicSidebarCard title="İlgili Rehber Yazılar">
       <div class="mc-blog-links">
        {relatedBlogPosts.map((post: any) => (
         <a href={`/blog/${post.slug}`} class="mc-blog-link">{post.title}</a>
        ))}
       </div>
      </PublicSidebarCard>
     )}

     <PublicSidebarCard title="Hızlı Cevaplar">
      <PublicFaqList items={faqItems} />
     </PublicSidebarCard>
    </Fragment>
  </PublicCollectionBody>
 </div>

 <script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `Şanlıurfa ${categoryName}`,
  description,
  url: `${baseUrl}/mekanlar/${kategori}`,
  about: { '@type': 'City', name: 'Şanlıurfa' },
  numberOfItems: totalCount,
  itemListElement: places.slice(0, 10).map((p: any, i: number) => ({
   '@type': 'ListItem',
   position: i + 1,
   item: {
    '@type': 'LocalBusiness',
    '@id': `${baseUrl}/isletme/${p.slug}`,
    name: p.name,
    url: `${baseUrl}/isletme/${p.slug}`,
    ...(p.address ? { address: p.address } : {}),
    ...(resolvePlaceImage(p) ? { image: toAbsoluteImageUrl(resolvePlaceImage(p)) } : {}),
    ...(p.rating ? { aggregateRating: { '@type': 'AggregateRating', ratingValue: Number(p.rating), reviewCount: p.review_count || 1, bestRating: 5 } } : {}),
   },
  })),
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
   '@type': 'Question',
   name: item.q,
   acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
   { '@type': 'ListItem', position: 1, name: 'Ana Sayfa', item: `${baseUrl}/` },
   { '@type': 'ListItem', position: 2, name: 'Mekanlar', item: `${baseUrl}/mekanlar` },
   { '@type': 'ListItem', position: 3, name: categoryName, item: `${baseUrl}/mekanlar/${kategori}` },
  ],
 })} is:inline />
</Layout>
