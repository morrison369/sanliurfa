---
import Layout from '../../layouts/Layout.astro';
import { query } from '../../lib/postgres';

let categories: any[] = [];
let featuredPlaces: any[] = [];

try {
  const catResult = await query(
    "SELECT c.*, (SELECT COUNT(*) FROM places p WHERE p.category_id = c.id AND p.status = 'active') as place_count FROM categories c WHERE c.parent_id = 10 AND c.is_active = true ORDER BY c.sort_order"
  );
  categories = catResult.rows;

  const featResult = await query(
    "SELECT * FROM places WHERE is_featured = true AND status = 'active' ORDER BY rating DESC LIMIT 6"
  );
  featuredPlaces = featResult.rows;
} catch (e) {
  console.error('Error loading mekanlar:', e);
}

const seo = {
  title: 'Şanlıurfa Mekanlar Rehberi | En İyi Mekanlar ve Yerel Lezzetler',
  description: 'Şanlıurfa\'nın en popüler mekanları. Kebapçılar, ciğerciler, kafeler, tatlıcılar ve daha fazlası. Güncel fiyatlar ve yorumlarla.',
};
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50">
    <!-- Hero -->
    <div class="bg-gradient-to-br from-red-700 to-red-900 text-white py-16">
      <div class="container mx-auto px-4">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Şanlıurfa Mekanlar</h1>
        <p class="text-xl text-red-100 max-w-2xl">
          Kebapçılardan ciğercilere, kafelerden tatlıcılara Şanlıurfa'nın en sevilen mekanları
        </p>
      </div>
    </div>

    <div class="container mx-auto px-4 py-12">
      <!-- Kategoriler Grid -->
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Kategoriler</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 mb-12">
        {categories.map((cat) => (
          <a
            href={`/mekanlar/${cat.slug}/`}
            class="bg-white rounded-xl p-6 shadow-sm hover:shadow-lg transition-all hover:-translate-y-1 border border-gray-100 group"
          >
            <div class="text-3xl mb-3">{
              cat.slug === 'kebapcilar' ? '🍖' :
              cat.slug === 'cigerciler' ? '🥩' :
              cat.slug === 'lahmacuncular' ? '🫓' :
              cat.slug === 'cig-kofteciler' ? '🧆' :
              cat.slug === 'kahvalti-mekanlari' ? '🍳' :
              cat.slug === 'tatlicilar' ? '🍮' :
              cat.slug === 'kafeler' ? '☕' :
              cat.slug === 'cay-bahceleri' ? '🍵' :
              cat.slug === 'firinlar' ? '🍞' :
              cat.slug === 'pastaneler' ? '🎂' :
              cat.slug === 'balik-restoranlari' ? '🐟' : '🍽️'
            }</div>
            <h3 class="font-bold text-gray-900 group-hover:text-red-600 transition-colors">{cat.name}</h3>
            <p class="text-sm text-gray-500 mt-1">{cat.place_count || 0} mekan</p>
          </a>
        ))}
      </div>

      {/* Öne Çıkan Mekanlar */}
      {featuredPlaces.length > 0 && (
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Öne Çıkan Mekanlar</h2>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {featuredPlaces.map((place) => (
              <a href={`/places/${place.slug}`} class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow group">
                <div class="h-48 bg-gradient-to-br from-red-100 to-orange-100 flex items-center justify-center text-5xl">
                  🍽️
                </div>
                <div class="p-5">
                  <h3 class="font-bold text-lg text-gray-900 group-hover:text-red-600">{place.name}</h3>
                  <p class="text-sm text-gray-500 mt-1 line-clamp-2">{place.short_description || place.description}</p>
                  <div class="flex items-center gap-2 mt-3">
                    <span class="text-yellow-500">★</span>
                    <span class="font-medium">{place.rating || '-'}</span>
                    <span class="text-gray-400">({place.review_count || 0} yorum)</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
</Layout>
