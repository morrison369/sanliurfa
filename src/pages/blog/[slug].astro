---
import { Icon } from 'astro-icon/components';
import Layout from '../../layouts/Layout.astro';
import { queryOne } from '../../lib/postgres';
import { resolveContentImage } from '../../lib/content-images';
import { getSiteBranding } from '../../lib/site-branding';
import RelatedPosts from '../../components/blog/RelatedPosts.astro';
import { logger } from '../../lib/logging';
const { baseUrl } = await getSiteBranding();

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/blog');

let post: any = null;

try {
  // Try DB first
  post = await queryOne(
    "SELECT * FROM blog_posts WHERE slug = $1 AND status = 'published'",
    [slug]
  );

  if (post) {
    // Content may contain HTML already
    post.content_html = post.content;
    post.reading_time = Math.ceil((post.content || '').split(/\s+/).length / 200);
    // Related posts query moved to <RelatedPosts server:defer> below.
  }
} catch (e) {
  logger.error('Error loading blog post from DB', e instanceof Error ? e : new Error(String(e)));
}

// Fallback: try Astro content collection
if (!post) {
  try {
    const { getPostBySlug: getFromCollection } = await import('../../lib/blog');
    const collectionPost = await getFromCollection(slug);
    if (collectionPost) {
      post = {
        ...collectionPost,
        content_html: null,
        author_name: collectionPost.author,
        published_at: collectionPost.publishedAt,
        reading_time: collectionPost.readingTime,
        featured_image: collectionPost.image,
      };
    }
  } catch { /* content collection not available in SSR */ }
}

const fallbackPosts: Record<string, any> = {
  'sanliurfa-hafta-sonu-rehberi': {
    slug: 'sanliurfa-hafta-sonu-rehberi',
    title: 'Şanlıurfa Hafta Sonu Rehberi: 2 Günde Neler Yapılır?',
    excerpt:
      "Şanlıurfa'da 2 günlük gezi planı. Cumartesi ve pazar günü yapılacaklar, gezilecek yerler ve yeme içme önerileri.",
    content: `## 1. Gün: Tarih ve Kültür
Sabah erken saatlerde Göbeklitepe ile başlayın. Ziyaret için 2-3 saat ayırmak, hem müze alanını hem de ana kazı bölgesini rahat gezmek için yeterlidir.

Öğle saatlerinde şehir merkezine dönüp ciğer kebabı, lahmacun veya patlıcan kebabı tercih edebilirsiniz. Kalabalık saatlere kalmamak için öğle planını erken yapmak daha kullanışlı olur.

Öğleden sonra Balıklıgöl, Dergah bölgesi, Rızvaniye Camii ve çevredeki tarihi sokaklar için idealdir. Bu rota yürüyerek gezilebilir ve fotoğraf için en güçlü şehir dokusunu verir.

Akşam Gümrük Hanı çevresinde mırra içebilir, Kapalı Çarşı ve Bakırcılar Çarşısı tarafında yerel ürünlere bakabilirsiniz.

## 2. Gün: Doğa, Lezzet ve Sıra Gecesi
İkinci gün için Harran kümbet evleri, geleneksel mimari ve ovayı kapsayan yarım günlük bir rota planlanabilir.

Öğle yemeğinde Şanlıurfa mutfağından lahmacun, bostana, kebap çeşitleri veya yöresel ev yemekleri seçilebilir.

Öğleden sonra Halfeti tekne turu için ayrılabilir. Batık şehir, Rumkale çevresi ve Fırat manzarası hafta sonu rotasına farklı bir tempo katar.

Akşam programında sıra gecesi tercih edilecekse rezervasyon, ulaşım ve dönüş saatleri önceden netleştirilmelidir.

## Pratik Planlama Notları
- Göbeklitepe ve Harran gibi merkez dışı rotalarda ulaşımı önceden planlayın.
- Yaz aylarında öğle saatlerini kapalı alan, müze veya yemek molası için kullanın.
- Balıklıgöl ve çarşı rotasını aynı gün içinde yürüyerek gezebilirsiniz.
- Halfeti için tekne saatlerini gitmeden önce kontrol edin.
- Şanlıurfa gezisinde rahat ayakkabı ve mevsime uygun kıyafet önemlidir.`,
    content_html: null,
    author_name: 'Şanlıurfa Rehberi',
    published_at: '2026-04-11T00:00:00.000Z',
    reading_time: 3,
    featured_image: '/images/blog/tarihi-yerler-rehberi.jpg',
    category: 'Gezi',
    tags: [
      { name: 'Şanlıurfa Gezi', slug: 'sanliurfa-gezi' },
      { name: 'Hafta Sonu', slug: 'hafta-sonu' },
    ],
  },
};

if (!post && slug && fallbackPosts[slug]) {
  post = fallbackPosts[slug];
}

if (!post) return Astro.redirect('/blog');

const title = post.title;
const description = post.excerpt || post.meta_description || '';
const getBlogImage = (entry: any, thumb = false) =>
  resolveContentImage({
    category: 'blog',
    slug: entry?.slug,
    explicit: entry?.featured_image || entry?.cover_image || entry?.image,
    placeholder: '/images/placeholder-blog.jpg',
    thumb,
  });
const faqItems = [
  { S: `${post.title} hakkında ne bilinmeli?`, C: post.excerpt || `${post.title} için detaylı bilgiyi yazımızda bulabilirsiniz.` },
  { S: `Bu yazı hangi kategoride?`, C: `Bu yazı ${post.category || 'Genel'} kategorisinde yayınlanmıştır.` },
  { S: `Şanlıurfa hakkında daha fazla yazı nerede bulunur?`, C: 'Şanlıurfa rehberiyle ilgili tüm yazılarımıza /blog sayfasından ulaşabilirsiniz.' },
];

---

<Layout seo={{
  title,
  description,
  ogImage: getBlogImage(post),
  type: 'article',
  publishedTime: post.created_at || post.published_at,
  modifiedTime: post.updated_at,
  keywords: post.tags?.length ? post.tags : ['Şanlıurfa', 'şehir rehberi', post.category || 'blog'],
  author: post.author_name || 'Sanliurfa.com',
  canonical: `/blog/${post.slug}`,
}}>
  <article class="min-h-screen bg-white">
    <!-- Hero -->
    <div class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)] text-white">
      <div class="container mx-auto px-4 py-16">
        <div class="max-w-3xl mx-auto text-center">
          <a href={`/blog?category=${post.category}`} class="inline-block px-3 py-1 bg-white/10 border border-white/20 rounded-sm text-sm mb-4 hover:bg-white/20 transition-colors text-[#F5EDD6]">
            {post.category}
          </a>
          <h1 class="text-3xl md:text-5xl font-bold mb-6 text-[#F5EDD6]">{post.title}</h1>
          <div class="flex items-center justify-center gap-6 text-[#9A8470] flex-wrap">
            <span class="flex items-center gap-2">
              <Icon name="lucide:user" class="w-5 h-5" />
              {post.author_name}
            </span>
            <span class="flex items-center gap-2">
              <Icon name="lucide:calendar" class="w-5 h-5" />
              {new Date(post.published_at!).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' })}
            </span>
            <span class="flex items-center gap-2">
              <Icon name="lucide:clock" class="w-5 h-5" />
              {post.reading_time} dk okuma
            </span>
          </div>
        </div>
      </div>
    </div>

    {/* Featured Image */}
    <div class="container mx-auto px-4 -mt-8">
      <div class="max-w-4xl mx-auto">
        <img
          src={getBlogImage(post)}
          alt={post.title}
          class="w-full h-64 md:h-96 object-cover rounded-sm shadow-md"
          onerror="this.setAttribute('src','/images/placeholder-blog.jpg')"
        />
      </div>
    </div>

    {/* Content */}
    <div class="container mx-auto px-4 py-12">
      <div class="max-w-3xl mx-auto">
        {/* Excerpt */}
        <p class="text-xl text-[#9A8470] italic border-l-4 border-urfa-400 pl-6 mb-8">
          {post.excerpt}
        </p>

        {/* Main Content */}
        <div class="prose prose-lg max-w-none">
          {post.content_html ? (
            <Fragment set:html={post.content_html} />
          ) : (
            <div class="markdown-content">
              {post.content.split('\n').map((line: string) => {
                if (line.startsWith('# ')) {
                  return <h1 class="text-3xl font-bold mt-8 mb-4 text-[#1A1008]">{line.slice(2)}</h1>;
                } else if (line.startsWith('## ')) {
                  return <h2 class="text-2xl font-bold mt-8 mb-4 text-[#1A1008]">{line.slice(3)}</h2>;
                } else if (line.startsWith('### ')) {
                  return <h3 class="text-xl font-bold mt-6 mb-3 text-[#1A1008]">{line.slice(4)}</h3>;
                } else if (line.startsWith('- ')) {
                  return <li class="ml-4 text-[#4A3828]">{line.slice(2)}</li>;
                } else if (line.startsWith('![')) {
                  const match = line.match(/!\[(.*?)\]\((.*?)\)/);
                  if (match) {
                    return <img src={match[2]} alt={match[1]} class="w-full rounded-sm my-6" />;
                  }
                } else if (line.trim()) {
                  return <p class="mb-4 leading-relaxed text-[#4A3828]">{line}</p>;
                }
                return null;
              })}
            </div>
          )}
        </div>

        {/* Tags */}
        {post.tags && post.tags.length > 0 && (
          <div class="mt-12 pt-8 border-t border-[rgba(200,160,100,0.2)]">
            <h4 class="font-bold text-[#1A1008] mb-3">Etiketler</h4>
            <div class="flex flex-wrap gap-2">
              {post.tags.map((tag: any) => (
                <a
                  href={`/blog/etiket/${tag.slug}`}
                  class="px-3 py-1 bg-[rgba(200,160,100,0.06)] border border-[rgba(200,160,100,0.15)] text-[#6B5540] rounded-sm text-sm hover:bg-[rgba(200,160,100,0.12)] hover:text-urfa-700 transition-colors"
                >
                  {tag.name}
                </a>
              ))}
            </div>
          </div>
        )}

        {/* Share */}
        <div class="mt-8 flex items-center gap-4">
          <span class="font-medium text-[#4A3828]">Paylaş:</span>
          <div class="flex gap-2">
            <button onclick="sharePage()" class="h-10 px-4 bg-urfa-600 text-white rounded-sm flex items-center justify-center hover:bg-urfa-700 transition-colors text-sm">
              Paylaş
            </button>
            <button onclick="copyLink()" class="h-10 px-4 border border-[rgba(200,160,100,0.2)] text-[#4A3828] rounded-sm flex items-center justify-center hover:border-urfa-300 transition-colors text-sm">
              Linki Kopyala
            </button>
          </div>
        </div>
      </div>
    </div>

    {/* Related Posts — Server Island, ana içeriği bloklamaz */}
    <RelatedPosts category={post.category} excludeSlug={post.slug} server:defer>
      <div slot="fallback" class="bg-[#FDFAF3] border-t border-[rgba(200,160,100,0.1)] py-12">
        <div class="container mx-auto px-4">
          <div class="h-8 bg-[rgba(200,160,100,0.1)] rounded-sm w-40 mb-6 animate-pulse"></div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="h-56 bg-[rgba(200,160,100,0.06)] rounded-sm animate-pulse"></div>
            <div class="h-56 bg-[rgba(200,160,100,0.06)] rounded-sm animate-pulse"></div>
            <div class="h-56 bg-[rgba(200,160,100,0.06)] rounded-sm animate-pulse"></div>
          </div>
        </div>
      </div>
    </RelatedPosts>
  </article>

  <script define:vars={{ slug: post.slug, title: post.title }} is:inline>
    const url = window.location.href;

    async function copyLink() {
      try {
        await navigator.clipboard.writeText(url);
        window.toast?.success('Link kopyalandı');
      } catch {
        window.toast?.error('Link kopyalanamadı');
      }
    }

    async function sharePage() {
      if (navigator.share) {
        try {
          await navigator.share({ title, url });
          return;
        } catch {
          // fall back to copy
        }
      }
      await copyLink();
    }
  </script>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: `${baseUrl}/blog` },
      { '@type': 'ListItem', position: 3, name: post.title, item: `${baseUrl}/blog/${post.slug}` },
    ],
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: post.title,
    description: post.excerpt || description,
    inLanguage: 'tr',
    url: `${baseUrl}/blog/${post.slug}`,
    image: (() => { const img = getBlogImage(post); return img.startsWith('http') ? img : `${baseUrl}${img}`; })(),
    datePublished: post.published_at || post.created_at,
    dateModified: post.updated_at || post.published_at || post.created_at,
    author: {
      '@type': 'Person',
      name: post.author_name || 'Sanliurfa.com',
    },
    '@id': `${baseUrl}/blog/${post.slug}`,
    publisher: {
      '@type': 'Organization',
      name: 'Sanliurfa.com',
      url: baseUrl,
      logo: { '@type': 'ImageObject', url: `${baseUrl}/favicon.svg`, width: 200, height: 200 },
    },
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': `${baseUrl}/blog/${post.slug}`,
    },
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: { '@type': 'Answer', text: item.C },
    })),
  })} is:inline />
</Layout>
