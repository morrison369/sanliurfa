---
import EditorialTemplate from '../../components/templates/EditorialTemplate.astro';
import Image from '../../components/Image.astro';
import PublicDetailHero from '../../components/public/PublicDetailHero.astro';
import PublicDetailBody from '../../components/public/PublicDetailBody.astro';
import PublicStickyCTA from '../../components/public/PublicStickyCTA.astro';
import { linkifyContent } from '../../lib/seo/internal-linker';
import PublicSidebarCard from '../../components/public/PublicSidebarCard.astro';
import PublicFaqList from '../../components/public/PublicFaqList.astro';
import PublicContentSection from '../../components/public/PublicContentSection.astro';
import PublicRichProse from '../../components/public/PublicRichProse.astro';
import { queryOne } from '../../lib/postgres';
import RelatedPosts from '../../components/blog/RelatedPosts.astro';
import BlogRelatedEvents from '../../components/blog/BlogRelatedEvents.astro';
import BlogRelatedPlaces from '../../components/blog/BlogRelatedPlaces.astro';
import BlogComments from '../../components/blog/BlogComments';
import { logger } from '../../lib/logging';
import { buildPageSeo } from '../../lib/seo/pageSeo';
import { getPublicAppUrl } from '../../lib/public-app-url';
import { resolveBlogImage } from '../../lib/public-image-resolvers';
import { getCachedPublicRouteData } from '../../lib/public-route-cache';
const baseUrl = getPublicAppUrl();

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/blog');

let post: any = null;

try {
 post = await getCachedPublicRouteData(`page:blog:detail:${slug}`, async () =>
  queryOne(
  "SELECT * FROM blog_posts WHERE slug = $1 AND status = 'published'",
  [slug]
  ),
 );

 if (post) {
 post.content_html = post.content;
 post.reading_time = Math.ceil((post.content || '').split(/\s+/).length / 200);
 }
} catch (e) {
 logger.error('Error loading blog post from DB', e instanceof Error ? e : new Error(String(e)));
}

if (!post) {
 try {
 const { getPostBySlug: getFromCollection } = await import('../../lib/blog');
 const collectionPost = await getFromCollection(slug);
 if (collectionPost) {
 post = {
 ...collectionPost,
 content_html: null,
 author_name: collectionPost.author,
 published_at: collectionPost.publishedAt,
 reading_time: collectionPost.readingTime,
 featured_image: collectionPost.image,
 };
 }
 } catch { /* content collection not available in SSR */ }
}

const fallbackPosts: Record<string, any> = {
 'sanliurfa-hafta-sonu-rehberi': {
 slug: 'sanliurfa-hafta-sonu-rehberi',
 title: 'Şanlıurfa Hafta Sonu Rehberi: 2 Günde Neler Yapılır?',
 excerpt:
 "Şanlıurfa'da 2 günlük gezi planı. Cumartesi ve pazar günü yapılacaklar, gezilecek yerler ve yeme içme önerileri.",
 content: `## 1. Gün: Tarih ve Kültür
Sabah erken saatlerde Göbeklitepe ile başlayın. Ziyaret için 2-3 saat ayırmak, hem müze alanını hem de ana kazı bölgesini rahat gezmek için yeterlidir.

Öğle saatlerinde şehir merkezine dönüp ciğer kebabı, lahmacun veya patlıcan kebabı tercih edebilirsiniz. Kalabalık saatlere kalmamak için öğle planını erken yapmak daha kullanışlı olur.

Öğleden sonra Balıklıgöl, Dergah bölgesi, Rızvaniye Camii ve çevredeki tarihi sokaklar için idealdir. Bu rota yürüyerek gezilebilir ve fotoğraf için en güçlü şehir dokusunu verir.

Akşam Gümrük Hanı çevresinde mırra içebilir, Kapalı Çarşı ve Bakırcılar Çarşısı tarafında yerel ürünlere bakabilirsiniz.

## 2. Gün: Doğa, Lezzet ve Sıra Gecesi
İkinci gün için Harran kümbet evleri, geleneksel mimari ve ovayı kapsayan yarım günlük bir rota planlanabilir.

Öğle yemeğinde Şanlıurfa mutfağından lahmacun, bostana, kebap çeşitleri veya yöresel ev yemekleri seçilebilir.

Öğleden sonra Halfeti tekne turu için ayrılabilir. Batık şehir, Rumkale çevresi ve Fırat manzarası hafta sonu rotasına farklı bir tempo katar.

Akşam programında sıra gecesi tercih edilecekse rezervasyon, ulaşım ve dönüş saatleri önceden netleştirilmelidir.

## Pratik Planlama Notları
- Göbeklitepe ve Harran gibi merkez dışı rotalarda ulaşımı önceden planlayın.
- Yaz aylarında öğle saatlerini kapalı alan, müze veya yemek molası için kullanın.
- Balıklıgöl ve çarşı rotasını aynı gün içinde yürüyerek gezebilirsiniz.
- Halfeti için tekne saatlerini gitmeden önce kontrol edin.
- Şanlıurfa gezisinde rahat ayakkabı ve mevsime uygun kıyafet önemlidir.`,
 content_html: null,
 author_name: 'Şanlıurfa Rehberi',
 published_at: '2026-04-11T00:00:00.000Z',
 reading_time: 3,
 featured_image: '/images/blog/tarihi-yerler-rehberi.jpg',
 category: 'Gezi',
 tags: [
 { name: 'Şanlıurfa Gezi', slug: 'sanliurfa-gezi' },
 { name: 'Hafta Sonu', slug: 'hafta-sonu' },
 ],
 },
};

if (!post && slug && fallbackPosts[slug]) {
 post = fallbackPosts[slug];
}

if (!post) return Astro.redirect('/blog');

const title = post.title;
const description = post.excerpt || post.meta_description || '';
const getBlogImage = (entry: any) => resolveBlogImage(entry);

// İçerikten gerçek FAQ Q&A çiftlerini çıkar (<h2>Sık Sorulan Sorular</h2> sonrasındaki <h3>/<p> blokları)
function extractContentFaq(html: string): Array<{S: string; C: string}> {
 if (!html || !html.includes('Sık Sorulan Sorular')) return [];
 const section = html.slice(html.indexOf('Sık Sorulan Sorular'));
 const matches = [...section.matchAll(/<h3[^>]*>([\s\S]*?)<\/h3>\s*<p[^>]*>([\s\S]*?)<\/p>/gi)];
 return matches.slice(0, 5)
  .map(m => ({ S: m[1].replace(/<[^>]+>/g, '').trim(), C: m[2].replace(/<[^>]+>/g, '').trim() }))
  .filter(p => p.S && p.C);
}

const contentFaq = post?.content ? extractContentFaq(post.content) : [];
const staticFaqItems = [
 {
  S: `${post.title} hakkında ne bilinmeli?`,
  C: post.excerpt && post.excerpt.length > 80
   ? post.excerpt
   : `${post.title} konusunu derinlemesine ele alan bu yazıda Şanlıurfa hakkında merak edilen bilgileri bulabilirsiniz. İçerik Sanliurfa.com editörleri tarafından hazırlanmış olup güncel ve doğrulanmış veriler içermektedir.`,
 },
 {
  S: `Bu yazı hangi kategoride?`,
  C: `Bu yazı ${post.category || 'Şanlıurfa Rehberi'} kategorisinde yayınlanmıştır. Sanliurfa.com blog bölümünde gezi, gastronomi, tarih, kültür ve günlük yaşam gibi başlıklarda yerel içerikler düzenli olarak paylaşılmaktadır.`,
 },
 {
  S: `Bu yazı ne zaman güncellendi?`,
  C: `Yazı ${post.published_at ? new Date(post.published_at).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' }) : 'yakın zamanda'} tarihinde yayımlanmış olup içerik gerekliliğine göre güncel tutulmaktadır. Doğruluk için yayım tarihini referans alabilirsiniz.`,
 },
 {
  S: `Şanlıurfa hakkında daha fazla yazı nerede bulunur?`,
  C: `Şanlıurfa rehberi, tarih, gastronomi ve gezi yazıları dahil tüm blog içeriklerimize sanliurfa.com/blog sayfasından ulaşabilirsiniz. Kategorilere göre filtreleyebilir, en çok okunan yazıları öne çıkan listeden takip edebilirsiniz.`,
 },
];
// Gerçek FAQ içeriği varsa onu kullan (≥3 çift), yoksa statik sorulara dön
const faqItems = contentFaq.length >= 3 ? contentFaq : staticFaqItems;
const CATEGORY_LINKS: Record<string, Array<{ label: string; href: string }>> = {
 'Gastronomi': [
  { label: 'Gastronomi Rehberi', href: '/gastronomi' },
  { label: 'En İyi Kebapçılar', href: '/en-iyi-kebapcilar' },
  { label: 'En İyi Cigerciler', href: '/en-iyi-cigerciler' },
  { label: 'Kahvaltı Mekanları', href: '/sanliurfa-kahvalti-mekanlari' },
 ],
 'Gezi': [
  { label: 'Gezilecek Yerler', href: '/gezilecek-yerler' },
  { label: 'Bugün Ne Yapılır?', href: '/bugun-sanliurfada-ne-yapilir' },
  { label: 'Gece Açık Mekanlar', href: '/sanliurfa-gece-acik-mekanlar' },
 ],
 'Tarih': [
  { label: 'Tarihi Yerler', href: '/tarihi-yerler' },
  { label: 'Dini ve Kültürel Yerler', href: '/dini-ve-kulturel-yerler' },
 ],
 'Kültür': [
  { label: 'Dini ve Kültürel Yerler', href: '/dini-ve-kulturel-yerler' },
  { label: 'Sıra Gecesi Mekanları', href: '/sanliurfa-sira-gecesi-mekanlari' },
  { label: 'Etkinlikler', href: '/etkinlikler' },
 ],
 'Ulaşım': [
  { label: 'Ulaşım Rehberi', href: '/ulasim' },
  { label: 'Otobüs Saatleri', href: '/ulasim/otobus-saatleri' },
  { label: 'Uçak Saatleri', href: '/ulasim/ucak-saatleri' },
 ],
 'Sağlık': [
  { label: 'Sağlık Hizmetleri', href: '/saglik' },
  { label: 'Nöbetçi Eczaneler', href: '/saglik/nobetci-eczaneler' },
 ],
 'Alışveriş': [
  { label: 'Alışveriş', href: '/alisveris' },
 ],
 'Tarım': [
  { label: 'Tarım ve Hayvancılık', href: '/tarim-ve-hayvancilik' },
 ],
 'İş': [
  { label: 'İş Dünyası ve Sanayi', href: '/is-dunyasi-ve-sanayi' },
 ],
};
const categoryLinks = CATEGORY_LINKS[post.category || ''] ?? [
 { label: 'Tüm Mekanlar', href: '/mekanlar' },
 { label: 'Blog Yazıları', href: '/blog' },
];

const isAuthenticated = !!Astro.locals.user;

const blogOgImage = getBlogImage(post);
const seo = buildPageSeo({
 title,
 description,
 ogImage: blogOgImage.includes('placeholder') ? undefined : blogOgImage,
 canonical: `/blog/${post.slug}`,
 keywords: post.tags?.length ? post.tags : ['Şanlıurfa', 'şehir rehberi', post.category || 'blog'],
 type: 'article',
 publishedTime: post.published_at ? new Date(post.published_at).toISOString() : undefined,
 modifiedTime: post.updated_at ? new Date(post.updated_at).toISOString() : undefined,
});
---

<EditorialTemplate seo={seo}>
 <style is:inline>
 .bl-content{max-width:100%}
 .bl-excerpt{font-size:1.05rem;color:var(--public-text-soft);font-style:italic;border-left:3px solid var(--public-accent);padding-left:1.25rem;line-height:1.8;margin:0}
 .bl-tags{margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(184,115,51,.15)}
 .bl-tags-title{font-size:.82rem;font-weight:700;color:var(--public-text);margin-bottom:.75rem}
 .bl-tag{display:inline-block;padding:.25rem .65rem;background:rgba(184,115,51,.06);border:1px solid rgba(184,115,51,.15);font-size:.78rem;color:var(--public-muted);margin:.25rem;transition:background .15s,color .15s}
 .bl-tag:hover{background:rgba(184,115,51,.12);color:var(--public-accent)}
 .bl-share{margin-top:2rem;display:flex;align-items:center;gap:1rem}
 .bl-share-label{font-size:.82rem;font-weight:600;color:var(--public-muted)}
 .bl-share-btn{padding:.5rem 1.1rem;font-size:.82rem;font-weight:600;border:none;cursor:pointer;transition:background .15s}
 .bl-share-primary{background:var(--public-accent);color:#fff}
 .bl-share-primary:hover{background:var(--public-accent-strong);color:#fff}
 .bl-share-secondary{background:transparent;border:1px solid rgba(184,115,51,.25);color:var(--public-muted)}
 .bl-share-secondary:hover{border-color:var(--public-accent);color:var(--public-accent)}
 .bl-side-text{margin:0;color:var(--public-muted);line-height:1.7;font-size:.88rem}
 .bl-meta-footer{margin-top:2rem;padding-top:1.5rem;border-top:1px solid rgba(184,115,51,.1);display:flex;flex-direction:column;gap:.4rem}
 .bl-updated{font-size:.78rem;color:var(--public-muted)}
 .bl-updated time{color:var(--public-text-soft)}
 .bl-source{font-size:.75rem;color:var(--public-muted);opacity:.7}
 .bl-byline{font-size:.82rem;color:var(--public-text);line-height:1.7;margin:0 0 .35rem}
 .bl-byline strong{color:var(--public-accent);font-weight:600}
 .bl-byline time{color:var(--public-text)}
 .bl-source a{color:var(--public-accent)}.bl-source a:hover{text-decoration:underline}
 </style>

 <Fragment slot="hero">
  <PublicDetailHero
   imageSrc={getBlogImage(post)}
   imageAlt={post.title}
   title={post.title}
   compact={true}
   badges={[
    { label: post.category, tone: 'dark' },
   ]}
   metaItems={[
    { label: String(post.author_name || 'Sanliurfa.com'), icon: 'lucide:user' },
    { label: new Date(post.published_at!).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' }), icon: 'lucide:calendar' },
    { label: `${post.reading_time} dk okuma`, icon: 'lucide:clock' },
   ]}
  />
 </Fragment>

 <PublicDetailBody compactSidebar>
 <div class="bl-content">
 {post.excerpt && (
 <PublicContentSection eyebrow="Özet">
  <p class="bl-excerpt">{post.excerpt}</p>
 </PublicContentSection>
 )}

 <PublicContentSection title="Yazının Tamamı">
 <PublicRichProse>
 {post.content_html ? (
 <Fragment set:html={linkifyContent(post.content_html, `/blog/${post.slug}`)} />
 ) : (
 <div>
 {post.content.split('\n').map((line: string) => {
 if (line.startsWith('# ')) {
 return <h1>{line.slice(2)}</h1>;
 } else if (line.startsWith('## ')) {
 return <h2>{line.slice(3)}</h2>;
 } else if (line.startsWith('### ')) {
 return <h3>{line.slice(4)}</h3>;
 } else if (line.startsWith('- ')) {
 return <li>{line.slice(2)}</li>;
 } else if (line.startsWith('![')) {
 const match = line.match(/!\[(.*?)\]\((.*?)\)/);
 if (match) {
 return <Image src={match[2]} alt={match[1]} width={960} height={540} />;
 }
 } else if (line.trim()) {
 return <p>{line}</p>;
 }
 return null;
 })}
 </div>
 )}
 </PublicRichProse>
 </PublicContentSection>

 {post.tags && post.tags.length > 0 && (
 <PublicContentSection title="Etiketler">
 <div class="bl-tags">
 <div>
 {post.tags.map((tag: any) => {
  const label = typeof tag === 'string' ? tag : (tag.name || tag.slug || String(tag));
  const slugTag = typeof tag === 'string' ? tag.toLowerCase().replace(/\s+/g, '-').replace(/[^\w-]/g, '') : (tag.slug || label.toLowerCase().replace(/\s+/g, '-'));
  return <a href={`/blog?etiket=${encodeURIComponent(slugTag)}`} class="bl-tag">{label}</a>;
 })}
 </div>
 </div>
 </PublicContentSection>
 )}

 <div class="bl-meta-footer">
  <p class="bl-byline">
   <strong>Yazar:</strong> {post.author_name || 'Sanliurfa.com Editöryel Ekibi'}
   {' · '}
   <strong>Yayın:</strong> <time datetime={post.published_at}>{new Date(post.published_at!).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' })}</time>
   {post.updated_at && post.updated_at !== post.published_at && (
    <>
     {' · '}<strong>Son güncelleme:</strong> <time datetime={post.updated_at}>{new Date(post.updated_at).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' })}</time>
    </>
   )}
  </p>
  <p class="bl-source">Kaynak: Sanliurfa.com Editöryel — Yerel araştırma ve yerinde derleme. Hata bildirimi: <a href="mailto:iletisim@sanliurfa.com">iletisim@sanliurfa.com</a>. <a href="/kunye">Yayın bilgileri</a></p>
 </div>

 <div class="bl-share">
 <span class="bl-share-label">Paylaş:</span>
 <button onclick="sharePage()" class="bl-share-btn bl-share-primary">Paylaş</button>
 <button onclick="copyLink()" class="bl-share-btn bl-share-secondary">Linki Kopyala</button>
 </div>
 </div>

 <Fragment slot="sidebar">
  <PublicSidebarCard title="Yazı Özeti">
   <p class="bl-side-text">
    {post.excerpt || `${post.title} yazısı ${post.category || 'Genel'} kategorisinde yayınlanmıştır.`}
   </p>
  </PublicSidebarCard>
  <PublicSidebarCard title="İlgili Sayfalar">
   <nav style="display:flex;flex-direction:column;gap:.5rem">
    {categoryLinks.map((link) => (
     <a href={link.href} style="display:flex;align-items:center;gap:.5rem;padding:.5rem .75rem;background:rgba(184,115,51,.07);border:1px solid rgba(184,115,51,.14);border-radius:.375rem;color:#B87333;font-size:.875rem;font-weight:600;text-decoration:none;transition:background .15s" onmouseenter="this.style.background='rgba(184,115,51,.14)'" onmouseleave="this.style.background='rgba(184,115,51,.07)'">
      <span style="flex-shrink:0">›</span>
      {link.label}
     </a>
    ))}
   </nav>
  </PublicSidebarCard>
  <PublicSidebarCard title="Hızlı Cevaplar">
   <PublicFaqList items={faqItems.map((item) => ({ q: item.S, a: item.C }))} />
  </PublicSidebarCard>
 </Fragment>
 </PublicDetailBody>

 <PublicStickyCTA
   shareUrl={`${baseUrl}/blog/${post.slug}`}
   shareTitle={post.title}
   commentAnchor="#yorumlar"
 />

 <BlogComments
  postId={post.id || post.slug}
  postTitle={post.title}
  isAuthenticated={isAuthenticated}
  client:visible
 />

 <BlogRelatedEvents category={post.category || 'Kültür'} server:defer>
  <div slot="fallback" style="height:8rem" />
 </BlogRelatedEvents>
 <BlogRelatedPlaces category={post.category || 'Turizm'} server:defer>
  <div slot="fallback" style="height:6rem" />
 </BlogRelatedPlaces>
 <RelatedPosts category={post.category} excludeSlug={post.slug} />

 <script define:vars={{ slug: post.slug, title: post.title }} is:inline>
 const url = window.location.href;

 async function copyLink() {
 try {
 await navigator.clipboard.writeText(url);
 window.toast?.success('Link kopyalandı');
 } catch {
 window.toast?.error('Link kopyalanamadı');
 }
 }

 async function sharePage() {
 if (navigator.share) {
 try {
 await navigator.share({ title, url });
 return;
 } catch {
 // fall back to copy
 }
 }
 await copyLink();
 }
 </script>
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BreadcrumbList',
 itemListElement: [
 { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
 { '@type': 'ListItem', position: 2, name: 'Blog', item: `${baseUrl}/blog` },
 { '@type': 'ListItem', position: 3, name: post.title, item: `${baseUrl}/blog/${post.slug}` },
 ],
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'BlogPosting',
 headline: post.title,
 description: post.excerpt || description,
 inLanguage: 'tr',
 url: `${baseUrl}/blog/${post.slug}`,
 image: (() => { const img = getBlogImage(post); return img.startsWith('http') ? img : `${baseUrl}${img}`; })(),
 datePublished: post.published_at || post.created_at,
 dateModified: post.updated_at || post.published_at || post.created_at,
 wordCount: post.content ? post.content.replace(/<[^>]+>/g, '').split(/\s+/).length : undefined,
 keywords: Array.isArray(post.tags) ? post.tags.join(', ') : (post.tags || ''),
 author: {
 '@type': post.author_name ? 'Person' : 'Organization',
 name: post.author_name || 'Sanliurfa.com Editöryel Ekibi',
 url: `${baseUrl}/yazarlar#editoryel-ekip`,
 },
 '@id': `${baseUrl}/blog/${post.slug}`,
 publisher: {
 '@type': 'Organization',
 name: 'Sanliurfa.com',
 url: baseUrl,
 logo: { '@type': 'ImageObject', url: `${baseUrl}/og-image.jpg`, width: 1200, height: 630 },
 sameAs: ['https://sanliurfa.com'],
 },
 mainEntityOfPage: {
 '@type': 'WebPage',
 '@id': `${baseUrl}/blog/${post.slug}`,
 },
 })} is:inline />
 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'FAQPage',
 mainEntity: faqItems.map((item) => ({
 '@type': 'Question',
 name: item.S,
 acceptedAnswer: { '@type': 'Answer', text: item.C },
 })),
 })} is:inline />
</EditorialTemplate>
