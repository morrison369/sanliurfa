---

// Blog Post Detail Page — reads from DB, falls back to content collection
import Layout from '../../layouts/Layout.astro';
import { queryOne, query } from '../../lib/postgres';
import { resolveContentImage } from '../../lib/content-images';
import { getSiteBranding } from '../../lib/site-branding';
const { baseUrl } = await getSiteBranding();

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/blog');

let post: any = null;
let relatedPosts: any[] = [];

try {
  // Try DB first
  post = await queryOne(
    "SELECT * FROM blog_posts WHERE slug = $1 AND status = 'published'",
    [slug]
  );

  if (post) {
    // Content may contain HTML already
    post.content_html = post.content;
    post.reading_time = Math.ceil((post.content || '').split(/\s+/).length / 200);

    const relResult = await query(
      "SELECT id, title, slug, excerpt, featured_image, category, created_at FROM blog_posts WHERE status = 'published' AND category = $1 AND slug != $2 LIMIT 3",
      [post.category, slug]
    );
    relatedPosts = relResult.rows;
  }
} catch (e) {
  console.error('Error loading blog post from DB:', e);
}

// Fallback: try Astro content collection
if (!post) {
  try {
    const { getPostBySlug: getFromCollection } = await import('../../lib/blog');
    const collectionPost = await getFromCollection(slug);
    if (collectionPost) {
      post = {
        ...collectionPost,
        content_html: null,
        author_name: collectionPost.author,
        published_at: collectionPost.publishedAt,
        reading_time: collectionPost.readingTime,
        featured_image: collectionPost.image,
      };
    }
  } catch { /* content collection not available in SSR */ }
}

const fallbackPosts: Record<string, any> = {
  'sanliurfa-hafta-sonu-rehberi': {
    slug: 'sanliurfa-hafta-sonu-rehberi',
    title: 'Şanlıurfa Hafta Sonu Rehberi: 2 Günde Neler Yapılır?',
    excerpt:
      "Şanlıurfa'da 2 günlük gezi planı. Cumartesi ve pazar günü yapılacaklar, gezilecek yerler ve yeme içme önerileri.",
    content: `## 1. Gün: Tarih ve Kültür
Sabah erken saatlerde Göbeklitepe ile başlayın. Ziyaret için 2-3 saat ayırmak, hem müze alanını hem de ana kazı bölgesini rahat gezmek için yeterlidir.

Öğle saatlerinde şehir merkezine dönüp ciğer kebabı, lahmacun veya patlıcan kebabı tercih edebilirsiniz. Kalabalık saatlere kalmamak için öğle planını erken yapmak daha kullanışlı olur.

Öğleden sonra Balıklıgöl, Dergah bölgesi, Rızvaniye Camii ve çevredeki tarihi sokaklar için idealdir. Bu rota yürüyerek gezilebilir ve fotoğraf için en güçlü şehir dokusunu verir.

Akşam Gümrük Hanı çevresinde mırra içebilir, Kapalı Çarşı ve Bakırcılar Çarşısı tarafında yerel ürünlere bakabilirsiniz.

## 2. Gün: Doğa, Lezzet ve Sıra Gecesi
İkinci gün için Harran kümbet evleri, geleneksel mimari ve ovayı kapsayan yarım günlük bir rota planlanabilir.

Öğle yemeğinde Şanlıurfa mutfağından lahmacun, bostana, kebap çeşitleri veya yöresel ev yemekleri seçilebilir.

Öğleden sonra Halfeti tekne turu için ayrılabilir. Batık şehir, Rumkale çevresi ve Fırat manzarası hafta sonu rotasına farklı bir tempo katar.

Akşam programında sıra gecesi tercih edilecekse rezervasyon, ulaşım ve dönüş saatleri önceden netleştirilmelidir.

## Pratik Planlama Notları
- Göbeklitepe ve Harran gibi merkez dışı rotalarda ulaşımı önceden planlayın.
- Yaz aylarında öğle saatlerini kapalı alan, müze veya yemek molası için kullanın.
- Balıklıgöl ve çarşı rotasını aynı gün içinde yürüyerek gezebilirsiniz.
- Halfeti için tekne saatlerini gitmeden önce kontrol edin.
- Şanlıurfa gezisinde rahat ayakkabı ve mevsime uygun kıyafet önemlidir.`,
    content_html: null,
    author_name: 'Şanlıurfa Rehberi',
    published_at: '2026-04-11T00:00:00.000Z',
    reading_time: 3,
    featured_image: '/images/blog/tarihi-yerler-rehberi.jpg',
    category: 'Gezi',
    tags: [
      { name: 'Şanlıurfa Gezi', slug: 'sanliurfa-gezi' },
      { name: 'Hafta Sonu', slug: 'hafta-sonu' },
    ],
  },
};

if (!post && slug && fallbackPosts[slug]) {
  post = fallbackPosts[slug];
}

if (!post) return Astro.redirect('/blog');

const title = post.title;
const description = post.excerpt || post.meta_description || '';
const getBlogImage = (entry: any, thumb = false) =>
  resolveContentImage({
    category: 'blog',
    slug: entry?.slug,
    explicit: entry?.featured_image || entry?.cover_image || entry?.image,
    placeholder: '/images/placeholder-blog.jpg',
    thumb,
  });
const faqItems = [
  { S: `${post.title} hakkında ne bilinmeli?`, C: post.excerpt || `${post.title} için detaylı bilgiyi yazımızda bulabilirsiniz.` },
  { S: `Bu yazı hangi kategoride?`, C: `Bu yazı ${post.category || 'Genel'} kategorisinde yayınlanmıştır.` },
  { S: `Şanlıurfa hakkında daha fazla yazı nerede bulunur?`, C: 'Şanlıurfa rehberiyle ilgili tüm yazılarımıza /blog sayfasından ulaşabilirsiniz.' },
];

---

<Layout seo={{
  title,
  description,
  ogImage: getBlogImage(post),
  type: 'article',
  publishedTime: post.created_at || post.published_at,
  modifiedTime: post.updated_at,
  keywords: post.tags?.length ? post.tags : ['Şanlıurfa', 'şehir rehberi', post.category || 'blog'],
  author: post.author_name || 'Sanliurfa.com',
  canonical: `/blog/${post.slug}`,
}}>
  <article class="min-h-screen bg-white">
    <!-- Hero -->
    <div class="bg-gradient-to-br from-amber-600 to-orange-700 text-white">
      <div class="container mx-auto px-4 py-16">
        <div class="max-w-3xl mx-auto text-center">
          <a href={`/blog?category=${post.category}`} class="inline-block px-3 py-1 bg-white/20 rounded-full text-sm mb-4 hover:bg-white/30 transition-colors">
            {post.category}
          </a>
          <h1 class="text-3xl md:text-5xl font-bold mb-6">{post.title}</h1>
          <div class="flex items-center justify-center gap-6 text-amber-100">
            <span class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
              {post.author_name}
            </span>
            <span class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              {new Date(post.published_at!).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' })}
            </span>
            <span class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              {post.reading_time} dk okuma
            </span>
          </div>
        </div>
      </div>
    </div>

    {/* Featured Image */}
    <div class="container mx-auto px-4 -mt-8">
      <div class="max-w-4xl mx-auto">
        <img
          src={getBlogImage(post)}
          alt={post.title}
          class="w-full h-64 md:h-96 object-cover rounded-2xl shadow-lg"
          onerror="this.setAttribute('src','/images/placeholder-blog.jpg')"
        />
      </div>
    </div>

    {/* Content */}
    <div class="container mx-auto px-4 py-12">
      <div class="max-w-3xl mx-auto">
        {/* Excerpt */}
        <p class="text-xl text-gray-600 italic border-l-4 border-amber-500 pl-6 mb-8">
          {post.excerpt}
        </p>

        {/* Main Content */}
        <div class="prose prose-lg prose-amber max-w-none">
          {post.content_html ? (
            <Fragment set:html={post.content_html} />
          ) : (
            <div class="markdown-content">
              {post.content.split('\n').map((line: string) => {
                if (line.startsWith('# ')) {
                  return <h1 class="text-3xl font-bold mt-8 mb-4">{line.slice(2)}</h1>;
                } else if (line.startsWith('## ')) {
                  return <h2 class="text-2xl font-bold mt-8 mb-4">{line.slice(3)}</h2>;
                } else if (line.startsWith('### ')) {
                  return <h3 class="text-xl font-bold mt-6 mb-3">{line.slice(4)}</h3>;
                } else if (line.startsWith('- ')) {
                  return <li class="ml-4">{line.slice(2)}</li>;
                } else if (line.startsWith('![')) {
                  const match = line.match(/!\[(.*?)\]\((.*?)\)/);
                  if (match) {
                    return <img src={match[2]} alt={match[1]} class="w-full rounded-lg my-6" />;
                  }
                } else if (line.trim()) {
                  return <p class="mb-4 leading-relaxed">{line}</p>;
                }
                return null;
              })}
            </div>
          )}
        </div>

        {/* Tags */}
        {post.tags && post.tags.length > 0 && (
          <div class="mt-12 pt-8 border-t">
            <h4 class="font-bold text-gray-900 mb-3">Etiketler</h4>
            <div class="flex flex-wrap gap-2">
              {post.tags.map((tag: any) => (
                <a
                  href={`/blog/etiket/${tag.slug}`}
                  class="px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-sm hover:bg-amber-100 hover:text-amber-700 transition-colors"
                >
                  {tag.name}
                </a>
              ))}
            </div>
          </div>
        )}

        {/* Share */}
        <div class="mt-8 flex items-center gap-4">
          <span class="font-medium text-gray-700">Paylaş:</span>
          <div class="flex gap-2">
            <button onclick="sharePage()" class="h-10 px-4 bg-amber-600 text-white rounded-full flex items-center justify-center hover:bg-amber-700 transition-colors">
              Paylaş
            </button>
            <button onclick="copyLink()" class="h-10 px-4 bg-gray-200 text-gray-700 rounded-full flex items-center justify-center hover:bg-gray-300 transition-colors">
              Linki Kopyala
            </button>
          </div>
        </div>
      </div>
    </div>

    {/* Related Posts */}
    {relatedPosts.length > 0 && (
      <div class="bg-gray-50 py-12">
        <div class="container mx-auto px-4">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Benzer Yazılar</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {relatedPosts.map(related => (
              <a href={`/blog/${related.slug}`} class="group">
                <article class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
                  <div class="h-40 bg-gradient-to-br from-amber-100 to-orange-100">
                    <img src={getBlogImage(related, true)} alt={related.title} class="w-full h-full object-cover" loading="lazy" onerror="this.setAttribute('src','/images/placeholder-blog.jpg')" />
                  </div>
                  <div class="p-4">
                    <h3 class="font-bold text-gray-900 group-hover:text-amber-600 transition-colors line-clamp-2">
                      {related.title}
                    </h3>
                    <p class="text-sm text-gray-500 mt-2">{related.reading_time} dk okuma</p>
                  </div>
                </article>
              </a>
            ))}
          </div>
        </div>
      </div>
    )}
  </article>

  <script define:vars={{ slug: post.slug, title: post.title }} is:inline>
    const url = window.location.href;
    
    async function copyLink() {
      try {
        await navigator.clipboard.writeText(url);
        alert('Link kopyalandı');
      } catch {
        alert('Link kopyalanamadı');
      }
    }

    async function sharePage() {
      if (navigator.share) {
        try {
          await navigator.share({ title, url });
          return;
        } catch {
          // fall back to copy
        }
      }
      await copyLink();
    }
  </script>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: `${baseUrl}/blog` },
      { '@type': 'ListItem', position: 3, name: post.title, item: `${baseUrl}/blog/${post.slug}` },
    ],
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: post.title,
    description: post.excerpt || description,
    inLanguage: 'tr',
    url: `${baseUrl}/blog/${post.slug}`,
    image: (() => { const img = getBlogImage(post); return img.startsWith('http') ? img : `${baseUrl}${img}`; })(),
    datePublished: post.published_at || post.created_at,
    dateModified: post.updated_at || post.published_at || post.created_at,
    author: {
      '@type': 'Person',
      name: post.author_name || 'Sanliurfa.com',
    },
    '@id': `${baseUrl}/blog/${post.slug}`,
    publisher: {
      '@type': 'Organization',
      name: 'Sanliurfa.com',
      url: baseUrl,
      logo: { '@type': 'ImageObject', url: `${baseUrl}/favicon.svg`, width: 200, height: 200 },
    },
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': `${baseUrl}/blog/${post.slug}`,
    },
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: { '@type': 'Answer', text: item.C },
    })),
  })} is:inline />
</Layout>
