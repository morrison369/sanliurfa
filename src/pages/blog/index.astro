---

// Blog Index Page
import Layout from '../../layouts/Layout.astro';
import Image from '../../components/Image.astro';
import { query } from '../../lib/postgres';
import { resolveContentImage } from '../../lib/content-images';
import { getSiteBranding } from '../../lib/site-branding';
const { baseUrl } = await getSiteBranding();

let posts: any[] = [];
let categories: any[] = [];

try {
  const postsResult = await query(
    "SELECT * FROM blog_posts WHERE status = 'published' ORDER BY published_at DESC NULLS LAST, created_at DESC LIMIT 12"
  );
  posts = postsResult.rows;

  const catResult = await query(
    "SELECT category, COUNT(*) as count FROM blog_posts WHERE status = 'published' AND category IS NOT NULL GROUP BY category ORDER BY count DESC"
  );
  categories = catResult.rows;
} catch (e) {
  console.error('Error loading blog:', e);
}

const seo = {
  title: 'Şanlıurfa Blog - Gezi Rehberi ve Haberler',
  description: 'Şanlıurfa hakkında en güncel blog yazıları, gezi rehberleri, tarihi yerler ve lezzet durakları.',
  ogImage: '/images/blog/tarihi-yerler-rehberi.jpg',
  keywords: ['şanlıurfa blog', 'urfa gezi rehberi', 'şanlıurfa haberler', 'urfa tarihi yazılar', 'şanlıurfa seyahat', 'urfa kültür', 'şanlıurfa yaşam'],
  canonical: '/blog',
};

const faqItems = [
  {
    S: 'Şanlıurfa hakkında gezi rehberi nerede bulunur?',
    C: 'Şanlıurfa blog sayfasında Göbeklitepe, Balıklıgöl, Harran ve şehrin tarihi mekânlarını anlatan detaylı gezi rehberleri yayımlanmaktadır.',
  },
  {
    S: 'Şanlıurfa yemek tarifleri ve gastronomi yazıları var mı?',
    C: 'Evet. Blogda çiğ köfte, lahmacun, kebap ve diğer yöresel Urfa lezzetleri hakkında tarifler ve gastronomi yazıları yer almaktadır.',
  },
  {
    S: 'Şanlıurfa blog yazıları ne sıklıkla güncelleniyor?',
    C: 'Blog, şehirdeki etkinlikler, tatil dönemleri ve öne çıkan gelişmelere göre düzenli olarak güncellenmektedir.',
  },
];

const getBlogImage = (post: any) =>
  resolveContentImage({
    category: 'blog',
    slug: post?.slug,
    explicit: post?.cover_image,
    placeholder: '/images/placeholder-blog.jpg',
  });
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50">
    <!-- Hero -->
    <div class="bg-gradient-to-br from-amber-600 to-orange-700 text-white py-16">
      <div class="container mx-auto px-4">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Şanlıurfa Blog</h1>
        <p class="text-xl text-amber-100 max-w-2xl">
          Şanlıurfa’nın tarihi, kültürü ve lezzetleri hakkında detaylı rehberler ve haberler
        </p>
      </div>
    </div>

    <div class="container mx-auto px-4 py-12">
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        <!-- Main Content -->
        <div class="lg:col-span-3">
          {posts.length > 0 ? (
            <div class="space-y-8">
              {posts.map((post) => (
                <a href={`/blog/${post.slug}`} class="group block">
                  <article class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow">
                    <div class="bg-gradient-to-br from-amber-100 to-orange-100 h-48">
                      <Image
                        src={getBlogImage(post)}
                        alt={post.title}
                        class="w-full h-full object-cover"
                        loading="lazy"
                        width={1200}
                        height={480}
                      />
                    </div>
                    <div class="p-6">
                      <span class="text-xs font-medium text-amber-600 uppercase tracking-wider">{post.category}</span>
                      <h3 class="font-bold text-gray-900 mt-2 group-hover:text-amber-600 transition-colors text-lg">
                        {post.title}
                      </h3>
                      <p class="text-gray-600 mt-2 line-clamp-2">{post.excerpt}</p>
                      <div class="flex items-center gap-4 mt-4 text-sm text-gray-500">
                        <span>{post.created_at ? new Date(post.created_at).toLocaleDateString('tr-TR') : ''}</span>
                      </div>
                    </div>
                  </article>
                </a>
              ))}
            </div>
          ) : (
            <div class="text-center py-16">
              <p class="text-gray-500 text-lg">Henüz blog yazısı yok.</p>
            </div>
          )}
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          {categories.length > 0 && (
            <div class="bg-white rounded-xl shadow-sm p-6">
              <h3 class="font-bold text-gray-900 mb-4">Kategoriler</h3>
              <div class="space-y-2">
                {categories.map((cat) => (
                  <a href={`/blog?category=${cat.slug}`} class="flex items-center justify-between py-2 text-gray-600 hover:text-amber-600">
                    <span>{cat.name}</span>
                    <span class="text-sm text-gray-400">({cat.count})</span>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Blog',
    name: 'Şanlıurfa Blog',
    description: 'Şanlıurfa hakkında gezi rehberleri, tarihi yerler ve lezzet yazıları.',
    url: `${baseUrl}/blog`,
    inLanguage: 'tr',
    publisher: {
      '@type': 'Organization',
      name: 'Sanliurfa.com',
      url: `${baseUrl}`,
    },
    blogPost: posts.slice(0, 10).map((p: any) => ({
      '@type': 'BlogPosting',
      headline: p.title,
      url: `${baseUrl}/blog/${p.slug}`,
      datePublished: p.published_at || p.created_at,
      dateModified: p.updated_at || p.published_at || p.created_at,
      image: p.cover_image || `${baseUrl}/images/placeholder-blog.jpg`,
    })),
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: `${baseUrl}/blog` },
    ],
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: { '@type': 'Answer', text: item.C },
    })),
  })} is:inline />
</Layout>