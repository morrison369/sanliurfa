---
// Blog Index Page
import Layout from '../../layouts/Layout.astro';
import { query } from '../../lib/postgres';

let posts: any[] = [];
let categories: any[] = [];

try {
  const postsResult = await query(
    "SELECT * FROM blog_posts WHERE status = 'published' ORDER BY published_at DESC NULLS LAST, created_at DESC LIMIT 12"
  );
  posts = postsResult.rows;

  const catResult = await query(
    "SELECT category, COUNT(*) as count FROM blog_posts WHERE status = 'published' AND category IS NOT NULL GROUP BY category ORDER BY count DESC"
  );
  categories = catResult.rows;
} catch (e) {
  console.error('Error loading blog:', e);
}

const seo = {
  title: 'Şanlıurfa Blog - Gezi Rehberi ve Haberler',
  description: 'Şanlıurfa hakkında en güncel blog yazıları, gezi rehberleri, tarihi yerler ve lezzet durakları.',
};
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50">
    <!-- Hero -->
    <div class="bg-gradient-to-br from-amber-600 to-orange-700 text-white py-16">
      <div class="container mx-auto px-4">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Şanlıurfa Blog</h1>
        <p class="text-xl text-amber-100 max-w-2xl">
          Şanlıurfa'nın tarihi, kültürü ve lezzetleri hakkında detaylı rehberler ve haberler
        </p>
      </div>
    </div>

    <div class="container mx-auto px-4 py-12">
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        <!-- Main Content -->
        <div class="lg:col-span-3">
          {posts.length > 0 ? (
            <div class="space-y-8">
              {posts.map((post) => (
                <a href={`/blog/${post.slug}`} class="group block">
                  <article class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow">
                    <div class="bg-gradient-to-br from-amber-100 to-orange-100 h-48">
                      {post.cover_image ? (
                        <img src={post.cover_image} alt={post.title} class="w-full h-full object-cover" />
                      ) : (
                        <div class="w-full h-full flex items-center justify-center text-amber-300">
                          <svg class="w-16 h-16" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd"/>
                          </svg>
                        </div>
                      )}
                    </div>
                    <div class="p-6">
                      <span class="text-xs font-medium text-amber-600 uppercase tracking-wider">{post.category}</span>
                      <h3 class="font-bold text-gray-900 mt-2 group-hover:text-amber-600 transition-colors text-lg">
                        {post.title}
                      </h3>
                      <p class="text-gray-600 mt-2 line-clamp-2">{post.excerpt}</p>
                      <div class="flex items-center gap-4 mt-4 text-sm text-gray-500">
                        <span>{post.created_at ? new Date(post.created_at).toLocaleDateString('tr-TR') : ''}</span>
                      </div>
                    </div>
                  </article>
                </a>
              ))}
            </div>
          ) : (
            <div class="text-center py-16">
              <p class="text-gray-500 text-lg">Henüz blog yazısı yok.</p>
            </div>
          )}
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          {categories.length > 0 && (
            <div class="bg-white rounded-xl shadow-sm p-6">
              <h3 class="font-bold text-gray-900 mb-4">Kategoriler</h3>
              <div class="space-y-2">
                {categories.map((cat) => (
                  <a href={`/blog?category=${cat.slug}`} class="flex items-center justify-between py-2 text-gray-600 hover:text-amber-600">
                    <span>{cat.name}</span>
                    <span class="text-sm text-gray-400">({cat.count})</span>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</Layout>
