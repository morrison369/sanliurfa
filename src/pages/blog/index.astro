---
import Layout from '../../layouts/Layout.astro';
import PublicPageIntro from '../../components/public/PublicPageIntro.astro';
import Image from '../../components/Image.astro';
import { query } from '../../lib/postgres';
import { logger } from '../../lib/logging';
import { resolveBlogImage } from '../../lib/public-image-resolvers';
import { getCachedPublicRouteData } from '../../lib/public-route-cache';

const etiket = Astro.url.searchParams.get('etiket') || '';
const category = Astro.url.searchParams.get('category') || '';

let posts: any[] = [];
let categories: any[] = [];
let popularTags: string[] = [];

try {
  if (etiket) {
    // Etiket filtresi — cache'leme yok (dinamik)
    const r = await query(
      `SELECT * FROM blog_posts WHERE status='published' AND published_at <= CURRENT_DATE AND $1=ANY(tags) ORDER BY published_at DESC NULLS LAST, created_at DESC LIMIT 50`,
      [etiket]
    );
    posts = r.rows;
  } else if (category) {
    const r = await query(
      `SELECT * FROM blog_posts WHERE status='published' AND published_at <= CURRENT_DATE AND category=$1 ORDER BY published_at DESC NULLS LAST, created_at DESC LIMIT 50`,
      [category]
    );
    posts = r.rows;
  } else {
    const today = new Date().toISOString().slice(0, 10);
    const data = await getCachedPublicRouteData(`page:blog:index:${today}`, async () => {
      const [postsResult, catResult, tagResult] = await Promise.all([
        query("SELECT * FROM blog_posts WHERE status='published' AND published_at <= CURRENT_DATE ORDER BY published_at DESC NULLS LAST, created_at DESC LIMIT 12"),
        query("SELECT category, COUNT(*) as count FROM blog_posts WHERE status='published' AND published_at <= CURRENT_DATE AND category IS NOT NULL GROUP BY category ORDER BY count DESC"),
        query("SELECT unnest(tags) as tag, COUNT(*) as cnt FROM blog_posts WHERE status='published' AND published_at <= CURRENT_DATE AND tags IS NOT NULL GROUP BY tag ORDER BY cnt DESC LIMIT 20"),
      ]);
      return {
        posts: postsResult.rows,
        categories: catResult.rows,
        tags: tagResult.rows.map((r: any) => r.tag as string),
      };
    });
    posts = data.posts;
    categories = data.categories;
    popularTags = data.tags || [];
  }

  if (!categories.length) {
    const catResult = await query("SELECT category, COUNT(*) as count FROM blog_posts WHERE status='published' AND published_at <= CURRENT_DATE AND category IS NOT NULL GROUP BY category ORDER BY count DESC");
    categories = catResult.rows;
  }
  if (!popularTags.length) {
    const tagResult = await query("SELECT unnest(tags) as tag, COUNT(*) as cnt FROM blog_posts WHERE status='published' AND published_at <= CURRENT_DATE AND tags IS NOT NULL GROUP BY tag ORDER BY cnt DESC LIMIT 20");
    popularTags = tagResult.rows.map((r: any) => r.tag as string);
  }
} catch (e) {
  logger.error('blog/index error', e instanceof Error ? e : new Error(String(e)));
}

const filterLabel = etiket ? `"${etiket}" Etiketi` : category ? `"${category}" Kategorisi` : '';
const isFiltered = !!(etiket || category);

const seo = {
  title: isFiltered
    ? `${filterLabel} — Şanlıurfa Blog`
    : 'Şanlıurfa Blog — Gezi Rehberi, Tarih ve Lezzet Yazıları',
  description: 'Şanlıurfa hakkında en güncel blog yazıları, gezi rehberleri, tarihi yerler ve lezzet durakları.',
  keywords: ['şanlıurfa blog', 'urfa gezi rehberi', 'şanlıurfa tarihi', 'urfa lezzetleri'],
  canonical: '/blog',
  ogImage: '/images/blog/urfa-tarihi.webp',
};

const getBlogImage = (post: any) => resolveBlogImage(post);
const formatDate = (d: string | null) => d ? new Date(d).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' }) : '';
---

<Layout seo={seo}>
  <style is:inline>
  .bl-layout{display:grid;grid-template-columns:1fr;gap:3rem;padding:3rem 0 5rem}
  @media(min-width:1024px){.bl-layout{grid-template-columns:1fr 240px}}
  .bl-list{display:flex;flex-direction:column;gap:1px;background:rgba(184,115,51,.08)}
  .bl-card{background:var(--bg-card);text-decoration:none;display:flex;flex-direction:column;transition:background .2s}
  @media(min-width:640px){.bl-card{flex-direction:row}}
  .bl-card:hover{background:var(--bg-hover)}
  .bl-card-img{width:100%;aspect-ratio:16/9;object-fit:cover;display:block;background:var(--public-accent-soft);flex-shrink:0}
  @media(min-width:640px){.bl-card-img{width:220px;aspect-ratio:auto;height:160px}}
  .bl-card-ph{width:100%;aspect-ratio:16/9;background:var(--public-accent-soft);display:flex;align-items:center;justify-content:center;font-size:2rem;flex-shrink:0}
  @media(min-width:640px){.bl-card-ph{width:220px;height:160px;aspect-ratio:auto}}
  .bl-card-body{padding:1.25rem;display:flex;flex-direction:column;gap:.3rem;flex:1}
  .bl-card-cat{font-size:.62rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--public-accent)}
  .bl-card-title{font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:600;color:var(--public-text);line-height:1.3}
  .bl-card-excerpt{font-size:.8rem;color:var(--public-muted);line-height:1.6;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;margin-top:.2rem}
  .bl-card-date{font-size:.7rem;color:var(--public-muted);margin-top:auto;padding-top:.5rem}
  .bl-side{display:flex;flex-direction:column;gap:1.25rem}
  .bl-side-card{background:var(--bg-card);border:1px solid var(--border);padding:1.25rem}
  .bl-side-lbl{font-size:.65rem;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--public-accent);margin-bottom:.85rem}
  .bl-cat-link{display:flex;align-items:center;justify-content:space-between;padding:.5rem 0;border-bottom:1px solid rgba(184,115,51,.08);font-size:.82rem;color:var(--public-text-soft);text-decoration:none;transition:color .15s}
  .bl-cat-link:last-child{border-bottom:none}
  .bl-cat-link:hover,.bl-cat-link.active{color:var(--public-accent)}
  .bl-tag-cloud{display:flex;flex-wrap:wrap;gap:.4rem;margin-top:.25rem}
  .bl-tag{font-size:.72rem;padding:.2rem .6rem;background:rgba(184,115,51,.1);color:var(--public-text-soft);border-radius:2rem;text-decoration:none;transition:background .15s,color .15s}
  .bl-tag:hover,.bl-tag.active{background:var(--public-accent);color:#fff}
  .bl-filter-bar{display:flex;align-items:center;gap:.75rem;margin-bottom:1.25rem;padding:.75rem 1rem;background:var(--bg-card);border:1px solid rgba(184,115,51,.2);font-size:.82rem;color:var(--public-text-soft)}
  .bl-empty{padding:5rem 0;text-align:center;color:var(--public-muted)}
  </style>

  <PublicPageIntro
    eyebrow="Şanlıurfa Yazıları"
    title={isFiltered ? filterLabel : 'Blog'}
    description="Tarihi yerler, yöresel lezzetler, gezi rehberleri ve şehrin gündelik yaşamı."
  />

  <div class="sf-container">
    <div class="bl-layout">
      <div>
        {isFiltered && (
          <div class="bl-filter-bar">
            <span>{posts.length} yazı bulundu</span>
            <a href="/blog" style="margin-left:auto;color:var(--public-accent);text-decoration:none;font-size:.78rem">✕ Filtreyi Kaldır</a>
          </div>
        )}

        {posts.length > 0 ? (
          <div class="bl-list" role="list" aria-label="Blog yazıları">
            {posts.map(post => (
              <a href={`/blog/${post.slug}`} class="bl-card" role="listitem" aria-label={post.title}>
                {getBlogImage(post)
                  ? <Image src={getBlogImage(post)} alt={post.title} class="bl-card-img" loading="lazy" width={220} height={160} />
                  : <div class="bl-card-ph" aria-hidden="true">📰</div>
                }
                <div class="bl-card-body">
                  {post.category && <span class="bl-card-cat">{post.category}</span>}
                  <h2 class="bl-card-title">{post.title}</h2>
                  {post.excerpt && <p class="bl-card-excerpt">{post.excerpt}</p>}
                  <span class="bl-card-date">{formatDate(post.published_at || post.created_at)}</span>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <div class="bl-empty">
            <p style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;color:var(--public-text-soft);margin-bottom:.5rem">
              {isFiltered ? `"${etiket || category}" için yazı bulunamadı` : 'Henüz yazı yok'}
            </p>
            {isFiltered && <a href="/blog" style="font-size:.85rem;color:var(--public-accent)">Tüm yazılara dön →</a>}
          </div>
        )}
      </div>

      <aside class="bl-side">
        {categories.length > 0 && (
          <div class="bl-side-card">
            <p class="bl-side-lbl">Kategoriler</p>
            <a href="/blog" class={`bl-cat-link${!isFiltered ? ' active' : ''}`}>
              <span>Tümü</span>
            </a>
            {categories.map((cat: any) => (
              <a
                href={`/blog?category=${encodeURIComponent(cat.category)}`}
                class={`bl-cat-link${category === cat.category ? ' active' : ''}`}
              >
                <span>{cat.category}</span>
                <span style="font-size:.7rem;color:var(--public-muted)">{cat.count}</span>
              </a>
            ))}
          </div>
        )}

        {popularTags.length > 0 && (
          <div class="bl-side-card">
            <p class="bl-side-lbl">Etiketler</p>
            <div class="bl-tag-cloud">
              {popularTags.map((tag: string) => (
                <a
                  href={`/blog?etiket=${encodeURIComponent(tag)}`}
                  class={`bl-tag${etiket === tag ? ' active' : ''}`}
                >
                  {tag}
                </a>
              ))}
            </div>
          </div>
        )}

        <div class="bl-side-card">
          <p class="bl-side-lbl">Hızlı Bağlantılar</p>
          {[
            { label: 'Göbeklitepe Rehberi', href: '/blog/gobeklitepe-rehberi-ziyaret-bilgileri' },
            { label: 'Balıklıgöl Tarihi', href: '/blog/balikligol-ziyaret-rehberi' },
            { label: 'Urfa Mutfağı', href: '/yemek-tarifleri' },
            { label: 'Halfeti Gezi', href: '/blog/halfeti-tekne-turu-rehberi' },
          ].map(l => (
            <a href={l.href} class="bl-cat-link">{l.label}</a>
          ))}
        </div>

        <a href="/isletme-kayit" class="sf-btn-primary" style="text-align:center;justify-content:center">
          İşletme Ekle
        </a>
      </aside>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org', '@type': 'Blog',
    name: 'Şanlıurfa Blog', url: 'https://sanliurfa.com/blog',
    inLanguage: 'tr',
    publisher: { '@type': 'Organization', name: 'Sanliurfa.com', url: 'https://sanliurfa.com' },
    blogPost: posts.slice(0, 10).map((p: any) => ({
      '@type': 'BlogPosting', headline: p.title, url: `https://sanliurfa.com/blog/${p.slug}`,
      datePublished: p.published_at || p.created_at, image: `https://sanliurfa.com${getBlogImage(p)}`,
    })),
  })} is:inline />
</Layout>
