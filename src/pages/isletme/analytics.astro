---
import Layout from "../../layouts/Layout.astro";
import { BusinessAnalyticsDashboard } from "../../components/BusinessAnalyticsDashboard";
import AuthFeatureLanding from "../../components/AuthFeatureLanding.astro";

const user = Astro.locals.user;
---

<Layout title="İşletme Analitikleri - Şanlıurfa" noindex>
  {
    !user ? (
      <AuthFeatureLanding
        eyebrow="İşletme analitikleri"
        title="Şanlıurfa işletmeniz için ölçülebilir büyüme paneli"
        description="Mekân görüntülenmeleri, yorumlar, takipçiler ve kampanya performansı işletme hesabında tek panelde toplanır. Hesap oluşturduktan sonra işletmenizi ekleyip analitikleri takip edebilirsiniz."
        loginRedirect="/isletme/analytics"
        features={[
          {
            title: "Mekân performansı",
            description:
              "Görüntülenme, yorum, puan ve takipçi metriklerini dönem bazlı takip edin.",
          },
          {
            title: "Veri destekli öneriler",
            description:
              "Eksik profil alanları, düşük yorum yanıt oranı ve görünürlük fırsatları için aksiyon önerileri alın.",
          },
          {
            title: "Kampanya bağlantısı",
            description:
              "Öne çıkan listeleme ve pazarlama kampanyalarının etkisini aynı işletme akışında görün.",
          },
        ]}
      />
    ) : (
      <div class="container mx-auto px-4 py-8">
        <div class="mb-8">
          <h1 class="text-4xl font-bold mb-2">İşletme analitikleri</h1>
          <p class="text-gray-600">
            Mekânınız hakkında detaylı istatistikler ve veri destekli öneriler.
          </p>
        </div>

        <BusinessAnalyticsDashboard client:load />

        <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-urfa-50 rounded-lg p-6 border border-urfa-200">
            <h3 class="font-semibold mb-2 text-urfa-900">Güncel veriler</h3>
            <p class="text-sm text-gray-700">
              Ziyaretçi sayısı, yorum ve etkileşimler hakkında güncel bilgi
              alın.
            </p>
          </div>

          <div class="bg-isot-50 rounded-lg p-6 border border-isot-200">
            <h3 class="font-semibold mb-2 text-isot-900">Akıllı öneriler</h3>
            <p class="text-sm text-gray-700">
              Veri destekli önerileri takip ederek işletme profilinizi
              geliştirin.
            </p>
          </div>

          <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
            <h3 class="font-semibold mb-2 text-gray-900">Eğilim analizi</h3>
            <p class="text-sm text-gray-700">
              Son 7, 30 ve 90 güne yönelik görüntülenme ve etkileşim
              değişimlerini izleyin.
            </p>
          </div>
        </div>
      </div>
    )
  }
</Layout>
