---
import Layout from '../../layouts/Layout.astro';
import { BusinessAnalyticsDashboard } from '../../components/BusinessAnalyticsDashboard';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/giris?redirect=/isletme/analytics');
}
---

<Layout seo={{ title: "İşletme Analitikleri - Şanlıurfa", noIndex: true }}>
  <div class="min-h-screen bg-[#FDFAF3]">
    <div class="bg-[#0D0A08] border-b border-[rgba(200,160,100,0.14)] text-white py-12">
      <div class="container mx-auto px-4">
        <p class="text-sm font-semibold uppercase tracking-widest text-[#9A8470] mb-2">İşletme Paneli</p>
        <h1 class="text-4xl font-bold text-[#F5EDD6] mb-2">İşletme Analitikleri</h1>
        <p class="text-[#C4B49A]">Mekanınız hakkında detaylı istatistikler ve AI-destekli öneriler</p>
      </div>
    </div>

    <div class="container mx-auto px-4 py-8">
      <BusinessAnalyticsDashboard client:visible />

      <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-[rgba(200,160,100,0.06)] rounded-sm p-6 border border-[rgba(200,160,100,0.2)]">
          <h3 class="font-semibold mb-2 text-[#1A1008]">Gerçek Zamanlı Veriler</h3>
          <p class="text-sm text-[#6B5540]">Ziyaretçi sayısı, inceleme ve etkileşimler hakkında anında bilgi alın.</p>
        </div>

        <div class="bg-[rgba(200,160,100,0.06)] rounded-sm p-6 border border-[rgba(200,160,100,0.2)]">
          <h3 class="font-semibold mb-2 text-[#1A1008]">AI Önerileri</h3>
          <p class="text-sm text-[#6B5540]">Yapay zeka destekli önerileri takip ederek işletmenizi geliştirin.</p>
        </div>

        <div class="bg-[rgba(200,160,100,0.06)] rounded-sm p-6 border border-[rgba(200,160,100,0.2)]">
          <h3 class="font-semibold mb-2 text-[#1A1008]">Eğilim Analizi</h3>
          <p class="text-sm text-[#6B5540]">Gelecek 30 ve 90 güne yönelik tahminler ve trend analizi.</p>
        </div>
      </div>
    </div>
  </div>
</Layout>
