---
import Layout from "../../layouts/Layout.astro";
import FeaturedListingsManager from "../../components/FeaturedListingsManager";
import MarketingCampaignBuilder from "../../components/MarketingCampaignBuilder";
import AuthFeatureLanding from "../../components/AuthFeatureLanding.astro";

const user = Astro.locals.user;

const seo = {
  title: "Pazarlama ve öne çıkan listelemeler",
  description:
    "Şanlıurfa işletmenizi öne çıkarın, kampanya oluşturun ve performansı takip edin.",
  noindex: true,
};
---

<Layout seo={seo}>
  {
    !user ? (
      <AuthFeatureLanding
        eyebrow="İşletme pazarlaması"
        title="Şanlıurfa işletmenizi doğru kitleye gösterin"
        description="Öne çıkan listelemeler, kampanyalar ve performans ölçümü işletme panelinde tek akışa bağlanır. Hesap oluşturduğunuzda işletmenizi ekleyip görünürlük çalışmalarını yönetebilirsiniz."
        loginRedirect="/isletme/pazarlama"
        features={[
          {
            title: "Öne çıkan listeleme",
            description:
              "Mekânınızı kategori, bölge ve arama akışlarında daha görünür hale getirecek tanıtım alanları.",
          },
          {
            title: "Kampanya yönetimi",
            description:
              "Yerel müşteri hedefleri, bütçe ve tarih aralığıyla kampanya oluşturma altyapısı.",
          },
          {
            title: "Performans takibi",
            description:
              "Görüntülenme, tıklama, yorum ve takip verilerini işletme analitikleriyle takip etme.",
          },
        ]}
      />
    ) : (
      <div class="bg-gray-50 dark:bg-gray-900 min-h-screen pt-20 pb-12">
        <div class="max-w-6xl mx-auto px-4">
          <div class="mb-8">
            <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-2">
              Pazarlama ve öne çıkan listelemeler
            </h1>
            <p class="text-gray-600 dark:text-gray-400">
              İşletmenizi pazarlayın, kampanyalar oluşturun ve öne çıkan
              listelemeleri yönetin.
            </p>
          </div>

          <div class="grid md:grid-cols-2 gap-8">
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
              <h2 class="text-2xl font-bold mb-6 pb-4 border-b border-gray-200 dark:border-gray-700">
                Öne çıkan listelemeler
              </h2>
              <div class="text-sm text-gray-600 dark:text-gray-400 mb-6">
                <p>
                  Öne çıkan listelemeler, işletmenizi platformda daha görünür
                  yapmak için kullanılan tanıtım alanlarıdır. Daha fazla
                  görünürlük kazanın, müşteri trafiğini artırın ve başarıyı
                  ölçün.
                </p>
              </div>
              <FeaturedListingsManager client:load />
            </div>

            <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
              <h2 class="text-2xl font-bold mb-6 pb-4 border-b border-gray-200 dark:border-gray-700">
                Pazarlama kampanyaları
              </h2>
              <div class="text-sm text-gray-600 dark:text-gray-400 mb-6">
                <p>
                  Hedeflenen pazarlama kampanyaları oluşturun. Bütçe yönetimi,
                  performans takibi ve detaylı analizler ile başarınızı
                  ölçülebilir hale getirin.
                </p>
              </div>
              <MarketingCampaignBuilder client:load />
            </div>
          </div>

          <div class="grid md:grid-cols-3 gap-6 mt-8">
            <div class="bg-urfa-50 dark:bg-urfa-900/20 border border-urfa-200 dark:border-urfa-800 rounded-lg p-4">
              <h3 class="font-semibold text-urfa-900 dark:text-urfa-100 mb-2">
                Analitik
              </h3>
              <p class="text-sm text-urfa-800 dark:text-urfa-200">
                Her kampanya ve öne çıkan listelemenizin performansını düzenli
                olarak izleyin.
              </p>
            </div>
            <div class="bg-isot-50 dark:bg-isot-900/20 border border-isot-200 dark:border-isot-800 rounded-lg p-4">
              <h3 class="font-semibold text-isot-900 dark:text-isot-100 mb-2">
                Bütçe kontrolü
              </h3>
              <p class="text-sm text-isot-800 dark:text-isot-200">
                Pazarlama harcamalarınızı kontrol edin ve yatırım geri
                dönüşünüzü takip edin.
              </p>
            </div>
            <div class="bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4">
              <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">
                Hedefleme
              </h3>
              <p class="text-sm text-gray-700 dark:text-gray-300">
                Kampanyalarınız için özel hedefler belirleyin ve doğru
                müşterilere ulaşın.
              </p>
            </div>
          </div>
        </div>
      </div>
    )
  }
</Layout>
