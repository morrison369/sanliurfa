---

import Layout from '../../layouts/Layout.astro';
import { query } from '../../lib/postgres';
import { getSiteBranding } from '../../lib/site-branding';
const { baseUrl } = await getSiteBranding();

let categories: any[] = [];
let featuredPlaces: any[] = [];
let totalCount = 0;

try {
  const catResult = await query(
    `SELECT c.id, c.name, c.slug, c.icon, c.description,
       COUNT(p.id)::int AS place_count
     FROM categories c
     LEFT JOIN places p ON p.category_id = c.id AND p.status = 'active'
     WHERE c.is_active = true AND c.parent_id IS NOT NULL
     GROUP BY c.id
     HAVING COUNT(p.id) > 0
     ORDER BY COUNT(p.id) DESC
     LIMIT 12`,
    []
  );
  categories = catResult.rows;

  const featResult = await query(
    `SELECT p.id, p.name, p.slug, p.short_description, p.address,
       p.rating, p.review_count, p.price_range, p.is_verified,
       c.name AS category_name, c.slug AS category_slug,
       d.name AS district_name
     FROM places p
     LEFT JOIN categories c ON c.id = p.category_id
     LEFT JOIN districts d ON d.id = p.district_id
     WHERE p.status = 'active' AND p.is_featured = true
     ORDER BY p.rating DESC NULLS LAST, p.review_count DESC NULLS LAST
     LIMIT 8`,
    []
  );
  featuredPlaces = featResult.rows;

  const countResult = await query(
    `SELECT COUNT(*)::int AS total FROM places WHERE status = 'active'`,
    []
  );
  totalCount = countResult.rows[0]?.total || 0;
} catch (e) {
  console.error('isletme index error:', e);
}

const seo = {
  title: 'Şanlıurfa İşletmeler | Tüm Mekan ve İşletme Listesi',
  description: `Şanlıurfa'da ${totalCount > 0 ? totalCount + ' ' : ''}aktif işletme ve mekan. Restoran, kafe, market, hizmet noktaları ve daha fazlası.`,
  canonical: '/isletme',
  keywords: ['şanlıurfa işletmeler', 'urfa mekanlar listesi', 'şanlıurfa tüm işletmeler', 'urfa restoran listesi', 'şanlıurfa mekan ara', 'urfa işletme rehberi'],
  ogImage: '/images/hero/hero-home.webp',
};

const faqItems = [
  {
    S: 'Şanlıurfa işletme rehberinde nasıl arama yapabilirim?',
    C: 'Kategori kartlarından ilgilendiğiniz sektörü seçin ya da arama sayfasından isim veya adres ile sorgulayın.',
  },
  {
    S: 'İşletmemi bu platforma nasıl ekleyebilirim?',
    C: "İşletme Ekle sayfasından başvurabilirsiniz. Başvurular 24-48 saat içinde incelenir.",
  },
  {
    S: 'İşletme bilgileri nasıl güncellenir?',
    C: 'İşletme sahibi hesabıyla giriş yaparak bilgilerinizi düzenleyebilir veya güncelleme talebi oluşturabilirsiniz.',
  },
];
---

<Layout seo={seo}>
  <div class="min-h-screen bg-gray-50">
    <!-- Hero -->
    <div class="bg-gradient-to-br from-slate-800 to-slate-900 text-white py-16">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold uppercase tracking-widest text-slate-400 mb-2">İŞLETME REHBERİ</p>
          <h1 class="text-4xl md:text-5xl font-bold mb-4">Şanlıurfa İşletmeleri</h1>
          <p class="text-xl text-slate-300 max-w-2xl">
            Restoranlardan hizmet noktalarına, marketlerden sağlık kuruluşlarına — Şanlıurfa’nın tüm işletmeleri tek platformda.
          </p>
          {totalCount > 0 && (
            <p class="mt-4 text-sm text-slate-400">{totalCount} aktif işletme kayıtlı</p>
          )}
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/isletme-kayit" class="inline-flex items-center gap-2 rounded-lg bg-red-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-red-500 transition-colors">
              + İşletmenizi Ekleyin
            </a>
            <a href="/arama" class="inline-flex items-center gap-2 rounded-lg bg-white/10 border border-white/20 px-5 py-2.5 text-sm font-semibold text-white hover:bg-white/20 transition-colors">
              İşletme Ara
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="container mx-auto px-4 py-10">

      <!-- Hızlı Bilgi -->
      <div class="rounded-2xl border border-slate-200 bg-white p-5 mb-8 shadow-sm">
        <h2 class="text-base font-bold text-slate-900">Hızlı Cevap</h2>
        <p class="mt-1 text-sm text-slate-600">
          Şanlıurfa işletme rehberi; restoran, kafe, sağlık kuruluşu, market, eğitim merkezi ve yerel hizmet noktalarını kapsar.
          Her işletme için adres, telefon, çalışma saatleri ve kullanıcı yorumları mevcuttur.
        </p>
      </div>

      <!-- Kategoriler -->
      {categories.length > 0 && (
        <section class="mb-12">
          <h2 class="text-2xl font-bold text-slate-900 mb-6">Kategoriler</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
            {categories.map((cat) => (
              <a
                href={`/mekanlar/${cat.slug}`}
                class="group rounded-xl border border-slate-200 bg-white p-4 shadow-sm hover:border-red-300 hover:shadow-md transition-all"
              >
                {cat.icon && <span class="text-2xl mb-2 block">{cat.icon}</span>}
                <p class="font-semibold text-slate-800 group-hover:text-red-700 transition-colors">{cat.name}</p>
                <p class="text-xs text-slate-500 mt-0.5">{cat.place_count} işletme</p>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Öne Çıkan İşletmeler -->
      {featuredPlaces.length > 0 && (
        <section class="mb-12">
          <h2 class="text-2xl font-bold text-slate-900 mb-6">Öne Çıkan İşletmeler</h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
            {featuredPlaces.map((place) => (
              <a
                href={`/isletme/${place.slug}`}
                class="group rounded-xl border border-slate-200 bg-white p-4 shadow-sm hover:border-red-300 hover:shadow-md transition-all"
              >
                <div class="flex items-start justify-between gap-2 mb-2">
                  <p class="font-semibold text-slate-800 group-hover:text-red-700 transition-colors leading-tight">{place.name}</p>
                  {place.is_verified && (
                    <span class="shrink-0 text-xs bg-green-50 text-green-700 border border-green-200 px-1.5 py-0.5 rounded-full">✓</span>
                  )}
                </div>
                {place.short_description && (
                  <p class="text-xs text-slate-500 mb-3 line-clamp-2">{place.short_description}</p>
                )}
                <div class="flex items-center justify-between">
                  <span class="text-xs text-slate-400">{place.category_name}</span>
                  {place.rating && (
                    <span class="text-xs font-semibold text-amber-600">★ {Number(place.rating).toFixed(1)}</span>
                  )}
                </div>
                {place.district_name && (
                  <p class="text-xs text-slate-400 mt-1">{place.district_name}</p>
                )}
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- İşletme Sahibi CTA -->
      <section class="rounded-2xl border border-red-100 bg-red-50 p-6 mb-12">
        <div class="flex flex-col md:flex-row md:items-center gap-4 justify-between">
          <div>
            <h2 class="text-lg font-bold text-red-900">İşletmenizi platforma ekleyin</h2>
            <p class="text-sm text-red-800 mt-1">
              Şanlıurfa’da işletme sahibi misiniz? Ücretsiz listeleme ile müşterilerinize ulaşın.
            </p>
          </div>
          <a
            href="/isletme-kayit"
            class="shrink-0 rounded-lg bg-red-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-red-500 transition-colors text-center"
          >
            Başvuru Formu
          </a>
        </div>
      </section>

      <!-- FAQ -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-6">Sık Sorulan Sorular</h2>
        <div class="space-y-3">
          {faqItems.map((item) => (
            <details class="rounded-xl border border-slate-200 bg-white shadow-sm group">
              <summary class="flex cursor-pointer items-center justify-between p-4 font-semibold text-slate-800 hover:text-red-700 transition-colors list-none">
                {item.S}
                <span class="ml-4 shrink-0 text-slate-400 group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="px-4 pb-4 text-sm text-slate-600">{item.C}</p>
            </details>
          ))}
        </div>
      </section>

    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Şanlıurfa İşletme Rehberi',
    description: 'Şanlıurfa\'da aktif işletme ve mekan listesi',
    url: `${baseUrl}/isletme`,
    numberOfItems: totalCount || undefined,
    itemListElement: featuredPlaces.slice(0, 5).map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'LocalBusiness',
        '@id': `${baseUrl}/isletme/${p.slug}`,
        name: p.name,
        url: `${baseUrl}/isletme/${p.slug}`,
        address: { '@type': 'PostalAddress', addressLocality: p.district_name || 'Şanlıurfa', addressCountry: 'TR' },
      },
    })),
  })} is:inline />

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map(item => ({
      '@type': 'Question',
      name: item.S,
      acceptedAnswer: { '@type': 'Answer', text: item.C },
    })),
  })} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Anasayfa', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'İşletmeler', item: `${baseUrl}/isletme` },
    ],
  })} is:inline />
</Layout>