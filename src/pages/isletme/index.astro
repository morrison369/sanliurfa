---
import ListingTemplate from '../../components/templates/ListingTemplate.astro';
import { query } from '../../lib/postgres';
import { logger } from '../../lib/logging';
import { buildPageSeo } from '../../lib/seo/pageSeo';
import { getCachedPublicRouteData } from '../../lib/public-route-cache';

let categories: any[] = [];
let featuredPlaces: any[] = [];
let totalCount = 0;

try {
 const data = await getCachedPublicRouteData('page:isletme:index', async () => {
  const [catResult, featResult, countResult] = await Promise.all([
  query(
  `SELECT c.id, c.name, c.slug, c.icon,
  COUNT(p.id)::int AS place_count
  FROM categories c
  LEFT JOIN places p ON p.category_id = c.id AND p.status = 'active'
  WHERE c.is_active = true AND c.parent_id IS NOT NULL
  GROUP BY c.id
  HAVING COUNT(p.id) > 0
  ORDER BY COUNT(p.id) DESC
  LIMIT 12`,
  []
  ),
  query(
  `SELECT p.id, p.name, p.slug, p.short_description, p.address,
  p.rating, p.review_count, p.price_range, p.is_verified,
  c.name AS category_name, c.slug AS category_slug,
  d.name AS district_name
  FROM places p
  LEFT JOIN categories c ON c.id = p.category_id
  LEFT JOIN districts d ON d.id = p.district_id
  WHERE p.status = 'active' AND p.is_featured = true
  ORDER BY p.rating DESC NULLS LAST, p.review_count DESC NULLS LAST
  LIMIT 9`,
  []
  ),
  query(`SELECT COUNT(*)::int AS total FROM places WHERE status = 'active'`, []),
  ]);
  return {
   categories: catResult.rows,
   featuredPlaces: featResult.rows,
   totalCount: countResult.rows[0]?.total || 0,
  };
 });
 categories = data.categories;
 featuredPlaces = data.featuredPlaces;
 totalCount = data.totalCount;
} catch (e) {
 logger.error('isletme/index error', e instanceof Error ? e : new Error(String(e)));
}

const categoryIcons: Record<string, string> = {
 kebap: '🥩', restoran: '🍽️', yemek: '🍽️', cafe: '☕', kafe: '☕',
 otel: '🏨', konaklama: '🏨', market: '🛍️', alışveriş: '🛒',
 sağlık: '⚕️', hastane: '⚕️', eczane: '💊', eğitim: '📚',
 spor: '⚽', güzellik: '💅', eğlence: '🎭', park: '🌿',
 banka: '🏦', ulaşım: '🚌', tatlı: '🍮', fırın: '🥖',
};
const getIcon = (name: string) => {
 const l = (name || '').toLowerCase();
 for (const [k, v] of Object.entries(categoryIcons)) if (l.includes(k)) return v;
 return '📍';
};

const seo = buildPageSeo({
 title: `Şanlıurfa İşletmeler${totalCount > 0 ? ` — ${totalCount} Mekan` : ''} | Sanliurfa.com`,
 description: `Şanlıurfa'nın tüm mekan ve işletme rehberi. Restoranlar, kafeler, oteller, sağlık kuruluşları${totalCount > 0 ? ` ve daha ${totalCount} kayıt` : ''}.`,
 canonical: '/isletme',
 keywords: ['şanlıurfa işletmeler', 'urfa mekanlar', 'şanlıurfa restoran', 'urfa rehber'],
});

const faqItems = [
 { S: 'Şanlıurfa işletme rehberinde nasıl arama yapabilirim?', C: 'Kategori kartlarından ilgilendiğiniz sektörü seçin ya da arama sayfasından isim veya adres ile sorgulayın.' },
 { S: 'İşletmemi platforma nasıl eklerim?', C: 'İşletme Ekle sayfasından başvurabilirsiniz. Başvurular 24-48 saat içinde incelenir.' },
 { S: 'İşletme bilgileri nasıl güncellenir?', C: 'İşletme sahibi hesabıyla giriş yaparak bilgilerinizi düzenleyebilirsiniz.' },
];
---

<ListingTemplate
 seo={seo}
 eyebrow="Şanlıurfa İşletme Rehberi"
 title="Tüm Mekanlar"
 description={`Restoranlardan hizmet noktalarına, marketlerden sağlık kuruluşlarına kadar ${totalCount > 0 ? totalCount : 'tüm'} Şanlıurfa işletmesini tek platformda inceleyin.`}
 actions={[
  { href: '/isletme-kayit', label: 'İşletme Ekle', variant: 'primary' },
  { href: '/arama', label: 'Mekan Ara', variant: 'ghost' },
 ]}
 stats={[
  { label: 'Toplam Kayıt', value: totalCount || 0 },
  { label: 'Kategori', value: categories.length },
  { label: 'Öne Çıkan', value: featuredPlaces.length },
 ]}
 quickAnswerTitle="Hızlı cevap"
 quickAnswerText="Kategori kartlarından sektör seçebilir, öne çıkan işletmeleri puan ve ilçe bilgisiyle hızlıca karşılaştırabilirsiniz."
>
 <style is:inline>
 /* cat grid */
 .il-cat-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(184,115,51,0.08); }
 @media(min-width:480px){.il-cat-grid{grid-template-columns:repeat(4,1fr);}}
 @media(min-width:768px){.il-cat-grid{grid-template-columns:repeat(6,1fr);}}
 .il-cat-card { background:var(--bg-surface);padding:1.4rem 0.5rem;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;text-decoration:none;gap:0.4rem;transition:background 0.15s; }
 .il-cat-card:hover { background:var(--bg-hover); }
 .il-cat-icon { font-size:1.6rem; }
 .il-cat-name { font-size:0.72rem;font-weight:600;letter-spacing:0.04em;color:var(--public-accent); }
 .il-cat-count { font-size:0.62rem;color:var(--public-muted); }
 /* place grid */
 .il-place-grid { display:grid;grid-template-columns:1fr;gap:1px;background:rgba(184,115,51,0.08); }
 @media(min-width:640px){.il-place-grid{grid-template-columns:repeat(2,1fr);}}
 @media(min-width:1024px){.il-place-grid{grid-template-columns:repeat(3,1fr);}}
 .il-place-card { background:var(--bg-card);text-decoration:none;padding:1.5rem;display:flex;flex-direction:column;gap:0.4rem;transition:background 0.2s; }
 .il-place-card:hover { background:var(--bg-hover); }
 .il-place-cat { font-size:0.62rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--public-accent); }
 .il-place-name { font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:600;color:var(--public-text);line-height:1.25; }
 .il-place-desc { font-size:0.78rem;color:var(--public-muted);line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden; }
 .il-place-meta { display:flex;align-items:center;gap:0.75rem;margin-top:auto;padding-top:0.75rem;border-top:1px solid rgba(184,115,51,0.08); }
 .il-place-rating { font-size:0.75rem;font-weight:600;color:var(--public-accent); }
 .il-place-badge { font-size:0.6rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#17B8A6;border:1px solid rgba(23,184,166,0.3);border-radius:2px;padding:0.1rem 0.35rem; }
 .il-place-district { font-size:0.72rem;color:var(--public-muted);margin-left:auto; }
 /* faq */
 .il-faq { border-top:1px solid rgba(184,115,51,0.1); }
 .il-faq summary { padding:1.1rem 1.25rem;font-size:0.9rem;font-weight:600;color:var(--public-accent);cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;transition:color 0.15s; }
 .il-faq summary:hover { color:var(--public-text); }
 .il-faq summary::after { content:'↓';font-size:0.7rem;color:var(--public-accent);transition:transform 0.2s; }
 .il-faq details[open] summary::after { transform:rotate(180deg); }
 .il-faq details + details { border-top:1px solid rgba(184,115,51,0.08); }
 .il-faq-answer { padding:0 1.25rem 1.25rem;font-size:0.85rem;color:var(--public-muted);line-height:1.7; }
 /* cta strip */
 .il-cta { padding:3rem;background:rgba(184,115,51,0.04);border:1px solid rgba(184,115,51,0.12);display:flex;flex-direction:column;gap:1.5rem;align-items:flex-start; }
 @media(min-width:768px){.il-cta{flex-direction:row;align-items:center;justify-content:space-between;}}
 </style>

 <!-- Kategoriler -->
 {categories.length > 0 && (
 <section style="padding:4rem 0;">
 <div class="sf-container">
 <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:2rem;gap:1rem;">
 <div>
 <p class="sf-section-label">Mekan Türleri</p>
 <h2 class="sf-section-title">Kategoriler</h2>
 </div>
 <a href="/arama" class="sf-section-link">Tüm Kategoriler</a>
 </div>
 </div>
 <div class="il-cat-grid" role="list" aria-label="İşletme kategorileri">
 {categories.map(cat => (
 <a href={`/mekanlar/${cat.slug}`} class="il-cat-card" role="listitem" aria-label={cat.name}>
 <span class="il-cat-icon" aria-hidden="true">{getIcon(cat.name)}</span>
 <span class="il-cat-name">{cat.name}</span>
 <span class="il-cat-count">{cat.place_count} mekan</span>
 </a>
 ))}
 </div>
 </section>
 )}

 <!-- Öne Çıkan İşletmeler -->
 {featuredPlaces.length > 0 && (
 <section style="padding:0 0 4rem;">
 <div class="sf-container" style="margin-bottom:2rem;">
 <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:1rem;">
 <div>
 <p class="sf-section-label">Öne Çıkanlar</p>
 <h2 class="sf-section-title">Seçkin İşletmeler</h2>
 </div>
 <a href="/arama" class="sf-section-link">Hepsini Gör</a>
 </div>
 </div>
 <div class="il-place-grid" role="list" aria-label="Öne çıkan işletmeler">
 {featuredPlaces.map(place => (
 <a href={`/isletme/${place.slug}`} class="il-place-card" role="listitem" aria-label={place.name}>
 {place.category_name && <span class="il-place-cat">{place.category_name}</span>}
 <h3 class="il-place-name">{place.name}</h3>
 {place.short_description && <p class="il-place-desc">{place.short_description}</p>}
 <div class="il-place-meta">
 {place.rating && <span class="il-place-rating">★ {Number(place.rating).toFixed(1)}</span>}
 {place.is_verified && <span class="il-place-badge">Onaylı</span>}
 {place.district_name && <span class="il-place-district">{place.district_name}</span>}
 </div>
 </a>
 ))}
 </div>
 </section>
 )}

 <!-- İşletme CTA -->
 <div class="sf-container" style="padding-bottom:4rem;">
 <div class="il-cta">
 <div>
 <h2 style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:600;color:var(--public-text);margin-bottom:0.5rem;">
 İşletmenizi platforma ekleyin
 </h2>
 <p style="font-size:0.85rem;color:var(--public-muted);line-height:1.6;">
 Şanlıurfa'da işletme sahibi misiniz? Ücretsiz listeleme ile müşterilerinize ulaşın.
 </p>
 </div>
 <a href="/isletme-kayit" class="sf-btn-primary" style="flex-shrink:0;">Başvuru Formu</a>
 </div>
 </div>

 <!-- FAQ -->
 <div class="sf-container" style="padding-bottom:5rem;">
 <p class="sf-section-label" style="margin-bottom:1.5rem;">Sık Sorulan Sorular</p>
 <div class="il-faq" style="border:1px solid rgba(184,115,51,0.12);">
 {faqItems.map(item => (
 <details>
 <summary>{item.S}</summary>
 <p class="il-faq-answer">{item.C}</p>
 </details>
 ))}
 </div>
 </div>

 <script type="application/ld+json" set:html={JSON.stringify({
 '@context': 'https://schema.org',
 '@type': 'ItemList',
 name: 'Şanlıurfa İşletme Rehberi',
 url: 'https://sanliurfa.com/isletme',
 numberOfItems: totalCount || undefined,
 itemListElement: featuredPlaces.slice(0, 5).map((p, i) => ({
 '@type': 'ListItem',
 position: i + 1,
 item: {
 '@type': 'LocalBusiness',
 '@id': `https://sanliurfa.com/isletme/${p.slug}`,
 name: p.name,
 url: `https://sanliurfa.com/isletme/${p.slug}`,
 address: { '@type': 'PostalAddress', addressLocality: p.district_name || 'Şanlıurfa', addressCountry: 'TR' },
 },
 })),
 })} is:inline />
</ListingTemplate>
