---
import { randomBytes } from 'node:crypto';

interface PlaceItem {
  id: string;
  name: string;
  lat: number;
  lon: number;
  category?: string;
  thumbnail?: string;
  rating?: number;
  slug?: string;
}

interface Props {
  places: PlaceItem[];
  center?: [number, number];
  zoom?: number;
  height?: string;
  singlePlace?: boolean;
  showCategoryFilter?: boolean;
}

const {
  places,
  center = [37.1592, 38.7969],
  zoom = 13,
  height = '500px',
  singlePlace = false,
  showCategoryFilter = false,
} = Astro.props;

const mapId = `map-${randomBytes(6).toString('hex')}`;
const mapDataId = `${mapId}-data`;

const categories = showCategoryFilter
  ? ([...new Set(places.map(p => p.category).filter(Boolean))] as string[])
  : [];

const mapData = JSON.stringify({ places, center, zoom, singlePlace, showCategoryFilter });
---

<div class="lm-wrapper" data-leaflet-map-root data-map-id={mapId} data-map-data-id={mapDataId}>
  {showCategoryFilter && categories.length > 0 && (
    <div class="lm-filters" id={`${mapId}-filters`}>
      <button class="lm-filter-btn lm-filter-active" data-category="">Tümü</button>
      {categories.map(cat => (
        <button class="lm-filter-btn" data-category={cat}>{cat}</button>
      ))}
    </div>
  )}
  <div id={mapId} class="lm-canvas" style={`--lm-height: ${height}; width: 100%; border-radius: 1rem; z-index: 1;`}></div>
</div>

<script id={mapDataId} type="application/json" set:html={mapData} is:inline></script>

<script>
 import { initLeafletMaps } from './leaflet-map.client';

 initLeafletMaps();
</script>

<style>
  .lm-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    height: 100%;
  }

  /* Harita yüksekliği — desktop'ta prop'tan gelir (--lm-height), mobilde 320px'e düşer */
  .lm-canvas {
    height: var(--lm-height, 500px);
  }
  @media (max-width: 640px) {
    .lm-canvas {
      height: 320px;
    }
  }

  .lm-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    padding: 0.25rem 0;
  }

  .lm-filter-btn {
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    border: 1px solid rgba(184, 115, 51, 0.3);
    background: rgba(184, 115, 51, 0.06);
    color: #4A3828;
    font-size: 0.8125rem;
    font-family: 'Jost', sans-serif;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }

  .lm-filter-btn:hover {
    background: rgba(184, 115, 51, 0.15);
    color: #1F1410;
  }

  .lm-filter-active {
    background: #B87333 !important;
    border-color: #B87333 !important;
    color: #0D0A08 !important;
    font-weight: 600;
  }

  .lm-locate-btn {
    cursor: pointer;
    width: 44px !important;
    height: 44px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    font-size: 20px;
    line-height: 1 !important;
    text-decoration: none !important;
  }

  :global(.leaflet-popup-content-wrapper) {
    border-radius: 12px !important;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15) !important;
  }

  :global(.leaflet-popup-content) {
    margin: 12px !important;
  }

  :global(.leaflet-container) {
    font-family: system-ui, -apple-system, sans-serif;
  }

  :global(.leaflet-control-attribution a) {
    display: inline-flex;
    align-items: center;
    min-height: 24px;
    padding-inline: 0.125rem;
  }
</style>
