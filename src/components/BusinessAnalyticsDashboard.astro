---
import LoadingWrapper from './ui/LoadingWrapper.astro';
import { UI_COPY_TR } from '../lib/ui-copy';

interface Props {
  placeId?: string;
}

const { placeId = '' } = Astro.props;
---

<div data-business-analytics-dashboard data-place-id={placeId} data-days="30">
  <LoadingWrapper
    loadingClass="space-y-4"
    loadingDataAttr="data-business-analytics-loading"
    message={UI_COPY_TR.businessAnalytics.loading}
    variant="skeleton"
    skeletonCount={6}
    skeletonItemClass="h-20 animate-pulse rounded-lg bg-gray-200"
    contentDataAttr="data-business-analytics-content"
    contentClass="hidden"
  />
</div>

<script>
  import { initBusinessAnalyticsDashboard } from '../scripts/business-analytics-dashboard';

  initBusinessAnalyticsDashboard();
</script>
