---
import Layout from '../../layouts/Layout.astro';

type Action = {
 href: string;
 label: string;
 variant?: 'primary' | 'ghost';
};

type Stat = {
 label: string;
 value: string | number;
};

type BreadcrumbItem = {
 href?: string;
 label: string;
};

interface Props {
 seo: any;
 title: string;
 description?: string;
 eyebrow?: string;
 quickAnswerTitle?: string;
 quickAnswerText?: string;
 actions?: Action[];
 stats?: Stat[];
 breadcrumbItems?: BreadcrumbItem[];
}

const {
 seo,
 title,
 description,
 eyebrow,
 quickAnswerTitle,
 quickAnswerText,
 actions = [],
 stats = [],
 breadcrumbItems = [],
} = Astro.props;
---

<Layout seo={seo}>
 {breadcrumbItems.length > 0 && (
  <div class="lt-breadcrumb">
   <div class="sf-container">
    <nav aria-label="Breadcrumb">
     {breadcrumbItems.map((item, index) => (
      <>
       {item.href ? <a href={item.href}>{item.label}</a> : <span class="lt-breadcrumb-current">{item.label}</span>}
       {index < breadcrumbItems.length - 1 && <span class="lt-breadcrumb-sep">/</span>}
      </>
     ))}
    </nav>
   </div>
  </div>
 )}

 <section class="lt-hero">
  <div class="sf-container">
   <div class="lt-hero-inner">
    {eyebrow && <p class="lt-eyebrow">{eyebrow}</p>}
    <h1 class="lt-title">{title}</h1>
    {description && <p class="lt-desc">{description}</p>}

    {actions.length > 0 && (
     <div class="lt-actions">
      {actions.map((action) => (
       <a href={action.href} class:list={['lt-action', action.variant === 'ghost' ? 'lt-action-ghost' : 'lt-action-primary']}>
        {action.label}
       </a>
      ))}
     </div>
    )}

    {stats.length > 0 && (
     <div class="lt-stats" aria-label="Sayfa özeti">
      {stats.map((stat) => (
       <div class="lt-stat">
        <span class="lt-stat-value">{stat.value}</span>
        <span class="lt-stat-label">{stat.label}</span>
       </div>
      ))}
     </div>
    )}

    {quickAnswerTitle && quickAnswerText && (
     <div class="lt-answer">
      <p class="lt-answer-label">{quickAnswerTitle}</p>
      <p class="lt-answer-text">{quickAnswerText}</p>
     </div>
    )}
   </div>
  </div>
 </section>

 <slot />
</Layout>

<style>
 .lt-breadcrumb {
  background: var(--bg);
  border-bottom: 1px solid rgba(184, 115, 51, 0.12);
  padding: 0.75rem 0;
 }

 .lt-breadcrumb nav {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.5rem;
  color: #7a6b58;
  font-size: 0.8rem;
 }

 .lt-breadcrumb a {
  display: inline-flex;
  align-items: center;
  min-height: 1.75rem;
  color: #7a6b58;
  text-decoration: none;
  transition: color 0.15s ease;
 }

 .lt-breadcrumb a:hover {
  color: #c4a882;
 }

 .lt-breadcrumb-current {
  color: #c4a882;
  font-weight: 600;
 }

 .lt-breadcrumb-sep {
  color: rgba(122, 107, 88, 0.7);
 }

 .lt-hero {
  position: relative;
  overflow: hidden;
  padding: clamp(3rem, 6vw, 5rem) 0 clamp(2.4rem, 5vw, 3.8rem);
  border-bottom: 1px solid rgba(184, 115, 51, 0.12);
  background:
   radial-gradient(circle at 18% 0%, rgba(212, 151, 24, 0.1) 0%, transparent 42%),
   radial-gradient(circle at 82% 100%, rgba(44, 122, 82, 0.08) 0%, transparent 40%),
   linear-gradient(180deg, #fbf6ec 0%, #f4ecd8 58%, #fbf6ec 100%);
 }

 .lt-hero-inner {
  max-width: 48rem;
  margin: 0 auto;
 }

 .lt-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  margin: 0 0 1rem;
  padding: 0.45rem 1rem;
  border: 1px solid rgba(44, 122, 82, 0.22);
  border-radius: 999px;
  background: rgba(44, 122, 82, 0.1);
  color: #1f5f40;
  font-size: 0.7rem;
  font-weight: 800;
  letter-spacing: 0.18em;
  text-transform: uppercase;
 }

 .lt-eyebrow::before {
  content: '';
  width: 0.45rem;
  height: 0.45rem;
  border-radius: 50%;
  background: #d49718;
 }

 .lt-title {
  margin: 0 0 0.9rem;
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(2.2rem, 5vw, 3.75rem);
  font-weight: 700;
  line-height: 1.08;
  background: linear-gradient(135deg, #c0571f 0%, #d49718 62%, #c0571f 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  color: #c0571f;
 }

 .lt-desc {
  max-width: 40rem;
  margin: 0;
  color: #3d2a1e;
  font-size: 1rem;
  line-height: 1.72;
 }

 .lt-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-top: 1.35rem;
 }

 .lt-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 2.8rem;
  padding: 0 1.2rem;
  border-radius: 999px;
  font-size: 0.88rem;
  font-weight: 700;
  text-decoration: none;
  transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
 }

 .lt-action:hover {
  transform: translateY(-1px);
 }

 .lt-action-primary {
  background: linear-gradient(135deg, #c0571f, #d49718);
  color: #fff6e1;
  box-shadow: 0 10px 24px -14px rgba(192, 87, 31, 0.55);
 }

 .lt-action-ghost {
  border: 1px solid rgba(192, 87, 31, 0.2);
  background: rgba(255, 255, 255, 0.78);
  color: #7a5b42;
 }

 .lt-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  margin-top: 1.5rem;
 }

 .lt-stat {
  min-width: 8rem;
  padding: 0.9rem 1rem;
  border: 1px solid rgba(192, 87, 31, 0.14);
  border-radius: 1rem;
  background: rgba(255, 255, 255, 0.86);
  box-shadow: 0 10px 24px -20px rgba(31, 20, 16, 0.45);
 }

 .lt-stat-value {
  display: block;
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: 1.7rem;
  font-weight: 800;
  line-height: 1;
  color: #c0571f;
 }

 .lt-stat-label {
  display: block;
  margin-top: 0.3rem;
  color: #6d5945;
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
 }

 .lt-answer {
  max-width: 40rem;
  margin-top: 1.15rem;
  padding: 1rem 1.1rem;
  border: 1px solid rgba(192, 87, 31, 0.14);
  border-radius: 1rem;
  background: rgba(255, 255, 255, 0.72);
 }

 .lt-answer-label {
  margin: 0 0 0.25rem;
  color: #c0571f;
  font-size: 0.72rem;
  font-weight: 800;
  letter-spacing: 0.16em;
  text-transform: uppercase;
 }

 .lt-answer-text {
  margin: 0;
  color: #5a4030;
  font-size: 0.95rem;
  line-height: 1.7;
 }

 @media (max-width: 640px) {
  .lt-actions,
  .lt-stats {
   gap: 0.65rem;
  }

  .lt-action {
   width: 100%;
  }

  .lt-stat {
   flex: 1 1 calc(50% - 0.65rem);
   min-width: 0;
  }
 }
</style>
