---
import LoadingWrapper from './ui/LoadingWrapper.astro';
import { UI_COPY_TR } from '../lib/ui-copy';
---

<div data-webhook-manager>
  <LoadingWrapper
    loadingClass="flex items-center justify-center py-12 text-sm text-slate-500"
    loadingDataAttr="data-webhook-manager-loading"
    message={UI_COPY_TR.webhooks.loading}
    contentDataAttr="data-webhook-manager-content"
    contentClass="hidden"
  />
</div>

<script>
  import { initWebhookManager } from '../scripts/webhook-manager';

  initWebhookManager();
</script>
