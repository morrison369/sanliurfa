<!-- ThemeScript.astro - FOUC prevention for the canonical light Şanlıurfa theme -->
<script is:inline>
 (function() {
   try {
     document.documentElement.classList.remove('dark');
     document.documentElement.dataset.theme = 'light';
     document.documentElement.style.colorScheme = 'light';

     // Older builds stored `theme=dark`; keep the site on its canonical public
     // palette until a complete dark theme exists.
     if (localStorage.getItem('theme') === 'dark') {
       localStorage.setItem('theme', 'light');
     }
   } catch {
     document.documentElement.classList.remove('dark');
     document.documentElement.dataset.theme = 'light';
   }
 })();
</script>
