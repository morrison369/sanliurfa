---
import Icon from '../Icon.astro';
import Image from '../Image.astro';
import { getPrimaryCityTaxonomyCategories } from '../../data/city-taxonomy';
import { getSiteSetting } from '../../lib/site-content';
import { getSanliurfaWeather } from '../../lib/weather/open-meteo';
import { query } from '../../lib/postgres';

const searchChipsFallback = [
  { label: 'Kebapçılar', href: '/mekanlar/yeme-icme-kebapcilar' },
  { label: 'Balıklıgöl', href: '/gezilecek-yerler/balikligol' },
  { label: 'Göbeklitepe', href: '/gezilecek-yerler/gobeklitepe' },
  { label: 'Kahvaltı', href: '/mekanlar/yeme-icme-kahvalti-mekanlari' },
  { label: 'Halfeti', href: '/ilceler/halfeti' },
  { label: 'Nöbetçi Eczane', href: '/saglik/nobetci-eczaneler' },
  { label: 'Otel', href: '/konaklama' },
];
const searchChipsSetting = await getSiteSetting('homepage.heroQuickLinks', {
  items: searchChipsFallback,
});
const searchChips = searchChipsSetting.items.length > 0 ? searchChipsSetting.items : searchChipsFallback;

const collageCards = [
  {
    title: 'Balıklıgöl',
    subtitle: 'Tarihi merkez',
    href: '/gezilecek-yerler/balikligol',
    image: '/images/places/balikligol.jpg',
    className: 'lg:col-span-7',
  },
  {
    title: 'Göbeklitepe',
    subtitle: 'Arkeoloji rotası',
    href: '/gezilecek-yerler/gobeklitepe',
    image: '/images/places/gobeklitepe.jpg',
    className: 'lg:col-span-5 lg:mt-10',
  },
  {
    title: 'Harran',
    subtitle: 'Kümbet evler',
    href: '/ilceler/harran',
    image: '/images/tarihi-yerler/harran-kumbet-evleri.jpg',
    className: 'lg:col-span-5 lg:-mt-4',
  },
  {
    title: 'Halfeti',
    subtitle: 'Saklı cennet',
    href: '/ilceler/halfeti',
    image: '/images/blog/halfeti.jpg',
    className: 'lg:col-span-7',
  },
];

const quickAccess = [
  {
    icon: 'map-pin',
    title: 'Mekanları Keşfet',
    desc: 'Restoran, kafe, otel ve yerel işletmeleri kategoriye göre incele.',
    href: '/mekanlar',
    cta: 'Mekanlara Git',
  },
  {
    icon: 'landmark',
    title: 'Gezilecek Yerler',
    desc: 'Balıklıgöl, Göbeklitepe, Harran ve şehir merkezindeki gezi noktalarını planla.',
    href: '/gezilecek-yerler',
    cta: 'Rotaları Gör',
  },
  {
    icon: 'cross',
    title: 'Nöbetçi Eczaneler',
    desc: 'Şanlıurfa ilçe bazlı güncel nöbetçi eczane bilgilerine hızlı ulaş.',
    href: '/saglik/nobetci-eczaneler',
    cta: 'Eczane Bul',
  },
  {
    icon: 'bus',
    title: 'Otobüs Saatleri',
    desc: 'Şehir içi ulaşım ve sık kullanılan hatlar için pratik bağlantılar.',
    href: '/ulasim/otobus-saatleri',
    cta: 'Saatlere Bak',
  },
  {
    icon: 'calendar-days',
    title: 'Etkinlikler',
    desc: 'Konser, sergi, festival ve yerel buluşmaları tek takvimde takip et.',
    href: '/etkinlikler',
    cta: 'Etkinlikleri Aç',
  },
  {
    icon: 'map',
    title: 'İlçeler',
    desc: 'Haliliye’den Halfeti’ye her ilçenin öne çıkan yerlerini keşfet.',
    href: '/ilceler',
    cta: 'İlçeleri İncele',
  },
];

const categories = getPrimaryCityTaxonomyCategories(14).map((category) => ({
  icon: category.icon,
  title: category.title,
  desc: category.description,
  href: category.href,
}));

const routes = [
  {
    title: 'Balıklıgöl ve Tarihi Çarşı Rotası',
    desc: 'Balıklıgöl çevresi, hanlar bölgesi, bakırcılar çarşısı ve geleneksel Urfa dokusunu aynı yürüyüşte birleştiren merkez rota.',
    href: '/gezilecek-yerler/balikligol',
    image: '/images/places/balikligol.jpg',
  },
  {
    title: 'Göbeklitepe ve Arkeoloji Rotası',
    desc: 'Tarihin sıfır noktasını, müze ziyaretini ve çevredeki arkeoloji duraklarını planlı bir gezi akışına dönüştür.',
    href: '/blog/gobeklitepe-rehberi-ziyaret-bilgileri',
    image: '/images/places/gobeklitepe.jpg',
  },
  {
    title: 'Halfeti ve Fırat Rotası',
    desc: 'Sakin şehir Halfeti, Fırat kıyısı, tekne rotaları ve fotoğraf duraklarıyla günü dolu geçiren keşif planı.',
    href: '/blog/halfetide-1-gun-tekne-turu',
    image: '/images/blog/halfeti.jpg',
  },
];

const districts = [
  ['Haliliye', 'Şehir merkezi, müzeler, çarşı ve yeme içme durakları.', 'haliliye'],
  ['Eyyübiye', 'Balıklıgöl çevresi, tarihi sokaklar ve kültür rotaları.', 'eyyubiye'],
  ['Karaköprü', 'Yeni yaşam alanları, kafeler ve aile dostu mekanlar.', 'karakopru'],
  ['Siverek', 'Karacadağ etkisi, yöresel lezzetler ve geniş ilçe hayatı.', 'siverek'],
  ['Viranşehir', 'Tarihi bağlantılar, yerel pazarlar ve ova kültürü.', 'viransehir'],
  ['Akçakale', 'Sınır hattı, tarım dokusu ve günlük şehir ihtiyaçları.', 'akcakale'],
  ['Harran', 'Kümbet evler, antik üniversite ve Mezopotamya izleri.', 'harran'],
  ['Birecik', 'Fırat kıyısı, kelaynaklar ve geçiş rotaları.', 'birecik'],
  ['Halfeti', 'Saklı kent, tekne turları ve Fırat manzarası.', 'halfeti'],
  ['Suruç', 'Ova kültürü, yerel ticaret ve ilçe rehberi.', 'suruc'],
  ['Ceylanpınar', 'Geniş arazi dokusu, sınır yaşamı ve yerel servisler.', 'ceylanpinar'],
  ['Bozova', 'Atatürk Barajı çevresi ve doğa odaklı kaçış noktaları.', 'bozova'],
  ['Hilvan', 'Merkez ile baraj havzası arasında sakin ilçe rotası.', 'hilvan'],
];

const todayItems = [
  {
    icon: 'calendar-check',
    title: 'Bugünkü etkinlikler',
    desc: 'Şehirde bugün öne çıkan konser, kültür sanat ve yerel buluşmaları incele.',
    href: '/etkinlikler/bugun',
  },
  {
    icon: 'cross',
    title: 'Nöbetçi eczaneler',
    desc: 'İlçe bazlı eczane bağlantılarına tek ekrandan ulaş.',
    href: '/saglik/nobetci-eczaneler',
  },
  {
    icon: 'search',
    title: 'Popüler aramalar',
    desc: 'Kebap, kahvaltı, Balıklıgöl ve otel aramalarını hızlı başlat.',
    href: '/arama',
  },
  {
    icon: 'bus',
    title: 'Güncel ulaşım bilgileri',
    desc: 'Otobüs ve uçak saatleri için şehir ulaşım sayfalarını aç.',
    href: '/ulasim/otobus-saatleri',
  },
  {
    icon: 'heart-handshake',
    title: 'Topluluk eşleşmeleri',
    desc: 'Fotoğraflı profil, kaydırma ve karşılıklı eşleşme deneyimini aç.',
    href: '/eslesme',
  },
];

const communityPanel = await getSiteSetting('homepage.communityPanel', {
  title: 'Şanlıurfa Topluluğu ve Eşleşme',
  description:
    'Şehir rehberi yalnızca mekan listesi değil; yerel profiller, takip, mesajlaşma ve swipe tabanlı eşleşme akışıyla yaşayan bir topluluk alanı.',
  items: [
    { label: 'Eşleşmeyi Aç', href: '/eslesme' },
    { label: 'Topluluğa Git', href: '/topluluk' },
    { label: 'Mesajları Gör', href: '/mesajlar' },
  ],
});
const communityPanelTitle = 'Şanlıurfa Topluluğu ve Eşleşme';
const communityFeatures = [
  {
    icon: 'heart-handshake',
    title: 'Eşleşme',
    desc: 'Şanlıurfa topluluğunda 4 fotoğraflı profil oluştur, sağa veya sola kaydır, karşılıklı beğenide eşleş.',
    href: '/eslesme',
    cta: communityPanel.items[0]?.label || 'Eşleşmeyi Aç',
  },
  {
    icon: 'users-round',
    title: 'Topluluk',
    desc: 'Yerel profilleri, takipleri, aktiviteleri ve şehir içi sosyal keşif akışını tek alanda gör.',
    href: '/topluluk',
    cta: communityPanel.items[1]?.label || 'Topluluğa Git',
  },
  {
    icon: 'message-circle',
    title: 'Mesajlaşma',
    desc: 'Eşleşme sonrası sohbeti ve yerel bağlantıları Sanliurfa.com hesabınla yönet.',
    href: '/mesajlar',
    cta: communityPanel.items[2]?.label || 'Mesajları Gör',
  },
];

const urfahaOzel = [
  { icon: 'flame', title: 'Sıra Gecesi Mekanları', desc: "Şanlıurfa'ya özgü sofra ve müzik geleneğiyle akşamları buluşturan geleneksel mekanlar.", href: '/sanliurfa-sira-gecesi-mekanlari' },
  { icon: 'beef', title: 'Kebapçılar', desc: 'Urfa kebabı, patlıcan kebabı ve çiğ köfteyle şehrin en köklü kebap ustaları.', href: '/mekanlar/yeme-icme-kebapcilar' },
  { icon: 'utensils', title: 'Ciğerciler', desc: "Ekmek arası ciğer kültürünün adresi; Urfa'nın sakatat geleneğini yaşatan işletmeler.", href: '/mekanlar/yeme-icme-cigerciler' },
  { icon: 'leaf', title: 'Çiğ Köfteciler', desc: 'Baharatlı iç harcı ve limon sıkımıyla şehrin vazgeçilmez sokak lezzeti.', href: '/mekanlar/yeme-icme-cig-kofteciler' },
  { icon: 'fish', title: 'Balıklıgöl Çevresi', desc: 'Kutsal gölün çevresinde kafe, çay bahçesi ve yerel lezzet durakları.', href: '/gezilecek-yerler/balikligol' },
  { icon: 'sailboat', title: 'Halfeti Gezi Noktaları', desc: "Saklı şehir Halfeti, tekne turları ve Fırat'ın en fotoğrafik kıyı durakları.", href: '/ilceler/halfeti' },
  { icon: 'landmark', title: 'Harran Gezilecek Yerler', desc: "Kümbet evler, antik üniversite kalıntıları ve Mezopotamya'nın izleri.", href: '/ilceler/harran' },
  { icon: 'shopping-basket', title: 'Yöresel Ürün Satıcıları', desc: 'İsot, biber salçası, fıstık ve el yapımı yerel ürünlerin satıldığı çarşı dükkanları.', href: '/alisveris/yoresel-urun-dukanlari' },
  { icon: 'hammer', title: 'Bakırcılar ve El İşi', desc: 'El dövmesi bakır kaplar, taş boncuk ve Urfa motifli el sanatı ürünleri.', href: '/alisveris/bakırcilar' },
  { icon: 'music', title: 'Düğün Salonları', desc: 'Şehir içi ve kır düğün salonları; kapasite, lokasyon ve fiyat bilgileri.', href: '/mekanlar/eglence-ve-sosyal-yasam-dugun-salonlari' },
];

const popularLinks = [
  ['Şanlıurfa kebapçıları', '/mekanlar/yeme-icme-kebapcilar'],
  ['Şanlıurfa kahvaltı mekanları', '/mekanlar/yeme-icme-kahvalti-mekanlari'],
  ['Balıklıgöl gezilecek yerler', '/gezilecek-yerler/balikligol'],
  ['Göbeklitepe nasıl gidilir', '/blog/gobeklitepe-rehberi-ziyaret-bilgileri'],
  ['Halfeti tekne turu', '/blog/halfetide-1-gun-tekne-turu'],
  ['Şanlıurfa otelleri', '/konaklama'],
  ['Şanlıurfa nöbetçi eczane', '/saglik/nobetci-eczaneler'],
  ['Şanlıurfa otobüs saatleri', '/ulasim/otobus-saatleri'],
  ['Harran gezilecek yerler', '/ilceler/harran'],
  ['Şanlıurfa sıra gecesi', '/sanliurfa-sira-gecesi-mekanlari'],
  ['Şanlıurfa eşleşme', '/eslesme'],
  ['Şanlıurfa topluluk', '/topluluk'],
];

let weatherTemp: number | null = null;
let weatherLabel = 'Güncel';
let weatherHumidity: number | null = null;
let pharmacyCount = 0;
let totalPlaceCount = 0;
let upcomingEventsCount = 0;

try {
  const [weatherResult, pharmacyResult, placeResult, eventResult] = await Promise.all([
    getSanliurfaWeather().catch(() => null),
    query('SELECT COUNT(*)::int AS count FROM pharmacies WHERE is_on_duty = true').catch(() => ({ rows: [] })),
    query("SELECT COUNT(*)::int AS count FROM places WHERE status = 'active'").catch(() => ({ rows: [] })),
    query("SELECT COUNT(*)::int AS count FROM events WHERE status = 'published' AND (end_date IS NULL OR end_date >= CURRENT_DATE) AND start_date <= CURRENT_DATE + INTERVAL '90 days'").catch(() => ({ rows: [] })),
  ]);
  if (weatherResult?.payload?.current) {
    weatherTemp = weatherResult.payload.current.temperature;
    weatherLabel = weatherResult.payload.current.weatherLabel;
    weatherHumidity = weatherResult.payload.current.humidity;
  }
  pharmacyCount = Number(pharmacyResult.rows[0]?.count || 0);
  totalPlaceCount = Number(placeResult.rows[0]?.count || 0);
  upcomingEventsCount = Number(eventResult.rows[0]?.count || 0);
} catch { /* silent */ }

const guidePosts = [
  ['Şanlıurfa’da Gezilecek En Güzel Yerler', 'Tarihi merkezden Göbeklitepe’ye uzanan güçlü gezi başlangıcı.', '/blog/sanliurfa-gezilecek-10-tarihi-yer'],
  ['Şanlıurfa’da Ne Yenir?', 'Kebap, lahmacun, çiğ köfte, isot ve yöresel sofralar için lezzet rehberi.', '/sanliurfada-ne-yenir'],
  ['Göbeklitepe Gezi Rehberi', 'Ziyaret saati, ulaşım ve çevre rotasıyla arkeoloji odaklı plan.', '/blog/gobeklitepe-rehberi-ziyaret-bilgileri'],
  ['Balıklıgöl Ziyaret Rehberi', 'Kutsal göl çevresi, hanlar bölgesi ve tarihi çarşı akışı.', '/gezilecek-yerler/balikligol'],
  ['Halfeti’de Ne Yapılır?', 'Tekne turu, Fırat manzarası ve sakin şehir deneyimi.', '/blog/halfetide-1-gun-tekne-turu'],
  ['Şanlıurfa’da Hafta Sonu Planı', 'Kısa sürede şehirden en iyi verimi almak için pratik rota.', '/bugun-sanliurfada-ne-yapilir'],
];
---

<!-- LCP boost: ana sayfa hero collage'ında ilk 2 görseli preload (AVIF first, WebP fallback).
     href + type ile browser format negotiation — sadece desteklenen formatı yükler.
     ~150-300ms LCP iyileştirmesi + JPG fallback eliminated (2026-05-13 perf optimization). -->
<link rel="preload" as="image" href="/images/places/balikligol.avif" type="image/avif" fetchpriority="high" />
<link rel="preload" as="image" href="/images/places/balikligol.webp" type="image/webp" fetchpriority="high" />
<link rel="preload" as="image" href="/images/places/gobeklitepe.avif" type="image/avif" />
<link rel="preload" as="image" href="/images/places/gobeklitepe.webp" type="image/webp" />

<div class="overflow-hidden bg-[#fff8ec] text-[#201711]">
  <section class="relative overflow-hidden bg-[#120c06]">
    {/* Hero background — local AVIF/WebP cascade (Pexels remote 607KB hero replaced 2026-05-13, LCP fix) */}
    <div
      class="absolute inset-0 opacity-35 hero-bg-image"
      aria-hidden="true"
    ></div>
    <style is:inline define:vars={{}}>{`
      .hero-bg-image {
        background-image: url('/images/hero/sanliurfa-landing.webp');
        background-image: -webkit-image-set(
          url('/images/hero/sanliurfa-landing.avif') type('image/avif'),
          url('/images/hero/sanliurfa-landing.webp') type('image/webp')
        );
        background-image: image-set(
          url('/images/hero/sanliurfa-landing.avif') type('image/avif'),
          url('/images/hero/sanliurfa-landing.webp') type('image/webp')
        );
        background-size: cover;
        background-position: center 40%;
      }
    `}</style>
    <div class="absolute inset-0 bg-gradient-to-r from-[#120c06]/95 via-[#120c06]/72 to-[#120c06]/30" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-[#120c06]/75 via-transparent to-transparent" aria-hidden="true"></div>

    <div class="relative z-10 mx-auto grid min-h-[calc(100svh-4rem)] w-full max-w-7xl items-center gap-10 px-4 py-10 sm:px-6 lg:grid-cols-[1.02fr_0.98fr] lg:px-8 lg:py-16">
      <div class="max-w-3xl hero-content">
        <p class="mb-4 inline-flex rounded-full border border-[#f4c56e]/35 bg-white/8 px-4 py-2 text-sm font-bold text-[#f4c56e] backdrop-blur-sm">
          Şanlıurfa şehir rehberi
        </p>
        <h1 class="font-display text-4xl font-semibold leading-[1.08] text-white sm:text-5xl lg:text-6xl">
          Şanlıurfa’yı Keşfetmenin En Kolay Yolu
        </h1>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-white/75">
          Balıklıgöl’den Göbeklitepe’ye, kebapçılardan nöbetçi eczanelere kadar Şanlıurfa’daki mekanları, rotaları ve günlük ihtiyaçları tek rehberde keşfet.
        </p>

        <form action="/arama" method="get" class="mt-8 rounded-2xl border border-white/15 bg-white p-2 shadow-2xl shadow-black/50">
          <div class="flex flex-col gap-2 sm:flex-row">
            <label class="sr-only" for="home-search">Şanlıurfa rehberinde ara</label>
            <div class="flex min-h-14 flex-1 items-center gap-3 rounded-xl bg-[#fff8ec] px-4">
              <Icon name="search" size={22} class="shrink-0 text-[#a4552e]" />
              <input
                id="home-search"
                name="q"
                type="search"
                autocomplete="off"
                placeholder="Mekan, ilçe, yemek, eczane veya gezilecek yer ara"
                class="h-14 w-full bg-transparent text-base font-semibold text-[#2b1c12] outline-none placeholder:text-[#8b765f]"
              />
            </div>
            <button class="min-h-14 rounded-xl bg-[#78331d] px-6 text-base font-black text-white shadow-lg shadow-[#78331d]/30 transition hover:bg-[#652918]">
              Ara
            </button>
          </div>
        </form>

        <div class="mt-4 flex flex-wrap gap-2" aria-label="Hızlı arama bağlantıları">
          {searchChips.map((chip) => (
            <a href={chip.href} class="rounded-full border border-white/25 bg-white/10 px-3.5 py-2 text-sm font-bold text-white/85 backdrop-blur-sm transition hover:border-[#f4c56e]/55 hover:bg-white/16 hover:text-white">
              {chip.label}
            </a>
          ))}
        </div>

        <div class="mt-8 flex flex-wrap items-center gap-x-8 gap-y-4 border-t border-white/15 pt-6">
          <div>
            <span class="block text-2xl font-black text-[#f4c56e]">{totalPlaceCount > 0 ? `${totalPlaceCount}+` : '195+'}</span>
            <span class="block text-xs font-bold uppercase tracking-wider text-white/55">Aktif Mekan</span>
          </div>
          <div class="hidden h-7 w-px bg-white/20 sm:block"></div>
          <div>
            <span class="block text-2xl font-black text-[#f4c56e]">{upcomingEventsCount > 0 ? upcomingEventsCount : '80+'}</span>
            <span class="block text-xs font-bold uppercase tracking-wider text-white/55">Etkinlik</span>
          </div>
          <div class="hidden h-7 w-px bg-white/20 sm:block"></div>
          <div>
            <span class="block text-2xl font-black text-[#f4c56e]">13</span>
            <span class="block text-xs font-bold uppercase tracking-wider text-white/55">İlçe</span>
          </div>
          <div class="hidden h-7 w-px bg-white/20 sm:block"></div>
          <div class="hidden sm:block">
            <span class="block text-2xl font-black text-[#f4c56e]">12.000</span>
            <span class="block text-xs font-bold uppercase tracking-wider text-white/55">Yıl Tarih</span>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4 lg:grid-cols-12">
        {collageCards.map((card, idx) => (
          <a href={card.href} class={`group relative min-w-0 min-h-44 overflow-hidden rounded-2xl border border-white/20 shadow-2xl shadow-black/50 ring-1 ring-white/10 transition duration-300 hover:ring-[#f4c56e]/30 ${card.className}`}>
            <Image src={card.image} alt={`${card.title} Şanlıurfa rehberi`} width={640} height={500} loading="eager" fetchpriority={idx === 0 ? 'high' : 'auto'} class="h-full min-h-44 w-full object-cover transition duration-700 group-hover:scale-[1.06]" />
            <span class="absolute inset-0 bg-gradient-to-t from-[#120c06]/88 via-[#120c06]/22 to-transparent"></span>
            <span class="absolute inset-0 bg-gradient-to-t from-[#78331d]/40 to-transparent opacity-0 transition duration-500 group-hover:opacity-100"></span>
            <span class="absolute bottom-4 left-4 right-4">
              <span class="block text-xs font-bold uppercase text-[#f4c56e]">{card.subtitle}</span>
              <span class="mt-1 block font-display text-2xl font-semibold text-white">{card.title}</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="sticky-widget border-b border-[#e8d9c4] bg-white shadow-sm">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 lg:divide-x lg:divide-[#e8d9c4]">

        <!-- Hava: mobilde sağ + alt border -->
        <div class="flex items-center gap-2.5 sm:gap-4 border-b border-r border-[#e8d9c4] py-4 pr-3 sm:py-5 sm:pr-4 lg:border-0 lg:py-6 lg:pr-6">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-[#fff4e1] text-[#78331d] sm:h-11 sm:w-11">
            <Icon name="thermometer" size={20} />
          </span>
          <div class="min-w-0">
            <p class="truncate text-[10px] font-black uppercase tracking-wide text-[#9a7a5c] sm:text-[11px] sm:tracking-wider">Hava</p>
            <p class="mt-0.5 text-lg font-black leading-none text-[#201711] sm:text-xl">
              {weatherTemp !== null ? `${Math.round(weatherTemp)}°C` : '--'}
            </p>
            <p class="mt-0.5 truncate text-xs font-medium text-[#66513d] sm:text-sm">{weatherLabel}</p>
