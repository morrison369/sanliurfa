---
interface Props {
  placeId?: string;
}

const { placeId = '' } = Astro.props;
---

<div data-marketing-campaign-builder data-place-id={placeId}>
  <div data-marketing-campaign-loading class="flex items-center justify-center p-8">
    <div class="h-12 w-12 animate-spin rounded-full border-b-2 border-blue-600"></div>
  </div>
  <div data-marketing-campaign-content class="hidden"></div>
</div>

<script>
  import { initMarketingCampaignBuilder } from '../scripts/marketing-campaign-builder';

  initMarketingCampaignBuilder();
</script>
