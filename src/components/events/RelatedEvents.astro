---
/**
 * RelatedEvents — Server Island
 *
 * "Benzer Etkinlikler" sidebar widget. Used with `server:defer` so the main event
 * detail content streams without waiting for the related-events query.
 *
 *   <RelatedEvents category={event.category} excludeId={event.id} server:defer>
 *     <div slot="fallback" class="..." />
 *   </RelatedEvents>
 */
import { query } from '../../lib/postgres';
import Image from '../Image.astro';
import { resolveContentImage } from '../../lib/content-images';
import { logger } from '../../lib/logging';

interface Props {
  category: string;
  excludeId: string | number;
}

const { category, excludeId } = Astro.props;

let relatedEvents: Array<{
  id: string | number;
  title: string;
  slug: string;
  image_url: string | null;
  start_date: string;
  location: string | null;
}> = [];

try {
  const result = await query(
    `SELECT id, title, slug, image_url, start_date, location
     FROM events
     WHERE status = 'published' AND category = $1 AND id != $2
       AND start_date >= CURRENT_DATE
     LIMIT 3`,
    [category, excludeId],
  );
  relatedEvents = result.rows;
} catch (e) {
  logger.error('RelatedEvents query failed', e instanceof Error ? e : new Error(String(e)));
}

const getEventImage = (ev: typeof relatedEvents[number]) =>
  resolveContentImage({
    category: 'etkinlikler',
    slug: ev?.slug,
    explicit: ev?.image_url,
    placeholder: '/images/placeholder-event.jpg',
    thumb: true,
  });
---

{relatedEvents.length > 0 && (
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
    <h3 class="font-semibold text-gray-900 dark:text-white mb-4">Benzer Etkinlikler</h3>
    <div class="space-y-4">
      {relatedEvents.map((related) => (
        <a href={`/etkinlikler/${related.slug}`} class="flex gap-3 group">
          <Image
            src={getEventImage(related)}
            alt={related.title}
            width={320}
            height={256}
            class="w-20 h-16 rounded-lg object-cover flex-shrink-0"
          />
          <div>
            <span class="text-xs text-urfa-600 dark:text-urfa-400">
              {new Date(related.start_date).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long' })}
            </span>
            <h4 class="font-medium text-gray-900 dark:text-white text-sm group-hover:text-urfa-600 dark:group-hover:text-urfa-400 transition-colors line-clamp-2">
              {related.title}
            </h4>
            <p class="text-xs text-gray-500 dark:text-gray-400">{related.location}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
)}
