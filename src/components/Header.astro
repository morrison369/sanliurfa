---
import NotificationBadge from './NotificationBadge';

interface Props {
  user?: { id: string; email?: string; fullName?: string; role?: string } | null;
}

const { user } = Astro.props;
const path = Astro.url.pathname;

const navLinks = [
  { href: '/mekanlar', label: 'Mekanlar' },
  { href: '/yeme-icme', label: 'Yeme İçme' },
  { href: '/saglik', label: 'Sağlık' },
  { href: '/saglik/nobetci-eczaneler', label: 'Eczaneler' },
  { href: '/konaklama', label: 'Oteller' },
  { href: '/gezilecek-yerler', label: 'Gezilecek Yerler' },
  { href: '/etkinlikler', label: 'Etkinlikler' },
  { href: '/ilceler', label: 'İlçeler' },
  { href: '/topluluk', label: 'Topluluk' },
  { href: '/blog', label: 'Blog' },
];

const isActive = (href: string) => href !== '/' && path.startsWith(href);
---

<header id="sf-header" class="sticky top-0 z-50 border-b border-[#eadcc4] bg-[#fffaf0]/92 backdrop-blur-xl">
  <div class="mx-auto flex h-16 w-full max-w-7xl items-center justify-between gap-4 px-4 sm:px-6 lg:px-8">
    <a href="/" class="flex min-h-11 min-w-0 items-center gap-1" aria-label="Sanliurfa.com ana sayfa">
      <span class="font-display text-[1.55rem] font-semibold leading-none text-[#201711]">
        Sanliurfa
      </span>
      <span class="text-[1.05rem] font-bold leading-none text-[#78331d]">.com</span>
    </a>

    <nav class="sf-main-nav hidden items-center gap-0.5 lg:flex" aria-label="Ana menü">
      {navLinks.map((item) => (
        <a
          href={item.href}
          class:list={[
                'whitespace-nowrap rounded-full px-2.5 py-2 text-xs font-semibold transition xl:px-3 xl:text-sm',
            isActive(item.href)
              ? 'bg-[#f1e3ce] text-[#8a3d22]'
              : 'text-[#604c3a] hover:bg-[#f7ecd9] hover:text-[#24160f]',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-2 lg:flex">
      <a
        href="/arama"
        aria-label="Ara"
        class="flex h-10 w-10 items-center justify-center rounded-full border border-[#d9c5a7] bg-white text-[#5c4938] transition hover:border-[#78331d] hover:text-[#78331d]"
      >
        <span aria-hidden="true">⌕</span>
      </a>
      <a
        href="/eslesme"
        class="rounded-full border border-[#d9c5a7] px-3 py-2 text-sm font-bold text-[#7b4129] transition hover:border-[#78331d] hover:bg-white"
      >
        Eşleşme
      </a>
      {user ? (
        <>
          <NotificationBadge client:visible />
          <a
            href={user.role === 'admin' ? '/admin' : '/profil'}
            class="rounded-full border border-[#d9c5a7] px-4 py-2 text-sm font-bold text-[#3d2c21] transition hover:border-[#78331d] hover:bg-white"
          >
            {user.role === 'admin' ? 'Admin Panel' : 'Profil'}
          </a>
        </>
      ) : (
        <a
          href="/isletme-kayit"
          class="whitespace-nowrap rounded-full bg-[#78331d] px-4 py-2 text-sm font-bold text-white shadow-sm shadow-[#78331d]/20 transition hover:bg-[#652918]"
        >
          İşletmeni Ekle
        </a>
      )}
    </div>

    <details class="group relative lg:hidden">
      <summary
        class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-full border border-[#decaa9] bg-white text-[#2d2118] [&::-webkit-details-marker]:hidden"
        aria-label="Menüyü aç"
        id="mobileMenuBtn"
      >
        <span class="sr-only">Menü</span>
        <span class="relative block h-4 w-5">
          <span class="absolute left-0 top-0 h-0.5 w-5 rounded bg-current transition group-open:top-2 group-open:rotate-45"></span>
          <span class="absolute left-0 top-2 h-0.5 w-5 rounded bg-current transition group-open:opacity-0"></span>
          <span class="absolute left-0 top-4 h-0.5 w-5 rounded bg-current transition group-open:top-2 group-open:-rotate-45"></span>
        </span>
      </summary>
      <div class="absolute right-0 mt-3 w-[min(20rem,calc(100vw-2rem))] rounded-2xl border border-[#eadcc4] bg-[#fffaf0] p-3 shadow-2xl shadow-[#2b1c12]/15">
        <nav class="grid gap-1" aria-label="Mobil menü">
          {navLinks.map((item) => (
            <a
              href={item.href}
              class:list={[
                'rounded-xl px-3 py-3 text-sm font-semibold',
                isActive(item.href)
                  ? 'bg-[#f1e3ce] text-[#8a3d22]'
                  : 'text-[#4f3d2e] hover:bg-[#f7ecd9]',
              ]}
            >
              {item.label}
            </a>
          ))}
          <a href="/isletme-kayit" class="mt-2 rounded-xl bg-[#78331d] px-3 py-3 text-center text-sm font-bold text-white">
            İşletmeni Ekle
          </a>
        </nav>
      </div>
    </details>
  </div>
</header>

<script is:inline>
  // Mobil menü: sayfa geçişinde ve dışarı tıklamada kapat
  function closeMobileMenu() {
    const d = document.querySelector('details.group');
    if (d) d.removeAttribute('open');
  }
  document.addEventListener('astro:page-load', closeMobileMenu);
  document.addEventListener('click', (e) => {
    const d = document.querySelector('details.group');
    if (d && d.open && !d.contains(e.target)) closeMobileMenu();
  });
</script>
