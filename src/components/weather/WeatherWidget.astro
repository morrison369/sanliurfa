---
// SVG ikonlar
const icons = {
  sun: `<svg class="w-8 h-8 text-white" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>`,
  cloud: `<svg class="w-5 h-5 text-gray-700 dark:text-gray-300" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/></svg>`,
  rain: `<svg class="w-5 h-5 text-gray-700 dark:text-gray-300" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 13v8"/><path d="M8 13v8"/><path d="M12 15v8"/><path d="M20 16.58A5 5 0 0 0 18 7h-1.26A8 8 0 1 0 4 15.25"/></svg>`,
  wind: `<svg class="w-4 h-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2"/></svg>`,
  droplets: `<svg class="w-4 h-4 text-blue-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.8-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/><path d="M12.56 12.85c1.25-.95 2.44-2.44 2.44-4.1 0-1.59-.91-3.05-2.44-3.95S9.56 3.55 9.56 2c.29 1.45 1.14 2.8 2.29 3.76S14 7.8 14 8.95c0 1.7-1.1 3.25-2.44 3.9z"/></svg>`,
  eye: `<svg class="w-4 h-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>`,
  thermometer: `<svg class="w-4 h-4 text-orange-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/></svg>`,
};

const weatherData = {
  current: {
    temp: 24,
    feelsLike: 26,
    condition: 'Güneşli',
    icon: icons.sun,
    humidity: 45,
    windSpeed: 12,
    visibility: 10,
    uvIndex: 6,
  },
  forecast: [
    { day: 'Pzt', icon: icons.sun, high: 26, low: 14 },
    { day: 'Sal', icon: icons.cloud, high: 24, low: 13 },
    { day: 'Çar', icon: icons.rain, high: 22, low: 12 },
    { day: 'Per', icon: icons.sun, high: 25, low: 14 },
    { day: 'Cum', icon: icons.sun, high: 27, low: 15 },
  ],
};
---

<div class="flex flex-col lg:flex-row items-center justify-between gap-6">
  <!-- Current Weather -->
  <div class="flex items-center gap-4">
    <div class="w-16 h-16 bg-gradient-to-br from-yellow-400 to-orange-500 rounded-2xl flex items-center justify-center text-white shadow-lg">
      <span set:html={weatherData.current.icon}></span>
    </div>
    <div>
      <div class="flex items-baseline gap-2">
        <span id="weather-temp" class="text-3xl font-bold text-gray-900 dark:text-white">{weatherData.current.temp}°C</span>
        <span id="weather-condition" class="text-gray-500 dark:text-gray-400">{weatherData.current.condition}</span>
      </div>
      <p id="weather-feels-like" class="text-sm text-gray-500 dark:text-gray-400">
        Hissedilen: {weatherData.current.feelsLike}°C
      </p>
    </div>
  </div>
  
  <!-- Weather Details -->
  <div class="flex items-center gap-6 text-sm">
    <div class="flex items-center gap-2 text-gray-600 dark:text-gray-300">
      <span set:html={icons.droplets}></span>
      <span id="weather-humidity">Nem: %{weatherData.current.humidity}</span>
    </div>
    <div class="flex items-center gap-2 text-gray-600 dark:text-gray-300">
      <span set:html={icons.wind}></span>
      <span id="weather-wind">Rüzgar: {weatherData.current.windSpeed} km/s</span>
    </div>
    <div class="flex items-center gap-2 text-gray-600 dark:text-gray-300">
      <span set:html={icons.eye}></span>
      <span id="weather-visibility">Görüş: {weatherData.current.visibility} km</span>
    </div>
    <div class="flex items-center gap-2 text-gray-600 dark:text-gray-300">
      <span set:html={icons.thermometer}></span>
      <span id="weather-uv">UV: {weatherData.current.uvIndex}</span>
    </div>
  </div>
  
  <!-- Forecast -->
  <div class="flex items-center gap-4">
    {weatherData.forecast.map((day, index) => (
      <div class="text-center px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors" data-forecast-index={index}>
        <div class="text-xs text-gray-500 dark:text-gray-400 mb-1 forecast-day">{day.day}</div>
        <span set:html={day.icon}></span>
        <div class="text-sm font-medium text-gray-900 dark:text-white forecast-high">{day.high}°</div>
        <div class="text-xs text-gray-500 dark:text-gray-400 forecast-low">{day.low}°</div>
      </div>
    ))}
  </div>
  
  <!-- Location -->
  <div class="text-right hidden lg:block">
    <div class="text-sm font-medium text-gray-900 dark:text-white">Şanlıurfa, TR</div>
    <div class="text-xs text-gray-500 dark:text-gray-400">Güncel hava durumu</div>
  </div>
</div>

<script is:inline>
  async function fetchWeather() {
    try {
      const response = await fetch('/api/weather/current');
      if (!response.ok) return;
      const body = await response.json();
      if (!body?.success || !body?.data) return;
      const current = body.data.current || {};
      const forecast = Array.isArray(body.data.forecast) ? body.data.forecast : [];

      const tempEl = document.getElementById('weather-temp');
      const conditionEl = document.getElementById('weather-condition');
      const feelsLikeEl = document.getElementById('weather-feels-like');
      const humidityEl = document.getElementById('weather-humidity');
      const windEl = document.getElementById('weather-wind');
      const visibilityEl = document.getElementById('weather-visibility');
      const uvEl = document.getElementById('weather-uv');

      if (tempEl && typeof current.temperature === 'number') tempEl.textContent = `${Math.round(current.temperature)}°C`;
      if (conditionEl && typeof current.weatherLabel === 'string') conditionEl.textContent = current.weatherLabel;
      if (feelsLikeEl && typeof current.feelsLike === 'number') feelsLikeEl.textContent = `Hissedilen: ${Math.round(current.feelsLike)}°C`;
      if (humidityEl && typeof current.humidity === 'number') humidityEl.textContent = `Nem: %${Math.round(current.humidity)}`;
      if (windEl && typeof current.windSpeed === 'number') windEl.textContent = `Rüzgar: ${Math.round(current.windSpeed)} km/s`;
      if (visibilityEl && typeof current.visibilityKm === 'number') visibilityEl.textContent = `Görüş: ${Math.round(current.visibilityKm)} km`;
      if (uvEl && typeof current.uvIndex === 'number') uvEl.textContent = `UV: ${Math.round(current.uvIndex)}`;

      const cards = document.querySelectorAll('[data-forecast-index]');
      cards.forEach((card, index) => {
        const day = card.querySelector('.forecast-day');
        const high = card.querySelector('.forecast-high');
        const low = card.querySelector('.forecast-low');
        const dayEntry = forecast[index] || {};
        if (day && typeof dayEntry.dayLabel === 'string') day.textContent = dayEntry.dayLabel;
        if (high && typeof dayEntry.high === 'number') high.textContent = `${Math.round(dayEntry.high)}°`;
        if (low && typeof dayEntry.low === 'number') low.textContent = `${Math.round(dayEntry.low)}°`;
      });
    } catch (error) {
      console.error('Weather fetch error:', error);
    }
  }

  fetchWeather();
  setInterval(fetchWeather, 30 * 60 * 1000);
</script>
