---
import { Picture } from 'astro:assets';

interface Props {
 src: string;
 alt: string;
 fallbackSrc?: string;
 width?: number;
 height?: number;
 class?: string;
 style?: string;
 loading?: 'lazy' | 'eager';
 decoding?: 'async' | 'sync' | 'auto';
 fetchpriority?: 'high' | 'low' | 'auto';
 formats?: ('avif' | 'webp' | 'jpeg' | 'png' | 'svg')[];
 fallbackFormat?: 'jpeg' | 'png' | 'svg';
 quality?: number;
}

const {
 src,
 alt,
 fallbackSrc,
 width = 800,
 height = 600,
 class: className = '',
 style,
 loading = 'lazy',
 decoding = 'async',
 fetchpriority = 'auto',
 formats = ['avif', 'webp'],
 fallbackFormat = 'jpeg',
 quality = 80
} = Astro.props;

// Remote image kontrolü
const isRemote = src.startsWith('http');
const authorizedRemoteHosts = new Set(['images.pexels.com', 'images.unsplash.com', 'source.unsplash.com']);
const shouldUseAstroPicture = (() => {
 if (!isRemote) return true;
 try {
 return authorizedRemoteHosts.has(new URL(src).hostname);
 } catch {
 return false;
 }
})();
const shouldUseFallbackImg = Boolean(fallbackSrc);
---

{shouldUseAstroPicture && !shouldUseFallbackImg ? (
 <Picture
 src={src}
 alt={alt}
 width={width}
 height={height}
 class={className}
 style={style}
 formats={formats}
 fallbackFormat={fallbackFormat}
 quality={quality}
 loading={loading}
 decoding={decoding}
 fetchpriority={fetchpriority}
 />
) : (
 <img
 src={src}
 alt={alt}
 width={width}
 height={height}
 class={className}
 style={style}
 loading={loading}
 decoding={decoding}
 fetchpriority={fetchpriority}
 onerror={`this.setAttribute('src',${JSON.stringify(fallbackSrc || '/images/placeholder.jpg')})`}
 />
)}
