---
import { Picture } from 'astro:assets';

interface Props {
 src: string;
 alt: string;
 fallbackSrc?: string;
 width?: number;
 height?: number;
 class?: string;
 style?: string;
 loading?: 'lazy' | 'eager';
 decoding?: 'async' | 'sync' | 'auto';
 fetchpriority?: 'high' | 'low' | 'auto';
 formats?: ('avif' | 'webp' | 'jpeg' | 'png' | 'svg')[];
 fallbackFormat?: 'jpeg' | 'png' | 'svg';
 quality?: number;
 /** LQIP shimmer placeholder — img-lqip class eklenir, görsel onload'da görünür */
 withShimmer?: boolean;
 /** Responsive sizes hint (örn. "(max-width: 768px) 100vw, 50vw") — srcset doğru kaynağı seçer */
 sizes?: string;
 /** Astro Picture için widths breakpoint array; verilirse srcset bu genişliklerde üretilir */
 widths?: number[];
}

const {
 src,
 alt,
 fallbackSrc,
 width = 800,
 height = 600,
 class: className = '',
 style,
 loading = 'lazy',
 decoding = 'async',
 fetchpriority = 'auto',
 formats = ['avif', 'webp'],
 fallbackFormat = 'jpeg',
 quality = 80,
 withShimmer = true,
 sizes,
 widths,
} = Astro.props;

const finalClass = withShimmer ? `${className} img-lqip`.trim() : className;

// Remote image kontrolü
const isRemote = src.startsWith('http');
const authorizedRemoteHosts = new Set(['images.pexels.com', 'images.unsplash.com', 'source.unsplash.com']);
const shouldUseAstroPicture = (() => {
 if (!isRemote) return true;
 try {
 return authorizedRemoteHosts.has(new URL(src).hostname);
 } catch {
 return false;
 }
})();
const shouldUseFallbackImg = Boolean(fallbackSrc);
---

{shouldUseAstroPicture && !shouldUseFallbackImg ? (
 <Picture
 src={src}
 alt={alt}
 width={width}
 height={height}
 class={finalClass}
 style={style}
 formats={formats}
 fallbackFormat={fallbackFormat}
 quality={quality}
 loading={loading}
 decoding={decoding}
 fetchpriority={fetchpriority}
 onload={withShimmer ? 'this.classList.add(\'img-lqip-loaded\')' : undefined}
 {...(sizes ? { sizes } : {})}
 {...(widths ? { widths } : {})}
 />
) : (
 <img
 src={src}
 alt={alt}
 width={width}
 height={height}
 class={finalClass}
 style={style}
 loading={loading}
 decoding={decoding}
 fetchpriority={fetchpriority}
 sizes={sizes}
 onload={withShimmer ? 'this.classList.add(\'img-lqip-loaded\')' : undefined}
 onerror={`this.setAttribute('src',${JSON.stringify(fallbackSrc || '/images/placeholder.jpg')});this.classList.add('img-lqip-loaded')`}
 />
)}
