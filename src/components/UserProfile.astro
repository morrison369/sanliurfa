---
import LoadingWrapper from './ui/LoadingWrapper.astro';
import { UI_COPY_TR } from '../lib/ui-copy';
---

<LoadingWrapper
  containerClass="container-custom"
  contentClass="hidden"
  contentDataAttr="data-user-profile-content"
  loadingClass="py-12 text-center text-gray-600"
  loadingDataAttr="data-user-profile-loading"
  message={UI_COPY_TR.profile.loading}
/>

<script>
  import { initUserProfile } from '../scripts/user-profile';

  initUserProfile();
</script>
