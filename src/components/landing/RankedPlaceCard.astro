---
/**
 * RankedPlaceCard — best-of landing sayfaları için sıralı mekan kartı.
 *
 * Pattern:
 *   <RankedPlaceCard place={p} rank={1} variant="restaurant" />
 *
 * - İlk 3 sıra için 🥇🥈🥉 emoji, sonrası numerik
 * - Astro Image (lazy, AVIF/WebP) — HARD RULE #26 uyumlu
 * - resolvePlaceImage helper ile görsel resolve (slug → /uploads/places/{slug}.jpg fallback)
 * - Rating + review_count + kategori + adres
 */
import Image from '../Image.astro';
import { Icon } from 'astro-icon/components';
import { resolvePlaceImage } from '../../lib/public-image-resolvers';
import type { LandingPlace } from '../../lib/landing/landing-schema';

interface Props {
  place: LandingPlace;
  rank: number;
  variant?: 'restaurant' | 'hotel' | 'attraction';
}

const { place, rank, variant = 'restaurant' } = Astro.props;

const rankBadge = rank === 1 ? '🥇' : rank === 2 ? '🥈' : rank === 3 ? '🥉' : String(rank);
const isTop3 = rank <= 3;

const fallbackIcon = variant === 'hotel'
  ? 'lucide:bed-double'
  : variant === 'attraction'
    ? 'lucide:landmark'
    : 'lucide:utensils';

const imageSrc = resolvePlaceImage({
  slug: place.slug,
  image_url: place.image_url ?? (Array.isArray(place.images) && place.images.length > 0 ? place.images[0] : null),
});

const ratingNum = typeof place.rating === 'number' ? place.rating : parseFloat(String(place.rating ?? ''));
const reviewNum = typeof place.review_count === 'number' ? place.review_count : parseInt(String(place.review_count ?? '0'), 10);
const hasRating = Number.isFinite(ratingNum) && ratingNum > 0;
const hasReviews = Number.isFinite(reviewNum) && reviewNum > 0;
---

<a href={`/isletme/${place.slug}`} class="rpc-card" data-top3={isTop3 ? 'true' : 'false'}>
  <div class="rpc-image-wrap">
    <div class="rpc-fallback" aria-hidden="true">
      <Icon name={fallbackIcon} class="rpc-fallback-icon" />
    </div>
    <Image
      src={imageSrc}
      alt={place.name}
      width={480}
      height={320}
      loading="lazy"
      class="rpc-image"
    />
    <div class="rpc-rank" aria-label={`${rank}. sıra`}>
      <span>{rankBadge}</span>
    </div>
  </div>

  <div class="rpc-body">
    <h3 class="rpc-name">{place.name}</h3>
    {place.category_name && <p class="rpc-cat">{place.category_name}</p>}
    {place.short_description && (
      <p class="rpc-desc">{place.short_description}</p>
    )}
    {place.address && !place.short_description && (
      <p class="rpc-addr">{place.address}</p>
    )}
    <div class="rpc-meta">
      {hasRating && <span class="rpc-rating">★ {ratingNum.toFixed(1)}</span>}
      {hasReviews && <span class="rpc-reviews">{reviewNum} yorum</span>}
      <span class="rpc-arrow" aria-hidden="true"><Icon name="lucide:arrow-right" /></span>
    </div>
  </div>
</a>

<style>
  .rpc-card {
    display: flex;
    background: var(--bg-card, #fff);
    border: 1px solid rgba(184, 115, 51, 0.16);
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
    min-height: 8rem;
  }
  .rpc-card:hover {
    border-color: var(--public-accent, #B87333);
    box-shadow: 0 4px 14px rgba(192, 87, 31, 0.08);
    transform: translateY(-1px);
  }
  .rpc-card[data-top3="true"] {
    border-color: rgba(212, 151, 24, 0.4);
  }
  .rpc-image-wrap {
    position: relative;
    width: 8.5rem;
    aspect-ratio: 4 / 3;
    flex-shrink: 0;
    background: var(--bg-surface, rgba(184, 115, 51, 0.06));
    overflow: hidden;
  }
  .rpc-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 0;
  }
  .rpc-fallback-icon {
    width: 2rem;
    height: 2rem;
    color: var(--public-accent, #B87333);
    opacity: 0.45;
  }
  .rpc-image,
  .rpc-image-wrap :global(picture) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    display: block;
    transition: transform 0.3s;
  }
  .rpc-card:hover .rpc-image,
  .rpc-card:hover .rpc-image-wrap :global(picture) {
    transform: scale(1.05);
  }
  .rpc-rank {
    position: absolute;
    top: 0.5rem;
    left: 0.5rem;
    z-index: 2;
    min-width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: rgba(13, 10, 8, 0.78);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 700;
    padding: 0 0.45rem;
  }
  .rpc-card[data-top3="true"] .rpc-rank {
    background: rgba(212, 151, 24, 0.92);
    color: #1F1410;
    font-size: 1.1rem;
  }
  .rpc-body {
    flex: 1;
    min-width: 0;
    padding: 0.85rem 1rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.2rem;
  }
  .rpc-name {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--public-text, #1F1410);
    line-height: 1.3;
  }
  .rpc-cat {
    margin: 0;
    font-size: 0.72rem;
    color: var(--public-muted, #7A6448);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
  }
  .rpc-desc {
    margin: 0.2rem 0 0;
    font-size: 0.82rem;
    color: var(--public-text-soft, #4A3828);
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .rpc-addr {
    margin: 0.2rem 0 0;
    font-size: 0.78rem;
    color: var(--public-muted, #7A6448);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .rpc-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 0.4rem;
    font-size: 0.78rem;
  }
  .rpc-rating {
    color: var(--public-accent, #B87333);
    font-weight: 700;
  }
  .rpc-reviews {
    color: var(--public-text-soft, #7A6448);
  }
  .rpc-arrow {
    margin-left: auto;
    color: var(--public-accent, #B87333);
    opacity: 0.6;
    transition: opacity 0.15s, transform 0.15s;
  }
  .rpc-arrow :global(svg) {
    width: 1rem;
    height: 1rem;
  }
  .rpc-card:hover .rpc-arrow {
    opacity: 1;
    transform: translateX(2px);
  }
  @media (max-width: 30rem) {
    .rpc-image-wrap { width: 6.5rem; }
    .rpc-body { padding: 0.65rem 0.85rem; }
  }
</style>
