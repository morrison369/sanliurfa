---
/**
 * Error Boundary Component
 * Catches errors in child components and displays fallback UI
 */

interface Props {
  fallback?: string;
}

const { fallback = 'Bir hata oluştu. Lütfen sayfayı yenileyin.' } = Astro.props;
---

<error-boundary class="error-boundary" data-fallback={fallback}>
  <slot />
</error-boundary>

<script>
  import * as Sentry from '@sentry/browser';

  class ErrorBoundary extends HTMLElement {
    connectedCallback() {
      const fallback = this.dataset.fallback || 'Bir hata oluştu.';
      
      window.addEventListener('error', (event) => {
        // Log to Sentry
        Sentry.captureException(event.error);
        
        // Show fallback UI
        this.showError(fallback);
      });
      
      window.addEventListener('unhandledrejection', (event) => {
        Sentry.captureException(event.reason);
        this.showError(fallback);
      });
    }
    
      showError(message: string) {
        this.innerHTML = `
          <div class="error-fallback p-6 bg-red-50 border border-red-200 rounded-lg text-center">
          <svg class="w-12 h-12 mx-auto mb-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
          </svg>
          <h3 class="text-lg font-semibold text-red-800 mb-2">Hata Oluştu</h3>
          <p class="text-red-600 mb-4">${message}</p>
          <button onclick="window.location.reload()" class="px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700 transition-colors">
            Sayfayı Yenile
          </button>
        </div>
      `;
    }
  }

  if (!customElements.get('error-boundary')) {
    customElements.define('error-boundary', ErrorBoundary);
  }
</script>

<style>
  .error-boundary {
    display: contents;
  }
  
  .error-fallback {
    animation: fadeIn 0.3s ease-in;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
