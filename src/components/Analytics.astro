---
/**
 * Consent-gated analytics loader.
 *
 * GA4, Microsoft Clarity ve Yandex Metrika sadece KVKK cookie tercihinde
 * analytics veya marketing izni varsa client tarafında dinamik yüklenir.
 */
interface Props {
  ga4MeasurementId?: string;
  clarityProjectId?: string;
  yandexMetricaId?: string;
  debug?: boolean;
}

const { ga4MeasurementId, clarityProjectId, yandexMetricaId, debug = false } = Astro.props as Props;
const hasAny = ga4MeasurementId || clarityProjectId || yandexMetricaId;
if (!hasAny) return;
---

<script is:inline define:vars={{ ga4MeasurementId, clarityProjectId, yandexMetricaId, debug }}>
  (function () {
    var loaded = { ga4: false, clarity: false, yandex: false };

    function consentAllowsAnalytics() {
      try {
        var raw = localStorage.getItem('sf_cookie');
        if (!raw) return false;
        var pref = JSON.parse(raw);
        return Boolean(pref && (pref.analytics === true || pref.marketing === true));
      } catch (_) {
        return false;
      }
    }

    function appendScript(src, onload) {
      if (!src) return;
      var script = document.createElement('script');
      script.async = true;
      script.src = src;
      if (onload) script.onload = onload;
      document.head.appendChild(script);
    }

    function loadGa4() {
      if (!ga4MeasurementId || loaded.ga4) return;
      loaded.ga4 = true;
      window.dataLayer = window.dataLayer || [];
      window.gtag = function () { window.dataLayer.push(arguments); };
      appendScript('https://www.googletagmanager.com/gtag/js?id=' + encodeURIComponent(ga4MeasurementId), function () {
        window.gtag('js', new Date());
        window.gtag('config', ga4MeasurementId, {
          send_page_view: true,
          transport_type: 'beacon',
          anonymize_ip: true,
          allow_google_signals: true,
          allow_ad_personalization_signals: false,
          cookie_flags: 'SameSite=None;Secure',
          cookie_expires: 63072000,
          ...(debug ? { debug_mode: true } : {}),
        });
      });
    }

    function loadClarity() {
      if (!clarityProjectId || loaded.clarity) return;
      loaded.clarity = true;
      window.clarity = window.clarity || function () {
        (window.clarity.q = window.clarity.q || []).push(arguments);
      };
      appendScript('https://www.clarity.ms/tag/' + encodeURIComponent(clarityProjectId) + '?ref=bwt');
    }

    function loadYandex() {
      if (!yandexMetricaId || loaded.yandex) return;
      loaded.yandex = true;
      window.ym = window.ym || function () {
        (window.ym.a = window.ym.a || []).push(arguments);
      };
      window.ym.l = 1 * new Date();
      appendScript('https://mc.yandex.ru/metrika/tag.js', function () {
        window.ym(Number(yandexMetricaId), 'init', {
          clickmap: true,
          trackLinks: true,
          accurateTrackBounce: true,
          webvisor: true,
        });
      });
    }

    function loadAllowedAnalytics() {
      if (!consentAllowsAnalytics()) return;
      loadGa4();
      loadClarity();
      loadYandex();
    }

    window.sfTrack = function (eventName, params) {
      if (!eventName) return;
      try {
        if (typeof window.gtag === 'function') {
          window.gtag('event', eventName, params || {});
        }
        if (typeof window.ym === 'function' && yandexMetricaId) {
          window.ym(Number(yandexMetricaId), 'reachGoal', eventName, params || {});
        }
        if (typeof window.clarity === 'function') {
          window.clarity('event', eventName);
          if (params) {
            Object.entries(params).forEach(function (entry) {
              try { window.clarity('set', String(entry[0]), String(entry[1])); } catch (_) {}
            });
          }
        }
      } catch (_) { /* sessiz */ }
    };

    window.addEventListener('sf-cookie-consent-changed', loadAllowedAnalytics);
    loadAllowedAnalytics();

    try {
      var sp = new URLSearchParams(window.location.search);
      var as = sp.get('auth_success');
      if (as) {
        setTimeout(function () { window.sfTrack('auth_success', { method: as }); }, 200);
        sp.delete('auth_success');
        var clean = window.location.pathname + (sp.toString() ? '?' + sp.toString() : '') + window.location.hash;
        window.history.replaceState({}, document.title, clean);
      }
    } catch (_) { /* sessiz */ }
  })();
</script>
