---
import Icon from './Icon.astro';

const year = new Date().getFullYear();

const social = [
  { label: 'Instagram', href: 'https://www.instagram.com/sanliurfacom', icon: 'lucide:instagram' },
  { label: 'Facebook',  href: 'https://www.facebook.com/sanliurfacom',  icon: 'lucide:facebook'  },
  { label: 'X',         href: 'https://x.com/sanliurfacom',             icon: 'lucide:twitter'   },
  { label: 'YouTube',   href: 'https://www.youtube.com/@sanliurfacom',  icon: 'lucide:youtube'   },
];

const groups = [
  {
    title: 'Keşfet',
    links: [
      { label: 'Mekanlar', href: '/mekanlar' },
      { label: 'Gezilecek Yerler', href: '/gezilecek-yerler' },
      { label: 'Etkinlikler', href: '/etkinlikler' },
      { label: 'Topluluk', href: '/topluluk' },
      { label: 'Eşleşme', href: '/eslesme' },
      { label: 'Harita', href: '/harita' },
    ],
  },
  {
    title: 'İlçeler',
    links: [
      { label: 'Haliliye', href: '/ilceler/haliliye' },
      { label: 'Eyyübiye', href: '/ilceler/eyyubiye' },
      { label: 'Karaköprü', href: '/ilceler/karakopru' },
      { label: 'Siverek', href: '/ilceler/siverek' },
      { label: 'Viranşehir', href: '/ilceler/viransehir' },
      { label: 'Harran', href: '/ilceler/harran' },
      { label: 'Halfeti', href: '/ilceler/halfeti' },
      { label: 'Tüm İlçeler', href: '/ilceler' },
    ],
  },
  {
    title: 'Kategoriler',
    links: [
      { label: 'Yeme İçme', href: '/yeme-icme' },
      { label: 'Kebapçılar', href: '/mekanlar/yeme-icme-kebapcilar' },
      { label: 'Ciğerciler', href: '/mekanlar/yeme-icme-cigerciler' },
      { label: 'Nöbetçi Eczaneler', href: '/saglik/nobetci-eczaneler' },
      { label: 'Otobüs Saatleri', href: '/ulasim/otobus-saatleri' },
      { label: 'Oteller', href: '/konaklama' },
      { label: 'Sıra Gecesi', href: '/sanliurfa-sira-gecesi-mekanlari' },
    ],
  },
  {
    title: 'Kurumsal',
    links: [
      { label: 'Hakkımızda', href: '/hakkinda' },
      { label: 'İletişim', href: '/iletisim' },
      { label: 'İşletme Ekle', href: '/isletme-kayit' },
      { label: 'Gizlilik', href: '/gizlilik-politikasi' },
    ],
  },
];
---

<footer class="bg-[#100a05]">
  <div class="mx-auto w-full max-w-7xl px-4 pt-14 pb-8 sm:px-6 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-[1.1fr_2fr]">
      <div>
        <a href="/" class="inline-flex items-center gap-1" aria-label="Sanliurfa.com ana sayfa">
          <span class="font-display text-3xl font-semibold text-white">Sanliurfa</span>
          <span class="text-lg font-bold text-[#f4c56e]">.com</span>
        </a>
        <p class="mt-1.5 text-xs font-bold uppercase tracking-[0.14em] text-[#f4c56e]/70">
          12.000 Yıllık Tarihin Modern Rehberi
        </p>
        <p class="mt-4 max-w-sm text-sm leading-7 text-white/50">
          Şanlıurfa mekanları, gezi rotaları, ilçeler, yemek kültürü ve günlük şehir servisleri için modern yerel rehber.
        </p>
        <div class="mt-5 flex flex-wrap gap-2">
          <a href="/saglik/nobetci-eczaneler" class="rounded-full border border-white/15 bg-white/6 px-3 py-2 text-xs font-bold text-white/65 transition hover:border-[#f4c56e]/45 hover:text-[#f4c56e]">Nöbetçi Eczane</a>
          <a href="/eslesme" class="rounded-full border border-white/15 bg-white/6 px-3 py-2 text-xs font-bold text-white/65 transition hover:border-[#f4c56e]/45 hover:text-[#f4c56e]">Eşleşme</a>
          <a href="/ulasim/otobus-saatleri" class="rounded-full border border-white/15 bg-white/6 px-3 py-2 text-xs font-bold text-white/65 transition hover:border-[#f4c56e]/45 hover:text-[#f4c56e]">Otobüs Saatleri</a>
          <a href="/isletme-kayit" class="rounded-full border border-white/15 bg-white/6 px-3 py-2 text-xs font-bold text-white/65 transition hover:border-[#f4c56e]/45 hover:text-[#f4c56e]">İşletme Ekle</a>
        </div>

        <div class="mt-7">
          <p class="text-xs font-black uppercase tracking-[0.13em] text-[#f4c56e]/80">Sosyal medya</p>
          <p class="mt-2 max-w-sm text-xs leading-6 text-white/45">Sanliurfa.com güncellemeleri, mekanlar ve etkinlikler için takip edin.</p>
          <div class="mt-3 flex flex-wrap gap-2">
            {social.map((item) => (
              <a
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Sanliurfa.com ${item.label}`}
                class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/15 bg-white/6 text-white/70 transition hover:border-[#f4c56e]/50 hover:bg-white/10 hover:text-[#f4c56e]"
              >
                <Icon name={item.icon} size={18} />
              </a>
            ))}
          </div>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-7 sm:grid-cols-4">
        {groups.map((group) => (
          <div>
            <p class="text-xs font-black uppercase tracking-[0.13em] text-[#f4c56e]/80">{group.title}</p>
            <ul class="mt-4 grid gap-2.5">
              {group.links.map((link) => (
                <li>
                  <a href={link.href} class="inline-flex min-h-8 items-center text-sm font-medium text-white/45 transition hover:text-white">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-12 flex flex-col gap-4 border-t border-white/10 pt-6 text-xs font-semibold text-white/35 sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} Sanliurfa.com. Tarihin sıfır noktasından şehir rehberi.</p>
      <div class="flex flex-wrap gap-4">
        <a href="/kullanim-kosullari" class="inline-flex min-h-8 items-center transition hover:text-white/65">Kullanım Koşulları</a>
        <a href="/kvkk" class="inline-flex min-h-8 items-center transition hover:text-white/65">KVKK</a>
        <a href="/iletisim" class="inline-flex min-h-8 items-center transition hover:text-white/65">İletişim</a>
      </div>
    </div>
  </div>
</footer>
