---
import { getSiteSetting } from '../lib/site-content';

const currentYear = new Date().getFullYear();

const footerLinksFallback = {
  explore: [
    { label: 'Mekanlar', href: '/mekanlar' },
    { label: 'Kebapçılar', href: '/mekanlar/kebapcilar' },
    { label: 'Ciğerciler', href: '/mekanlar/cigerciler' },
    { label: 'Kafeler', href: '/mekanlar/kafeler' },
    { label: 'Gezilecek Yerler', href: '/gezilecek-yerler' },
    { label: 'Etkinlikler', href: '/etkinlikler' },
  ],
  districts: [
    { label: 'Eyyübiye', href: '/ilceler/eyyubiye' },
    { label: 'Haliliye', href: '/ilceler/haliliye' },
    { label: 'Karaköprü', href: '/ilceler/karakopru' },
    { label: 'Halfeti', href: '/ilceler/halfeti' },
    { label: 'Harran', href: '/ilceler/harran' },
    { label: 'Tüm İlçeler', href: '/ilceler' },
  ],
  popular: [
    { label: 'En İyi Kebapçılar', href: '/en-iyi-kebapcilar' },
    { label: 'Kahvaltı Mekanları', href: '/sanliurfa-kahvalti-mekanlari' },
    { label: 'Ne Yenir?', href: '/sanliurfada-ne-yenir' },
    { label: 'Yemek Tarifleri', href: '/yemek-tarifleri' },
    { label: 'Nöbetçi Eczaneler', href: '/saglik/nobetci-eczaneler' },
    { label: 'Topluluk Özellikleri', href: '/topluluk' },
    { label: 'Hafta Sonu Rehberi', href: '/blog/sanliurfa-hafta-sonu-rehberi' },
    { label: 'Blog', href: '/blog' },
  ],
  company: [
    { label: 'Hakkımızda', href: '/hakkinda' },
    { label: 'İletişim', href: '/iletisim' },
    { label: 'İşletme Ekleyin', href: '/isletme-kayit' },
    { label: 'Gizlilik Politikası', href: '/gizlilik-politikasi' },
    { label: 'Kullanım Koşulları', href: '/kullanim-kosullari' },
    { label: 'KVKK', href: '/kvkk' },
  ],
  services: [
    { label: 'Nöbetçi Eczaneler', href: '/saglik/nobetci-eczaneler' },
    { label: 'Otobüs Saatleri', href: '/ulasim/otobus-saatleri' },
    { label: 'Uçak Saatleri', href: '/ulasim/ucak-saatleri' },
    { label: 'Etkinlik Takvimi', href: '/etkinlikler' },
    { label: 'Yemek Tarifleri', href: '/yemek-tarifleri' },
    { label: 'Premium Üyelik', href: '/fiyatlandirma' },
    { label: 'İlçe Rehberi', href: '/ilceler' },
    { label: 'Mekan Rehberi', href: '/mekanlar' },
  ],
};

const footerLinks = await getSiteSetting('footer.links', footerLinksFallback);
const footerBrandFallback = {
  title: 'Sanliurfa.com',
  highlight: '.com',
  description:
    "Şanlıurfa’nın en kapsamlı şehir rehberi. Mekanlar, gezilecek yerler, etkinlikler ve daha fazlası.",
  infoNote: 'Resmi sosyal medya hesabımız bulunmamaktadır.',
};
const footerBottomFallback = {
  copyrightLabel: `© ${currentYear} Sanliurfa.com — Tarihin Sıfır Noktası`,
  legalLinks: [
    { label: 'Gizlilik', href: '/gizlilik-politikasi' },
    { label: 'Koşullar', href: '/kullanim-kosullari' },
    { label: 'İletişim', href: '/iletisim' },
  ],
};

const footerBrand = await getSiteSetting('footer.brand', footerBrandFallback);
const footerBottom = await getSiteSetting('footer.bottom', footerBottomFallback);
const socialProfilesFallback = {
  instagram: { enabled: false, handle: '', url: '' },
  tiktok: { enabled: false, handle: '', url: '' },
  youtube: { enabled: false, handle: '', url: '' },
  x: { enabled: false, handle: '', url: '' },
};
const socialProfilesRaw = await getSiteSetting('social.profiles', socialProfilesFallback);
const socialProfiles = Object.entries(socialProfilesRaw as Record<string, any>)
  .filter(([, v]) => v?.enabled && v?.url)
  .map(([platform, v]) => ({ platform, url: v.url, handle: v.handle || '' }));
const bottomLinks = Array.isArray((footerBottom as any)?.legalLinks)
  ? (footerBottom as any).legalLinks
  : footerBottomFallback.legalLinks;

---

<footer style="background:#0A0806;border-top:1px solid rgba(200,160,100,0.14);">

  {/* Main footer grid */}
  <div class="container mx-auto px-4 sm:px-6" style="padding-top:4rem;padding-bottom:3rem;">

    {/* Top: wordmark + description */}
    <div style="display:grid;grid-template-columns:1fr;gap:3rem;margin-bottom:3.5rem;" class="lg:grid-cols-[2fr_3fr]">
      <div>
        <a href="/" style="display:inline-flex;align-items:baseline;gap:0.0625rem;text-decoration:none;margin-bottom:1.25rem;display:flex;">
          <span style="font-family:'Cormorant Garamond',Georgia,serif;font-size:2.25rem;font-weight:300;font-style:italic;color:#F5EDD6;letter-spacing:-0.02em;line-height:1;">
            {(footerBrand as any).title || 'Sanliurfa'}
          </span>
          <span style="font-family:'Jost',system-ui,sans-serif;font-size:1.125rem;font-weight:700;color:#CE8E38;letter-spacing:0.04em;align-self:flex-end;padding-bottom:0.25rem;">
            {(footerBrand as any).highlight || '.com'}
          </span>
        </a>
        <p style="font-size:0.875rem;line-height:1.7;color:#6B5540;max-width:22rem;margin-bottom:1.25rem;font-family:'Jost',sans-serif;">
          {(footerBrand as any).description || footerBrandFallback.description}
        </p>
        <p style="font-size:0.6875rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:#4A3828;font-family:'Jost',sans-serif;">
          {(footerBrand as any).infoNote || footerBrandFallback.infoNote}
        </p>
      </div>

      {/* Link columns */}
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:2rem;" class="sm:grid-cols-4">
        <div>
          <p style="font-size:0.5625rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#CE8E38;margin-bottom:1rem;font-family:'Jost',sans-serif;">Keşfet</p>
          <ul style="display:flex;flex-direction:column;gap:0.5rem;list-style:none;padding:0;margin:0;">
            {footerLinks.explore.map(link => (
              <li>
                <a href={link.href} style="font-size:0.8125rem;color:#6B5540;text-decoration:none;transition:color 0.15s;font-family:'Jost',sans-serif;" onmouseover="this.style.color='#C4B49A'" onmouseout="this.style.color='#6B5540'">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <p style="font-size:0.5625rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#CE8E38;margin-bottom:1rem;font-family:'Jost',sans-serif;">İlçeler</p>
          <ul style="display:flex;flex-direction:column;gap:0.5rem;list-style:none;padding:0;margin:0;">
            {footerLinks.districts.map(link => (
              <li>
                <a href={link.href} style="font-size:0.8125rem;color:#6B5540;text-decoration:none;transition:color 0.15s;font-family:'Jost',sans-serif;" onmouseover="this.style.color='#C4B49A'" onmouseout="this.style.color='#6B5540'">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <p style="font-size:0.5625rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#CE8E38;margin-bottom:1rem;font-family:'Jost',sans-serif;">Popüler</p>
          <ul style="display:flex;flex-direction:column;gap:0.5rem;list-style:none;padding:0;margin:0;">
            {footerLinks.popular.map(link => (
              <li>
                <a href={link.href} style="font-size:0.8125rem;color:#6B5540;text-decoration:none;transition:color 0.15s;font-family:'Jost',sans-serif;" onmouseover="this.style.color='#C4B49A'" onmouseout="this.style.color='#6B5540'">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <p style="font-size:0.5625rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#CE8E38;margin-bottom:1rem;font-family:'Jost',sans-serif;">Kurumsal</p>
          <ul style="display:flex;flex-direction:column;gap:0.5rem;list-style:none;padding:0;margin:0;">
            {footerLinks.company.map(link => (
              <li>
                <a href={link.href} style="font-size:0.8125rem;color:#6B5540;text-decoration:none;transition:color 0.15s;font-family:'Jost',sans-serif;" onmouseover="this.style.color='#C4B49A'" onmouseout="this.style.color='#6B5540'">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    {/* Services strip */}
    <div style="border-top:1px solid rgba(200,160,100,0.1);border-bottom:1px solid rgba(200,160,100,0.1);padding:1.5rem 0;margin-bottom:2.5rem;">
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1.5rem;" class="sm:grid-cols-4">
        <div>
          <p style="font-size:0.5625rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:#4A3828;margin-bottom:0.5rem;font-family:'Jost',sans-serif;">Platform</p>
          <p style="font-size:0.8125rem;color:#6B5540;line-height:1.5;font-family:'Jost',sans-serif;">Şanlıurfa odaklı yerel dijital rehber</p>
        </div>
        <div>
          <p style="font-size:0.5625rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:#4A3828;margin-bottom:0.5rem;font-family:'Jost',sans-serif;">Kapsam</p>
          <p style="font-size:0.8125rem;color:#6B5540;line-height:1.5;font-family:'Jost',sans-serif;">Mekan, sağlık, ulaşım, gezi, ilçe, tarif</p>
        </div>
        <div>
          <p style="font-size:0.5625rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:#4A3828;margin-bottom:0.5rem;font-family:'Jost',sans-serif;">Hızlı Servisler</p>
          <ul style="display:flex;flex-direction:column;gap:0.25rem;list-style:none;padding:0;margin:0;">
            {footerLinks.services.slice(0, 3).map((link) => (
              <li>
                <a href={link.href} style="font-size:0.8125rem;color:#6B5540;text-decoration:none;transition:color 0.15s;font-family:'Jost',sans-serif;" onmouseover="this.style.color='#C4B49A'" onmouseout="this.style.color='#6B5540'">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <p style="font-size:0.5625rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:#4A3828;margin-bottom:0.5rem;font-family:'Jost',sans-serif;">Bilgilendirme</p>
          {socialProfiles.length > 0 ? (
            <ul style="display:flex;flex-direction:column;gap:0.25rem;list-style:none;padding:0;margin:0;">
              {socialProfiles.map((profile) => (
                <li>
                  <a href={profile.url} rel="noopener noreferrer nofollow" target="_blank" style="font-size:0.8125rem;color:#6B5540;text-decoration:none;transition:color 0.15s;font-family:'Jost',sans-serif;" onmouseover="this.style.color='#C4B49A'" onmouseout="this.style.color='#6B5540'">
                    {profile.platform.toUpperCase()} {profile.handle}
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <p style="font-size:0.8125rem;color:#6B5540;line-height:1.5;font-family:'Jost',sans-serif;">{(footerBrand as any).infoNote || footerBrandFallback.infoNote}</p>
          )}
        </div>
      </div>
    </div>

    {/* Bottom bar */}
    <div style="display:flex;flex-direction:column;align-items:center;justify-content:space-between;gap:1rem;" class="sm:flex-row">
      <p style="font-size:0.6875rem;font-weight:500;letter-spacing:0.08em;color:#4A3828;font-family:'Jost',sans-serif;">
        {(footerBottom as any).copyrightLabel || footerBottomFallback.copyrightLabel}
      </p>
      <div style="display:flex;align-items:center;gap:1.5rem;">
        {bottomLinks.map((link: { label: string; href: string }) => (
          <a href={link.href} style="font-size:0.6875rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:#4A3828;text-decoration:none;transition:color 0.15s;font-family:'Jost',sans-serif;" onmouseover="this.style.color='#C4B49A'" onmouseout="this.style.color='#4A3828'">{link.label}</a>
        ))}
      </div>
    </div>
  </div>
</footer>
