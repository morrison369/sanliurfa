---
import { MapPin, Phone, Mail, Send } from "lucide-react";
import { DEFAULT_PUBLIC_SITE_SETTINGS, type FooterSettings } from "../lib/site-settings";

interface Props {
  settings?: FooterSettings;
}

const { settings = DEFAULT_PUBLIC_SITE_SETTINGS.footer } = Astro.props;
const currentYear = new Date().getFullYear();
const brandParts = settings.brandName.split(".");
const brandPrimary = brandParts[0] || "Şanlıurfa";
const brandSuffix = brandParts.length > 1 ? `.${brandParts.slice(1).join(".")}` : ".com";
const hasPhone = settings.phoneLabel.trim().length > 0 && settings.phoneHref.trim().length > 0;
---

<footer class="bg-urfa-900 dark:bg-gray-950 text-white">
  <!-- Bülten Alanı -->
  <div class="border-b border-urfa-800 dark:border-gray-800">
    <div class="container-custom py-12">
      <div class="flex flex-col lg:flex-row items-center justify-between gap-6">
        <div class="text-center lg:text-left">
          <h3 class="text-2xl font-display font-bold">{settings.newsletterTitle}</h3>
          <p class="mt-2 text-urfa-200">
            {settings.newsletterDescription}
          </p>
        </div>
        <form
          class="flex w-full max-w-md gap-2"
          action="/api/newsletter/subscribe"
          method="POST"
        >
          <input
            type="email"
            name="email"
            placeholder="E-posta adresiniz"
            required
            class="flex-1 px-4 py-3 bg-urfa-800 dark:bg-gray-800 border border-urfa-700 dark:border-gray-600 rounded-lg text-white placeholder-urfa-400 dark:placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-urfa-500"
          />
          <button
            type="submit"
            class="px-6 py-3 bg-isot-600 hover:bg-isot-700 rounded-lg font-medium transition-colors flex items-center gap-2"
          >
            <Send className="w-4 h-4" />
            <span class="hidden sm:inline">Abone Ol</span>
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Main Footer Content -->
  <div class="container-custom py-12 lg:py-16">
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-8">
      <!-- Brand Column -->
      <div class="col-span-2">
        <a href="/" class="flex items-center space-x-2 mb-4">
          <div
            class="w-10 h-10 bg-white rounded-lg flex items-center justify-center text-urfa-900 font-bold text-xl"
          >
            Ş
          </div>
          <span class="font-display font-bold text-xl">
            {brandPrimary}<span class="text-urfa-300">{brandSuffix}</span>
          </span>
        </a>
        <p class="text-urfa-200 dark:text-gray-300 text-sm mb-6 max-w-xs">
          {settings.brandDescription}
        </p>

        <!-- Contact Info -->
        <div class="space-y-3 text-sm">
          <a
            href={`mailto:${settings.email}`}
            class="flex items-center gap-2 text-urfa-200 dark:text-gray-300 hover:text-white dark:hover:text-white transition-colors"
          >
            <Mail className="w-4 h-4" />
            {settings.email}
          </a>
          {
            hasPhone && (
              <a
                href={`tel:${settings.phoneHref}`}
                class="flex items-center gap-2 text-urfa-200 dark:text-gray-300 hover:text-white dark:hover:text-white transition-colors"
              >
                <Phone className="w-4 h-4" />
                {settings.phoneLabel}
              </a>
            )
          }
          <div class="flex items-start gap-2 text-urfa-200 dark:text-gray-300">
            <MapPin className="w-4 h-4 mt-0.5 flex-shrink-0" />
            <span>{settings.address}</span>
          </div>
        </div>

        <p class="mt-6 text-xs text-urfa-300 dark:text-gray-400">
          {settings.socialNote}
        </p>
      </div>

      <!-- Links Columns -->
      {
        settings.columns.map((column) => (
          <div>
            <h4 class="font-semibold text-white mb-4">{column.title}</h4>
            <ul class="space-y-2">
              {column.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-urfa-200 dark:text-gray-300 hover:text-white dark:hover:text-white transition-colors"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-urfa-800 dark:border-gray-800">
    <div class="container-custom py-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-sm text-urfa-300 dark:text-gray-400">
          &copy; {currentYear} sanliurfa.com. Tüm hakları saklıdır.
        </p>

        <div class="flex flex-wrap items-center justify-center gap-2">
          <span class="rounded-full border border-urfa-700 px-3 py-1 text-xs text-urfa-300 dark:border-gray-700 dark:text-gray-400">
            HTTPS korumalı
          </span>
          <span class="rounded-full border border-urfa-700 px-3 py-1 text-xs text-urfa-300 dark:border-gray-700 dark:text-gray-400">
            Türkçe şehir rehberi
          </span>
        </div>
      </div>
    </div>
  </div>
</footer>
