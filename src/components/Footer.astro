---
import Icon from './Icon.astro';
import { getSiteSetting } from '../lib/site-content';
import { PUBLISHER_PROFILE } from '../lib/transparency';

const year = new Date().getFullYear();

const social = [
  { label: 'Instagram', href: 'https://www.instagram.com/sanliurfacom', icon: 'lucide:instagram' },
  { label: 'Facebook',  href: 'https://www.facebook.com/sanliurfacom',  icon: 'lucide:facebook'  },
  { label: 'X',         href: 'https://x.com/sanliurfacom',             icon: 'lucide:twitter'   },
  { label: 'YouTube',   href: 'https://www.youtube.com/@sanliurfacom',  icon: 'lucide:youtube'   },
];

const fallbackGroups = [
  {
    title: 'Keşfet',
    links: [
      { label: 'Mekanlar', href: '/mekanlar' },
      { label: 'Gezilecek Yerler', href: '/gezilecek-yerler' },
      { label: 'Etkinlikler', href: '/etkinlikler' },
      { label: 'Topluluk', href: '/topluluk' },
      { label: 'Eşleşme', href: '/eslesme' },
      { label: 'Harita', href: '/harita' },
    ],
  },
  {
    title: 'İlçeler',
    links: [
      { label: 'Haliliye', href: '/ilceler/haliliye' },
      { label: 'Eyyübiye', href: '/ilceler/eyyubiye' },
      { label: 'Karaköprü', href: '/ilceler/karakopru' },
      { label: 'Siverek', href: '/ilceler/siverek' },
      { label: 'Viranşehir', href: '/ilceler/viransehir' },
      { label: 'Harran', href: '/ilceler/harran' },
      { label: 'Halfeti', href: '/ilceler/halfeti' },
      { label: 'Tüm İlçeler', href: '/ilceler' },
    ],
  },
  {
    title: 'Kategoriler',
    links: [
      { label: 'Yeme İçme', href: '/yeme-icme' },
      { label: 'Kebapçılar', href: '/mekanlar/yeme-icme-kebapcilar' },
      { label: 'Ciğerciler', href: '/mekanlar/yeme-icme-cigerciler' },
      { label: 'Nöbetçi Eczaneler', href: '/saglik/nobetci-eczaneler' },
      { label: 'Otobüs Saatleri', href: '/ulasim/otobus-saatleri' },
      { label: 'Oteller', href: '/konaklama' },
      { label: 'Sıra Gecesi', href: '/sanliurfa-sira-gecesi-mekanlari' },
    ],
  },
  {
    title: 'Gezi Rehberleri',
    links: [
      { label: 'Şanlıurfa Rehberi', href: '/sanliurfa-gezi-rehberi' },
      { label: 'Göbeklitepe', href: '/gobeklitepe-gezi-rehberi' },
      { label: 'Balıklıgöl', href: '/balikligol-gezi-rehberi' },
      { label: 'Halfeti', href: '/halfeti-gezi-rehberi' },
      { label: 'Harran', href: '/harran-gezi-rehberi' },
      { label: 'En İyi Kebapçılar', href: '/en-iyi-kebapcilar' },
      { label: 'Kahvaltı Mekanları', href: '/sanliurfa-kahvalti-mekanlari' },
    ],
  },
  {
    title: 'Kurumsal',
    links: [
      { label: 'Hakkımızda', href: '/hakkinda' },
      { label: 'Yazarlar', href: '/yazarlar' },
      { label: 'Yayın Politikası', href: '/yayin-politikasi' },
      { label: 'İletişim', href: '/iletisim' },
      { label: 'Künye', href: '/kunye' },
      { label: 'İşletme Ekle', href: '/isletme-kayit' },
      { label: 'Gizlilik', href: '/gizlilik-politikasi' },
    ],
  },
];

const footerLinksSetting = await getSiteSetting('footer.links', { groups: fallbackGroups });
const groups =
  Array.isArray(footerLinksSetting.groups) && footerLinksSetting.groups.length > 0
    ? footerLinksSetting.groups
    : fallbackGroups;
---

<footer class="bg-[#100a05]">
  <div class="mx-auto w-full max-w-7xl px-4 pt-14 pb-8 sm:px-6 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-[1.1fr_2fr]">
      <div>
        <a href="/" class="inline-flex items-center gap-1" aria-label="Sanliurfa.com ana sayfa">
          <span class="font-display text-3xl font-semibold text-white">Sanliurfa</span>
          <span class="text-lg font-bold text-[#f4c56e]">.com</span>
        </a>
        <p class="mt-1.5 text-xs font-bold uppercase tracking-[0.14em] text-[#f4c56e]/70">
          12.000 Yıllık Tarihin Modern Rehberi
        </p>
        <p class="mt-4 max-w-sm text-sm leading-7 text-white/50">
          Şanlıurfa mekanları, gezi rotaları, ilçeler, yemek kültürü ve günlük şehir servisleri için
          editöryel standartlarla hazırlanan yerel rehber.
        </p>
        <div class="mt-5 flex flex-wrap gap-2">
          <a href="/saglik/nobetci-eczaneler" class="rounded-full border border-white/15 bg-white/6 px-3 py-2 text-xs font-bold text-white/65 transition hover:border-[#f4c56e]/45 hover:text-[#f4c56e]">Nöbetçi Eczane</a>
          <a href="/eslesme" class="rounded-full border border-white/15 bg-white/6 px-3 py-2 text-xs font-bold text-white/65 transition hover:border-[#f4c56e]/45 hover:text-[#f4c56e]">Eşleşme</a>
          <a href="/ulasim/otobus-saatleri" class="rounded-full border border-white/15 bg-white/6 px-3 py-2 text-xs font-bold text-white/65 transition hover:border-[#f4c56e]/45 hover:text-[#f4c56e]">Otobüs Saatleri</a>
          <a href="/isletme-kayit" class="rounded-full border border-white/15 bg-white/6 px-3 py-2 text-xs font-bold text-white/65 transition hover:border-[#f4c56e]/45 hover:text-[#f4c56e]">İşletme Ekle</a>
          <a href="/etkinlik-ekle" class="rounded-full border border-white/15 bg-white/6 px-3 py-2 text-xs font-bold text-white/65 transition hover:border-[#f4c56e]/45 hover:text-[#f4c56e]">Etkinlik Ekle</a>
        </div>

        <div class="mt-7">
          <p class="text-xs font-black uppercase tracking-[0.13em] text-[#f4c56e]/80">E-Bülten</p>
          <p class="mt-2 max-w-sm text-xs leading-6 text-white/45">Yeni rehberler, etkinlikler ve mekanlar — haftada bir gelen kutusunda.</p>
          <form id="footer-newsletter" class="mt-3 flex gap-2 max-w-sm">
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              placeholder="ornek@email.com"
              class="flex-1 min-w-0 rounded-md border border-white/15 bg-white/6 px-3 py-2 text-sm text-white placeholder:text-white/35 focus:border-[#f4c56e]/60 focus:outline-none"
            />
            <button type="submit" class="rounded-md bg-[#f4c56e] px-3 py-2 text-xs font-bold text-[#1a0f08] transition hover:opacity-90 disabled:opacity-60">Abone Ol</button>
          </form>
          <p id="footer-newsletter-msg" class="mt-2 text-xs text-white/55" hidden></p>
        </div>

        <div class="mt-7">
          <p class="text-xs font-black uppercase tracking-[0.13em] text-[#f4c56e]/80">İletişim</p>
          <address class="mt-3 not-italic text-sm leading-7 text-white/55">
            <p>🏢 {PUBLISHER_PROFILE.legalName}</p>
            <p>📰 <a href="/yazarlar#editoryel-ekip" class="hover:text-[#f4c56e]">{PUBLISHER_PROFILE.publisherName}</a></p>
            <p>📧 <a href={`mailto:${PUBLISHER_PROFILE.generalEmail}`} class="hover:text-[#f4c56e]">{PUBLISHER_PROFILE.generalEmail}</a></p>
            <p>💼 <a href={`mailto:${PUBLISHER_PROFILE.businessEmail}`} class="hover:text-[#f4c56e]">{PUBLISHER_PROFILE.businessEmail}</a></p>
            <p>📍 {PUBLISHER_PROFILE.address}</p>
            <p>📄 <a href="/kunye" class="hover:text-[#f4c56e]">Yayın bilgileri (Künye)</a></p>
            <p>📘 <a href="/yayin-politikasi" class="hover:text-[#f4c56e]">Yayın politikası ve düzeltme ilkeleri</a></p>
          </address>
        </div>

        <div class="mt-7">
          <p class="text-xs font-black uppercase tracking-[0.13em] text-[#f4c56e]/80">Sosyal medya</p>
          <p class="mt-2 max-w-sm text-xs leading-6 text-white/45">Sanliurfa.com güncellemeleri, mekanlar ve etkinlikler için takip edin.</p>
          <div class="mt-3 flex flex-wrap gap-2">
            {social.map((item) => (
              <a
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Sanliurfa.com ${item.label}`}
                class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/15 bg-white/6 text-white/70 transition hover:border-[#f4c56e]/50 hover:bg-white/10 hover:text-[#f4c56e]"
              >
                <Icon name={item.icon} size={18} />
              </a>
            ))}
          </div>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-7 sm:grid-cols-3 lg:grid-cols-5">
        {groups.map((group) => (
          <div>
            <p class="text-xs font-black uppercase tracking-[0.13em] text-[#f4c56e]/80">{group.title}</p>
            <ul class="mt-4 grid gap-2.5">
              {group.links.map((link) => (
                <li>
                  <a href={link.href} class="inline-flex min-h-8 items-center text-sm font-medium text-white/45 transition hover:text-white">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-12 flex flex-col gap-4 border-t border-white/10 pt-6 text-xs font-semibold text-white/35 sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} Sanliurfa.com. Tarihin sıfır noktasından şehir rehberi.</p>
      <div class="flex flex-wrap gap-4">
        <a href="/kullanim-kosullari" class="inline-flex min-h-8 items-center transition hover:text-white/65">Kullanım Koşulları</a>
        <a href="/kvkk" class="inline-flex min-h-8 items-center transition hover:text-white/65">KVKK</a>
        <a href="/yayin-politikasi" class="inline-flex min-h-8 items-center transition hover:text-white/65">Yayın Politikası</a>
        <a href="/iletisim" class="inline-flex min-h-8 items-center transition hover:text-white/65">İletişim</a>
      </div>
    </div>
  </div>
</footer>

<script is:inline>
  (function() {
    var form = document.getElementById('footer-newsletter');
    if (!form) return;
    var msg = document.getElementById('footer-newsletter-msg');
    var input = form.querySelector('input[name="email"]');
    var btn = form.querySelector('button');
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      if (!input.value || btn.disabled) return;
      btn.disabled = true;
      var originalText = btn.textContent;
      btn.textContent = 'Gönderiliyor...';
      msg.hidden = true;
      try {
        var res = await fetch('/api/newsletter/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: input.value })
        });
        var data = await res.json();
        if (res.ok || res.status === 409) {
          msg.textContent = '✓ Abone olundu. Teşekkürler!';
          msg.style.color = '#86efac';
          input.value = '';
          if (typeof window.sfTrack === 'function') {
            window.sfTrack('newsletter_subscribe', { source: 'footer', duplicate: res.status === 409 });
          }
        } else {
          msg.textContent = data?.detail || data?.error || 'Abonelik gerçekleşmedi.';
          msg.style.color = '#fca5a5';
        }
      } catch (err) {
        msg.textContent = 'Bağlantı hatası. Lütfen tekrar deneyin.';
        msg.style.color = '#fca5a5';
      } finally {
        msg.hidden = false;
        btn.disabled = false;
        btn.textContent = originalText;
      }
    });
  })();
</script>
