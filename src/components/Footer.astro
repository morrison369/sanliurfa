---
const currentYear = new Date().getFullYear();

const footerLinks = {
  explore: [
    { label: 'Mekanlar', href: '/places' },
    { label: 'Restoranlar', href: '/kategoriler/restaurant' },
    { label: 'Oteller', href: '/kategoriler/hotel' },
    { label: 'Turistik Yerler', href: '/kategoriler/attraction' },
    { label: 'Alisveris', href: '/kategoriler/shopping' },
  ],
  company: [
    { label: 'Hakkimizda', href: '/hakkimizda' },
    { label: 'Iletisim', href: '/iletisim' },
    { label: 'İşletme Ekleyin', href: '/isletme-kayit' },
    { label: 'Rehberler', href: '/rehberler' },
    { label: 'Blog', href: '/blog' },
  ],
  support: [
    { label: 'Yardim Merkezi', href: '/yardim' },
    { label: 'SSS', href: '/sss' },
    { label: 'Gizlilik Politikasi', href: '/gizlilik' },
    { label: 'Kullanim Kosullari', href: '/kosullar' },
    { label: 'Cerez Politikasi', href: '/cerezler' },
  ],
};

const socialLinks = [
  { label: 'Facebook', icon: '📘', href: '#' },
  { label: 'Instagram', icon: '📷', href: '#' },
  { label: 'Twitter', icon: '🐦', href: '#' },
  { label: 'YouTube', icon: '📺', href: '#' },
];
---

<footer class="bg-gray-900 text-white">
  <div class="container mx-auto px-4 py-12">
    <div class="grid md:grid-cols-2 lg:grid-cols-5 gap-8 mb-8">
      {/* Brand */}
      <div class="lg:col-span-2">
        <a href="/" class="text-2xl font-bold text-white mb-4 inline-block">
          Sanliurfa<span class="text-red-500">.com</span>
        </a>
        <p class="text-gray-400 mb-6 max-w-sm">
          Sanliurfa'nin en kapsamli mekan rehberi. Restoranlardan otellere, 
          tarihi yerlerden alisveris noktalarina her sey burada.
        </p>
        {/* Social Links */}
        <div class="flex gap-4">
          {socialLinks.map(social => (
            <a
              href={social.href}
              class="w-10 h-10 bg-gray-800 rounded-lg flex items-center justify-center hover:bg-gray-700 transition-colors"
              aria-label={social.label}
            >
              <span class="text-xl">{social.icon}</span>
            </a>
          ))}
        </div>
      </div>

      {/* Links */}
      <div>
        <h4 class="font-bold text-lg mb-4">Kesfet</h4>
        <ul class="space-y-2">
          {footerLinks.explore.map(link => (
            <li>
              <a href={link.href} class="text-gray-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-bold text-lg mb-4">Sirket</h4>
        <ul class="space-y-2">
          {footerLinks.company.map(link => (
            <li>
              <a href={link.href} class="text-gray-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-bold text-lg mb-4">Destek</h4>
        <ul class="space-y-2">
          {footerLinks.support.map(link => (
            <li>
              <a href={link.href} class="text-gray-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    {/* Newsletter */}
    <div class="border-t border-gray-800 pt-8 mb-8">
      <div class="max-w-md mx-auto text-center">
        <h4 class="font-bold text-lg mb-2">Bultenimize Abone Olun</h4>
        <p class="text-gray-400 text-sm mb-4">
          Sanliurfa'daki yeni mekanlar ve etkinliklerden haberdar olun.
        </p>
        <form class="flex gap-2">
          <input
            type="email"
            placeholder="E-posta adresiniz"
            class="flex-1 px-4 py-2 bg-gray-800 border border-gray-700 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-red-500"
          />
          <button
            type="submit"
            class="px-6 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors"
          >
            Abone Ol
          </button>
        </form>
      </div>
    </div>

    {/* Bottom */}
    <div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-gray-400 text-sm">
        © {currentYear} Sanliurfa.com. Tüm haklari saklidir.
      </p>
      <div class="flex gap-6 text-sm text-gray-400">
        <a href="/gizlilik" class="hover:text-white transition-colors">Gizlilik</a>
        <a href="/kosullar" class="hover:text-white transition-colors">Kosullar</a>
        <a href="/iletisim" class="hover:text-white transition-colors">Iletisim</a>
      </div>
    </div>
  </div>
</footer>
