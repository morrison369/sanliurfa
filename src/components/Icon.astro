---
/**
 * Icon — astro-icon wrapper.
 *
 * Backward compat: legacy callers `<Icon name="home" />` (collection prefix yok)
 * → otomatik `lucide:home` olarak resolve edilir.
 *
 * Modern usage: `<Icon name="heroicons:bell" />` veya `<Icon name="lucide:map-pin" />`.
 *
 * astro-icon Iconify-based; SVG path'leri build-time tree-shake edilir, sadece
 * gerçekten kullanılan icon'lar bundle'a girer.
 */
import { Icon as AstroIcon } from 'astro-icon/components';

interface Props {
 name: string;
 size?: number;
 class?: string;
}

const { name, size = 24, class: className = '' } = Astro.props;

// Bare name → lucide collection (legacy backward compat).
const fullName = name.includes(':') ? name : `lucide:${name}`;
---

<AstroIcon
 name={fullName}
 width={size}
 height={size}
 class={className}
/>
