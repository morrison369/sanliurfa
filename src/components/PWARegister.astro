---
// PWA Service Worker kayıt bileşeni
---

<script>
 // Service Worker kaydı
 if ('serviceWorker' in navigator) {
 window.addEventListener('load', async () => {
 try {
 const registration = await navigator.serviceWorker.register('/sw.js');
 if (import.meta.env.DEV) {
 console.debug('[PWA] Service Worker registered:', registration.scope);
 }
 
 // Güncelleme kontrolü
 registration.addEventListener('updatefound', () => {
 const newWorker = registration.installing;
 newWorker?.addEventListener('statechange', () => {
 if (newWorker.state === 'installed' && navigator.serviceWorker.controller) {
 // Yeni versiyon mevcut
 showUpdateNotification();
 }
 });
 });
 } catch (error) {
 console.error('[PWA] Service Worker registration failed:', error);
 }
 });
 }
 
 // Güncelleme bildirimi
 function showUpdateNotification() {
 const toast = (window as any).toast;
 if (toast) {
 toast.show({
 message: 'Yeni bir güncelleme mevcut!',
 type: 'info',
 duration: 0,
 action: {
 label: 'Yenile',
 onClick: () => {
 window.location.reload();
 }
 }
 });
 }
 }
 
 // Install prompt handler — yakalayıp daha sonra göstermek için sakla
 let deferredInstallPrompt: any = null;
 window.addEventListener('beforeinstallprompt', (e) => {
   e.preventDefault();
   deferredInstallPrompt = e;
   // Custom install butonu visible yap
   document.querySelectorAll<HTMLButtonElement>('[data-pwa-install]').forEach((btn) => {
     btn.hidden = false;
     btn.disabled = false;
   });
 });

 // Bir install butonuna tıklandığında deferred prompt'u tetikle
 document.addEventListener('click', async (e) => {
   const target = (e.target as HTMLElement)?.closest<HTMLButtonElement>('[data-pwa-install]');
   if (!target) return;
   if (!deferredInstallPrompt) return;
   target.disabled = true;
   deferredInstallPrompt.prompt();
   try {
     const choice = await deferredInstallPrompt.userChoice;
     if ((window as any).sfTrack) {
       (window as any).sfTrack('pwa_install_prompt', { outcome: choice?.outcome || 'unknown' });
     }
     if (choice?.outcome !== 'accepted') {
       target.disabled = false;
     }
   } catch {
     target.disabled = false;
   } finally {
     deferredInstallPrompt = null;
     // Diğer install butonlarını gizle
     document.querySelectorAll<HTMLButtonElement>('[data-pwa-install]').forEach((btn) => {
       btn.hidden = true;
     });
   }
 });

 // App installed
 window.addEventListener('appinstalled', () => {
 if (import.meta.env.DEV) {
 console.debug('[PWA] App installed');
 }
 if ((window as any).sfTrack) {
   (window as any).sfTrack('pwa_installed', {});
 }
 const toast = (window as any).toast;
 if (toast) {
 toast.success('Sanliurfa.com ana ekranınıza eklendi!');
 }
 });
 
 // Online/Offline durumu
 window.addEventListener('online', () => {
 if (import.meta.env.DEV) {
 console.debug('[PWA] Online');
 }
 const toast = (window as any).toast;
 if (toast) {
 toast.success('İnternet bağlantısı geri geldi');
 }
 });
 
 window.addEventListener('offline', () => {
 if (import.meta.env.DEV) {
 console.debug('[PWA] Offline');
 }
 const toast = (window as any).toast;
 if (toast) {
 toast.warning('Çevrimdışı moddasınız. Bazı özellikler sınırlı olabilir.');
 }
 });
</script>
