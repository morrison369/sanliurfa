---
// PWA Service Worker kayıt bileşeni
---

<script>
 // Service Worker kaydı
 if ('serviceWorker' in navigator) {
 window.addEventListener('load', async () => {
 try {
 const registration = await navigator.serviceWorker.register('/sw.js');
 if (import.meta.env.DEV) {
 console.debug('[PWA] Service Worker registered:', registration.scope);
 }
 
 // Güncelleme kontrolü
 registration.addEventListener('updatefound', () => {
 const newWorker = registration.installing;
 newWorker?.addEventListener('statechange', () => {
 if (newWorker.state === 'installed' && navigator.serviceWorker.controller) {
 // Yeni versiyon mevcut
 showUpdateNotification();
 }
 });
 });
 } catch (error) {
 console.error('[PWA] Service Worker registration failed:', error);
 }
 });
 }
 
 // Güncelleme bildirimi
 function showUpdateNotification() {
 const toast = (window as any).toast;
 if (toast) {
 toast.show({
 message: 'Yeni bir güncelleme mevcut!',
 type: 'info',
 duration: 0,
 action: {
 label: 'Yenile',
 onClick: () => {
 window.location.reload();
 }
 }
 });
 }
 }
 
 // App installed
 window.addEventListener('appinstalled', () => {
 if (import.meta.env.DEV) {
 console.debug('[PWA] App installed');
 }
 
 const toast = (window as any).toast;
 if (toast) {
 toast.success('Sanliurfa.com ana ekranınıza eklendi!');
 }
 });
 
 // Online/Offline durumu
 window.addEventListener('online', () => {
 if (import.meta.env.DEV) {
 console.debug('[PWA] Online');
 }
 const toast = (window as any).toast;
 if (toast) {
 toast.success('İnternet bağlantısı geri geldi');
 }
 });
 
 window.addEventListener('offline', () => {
 if (import.meta.env.DEV) {
 console.debug('[PWA] Offline');
 }
 const toast = (window as any).toast;
 if (toast) {
 toast.warning('Çevrimdışı moddasınız. Bazı özellikler sınırlı olabilir.');
 }
 });
</script>
