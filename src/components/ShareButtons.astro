---
<div class="flex items-center gap-2">
  <span class="text-sm text-gray-500">Paylaş:</span>
  <div class="flex items-center gap-1">
    <button
      onclick="nativeShare()"
      class="h-8 px-3 bg-amber-600 hover:bg-amber-700 text-white rounded-full flex items-center justify-center text-xs font-semibold transition-colors"
      title="Paylaş"
    >
      Paylaş
    </button>
    <!-- Copy Link -->
    <button
      onclick="copyLink()"
      class="w-8 h-8 bg-gray-200 hover:bg-gray-300 text-gray-700 rounded-full flex items-center justify-center text-sm font-bold transition-colors"
      title="Linki kopyala"
    >
      📋
    </button>
  </div>
</div>

<script is:inline>
  async function nativeShare() {
    const title = document.title;
    const text = '';
    const url = window.location.href;
    if (navigator.share) {
      try {
        await navigator.share({ title, text, url });
        return;
      } catch {
        // user aborted, fallback below
      }
    }
    await copyLink();
  }

  async function copyLink() {
    try {
      await navigator.clipboard.writeText(window.location.href);
      if (window.toast) {
        window.toast.success('Link kopyalandı!');
      } else {
        alert('Link kopyalandı!');
      }
    } catch (err) {
      console.error('Kopyalama hatası:', err);
    }
  }
</script>
