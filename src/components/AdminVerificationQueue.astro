---
import LoadingWrapper from './ui/LoadingWrapper.astro';
import { UI_COPY_TR } from '../lib/ui-copy';

export interface Props {
  title?: string;
}

const { title = UI_COPY_TR.verificationQueue.title } = Astro.props;
---

<section data-admin-verification-queue class="space-y-4" aria-live="polite">
  <header class="space-y-1">
    <h2 class="text-xl font-semibold text-gray-900 dark:text-white">{title}</h2>
    <p class="text-sm text-gray-600 dark:text-gray-400">
      Bekleyen mekan doğrulama taleplerini inceleyin, onaylayın veya gerekçeyle reddedin.
    </p>
  </header>
  <LoadingWrapper
    loadingClass="py-8 text-center text-gray-500"
    loadingDataAttr="data-admin-verification-queue-loading"
    message={UI_COPY_TR.verificationQueue.loading}
    contentDataAttr="data-admin-verification-queue-content"
    contentClass="hidden"
  />
</section>

<script>
  import { initAdminVerificationQueue } from '../scripts/admin-verification-queue';

  initAdminVerificationQueue();
</script>
