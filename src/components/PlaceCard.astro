---
import { Icon } from 'astro-icon/components';
import Image from './Image.astro';
import FavoriteButton from './places/FavoriteButton.astro';
import { resolvePlaceImage } from '../lib/public-image-resolvers';

interface Props {
 title?: string;
 description?: string;
 image?: string;
 thumb?: string;
 category?: string;
 rating?: number;
 reviewCount?: number;
 slug?: string;
 place?: {
  id: string;
  name: string;
  slug: string;
  description?: string;
  image_url?: string;
  category?: string;
  rating?: number | string;
  review_count?: number | string;
  price_range?: string;
  address?: string;
  created_at?: string | Date | null;
 };
 compact?: boolean;
}

const isAuthenticated = Boolean(Astro.locals.user?.id);

const {
 title, description, image, category, rating, reviewCount, slug,
 place, compact = false
} = Astro.props;

const name = place?.name || title || '';
const placeSlug = place?.slug || slug || '';
const placeDesc = place?.description || description || '';
const placeImage = place
 ? resolvePlaceImage(place)
 : (image || '/images/placeholder-place.jpg');
const placeCategory = place?.category || category || 'general';
const rawRating = place?.rating ?? rating ?? 0;
const ratingNumber = typeof rawRating === 'number' ? rawRating : Number(rawRating);
const placeRating = Number.isFinite(ratingNumber) ? ratingNumber : 0;
const rawReviewCount = place?.review_count ?? reviewCount ?? 0;
const reviewCountNumber = typeof rawReviewCount === 'number' ? rawReviewCount : Number(rawReviewCount);
const placeReviewCount = Number.isFinite(reviewCountNumber) ? reviewCountNumber : 0;

// Son 7 günde eklenmiş mekanları "Yeni" badge ile göster
const createdAt = place?.created_at ? new Date(place.created_at) : null;
const isNew = createdAt && !isNaN(createdAt.getTime()) && (Date.now() - createdAt.getTime()) < 7 * 24 * 60 * 60 * 1000;
const priceRange = place?.price_range || '';

const categoryIcons: Record<string, string> = {
 restaurant:    'lucide:utensils',
 hotel:         'lucide:building-2',
 shopping:      'lucide:shopping-bag',
 attraction:    'lucide:landmark',
 service:       'lucide:wrench',
 entertainment: 'lucide:music-2',
 dini:          'lucide:star',
 tarihi:        'lucide:castle',
 yemek:         'lucide:chef-hat',
 doga:          'lucide:tree-pine',
 general:       'lucide:map-pin',
};

const categoryNames: Record<string, string> = {
 restaurant:    'Restoran',
 hotel:         'Otel',
 shopping:      'Alışveriş',
 attraction:    'Turistik Yer',
 service:       'Hizmet',
 entertainment: 'Eğlence',
 dini:          'Dini Yer',
 tarihi:        'Tarihi Yer',
 yemek:         'Yemek',
 doga:          'Doğa',
 general:       'Mekan',
};

const catIcon = categoryIcons[placeCategory] || categoryIcons.general;
const catLabel = categoryNames[placeCategory] || placeCategory.charAt(0).toUpperCase() + placeCategory.slice(1);
---

<article class={`group relative bg-[var(--bg-card)] border border-[var(--border-soft)] rounded-xl overflow-hidden hover:border-[var(--border)] hover:shadow-lg hover:shadow-[rgba(31,20,16,0.08)] transition-all duration-200 ${compact ? '' : ''}`}>
 {place?.id && (
  <div style="position:absolute;top:.65rem;right:.65rem;z-index:10">
   <FavoriteButton placeId={place.id} placeSlug={placeSlug} isAuthenticated={isAuthenticated} variant="card" />
  </div>
 )}
 <a href={`/isletme/${placeSlug}`} class="block">
  <div class="relative overflow-hidden aspect-[4/3] bg-[var(--bg-surface)]">
   <!-- CSS placeholder layer: Picture yüklenemezse arkadan görünür (kategori ikon) -->
   <div class="absolute inset-0 flex flex-col items-center justify-center gap-3 bg-[var(--bg-surface)]" aria-hidden="true">
    <Icon name={catIcon} class="w-12 h-12 text-[var(--copper)] opacity-60" />
    <span class="text-sm font-semibold text-[var(--text-3)]">{catLabel}</span>
   </div>
   <!-- Astro Picture: AVIF/WebP + lazy + responsive (HARD RULE #26 uyumlu) -->
   <Image
    src={placeImage}
    alt={name}
    width={compact ? 320 : 480}
    height={compact ? 240 : 360}
    loading="lazy"
    sizes={compact ? '(max-width: 640px) 50vw, 320px' : '(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw'}
    class="relative w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-300"
   />

   <!-- Kategori rozeti (görsel üzerinde) -->
   <span
    class="absolute top-3 left-3 flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold text-white"
    style="background:rgba(13,10,8,0.65);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px)"
   >
    <Icon name={catIcon} class="w-3 h-3" />
    {catLabel}
   </span>

   {isNew && (
    <span
     class="absolute top-3 right-12 flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-bold text-white uppercase tracking-wider"
     style="background:linear-gradient(135deg,#C0571F,#D49718);box-shadow:0 2px 8px -2px rgba(192,87,31,0.6)"
     title="Son 7 günde eklendi"
    >
     ⚡ Yeni
    </span>
   )}

   {placeRating > 0 && (
    <div
     class="absolute bottom-3 right-3 flex items-center gap-1 px-2 py-1 rounded-full text-xs font-bold text-white"
     style="background:rgba(13,10,8,0.70);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px)"
    >
     <Icon name="lucide:star" class="w-3.5 h-3.5 text-[#F5C542]" />
     <span>{placeRating.toFixed(1)}</span>
     {placeReviewCount > 0 && <span class="opacity-70">({placeReviewCount})</span>}
    </div>
   )}
  </div>

  <div class={compact ? 'p-3' : 'p-4'}>
   <h3 class={`font-bold text-[var(--text-1)] group-hover:text-[var(--copper)] transition-colors leading-snug ${compact ? 'text-base mb-1' : 'text-base mb-2'}`}>
    {name}
   </h3>

   {!compact && placeDesc && (
    <p class="text-[var(--text-3)] text-sm line-clamp-2 mb-3 leading-relaxed">
     {placeDesc}
    </p>
   )}

   {compact && priceRange && (
    <div class="flex items-center gap-2 text-sm text-[var(--text-3)]">
     <span>{'₺'.repeat(parseInt(priceRange))}</span>
    </div>
   )}

   {!compact && (
    <div class="flex items-center text-[var(--copper)] font-semibold text-sm mt-2">
     <span>Detayları Gör</span>
     <Icon name="lucide:chevron-right" class="w-4 h-4 ml-1 transform group-hover:translate-x-1 transition-transform" />
    </div>
   )}
  </div>
 </a>
</article>
