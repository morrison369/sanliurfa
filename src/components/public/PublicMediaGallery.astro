---
import Image from '../Image.astro';

interface Props {
  title?: string;
  items: string[];
  altBase: string;
}

const { title = 'Galeri', items = [], altBase } = Astro.props;
const galleryItems = items.filter(Boolean);
---

{galleryItems.length > 0 && (
  <section class="pmg">
    <h2 class="pmg-title">{title}</h2>
    <div class="pmg-grid">
      {galleryItems.map((src, index) => (
        <div class:list={['pmg-item', index === 0 && galleryItems.length > 2 && 'pmg-item--lead']}>
          <Image
            src={src}
            alt={`${altBase} ${index + 1}`}
            width={960}
            height={720}
            class="pmg-image"
            loading="lazy"
            sizes={index === 0 && galleryItems.length > 2 ? '(max-width: 768px) 100vw, 66vw' : '(max-width: 768px) 50vw, 33vw'}
          />
        </div>
      ))}
    </div>
  </section>
)}

<style>
  .pmg-title {
    margin: 0 0 0.9rem;
    color: var(--public-text);
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.45rem;
    font-weight: 700;
  }

  .pmg-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .pmg-item {
    overflow: hidden;
    border-radius: 0.85rem;
    background: rgba(184, 115, 51, 0.06);
    min-height: 11rem;
  }

  .pmg-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (min-width: 768px) {
    .pmg-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .pmg-item--lead {
      grid-column: span 2;
      grid-row: span 2;
    }
  }
</style>
