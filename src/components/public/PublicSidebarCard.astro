---
interface Props {
 title?: string;
 eyebrow?: string;
 accent?: boolean;
}

const { title, eyebrow, accent = false } = Astro.props;
---

<section class:list={['psc', accent && 'psc--accent']}>
  {(eyebrow || title) && (
    <header class="psc-head">
      {eyebrow && <p class="psc-eyebrow">{eyebrow}</p>}
      {title && <p class="psc-title">{title}</p>}
    </header>
  )}
  <div class="psc-body">
    <slot />
  </div>
</section>

<style>
  .psc {
    border: 1px solid var(--public-border);
    border-radius: var(--public-radius);
    background: var(--public-surface);
    padding: 1.25rem;
    box-shadow: var(--public-card-shadow);
  }

  .psc--accent {
    background: linear-gradient(135deg, var(--public-accent) 0%, var(--public-warning) 100%);
    border-color: transparent;
    color: #fff6e1;
  }

  .psc-head {
    margin-bottom: 0.9rem;
  }

  .psc-eyebrow {
    margin: 0 0 0.3rem;
    color: var(--public-accent);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .psc--accent .psc-eyebrow {
    color: rgba(255, 246, 225, 0.86);
  }

  .psc-title {
    margin: 0;
    color: var(--public-text);
    font-size: 0.92rem;
    font-weight: 700;
  }

  .psc--accent .psc-title {
    color: #fff;
  }

  .psc-body {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
</style>
