---
import Image from '../Image.astro';

interface Item {
  href: string;
  title: string;
  description?: string | undefined;
  imageSrc?: string | undefined;
  imageAlt?: string | undefined;
  meta?: string | undefined;
}

interface Props {
  title: string;
  items: Item[];
}

const { title, items = [] } = Astro.props;
---

{items.length > 0 && (
  <section class="prg">
    <p class="prg-title">{title}</p>
    <div class="prg-grid">
      {items.map((item) => (
        <a href={item.href} class="prg-card">
          {item.imageSrc && (
            <div class="prg-media">
              <Image
                src={item.imageSrc}
                alt={item.imageAlt || item.title}
                class="prg-image"
                loading="lazy"
                width={420}
                height={240}
                sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
              />
            </div>
          )}
          <div class="prg-body">
            {item.meta && <p class="prg-meta">{item.meta}</p>}
            <p class="prg-name">{item.title}</p>
            {item.description && <p class="prg-desc">{item.description}</p>}
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .prg {
    margin-top: 3rem;
  }

  .prg-title {
    margin: 0 0 1rem;
    color: var(--public-text);
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem;
    font-weight: 700;
  }

  .prg-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .prg-card {
    border: 1px solid var(--public-border);
    border-radius: var(--public-radius);
    background: var(--public-surface);
    text-decoration: none;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }

  .prg-card:hover {
    border-color: var(--public-accent);
    transform: translateY(-2px);
  }

  .prg-media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--public-accent-soft);
  }

  .prg-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .prg-body {
    padding: 1rem;
  }

  .prg-meta {
    margin: 0 0 0.3rem;
    color: var(--public-accent);
    font-size: 0.72rem;
  }

  .prg-name {
    margin: 0 0 0.35rem;
    color: var(--public-text);
    font-size: 0.92rem;
    font-weight: 700;
  }

  .prg-desc {
    margin: 0;
    color: var(--public-muted);
    font-size: 0.8rem;
    line-height: 1.5;
  }
</style>
