---
import Image from '../Image.astro';
import { Icon } from 'astro-icon/components';

type Badge = {
  label: string;
  tone?: 'default' | 'accent';
};

type MetaItem = {
  label: string;
  icon?: string;
};

type Item = {
  href: string;
  title: string;
  description?: string;
  imageSrc: string;
  imageAlt?: string;
  badges?: Badge[];
  metaItems?: MetaItem[];
};

interface Props {
  items: Item[];
}

const { items = [] } = Astro.props;
---

{items.length > 0 && (
  <div class="pcl">
    {items.map((item) => (
      <a href={item.href} class="pcl-card">
        <div class="pcl-media">
          <Image
            src={item.imageSrc}
            alt={item.imageAlt || item.title}
            width={640}
            height={360}
            class="pcl-image"
            loading="lazy"
            sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
          />
        </div>
        <div class="pcl-body">
          {item.badges && item.badges.length > 0 && (
            <div class="pcl-badges">
              {item.badges.map((badge) => (
                <span class:list={['pcl-badge', badge.tone === 'accent' && 'pcl-badge--accent']}>
                  {badge.label}
                </span>
              ))}
            </div>
          )}
          <h2 class="pcl-title">{item.title}</h2>
          {item.description && <p class="pcl-desc">{item.description}</p>}
          {item.metaItems && item.metaItems.length > 0 && (
            <div class="pcl-meta">
              {item.metaItems.map((meta) => (
                <span class="pcl-meta-item">
                  {meta.icon && <Icon name={meta.icon} style="width:1rem;height:1rem" />}
                  {meta.label}
                </span>
              ))}
            </div>
          )}
        </div>
      </a>
    ))}
  </div>
)}

<style>
  .pcl {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .pcl-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid var(--public-border);
    border-radius: var(--public-radius);
    background: var(--public-surface);
    text-decoration: none;
    transition: border-color 0.15s ease, background 0.15s ease;
  }

  .pcl-card:hover {
    border-color: var(--public-accent);
    background: var(--public-surface-hover);
  }

  .pcl-media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--public-accent-soft);
    flex-shrink: 0;
  }

  .pcl-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .pcl-card:hover .pcl-image {
    transform: scale(1.03);
  }

  .pcl-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    justify-content: center;
    padding: 1.25rem 1.5rem;
  }

  .pcl-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.65rem;
  }

  .pcl-badge {
    padding: 0.2rem 0.6rem;
    border: 1px solid var(--public-border);
    color: var(--public-accent);
    font-size: 0.67rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .pcl-badge--accent {
    border-color: var(--public-accent);
    background: var(--public-accent-soft);
    color: var(--public-accent-strong);
  }

  .pcl-title {
    margin: 0 0 0.45rem;
    color: var(--public-text);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .pcl-desc {
    margin: 0 0 0.75rem;
    color: var(--public-muted);
    font-size: 0.8rem;
    line-height: 1.6;
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .pcl-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    color: var(--public-text-soft);
    font-size: 0.75rem;
  }

  .pcl-meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  @media (min-width: 640px) {
    .pcl-card {
      flex-direction: row;
    }

    .pcl-media {
      width: 32%;
      aspect-ratio: auto;
    }
  }
</style>
