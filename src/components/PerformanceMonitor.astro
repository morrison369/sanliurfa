---
// Performance monitoring component
// Injects performance tracking scripts
---

{import.meta.env.PROD && (
  <script>
    // Core Web Vitals monitoring
    (function() {
      // Wait for page load
      if (document.readyState === 'complete') {
        initMonitoring();
      } else {
        window.addEventListener('load', initMonitoring);
      }

      function initMonitoring() {
        // Use requestIdleCallback for non-critical work
        if ('requestIdleCallback' in window) {
          requestIdleCallback(collectMetrics);
        } else {
          setTimeout(collectMetrics, 1000);
        }
      }

      function collectMetrics() {
        // Navigation Timing
        const nav = performance.getEntriesByType('navigation')[0] as PerformanceNavigationTiming;
        if (nav) {
          logMetric('TTFB', nav.responseStart - nav.startTime);
          logMetric('DOMContentLoaded', nav.domContentLoadedEventEnd - nav.startTime);
          logMetric('Load', nav.loadEventEnd - nav.startTime);
        }

        // LCP
        if ('PerformanceObserver' in window) {
          new PerformanceObserver((list) => {
            const entries = list.getEntries();
            const lastEntry = entries[entries.length - 1] as PerformanceEntry & { startTime: number };
            logMetric('LCP', lastEntry.startTime);
          }).observe({ entryTypes: ['largest-contentful-paint'] as any });

          // CLS
          let clsValue = 0;
          new PerformanceObserver((list) => {
            for (const entry of list.getEntries()) {
              const clsEntry = entry as PerformanceEntry & { hadRecentInput: boolean; value: number };
              if (!clsEntry.hadRecentInput) {
                clsValue += clsEntry.value;
              }
            }
            logMetric('CLS', clsValue);
          }).observe({ entryTypes: ['layout-shift'] as any });

          // FID
          new PerformanceObserver((list) => {
            for (const entry of list.getEntries()) {
              const fidEntry = entry as PerformanceEntry & { processingStart: number; startTime: number };
              logMetric('FID', fidEntry.processingStart - fidEntry.startTime);
            }
          }).observe({ entryTypes: ['first-input'] as any });
        }
      }

      function logMetric(name: string, value: number) {
        // Send to analytics (using sendBeacon for reliability)
        const data = JSON.stringify({
          name,
          value,
          url: window.location.href,
          timestamp: new Date().toISOString(),
        });

        if (navigator.sendBeacon) {
          navigator.sendBeacon('/api/analytics/performance', data);
        }

        // Console log in dev mode
        if (import.meta.env.DEV) {
          console.log(`[Performance] ${name}: ${value}`);
        }
      }
    })();
  </script>
)}

{/* Resource hints */}
<link rel="dns-prefetch" href="//fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
