---
/**
 * NearbyPharmacies — Server Island
 *
 * Sidebar widget on /mahalleler/[ilce]/[mahalle] showing nearby pharmacies.
 * Used with `server:defer` so the main neighborhood content (district + place list)
 * streams without waiting on the pharmacies query.
 *
 * <NearbyPharmacies neighborhoodId={neighborhood.id} server:defer>
 * <div slot="fallback" class="..." />
 * </NearbyPharmacies>
 */
import { query } from '../../lib/postgres';
import { logger } from '../../lib/logging';

interface Props {
 neighborhoodId: string | number;
}

const { neighborhoodId } = Astro.props;

let nearbyPharmacies: Array<{
 name: string;
 address: string | null;
 phone: string | null;
}> = [];

try {
 const result = await query(
 'SELECT name, address, phone FROM pharmacies WHERE neighborhood_id = $1 ORDER BY name LIMIT 10',
 [neighborhoodId],
 );
 nearbyPharmacies = result.rows;
} catch (e) {
 logger.error('NearbyPharmacies query failed', e instanceof Error ? e : new Error(String(e)));
}
---

<div class="bg-[var(--bg-card)] border border-[rgba(184,115,51,0.14)] rounded-sm p-5 mb-6">
 <h3 class="font-bold text-[#1F1410] mb-3">💊 Yakın Eczaneler</h3>
 {nearbyPharmacies.length > 0 ? (
 <div class="space-y-3">
 {nearbyPharmacies.map((ph) => (
 <div class="text-sm">
 <p class="font-medium text-[#1F1410]">{ph.name}</p>
 <p class="text-[#7A6B58] text-xs">{ph.address}</p>
 {ph.phone && <a href={`tel:${ph.phone}`} class="text-[#B87333] text-xs">{ph.phone}</a>}
 </div>
 ))}
 </div>
 ) : (
 <p class="text-[#7A6B58] text-sm">Yakın eczane bilgisi eklenecek.</p>
 )}
 <a href="/saglik/nobetci-eczaneler" class="text-sm text-[#B87333] hover:underline mt-3 block">Nöbetçi Eczaneler →</a>
</div>
