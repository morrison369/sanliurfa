---
type Feature = {
  title: string;
  description: string;
};

export interface Props {
  eyebrow: string;
  title: string;
  description: string;
  loginRedirect: string;
  features: Feature[];
}

const { eyebrow, title, description, loginRedirect, features } = Astro.props;
---

<section
  class="bg-gradient-to-br from-urfa-950 via-urfa-900 to-isot-900 text-white"
>
  <div class="container-custom py-14">
    <p class="text-sm uppercase tracking-wide text-urfa-200">{eyebrow}</p>
    <h1 class="mt-3 text-4xl md:text-5xl font-display font-bold">{title}</h1>
    <p class="mt-4 max-w-3xl text-lg text-urfa-100">{description}</p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a href="/kayit" class="btn-accent">Ücretsiz hesap oluştur</a>
      <a
        href={`/giris?redirect=${encodeURIComponent(loginRedirect)}`}
        class="btn bg-white/10 text-white hover:bg-white/20"
      >
        Giriş yap
      </a>
    </div>
  </div>
</section>

<section class="section bg-gray-50 dark:bg-gray-900">
  <div class="container-custom">
    <div class="grid gap-6 md:grid-cols-3">
      {
        features.map((feature) => (
          <article class="rounded-3xl border border-gray-100 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-800">
            <h2 class="text-xl font-display font-bold text-gray-900 dark:text-white">
              {feature.title}
            </h2>
            <p class="mt-3 text-sm leading-6 text-gray-600 dark:text-gray-400">
              {feature.description}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
