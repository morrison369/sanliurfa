---
// Rich Text Editor Component using Quill
interface Props {
  name: string;
  value?: string;
  placeholder?: string;
  height?: string;
}

const { name, value = '', placeholder = 'İçerik yazın...', height = '400px' } = Astro.props;
const editorId = `editor-${Math.random().toString(36).substr(2, 9)}`;
const textareaId = `textarea-${name}`;
---

<div class="rich-text-editor">
  <div id={editorId} style={`height: ${height};`}></div>
  <textarea 
    id={textareaId} 
    name={name} 
    class="hidden" 
    set:html={value}
  ></textarea>
</div>

<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet" />
<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>

<script define:vars={{ editorId, textareaId, placeholder, value }}>
  const toolbarOptions = [
    [{ 'header': [1, 2, 3, false] }],
    ['bold', 'italic', 'underline'],
    [{ 'color': [] }, { 'background': [] }],
    ['blockquote', 'code-block'],
    [{ 'list': 'ordered'}, { 'list': 'bullet' }],
    [{ 'align': [] }],
    ['link', 'image'],
    ['clean']
  ];

  const quill = new Quill(`#${editorId}`, {
    theme: 'snow',
    placeholder: placeholder,
    modules: { toolbar: toolbarOptions }
  });

  if (value) {
    quill.root.innerHTML = value;
  }

  const textarea = document.getElementById(textareaId);
  const form = textarea?.closest('form');
  
  if (form) {
    form.addEventListener('submit', () => {
      textarea.value = quill.root.innerHTML;
    });
  }
</script>

<style is:global>
  .ql-toolbar {
    border-top-left-radius: 0.5rem;
    border-top-right-radius: 0.5rem;
    background: #f9fafb;
  }
  .ql-container {
    border-bottom-left-radius: 0.5rem;
    border-bottom-right-radius: 0.5rem;
  }
</style>
