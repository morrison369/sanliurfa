---
/**
 * BlogRelatedEvents — Blog yazısıyla aynı kategoride yaklaşan etkinlikleri gösterir.
 * server:defer ile kullanılır, blog içeriğinin yüklenmesini bloke etmez.
 */
import { query } from '../../lib/postgres';
import { logger } from '../../lib/logging';
import { resolveEventImage } from '../../lib/public-image-resolvers';
import Image from '../Image.astro';

interface Props {
  category: string;
  limit?: number;
}

const { category, limit = 3 } = Astro.props;

const categoryMap: Record<string, string[]> = {
  'Gastronomi': ['Gastronomi'],
  'Turizm': ['Turizm', 'Kültür'],
  'Kültür': ['Kültür', 'Sanat', 'Festival'],
  'Tarih': ['Kültür', 'Turizm'],
  'Sanat': ['Sanat', 'Kültür'],
  'Festival': ['Festival', 'Kültür'],
  'Gezi': ['Turizm', 'Festival'],
};

const eventCategories = categoryMap[category] ?? [category];

let events: Array<{ title: string; slug: string; image_url: string | null; start_date: string; location: string | null; is_free: boolean }> = [];

try {
  const result = await query(
    `SELECT title, slug, image_url, start_date, location, is_free
     FROM events
     WHERE status = 'published'
       AND category = ANY($1::text[])
       AND start_date >= CURRENT_DATE
     ORDER BY start_date ASC
     LIMIT $2`,
    [eventCategories, limit],
  );
  events = result.rows;
} catch (e) {
  logger.error('BlogRelatedEvents query failed', e instanceof Error ? e : new Error(String(e)));
}

const fmt = (d: string) => new Date(d).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long' });
const getImg = (ev: typeof events[number]) => resolveEventImage(ev, { thumb: true });
---

{events.length > 0 && (
  <aside class="bre-wrap">
    <h3 class="bre-title">Yaklaşan Etkinlikler</h3>
    <ul class="bre-list">
      {events.map((ev) => (
        <li class="bre-item">
          <a href={`/etkinlikler/${ev.slug}`} class="bre-link">
            <Image src={getImg(ev)} alt={ev.title} class="bre-img" loading="lazy" width={64} height={64} />
            <div class="bre-info">
              <span class="bre-name">{ev.title}</span>
              <span class="bre-meta">
                {fmt(ev.start_date)}
                {ev.is_free && <span class="bre-free">Ücretsiz</span>}
              </span>
            </div>
          </a>
        </li>
      ))}
    </ul>
    <a href="/etkinlikler" class="bre-all">Tüm Etkinlikler →</a>
  </aside>
)}

<style>
.bre-wrap {
  background: var(--bg-card, #fff);
  border: 1px solid rgba(184,115,51,.13);
  border-radius: 1rem;
  padding: 1.25rem 1.1rem;
  margin-top: 1.5rem;
}
.bre-title {
  font-size: .8rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
  color: var(--urfa-600, #b87333); margin: 0 0 .9rem;
}
.bre-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: .6rem; }
.bre-link {
  display: flex; gap: .75rem; align-items: center; text-decoration: none;
  padding: .5rem .4rem; border-radius: .6rem;
  transition: background .15s;
}
.bre-link:hover { background: rgba(184,115,51,.07); }
.bre-img { width: 52px; height: 52px; object-fit: cover; border-radius: .5rem; flex-shrink: 0; }
.bre-info { display: flex; flex-direction: column; gap: .15rem; min-width: 0; }
.bre-name {
  font-size: .85rem; font-weight: 600; color: var(--text-primary, #1a1a1a);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.bre-meta { font-size: .75rem; color: var(--text-muted, #777); display: flex; align-items: center; gap: .4rem; }
.bre-free {
  background: rgba(44,122,82,.12); color: #2c7a52;
  font-size: .65rem; font-weight: 700; padding: .1rem .4rem; border-radius: .3rem;
}
.bre-all {
  display: block; text-align: center; margin-top: .9rem;
  font-size: .78rem; font-weight: 600; color: var(--urfa-600, #b87333);
  text-decoration: none;
}
.bre-all:hover { text-decoration: underline; }
</style>
