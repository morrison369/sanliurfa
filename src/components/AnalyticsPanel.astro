---
import LoadingWrapper from './ui/LoadingWrapper.astro';
import { UI_COPY_TR } from '../lib/ui-copy';
---

<LoadingWrapper
  contentClass="hidden"
  contentDataAttr="data-analytics-panel-content"
  loadingClass="flex items-center justify-center p-8"
  loadingDataAttr="data-analytics-panel-loading"
  message={UI_COPY_TR.analytics.loading}
  spinner={true}
/>

<script>
  import { initAnalyticsPanel } from '../scripts/analytics-panel';

  initAnalyticsPanel();
</script>
