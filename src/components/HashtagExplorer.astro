---
interface Props {
  initialSlug?: string | null;
}

const { initialSlug = null } = Astro.props;
---

<div data-hashtag-explorer data-initial-slug={initialSlug || ''}>
  <div data-hashtag-explorer-content class="space-y-6">
    <div class="space-y-6">
      <div class="h-12 animate-pulse rounded bg-gray-200 dark:bg-gray-700"></div>
      <div class="grid grid-cols-2 gap-4">
        <div class="h-24 animate-pulse rounded bg-gray-200 dark:bg-gray-700"></div>
        <div class="h-24 animate-pulse rounded bg-gray-200 dark:bg-gray-700"></div>
        <div class="h-24 animate-pulse rounded bg-gray-200 dark:bg-gray-700"></div>
        <div class="h-24 animate-pulse rounded bg-gray-200 dark:bg-gray-700"></div>
      </div>
    </div>
  </div>
</div>

<script>
  import { initHashtagExplorer } from '../scripts/hashtag-explorer';

  initHashtagExplorer();
</script>
