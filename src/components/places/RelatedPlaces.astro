---
/**
 * RelatedPlaces — Server Island
 *
 * Renders the "Similar places" panel on a venue detail page. Designed to be used
 * with `server:defer` so the main place content reaches the browser before this
 * secondary query completes:
 *
 *   <RelatedPlaces categoryId={place.category_id} excludePlaceId={place.id} server:defer>
 *     <div slot="fallback" class="animate-pulse h-32 bg-gray-100 rounded-xl" />
 *   </RelatedPlaces>
 *
 * Returns nothing (empty markup) when no related places are found, so the parent
 * layout collapses naturally.
 */
import { query } from '../../lib/postgres';
import { logger } from '../../lib/logging';

interface Props {
  categoryId: string | null | undefined;
  excludePlaceId: string | null | undefined;
}

const { categoryId, excludePlaceId } = Astro.props;

let relatedPlaces: Array<{
  slug: string;
  name: string;
  short_description: string | null;
  rating: number | null;
  price_range: string | null;
}> = [];

if (categoryId && excludePlaceId) {
  try {
    const result = await query(
      `SELECT id, name, slug, short_description, rating, price_range
       FROM places
       WHERE category_id = $1 AND id != $2 AND status = 'active'
       ORDER BY rating DESC LIMIT 4`,
      [categoryId, excludePlaceId],
    );
    relatedPlaces = result.rows;
  } catch (e) {
    // Soft-fail: empty section is preferable to a 500 page on a secondary widget.
    logger.error('RelatedPlaces query failed', e instanceof Error ? e : new Error(String(e)));
  }
}
---

{relatedPlaces.length > 0 && (
  <div class="bg-white rounded-xl p-6 shadow-sm">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Benzer Mekanlar</h2>
    <div class="grid sm:grid-cols-2 gap-4">
      {relatedPlaces.map((r) => (
        <a
          href={`/isletme/${r.slug}`}
          class="flex items-center gap-3 p-3 rounded-lg border hover:border-red-300 hover:bg-red-50 transition-colors group"
        >
          <div class="w-10 h-10 bg-red-100 rounded-lg flex items-center justify-center text-lg flex-shrink-0">🍽️</div>
          <div>
            <p class="font-medium text-gray-900 group-hover:text-red-600 text-sm">{r.name}</p>
            {r.rating && <p class="text-xs text-gray-500">★ {r.rating}</p>}
          </div>
        </a>
      ))}
    </div>
  </div>
)}
