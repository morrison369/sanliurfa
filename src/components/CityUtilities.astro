---
import { Plane, Pill, Bus, ArrowRight, MapPin } from 'lucide-react';
import { DEFAULT_PUBLIC_SITE_SETTINGS, type CityServiceItem } from '../lib/site-settings';

interface Props {
  services?: CityServiceItem[];
}

const { services = DEFAULT_PUBLIC_SITE_SETTINGS.cityServices } = Astro.props;

const iconMap: Record<string, any> = {
  'nobetci-eczaneler': Pill,
  'otobus-saatleri': Bus,
  'ucak-saatleri': Plane
};
---

<section class="bg-white dark:bg-gray-900 border-y border-gray-100 dark:border-gray-800">
  <div class="container-custom py-12">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-8">
      <div>
        <p class="text-sm font-semibold tracking-wide text-urfa-600 uppercase">Şehir Servisleri</p>
        <h2 class="text-3xl font-display font-bold text-gray-900 dark:text-white mt-2">
          Güncel Şanlıurfa Bilgileri
        </h2>
        <p class="text-gray-600 dark:text-gray-300 mt-2">
          Nöbetçi eczaneler, otobüs saatleri ve uçak seferleri için hızlı erişim.
        </p>
      </div>
      <a href="/sehir-servisleri" class="inline-flex items-center gap-2 text-urfa-600 font-medium hover:text-urfa-700">
        Tüm servisler
        <ArrowRight className="w-4 h-4" />
      </a>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      {services.map((service) => {
        const Icon = iconMap[service.slug] || MapPin;
        return (
          <a
            href={service.href}
            class="group rounded-2xl border border-gray-200 dark:border-gray-700 p-5 bg-gray-50 dark:bg-gray-800 hover:border-urfa-400 hover:shadow-lg transition-all"
          >
            <div class="flex items-center justify-between gap-4 mb-4">
              <div class="w-12 h-12 rounded-xl bg-urfa-100 dark:bg-urfa-900/30 text-urfa-700 dark:text-urfa-300 flex items-center justify-center">
                <Icon className="w-6 h-6" />
              </div>
              {service.badge && (
                <span class="px-2.5 py-1 rounded-full bg-isot-100 text-isot-700 text-xs font-semibold">
                  {service.badge}
                </span>
              )}
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{service.title}</h3>
            <p class="text-sm text-gray-600 dark:text-gray-300 mt-2">{service.description}</p>
            <span class="inline-flex items-center gap-1 text-sm font-medium text-urfa-700 mt-4">
              Detaya git
              <ArrowRight className="w-4 h-4 transition-transform group-hover:translate-x-1" />
            </span>
          </a>
        );
      })}
    </div>
  </div>
</section>
