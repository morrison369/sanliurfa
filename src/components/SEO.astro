---
import { getSiteSetting } from '../lib/site-content';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noIndex?: boolean;
  noFollow?: boolean;
  keywords?: string[];
  author?: string;
  publishedTime?: string;
  modifiedTime?: string;
  type?: 'website' | 'article';
}

const {
  title,
  description = '',
  canonical,
  ogImage = '/og-image.png',
  noIndex = false,
  noFollow = false,
  keywords = [],
  author = 'Sanliurfa.com',
  publishedTime,
  modifiedTime,
  type = 'website',
} = Astro.props;

const homepageSchemaFallback = {
  siteName: 'Sanliurfa.com',
  baseUrl: 'https://sanliurfa.com',
};
const homepageSchema = await getSiteSetting('homepage.schema', homepageSchemaFallback);
const siteName = String((homepageSchema as any)?.siteName || homepageSchemaFallback.siteName);
const siteUrl = String((homepageSchema as any)?.baseUrl || import.meta.env.SITE_URL || homepageSchemaFallback.baseUrl);
const fullTitle = title.includes('Şanlıurfa') ? title : `${title} | ${siteName}`;
const canonicalUrl = canonical ? `${siteUrl}${canonical.replace(/\/$/, '')}` : `${siteUrl}${Astro.url.pathname.replace(/\/$/, '')}`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
const ogImageExt = ogImageUrl.split('?')[0].split('.').pop()?.toLowerCase() || 'jpeg';
const ogImageType = ogImageExt === 'webp' ? 'image/webp' : ogImageExt === 'png' ? 'image/png' : ogImageExt === 'gif' ? 'image/gif' : 'image/jpeg';
---

<!-- Primary Meta Tags -->
<title>{fullTitle}</title>
<meta name="description" content={description} />
{keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
<meta name="author" content={author} />
<meta name="robots" content={`${noIndex ? 'noindex' : 'index'}, ${noFollow ? 'nofollow' : 'follow'}`} />
<link rel="canonical" href={canonicalUrl} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content={ogImageType} />
<meta property="og:image:alt" content={fullTitle} />
<meta property="og:site_name" content={siteName} />
<meta property="og:locale" content="tr_TR" />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalUrl} />
<meta property="twitter:title" content={fullTitle} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={ogImageUrl} />
<meta property="twitter:image:alt" content={fullTitle} />

<!-- Article specific -->
{type === 'article' && (
  <>
    <meta property="article:author" content={author} />
  </>
)}


