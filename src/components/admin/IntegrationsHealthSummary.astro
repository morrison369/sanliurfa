---
/**
 * IntegrationsHealthSummary — Server Island
 *
 * Admin dashboard widget: at-a-glance status of all 5 admin-managed integrations.
 * Each integration is a clickable card linking to /admin/integrations.
 */
import { Icon } from 'astro-icon/components';
import { queryOne } from '../../lib/postgres';
import { logger } from '../../lib/logging';

type Status = 'configured' | 'unconfigured';

const summary: Record<string, Status> = {
 resend: 'unconfigured',
 smtp: 'unconfigured',
 stripe: 'unconfigured',
 analytics: 'unconfigured',
 image_providers: 'unconfigured',
};

try {
 const rows = await Promise.all([
  queryOne<{ setting_value: { api_key?: string } }>(
   `SELECT setting_value FROM site_settings WHERE setting_key = 'integrations.email'`, [],
  ),
  queryOne<{ setting_value: { host?: string; user?: string; pass?: string } }>(
   `SELECT setting_value FROM site_settings WHERE setting_key = 'integrations.smtp'`, [],
  ),
  queryOne<{ setting_value: { secret_key?: string } }>(
   `SELECT setting_value FROM site_settings WHERE setting_key = 'integrations.payment'`, [],
  ),
  queryOne<{ setting_value: { ga_id?: string } }>(
   `SELECT setting_value FROM site_settings WHERE setting_key = 'integrations.analytics'`, [],
  ),
  queryOne<{ setting_value: { unsplash_access_key?: string; pexels_api_key?: string } }>(
   `SELECT setting_value FROM site_settings WHERE setting_key = 'integrations.image_providers'`, [],
  ),
 ]);
 if (rows[0]?.setting_value?.api_key || process.env.RESEND_API_KEY) summary.resend = 'configured';
 const smtp = rows[1]?.setting_value;
 if ((smtp?.host && smtp?.user && smtp?.pass) || (process.env.SMTP_HOST && process.env.SMTP_USER && process.env.SMTP_PASS)) summary.smtp = 'configured';
 if (rows[2]?.setting_value?.secret_key || process.env.STRIPE_SECRET_KEY) summary.stripe = 'configured';
 if (rows[3]?.setting_value?.ga_id) summary.analytics = 'configured';
 const ip = rows[4]?.setting_value;
 if (ip?.unsplash_access_key || ip?.pexels_api_key || process.env.UNSPLASH_ACCESS_KEY || process.env.PEXELS_API_KEY) summary.image_providers = 'configured';
} catch (e) {
 logger.error('IntegrationsHealthSummary lookup failed', e instanceof Error ? e : new Error(String(e)));
}

const cards: Array<{ key: string; name: string; icon: string; status: Status }> = [
 { key: 'resend', name: 'Resend', icon: 'lucide:mail', status: summary.resend },
 { key: 'smtp', name: 'SMTP', icon: 'lucide:server', status: summary.smtp },
 { key: 'stripe', name: 'Stripe', icon: 'lucide:credit-card', status: summary.stripe },
 { key: 'analytics', name: 'Analytics', icon: 'lucide:bar-chart-3', status: summary.analytics },
 { key: 'image_providers', name: 'Resim API', icon: 'lucide:image', status: summary.image_providers },
];

const configuredCount = cards.filter((c) => c.status === 'configured').length;
const healthRatio = (configuredCount / cards.length) * 100;
---

<section class="ihs-section">
 <header class="ihs-head">
  <div class="ihs-head-info">
   <h2 class="ihs-title">
    <Icon name="lucide:plug" class="w-4 h-4" /> Entegrasyon Sağlığı
   </h2>
   <div class="ihs-meta">
    <span class="ihs-bar">
     <span class="ihs-bar-fill" style={`width: ${healthRatio}%`}></span>
    </span>
    <span class="ihs-meta-text"><strong>{configuredCount}</strong> / {cards.length} aktif</span>
   </div>
  </div>
  <a href="/admin/integrations" class="ihs-manage">
   Yönet
   <Icon name="lucide:arrow-right" class="w-3.5 h-3.5" />
  </a>
 </header>

 <div class="ihs-grid">
  {cards.map((c) => (
   <a
    href="/admin/integrations"
    class:list={['ihs-card', c.status === 'configured' ? 'ihs-card--ok' : 'ihs-card--off']}
   >
    <div class="ihs-card-ico">
     <Icon name={c.icon} class="w-4 h-4" />
    </div>
    <div class="ihs-card-name">{c.name}</div>
    <div class:list={['ihs-card-status', c.status === 'configured' ? 'ihs-card-status--ok' : 'ihs-card-status--off']}>
     {c.status === 'configured' ? (
      <>
       <Icon name="lucide:check-circle" class="w-3 h-3" /> Aktif
      </>
     ) : (
      <>
       <Icon name="lucide:alert-circle" class="w-3 h-3" /> Eksik
      </>
     )}
    </div>
   </a>
  ))}
 </div>
</section>

<style>
 .ihs-section {
  background: var(--adm-bg-elev);
  border: 1px solid var(--adm-border);
  border-radius: 12px;
  padding: 1.15rem 1.25rem;
 }

 .ihs-head {
  display: flex; align-items: center; justify-content: space-between;
  gap: 1rem;
  margin-bottom: 1rem;
  flex-wrap: wrap;
 }
 .ihs-head-info { min-width: 0; flex: 1; }
 .ihs-title {
  display: inline-flex; align-items: center; gap: 0.5rem;
  margin: 0 0 0.5rem;
  font-size: 1rem; font-weight: 600;
  color: var(--adm-text);
 }
 .ihs-meta {
  display: flex; align-items: center; gap: 0.65rem;
 }
 .ihs-bar {
  display: block;
  flex: 1; max-width: 200px;
  height: 6px;
  background: var(--adm-bg);
  border-radius: 999px;
  overflow: hidden;
 }
 .ihs-bar-fill {
  display: block;
  height: 100%;
  background: linear-gradient(90deg, rgb(16,185,129), rgb(5,150,105));
  transition: width 0.3s;
 }
 .ihs-meta-text {
  font-size: 0.82rem;
  color: var(--adm-text-muted);
  font-weight: 500;
  white-space: nowrap;
 }
 .ihs-meta-text strong { color: var(--adm-text); font-weight: 700; }

 .ihs-manage {
  display: inline-flex; align-items: center; gap: 0.3rem;
  padding: 0.45rem 0.85rem;
  background: var(--adm-accent);
  color: #fff;
  border-radius: 8px;
  font-size: 0.82rem; font-weight: 600;
  text-decoration: none;
  transition: filter 0.15s;
  flex-shrink: 0;
 }
 .ihs-manage:hover { filter: brightness(0.93); }

 .ihs-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: 0.65rem;
 }
 .ihs-card {
  display: flex; flex-direction: column; align-items: center;
  padding: 0.85rem 0.65rem;
  background: var(--adm-bg);
  border: 1px solid var(--adm-border);
  border-radius: 10px;
  text-decoration: none;
  text-align: center;
  transition: all 0.18s;
 }
 .ihs-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 20px -6px rgba(31,20,16,0.1);
 }
 .ihs-card--ok { border-color: rgba(16,185,129,0.25); }
 .ihs-card--ok:hover { border-color: rgb(16,185,129); }
 .ihs-card--off { border-color: rgba(225,29,72,0.18); }
 .ihs-card--off:hover { border-color: rgb(190,18,60); }

 .ihs-card-ico {
  width: 36px; height: 36px;
  border-radius: 9px;
  display: inline-flex; align-items: center; justify-content: center;
  margin-bottom: 0.5rem;
 }
 .ihs-card--ok .ihs-card-ico { background: rgba(16,185,129,0.12); color: rgb(5,150,105); }
 .ihs-card--off .ihs-card-ico { background: rgba(225,29,72,0.12); color: rgb(190,18,60); }

 .ihs-card-name {
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--adm-text);
  margin-bottom: 0.35rem;
 }
 .ihs-card-status {
  display: inline-flex; align-items: center; gap: 0.2rem;
  font-size: 0.7rem;
  font-weight: 600;
 }
 .ihs-card-status--ok { color: rgb(5,150,105); }
 .ihs-card-status--off { color: rgb(190,18,60); }
</style>
