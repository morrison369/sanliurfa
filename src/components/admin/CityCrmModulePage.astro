---
import { Icon } from 'astro-icon/components';
import type { AdminCrmModule } from '../../data/admin-city-crm';
import AdsCrmPanel from './AdsCrmPanel.astro';
import ClassifiedsCrmPanel from './ClassifiedsCrmPanel.astro';
import ControlCrmPanel from './ControlCrmPanel.astro';
import LocationsCrmPanel from './LocationsCrmPanel.astro';
import OpsCrmPanel from './OpsCrmPanel.astro';
import SeoCrmPanel from './SeoCrmPanel.astro';
import SocialCrmPanel from './SocialCrmPanel.astro';
import { getAdSenseAdminSummary } from '../../lib/admin/adsense-admin';
import { buildBotFindings, getAdminCrmCounts, getAdminCrmPreview, getBotCards } from '../../lib/admin/city-crm';

interface Props {
  module: AdminCrmModule;
}

const { module } = Astro.props as Props;
const counts = await getAdminCrmCounts();
const rows = await getAdminCrmPreview(module);
const bots = getBotCards(module.botKeys);
const adsenseSummary = module.slug === 'ads' ? await getAdSenseAdminSummary() : null;
---

<div class="crm-page" data-city-crm-live>
  <section class="crm-module-hero">
    <div class="crm-module-title">
      <span><Icon name={module.icon} class="w-4 h-4" /></span>
      <div>
        <p>{module.eyebrow}</p>
        <h2>{module.title}</h2>
      </div>
    </div>
    <p class="crm-module-desc">{module.description}</p>
    <div class="crm-actions">
      {module.primaryHref && <a href={module.primaryHref} class="crm-btn crm-btn--primary">{module.primaryLabel || 'Yeni kayıt'}</a>}
      {module.existingHref && <a href={module.existingHref} class="crm-btn">Mevcut ekranı aç</a>}
      <a href="/admin/bots" class="crm-btn">Botlar</a>
    </div>
  </section>

  <section class="crm-grid-3">
    <div class="crm-card">
      <span class="crm-card-label">Filtre/segment</span>
      <strong>{module.filters.length}</strong>
      <p>Liste ekranında kullanılacak ana filtreler tanımlı.</p>
    </div>
    <div class="crm-card">
      <span class="crm-card-label">Form alanı</span>
      <strong>{module.fields.length}</strong>
      <p>Büyük formlar sekmeli UX ile yönetilecek alan haritası.</p>
    </div>
    <div class="crm-card">
      <span class="crm-card-label">Manuel bot</span>
      <strong>{module.botKeys.length}</strong>
      <p>Otomatik işlem yok; öneriler admin onayına düşer.</p>
    </div>
  </section>

  <section class="crm-panel">
    <div class="crm-panel-head">
      <div>
        <h3>Liste ve segmentleme</h3>
        <p>Vercel/Linear tarzı kompakt tablo için kullanılacak filtreler.</p>
      </div>
      <div class="crm-search-row">
        <input type="search" placeholder={`${module.title} içinde ara...`} data-crm-filter />
        <button type="button">Filtrele</button>
      </div>
    </div>
    <div class="crm-chip-row">
      {module.filters.map((filter) => <span>{filter}</span>)}
    </div>
  </section>

  {module.slug === 'businesses' && (
    <section class="crm-panel crm-business-crm">
      <div class="crm-panel-head">
        <div>
          <h3>Canlı Mekanlar CRM tablosu</h3>
          <p>Mevcut `/api/admin/places` endpoint’i ile çalışır. Bulk işlemler soft status değiştirir; veri silmez.</p>
        </div>
        <a class="crm-btn crm-btn--primary" href="/admin/places/add">Yeni işletme</a>
      </div>
      <div class="crm-live-toolbar">
        <input type="search" id="crm-place-search" placeholder="İşletme adı, adres veya kategori ara..." />
        <select id="crm-place-status">
          <option value="all">Tüm durumlar</option>
          <option value="active">Yayında</option>
          <option value="pending">Onay bekliyor</option>
          <option value="suspended">Pasif</option>
          <option value="rejected">Reddedildi</option>
        </select>
        <button type="button" id="crm-place-load">Ara</button>
      </div>
      <div class="crm-table-wrap">
        <table class="crm-table crm-live-table">
          <thead>
            <tr>
              <th><input type="checkbox" id="crm-place-all" aria-label="Tümünü seç" /></th>
              <th>İşletme</th>
              <th>Kategori</th>
              <th>Durum</th>
              <th>Kalite</th>
              <th>Aksiyon</th>
            </tr>
          </thead>
          <tbody id="crm-place-body">
            <tr><td colspan="6">Yükleniyor...</td></tr>
          </tbody>
        </table>
      </div>
      <div class="crm-bulkbar" id="crm-place-bulk" hidden>
        <strong><span id="crm-place-selected">0</span> kayıt seçildi</strong>
        <button type="button" data-place-bulk="approve">Yayına al</button>
        <button type="button" data-place-bulk="suspend">Pasife çek</button>
        <button type="button" data-place-bulk="feature">Öne çıkar</button>
        <button type="button" data-place-bulk="delete">Arşivle</button>
      </div>
    </section>
  )}

  {module.slug === 'submissions' && (
    <section class="crm-panel">
      <div class="crm-panel-head">
        <div>
          <h3>Başvuru pipeline</h3>
          <p>Başvurular onaylanmadan public siteye otomatik çıkmaz. Tek tıkla işletmeye dönüştürme mevcut kayıt akışına bağlanır.</p>
        </div>
        <a class="crm-btn" href="/admin/claims">Eski talepler ekranı</a>
      </div>
      <div class="crm-pipeline">
        {['Yeni başvuru', 'İnceleniyor', 'Eksik bilgi', 'Onaylandı', 'Yayına alındı', 'Reddedildi', 'Arşiv'].map((column, index) => (
          <section class="crm-pipe-col">
            <h4>{column}</h4>
            <div class="crm-pipe-card">
              <strong>{index === 0 ? `${rows.length} kayıt` : '0 kayıt'}</strong>
              <p>{index === 0 ? 'Son başvurular veri önizleme tablosunda listelenir.' : 'Bu kolon için durum eşleştirme hazır.'}</p>
            </div>
          </section>
        ))}
      </div>
    </section>
  )}

  {(module.slug === 'locations/districts' || module.slug === 'locations/neighborhoods') && (
    <LocationsCrmPanel mode={module.slug} />
  )}

  {(module.slug === 'events' || module.slug === 'pharmacies') && (
    <OpsCrmPanel mode={module.slug} />
  )}

  {(module.slug === 'reviews' || module.slug === 'ads' || module.slug === 'map') && (
    <ControlCrmPanel mode={module.slug} />
  )}

  {(module.slug === 'community/users' ||
    module.slug === 'community/profiles' ||
    module.slug === 'community/reports' ||
    module.slug === 'messages') && (
    <SocialCrmPanel mode={module.slug} />
  )}

  {module.slug === 'classifieds' && (
    <ClassifiedsCrmPanel />
  )}

  {module.slug === 'seo' && (
    <SeoCrmPanel />
  )}

  {module.slug === 'bots' && (
    <section class="crm-panel crm-bot-console">
      <div class="crm-panel-head">
        <div>
          <h3>Manuel bot çalışma sonuçları</h3>
          <p>Botlar veri değiştirmez. Çıkan öneriler burada listelenir; uygulama kararı admin’e aittir.</p>
        </div>
      </div>
      <div class="crm-bot-result" id="crm-bot-result">
        <strong>Henüz bot çalıştırılmadı</strong>
        <p>Alt bölümdeki “Manuel çalıştır” butonlarından biriyle analiz başlatın.</p>
      </div>
    </section>
  )}

  {module.slug === 'settings' && (
    <section class="crm-panel">
      <div class="crm-panel-head">
        <div>
          <h3>Admin kontrollü frontend anahtarları</h3>
          <p>Landing page dahil içerik, görsel ve tema değişiklikleri `site_settings` üzerinden draft/publish akışıyla yönetilir.</p>
        </div>
        <a class="crm-btn crm-btn--primary" href="/admin/site-content">Site içerik editörü</a>
      </div>
      <div class="crm-settings-grid">
        {['homepage.hero', 'homepage.routes', 'homepage.quickAccess', 'homepage.theme', 'homepage.sectionCopy', 'homepage.sectionStyles', 'header.navLinks', 'footer.links'].map((key) => (
          <a href={`/admin/site-content?key=${key}`} class="crm-setting-card">
            <strong>{key}</strong>
            <span>Taslak / önizleme / yayın</span>
          </a>
        ))}
      </div>
    </section>
  )}

  {module.slug === 'media' && (
    <section class="crm-panel">
      <div class="crm-panel-head">
        <div>
          <h3>Local medya kütüphanesi</h3>
          <p>CDN/object storage yok. Görseller local storage + `site_platform` medya kayıtları üzerinden yönetilir.</p>
        </div>
        <button class="crm-btn" type="button" id="crm-media-load">Medya yükle</button>
      </div>
      <div class="crm-media-grid" id="crm-media-grid">
        <div class="crm-empty"><strong>Medya bekleniyor</strong><p>Listeyi yüklemek için butona basın.</p></div>
      </div>
    </section>
  )}

  {module.slug === 'ads' && (
    <AdsCrmPanel adsenseSummary={adsenseSummary} />
  )}

  {module.slug === 'community/users' && (
    <section class="crm-panel">
      <div class="crm-panel-head">
        <div>
          <h3>Rol ve yetki matrisi</h3>
          <p>Mevcut auth korunur. Roller için hangi modülün görülebileceği admin panelinde netleştirildi.</p>
        </div>
        <a class="crm-btn" href="/admin/users">Kullanıcı tablosu</a>
      </div>
      <div class="crm-role-grid">
        {[
          ['Super Admin', 'Her şey'],
          ['Editor', 'Mekan, kategori, blog, etkinlik'],
          ['Moderator', 'Yorum, topluluk, eşleşme, başvuru'],
          ['Sales', 'Reklam ve sponsorlu alanlar'],
          ['SEO Manager', 'SEO merkezi, içerik önerileri'],
          ['Support', 'Başvurular ve işletme destek notları'],
        ].map(([role, scope]) => (
          <article class="crm-role-card">
            <strong>{role}</strong>
            <p>{scope}</p>
          </article>
        ))}
      </div>
    </section>
  )}

  <section class="crm-panel">
    <div class="crm-panel-head">
      <div>
        <h3>Alan haritası</h3>
        <p>CRUD/form geliştirme sözleşmesi. Veri silme yerine pasif/arşiv mantığı kullanılır.</p>
      </div>
    </div>
    <div class="crm-field-grid">
      {module.fields.map((field) => <span>{field}</span>)}
    </div>
  </section>

  <section class="crm-panel">
    <div class="crm-panel-head">
      <div>
        <h3>Veri önizleme</h3>
        <p>Mevcut DB’den okunur; tablo yoksa boş state gösterir, public siteyi bozmaz.</p>
      </div>
    </div>
    {rows.length > 0 ? (
      <div class="crm-table-wrap">
        <table class="crm-table">
          <thead>
            <tr>
              {Object.keys(rows[0]).slice(0, 6).map((key) => <th>{key}</th>)}
            </tr>
          </thead>
          <tbody>
            {rows.map((row) => (
              <tr>
                {Object.entries(row).slice(0, 6).map(([_, value]) => (
                  <td>{value === null || value === undefined ? '—' : String(value)}</td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ) : (
      <div class="crm-empty">
        <Icon name="lucide:database" class="w-5 h-5" />
        <strong>Bu modül için önizleme verisi yok</strong>
        <p>Tablo henüz boş olabilir veya mevcut şemada farklı adla tutuluyor olabilir. Modül UI sözleşmesi hazır.</p>
      </div>
    )}
  </section>

  {bots.length > 0 && (
    <section class="crm-panel">
      <div class="crm-panel-head">
        <div>
          <h3>Manuel bot önerileri</h3>
          <p>Botlar arka planda çalışmaz. Butonlar öneri akışını başlatmak için panel içi manuel tetikleyicidir.</p>
        </div>
      </div>
      <div class="crm-bot-grid">
        {bots.map((bot) => {
          const finding = buildBotFindings(counts, bot);
          return (
            <article class={`crm-bot crm-bot--${bot.risk}`}>
              <div>
                <span class="crm-risk">{bot.risk}</span>
                <h4>{bot.title}</h4>
                <p>{bot.description}</p>
              </div>
              <ul>
                {bot.checks.map((check) => <li>{check}</li>)}
              </ul>
              <div class="crm-bot-foot">
                <span>{finding.issues} sorun · {finding.suggestions} öneri</span>
              <button type="button" data-bot-run={bot.key}>Manuel çalıştır</button>
              </div>
            </article>
          );
        })}
      </div>
    </section>
  )}
</div>

<script is:inline>
  if (document.querySelector('[data-city-crm-live]')) {
    import('/admin/city-crm-live.js')
      .then((module) => module.initCityCrmLive?.())
      .catch(() => {});
  }

  if (document.querySelector('[data-classifieds-crm]')) {
    import('/admin/classifieds-crm.js')
      .then((module) => module.initClassifiedsCrm?.())
      .catch(() => {});
  }

  if (document.querySelector('[data-adsense-live]')) {
    import('/admin/adsense-live.js')
      .then((module) => module.initAdsenseLive?.())
      .catch(() => {});
  }
</script>

<style>
  .crm-page { display: flex; flex-direction: column; gap: 1rem; }
  .crm-module-hero, .crm-panel, .crm-card {
    background: var(--adm-bg-elev); border: 1px solid var(--adm-border); border-radius: 16px;
  }
  .crm-module-hero { padding: 1.25rem; display: grid; gap: 1rem; }
  .crm-module-title { display: flex; align-items: center; gap: .8rem; }
  .crm-module-title > span { width: 42px; height: 42px; border-radius: 12px; display: inline-flex; align-items: center; justify-content: center; background: var(--adm-bg-hover); color: var(--adm-accent); }
  .crm-module-title p, .crm-card-label { margin: 0; color: var(--adm-text-soft); font-size: .7rem; font-weight: 800; letter-spacing: .1em; text-transform: uppercase; }
  .crm-module-title h2 { margin: .15rem 0 0; font-size: 1.45rem; letter-spacing: -.02em; }
  .crm-module-desc { margin: 0; color: var(--adm-text-muted); max-width: 880px; line-height: 1.6; }
  .crm-actions { display: flex; flex-wrap: wrap; gap: .55rem; }
  .crm-btn {
    display: inline-flex; align-items: center; justify-content: center; min-height: 36px;
    padding: .5rem .85rem; border: 1px solid var(--adm-border); border-radius: 10px;
    color: var(--adm-text); text-decoration: none; font-weight: 750; font-size: .82rem;
    background: var(--adm-bg-elev);
  }
  .crm-btn--primary { background: var(--adm-text); color: var(--adm-bg); border-color: var(--adm-text); }
  .crm-grid-3 { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: .8rem; }
  .crm-card { padding: 1rem; }
  .crm-card strong { display: block; margin: .35rem 0; font-size: 1.7rem; }
  .crm-card p, .crm-panel-head p, .crm-empty p, .crm-bot p { margin: .2rem 0 0; color: var(--adm-text-muted); line-height: 1.5; font-size: .84rem; }
  .crm-panel { padding: 1rem; }
  .crm-panel-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; margin-bottom: .8rem; }
  .crm-panel-head h3 { margin: 0; font-size: 1rem; }
  .crm-search-row { display: flex; gap: .45rem; }
  .crm-search-row input { min-width: 240px; border: 1px solid var(--adm-border); border-radius: 10px; padding: .55rem .7rem; background: var(--adm-bg); color: var(--adm-text); }
  .crm-search-row button, .crm-bot-foot button { border: 1px solid var(--adm-border); border-radius: 9px; background: var(--adm-bg); color: var(--adm-text); padding: .5rem .7rem; font-weight: 750; cursor: pointer; }
  .crm-live-toolbar { display: grid; grid-template-columns: 1fr 180px 220px auto; gap: .55rem; margin-bottom: .8rem; }
  .crm-export-fields { display: flex; flex-wrap: wrap; gap: .6rem; margin: 0 0 .8rem; }
  .crm-export-summary {
    align-items: flex-start;
    background: var(--adm-bg);
    border: 1px solid var(--adm-border);
    border-radius: 14px;
    display: grid;
    gap: .18rem;
    margin: 0 0 .8rem;
    padding: .8rem .95rem;
  }
  .crm-export-summary strong {
    color: var(--adm-text);
    font-size: .84rem;
  }
  .crm-export-summary span {
    color: var(--adm-text-muted);
    font-size: .76rem;
  }
  .crm-export-summary code {
    background: color-mix(in srgb, var(--adm-bg-hover) 80%, transparent);
    border: 1px solid var(--adm-border);
    border-radius: 10px;
    color: var(--adm-text-soft);
    display: block;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: .72rem;
    margin-top: .2rem;
    overflow-wrap: anywhere;
    padding: .45rem .55rem;
  }
  .crm-search-history {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: .7rem;
    margin: 0 0 .8rem;
  }
  .crm-search-history strong {
    color: var(--adm-text-muted);
    font-size: .72rem;
    letter-spacing: .04em;
    text-transform: uppercase;
  }
  .crm-search-history-list {
    display: flex;
    flex-wrap: wrap;
    gap: .55rem;
  }
  .crm-search-history-list button {
    align-items: center;
    background: color-mix(in srgb, var(--adm-bg-hover) 76%, transparent);
    border: 1px solid var(--adm-border);
    border-radius: 999px;
    color: var(--adm-text);
    cursor: pointer;
    display: inline-flex;
    font: inherit;
    gap: .45rem;
    padding: .38rem .78rem;
  }
  .crm-search-history-list button:hover {
    border-color: color-mix(in srgb, var(--admin-accent) 35%, var(--adm-border));
    color: var(--admin-accent-strong);
  }
  .crm-search-history-list button[data-active='true'] {
    background: color-mix(in srgb, var(--admin-accent) 12%, var(--adm-bg-hover));
    border-color: color-mix(in srgb, var(--admin-accent) 36%, var(--adm-border));
    color: var(--admin-accent-strong);
  }
  .crm-search-history-remove {
    background: transparent;
    border: 0;
    color: inherit;
    cursor: pointer;
    font: inherit;
    font-size: .95rem;
    line-height: 1;
    padding: 0;
  }
  .crm-search-history-clear {
    background: transparent;
    border: 1px solid var(--adm-border);
    border-radius: 999px;
    color: var(--adm-text-muted);
    cursor: pointer;
    font: inherit;
    margin-left: auto;
    padding: .38rem .78rem;
  }
  .crm-search-history-clear:hover {
    border-color: color-mix(in srgb, #d66a5a 45%, var(--adm-border));
    color: #d66a5a;
  }
  .crm-export-preset {
    align-items: center;
    background: color-mix(in srgb, var(--admin-accent) 8%, var(--admin-panel));
    border: 1px solid var(--admin-border);
    border-radius: 999px;
    display: inline-flex;
    gap: .5rem;
    padding: .45rem .75rem;
  }
  .crm-export-mode {
    align-items: center;
    background: var(--adm-bg);
    border: 1px solid var(--adm-border);
    border-radius: 999px;
    color: var(--adm-text-muted);
    display: inline-flex;
    gap: .5rem;
    padding: .45rem .75rem;
  }
  .crm-export-mode select {
    background: transparent;
    border: 0;
    color: var(--adm-text);
    font: inherit;
    outline: 0;
  }
  .crm-export-preset select {
    background: transparent;
    border: 0;
    color: var(--admin-text);
    font: inherit;
    outline: 0;
  }
  .crm-export-fields label {
    align-items: center; background: var(--adm-bg); border: 1px solid var(--adm-border); border-radius: 999px;
    color: var(--adm-text-muted); display: inline-flex; font-size: .74rem; font-weight: 800; gap: .35rem; padding: .35rem .65rem;
  }
  .crm-export-move {
    display: inline-flex;
    gap: .2rem;
    margin-left: .1rem;
  }
  .crm-export-move button {
    background: transparent;
    border: 0;
    color: var(--adm-text-soft);
    cursor: pointer;
    font: inherit;
    font-size: .68rem;
    padding: 0 .1rem;
  }
  .crm-live-toolbar input, .crm-live-toolbar select {
    border: 1px solid var(--adm-border); border-radius: 10px; padding: .58rem .7rem;
    background: var(--adm-bg); color: var(--adm-text);
  }
  .crm-live-toolbar button {
    border: 1px solid var(--adm-border); border-radius: 10px; padding: .58rem .8rem;
    background: var(--adm-text); color: var(--adm-bg); font-weight: 800; cursor: pointer;
  }
  .crm-classified-report-grid {
    display: grid;
    gap: .7rem;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    margin: 0 0 .85rem;
  }
  .crm-classified-report-grid button {
    background: var(--adm-bg);
    border: 1px solid var(--adm-border);
    border-radius: 14px;
    cursor: pointer;
    font: inherit;
    text-align: left;
    padding: .85rem .95rem;
  }
  .crm-classified-report-grid button[data-active='true'] {
    background: color-mix(in srgb, var(--adm-accent) 12%, var(--adm-bg));
    border-color: color-mix(in srgb, var(--adm-accent) 30%, var(--adm-border));
  }
  .crm-classified-report-grid strong {
    color: var(--adm-text);
    display: block;
    font-size: 1rem;
    font-weight: 900;
  }
  .crm-classified-report-grid span {
    color: var(--adm-text-muted);
    font-size: .76rem;
  }
  .crm-live-table td strong { display: block; max-width: 280px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .crm-live-table td small { display: block; color: var(--adm-text-soft); margin-top: .12rem; }
  .crm-live-table th small {
    color: var(--adm-text-soft);
