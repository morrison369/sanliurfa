---
/**
 * AdmStatGrid — admin sayfaları için color-coded stat cards.
 *
 * Kullanım:
 *   <AdmStatGrid stats={[
 *     { label: 'Toplam', value: 533, icon: 'lucide:store', color: 'indigo', href: '/admin/places' },
 *     { label: 'Aktif', value: 510, icon: 'lucide:check', color: 'emerald' },
 *   ]} />
 */
import { Icon } from 'astro-icon/components';

interface StatItem {
 label: string;
 value: number | string;
 icon?: string;
 color?: 'indigo' | 'emerald' | 'amber' | 'rose' | 'sky' | 'violet' | 'teal' | 'slate';
 href?: string;
 detail?: string;
 delta?: { value: string; positive?: boolean | null };
}

interface Props {
 stats: StatItem[];
 cols?: number;
}

const { stats } = Astro.props;
---

<div class="adm-stat-grid">
 {stats.map((s, idx) => {
  const inner = (
   <>
    <div class="adm-stat-bg" aria-hidden="true"></div>
    <div class="adm-stat-row">
     {s.icon && <span class="adm-stat-icon"><Icon name={s.icon} class="w-5 h-5" /></span>}
     {s.delta && s.delta.positive !== null && s.delta.positive !== undefined && (
      <span class:list={['adm-stat-delta', s.delta.positive === false && 'adm-stat-delta--down']}>
       <Icon name={s.delta.positive ? 'lucide:trending-up' : 'lucide:trending-down'} class="w-3 h-3" />
       {s.delta.value}
      </span>
     )}
    </div>
    <p class="adm-stat-val">
     {typeof s.value === 'number' ? s.value.toLocaleString('tr-TR') : s.value}
    </p>
    <p class="adm-stat-lbl">{s.label}</p>
    {s.detail && <p class="adm-stat-detail">{s.detail}</p>}
   </>
  );
  const classes = ['adm-stat-card', `adm-stat-card--${s.color || 'indigo'}`];
  if (s.href) {
   return <a href={s.href} class:list={classes} style={`animation-delay: ${idx * 0.06}s`}>{inner}</a>;
  }
  return <div class:list={classes} style={`animation-delay: ${idx * 0.06}s`}>{inner}</div>;
 })}
</div>

<style is:global>
 .adm-stat-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 1rem;
 }
 .adm-stat-card {
  position: relative;
  background: var(--adm-bg-elev);
  border: 1px solid var(--adm-border);
  border-radius: 14px;
  padding: 1.2rem 1.3rem;
  text-decoration: none;
  color: var(--adm-text);
  overflow: hidden;
  display: flex; flex-direction: column;
  transition: transform 0.18s, box-shadow 0.18s, border-color 0.18s;
  opacity: 0;
  animation: admStatIn 0.4s ease-out forwards;
 }
 @keyframes admStatIn {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
 }
 a.adm-stat-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 12px 32px -8px rgba(31,20,16,0.12);
  border-color: var(--stat-c-accent);
 }
 .adm-stat-bg {
  position: absolute; inset: 0; pointer-events: none;
  background: radial-gradient(circle at 100% 0%, var(--stat-c-accent) 0%, transparent 55%);
  opacity: 0.06;
 }
 .adm-stat-row {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 0.75rem;
  position: relative;
 }
 .adm-stat-icon {
  width: 40px; height: 40px; border-radius: 11px;
  background: var(--stat-c-soft);
  color: var(--stat-c-accent);
  display: inline-flex; align-items: center; justify-content: center;
 }
 .adm-stat-delta {
  display: inline-flex; align-items: center; gap: 0.22rem;
  font-size: 0.72rem; font-weight: 700;
  padding: 0.2rem 0.5rem; border-radius: 999px;
  background: rgba(16,185,129,0.12); color: rgb(5,150,105);
 }
 .adm-stat-delta--down { background: rgba(225,29,72,0.12); color: rgb(190,18,60); }
 .adm-stat-val {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2.25rem; font-weight: 700;
  margin: 0; line-height: 1;
  color: var(--adm-text);
  letter-spacing: -0.02em;
  position: relative;
 }
 .adm-stat-lbl {
  margin: 0.4rem 0 0; font-size: 0.84rem; font-weight: 600;
  color: var(--adm-text-muted);
  position: relative;
 }
 .adm-stat-detail {
  margin: 0.25rem 0 0; font-size: 0.72rem;
  color: var(--adm-text-soft);
  position: relative;
 }
 .adm-stat-card--indigo { --stat-c-accent: rgb(99,102,241); --stat-c-soft: rgba(99,102,241,0.12); }
 .adm-stat-card--emerald { --stat-c-accent: rgb(16,185,129); --stat-c-soft: rgba(16,185,129,0.12); }
 .adm-stat-card--amber { --stat-c-accent: rgb(217,119,6); --stat-c-soft: rgba(217,119,6,0.12); }
 .adm-stat-card--rose { --stat-c-accent: rgb(225,29,72); --stat-c-soft: rgba(225,29,72,0.10); }
 .adm-stat-card--sky { --stat-c-accent: rgb(2,132,199); --stat-c-soft: rgba(2,132,199,0.12); }
 .adm-stat-card--violet { --stat-c-accent: rgb(139,92,246); --stat-c-soft: rgba(139,92,246,0.12); }
 .adm-stat-card--teal { --stat-c-accent: rgb(13,148,136); --stat-c-soft: rgba(13,148,136,0.12); }
 .adm-stat-card--slate { --stat-c-accent: rgb(100,116,139); --stat-c-soft: rgba(100,116,139,0.12); }
</style>
