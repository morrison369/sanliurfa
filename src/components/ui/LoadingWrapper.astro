---
interface Props {
  containerClass?: string;
  contentClass?: string;
  contentDataAttr?: string;
  loadingClass?: string;
  loadingDataAttr: string;
  message: string;
  spinner?: boolean;
  skeletonCount?: number;
  skeletonItemClass?: string;
  variant?: 'text' | 'spinner' | 'skeleton';
}

const {
  containerClass = '',
  contentClass = 'hidden',
  contentDataAttr,
  loadingClass = '',
  loadingDataAttr,
  message,
  spinner = false,
  skeletonCount = 3,
  skeletonItemClass = 'h-16 animate-pulse rounded-lg bg-gray-200 dark:bg-gray-700',
  variant = spinner ? 'spinner' : 'text',
} = Astro.props;
---

<div class={containerClass}>
  <div data-loading-wrapper-loading {...{ [loadingDataAttr]: '' }} class={loadingClass}>
    {
      variant === 'spinner' ? (
        <>
          <div class="h-12 w-12 animate-spin rounded-full border-b-2 border-blue-600"></div>
          <span class="sr-only">{message}</span>
        </>
      ) : variant === 'skeleton' ? (
        <>
          <span class="sr-only">{message}</span>
          {Array.from({ length: skeletonCount }).map(() => (
            <div class={skeletonItemClass}></div>
          ))}
        </>
      ) : (
        message
      )
    }
  </div>
  <div data-loading-wrapper-content {...(contentDataAttr ? { [contentDataAttr]: '' } : {})} class={contentClass}></div>
</div>
