---
import { actions, isInputError } from 'astro:actions';

interface Props {
  placeId: string;
  placeName: string;
}

const { placeId, placeName } = Astro.props;
const reviewResult = Astro.getActionResult(actions.submitPlaceReview);
const reviewInputErrors = isInputError(reviewResult?.error) ? reviewResult.error.fields : {};
const reviewSubmitError =
  !isInputError(reviewResult?.error) && reviewResult?.error?.message
    ? reviewResult.error.message
    : null;
---

<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" data-review-form>
  <h3 class="text-lg font-semibold text-gray-900 mb-4">Değerlendirme Yaz</h3>

  {reviewResult?.data?.success && (
    <div class="mb-4 rounded-lg border border-green-200 bg-green-50 p-3 text-sm text-green-700">
      Yorumunuz alındı. {reviewResult.data.pointsEarned > 0 ? `+${reviewResult.data.pointsEarned} puan kazandınız.` : 'Onaylandıktan sonra yayınlanacaktır.'}
    </div>
  )}

  {reviewSubmitError && (
    <div class="mb-4 rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700">
      {reviewSubmitError}
    </div>
  )}
  
  <form action={actions.submitPlaceReview} method="POST" class="space-y-4">
    <input type="hidden" name="placeId" value={placeId} />
    <!-- Rating -->
    <div>
      <label class="label block mb-2">Puanınız</label>
      <div class="flex items-center gap-2" data-rating-input>
        {[1, 2, 3, 4, 5].map((star) => (
          <button
            type="button"
            data-rating={star}
            class="text-3xl text-gray-300 hover:text-yellow-400 transition-colors focus:outline-none"
          >
            ★
          </button>
        ))}
      </div>
      <input type="hidden" name="rating" data-rating-value required />
      {reviewInputErrors.rating && (
        <p class="mt-2 text-sm text-red-600">{reviewInputErrors.rating.join(', ')}</p>
      )}
    </div>
    
    <!-- Title -->
    <div>
      <label for="review-title" class="label block mb-1">Başlık (Opsiyonel)</label>
      <input
        type="text"
        id="review-title"
        name="title"
        class="input"
        placeholder="Örn: Harika bir deneyim"
      />
      {reviewInputErrors.title && (
        <p class="mt-2 text-sm text-red-600">{reviewInputErrors.title.join(', ')}</p>
      )}
    </div>
    
    <!-- Content -->
    <div>
      <label for="review-content" class="label block mb-1">Yorumunuz *</label>
      <textarea
        id="review-content"
        name="content"
        rows={4}
        class="input resize-none"
        placeholder={`${placeName} hakkında düşüncelerinizi paylaşın...`}
        required
        minlength="10"
      ></textarea>
      {reviewInputErrors.content && (
        <p class="mt-2 text-sm text-red-600">{reviewInputErrors.content.join(', ')}</p>
      )}
      <p class="text-xs text-gray-500 mt-1">En az 10 karakter</p>
    </div>
    
    <!-- Visit Date -->
    <div>
      <label for="visit-date" class="label block mb-1">Ziyaret Tarihi</label>
      <input
        type="date"
        id="visit-date"
        name="visitDate"
        class="input"
        max={new Date().toISOString().split('T')[0]}
      />
    </div>
    
    <!-- Submit -->
    <div class="flex items-center justify-between pt-4">
      <p class="text-sm text-gray-500">
        <span class="text-yellow-500">+50 puan</span> kazanacaksınız
      </p>
      <button type="submit" class="btn-primary">
        Gönder
      </button>
    </div>
  </form>
</div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.querySelector('[data-review-form]');
    if (!form) return;
    
    const ratingInput = form.querySelector('[data-rating-input]');
    const ratingValue = form.querySelector('[data-rating-value]');
    const stars = form.querySelectorAll('[data-rating]');
    let selectedRating = 0;
    
    // Rating selection
    stars.forEach((star) => {
      star.addEventListener('click', () => {
        const rating = parseInt(star.getAttribute('data-rating') || '0');
        selectedRating = rating;
        ratingValue.value = String(rating);
        
        stars.forEach((s, i) => {
          if (i < rating) {
            s.classList.add('text-yellow-400');
            s.classList.remove('text-gray-300');
          } else {
            s.classList.remove('text-yellow-400');
            s.classList.add('text-gray-300');
          }
        });
      });
      
      // Hover effect
      star.addEventListener('mouseenter', () => {
        const rating = parseInt(star.getAttribute('data-rating') || '0');
        stars.forEach((s, i) => {
          if (i < rating) {
            s.classList.add('text-yellow-200');
          } else {
            s.classList.remove('text-yellow-200');
          }
        });
      });
    });
    
    ratingInput?.addEventListener('mouseleave', () => {
      stars.forEach((s, i) => {
        s.classList.remove('text-yellow-200');
        if (i < selectedRating) {
          s.classList.add('text-yellow-400');
        } else {
          s.classList.add('text-gray-300');
        }
      });
    });
    
  });
</script>



