---
interface Props {
  currentUserId?: string;
}

const { currentUserId } = Astro.props;
---

<div data-user-search-results data-current-user-id={currentUserId || ''}>
  <div data-user-search-content>
    <div class="text-center py-16">
      <p class="mb-4 text-4xl">🔍</p>
      <p class="text-lg text-gray-600 dark:text-gray-400">
        Kullanıcı aramak için arama kutusunu kullanın.
      </p>
      <p class="mt-2 text-sm text-gray-500 dark:text-gray-500">En az 2 karakter girin.</p>
    </div>
  </div>
</div>

<script>
  import { initUserSearchResults } from '../scripts/user-search-results';

  initUserSearchResults();
</script>
