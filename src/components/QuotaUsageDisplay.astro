---
interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<div
  class="space-y-4"
  data-quota-usage-display
  data-compact={compact ? 'true' : 'false'}
>
  <div data-quota-loading class="space-y-3">
    <div class="h-12 animate-pulse rounded-lg bg-gray-200 dark:bg-gray-700"></div>
    <div class="h-12 animate-pulse rounded-lg bg-gray-200 dark:bg-gray-700"></div>
    <div class="h-12 animate-pulse rounded-lg bg-gray-200 dark:bg-gray-700"></div>
  </div>
  <div data-quota-content class="hidden"></div>
</div>

<script>
  import { initQuotaUsageDisplays } from '../scripts/quota-usage-display';

  initQuotaUsageDisplays();
</script>
